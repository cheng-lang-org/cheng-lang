fn CompilerCsgCloneStrSeq(items: str[]): str[] =
    var out: str[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn CompilerCsgCloneInt32Seq(items: int32[]): int32[] =
    var out: int32[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn CompilerLegacySourceUnitClone(unit: CompilerLegacySourceUnit): CompilerLegacySourceUnit =
    var out: CompilerLegacySourceUnit
    out.sourcePath = unit.sourcePath
    out.modulePath = unit.modulePath
    out.legacyText = unit.legacyText
    out.migratedText = unit.migratedText
    return out

fn CompilerLegacySourceUnitsClone(units: CompilerLegacySourceUnit[]): CompilerLegacySourceUnit[] =
    var out: CompilerLegacySourceUnit[]
    for i in 0..<units.len:
        add(out, CompilerLegacySourceUnitClone(units[i]))
    return out

fn CompilerCsgCloneNode(node: CompilerCsgNode): CompilerCsgNode =
    var out: CompilerCsgNode
    out.nodeId = node.nodeId
    out.nodeKind = node.nodeKind
    out.ownerNodeId = node.ownerNodeId
    out.modulePath = node.modulePath
    out.symbolText = node.symbolText
    out.factText = node.factText
    out.resultLayoutKind = node.resultLayoutKind
    out.effectKind = node.effectKind
    out.capabilityKind = node.capabilityKind
    out.callConv = node.callConv
    out.entryFlag = node.entryFlag
    out.exportedFlag = node.exportedFlag
    out.exportSymbolName = node.exportSymbolName
    out.factCid = node.factCid
    return out

fn CompilerCsgCloneNodes(nodes: CompilerCsgNode[]): CompilerCsgNode[] =
    var out: CompilerCsgNode[]
    for i in 0..<nodes.len:
        add(out, CompilerCsgCloneNode(nodes[i]))
    return out

fn CompilerCsgCloneEdge(edge: CompilerCsgEdge): CompilerCsgEdge =
    var out: CompilerCsgEdge
    out.edgeId = edge.edgeId
    out.fromNodeId = edge.fromNodeId
    out.toNodeId = edge.toNodeId
    out.edgeKind = edge.edgeKind
    out.edgeCid = edge.edgeCid
    return out

fn CompilerCsgCloneEdges(edges: CompilerCsgEdge[]): CompilerCsgEdge[] =
    var out: CompilerCsgEdge[]
    for i in 0..<edges.len:
        add(out, CompilerCsgCloneEdge(edges[i]))
    return out

fn CompilerCsgClone(csg: CompilerCsg): CompilerCsg =
    var out: CompilerCsg
    out.version = csg.version
    out.packageId = csg.packageId
    out.sourceBundleCid = csg.sourceBundleCid
    out.exprLayer = parser.NormalizedExprLayerClone(csg.exprLayer)
    out.typedExprFacts = texpr.TypedExprFactsClone(csg.typedExprFacts)
    out.typedIr = texpr.TypedExprIrClone(csg.typedIr)
    out.nodeCount = csg.nodeCount
    out.edgeCount = csg.edgeCount
    out.nodes = CompilerCsgCloneNodes(csg.nodes)
    out.edges = CompilerCsgCloneEdges(csg.edges)
    out.canonicalGraphCid = csg.canonicalGraphCid
    out.graphCid = csg.graphCid
    return out

fn CompilerExportSurfaceClone(surface: CsgExportSurface): CsgExportSurface =
    var out: CsgExportSurface
    out.version = surface.version
    out.packageId = surface.packageId
    out.exportedSymbolCount = surface.exportedSymbolCount
    out.exportedSymbols = CompilerCsgCloneStrSeq(surface.exportedSymbols)
    out.exportedTargetNames = CompilerCsgCloneStrSeq(surface.exportedTargetNames)
    out.exportedLayouts = CompilerCsgCloneInt32Seq(surface.exportedLayouts)
    out.exportedEffects = CompilerCsgCloneInt32Seq(surface.exportedEffects)
    out.exportedCapabilities = CompilerCsgCloneInt32Seq(surface.exportedCapabilities)
    out.surfaceCid = surface.surfaceCid
    return out

fn CompilerLegacyMigrationClone(migration: CompilerLegacyMigration): CompilerLegacyMigration =
    var out: CompilerLegacyMigration
    out.version = migration.version
    out.packageId = migration.packageId
    out.entrySourcePath = migration.entrySourcePath
    out.entryModulePath = migration.entryModulePath
    out.unitCount = migration.unitCount
    out.units = CompilerLegacySourceUnitsClone(migration.units)
    out.appliedRuleCount = migration.appliedRuleCount
    out.appliedRules = CompilerCsgCloneStrSeq(migration.appliedRules)
    out.legacySourceBundleCid = migration.legacySourceBundleCid
    out.migratedSourceBundleCid = migration.migratedSourceBundleCid
    out.compilerCsg = CompilerCsgClone(migration.compilerCsg)
    out.exportSurface = CompilerExportSurfaceClone(migration.exportSurface)
    out.migrationCid = migration.migrationCid
    return out

fn CompilerCsgAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn CompilerCsgAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(value))

fn CompilerCsgAppendText(buf: var layout.ByteBuf, text: str) =
    CompilerCsgAppendU32BE(buf, text.len)
    for i in 0..<text.len:
        layout.ByteBufAppendByte(buf, text[i])

fn CompilerCsgBufCid(buf: var layout.ByteBuf): layout.FixedBytes32 =
    let data = layout.ByteBufToBytes(buf)
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(data))

fn CompilerCsgHashNode(nodeKind: int32,
                         ownerNodeId: int32,
                         modulePath: str,
                         symbolText: str,
                         factText: str,
                         resultLayoutKind: int32,
                         effectKind: int32,
                         capabilityKind: int32,
                         callConv: int32,
                         entryFlag: int32,
                         exportedFlag: int32,
                         exportSymbolName: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.node")
    CompilerCsgAppendU32BE(buf, nodeKind)
    CompilerCsgAppendU32BE(buf, ownerNodeId)
    CompilerCsgAppendText(buf, modulePath)
    CompilerCsgAppendText(buf, symbolText)
    CompilerCsgAppendText(buf, factText)
    CompilerCsgAppendU32BE(buf, resultLayoutKind)
    CompilerCsgAppendU32BE(buf, effectKind)
    CompilerCsgAppendU32BE(buf, capabilityKind)
    CompilerCsgAppendU32BE(buf, callConv)
    CompilerCsgAppendU32BE(buf, entryFlag)
    CompilerCsgAppendU32BE(buf, exportedFlag)
    CompilerCsgAppendText(buf, exportSymbolName)
    return CompilerCsgBufCid(buf)

fn CompilerCsgHashEdge(fromNodeId: int32,
                         toNodeId: int32,
                         edgeKind: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.edge")
    CompilerCsgAppendU32BE(buf, fromNodeId)
    CompilerCsgAppendU32BE(buf, toNodeId)
    CompilerCsgAppendU32BE(buf, edgeKind)
    return CompilerCsgBufCid(buf)

fn CompilerCsgGraphCid(packageId: str,
                         sourceBundleCid: layout.FixedBytes32,
                         workspaceRoot: str,
                         packageRoot: str,
                         externalPackageRoots: parser.ParserExternalPackageRoot[],
                         overrides: CompilerCsgSourceText[],
                         exprLayer: parser.NormalizedExprLayer,
                         typedExprFacts: TypedExprFact[],
                         nodes: CompilerCsgNode[],
                         edges: CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.graph")
    CompilerCsgAppendText(buf, packageId)
    CompilerCsgAppendFixed32(buf, sourceBundleCid)
    let _ = workspaceRoot
    let _ = packageRoot
    let _ = externalPackageRoots
    let _ = overrides
    CompilerCsgAppendU32BE(buf, exprLayer.sourceCount)
    CompilerCsgAppendU32BE(buf, exprLayer.exprs.len)
    CompilerCsgAppendU32BE(buf, exprLayer.questionResidualCount)
    CompilerCsgAppendU32BE(buf, typedExprFacts.len)
    CompilerCsgAppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let node = nodes[i]
        CompilerCsgAppendU32BE(buf, node.nodeId)
        CompilerCsgAppendFixed32(buf, node.factCid)
    CompilerCsgAppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let edge = edges[i]
        CompilerCsgAppendU32BE(buf, edge.edgeId)
        CompilerCsgAppendFixed32(buf, edge.edgeCid)
    return CompilerCsgBufCid(buf)

fn CompilerCsgCanonicalGraphCid(packageId: str,
                                  sourceBundleCid: layout.FixedBytes32,
                                  workspaceRoot: str,
                                  packageRoot: str,
                                  externalPackageRoots: parser.ParserExternalPackageRoot[],
                                  overrides: CompilerCsgSourceText[],
                                  exprLayer: parser.NormalizedExprLayer,
                                  typedExprFacts: TypedExprFact[],
                                  nodes: CompilerCsgNode[],
                                  edges: CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.canonical_graph")
    CompilerCsgAppendText(buf, packageId)
    let _ = sourceBundleCid
    let _ = workspaceRoot
    let _ = packageRoot
    let _ = externalPackageRoots
    let _ = overrides
    let _ = exprLayer
    let _ = typedExprFacts
    CompilerCsgAppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let node = nodes[i]
        CompilerCsgAppendU32BE(buf, node.nodeId)
        CompilerCsgAppendFixed32(buf, node.factCid)
    CompilerCsgAppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let edge = edges[i]
        CompilerCsgAppendU32BE(buf, edge.edgeId)
        CompilerCsgAppendFixed32(buf, edge.edgeCid)
    return CompilerCsgBufCid(buf)

fn CompilerCsgAddUnique(items: var str[],
                          text: str) =
    for i in 0..<items.len:
        if items[i] == text:
            return
    add(items, text)

fn CompilerCsgTextSetInit(minCap: int32): CompilerCsgTextSet =
    var out: CompilerCsgTextSet
    out.lookup = parser.ParserTextLookupInit(minCap)
    return out

fn CompilerCsgTextSetInsert(seen: var CompilerCsgTextSet,
                              text: str): bool =
    if text == "":
        if seen.emptySeen:
            return false
        seen.emptySeen = true
        return true
    return parser.ParserTextLookupInsertExact(seen.lookup, text)

fn CompilerCsgAddUniqueFast(items: var str[],
                              seen: var CompilerCsgTextSet,
                              text: str) =
    if CompilerCsgTextSetInsert(seen, text):
        add(items, text)

fn CompilerCsgStrLess(left: str,
                        right: str): bool =
    if left == right:
        return false
    let leftLen = left.len
    let rightLen = right.len
    let sharedLen = leftLen < rightLen ? leftLen : rightLen
    for i in 0..<sharedLen:
        if left[i] == right[i]:
            continue
        return left[i] < right[i]
    return leftLen < rightLen

fn CompilerCsgSortStrs(items: var str[]) =
    if items.len <= 1:
        return
    let count = items.len
    var scratch: str[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(scratch, items[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortStrsPass(scratch, items, width)
        else:
            CompilerCsgMergeSortStrsPass(items, scratch, width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            items[i] = scratch[i]

fn CompilerCsgMergeSortStrsPass(src: var str[],
                                  dst: var str[],
                                  width: int32) =
    let count = src.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid && (right >= rightEnd || !CompilerCsgStrLess(src[right], src[left])):
                dst[outIndex] = src[left]
                left = left + 1
            else:
                dst[outIndex] = src[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgSourcePathModulePairLess(leftSource: str,
                                         leftModule: str,
                                         rightSource: str,
                                         rightModule: str): bool =
    if leftModule != rightModule:
        return CompilerCsgStrLess(leftModule, rightModule)
    return CompilerCsgStrLess(leftSource, rightSource)

fn CompilerCsgSortSourcePathModulePairs(sources: var str[],
                                         modules: var str[]) =
    if sources.len <= 1:
        return
    let count = sources.len
    var sourceScratch: str[]
    var moduleScratch: str[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(sourceScratch, sources[i])
        add(moduleScratch, modules[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortSourcePathModulePairsPass(sourceScratch,
                                                           moduleScratch,
                                                           sources,
                                                           modules,
                                                           width)
        else:
            CompilerCsgMergeSortSourcePathModulePairsPass(sources,
                                                           modules,
                                                           sourceScratch,
                                                           moduleScratch,
                                                           width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            sources[i] = sourceScratch[i]
            modules[i] = moduleScratch[i]

fn CompilerCsgMergeSortSourcePathModulePairsPass(srcSources: var str[],
                                                   srcModules: var str[],
                                                   dstSources: var str[],
                                                   dstModules: var str[],
                                                   width: int32) =
    let count = srcSources.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid &&
               (right >= rightEnd ||
                !CompilerCsgSourcePathModulePairLess(srcSources[right],
                                                     srcModules[right],
                                                     srcSources[left],
                                                     srcModules[left])):
                dstSources[outIndex] = srcSources[left]
                dstModules[outIndex] = srcModules[left]
                left = left + 1
            else:
                dstSources[outIndex] = srcSources[right]
                dstModules[outIndex] = srcModules[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgAddUniqueImportPair(pairs: var CompilerCsgImportPair[],
                                    ownerModulePath: str,
                                    targetModulePath: str) =
    for i in 0..<pairs.len:
        if pairs[i].ownerModulePath != ownerModulePath:
            continue
        if pairs[i].targetModulePath != targetModulePath:
            continue
        return
    add(pairs, CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                       targetModulePath: targetModulePath))

fn CompilerCsgTextHash(text: str): int32 =
    var h: int32
    for i in 0..<text.len:
        h = h * 131 + Int32(text[i])
    if h < 0:
        h = -h
    return h

fn CompilerCsgTextFirstCode(text: str): int32 =
    if text.len <= 0:
        return 0
    return Int32(text[0])

fn CompilerCsgTextLastCode(text: str): int32 =
    if text.len <= 0:
        return 0
    return Int32(text[text.len - 1])

fn CompilerCsgImportPairLookupInit(minCap: int32): CompilerCsgImportPairLookup =
    var lookup: CompilerCsgImportPairLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    for i in 0..<cap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(lookup.slots, 0)
    return lookup

fn CompilerCsgImportPairLookupHash(ownerLen: int32,
                                     ownerFirstCode: int32,
                                     ownerLastCode: int32,
                                     ownerHash: int32,
                                     targetLen: int32,
                                     targetFirstCode: int32,
                                     targetLastCode: int32,
                                     targetHash: int32): int64 =
    var h: int64 = Int64(ownerHash)
    h = h * 131 + Int64(ownerLen)
    h = h * 131 + Int64(ownerFirstCode)
    h = h * 131 + Int64(ownerLastCode)
    h = h * 131 + Int64(targetHash)
    h = h * 131 + Int64(targetLen)
    h = h * 131 + Int64(targetFirstCode)
    h = h * 131 + Int64(targetLastCode)
    if h < 0:
        h = -h
    return h

fn CompilerCsgImportPairLookupSlotForParts(lookup: CompilerCsgImportPairLookup,
                                             ownerLen: int32,
                                             ownerFirstCode: int32,
                                             ownerLastCode: int32,
                                             ownerHash: int32,
                                             targetLen: int32,
                                             targetFirstCode: int32,
                                             targetLastCode: int32,
                                             targetHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = Int32(CompilerCsgImportPairLookupHash(ownerLen,
                                                               ownerFirstCode,
                                                               ownerLastCode,
                                                               ownerHash,
                                                               targetLen,
                                                               targetFirstCode,
                                                               targetLastCode,
                                                               targetHash) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucketIndex = bucketIndexPlus1 - 1
        if lookup.buckets[bucketIndex].ownerLen == ownerLen &&
           lookup.buckets[bucketIndex].ownerFirstCode == ownerFirstCode &&
           lookup.buckets[bucketIndex].ownerLastCode == ownerLastCode &&
           lookup.buckets[bucketIndex].ownerHash == ownerHash &&
           lookup.buckets[bucketIndex].targetLen == targetLen &&
           lookup.buckets[bucketIndex].targetFirstCode == targetFirstCode &&
           lookup.buckets[bucketIndex].targetLastCode == targetLastCode &&
           lookup.buckets[bucketIndex].targetHash == targetHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn CompilerCsgImportPairLookupRehash(lookup: var CompilerCsgImportPairLookup,
                                       newCap: int32) =
    var slots: int32[]
    for i in 0..<newCap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(slots, 0)
    lookup.slots = slots
    for bucketIndex in 0..<lookup.buckets.len:
        if bucketIndex % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let slot = CompilerCsgImportPairLookupSlotForParts(lookup,
                                                            lookup.buckets[bucketIndex].ownerLen,
                                                            lookup.buckets[bucketIndex].ownerFirstCode,
                                                            lookup.buckets[bucketIndex].ownerLastCode,
                                                            lookup.buckets[bucketIndex].ownerHash,
                                                            lookup.buckets[bucketIndex].targetLen,
                                                            lookup.buckets[bucketIndex].targetFirstCode,
                                                            lookup.buckets[bucketIndex].targetLastCode,
                                                            lookup.buckets[bucketIndex].targetHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1

fn CompilerCsgImportPairLookupGrow(lookup: var CompilerCsgImportPairLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    CompilerCsgImportPairLookupRehash(lookup, nextCap)

fn CompilerCsgImportPairLookupEnsureBucket(lookup: var CompilerCsgImportPairLookup,
                                             ownerModulePath: str,
                                             targetModulePath: str): int32 =
    if lookup.slots.len <= 0:
        lookup = CompilerCsgImportPairLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        CompilerCsgImportPairLookupGrow(lookup)
    let ownerLen = ownerModulePath.len
    let ownerFirstCode = CompilerCsgTextFirstCode(ownerModulePath)
    let ownerLastCode = CompilerCsgTextLastCode(ownerModulePath)
    let ownerHash = CompilerCsgTextHash(ownerModulePath)
    let targetLen = targetModulePath.len
    let targetFirstCode = CompilerCsgTextFirstCode(targetModulePath)
    let targetLastCode = CompilerCsgTextLastCode(targetModulePath)
    let targetHash = CompilerCsgTextHash(targetModulePath)
    let slot = CompilerCsgImportPairLookupSlotForParts(lookup,
                                                        ownerLen,
                                                        ownerFirstCode,
                                                        ownerLastCode,
                                                        ownerHash,
                                                        targetLen,
                                                        targetFirstCode,
                                                        targetLastCode,
                                                        targetHash)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: CompilerCsgImportPairLookupBucket
    bucket.ownerLen = ownerLen
    bucket.ownerFirstCode = ownerFirstCode
    bucket.ownerLastCode = ownerLastCode
    bucket.ownerHash = ownerHash
    bucket.targetLen = targetLen
    bucket.targetFirstCode = targetFirstCode
    bucket.targetLastCode = targetLastCode
    bucket.targetHash = targetHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn CompilerCsgImportPairLookupInsert(lookup: var CompilerCsgImportPairLookup,
                                       ownerModulePath: str,
                                       targetModulePath: str): bool =
    let bucketIndex = CompilerCsgImportPairLookupEnsureBucket(lookup,
                                                               ownerModulePath,
                                                               targetModulePath)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        let item = lookup.buckets[bucketIndex].items[i]
        if item.ownerModulePath == ownerModulePath &&
           item.targetModulePath == targetModulePath:
            return false
    add(lookup.buckets[bucketIndex].items,
        CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                targetModulePath: targetModulePath))
    return true

fn CompilerCsgAddUniqueImportPairFast(pairs: var CompilerCsgImportPair[],
                                        seen: var CompilerCsgImportPairLookup,
                                        ownerModulePath: str,
                                        targetModulePath: str) =
    if CompilerCsgImportPairLookupInsert(seen,
                                          ownerModulePath,
                                          targetModulePath):
        add(pairs, CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                           targetModulePath: targetModulePath))

fn CompilerCsgImportPairLess(left: CompilerCsgImportPair,
                               right: CompilerCsgImportPair): bool =
    if left.ownerModulePath != right.ownerModulePath:
        return CompilerCsgStrLess(left.ownerModulePath, right.ownerModulePath)
    return CompilerCsgStrLess(left.targetModulePath, right.targetModulePath)

fn CompilerCsgSortImportPairs(pairs: var CompilerCsgImportPair[]) =
    if pairs.len <= 1:
        return
    let count = pairs.len
    var scratch: CompilerCsgImportPair[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(scratch, pairs[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortImportPairsPass(scratch, pairs, width)
        else:
            CompilerCsgMergeSortImportPairsPass(pairs, scratch, width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            pairs[i] = scratch[i]

fn CompilerCsgMergeSortImportPairsPass(src: var CompilerCsgImportPair[],
                                         dst: var CompilerCsgImportPair[],
                                         width: int32) =
    let count = src.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid && (right >= rightEnd || !CompilerCsgImportPairLess(src[right], src[left])):
                dst[outIndex] = src[left]
                left = left + 1
            else:
                dst[outIndex] = src[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgModuleNodeId(nodes: CompilerCsgNode[],
                             modulePath: str): int32 =
    for i in 0..<nodes.len:
        let node = nodes[i]
        if node.nodeKind != CompilerCsgNodeKindModule:
            continue
        if node.modulePath == modulePath:
            return node.nodeId
    return -1

fn CompilerCsgModuleIndex(modules: str[],
                            modulePath: str): int32 =
    var lo: int32
    var hi = modules.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let item = modules[mid]
        if item == modulePath:
            return mid
        if CompilerCsgStrLess(item, modulePath):
            lo = mid + 1
        else:
            hi = mid
    return -1

fn CompilerCsgModuleNodeIdIndexed(modules: str[],
                                    moduleNodeIds: int32[],
                                    modulePath: str): int32 =
    let index = CompilerCsgModuleIndex(modules, modulePath)
    if index < 0 || index >= moduleNodeIds.len:
        return -1
    return moduleNodeIds[index]

fn CompilerCsgSymbolExported(functionName: str,
                               entryFlag: int32): bool =
    let _ = entryFlag
    if functionName.len <= 0:
        return false
    let ch = functionName[0]
    return ch >= 'A' && ch <= 'Z'

fn CompilerCsgFindText(text: str,
                         needle: str): int32 =
    if needle.len <= 0:
        return 0
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn CompilerCsgTargetExportName(symbolText: str,
                                 explicitExportName: str,
                                 functionName: str): str =
    if explicitExportName.len > 0:
        return explicitExportName
    if functionName.len > 0:
        return functionName
    let suffixPos = CompilerCsgFindText(symbolText, "::")
    if suffixPos < 0:
        return symbolText
    return chengpath.TextSlice(symbolText, suffixPos + 2, symbolText.len - (suffixPos + 2))

fn CompilerCsgShouldExportSymbol(emitKind: creq.CompilerEmit,
                                   entrySourceFlag: bool,
                                   entryHasExplicitExports: bool,
                                   explicitExportName: str,
                                   functionName: str,
                                   entryFlag: int32): bool =
    if emitKind != creq.EmitShared && emitKind != creq.EmitObj:
        if explicitExportName.len > 0:
            return true
        return CompilerCsgSymbolExported(functionName, entryFlag)
    if !entrySourceFlag:
        return false
    if entryHasExplicitExports:
        return explicitExportName.len > 0
    return true

fn CompilerCsgSourceTextLookup(overrides: CompilerCsgSourceText[],
                                 sourcePath: str,
                                 out: var str): bool =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        out = overrides[i].text
        return true
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    for i in 0..<overrides.len:
        let overrideSourcePath = parser.ParserNormalizePath(overrides[i].sourcePath)
        if overrideSourcePath != normalizedSourcePath:
            continue
        out = overrides[i].text
        return true
    return false

fn CompilerCsgRestoreSourceTextOverrides(overrides: CompilerCsgSourceText[],
                                           sourceTexts: var TypedExprSourceText[]) =
    for i in 0..<sourceTexts.len:
        var sourceText = sourceTexts[i]
        var overrideText = ""
        if !CompilerCsgSourceTextLookup(overrides, sourceText.sourcePath, overrideText):
            continue
        sourceText.text = overrideText
        sourceTexts[i] = sourceText

fn CompilerCsgSourceModulePath(workspaceRoot: str,
                                 packageRoot: str,
                                 externalPackageRoots: parser.ParserExternalPackageRoot[],
                                 overrides: CompilerCsgSourceText[],
                                 sourcePath: str): str =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        if overrides[i].modulePath.len > 0:
            return overrides[i].modulePath
    return parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                         packageRoot,
                                                                         externalPackageRoots,
                                                                         sourcePath)

fn CompilerCsgIsBrowserAbiSupportModule(modulePath: str): bool =
    if modulePath == browsercodec.BrowserContentCodecModulePath():
        return true
    if modulePath == "cheng/libp2p/browser/browser_content_codec_codegen":
        return true
    if modulePath == "cheng/libp2p/browser/browser_content_codec_rule_schema":
        return true
    if modulePath == browserprobe.BrowserHostProbeModulePath():
        return true
    if modulePath == "cheng/libp2p/browser/browser_host_probe_codegen":
        return true
    if modulePath == "cheng/libp2p/browser/browser_host_probe_rule_schema":
        return true
    return modulePath == "cheng/core/lang/browser_abi_rule"

fn CompilerCsgAddBrowserAbiRulesForSource(rules: var BrowserAbiRule[],
                                            linkPlan: slplan.SystemLinkPlanStub,
                                            ownerModulePath: str,
                                            sourcePath: str) =
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    let normalizedEntryPath = parser.ParserNormalizePath(linkPlan.entryPath)
    if normalizedSourcePath == normalizedEntryPath:
        if ownerModulePath == browsercodec.BrowserContentCodecModulePath():
            let codecRules = browsercodec.BrowserContentCodecRules(normalizedSourcePath)
            for i in 0..<codecRules.len:
                add(rules, BrowserAbiRuleClone(codecRules[i]))
            return
        if ownerModulePath == browserprobe.BrowserHostProbeModulePath():
            let probeRules = browserprobe.BrowserHostProbeRules(normalizedSourcePath)
            for i in 0..<probeRules.len:
                add(rules, BrowserAbiRuleClone(probeRules[i]))
            return
    if ownerModulePath == browsercodec.BrowserContentCodecModulePath():
        let codecRuleNames = browsercodec.BrowserContentCodecRuleNames()
        for i in 0..<codecRuleNames.len:
            let triggerNames = browsercodec.BrowserContentCodecRuleTriggerNames(codecRuleNames[i])
            var used = false
            for j in 0..<linkPlan.sourceClosurePaths.len:
                let currentSourcePath = parser.ParserNormalizePath(linkPlan.sourceClosurePaths[j])
                if currentSourcePath == normalizedSourcePath:
                    continue
                let currentModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                                       linkPlan.packageRoot,
                                                                                                       externalPackageRoots,
                                                                                                       currentSourcePath)
                if CompilerCsgIsBrowserAbiSupportModule(currentModulePath):
                    continue
                let text = chengpath.ReadTextFile("", currentSourcePath)
                for k in 0..<triggerNames.len:
                    let triggerCall = Fmt"{triggerNames[k]}("
                    if strutil.Contains(text, triggerCall):
                        used = true
                        break
                if used:
                    break
            if used:
                add(rules, browsercodec.BrowserContentCodecRuleByName(normalizedSourcePath,
                                                                        codecRuleNames[i]))
        return
    if ownerModulePath == browserprobe.BrowserHostProbeModulePath():
        let probeRuleNames = browserprobe.BrowserHostProbeRuleNames()
        for i in 0..<probeRuleNames.len:
            let triggerNames = browserprobe.BrowserHostProbeRuleTriggerNames(probeRuleNames[i])
            var used = false
            for j in 0..<linkPlan.sourceClosurePaths.len:
                let currentSourcePath = parser.ParserNormalizePath(linkPlan.sourceClosurePaths[j])
                if currentSourcePath == normalizedSourcePath:
                    continue
                let currentModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                                       linkPlan.packageRoot,
                                                                                                       externalPackageRoots,
                                                                                                       currentSourcePath)
                if CompilerCsgIsBrowserAbiSupportModule(currentModulePath):
                    continue
                let text = chengpath.ReadTextFile("", currentSourcePath)
                for k in 0..<triggerNames.len:
                    let triggerCall = Fmt"{triggerNames[k]}("
                    if strutil.Contains(text, triggerCall):
                        used = true
                        break
                if used:
                    break
            if used:
                add(rules, browserprobe.BrowserHostProbeRuleByName(normalizedSourcePath,
                                                                     probeRuleNames[i]))
        return

fn CompilerBrowserAbiRulesForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiRule[] =
    var out: BrowserAbiRule[]
    var orderedSources: str[]
    var orderedModules: str[]
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let sourcePath = linkPlan.sourceClosurePaths[i]
        add(orderedSources, sourcePath)
        add(orderedModules,
            parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                          linkPlan.packageRoot,
                                                                          externalPackageRoots,
                                                                          sourcePath))
    CompilerCsgSortSourcePathModulePairs(orderedSources, orderedModules)
    for i in 0..<orderedSources.len:
        let sourcePath = orderedSources[i]
        let ownerModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                             linkPlan.packageRoot,
                                                                                             externalPackageRoots,
                                                                                             sourcePath)
        CompilerCsgAddBrowserAbiRulesForSource(out, linkPlan, ownerModulePath, sourcePath)
    return out

fn CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiBridgeSpec[] =
    let rules = CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    return BrowserAbiBridgeSpecsFromRules(rules)

fn CompilerBrowserAbiBridgeSpecsForSource(linkPlan: slplan.SystemLinkPlanStub,
                                            sourcePathRaw: str): BrowserAbiBridgeSpec[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let specs = CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    return BrowserAbiBridgeSpecsForSource(specs, sourcePath)

fn CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiBridgePlan[] =
    let specs = CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    return BrowserAbiBridgePlansFromSpecs(specs)

fn CompilerBrowserAbiBridgePlansForSource(linkPlan: slplan.SystemLinkPlanStub,
                                            sourcePathRaw: str): BrowserAbiBridgePlan[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let plans = CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    return BrowserAbiBridgePlansForSource(plans, sourcePath)

fn CompilerLegacyLineIndentAt(rawLine: str,
                                stop: int32): str =
    let n = rawLine.len
    if stop >= n:
        return rawLine
    for i in stop..<n:
        let code = Int32(rawLine[i])
        if code == 32 || code == 9:
            continue
        return chengpath.TextSlice(rawLine, 0, i)
    return rawLine

fn CompilerLegacyLineIndent(rawLine: str): str =
    return CompilerLegacyLineIndentAt(rawLine, 0)

fn CompilerLegacyFindMatchingBracket(text: str,
                                       openIndex: int32): int32 =
    return CompilerLegacyFindMatchingBracketStep(text, openIndex, 0)

fn CompilerLegacyFindMatchingBracketStep(text: str,
                                           index: int32,
                                           depth: int32): int32 =
    let n = text.len
    var currentDepth = depth
    for i in index..<n:
        let code = Int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            let nextDepth = currentDepth - 1
            if nextDepth == 0:
                return i
            currentDepth = nextDepth
    return -1

fn CompilerLegacyTopLevelComma(text: str): int32 =
    return CompilerLegacyTopLevelCommaStep(text, 0, 0)

fn CompilerLegacyTopLevelCommaStep(text: str,
                                     index: int32,
                                     depth: int32): int32 =
    let n = text.len
    var currentDepth = depth
    for i in index..<n:
        let code = Int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            currentDepth = currentDepth - 1
            continue
        if code == 44 && currentDepth == 0:
            return i
    return -1

fn CompilerLegacyRewriteSeqTypes(textRaw: str,
                                   outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < text.len:
        if i + 4 > text.len:
            break
        if chengpath.TextSlice(text, i, 4) != "seq[":
            i = i + 1
            continue
        let closePos = CompilerLegacyFindMatchingBracket(text, i + 3)
        if closePos <= i + 3:
            i = i + 1
            continue
        let inner = chengpath.TextSlice(text, i + 4, closePos - (i + 4))
        let replacement = strutil.Join([strutil.Strip(inner), "[]"], "")
        let prefix = chengpath.TextSlice(text, 0, i)
        let suffix = chengpath.TextSlice(text, closePos + 1, text.len - (closePos + 1))
        var rewritten = strutil.Join([prefix, replacement], "")
        rewritten = strutil.Join([rewritten, suffix], "")
        text = rewritten
        outAppliedCount = outAppliedCount + 1
        i = i + replacement.len
    return text

fn CompilerLegacyRewriteArrayTypes(textRaw: str,
                                     outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < text.len:
        if i + 6 > text.len:
            break
        if chengpath.TextSlice(text, i, 6) != "array[":
            i = i + 1
            continue
        let closePos = CompilerLegacyFindMatchingBracket(text, i + 5)
        if closePos <= i + 5:
            i = i + 1
            continue
        let inner = chengpath.TextSlice(text, i + 6, closePos - (i + 6))
        let commaPos = CompilerLegacyTopLevelComma(inner)
        if commaPos <= 0:
            i = i + 1
            continue
        let elemText = strutil.Strip(chengpath.TextSlice(inner, 0, commaPos))
        let lenText = strutil.Strip(chengpath.TextSlice(inner, commaPos + 1, inner.len - (commaPos + 1)))
        let replacement = strutil.Join([elemText, "[", lenText, "]"], "")
        let prefix = chengpath.TextSlice(text, 0, i)
        let suffix = chengpath.TextSlice(text, closePos + 1, text.len - (closePos + 1))
        var rewritten = strutil.Join([prefix, replacement], "")
        rewritten = strutil.Join([rewritten, suffix], "")
        text = rewritten
        outAppliedCount = outAppliedCount + 1
        i = i + replacement.len
    return text

fn CompilerLegacyNormalizeText(textRaw: str,
                                 outAppliedRules: var str[],
                                 outAppliedCount: var int32): str =
    outAppliedRules = []
    outAppliedCount = 0
    var text = textRaw
    let elseIfText = strutil.Replace(text, "else if", "elif")
    if elseIfText != text:
        CompilerCsgAddUnique(outAppliedRules, "else_if_to_elif")
        outAppliedCount = outAppliedCount + 1
        text = elseIfText
    let atListText = strutil.Replace(text, "@[]", "[]")
    if atListText != text:
        CompilerCsgAddUnique(outAppliedRules, "at_list_to_list")
        outAppliedCount = outAppliedCount + 1
        text = atListText
    var seqApplied = 0
    text = CompilerLegacyRewriteSeqTypes(text, seqApplied)
    if seqApplied > 0:
        CompilerCsgAddUnique(outAppliedRules, "seq_type_to_suffix")
        outAppliedCount = outAppliedCount + seqApplied
    var arrayApplied = 0
    text = CompilerLegacyRewriteArrayTypes(text, arrayApplied)
    if arrayApplied > 0:
        CompilerCsgAddUnique(outAppliedRules, "array_type_to_suffix")
        outAppliedCount = outAppliedCount + arrayApplied
    let lines = parser.ParserSplitChar(text, '\n')
    var out = ""
    for i in 0..<lines.len:
        var line = lines[i]
        let trimmed = chengpath.PathTrim(line)
        let indent = CompilerLegacyLineIndent(line)
        if chengpath.TextStartsWith(trimmed, "proc "):
            CompilerCsgAddUnique(outAppliedRules, "proc_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 5, trimmed.len - 5)], "")
        elif chengpath.TextStartsWith(trimmed, "method "):
            CompilerCsgAddUnique(outAppliedRules, "method_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 7, trimmed.len - 7)], "")
        elif chengpath.TextStartsWith(trimmed, "converter "):
            CompilerCsgAddUnique(outAppliedRules, "converter_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 10, trimmed.len - 10)], "")
        if i > 0:
            out = strutil.Join([out, "\n"], "")
        out = strutil.Join([out, line], "")
    return out

fn CompilerLegacyPackageId(modulePathRaw: str): str =
    let parts = parser.ParserSplitChar(chengpath.PathTrim(modulePathRaw), '/')
    if parts.len >= 2:
        return strutil.Join([parts[0], "/", parts[1]], "")
    if parts.len == 1:
        return parts[0]
    return "legacy"

fn CompilerCsgAddUniqueImportEdge(edges: var parser.ImportEdge[],
                                    edge: parser.ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn CompilerLegacyCollectClosure(workspaceRoot: str,
                                  packageRoot: str,
                                  sourcePathRaw: str,
                                  entryModulePathOverride: str,
                                  seen: var str[],
                                  units: var CompilerLegacySourceUnit[],
                                  ownerModulePaths: var str[],
                                  importEdges: var parser.ImportEdge[],
                                  outAppliedRules: var str[],
                                  outAppliedCount: var int32,
                                  unresolvedImportCount: var int32,
                                  err: var str): bool =
    let sourcePath = chengpath.PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = " compiler migration: missing legacy source path"
        return false
    for i in 0..<seen.len:
        if seen[i] == sourcePath:
            err = ""
            return true
    if !chengpath.PathFileExists(sourcePath):
        err = strutil.Join([" compiler migration: missing legacy source: ", sourcePath], "")
        return false
    add(seen, sourcePath)
    let legacyText = chengpath.ReadTextFile("", sourcePath)
    var localRules: str[]
    var localAppliedCount = 0
    let migratedText = CompilerLegacyNormalizeText(legacyText, localRules, localAppliedCount)
    var modulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    if entryModulePathOverride.len > 0:
        if sourcePath == seen[0]:
            modulePath = entryModulePathOverride
    var unit: CompilerLegacySourceUnit
    unit.sourcePath = sourcePath
    unit.modulePath = modulePath
    unit.legacyText = legacyText
    unit.migratedText = migratedText
    add(units, unit)
    CompilerCsgAddUnique(ownerModulePaths, modulePath)
    for i in 0..<localRules.len:
        CompilerCsgAddUnique(outAppliedRules, localRules[i])
    outAppliedCount = outAppliedCount + localAppliedCount
    var localEdges: parser.ImportEdge[]
    if !parser.ParserReadImportEdges(workspaceRoot, packageRoot, modulePath, migratedText, localEdges, err):
        return false
    for i in 0..<localEdges.len:
        let edge = localEdges[i]
        CompilerCsgAddUniqueImportEdge(importEdges, edge)
        if edge.resolved:
            CompilerCsgAddUnique(ownerModulePaths, edge.targetModulePath)
            if !CompilerLegacyCollectClosure(workspaceRoot,
                                               packageRoot,
                                               edge.targetSourcePath,
                                               "",
                                               seen,
                                               units,
                                               ownerModulePaths,
                                               importEdges,
                                               outAppliedRules,
                                               outAppliedCount,
                                               unresolvedImportCount,
                                               err):
                return false
        else:
            unresolvedImportCount = unresolvedImportCount + 1
    err = ""
    return true

fn CompilerLegacyFindUnitText(units: CompilerLegacySourceUnit[],
                                sourcePath: str,
                                out: var str): bool =
    for i in 0..<units.len:
        if units[i].sourcePath != sourcePath:
            continue
        out = units[i].migratedText
        return true
    return false

fn CompilerLegacyBuildPlan(workspaceRoot: str,
                             packageRoot: str,
                             entrySourcePath: str,
                             packageId: str,
                             units: CompilerLegacySourceUnit[],
                             ownerModulePaths: str[],
                             importEdges: parser.ImportEdge[],
                             unresolvedImportCount: int32,
                             out: var slplan.SystemLinkPlanStub): bool =
    let entryModulePath = units.len > 0 ? units[0].modulePath : parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, entrySourcePath)
    out.entryPath = entrySourcePath
    out.outputPath = ""
    out.targetTriple = "arm64-apple-darwin"
    out.emitKind = creq.EmitExe
    out.packageRoot = packageRoot
    out.workspaceRoot = workspaceRoot
    out.packageId = packageId
    out.moduleStem = parser.ParserFileStem(entrySourcePath)
    out.moduleKind = entryModulePath == "cheng/core/tooling/compiler_main" ? slplan.SystemCompilerControlPlane : slplan.SystemOrdinaryProgram
    out.sourceClosurePaths = []
    for i in 0..<units.len:
        add(out.sourceClosurePaths, units[i].sourcePath)
    out.ownerModulePaths = ownerModulePaths
    out.importEdges = importEdges
    out.importEdgeCount = importEdges.len
    out.unresolvedImportCount = unresolvedImportCount
    out.hasCompilerTopLevel = true
    var entryText = ""
    let foundEntryText = CompilerLegacyFindUnitText(units, entrySourcePath, entryText)
    out.mainFunctionPresent = foundEntryText && parser.ParserMainFunctionPresent(entryText)
    if out.moduleKind == slplan.SystemCompilerControlPlane:
        out.runtimeTargets = ["runtime/compiler.tooling_argv_entry"]
    else:
        out.runtimeTargets = ["runtime/compiler.program_argv_entry"]
    var providerModules: str[]
    add(providerModules, "runtime/compiler_runtime")
    add(providerModules, "runtime/core_runtime")
    add(providerModules, "runtime/debug_runtime")
    add(providerModules, "runtime/program_support")
    add(providerModules, "runtime/program_support_get_env_bridge")
    add(providerModules, "runtime/program_support_host_runtime")
    out.providerModules = providerModules
    out.entrySymbol = out.mainFunctionPresent ? "main" : ""
    out.missingReasons = []
    out.parserSyntaxTag = "cheng.legacy_migrated_source"
    out.parserSourceKind = 1
    out.buildEntryPath = entrySourcePath
    out.buildSourceUnitCount = units.len
    out.linkMode = "system_link"
    out.pipelineStage = "legacy_source_to_canonical_csg"
    return true

fn BuildCompilerLegacyMigration(workspaceRoot: str,
                                  packageRoot: str,
                                  entrySourcePath: str,
                                  packageIdHint: str,
                                  entryModulePathOverride: str): Result[CompilerLegacyMigration] =
    var seen: str[]
    var units: CompilerLegacySourceUnit[]
    var ownerModulePaths: str[]
    var importEdges: parser.ImportEdge[]
    var appliedRules: str[]
    var appliedCount = 0
    var unresolvedImportCount = 0
    var err = ""
    if !CompilerLegacyCollectClosure(workspaceRoot,
                                       packageRoot,
                                       entrySourcePath,
                                       entryModulePathOverride,
                                       seen,
                                       units,
                                       ownerModulePaths,
                                       importEdges,
                                       appliedRules,
                                       appliedCount,
                                       unresolvedImportCount,
                                       err):
        return Err[CompilerLegacyMigration](err)
    CompilerCsgSortStrs(ownerModulePaths)
    var legacyTexts: str[]
    var legacyModulePaths: str[]
    var migratedTexts: str[]
    var migratedModulePaths: str[]
    for i in 0..<units.len:
        add(legacyModulePaths, units[i].modulePath)
        add(legacyTexts, units[i].legacyText)
        add(migratedModulePaths, units[i].modulePath)
        add(migratedTexts, units[i].migratedText)
    let packageId = packageIdHint.len > 0 ? packageIdHint : CompilerLegacyPackageId(units[0].modulePath)
    let legacyBundleRes = cworld.CompilerWorldSourceBundleCidFromModuleTexts(packageId,
                                                                               legacyModulePaths,
                                                                               legacyTexts)
    if IsErr(legacyBundleRes):
        return Err[CompilerLegacyMigration](Error(legacyBundleRes))
    let migratedBundleRes = cworld.CompilerWorldSourceBundleCidFromModuleTexts(packageId,
                                                                                 migratedModulePaths,
                                                                                 migratedTexts)
    if IsErr(migratedBundleRes):
        return Err[CompilerLegacyMigration](Error(migratedBundleRes))
    var plan: slplan.SystemLinkPlanStub
    if !CompilerLegacyBuildPlan(workspaceRoot,
                                  packageRoot,
                                  entrySourcePath,
                                  packageId,
                                  units,
                                  ownerModulePaths,
                                  importEdges,
                                  unresolvedImportCount,
                                  plan):
        return Err[CompilerLegacyMigration](" compiler migration: failed to build legacy plan")
    var overrides: CompilerCsgSourceText[]
    for i in 0..<units.len:
        var override: CompilerCsgSourceText
        override.sourcePath = units[i].sourcePath
        override.modulePath = units[i].modulePath
        override.text = units[i].migratedText
        add(overrides, override)
    let csgRes = BuildCompilerCsgWithOverrides(plan, Value(migratedBundleRes), overrides)
    if IsErr(csgRes):
        return Err[CompilerLegacyMigration](Error(csgRes))
    let csg = CompilerCsgClone(Value(csgRes))
    let surface = CompilerExportSurfaceClone(CompilerExportSurfaceFromCsg(csg))
    var migBuf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(migBuf, "cheng.compiler.legacy_migration")
    CompilerCsgAppendText(migBuf, packageId)
    CompilerCsgAppendText(migBuf, entrySourcePath)
    CompilerCsgAppendFixed32(migBuf, Value(legacyBundleRes))
    CompilerCsgAppendFixed32(migBuf, Value(migratedBundleRes))
    CompilerCsgAppendFixed32(migBuf, csg.canonicalGraphCid)
    CompilerCsgAppendFixed32(migBuf, surface.surfaceCid)
    CompilerCsgAppendU32BE(migBuf, appliedRules.len)
    for i in 0..<appliedRules.len:
        CompilerCsgAppendText(migBuf, appliedRules[i])
    var out: CompilerLegacyMigration
    out.version = 1
    out.packageId = packageId
    out.entrySourcePath = entrySourcePath
    out.entryModulePath = units[0].modulePath
    out.unitCount = units.len
    out.units = CompilerLegacySourceUnitsClone(units)
    out.appliedRuleCount = appliedCount
    out.appliedRules = appliedRules
    out.legacySourceBundleCid = Value(legacyBundleRes)
    out.migratedSourceBundleCid = Value(migratedBundleRes)
    out.compilerCsg = CompilerCsgClone(csg)
    out.exportSurface = CompilerExportSurfaceClone(surface)
    out.migrationCid = CompilerCsgBufCid(migBuf)
    return Ok[CompilerLegacyMigration](out)

fn CompilerLegacyMigrationReport(migration: CompilerLegacyMigration): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", migration.packageId, "\n"], "")
    out = strutil.Join([out, "entry_source_path=", migration.entrySourcePath, "\n"], "")
    out = strutil.Join([out, "entry_module_path=", migration.entryModulePath, "\n"], "")
    out = strutil.Join([out, "unit_count=", IntToStr(migration.unitCount), "\n"], "")
    out = strutil.Join([out, "applied_rule_count=", IntToStr(migration.appliedRuleCount), "\n"], "")
    out = strutil.Join([out, "legacy_source_bundle_cid=", layout.FixedBytes32Hex(migration.legacySourceBundleCid), "\n"], "")
    out = strutil.Join([out, "migrated_source_bundle_cid=", layout.FixedBytes32Hex(migration.migratedSourceBundleCid), "\n"], "")
    out = strutil.Join([out, "canonical_graph_cid=", layout.FixedBytes32Hex(migration.compilerCsg.canonicalGraphCid), "\n"], "")
    out = strutil.Join([out, "graph_cid=", layout.FixedBytes32Hex(migration.compilerCsg.graphCid), "\n"], "")
    out = strutil.Join([out, "surface_cid=", layout.FixedBytes32Hex(migration.exportSurface.surfaceCid), "\n"], "")
    out = strutil.Join([out, "migration_cid=", layout.FixedBytes32Hex(migration.migrationCid)], "")
    for i in 0..<migration.appliedRules.len:
        out = strutil.Join([out, "\n", "applied_rule[", IntToStr(i), "]=", migration.appliedRules[i]], "")
    return out

fn CompilerCsgAddNode(nodes: var CompilerCsgNode[],
                        nodeKind: int32,
                        ownerNodeId: int32,
                        modulePath: str,
                        symbolText: str,
                        factText: str,
                        resultLayoutKind: int32,
                        effectKind: int32,
                        capabilityKind: int32,
                        callConv: int32,
                        entryFlag: int32,
                        exportedFlag: int32,
                        exportSymbolName: str): int32 =
    var node: CompilerCsgNode
    node.nodeId = nodes.len + 1
    node.nodeKind = nodeKind
    node.ownerNodeId = ownerNodeId
    node.modulePath = modulePath
    node.symbolText = symbolText
    node.factText = factText
    node.resultLayoutKind = resultLayoutKind
    node.effectKind = effectKind
    node.capabilityKind = capabilityKind
    node.callConv = callConv
    node.entryFlag = entryFlag
    node.exportedFlag = exportedFlag
    node.exportSymbolName = exportSymbolName
    node.factCid = CompilerCsgHashNode(nodeKind,
                                         ownerNodeId,
                                         modulePath,
                                         symbolText,
                                         factText,
                                         resultLayoutKind,
                                         effectKind,
                                         capabilityKind,
                                         callConv,
                                         entryFlag,
                                         exportedFlag,
                                         exportSymbolName)
    add(nodes, node)
    return node.nodeId

fn CompilerCsgAddEdge(edges: var CompilerCsgEdge[],
                        fromNodeId: int32,
                        toNodeId: int32,
                        edgeKind: int32) =
    var edge: CompilerCsgEdge
    edge.edgeId = edges.len + 1
    edge.fromNodeId = fromNodeId
    edge.toNodeId = toNodeId
    edge.edgeKind = edgeKind
    edge.edgeCid = CompilerCsgHashEdge(fromNodeId, toNodeId, edgeKind)
    add(edges, edge)

fn CompilerCsgExprLayerForText(sourcePath: str,
                                 text: str,
                                 importcCallNames: str[],
                                 localCallNames: str[],
                                 externalCallNames: str[],
                                 currentProfile: parser.NormalizedExprCallProfile,
                                 profiles: parser.NormalizedExprCallProfile[],
                                 profileIndexLookup: parser.ParserSourcePathIndexLookup,
                                 layer: var parser.NormalizedExprLayer): Result[bool] =
    var err: str
    if !parser.ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePath,
                                                                                text,
                                                                                importcCallNames,
                                                                                localCallNames,
                                                                                externalCallNames,
                                                                                currentProfile,
                                                                                profiles,
                                                                                profileIndexLookup,
                                                                                layer,
                                                                                err):
        if err != "":
            return Err[bool](err)
        return Err[bool](" compiler csg: expr layer read failed")
    return Ok[bool](true)

fn CompilerCsgTextRangeEquals(text: str,
                               start: int32,
                               stop: int32,
                               expected: str): bool =
    if start < 0 || stop < start || stop > text.len:
        return false
    if stop - start != expected.len:
        return false
    for i in 0..<expected.len:
        if text[start + i] != expected[i]:
            return false
    return true

fn CompilerCsgTrimmedLineEquals(line: str,
                                 expected: str): bool =
    var start: int32
    var stop: int32
    if !parser.ParserTrimmedLineRange(line, start, stop):
        return false
    return CompilerCsgTextRangeEquals(line, start, stop, expected)

fn CompilerCsgExprLayerForProfile(sourcePath: str,
                                   importcCallNames: str[],
                                   localCallNames: str[],
                                   externalCallNames: str[],
                                   currentProfile: parser.NormalizedExprCallProfile,
                                   profiles: parser.NormalizedExprCallProfile[],
                                   profileIndexLookup: parser.ParserSourcePathIndexLookup,
                                   layer: var parser.NormalizedExprLayer): Result[bool] =
    if sourcePath == "":
        return Err[bool]("missing source path")
    layer = parser.NormalizedExprLayer()
    layer.sourceCount = 1
    var localCallLookup = parser.ParserTextLookupBuildExact(localCallNames)
    var externalCallLookup = parser.ParserTextLookupBuildExact(externalCallNames)
    var importcCallLookup = parser.ParserTextLookupBuildExact(importcCallNames)
    var knownCallLookup = parser.ParserTextLookupInit(localCallNames.len +
                                                       externalCallNames.len +
                                                       importcCallNames.len + 8)
    parser.ParserTextLookupAddAllExact(knownCallLookup, localCallNames)
    parser.ParserTextLookupAddAllExact(knownCallLookup, externalCallNames)
    parser.ParserTextLookupAddAllExact(knownCallLookup, importcCallNames)
    var profileCallLookupCache = parser.ParserBuildProfileCallLookupCache(profiles)
    var inTypeBlock = false
    var typeBlockIndent: int32 = -1
    for i in 0..<currentProfile.lines.len:
        if i % 128 == 0:
            os.ProcessResourceGuardCheck()
        let line = parser.ParserStripLineComment(currentProfile.lines[i])
        if !parser.ParserHasNonTrimChar(line):
            continue
        let lineNumber = i + 1
        let lineIndent: int32 = parser.ParserLineIndent(line)
        if inTypeBlock && lineIndent <= typeBlockIndent:
            inTypeBlock = false
        if !parser.ParserHasLeadingIndent(line):
            inTypeBlock = CompilerCsgTrimmedLineEquals(line, "type")
            if inTypeBlock:
                typeBlockIndent = lineIndent
        var redundantType = ""
        var redundantExpr = ""
        if parser.ParserFindRedundantExplicitDefaultLine(line,
                                                          inTypeBlock,
                                                          currentProfile,
                                                          profiles,
                                                          redundantType,
                                                          redundantExpr):
            return Err[bool](parser.ParserRedundantExplicitDefaultError(redundantType, redundantExpr))
        var strictErr = ""
        if parser.ParserRejectSpaceCallIfStrict(line, lineNumber, knownCallLookup, strictErr):
            return Err[bool](strictErr)
        parser.ParserAppendSimpleSurfaceExprsLine(sourcePath,
                                                   lineNumber,
                                                   line,
                                                   true,
                                                   true,
                                                   true,
                                                   layer)
        parser.ParserAppendReturnStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendAssignStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendControlStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendStringifyCallExprsLine(sourcePath,
                                                   lineNumber,
                                                   line,
                                                   layer)
        var defaultErr = ""
        if !parser.ParserAppendDefaultInitExprsLine(sourcePath,
                                                     lineNumber,
                                                     line,
                                                     currentProfile,
                                                     profiles,
                                                     layer,
                                                     defaultErr):
            return Err[bool](defaultErr)
        parser.ParserAppendConstructorExprsLine(sourcePath,
                                                 lineNumber,
                                                 line,
                                                 currentProfile,
                                                 profiles,
                                                 layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &localCallLookup,
                                          parser.NormalizedExprSurfaceCallLocal,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &externalCallLookup,
                                          parser.NormalizedExprSurfaceCallExternal,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &importcCallLookup,
                                          parser.NormalizedExprSurfaceCallImportc,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendMemberCallExprsLine(sourcePath,
                                                lineNumber,
                                                line,
                                                knownCallLookup,
                                                currentProfile,
                                                layer)
    layer.questionResidualCount = 0
    return Ok[bool](true)

fn BuildCompilerCsgWithOverridesInto(linkPlan: slplan.SystemLinkPlanStub,
                                      sourceBundleCid: layout.FixedBytes32,
                                      sourceTextOverrides: CompilerCsgSourceText[],
                                      out: var CompilerCsg,
                                      err: var str): bool =
    err = ""
    var modules: str[]
    var importPairs: CompilerCsgImportPair[]
    var moduleSeen = CompilerCsgTextSetInit(linkPlan.ownerModulePaths.len +
                                              linkPlan.importEdges.len * 2 + 8)
    var importPairSeen = CompilerCsgImportPairLookupInit(linkPlan.importEdges.len * 2 + 8)
    for i in 0..<linkPlan.ownerModulePaths.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.ownerModulePaths[i])
    for i in 0..<linkPlan.importEdges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.importEdges[i].ownerModulePath)
        if linkPlan.importEdges[i].resolved:
            CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.importEdges[i].targetModulePath)
            CompilerCsgAddUniqueImportPairFast(importPairs,
                                                importPairSeen,
                                                linkPlan.importEdges[i].ownerModulePath,
                                                linkPlan.importEdges[i].targetModulePath)
    CompilerCsgSortStrs(modules)
    CompilerCsgSortImportPairs(importPairs)
    var nodes: CompilerCsgNode[]
    var edges: CompilerCsgEdge[]
    var exprLayer = parser.NormalizedExprLayer()
    var packageNode: CompilerCsgNode
    packageNode.nodeId = nodes.len + 1
    packageNode.nodeKind = CompilerCsgNodeKindPackage
    packageNode.ownerNodeId = 0
    packageNode.modulePath = ""
    packageNode.symbolText = ""
    packageNode.factText = linkPlan.packageId
    packageNode.resultLayoutKind = 0
    packageNode.effectKind = 0
    packageNode.capabilityKind = 0
    packageNode.callConv = 0
    packageNode.entryFlag = 0
    packageNode.exportedFlag = 0
    packageNode.exportSymbolName = ""
    var packageBuf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(packageBuf, "cheng.compiler.csg.node")
    CompilerCsgAppendU32BE(packageBuf, packageNode.nodeKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.ownerNodeId)
    CompilerCsgAppendText(packageBuf, packageNode.modulePath)
    CompilerCsgAppendText(packageBuf, packageNode.symbolText)
    CompilerCsgAppendText(packageBuf, packageNode.factText)
    CompilerCsgAppendU32BE(packageBuf, packageNode.resultLayoutKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.effectKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.capabilityKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.callConv)
    CompilerCsgAppendU32BE(packageBuf, packageNode.entryFlag)
    CompilerCsgAppendU32BE(packageBuf, packageNode.exportedFlag)
    CompilerCsgAppendText(packageBuf, packageNode.exportSymbolName)
    packageNode.factCid = CompilerCsgBufCid(packageBuf)
    add(nodes, packageNode)
    let packageNodeId = packageNode.nodeId
    var moduleNodeIds: int32[]
    for i in 0..<modules.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        var moduleNode: CompilerCsgNode
        moduleNode.nodeId = nodes.len + 1
        moduleNode.nodeKind = CompilerCsgNodeKindModule
        moduleNode.ownerNodeId = packageNodeId
        moduleNode.modulePath = modules[i]
        moduleNode.symbolText = ""
        moduleNode.factText = modules[i]
        moduleNode.resultLayoutKind = 0
        moduleNode.effectKind = 0
        moduleNode.capabilityKind = 0
        moduleNode.callConv = 0
        moduleNode.entryFlag = 0
        moduleNode.exportedFlag = 0
        moduleNode.exportSymbolName = ""
        var moduleBuf: layout.ByteBuf = layout.ByteBufInit(256)
        CompilerCsgAppendText(moduleBuf, "cheng.compiler.csg.node")
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.nodeKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.ownerNodeId)
        CompilerCsgAppendText(moduleBuf, moduleNode.modulePath)
        CompilerCsgAppendText(moduleBuf, moduleNode.symbolText)
        CompilerCsgAppendText(moduleBuf, moduleNode.factText)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.resultLayoutKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.effectKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.capabilityKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.callConv)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.entryFlag)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.exportedFlag)
        CompilerCsgAppendText(moduleBuf, moduleNode.exportSymbolName)
        moduleNode.factCid = CompilerCsgBufCid(moduleBuf)
        add(nodes, moduleNode)
        add(moduleNodeIds, moduleNode.nodeId)
        CompilerCsgAddEdge(edges, packageNodeId, moduleNode.nodeId, CompilerCsgEdgeKindContains)
    for i in 0..<importPairs.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let pair = importPairs[i]
        let fromNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                        moduleNodeIds,
                                                        pair.ownerModulePath)
        let toNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                      moduleNodeIds,
                                                      pair.targetModulePath)
        if fromNodeId <= 0 || toNodeId <= 0:
            continue
        CompilerCsgAddEdge(edges, fromNodeId, toNodeId, CompilerCsgEdgeKindImports)
    var orderedSources: str[]
    var orderedSourceModules: str[]
    var typedSourceTexts: TypedExprSourceText[]
    var exprCallProfiles: parser.NormalizedExprCallProfile[]
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    for i in 0..<linkPlan.sourceClosurePaths.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = linkPlan.sourceClosurePaths[i]
        add(orderedSources, sourcePath)
        add(orderedSourceModules,
            CompilerCsgSourceModulePath(linkPlan.workspaceRoot,
                                          linkPlan.packageRoot,
                                          externalPackageRoots,
                                          sourceTextOverrides,
                                          sourcePath))
    CompilerCsgSortSourcePathModulePairs(orderedSources, orderedSourceModules)
    for sourceIndex in 0..<orderedSources.len:
        if sourceIndex % 16 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = orderedSources[sourceIndex]
        let ownerModulePath = orderedSourceModules[sourceIndex]
        let ownerModuleNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                               moduleNodeIds,
                                                               ownerModulePath)
        if ownerModuleNodeId <= 0:
            continue
        var text = ""
        if !CompilerCsgSourceTextLookup(sourceTextOverrides, sourcePath, text):
            text = chengpath.ReadTextFile("", sourcePath)
        add(typedSourceTexts, texpr.TypedExprSourceTextNewWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                      linkPlan.packageRoot,
                                                                                      externalPackageRoots,
                                                                                      sourcePath,
                                                                                      text))
        var profile: parser.NormalizedExprCallProfile
        var profileErr = ""
        if !parser.ParserBuildExprCallProfileWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                        linkPlan.packageRoot,
                                                                        externalPackageRoots,
                                                                        sourcePath,
                                                                        text,
                                                                        profile,
                                                                        profileErr):
            err = " compiler csg: normalized decl read failed"
            return false
        add(exprCallProfiles, profile)
    let profileIndexLookup = parser.ParserSourcePathIndexLookupBuild(exprCallProfiles)
    parser.ParserBindImportEdgeTargetProfileIndices(exprCallProfiles, profileIndexLookup)
    var externalVisibleNameCache: parser.ParserTextSeqCacheEntry[]
    var externalQualifiedNameCache: parser.ParserQualifiedTextSeqCacheEntry[]
    for sourceIndex in 0..<exprCallProfiles.len:
        if sourceIndex % 16 == 0:
            os.ProcessResourceGuardCheck()
        var profile = exprCallProfiles[sourceIndex]
        let sourcePath = profile.sourcePath
        let ownerModulePath = orderedSourceModules[sourceIndex]
        let ownerModuleNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                               moduleNodeIds,
                                                               ownerModulePath)
        if ownerModuleNodeId <= 0:
            continue
        var sourceExternalCalls: str[]
        parser.ParserCollectExternalCallNamesCached(exprCallProfiles,
                                                      profileIndexLookup,
                                                      sourceIndex,
                                                      externalVisibleNameCache,
                                                      externalQualifiedNameCache,
                                                      sourceExternalCalls)
        var sourceExprLayer = parser.NormalizedExprLayer()
        let sourceExprRes = CompilerCsgExprLayerForProfile(sourcePath,
                                                            profile.importcCallNames,
                                                            profile.localCallNames,
                                                            sourceExternalCalls,
                                                            profile,
                                                            exprCallProfiles,
                                                            profileIndexLookup,
                                                            sourceExprLayer)
        if IsErr(sourceExprRes):
            err = Error(sourceExprRes)
            return false
        parser.NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
        let entrySourceFlag = sourcePath == linkPlan.entryPath
        var entryHasExplicitExports = false
        if entrySourceFlag && (linkPlan.emitKind == creq.EmitShared || linkPlan.emitKind == creq.EmitObj):
            for scanIndex in 0..<profile.decls.len:
                if scanIndex % 256 == 0:
                    os.ProcessResourceGuardCheck()
                if profile.decls[scanIndex].importc:
                    continue
                if profile.decls[scanIndex].explicitExportName.len > 0:
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<profile.decls.len:
            if declIndex % 64 == 0:
                os.ProcessResourceGuardCheck()
            let decl = profile.decls[declIndex]
            let functionName = decl.name
            if decl.importc:
                continue
            let pendingExportName = decl.explicitExportName
            var entryFlag = 0
            if sourcePath == linkPlan.entryPath && functionName == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if functionName == "main":
                resultLayoutKind = 5
            var effectKind = CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = CompilerCsgEffectProgramEntry
            var capabilityKind = CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = CompilerCsgCapabilityEntrypoint
            let callConv = 1
            let symbolText = parser.ParserConcat3(ownerModulePath, "::", functionName)
            var exportedFlag = 0
            if CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                               entrySourceFlag,
                                               entryHasExplicitExports,
                                               pendingExportName,
                                               functionName,
                                               entryFlag):
                exportedFlag = 1
            var exportSymbolName = ""
            if exportedFlag != 0:
                exportSymbolName = CompilerCsgTargetExportName(symbolText,
                                                                 pendingExportName,
                                                                 functionName)
            var symbolNode: CompilerCsgNode
            symbolNode.nodeId = nodes.len + 1
            symbolNode.nodeKind = CompilerCsgNodeKindSymbol
            symbolNode.ownerNodeId = ownerModuleNodeId
            symbolNode.modulePath = ownerModulePath
            symbolNode.symbolText = symbolText
            symbolNode.factText = functionName
            symbolNode.resultLayoutKind = resultLayoutKind
            symbolNode.effectKind = effectKind
            symbolNode.capabilityKind = capabilityKind
            symbolNode.callConv = callConv
            symbolNode.entryFlag = entryFlag
            symbolNode.exportedFlag = exportedFlag
            symbolNode.exportSymbolName = exportSymbolName
            var symbolBuf: layout.ByteBuf = layout.ByteBufInit(256)
            CompilerCsgAppendText(symbolBuf, "cheng.compiler.csg.node")
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.nodeKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.ownerNodeId)
            CompilerCsgAppendText(symbolBuf, symbolNode.modulePath)
            CompilerCsgAppendText(symbolBuf, symbolNode.symbolText)
            CompilerCsgAppendText(symbolBuf, symbolNode.factText)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.resultLayoutKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.effectKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.capabilityKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.callConv)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.entryFlag)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.exportedFlag)
            CompilerCsgAppendText(symbolBuf, symbolNode.exportSymbolName)
            symbolNode.factCid = CompilerCsgBufCid(symbolBuf)
            add(nodes, symbolNode)
            let symbolNodeId = symbolNode.nodeId
            CompilerCsgAddEdge(edges, ownerModuleNodeId, symbolNodeId, CompilerCsgEdgeKindContains)
        profile.text = ""
        profile.lines = []
        exprCallProfiles[sourceIndex] = profile
    exprCallProfiles = []
    orderedSources = []
    orderedSourceModules = []
    var typedExprFacts: TypedExprFact[]
    var typedErr = ""
    os.ProcessResourceGuardCheck()
    if !texpr.TypedExprBuildFacts(typedSourceTexts, exprLayer, typedExprFacts, typedErr):
        if typedErr != "":
            err = typedErr
            return false
        err = " compiler csg: typed expr build failed"
        return false
    CompilerCsgRestoreSourceTextOverrides(sourceTextOverrides, typedSourceTexts)
    var typedIr: texpr.TypedExprIr
    var typedIrErr = ""
    if !texpr.TypedExprBuildIrWithFacts(typedSourceTexts, typedExprFacts, typedIr, typedIrErr):
        if typedIrErr != "":
            err = typedIrErr
            return false
        err = " compiler csg: typed ir build failed"
        return false
    typedSourceTexts = []
    os.ProcessResourceGuardCheck()
    let canonicalGraphCid = CompilerCsgCanonicalGraphCid(linkPlan.packageId,
                                                          sourceBundleCid,
                                                          linkPlan.workspaceRoot,
                                                          linkPlan.packageRoot,
                                                          externalPackageRoots,
                                                          sourceTextOverrides,
                                                          exprLayer,
                                                          typedExprFacts,
                                                          nodes,
                                                          edges)
    os.ProcessResourceGuardCheck()
    let graphCid = CompilerCsgGraphCid(linkPlan.packageId,
                                        sourceBundleCid,
                                        linkPlan.workspaceRoot,
                                        linkPlan.packageRoot,
                                        externalPackageRoots,
                                        sourceTextOverrides,
                                        exprLayer,
                                        typedExprFacts,
                                        nodes,
                                        edges)
    out.version = 1
    out.packageId = linkPlan.packageId
    out.sourceBundleCid = sourceBundleCid
    out.exprLayer = exprLayer
    out.typedExprFacts = typedExprFacts
    out.typedIr = typedIr
    out.nodes = nodes
    out.edges = edges
    out.nodeCount = nodes.len
    out.edgeCount = edges.len
    out.canonicalGraphCid = canonicalGraphCid
    out.graphCid = graphCid
    return true

fn BuildCompilerCsgWithOverrides(linkPlan: slplan.SystemLinkPlanStub,
                                   sourceBundleCid: layout.FixedBytes32,
                                   sourceTextOverrides: CompilerCsgSourceText[]): Result[CompilerCsg] =
    var out: CompilerCsg
    var err = ""
    if !BuildCompilerCsgWithOverridesInto(linkPlan,
                                          sourceBundleCid,
                                          sourceTextOverrides,
                                          out,
                                          err):
        return Err[CompilerCsg](err)
    return Ok[CompilerCsg](out)

fn BuildCompilerCsgInto(linkPlan: slplan.SystemLinkPlanStub,
                         sourceBundleCid: layout.FixedBytes32,
                         out: var CompilerCsg,
                         err: var str): bool =
    var sourceTextOverrides: CompilerCsgSourceText[]
    sourceTextOverrides = []
    return BuildCompilerCsgWithOverridesInto(linkPlan,
                                             sourceBundleCid,
                                             sourceTextOverrides,
                                             out,
                                             err)

fn BuildCompilerCsg(linkPlan: slplan.SystemLinkPlanStub,
                      sourceBundleCid: layout.FixedBytes32): Result[CompilerCsg] =
    var sourceTextOverrides: CompilerCsgSourceText[]
    sourceTextOverrides = []
    return BuildCompilerCsgWithOverrides(linkPlan, sourceBundleCid, sourceTextOverrides)

fn CompilerExportSurfaceFromCsg(csg: CompilerCsg): CsgExportSurface =
    var out: CsgExportSurface
    out.version = 1
    out.packageId = csg.packageId
    out.exportedSymbols = []
    out.exportedTargetNames = []
    out.exportedLayouts = []
    out.exportedEffects = []
    out.exportedCapabilities = []
    for i in 0..<csg.nodes.len:
        let node = csg.nodes[i]
        if node.nodeKind != CompilerCsgNodeKindSymbol:
            continue
        if node.exportedFlag == 0:
            continue
        add(out.exportedSymbols, node.symbolText)
        add(out.exportedTargetNames, node.exportSymbolName)
        add(out.exportedLayouts, node.resultLayoutKind)
        add(out.exportedEffects, node.effectKind)
        add(out.exportedCapabilities, node.capabilityKind)
    out.exportedSymbolCount = out.exportedSymbols.len
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.export_surface")
    CompilerCsgAppendText(buf, out.packageId)
    CompilerCsgAppendU32BE(buf, out.exportedSymbolCount)
    for i in 0..<out.exportedSymbols.len:
        CompilerCsgAppendText(buf, out.exportedSymbols[i])
        CompilerCsgAppendText(buf, out.exportedTargetNames[i])
        CompilerCsgAppendU32BE(buf, out.exportedLayouts[i])
        CompilerCsgAppendU32BE(buf, out.exportedEffects[i])
        CompilerCsgAppendU32BE(buf, out.exportedCapabilities[i])
    out.surfaceCid = CompilerCsgBufCid(buf)
    return out

fn CompilerExportSurfaceCompatible(base: CsgExportSurface,
                                     next: CsgExportSurface): bool =
    if base.packageId != next.packageId:
        return false
    if base.exportedSymbolCount != next.exportedSymbolCount:
        return false
    for i in 0..<base.exportedSymbolCount:
        if base.exportedSymbols[i] != next.exportedSymbols[i]:
            return false
        if base.exportedTargetNames[i] != next.exportedTargetNames[i]:
            return false
        if base.exportedLayouts[i] != next.exportedLayouts[i]:
            return false
        if base.exportedEffects[i] != next.exportedEffects[i]:
            return false
        if base.exportedCapabilities[i] != next.exportedCapabilities[i]:
            return false
    return true

fn CompileReceiptMake(worldHeadCid: layout.FixedBytes32,
                        compilerCsgCid: layout.FixedBytes32,
                        canonicalCompilerCsgCid: layout.FixedBytes32,
                        targetTriple: str,
                        outputDigest: layout.FixedBytes32,
                        canonicalOutputDigest: layout.FixedBytes32,
                        bootstrapStage: str,
                        runtimeProviderSet: str[]): CompileReceipt =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.compile_receipt")
    CompilerCsgAppendFixed32(buf, worldHeadCid)
    CompilerCsgAppendFixed32(buf, compilerCsgCid)
    CompilerCsgAppendFixed32(buf, canonicalCompilerCsgCid)
    CompilerCsgAppendText(buf, targetTriple)
    CompilerCsgAppendFixed32(buf, outputDigest)
    CompilerCsgAppendFixed32(buf, canonicalOutputDigest)
    CompilerCsgAppendText(buf, bootstrapStage)
    CompilerCsgAppendU32BE(buf, runtimeProviderSet.len)
    for i in 0..<runtimeProviderSet.len:
        CompilerCsgAppendText(buf, runtimeProviderSet[i])
    var out: CompileReceipt
    out.version = 1
    out.worldHeadCid = worldHeadCid
    out.compilerCsgCid = compilerCsgCid
    out.canonicalCompilerCsgCid = canonicalCompilerCsgCid
    out.targetTriple = targetTriple
    out.outputDigest = outputDigest
    out.canonicalOutputDigest = canonicalOutputDigest
    out.bootstrapStage = bootstrapStage
    out.runtimeProviderSet = runtimeProviderSet
    out.receiptCid = CompilerCsgBufCid(buf)
    return out

fn CompileOutputDigest(outputPath: str,
                         targetTriple: str,
                         providerModules: str[],
                         csgCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.output_digest")
    let _ = outputPath
    CompilerCsgAppendText(buf, targetTriple)
    CompilerCsgAppendFixed32(buf, csgCid)
    CompilerCsgAppendU32BE(buf, providerModules.len)
    for i in 0..<providerModules.len:
        CompilerCsgAppendText(buf, providerModules[i])
    return CompilerCsgBufCid(buf)

fn CompilerCsgReport(csg: CompilerCsg): str =
    var out = ""
    let typedExprFacts = csg.typedExprFacts
    let loweringRules = texpr.TypedExprLoweringRulesFromFacts(typedExprFacts)
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", csg.packageId, "\n"], "")
    out = strutil.Join([out, "source_bundle_cid=", layout.FixedBytes32Hex(csg.sourceBundleCid), "\n"], "")
    out = strutil.Join([out, "expr_surface_source_count=", IntToStr(csg.exprLayer.sourceCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_expr_count=", IntToStr(parser.NormalizedExprLayerExprCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_if_count=", IntToStr(parser.NormalizedExprLayerIfCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_range_count=", IntToStr(parser.NormalizedExprLayerRangeCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_comprehension_count=", IntToStr(parser.NormalizedExprLayerComprehensionCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_fmt_count=", IntToStr(parser.NormalizedExprLayerStrFormatCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_result_intrinsic_count=", IntToStr(parser.NormalizedExprLayerResultIntrinsicCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_try_count=", IntToStr(parser.NormalizedExprLayerTryCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_default_init_count=", IntToStr(parser.NormalizedExprLayerDefaultInitCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_constructor_count=", IntToStr(parser.NormalizedExprLayerConstructorCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_return_count=", IntToStr(parser.NormalizedExprLayerReturnCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_assign_count=", IntToStr(parser.NormalizedExprLayerAssignCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_if_stmt_count=", IntToStr(parser.NormalizedExprLayerIfStmtCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_elif_stmt_count=", IntToStr(parser.NormalizedExprLayerElifStmtCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_else_stmt_count=", IntToStr(parser.NormalizedExprLayerElseStmtCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_for_stmt_count=", IntToStr(parser.NormalizedExprLayerForStmtCount(csg.exprLayer)), "\n"], "")
    out = strutil.Join([out, "expr_surface_question_residual_count=", IntToStr(csg.exprLayer.questionResidualCount), "\n"], "")
    out = strutil.Join([out, texpr.TypedExprReportText(typedExprFacts, loweringRules)], "")
    out = strutil.Join([out, CompilerCsgEgraphActiveContractReport(), "\n"], "")
    out = strutil.Join([out, "canonical_graph_cid=", layout.FixedBytes32Hex(csg.canonicalGraphCid), "\n"], "")
    out = strutil.Join([out, "graph_cid=", layout.FixedBytes32Hex(csg.graphCid), "\n"], "")
    out = strutil.Join([out, "node_count=", IntToStr(csg.nodeCount), "\n"], "")
    out = strutil.Join([out, "edge_count=", IntToStr(csg.edgeCount)], "")
    for i in 0..<csg.nodes.len:
        out = strutil.Join([out, "\n", CompilerCsgNodeReportLine(i, csg.nodes[i])], "")
    for i in 0..<csg.edges.len:
        out = strutil.Join([out, "\n", CompilerCsgEdgeReportLine(i, csg.edges[i])], "")
    return out

fn CompilerCsgWireReport(csg: CompilerCsg): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", csg.packageId, "\n"], "")
    out = strutil.Join([out, "source_bundle_cid=", layout.FixedBytes32Hex(csg.sourceBundleCid), "\n"], "")
    out = strutil.Join([out, CompilerCsgEgraphActiveContractReport(), "\n"], "")
    out = strutil.Join([out, "canonical_graph_cid=", layout.FixedBytes32Hex(csg.canonicalGraphCid), "\n"], "")
    out = strutil.Join([out, "graph_cid=", layout.FixedBytes32Hex(csg.graphCid), "\n"], "")
    out = strutil.Join([out, "node_count=", IntToStr(csg.nodeCount), "\n"], "")
    out = strutil.Join([out, "edge_count=", IntToStr(csg.edgeCount)], "")
    return out

fn CompilerCsgEgraphActiveContractReport(): str =
    return econtract.CompilerCsgEgraphActiveContractReport()

fn CompilerCsgUirEgraphUnavailableExitCode(): int32 =
    return econtract.CompilerCsgUirEgraphUnavailableExitCode()

fn CompilerCsgNodeReportLine(index: int32,
                               node: CompilerCsgNode): str =
    var out = ""
    out = strutil.Join([out, "node[", IntToStr(index), "]="], "")
    out = strutil.Join([out, IntToStr(node.nodeKind), "|"], "")
    out = strutil.Join([out, IntToStr(node.ownerNodeId), "|"], "")
    out = strutil.Join([out, node.modulePath, "|"], "")
    out = strutil.Join([out, node.symbolText, "|"], "")
    out = strutil.Join([out, node.factText, "|"], "")
    out = strutil.Join([out, IntToStr(node.resultLayoutKind), "|"], "")
    out = strutil.Join([out, IntToStr(node.effectKind), "|"], "")
    out = strutil.Join([out, IntToStr(node.capabilityKind), "|"], "")
    out = strutil.Join([out, IntToStr(node.callConv), "|"], "")
    out = strutil.Join([out, IntToStr(node.entryFlag), "|"], "")
    out = strutil.Join([out, IntToStr(node.exportedFlag), "|"], "")
    out = strutil.Join([out, node.exportSymbolName, "|"], "")
    out = strutil.Join([out, layout.FixedBytes32Hex(node.factCid)], "")
    return out

fn CompilerCsgEdgeReportLine(index: int32,
                               edge: CompilerCsgEdge): str =
    var out = ""
    out = strutil.Join([out, "edge[", IntToStr(index), "]="], "")
    out = strutil.Join([out, IntToStr(edge.edgeKind), "|"], "")
    out = strutil.Join([out, IntToStr(edge.fromNodeId), "|"], "")
    out = strutil.Join([out, IntToStr(edge.toNodeId), "|"], "")
    out = strutil.Join([out, layout.FixedBytes32Hex(edge.edgeCid)], "")
    return out

fn CompilerExportSurfaceReport(surface: CsgExportSurface): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", surface.packageId, "\n"], "")
    out = strutil.Join([out, "exported_count=", IntToStr(surface.exportedSymbolCount), "\n"], "")
    out = strutil.Join([out, "surface_cid=", layout.FixedBytes32Hex(surface.surfaceCid)], "")
    for i in 0..<surface.exportedSymbolCount:
        out = strutil.Join([out, "\n", CompilerExportSurfaceReportLine(surface, i)], "")
    return out

fn CompilerExportSurfaceReportLine(surface: CsgExportSurface,
                                     index: int32): str =
    var out = ""
    out = strutil.Join([out, "export[", IntToStr(index), "]="], "")
    out = strutil.Join([out, surface.exportedSymbols[index], "|"], "")
    out = strutil.Join([out, surface.exportedTargetNames[index], "|"], "")
    out = strutil.Join([out, IntToStr(surface.exportedLayouts[index]), "|"], "")
    out = strutil.Join([out, IntToStr(surface.exportedEffects[index]), "|"], "")
    out = strutil.Join([out, IntToStr(surface.exportedCapabilities[index])], "")
    return out

fn CompilerCsgTextStartsWith(text: str,
                               prefix: str): bool =
    if prefix.len <= 0:
        return true
    if text.len < prefix.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn CompilerCsgParseUintText(text: str,
                              outOk: var bool): int32 =
    outOk = false
    if text.len <= 0:
        return 0
    var value = Int32(0)
    for i in 0..<text.len:
        let ch = text[i]
        if ch < '0' || ch > '9':
            return 0
        value = value * 10 + (Int32(ch) - Int32('0'))
    outOk = true
    return value

fn CompilerExportSurfaceFromReportText(text: str,
                                         out: var CsgExportSurface): Result[bool] =
    let packageId = compilerCsgLineValue(text, "package_id")
    let countText = compilerCsgLineValue(text, "exported_count")
    if countText.len <= 0:
        return Err[bool](" compiler csg: exported_count missing")
    var countOk = false
    let exportedCount = CompilerCsgParseUintText(countText, countOk)
    if !countOk:
        return Err[bool](strutil.Join([" compiler csg: invalid exported_count: ", countText], ""))
    out.exportedSymbols = []
    out.exportedTargetNames = []
    out.exportedLayouts = []
    out.exportedEffects = []
    out.exportedCapabilities = []
    let surfaceCidRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "surface_cid"))
    if IsErr(surfaceCidRes):
        return Err[bool](" compiler csg: invalid surface cid")
    let surfaceCid = Value(surfaceCidRes)
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if !CompilerCsgTextStartsWith(line, "export["):
            continue
        var eqPos = -1
        for j in 0..<line.len:
            if line[j] == '=':
                eqPos = j
                break
        if eqPos < 0 || eqPos + 1 >= line.len:
            continue
        let payload = strutil.SliceStr(line, eqPos + 1, line.len - 1)
        var firstSep = -1
        var secondSep = -1
        var thirdSep = -1
        var fourthSep = -1
        for j in 0..<payload.len:
            if payload[j] != '|':
                continue
            if firstSep < 0:
                firstSep = j
                continue
            if secondSep < 0:
                secondSep = j
                continue
            if thirdSep < 0:
                thirdSep = j
                continue
            if fourthSep < 0:
                fourthSep = j
                continue
            return Err[bool](" compiler csg: export row has too many separators")
        if firstSep <= 0 || secondSep <= firstSep + 1 || thirdSep <= secondSep + 1 || thirdSep >= payload.len - 1:
            return Err[bool](" compiler csg: export row separator positions invalid")
        add(out.exportedSymbols, strutil.SliceStr(payload, 0, firstSep - 1))
        var targetName = ""
        var layoutOk = false
        var effectOk = false
        var capabilityOk = false
        var layoutText = ""
        var effectText = ""
        var capabilityText = ""
        if fourthSep >= 0:
            if fourthSep <= thirdSep + 1 || fourthSep >= payload.len - 1:
                return Err[bool](" compiler csg: export row target separator invalid")
            targetName = strutil.SliceStr(payload, firstSep + 1, secondSep - 1)
            layoutText = strutil.SliceStr(payload, secondSep + 1, thirdSep - 1)
            effectText = strutil.SliceStr(payload, thirdSep + 1, fourthSep - 1)
            capabilityText = strutil.SliceStr(payload, fourthSep + 1, payload.len - 1)
        else:
            targetName = CompilerCsgTargetExportName(out.exportedSymbols[out.exportedSymbols.len - 1], "", "")
            layoutText = strutil.SliceStr(payload, firstSep + 1, secondSep - 1)
            effectText = strutil.SliceStr(payload, secondSep + 1, thirdSep - 1)
            capabilityText = strutil.SliceStr(payload, thirdSep + 1, payload.len - 1)
        let layoutValue = CompilerCsgParseUintText(layoutText, layoutOk)
        let effectValue = CompilerCsgParseUintText(effectText, effectOk)
        let capabilityValue = CompilerCsgParseUintText(capabilityText, capabilityOk)
        if !layoutOk || !effectOk || !capabilityOk:
            return Err[bool](" compiler csg: export row numeric field invalid")
        add(out.exportedTargetNames, targetName)
        add(out.exportedLayouts, layoutValue)
        add(out.exportedEffects, effectValue)
        add(out.exportedCapabilities, capabilityValue)
    if out.exportedSymbols.len != exportedCount:
        return Err[bool](strutil.Join([" compiler csg: export count mismatch parsed=", IntToStr(out.exportedSymbols.len), " expected=", IntToStr(exportedCount), " countText=", countText], ""))
    out.version = 1
    out.packageId = packageId
    out.exportedSymbolCount = exportedCount
    out.surfaceCid = surfaceCid
    return Ok[bool](true)

fn CompilerCsgGraphCidFromReportText(text: str): Result[layout.FixedBytes32] =
    let raw = compilerCsgLineValue(text, "graph_cid")
    if raw.len <= 0:
        return Err[layout.FixedBytes32](" compiler csg: graph_cid missing")
    return layout.FixedBytes32FromHex(raw)

fn CompilerCsgCanonicalGraphCidFromReportText(text: str): Result[layout.FixedBytes32] =
    let raw = compilerCsgLineValue(text, "canonical_graph_cid")
    if raw.len <= 0:
        return Err[layout.FixedBytes32](" compiler csg: canonical_graph_cid missing")
    return layout.FixedBytes32FromHex(raw)

fn CompileReceiptReport(receipt: CompileReceipt): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "world_head_cid=", layout.FixedBytes32Hex(receipt.worldHeadCid), "\n"], "")
    out = strutil.Join([out, "compiler_csg_cid=", layout.FixedBytes32Hex(receipt.compilerCsgCid), "\n"], "")
    out = strutil.Join([out, "canonical_compiler_csg_cid=", layout.FixedBytes32Hex(receipt.canonicalCompilerCsgCid), "\n"], "")
    out = strutil.Join([out, "target=", receipt.targetTriple, "\n"], "")
    out = strutil.Join([out, "output_digest=", layout.FixedBytes32Hex(receipt.outputDigest), "\n"], "")
    out = strutil.Join([out, "canonical_output_digest=", layout.FixedBytes32Hex(receipt.canonicalOutputDigest), "\n"], "")
    out = strutil.Join([out, "bootstrap_stage=", receipt.bootstrapStage, "\n"], "")
    out = strutil.Join([out, "runtime_provider_count=", IntToStr(receipt.runtimeProviderSet.len), "\n"], "")
    out = strutil.Join([out, "receipt_cid=", layout.FixedBytes32Hex(receipt.receiptCid)], "")
    for i in 0..<receipt.runtimeProviderSet.len:
        out = strutil.Join([out, "\n", CompileReceiptProviderReportLine(receipt.runtimeProviderSet[i], i)], "")
    return out

fn CompileReceiptProviderReportLine(provider: str,
                                      index: int32): str =
    var out = ""
    out = strutil.Join([out, "runtime_provider[", IntToStr(index), "]="], "")
    out = strutil.Join([out, provider], "")
    return out

fn CompileReceiptFromReportText(text: str,
                                  out: var CompileReceipt): Result[bool] =
    let worldHeadRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "world_head_cid"))
    if IsErr(worldHeadRes):
        return Err[bool](" compiler csg: invalid world_head_cid")
    let csgRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "compiler_csg_cid"))
    if IsErr(csgRes):
        return Err[bool](" compiler csg: invalid compiler_csg_cid")
    let canonicalCsgRaw = compilerCsgLineValue(text, "canonical_compiler_csg_cid")
    var canonicalCsgRes: Result[layout.FixedBytes32]
    if canonicalCsgRaw.len > 0:
        canonicalCsgRes = layout.FixedBytes32FromHex(canonicalCsgRaw)
    else:
        canonicalCsgRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "compiler_csg_cid"))
    if IsErr(canonicalCsgRes):
        return Err[bool](" compiler csg: invalid canonical_compiler_csg_cid")
    let digestRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "output_digest"))
    if IsErr(digestRes):
        return Err[bool](" compiler csg: invalid output_digest")
    let canonicalDigestRaw = compilerCsgLineValue(text, "canonical_output_digest")
    var canonicalDigestRes: Result[layout.FixedBytes32]
    if canonicalDigestRaw.len > 0:
        canonicalDigestRes = layout.FixedBytes32FromHex(canonicalDigestRaw)
    else:
        canonicalDigestRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "output_digest"))
    if IsErr(canonicalDigestRes):
        return Err[bool](" compiler csg: invalid canonical_output_digest")
    let receiptCidRes = layout.FixedBytes32FromHex(compilerCsgLineValue(text, "receipt_cid"))
    if IsErr(receiptCidRes):
        return Err[bool](" compiler csg: invalid receipt_cid")
    out.version = 1
    out.worldHeadCid = Value(worldHeadRes)
    out.compilerCsgCid = Value(csgRes)
    out.canonicalCompilerCsgCid = Value(canonicalCsgRes)
    out.targetTriple = compilerCsgLineValue(text, "target")
    out.outputDigest = Value(digestRes)
    out.canonicalOutputDigest = Value(canonicalDigestRes)
    out.bootstrapStage = compilerCsgLineValue(text, "bootstrap_stage")
    out.runtimeProviderSet = []
    let providerPrefix = "runtime_provider["
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        var providerLine = false
        if line.len >= providerPrefix.len:
            providerLine = true
            for j in 0..<providerPrefix.len:
                if line[j] != providerPrefix[j]:
                    providerLine = false
                    break
        if !providerLine:
            continue
        let parts = strutil.Split(line, '=')
        if parts.len < 2:
            continue
        add(out.runtimeProviderSet, parts[1])
    out.receiptCid = Value(receiptCidRes)
    return Ok[bool](true)

fn CompileReceiptRuntimeProviderSetEqual(left: str[],
                                           right: str[]): bool =
    if left.len != right.len:
        return false
    for i in 0..<left.len:
        if left[i] != right[i]:
            return false
    return true

fn CompileReceiptEquivalent(base: CompileReceipt,
                              next: CompileReceipt): bool =
    if !layout.FixedBytes32Equal(base.canonicalCompilerCsgCid, next.canonicalCompilerCsgCid):
        return false
    if base.targetTriple != next.targetTriple:
        return false
    if !layout.FixedBytes32Equal(base.canonicalOutputDigest, next.canonicalOutputDigest):
        return false
    if base.bootstrapStage != next.bootstrapStage:
        return false
    if !CompileReceiptRuntimeProviderSetEqual(base.runtimeProviderSet, next.runtimeProviderSet):
        return false
    return true

fn compilerCsgLineValue(text: str, key: str): str =
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        let line = strutil.Strip(lineRaw)
        var matchedPrefix = false
        if line.len > key.len:
            if Int32(line[key.len]) == 61:
                matchedPrefix = true
        if !matchedPrefix:
            continue
        var matched = true
        for j in 0..<key.len:
            if line[j] != key[j]:
                matched = false
                break
        if !matched:
            continue
        let valueRaw = strutil.SliceStr(line, key.len + 1, line.len - 1)
        let value = strutil.Strip(valueRaw)
        return value
    return ""
