fn CompilerCsgCloneStrSeq(items: str[]): str[] =
    var out: str[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn CompilerCsgCloneInt32Seq(items: int32[]): int32[] =
    var out: int32[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn CompilerLegacySourceUnitClone(unit: CompilerLegacySourceUnit): CompilerLegacySourceUnit =
    var out: CompilerLegacySourceUnit
    out.sourcePath = unit.sourcePath
    out.modulePath = unit.modulePath
    out.legacyText = unit.legacyText
    out.migratedText = unit.migratedText
    return out

fn CompilerLegacySourceUnitsClone(units: CompilerLegacySourceUnit[]): CompilerLegacySourceUnit[] =
    var out: CompilerLegacySourceUnit[]
    for i in 0..<units.len:
        add(out, CompilerLegacySourceUnitClone(units[i]))
    return out

fn CompilerCsgCloneNode(node: CompilerCsgNode): CompilerCsgNode =
    var out: CompilerCsgNode
    out.nodeId = node.nodeId
    out.nodeKind = node.nodeKind
    out.ownerNodeId = node.ownerNodeId
    out.modulePath = node.modulePath
    out.symbolText = node.symbolText
    out.factText = node.factText
    out.resultLayoutKind = node.resultLayoutKind
    out.effectKind = node.effectKind
    out.capabilityKind = node.capabilityKind
    out.callConv = node.callConv
    out.entryFlag = node.entryFlag
    out.exportedFlag = node.exportedFlag
    out.exportSymbolName = node.exportSymbolName
    out.factCid = node.factCid
    return out

fn CompilerCsgCloneNodes(nodes: CompilerCsgNode[]): CompilerCsgNode[] =
    var out: CompilerCsgNode[]
    for i in 0..<nodes.len:
        add(out, CompilerCsgCloneNode(nodes[i]))
    return out

fn CompilerCsgCloneEdge(edge: CompilerCsgEdge): CompilerCsgEdge =
    var out: CompilerCsgEdge
    out.edgeId = edge.edgeId
    out.fromNodeId = edge.fromNodeId
    out.toNodeId = edge.toNodeId
    out.edgeKind = edge.edgeKind
    out.edgeCid = edge.edgeCid
    return out

fn CompilerCsgCloneEdges(edges: CompilerCsgEdge[]): CompilerCsgEdge[] =
    var out: CompilerCsgEdge[]
    for i in 0..<edges.len:
        add(out, CompilerCsgCloneEdge(edges[i]))
    return out

fn CompilerCsgClone(csg: CompilerCsg): CompilerCsg =
    var out: CompilerCsg
    out.version = csg.version
    out.packageId = csg.packageId
    out.sourceBundleCid = csg.sourceBundleCid
    out.exprLayer = parser.NormalizedExprLayerClone(csg.exprLayer)
    out.typedExprFacts = texpr.TypedExprFactsClone(csg.typedExprFacts)
    out.typedIr = texpr.TypedExprIrClone(csg.typedIr)
    out.nodeCount = csg.nodeCount
    out.edgeCount = csg.edgeCount
    out.nodes = CompilerCsgCloneNodes(csg.nodes)
    out.edges = CompilerCsgCloneEdges(csg.edges)
    out.canonicalGraphCid = csg.canonicalGraphCid
    out.graphCid = csg.graphCid
    return out

fn CompilerExportSurfaceClone(surface: CsgExportSurface): CsgExportSurface =
    var out: CsgExportSurface
    out.version = surface.version
    out.packageId = surface.packageId
    out.exportedSymbolCount = surface.exportedSymbolCount
    out.exportedSymbols = CompilerCsgCloneStrSeq(surface.exportedSymbols)
    out.exportedTargetNames = CompilerCsgCloneStrSeq(surface.exportedTargetNames)
    out.exportedLayouts = CompilerCsgCloneInt32Seq(surface.exportedLayouts)
    out.exportedEffects = CompilerCsgCloneInt32Seq(surface.exportedEffects)
    out.exportedCapabilities = CompilerCsgCloneInt32Seq(surface.exportedCapabilities)
    out.surfaceCid = surface.surfaceCid
    return out

fn CompilerLegacyMigrationClone(migration: CompilerLegacyMigration): CompilerLegacyMigration =
    var out: CompilerLegacyMigration
    out.version = migration.version
    out.packageId = migration.packageId
    out.entrySourcePath = migration.entrySourcePath
    out.entryModulePath = migration.entryModulePath
    out.unitCount = migration.unitCount
    out.units = CompilerLegacySourceUnitsClone(migration.units)
    out.appliedRuleCount = migration.appliedRuleCount
    out.appliedRules = CompilerCsgCloneStrSeq(migration.appliedRules)
    out.legacySourceBundleCid = migration.legacySourceBundleCid
    out.migratedSourceBundleCid = migration.migratedSourceBundleCid
    out.compilerCsg = CompilerCsgClone(migration.compilerCsg)
    out.exportSurface = CompilerExportSurfaceClone(migration.exportSurface)
    out.migrationCid = migration.migrationCid
    return out

fn CompilerCsgAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn CompilerCsgAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(value))

fn CompilerCsgAppendText(buf: var layout.ByteBuf, text: str) =
    CompilerCsgAppendU32BE(buf, text.len)
    for i in 0..<text.len:
        layout.ByteBufAppendByte(buf, text[i])

fn CompilerCsgBufCid(buf: var layout.ByteBuf): layout.FixedBytes32 =
    let data = layout.ByteBufToBytes(buf)
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(data))

fn CompilerCsgHashNode(nodeKind: int32,
                         ownerNodeId: int32,
                         modulePath: str,
                         symbolText: str,
                         factText: str,
                         resultLayoutKind: int32,
                         effectKind: int32,
                         capabilityKind: int32,
                         callConv: int32,
                         entryFlag: int32,
                         exportedFlag: int32,
                         exportSymbolName: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.node")
    CompilerCsgAppendU32BE(buf, nodeKind)
    CompilerCsgAppendU32BE(buf, ownerNodeId)
    CompilerCsgAppendText(buf, modulePath)
    CompilerCsgAppendText(buf, symbolText)
    CompilerCsgAppendText(buf, factText)
    CompilerCsgAppendU32BE(buf, resultLayoutKind)
    CompilerCsgAppendU32BE(buf, effectKind)
    CompilerCsgAppendU32BE(buf, capabilityKind)
    CompilerCsgAppendU32BE(buf, callConv)
    CompilerCsgAppendU32BE(buf, entryFlag)
    CompilerCsgAppendU32BE(buf, exportedFlag)
    CompilerCsgAppendText(buf, exportSymbolName)
    return CompilerCsgBufCid(buf)

fn CompilerCsgHashEdge(fromNodeId: int32,
                         toNodeId: int32,
                         edgeKind: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.edge")
    CompilerCsgAppendU32BE(buf, fromNodeId)
    CompilerCsgAppendU32BE(buf, toNodeId)
    CompilerCsgAppendU32BE(buf, edgeKind)
    return CompilerCsgBufCid(buf)

fn CompilerCsgGraphCid(packageId: str,
                         sourceBundleCid: layout.FixedBytes32,
                         workspaceRoot: str,
                         packageRoot: str,
                         externalPackageRoots: parser.ParserExternalPackageRoot[],
                         overrides: CompilerCsgSourceText[],
                         exprLayer: parser.NormalizedExprLayer,
                         typedExprFacts: TypedExprFact[],
                         nodes: CompilerCsgNode[],
                         edges: CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.graph")
    CompilerCsgAppendText(buf, packageId)
    CompilerCsgAppendFixed32(buf, sourceBundleCid)
    let _ = workspaceRoot
    let _ = packageRoot
    let _ = externalPackageRoots
    let _ = overrides
    CompilerCsgAppendU32BE(buf, exprLayer.sourceCount)
    CompilerCsgAppendU32BE(buf, exprLayer.exprs.len)
    CompilerCsgAppendU32BE(buf, exprLayer.questionResidualCount)
    CompilerCsgAppendU32BE(buf, typedExprFacts.len)
    CompilerCsgAppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let node = nodes[i]
        CompilerCsgAppendU32BE(buf, node.nodeId)
        CompilerCsgAppendFixed32(buf, node.factCid)
    CompilerCsgAppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let edge = edges[i]
        CompilerCsgAppendU32BE(buf, edge.edgeId)
        CompilerCsgAppendFixed32(buf, edge.edgeCid)
    return CompilerCsgBufCid(buf)

fn CompilerCsgCanonicalGraphCid(packageId: str,
                                  sourceBundleCid: layout.FixedBytes32,
                                  workspaceRoot: str,
                                  packageRoot: str,
                                  externalPackageRoots: parser.ParserExternalPackageRoot[],
                                  overrides: CompilerCsgSourceText[],
                                  exprLayer: parser.NormalizedExprLayer,
                                  typedExprFacts: TypedExprFact[],
                                  nodes: CompilerCsgNode[],
                                  edges: CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    CompilerCsgAppendText(buf, "cheng.compiler.csg.canonical_graph")
    CompilerCsgAppendText(buf, packageId)
    let _ = sourceBundleCid
    let _ = workspaceRoot
    let _ = packageRoot
    let _ = externalPackageRoots
    let _ = overrides
    let _ = exprLayer
    let _ = typedExprFacts
    CompilerCsgAppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let node = nodes[i]
        CompilerCsgAppendU32BE(buf, node.nodeId)
        CompilerCsgAppendFixed32(buf, node.factCid)
    CompilerCsgAppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let edge = edges[i]
        CompilerCsgAppendU32BE(buf, edge.edgeId)
        CompilerCsgAppendFixed32(buf, edge.edgeCid)
    return CompilerCsgBufCid(buf)

fn CompilerCsgAddUnique(items: var str[],
                          text: str) =
    for i in 0..<items.len:
        if items[i] == text:
            return
    add(items, text)

fn CompilerCsgTextSetInit(minCap: int32): CompilerCsgTextSet =
    var out: CompilerCsgTextSet
    out.lookup = parser.ParserTextLookupInit(minCap)
    return out

fn CompilerCsgTextSetInsert(seen: var CompilerCsgTextSet,
                              text: str): bool =
    if text == "":
        if seen.emptySeen:
            return false
        seen.emptySeen = true
        return true
    return parser.ParserTextLookupInsertExact(seen.lookup, text)

fn CompilerCsgAddUniqueFast(items: var str[],
                              seen: var CompilerCsgTextSet,
                              text: str) =
    if CompilerCsgTextSetInsert(seen, text):
        add(items, text)

fn CompilerCsgStrLess(left: str,
                        right: str): bool =
    if left == right:
        return false
    let leftLen = left.len
    let rightLen = right.len
    let sharedLen = leftLen < rightLen ? leftLen : rightLen
    for i in 0..<sharedLen:
        if left[i] == right[i]:
            continue
        return left[i] < right[i]
    return leftLen < rightLen

fn CompilerCsgSortStrs(items: var str[]) =
    if items.len <= 1:
        return
    let count = items.len
    var scratch: str[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(scratch, items[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortStrsPass(scratch, items, width)
        else:
            CompilerCsgMergeSortStrsPass(items, scratch, width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            items[i] = scratch[i]

fn CompilerCsgMergeSortStrsPass(src: var str[],
                                  dst: var str[],
                                  width: int32) =
    let count = src.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid && (right >= rightEnd || !CompilerCsgStrLess(src[right], src[left])):
                dst[outIndex] = src[left]
                left = left + 1
            else:
                dst[outIndex] = src[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgSourcePathModulePairLess(leftSource: str,
                                         leftModule: str,
                                         rightSource: str,
                                         rightModule: str): bool =
    if leftModule != rightModule:
        return CompilerCsgStrLess(leftModule, rightModule)
    return CompilerCsgStrLess(leftSource, rightSource)

fn CompilerCsgSortSourcePathModulePairs(sources: var str[],
                                         modules: var str[]) =
    if sources.len <= 1:
        return
    let count = sources.len
    var sourceScratch: str[]
    var moduleScratch: str[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(sourceScratch, sources[i])
        add(moduleScratch, modules[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortSourcePathModulePairsPass(sourceScratch,
                                                           moduleScratch,
                                                           sources,
                                                           modules,
                                                           width)
        else:
            CompilerCsgMergeSortSourcePathModulePairsPass(sources,
                                                           modules,
                                                           sourceScratch,
                                                           moduleScratch,
                                                           width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            sources[i] = sourceScratch[i]
            modules[i] = moduleScratch[i]

fn CompilerCsgMergeSortSourcePathModulePairsPass(srcSources: var str[],
                                                   srcModules: var str[],
                                                   dstSources: var str[],
                                                   dstModules: var str[],
                                                   width: int32) =
    let count = srcSources.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid &&
               (right >= rightEnd ||
                !CompilerCsgSourcePathModulePairLess(srcSources[right],
                                                     srcModules[right],
                                                     srcSources[left],
                                                     srcModules[left])):
                dstSources[outIndex] = srcSources[left]
                dstModules[outIndex] = srcModules[left]
                left = left + 1
            else:
                dstSources[outIndex] = srcSources[right]
                dstModules[outIndex] = srcModules[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgAddUniqueImportPair(pairs: var CompilerCsgImportPair[],
                                    ownerModulePath: str,
                                    targetModulePath: str) =
    for i in 0..<pairs.len:
        if pairs[i].ownerModulePath != ownerModulePath:
            continue
        if pairs[i].targetModulePath != targetModulePath:
            continue
        return
    add(pairs, CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                       targetModulePath: targetModulePath))

fn CompilerCsgTextHash(text: str): int32 =
    var h: int32
    for i in 0..<text.len:
        h = h * 131 + Int32(text[i])
    if h < 0:
        h = -h
    return h

fn CompilerCsgTextFirstCode(text: str): int32 =
    if text.len <= 0:
        return 0
    return Int32(text[0])

fn CompilerCsgTextLastCode(text: str): int32 =
    if text.len <= 0:
        return 0
    return Int32(text[text.len - 1])

fn CompilerCsgImportPairLookupInit(minCap: int32): CompilerCsgImportPairLookup =
    var lookup: CompilerCsgImportPairLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    for i in 0..<cap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(lookup.slots, 0)
    return lookup

fn CompilerCsgImportPairLookupHash(ownerLen: int32,
                                     ownerFirstCode: int32,
                                     ownerLastCode: int32,
                                     ownerHash: int32,
                                     targetLen: int32,
                                     targetFirstCode: int32,
                                     targetLastCode: int32,
                                     targetHash: int32): int64 =
    var h: int64 = Int64(ownerHash)
    h = h * 131 + Int64(ownerLen)
    h = h * 131 + Int64(ownerFirstCode)
    h = h * 131 + Int64(ownerLastCode)
    h = h * 131 + Int64(targetHash)
    h = h * 131 + Int64(targetLen)
    h = h * 131 + Int64(targetFirstCode)
    h = h * 131 + Int64(targetLastCode)
    if h < 0:
        h = -h
    return h

fn CompilerCsgImportPairLookupSlotForParts(lookup: CompilerCsgImportPairLookup,
                                             ownerLen: int32,
                                             ownerFirstCode: int32,
                                             ownerLastCode: int32,
                                             ownerHash: int32,
                                             targetLen: int32,
                                             targetFirstCode: int32,
                                             targetLastCode: int32,
                                             targetHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = Int32(CompilerCsgImportPairLookupHash(ownerLen,
                                                               ownerFirstCode,
                                                               ownerLastCode,
                                                               ownerHash,
                                                               targetLen,
                                                               targetFirstCode,
                                                               targetLastCode,
                                                               targetHash) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucketIndex = bucketIndexPlus1 - 1
        if lookup.buckets[bucketIndex].ownerLen == ownerLen &&
           lookup.buckets[bucketIndex].ownerFirstCode == ownerFirstCode &&
           lookup.buckets[bucketIndex].ownerLastCode == ownerLastCode &&
           lookup.buckets[bucketIndex].ownerHash == ownerHash &&
           lookup.buckets[bucketIndex].targetLen == targetLen &&
           lookup.buckets[bucketIndex].targetFirstCode == targetFirstCode &&
           lookup.buckets[bucketIndex].targetLastCode == targetLastCode &&
           lookup.buckets[bucketIndex].targetHash == targetHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn CompilerCsgImportPairLookupRehash(lookup: var CompilerCsgImportPairLookup,
                                       newCap: int32) =
    var slots: int32[]
    for i in 0..<newCap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(slots, 0)
    lookup.slots = slots
    for bucketIndex in 0..<lookup.buckets.len:
        if bucketIndex % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let slot = CompilerCsgImportPairLookupSlotForParts(lookup,
                                                            lookup.buckets[bucketIndex].ownerLen,
                                                            lookup.buckets[bucketIndex].ownerFirstCode,
                                                            lookup.buckets[bucketIndex].ownerLastCode,
                                                            lookup.buckets[bucketIndex].ownerHash,
                                                            lookup.buckets[bucketIndex].targetLen,
                                                            lookup.buckets[bucketIndex].targetFirstCode,
                                                            lookup.buckets[bucketIndex].targetLastCode,
                                                            lookup.buckets[bucketIndex].targetHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1

fn CompilerCsgImportPairLookupGrow(lookup: var CompilerCsgImportPairLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    CompilerCsgImportPairLookupRehash(lookup, nextCap)

fn CompilerCsgImportPairLookupEnsureBucket(lookup: var CompilerCsgImportPairLookup,
                                             ownerModulePath: str,
                                             targetModulePath: str): int32 =
    if lookup.slots.len <= 0:
        lookup = CompilerCsgImportPairLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        CompilerCsgImportPairLookupGrow(lookup)
    let ownerLen = ownerModulePath.len
    let ownerFirstCode = CompilerCsgTextFirstCode(ownerModulePath)
    let ownerLastCode = CompilerCsgTextLastCode(ownerModulePath)
    let ownerHash = CompilerCsgTextHash(ownerModulePath)
    let targetLen = targetModulePath.len
    let targetFirstCode = CompilerCsgTextFirstCode(targetModulePath)
    let targetLastCode = CompilerCsgTextLastCode(targetModulePath)
    let targetHash = CompilerCsgTextHash(targetModulePath)
    let slot = CompilerCsgImportPairLookupSlotForParts(lookup,
                                                        ownerLen,
                                                        ownerFirstCode,
                                                        ownerLastCode,
                                                        ownerHash,
                                                        targetLen,
                                                        targetFirstCode,
                                                        targetLastCode,
                                                        targetHash)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: CompilerCsgImportPairLookupBucket
    bucket.ownerLen = ownerLen
    bucket.ownerFirstCode = ownerFirstCode
    bucket.ownerLastCode = ownerLastCode
    bucket.ownerHash = ownerHash
    bucket.targetLen = targetLen
    bucket.targetFirstCode = targetFirstCode
    bucket.targetLastCode = targetLastCode
    bucket.targetHash = targetHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn CompilerCsgImportPairLookupInsert(lookup: var CompilerCsgImportPairLookup,
                                       ownerModulePath: str,
                                       targetModulePath: str): bool =
    let bucketIndex = CompilerCsgImportPairLookupEnsureBucket(lookup,
                                                               ownerModulePath,
                                                               targetModulePath)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        let item = lookup.buckets[bucketIndex].items[i]
        if item.ownerModulePath == ownerModulePath &&
           item.targetModulePath == targetModulePath:
            return false
    add(lookup.buckets[bucketIndex].items,
        CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                targetModulePath: targetModulePath))
    return true

fn CompilerCsgAddUniqueImportPairFast(pairs: var CompilerCsgImportPair[],
                                        seen: var CompilerCsgImportPairLookup,
                                        ownerModulePath: str,
                                        targetModulePath: str) =
    if CompilerCsgImportPairLookupInsert(seen,
                                          ownerModulePath,
                                          targetModulePath):
        add(pairs, CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                           targetModulePath: targetModulePath))

fn CompilerCsgImportPairLess(left: CompilerCsgImportPair,
                               right: CompilerCsgImportPair): bool =
    if left.ownerModulePath != right.ownerModulePath:
        return CompilerCsgStrLess(left.ownerModulePath, right.ownerModulePath)
    return CompilerCsgStrLess(left.targetModulePath, right.targetModulePath)

fn CompilerCsgSortImportPairs(pairs: var CompilerCsgImportPair[]) =
    if pairs.len <= 1:
        return
    let count = pairs.len
    var scratch: CompilerCsgImportPair[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(scratch, pairs[i])
    var width: int32 = 1
    var readScratch = false
    while width < count:
        if readScratch:
            CompilerCsgMergeSortImportPairsPass(scratch, pairs, width)
        else:
            CompilerCsgMergeSortImportPairsPass(pairs, scratch, width)
        readScratch = !readScratch
        if width > count / 2:
            width = count
        else:
            width = width * 2
    if readScratch:
        for i in 0..<count:
            if i % 4096 == 0:
                os.ProcessResourceGuardCheck()
            pairs[i] = scratch[i]

fn CompilerCsgMergeSortImportPairsPass(src: var CompilerCsgImportPair[],
                                         dst: var CompilerCsgImportPair[],
                                         width: int32) =
    let count = src.len
    var leftStart: int32
    while leftStart < count:
        if leftStart % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let midRaw = leftStart + width
        let mid = midRaw < count ? midRaw : count
        let rightEndRaw = leftStart + width * 2
        let rightEnd = rightEndRaw < count ? rightEndRaw : count
        var left = leftStart
        var right = mid
        for outIndex in leftStart..<rightEnd:
            if outIndex % 4096 == 0:
                os.ProcessResourceGuardCheck()
            if left < mid && (right >= rightEnd || !CompilerCsgImportPairLess(src[right], src[left])):
                dst[outIndex] = src[left]
                left = left + 1
            else:
                dst[outIndex] = src[right]
                right = right + 1
        leftStart = leftStart + width * 2

fn CompilerCsgModuleNodeId(nodes: CompilerCsgNode[],
                             modulePath: str): int32 =
    for i in 0..<nodes.len:
        let node = nodes[i]
        if node.nodeKind != CompilerCsgNodeKindModule:
            continue
        if node.modulePath == modulePath:
            return node.nodeId
    return -1

fn CompilerCsgModuleIndex(modules: str[],
                            modulePath: str): int32 =
    var lo: int32
    var hi = modules.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let item = modules[mid]
        if item == modulePath:
            return mid
        if CompilerCsgStrLess(item, modulePath):
            lo = mid + 1
        else:
            hi = mid
    return -1

fn CompilerCsgModuleNodeIdIndexed(modules: str[],
                                    moduleNodeIds: int32[],
                                    modulePath: str): int32 =
    let index = CompilerCsgModuleIndex(modules, modulePath)
    if index < 0 || index >= moduleNodeIds.len:
        return -1
    return moduleNodeIds[index]

fn CompilerCsgSymbolExported(functionName: str,
                               entryFlag: int32): bool =
    let _ = entryFlag
    if functionName.len <= 0:
        return false
    let ch = functionName[0]
    return ch >= 'A' && ch <= 'Z'

fn CompilerCsgFindText(text: str,
                         needle: str): int32 =
    if needle.len <= 0:
        return 0
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn CompilerCsgTargetExportName(symbolText: str,
                                 explicitExportName: str,
                                 functionName: str): str =
    if explicitExportName.len > 0:
        return explicitExportName
    if functionName.len > 0:
        return functionName
    let suffixPos = CompilerCsgFindText(symbolText, "::")
    if suffixPos < 0:
        return symbolText
    return chengpath.TextSlice(symbolText, suffixPos + 2, symbolText.len - (suffixPos + 2))

fn CompilerCsgShouldExportSymbol(emitKind: creq.CompilerEmit,
                                   entrySourceFlag: bool,
                                   entryHasExplicitExports: bool,
                                   explicitExportName: str,
                                   functionName: str,
                                   entryFlag: int32): bool =
    if emitKind != creq.EmitShared && emitKind != creq.EmitObj:
        if explicitExportName.len > 0:
            return true
        return CompilerCsgSymbolExported(functionName, entryFlag)
    if !entrySourceFlag:
        return false
    if entryHasExplicitExports:
        return explicitExportName.len > 0
    return true

fn CompilerCsgExportRootNameMatches(root: str,
                                      candidate: str): bool =
    if root == candidate:
        return true
    if len(root) > 1 && root[0] == '_':
        let strippedRoot = chengpath.TextSlice(root, 1, len(root) - 1)
        if strippedRoot == candidate:
            return true
    if len(candidate) > 1 && candidate[0] == '_':
        let strippedCandidate = chengpath.TextSlice(candidate, 1, len(candidate) - 1)
        if root == strippedCandidate:
            return true
    return false

fn CompilerCsgExportRootSelected(roots: str[],
                                  symbolText: str,
                                  explicitExportName: str,
                                  functionName: str): bool =
    if roots.len <= 0:
        return true
    let targetName = CompilerCsgTargetExportName(symbolText,
                                                 explicitExportName,
                                                 functionName)
    for i in 0..<roots.len:
        let root = roots[i]
        if CompilerCsgExportRootNameMatches(root, targetName):
            return true
        if CompilerCsgExportRootNameMatches(root, functionName):
            return true
        if CompilerCsgExportRootNameMatches(root, symbolText):
            return true
    return false

fn CompilerCsgSourceTextLookup(overrides: CompilerCsgSourceText[],
                                 sourcePath: str,
                                 out: var str): bool =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        out = overrides[i].text
        return true
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    for i in 0..<overrides.len:
        let overrideSourcePath = parser.ParserNormalizePath(overrides[i].sourcePath)
        if overrideSourcePath != normalizedSourcePath:
            continue
        out = overrides[i].text
        return true
    return false

fn CompilerCsgSourceTextLookupBuild(overrides: CompilerCsgSourceText[]): CompilerCsgSourceTextLookupEntry[] =
    var out: CompilerCsgSourceTextLookupEntry[]
    for i in 0..<overrides.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        var entry: CompilerCsgSourceTextLookupEntry
        entry.sourcePath = overrides[i].sourcePath
        entry.normalizedSourcePath = parser.ParserNormalizePath(overrides[i].sourcePath)
        entry.modulePath = overrides[i].modulePath
        entry.text = overrides[i].text
        add(out, entry)
    return out

fn CompilerCsgSourceTextLookupFast(overrides: CompilerCsgSourceTextLookupEntry[],
                                    sourcePath: str,
                                    normalizedSourcePath: str,
                                    out: var str): bool =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        out = overrides[i].text
        return true
    for i in 0..<overrides.len:
        if overrides[i].normalizedSourcePath != normalizedSourcePath:
            continue
        out = overrides[i].text
        return true
    return false

fn CompilerCsgRestoreSourceTextOverrides(overrides: CompilerCsgSourceText[],
                                           sourceTexts: var TypedExprSourceText[]) =
    for i in 0..<sourceTexts.len:
        var sourceText = sourceTexts[i]
        var overrideText = ""
        if !CompilerCsgSourceTextLookup(overrides, sourceText.sourcePath, overrideText):
            continue
        sourceText.text = overrideText
        sourceTexts[i] = sourceText

fn CompilerCsgRestoreSourceTextOverridesFast(overrides: CompilerCsgSourceTextLookupEntry[],
                                               sourceTexts: var TypedExprSourceText[]) =
    for i in 0..<sourceTexts.len:
        var sourceText = sourceTexts[i]
        let normalizedSourcePath = parser.ParserNormalizePath(sourceText.sourcePath)
        var overrideText = ""
        if !CompilerCsgSourceTextLookupFast(overrides,
                                             sourceText.sourcePath,
                                             normalizedSourcePath,
                                             overrideText):
            continue
        sourceText.text = overrideText
        sourceTexts[i] = sourceText

fn CompilerCsgSourceModulePath(workspaceRoot: str,
                                 packageRoot: str,
                                 externalPackageRoots: parser.ParserExternalPackageRoot[],
                                 overrides: CompilerCsgSourceText[],
                                 sourcePath: str): str =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        if overrides[i].modulePath.len > 0:
            return overrides[i].modulePath
    return parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                         packageRoot,
                                                                         externalPackageRoots,
                                                                         sourcePath)

fn CompilerCsgSourceModulePathFast(workspaceRoot: str,
                                    packageRoot: str,
                                    externalPackageRoots: parser.ParserExternalPackageRoot[],
                                    overrides: CompilerCsgSourceTextLookupEntry[],
                                    sourcePath: str): str =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        if overrides[i].modulePath.len > 0:
            return overrides[i].modulePath
    return parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                        packageRoot,
                                                                        externalPackageRoots,
                                                                        sourcePath)

fn CompilerCsgIsBrowserAbiSupportModule(modulePath: str): bool =
    if modulePath == browsercodec.BrowserContentCodecModulePath():
        return true
    if modulePath == "cheng/libp2p/browser/browser_content_codec_codegen":
        return true
    if modulePath == "cheng/libp2p/browser/browser_content_codec_rule_schema":
        return true
    if modulePath == browserprobe.BrowserHostProbeModulePath():
        return true
    if modulePath == "cheng/libp2p/browser/browser_host_probe_codegen":
        return true
    if modulePath == "cheng/libp2p/browser/browser_host_probe_rule_schema":
        return true
    return modulePath == "cheng/core/lang/browser_abi_rule"

fn CompilerCsgAddBrowserAbiRulesForSource(rules: var BrowserAbiRule[],
                                            linkPlan: slplan.SystemLinkPlanStub,
                                            ownerModulePath: str,
                                            sourcePath: str) =
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    let normalizedEntryPath = parser.ParserNormalizePath(linkPlan.entryPath)
    if normalizedSourcePath == normalizedEntryPath:
        if ownerModulePath == browsercodec.BrowserContentCodecModulePath():
            let codecRules = browsercodec.BrowserContentCodecRules(normalizedSourcePath)
            for i in 0..<codecRules.len:
                add(rules, BrowserAbiRuleClone(codecRules[i]))
            return
        if ownerModulePath == browserprobe.BrowserHostProbeModulePath():
            let probeRules = browserprobe.BrowserHostProbeRules(normalizedSourcePath)
            for i in 0..<probeRules.len:
                add(rules, BrowserAbiRuleClone(probeRules[i]))
            return
    if ownerModulePath == browsercodec.BrowserContentCodecModulePath():
        let codecRuleNames = browsercodec.BrowserContentCodecRuleNames()
        for i in 0..<codecRuleNames.len:
            let triggerNames = browsercodec.BrowserContentCodecRuleTriggerNames(codecRuleNames[i])
            var used = false
            for j in 0..<linkPlan.sourceClosurePaths.len:
                let currentSourcePath = parser.ParserNormalizePath(linkPlan.sourceClosurePaths[j])
                if currentSourcePath == normalizedSourcePath:
                    continue
                let currentModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                                       linkPlan.packageRoot,
                                                                                                       externalPackageRoots,
                                                                                                       currentSourcePath)
                if CompilerCsgIsBrowserAbiSupportModule(currentModulePath):
                    continue
                let text = chengpath.ReadTextFile("", currentSourcePath)
                for k in 0..<triggerNames.len:
                    let triggerCall = Fmt"{triggerNames[k]}("
                    if strutil.Contains(text, triggerCall):
                        used = true
                        break
                if used:
                    break
            if used:
                add(rules, browsercodec.BrowserContentCodecRuleByName(normalizedSourcePath,
                                                                        codecRuleNames[i]))
        return
    if ownerModulePath == browserprobe.BrowserHostProbeModulePath():
        let probeRuleNames = browserprobe.BrowserHostProbeRuleNames()
        for i in 0..<probeRuleNames.len:
            let triggerNames = browserprobe.BrowserHostProbeRuleTriggerNames(probeRuleNames[i])
            var used = false
            for j in 0..<linkPlan.sourceClosurePaths.len:
                let currentSourcePath = parser.ParserNormalizePath(linkPlan.sourceClosurePaths[j])
                if currentSourcePath == normalizedSourcePath:
                    continue
                let currentModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                                       linkPlan.packageRoot,
                                                                                                       externalPackageRoots,
                                                                                                       currentSourcePath)
                if CompilerCsgIsBrowserAbiSupportModule(currentModulePath):
                    continue
                let text = chengpath.ReadTextFile("", currentSourcePath)
                for k in 0..<triggerNames.len:
                    let triggerCall = Fmt"{triggerNames[k]}("
                    if strutil.Contains(text, triggerCall):
                        used = true
                        break
                if used:
                    break
            if used:
                add(rules, browserprobe.BrowserHostProbeRuleByName(normalizedSourcePath,
                                                                     probeRuleNames[i]))
        return

fn CompilerBrowserAbiRulesForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiRule[] =
    var out: BrowserAbiRule[]
    var orderedSources: str[]
    var orderedModules: str[]
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let sourcePath = linkPlan.sourceClosurePaths[i]
        add(orderedSources, sourcePath)
        add(orderedModules,
            parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                          linkPlan.packageRoot,
                                                                          externalPackageRoots,
                                                                          sourcePath))
    CompilerCsgSortSourcePathModulePairs(orderedSources, orderedModules)
    for i in 0..<orderedSources.len:
        let sourcePath = orderedSources[i]
        let ownerModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                             linkPlan.packageRoot,
                                                                                             externalPackageRoots,
                                                                                             sourcePath)
        CompilerCsgAddBrowserAbiRulesForSource(out, linkPlan, ownerModulePath, sourcePath)
    return out

fn CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiBridgeSpec[] =
    let rules = CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    return BrowserAbiBridgeSpecsFromRules(rules)

fn CompilerBrowserAbiBridgeSpecsForSource(linkPlan: slplan.SystemLinkPlanStub,
                                            sourcePathRaw: str): BrowserAbiBridgeSpec[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let specs = CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    return BrowserAbiBridgeSpecsForSource(specs, sourcePath)

fn CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): BrowserAbiBridgePlan[] =
    let specs = CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    return BrowserAbiBridgePlansFromSpecs(specs)

fn CompilerBrowserAbiBridgePlansForSource(linkPlan: slplan.SystemLinkPlanStub,
                                            sourcePathRaw: str): BrowserAbiBridgePlan[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let plans = CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    return BrowserAbiBridgePlansForSource(plans, sourcePath)

fn CompilerLegacyLineIndentAt(rawLine: str,
                                stop: int32): str =
    let n = rawLine.len
    if stop >= n:
        return rawLine
    for i in stop..<n:
        let code = Int32(rawLine[i])
        if code == 32 || code == 9:
            continue
        return chengpath.TextSlice(rawLine, 0, i)
    return rawLine

fn CompilerLegacyLineIndent(rawLine: str): str =
    return CompilerLegacyLineIndentAt(rawLine, 0)

fn CompilerLegacyFindMatchingBracket(text: str,
                                       openIndex: int32): int32 =
    return CompilerLegacyFindMatchingBracketStep(text, openIndex, 0)

fn CompilerLegacyFindMatchingBracketStep(text: str,
                                           index: int32,
                                           depth: int32): int32 =
    let n = text.len
    var currentDepth = depth
    for i in index..<n:
        let code = Int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            let nextDepth = currentDepth - 1
            if nextDepth == 0:
                return i
            currentDepth = nextDepth
    return -1

fn CompilerLegacyTopLevelComma(text: str): int32 =
    return CompilerLegacyTopLevelCommaStep(text, 0, 0)

fn CompilerLegacyTopLevelCommaStep(text: str,
                                     index: int32,
                                     depth: int32): int32 =
    let n = text.len
    var currentDepth = depth
    for i in index..<n:
        let code = Int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            currentDepth = currentDepth - 1
            continue
        if code == 44 && currentDepth == 0:
            return i
    return -1

fn CompilerLegacyRewriteSeqTypes(textRaw: str,
                                   outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < text.len:
        if i + 4 > text.len:
            break
        if chengpath.TextSlice(text, i, 4) != "seq[":
            i = i + 1
            continue
        let closePos = CompilerLegacyFindMatchingBracket(text, i + 3)
        if closePos <= i + 3:
            i = i + 1
            continue
        let inner = chengpath.TextSlice(text, i + 4, closePos - (i + 4))
        let replacement = strutil.Join([strutil.Strip(inner), "[]"], "")
        let prefix = chengpath.TextSlice(text, 0, i)
        let suffix = chengpath.TextSlice(text, closePos + 1, text.len - (closePos + 1))
        var rewritten = strutil.Join([prefix, replacement], "")
        rewritten = strutil.Join([rewritten, suffix], "")
        text = rewritten
        outAppliedCount = outAppliedCount + 1
        i = i + replacement.len
    return text

fn CompilerLegacyRewriteArrayTypes(textRaw: str,
                                     outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < text.len:
        if i + 6 > text.len:
            break
        if chengpath.TextSlice(text, i, 6) != "array[":
            i = i + 1
            continue
        let closePos = CompilerLegacyFindMatchingBracket(text, i + 5)
        if closePos <= i + 5:
            i = i + 1
            continue
        let inner = chengpath.TextSlice(text, i + 6, closePos - (i + 6))
        let commaPos = CompilerLegacyTopLevelComma(inner)
        if commaPos <= 0:
            i = i + 1
            continue
        let elemText = strutil.Strip(chengpath.TextSlice(inner, 0, commaPos))
        let lenText = strutil.Strip(chengpath.TextSlice(inner, commaPos + 1, inner.len - (commaPos + 1)))
        let replacement = strutil.Join([elemText, "[", lenText, "]"], "")
        let prefix = chengpath.TextSlice(text, 0, i)
        let suffix = chengpath.TextSlice(text, closePos + 1, text.len - (closePos + 1))
        var rewritten = strutil.Join([prefix, replacement], "")
        rewritten = strutil.Join([rewritten, suffix], "")
        text = rewritten
        outAppliedCount = outAppliedCount + 1
        i = i + replacement.len
    return text

fn CompilerLegacyNormalizeText(textRaw: str,
                                 outAppliedRules: var str[],
                                 outAppliedCount: var int32): str =
    outAppliedRules = []
    outAppliedCount = 0
    var text = textRaw
    let elseIfText = strutil.Replace(text, "else if", "elif")
    if elseIfText != text:
        CompilerCsgAddUnique(outAppliedRules, "else_if_to_elif")
        outAppliedCount = outAppliedCount + 1
        text = elseIfText
    let atListText = strutil.Replace(text, "@[]", "[]")
    if atListText != text:
        CompilerCsgAddUnique(outAppliedRules, "at_list_to_list")
        outAppliedCount = outAppliedCount + 1
        text = atListText
    var seqApplied = 0
    text = CompilerLegacyRewriteSeqTypes(text, seqApplied)
    if seqApplied > 0:
        CompilerCsgAddUnique(outAppliedRules, "seq_type_to_suffix")
        outAppliedCount = outAppliedCount + seqApplied
    var arrayApplied = 0
    text = CompilerLegacyRewriteArrayTypes(text, arrayApplied)
    if arrayApplied > 0:
        CompilerCsgAddUnique(outAppliedRules, "array_type_to_suffix")
        outAppliedCount = outAppliedCount + arrayApplied
    let lines = parser.ParserSplitChar(text, '\n')
    var out = ""
    for i in 0..<lines.len:
        var line = lines[i]
        let trimmed = chengpath.PathTrim(line)
        let indent = CompilerLegacyLineIndent(line)
        if chengpath.TextStartsWith(trimmed, "proc "):
            CompilerCsgAddUnique(outAppliedRules, "proc_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 5, trimmed.len - 5)], "")
        elif chengpath.TextStartsWith(trimmed, "method "):
            CompilerCsgAddUnique(outAppliedRules, "method_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 7, trimmed.len - 7)], "")
        elif chengpath.TextStartsWith(trimmed, "converter "):
            CompilerCsgAddUnique(outAppliedRules, "converter_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = strutil.Join([indent, "fn ", chengpath.TextSlice(trimmed, 10, trimmed.len - 10)], "")
        if i > 0:
            out = strutil.Join([out, "\n"], "")
        out = strutil.Join([out, line], "")
    return out

fn CompilerLegacyPackageId(modulePathRaw: str): str =
    let parts = parser.ParserSplitChar(chengpath.PathTrim(modulePathRaw), '/')
    if parts.len >= 2:
        return strutil.Join([parts[0], "/", parts[1]], "")
    if parts.len == 1:
        return parts[0]
    return "legacy"

fn CompilerCsgAddUniqueImportEdge(edges: var parser.ImportEdge[],
                                    edge: parser.ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn CompilerLegacyCollectClosure(workspaceRoot: str,
                                  packageRoot: str,
                                  sourcePathRaw: str,
                                  entryModulePathOverride: str,
                                  seen: var str[],
                                  units: var CompilerLegacySourceUnit[],
                                  ownerModulePaths: var str[],
                                  importEdges: var parser.ImportEdge[],
                                  outAppliedRules: var str[],
                                  outAppliedCount: var int32,
                                  unresolvedImportCount: var int32,
                                  err: var str): bool =
    let sourcePath = chengpath.PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = " compiler migration: missing legacy source path"
        return false
    for i in 0..<seen.len:
        if seen[i] == sourcePath:
            err = ""
            return true
    if !chengpath.PathFileExists(sourcePath):
        err = strutil.Join([" compiler migration: missing legacy source: ", sourcePath], "")
        return false
    add(seen, sourcePath)
    let legacyText = chengpath.ReadTextFile("", sourcePath)
    var localRules: str[]
    var localAppliedCount = 0
    let migratedText = CompilerLegacyNormalizeText(legacyText, localRules, localAppliedCount)
    var modulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    if entryModulePathOverride.len > 0:
        if sourcePath == seen[0]:
            modulePath = entryModulePathOverride
    var unit: CompilerLegacySourceUnit
    unit.sourcePath = sourcePath
    unit.modulePath = modulePath
    unit.legacyText = legacyText
    unit.migratedText = migratedText
    add(units, unit)
    CompilerCsgAddUnique(ownerModulePaths, modulePath)
    for i in 0..<localRules.len:
        CompilerCsgAddUnique(outAppliedRules, localRules[i])
    outAppliedCount = outAppliedCount + localAppliedCount
    var localEdges: parser.ImportEdge[]
    if !parser.ParserReadImportEdges(workspaceRoot, packageRoot, modulePath, migratedText, localEdges, err):
        return false
    for i in 0..<localEdges.len:
        let edge = localEdges[i]
        CompilerCsgAddUniqueImportEdge(importEdges, edge)
        if edge.resolved:
            CompilerCsgAddUnique(ownerModulePaths, edge.targetModulePath)
            if !CompilerLegacyCollectClosure(workspaceRoot,
                                               packageRoot,
                                               edge.targetSourcePath,
                                               "",
                                               seen,
                                               units,
                                               ownerModulePaths,
                                               importEdges,
                                               outAppliedRules,
                                               outAppliedCount,
                                               unresolvedImportCount,
                                               err):
                return false
        else:
            unresolvedImportCount = unresolvedImportCount + 1
    err = ""
    return true

fn CompilerLegacyFindUnitText(units: CompilerLegacySourceUnit[],
                                sourcePath: str,
                                out: var str): bool =
    for i in 0..<units.len:
        if units[i].sourcePath != sourcePath:
            continue
        out = units[i].migratedText
        return true
    return false

fn CompilerLegacyBuildPlan(workspaceRoot: str,
                             packageRoot: str,
                             entrySourcePath: str,
                             packageId: str,
                             units: CompilerLegacySourceUnit[],
                             ownerModulePaths: str[],
                             importEdges: parser.ImportEdge[],
                             unresolvedImportCount: int32,
                             out: var slplan.SystemLinkPlanStub): bool =
    let entryModulePath = units.len > 0 ? units[0].modulePath : parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, entrySourcePath)
    out.entryPath = entrySourcePath
    out.outputPath = ""
    out.targetTriple = "arm64-apple-darwin"
    out.emitKind = creq.EmitExe
    out.packageRoot = packageRoot
    out.workspaceRoot = workspaceRoot
    out.packageId = packageId
    out.moduleStem = parser.ParserFileStem(entrySourcePath)
    out.moduleKind = entryModulePath == "cheng/core/tooling/compiler_main" ? slplan.SystemCompilerControlPlane : slplan.SystemOrdinaryProgram
    out.sourceClosurePaths = []
    for i in 0..<units.len:
        add(out.sourceClosurePaths, units[i].sourcePath)
    out.ownerModulePaths = ownerModulePaths
    out.importEdges = importEdges
    out.importEdgeCount = importEdges.len
    out.unresolvedImportCount = unresolvedImportCount
    out.hasCompilerTopLevel = true
    var entryText = ""
    let foundEntryText = CompilerLegacyFindUnitText(units, entrySourcePath, entryText)
    out.mainFunctionPresent = foundEntryText && parser.ParserMainFunctionPresent(entryText)
    if out.moduleKind == slplan.SystemCompilerControlPlane:
        out.runtimeTargets = ["runtime/compiler.tooling_argv_entry"]
    else:
        out.runtimeTargets = ["runtime/compiler.program_argv_entry"]
    var providerModules: str[]
    add(providerModules, "runtime/compiler_runtime")
    add(providerModules, "runtime/core_runtime")
    add(providerModules, "runtime/debug_runtime")
    add(providerModules, "runtime/program_support")
    add(providerModules, "runtime/program_support_get_env_bridge")
    add(providerModules, "runtime/program_support_host_runtime")
    out.providerModules = providerModules
    out.entrySymbol = out.mainFunctionPresent ? "main" : ""
    out.missingReasons = []
    out.parserSyntaxTag = "cheng.legacy_migrated_source"
    out.parserSourceKind = 1
    out.buildEntryPath = entrySourcePath
    out.buildSourceUnitCount = units.len
    out.linkMode = "system_link"
    out.pipelineStage = "legacy_source_to_canonical_csg"
    return true

fn BuildCompilerLegacyMigration(workspaceRoot: str,
                                  packageRoot: str,
                                  entrySourcePath: str,
                                  packageIdHint: str,
                                  entryModulePathOverride: str): Result[CompilerLegacyMigration] =
    var seen: str[]
    var units: CompilerLegacySourceUnit[]
    var ownerModulePaths: str[]
    var importEdges: parser.ImportEdge[]
    var appliedRules: str[]
    var appliedCount = 0
    var unresolvedImportCount = 0
    var err = ""
    if !CompilerLegacyCollectClosure(workspaceRoot,
                                       packageRoot,
                                       entrySourcePath,
                                       entryModulePathOverride,
                                       seen,
                                       units,
                                       ownerModulePaths,
                                       importEdges,
                                       appliedRules,
                                       appliedCount,
                                       unresolvedImportCount,
                                       err):
        return Err[CompilerLegacyMigration](err)
    CompilerCsgSortStrs(ownerModulePaths)
    var legacyTexts: str[]
    var legacyModulePaths: str[]
    var migratedTexts: str[]
    var migratedModulePaths: str[]
    for i in 0..<units.len:
        add(legacyModulePaths, units[i].modulePath)
        add(legacyTexts, units[i].legacyText)
        add(migratedModulePaths, units[i].modulePath)
        add(migratedTexts, units[i].migratedText)
    let packageId = packageIdHint.len > 0 ? packageIdHint : CompilerLegacyPackageId(units[0].modulePath)
    let legacyBundleRes = cworld.CompilerWorldSourceBundleCidFromModuleTexts(packageId,
                                                                               legacyModulePaths,
                                                                               legacyTexts)
    if IsErr(legacyBundleRes):
        return Err[CompilerLegacyMigration](Error(legacyBundleRes))
    let migratedBundleRes = cworld.CompilerWorldSourceBundleCidFromModuleTexts(packageId,
                                                                                 migratedModulePaths,
                                                                                 migratedTexts)
    if IsErr(migratedBundleRes):
        return Err[CompilerLegacyMigration](Error(migratedBundleRes))
    var plan: slplan.SystemLinkPlanStub
    if !CompilerLegacyBuildPlan(workspaceRoot,
                                  packageRoot,
                                  entrySourcePath,
                                  packageId,
                                  units,
                                  ownerModulePaths,
                                  importEdges,
                                  unresolvedImportCount,
                                  plan):
        return Err[CompilerLegacyMigration](" compiler migration: failed to build legacy plan")
    var overrides: CompilerCsgSourceText[]
    for i in 0..<units.len:
        var override: CompilerCsgSourceText
        override.sourcePath = units[i].sourcePath
        override.modulePath = units[i].modulePath
        override.text = units[i].migratedText
        add(overrides, override)
    let csgRes = BuildCompilerCsgWithOverrides(plan, Value(migratedBundleRes), overrides)
    if IsErr(csgRes):
        return Err[CompilerLegacyMigration](Error(csgRes))
    let csg = CompilerCsgClone(Value(csgRes))
    let surface = CompilerExportSurfaceClone(CompilerExportSurfaceFromCsg(csg))
    var migBuf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(migBuf, "cheng.compiler.legacy_migration")
    CompilerCsgAppendText(migBuf, packageId)
    CompilerCsgAppendText(migBuf, entrySourcePath)
    CompilerCsgAppendFixed32(migBuf, Value(legacyBundleRes))
    CompilerCsgAppendFixed32(migBuf, Value(migratedBundleRes))
    CompilerCsgAppendFixed32(migBuf, csg.canonicalGraphCid)
    CompilerCsgAppendFixed32(migBuf, surface.surfaceCid)
    CompilerCsgAppendU32BE(migBuf, appliedRules.len)
    for i in 0..<appliedRules.len:
        CompilerCsgAppendText(migBuf, appliedRules[i])
    var out: CompilerLegacyMigration
    out.version = 1
    out.packageId = packageId
    out.entrySourcePath = entrySourcePath
    out.entryModulePath = units[0].modulePath
    out.unitCount = units.len
    out.units = CompilerLegacySourceUnitsClone(units)
    out.appliedRuleCount = appliedCount
    out.appliedRules = appliedRules
    out.legacySourceBundleCid = Value(legacyBundleRes)
    out.migratedSourceBundleCid = Value(migratedBundleRes)
    out.compilerCsg = CompilerCsgClone(csg)
    out.exportSurface = CompilerExportSurfaceClone(surface)
    out.migrationCid = CompilerCsgBufCid(migBuf)
    return Ok[CompilerLegacyMigration](out)

fn CompilerLegacyMigrationReport(migration: CompilerLegacyMigration): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", migration.packageId, "\n"], "")
    out = strutil.Join([out, "entry_source_path=", migration.entrySourcePath, "\n"], "")
    out = strutil.Join([out, "entry_module_path=", migration.entryModulePath, "\n"], "")
    out = strutil.Join([out, "unit_count=", IntToStr(migration.unitCount), "\n"], "")
    out = strutil.Join([out, "applied_rule_count=", IntToStr(migration.appliedRuleCount), "\n"], "")
    out = strutil.Join([out, "legacy_source_bundle_cid=", layout.FixedBytes32Hex(migration.legacySourceBundleCid), "\n"], "")
    out = strutil.Join([out, "migrated_source_bundle_cid=", layout.FixedBytes32Hex(migration.migratedSourceBundleCid), "\n"], "")
    out = strutil.Join([out, "canonical_graph_cid=", layout.FixedBytes32Hex(migration.compilerCsg.canonicalGraphCid), "\n"], "")
    out = strutil.Join([out, "graph_cid=", layout.FixedBytes32Hex(migration.compilerCsg.graphCid), "\n"], "")
    out = strutil.Join([out, "surface_cid=", layout.FixedBytes32Hex(migration.exportSurface.surfaceCid), "\n"], "")
    out = strutil.Join([out, "migration_cid=", layout.FixedBytes32Hex(migration.migrationCid)], "")
    for i in 0..<migration.appliedRules.len:
        out = strutil.Join([out, "\n", "applied_rule[", IntToStr(i), "]=", migration.appliedRules[i]], "")
    return out

fn CompilerCsgAddNode(nodes: var CompilerCsgNode[],
                        nodeKind: int32,
                        ownerNodeId: int32,
                        modulePath: str,
                        symbolText: str,
                        factText: str,
                        resultLayoutKind: int32,
                        effectKind: int32,
                        capabilityKind: int32,
                        callConv: int32,
                        entryFlag: int32,
                        exportedFlag: int32,
                        exportSymbolName: str): int32 =
    var node: CompilerCsgNode
    node.nodeId = nodes.len + 1
    node.nodeKind = nodeKind
    node.ownerNodeId = ownerNodeId
    node.modulePath = modulePath
    node.symbolText = symbolText
    node.factText = factText
    node.resultLayoutKind = resultLayoutKind
    node.effectKind = effectKind
    node.capabilityKind = capabilityKind
    node.callConv = callConv
    node.entryFlag = entryFlag
    node.exportedFlag = exportedFlag
    node.exportSymbolName = exportSymbolName
    node.factCid = CompilerCsgHashNode(nodeKind,
                                         ownerNodeId,
                                         modulePath,
                                         symbolText,
                                         factText,
                                         resultLayoutKind,
                                         effectKind,
                                         capabilityKind,
                                         callConv,
                                         entryFlag,
                                         exportedFlag,
                                         exportSymbolName)
    add(nodes, node)
    return node.nodeId

fn CompilerCsgAddEdge(edges: var CompilerCsgEdge[],
                        fromNodeId: int32,
                        toNodeId: int32,
                        edgeKind: int32) =
    var edge: CompilerCsgEdge
    edge.edgeId = edges.len + 1
    edge.fromNodeId = fromNodeId
    edge.toNodeId = toNodeId
    edge.edgeKind = edgeKind
    edge.edgeCid = CompilerCsgHashEdge(fromNodeId, toNodeId, edgeKind)
    add(edges, edge)

fn CompilerCsgExprLayerForText(sourcePath: str,
                                 text: str,
                                 importcCallNames: str[],
                                 localCallNames: str[],
                                 externalCallNames: str[],
                                 currentProfile: parser.NormalizedExprCallProfile,
                                 profiles: parser.NormalizedExprCallProfile[],
                                 profileIndexLookup: parser.ParserSourcePathIndexLookup,
                                 layer: var parser.NormalizedExprLayer): Result[bool] =
    var err: str
    if !parser.ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePath,
                                                                                text,
                                                                                importcCallNames,
                                                                                localCallNames,
                                                                                externalCallNames,
                                                                                currentProfile,
                                                                                profiles,
                                                                                profileIndexLookup,
                                                                                layer,
                                                                                err):
        if err != "":
            return Err[bool](err)
        return Err[bool](" compiler csg: expr layer read failed")
    return Ok[bool](true)

fn CompilerCsgTextRangeEquals(text: str,
                               start: int32,
                               stop: int32,
                               expected: str): bool =
    if start < 0 || stop < start || stop > text.len:
        return false
    if stop - start != expected.len:
        return false
    for i in 0..<expected.len:
        if text[start + i] != expected[i]:
            return false
    return true

fn CompilerCsgTrimmedLineEquals(line: str,
                                 expected: str): bool =
    var start: int32
    var stop: int32
    if !parser.ParserTrimmedLineRange(line, start, stop):
        return false
    return CompilerCsgTextRangeEquals(line, start, stop, expected)

fn CompilerCsgExprLayerForProfile(sourcePath: str,
                                   importcCallNames: str[],
                                   localCallNames: str[],
                                   externalCallNames: str[],
                                   currentProfile: parser.NormalizedExprCallProfile,
                                   profiles: parser.NormalizedExprCallProfile[],
                                   profileIndexLookup: parser.ParserSourcePathIndexLookup,
                                   profileCallLookupCache: var parser.ParserProfileCallLookupCacheEntry[],
                                   layer: var parser.NormalizedExprLayer): Result[bool] =
    if sourcePath == "":
        return Err[bool]("missing source path")
    layer = parser.NormalizedExprLayer()
    layer.sourceCount = 1
    var localCallLookup = parser.ParserTextLookupBuildExact(localCallNames)
    var externalCallLookup = parser.ParserTextLookupBuildExact(externalCallNames)
    var importcCallLookup = parser.ParserTextLookupBuildExact(importcCallNames)
    var knownCallLookup = parser.ParserTextLookupInit(localCallNames.len +
                                                       externalCallNames.len +
                                                       importcCallNames.len + 8)
    parser.ParserTextLookupAddAllExact(knownCallLookup, localCallNames)
    parser.ParserTextLookupAddAllExact(knownCallLookup, externalCallNames)
    parser.ParserTextLookupAddAllExact(knownCallLookup, importcCallNames)
    var inTypeBlock = false
    var typeBlockIndent: int32 = -1
    for i in 0..<currentProfile.lines.len:
        if i % 128 == 0:
            os.ProcessResourceGuardCheck()
        let line = parser.ParserStripLineComment(currentProfile.lines[i])
        if !parser.ParserHasNonTrimChar(line):
            continue
        let lineNumber = i + 1
        let lineIndent: int32 = parser.ParserLineIndent(line)
        if inTypeBlock && lineIndent <= typeBlockIndent:
            inTypeBlock = false
        if !parser.ParserHasLeadingIndent(line):
            inTypeBlock = CompilerCsgTrimmedLineEquals(line, "type")
            if inTypeBlock:
                typeBlockIndent = lineIndent
        var redundantType = ""
        var redundantExpr = ""
        if parser.ParserFindRedundantExplicitDefaultLine(line,
                                                          inTypeBlock,
                                                          currentProfile,
                                                          profiles,
                                                          redundantType,
                                                          redundantExpr):
            return Err[bool](parser.ParserRedundantExplicitDefaultError(redundantType, redundantExpr))
        var strictErr = ""
        if parser.ParserRejectSpaceCallIfStrict(line, lineNumber, knownCallLookup, strictErr):
            return Err[bool](strictErr)
        parser.ParserAppendSimpleSurfaceExprsLine(sourcePath,
                                                   lineNumber,
                                                   line,
                                                   true,
                                                   true,
                                                   true,
                                                   layer)
        parser.ParserAppendReturnStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendAssignStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendControlStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendMatchStmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        parser.ParserAppendStringifyCallExprsLine(sourcePath,
                                                   lineNumber,
                                                   line,
                                                   layer)
        var defaultErr = ""
        if !parser.ParserAppendDefaultInitExprsLine(sourcePath,
                                                     lineNumber,
                                                     line,
                                                     currentProfile,
                                                     profiles,
                                                     layer,
                                                     defaultErr):
            return Err[bool](defaultErr)
        parser.ParserAppendConstructorExprsLine(sourcePath,
                                                 lineNumber,
                                                 line,
                                                 currentProfile,
                                                 profiles,
                                                 layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &localCallLookup,
                                          parser.NormalizedExprSurfaceCallLocal,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &externalCallLookup,
                                          parser.NormalizedExprSurfaceCallExternal,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          &importcCallLookup,
                                          parser.NormalizedExprSurfaceCallImportc,
                                          currentProfile,
                                          profiles,
                                          profileIndexLookup,
                                          profileCallLookupCache,
                                          layer)
        parser.ParserAppendMemberCallExprsLine(sourcePath,
                                                lineNumber,
                                                line,
                                                knownCallLookup,
                                                currentProfile,
                                                layer)
    layer.questionResidualCount = 0
    return Ok[bool](true)

fn BuildCompilerCsgWithOverridesInto(linkPlan: slplan.SystemLinkPlanStub,
                                      sourceBundleCid: layout.FixedBytes32,
                                      sourceTextOverrides: CompilerCsgSourceText[],
                                      out: var CompilerCsg,
                                      err: var str): bool =
    err = ""
    var modules: str[]
    var importPairs: CompilerCsgImportPair[]
    var moduleSeen = CompilerCsgTextSetInit(linkPlan.ownerModulePaths.len +
                                              linkPlan.importEdges.len * 2 + 8)
    var importPairSeen = CompilerCsgImportPairLookupInit(linkPlan.importEdges.len * 2 + 8)
    for i in 0..<linkPlan.ownerModulePaths.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.ownerModulePaths[i])
    for i in 0..<linkPlan.importEdges.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.importEdges[i].ownerModulePath)
        if linkPlan.importEdges[i].resolved:
            CompilerCsgAddUniqueFast(modules, moduleSeen, linkPlan.importEdges[i].targetModulePath)
            CompilerCsgAddUniqueImportPairFast(importPairs,
                                                importPairSeen,
                                                linkPlan.importEdges[i].ownerModulePath,
                                                linkPlan.importEdges[i].targetModulePath)
    CompilerCsgSortStrs(modules)
    CompilerCsgSortImportPairs(importPairs)
    var nodes: CompilerCsgNode[]
    var edges: CompilerCsgEdge[]
    var exprLayer = parser.NormalizedExprLayer()
    var packageNode: CompilerCsgNode
    packageNode.nodeId = nodes.len + 1
    packageNode.nodeKind = CompilerCsgNodeKindPackage
    packageNode.ownerNodeId = 0
    packageNode.modulePath = ""
    packageNode.symbolText = ""
    packageNode.factText = linkPlan.packageId
    packageNode.resultLayoutKind = 0
    packageNode.effectKind = 0
    packageNode.capabilityKind = 0
    packageNode.callConv = 0
    packageNode.entryFlag = 0
    packageNode.exportedFlag = 0
    packageNode.exportSymbolName = ""
    var packageBuf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(packageBuf, "cheng.compiler.csg.node")
    CompilerCsgAppendU32BE(packageBuf, packageNode.nodeKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.ownerNodeId)
    CompilerCsgAppendText(packageBuf, packageNode.modulePath)
    CompilerCsgAppendText(packageBuf, packageNode.symbolText)
    CompilerCsgAppendText(packageBuf, packageNode.factText)
    CompilerCsgAppendU32BE(packageBuf, packageNode.resultLayoutKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.effectKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.capabilityKind)
    CompilerCsgAppendU32BE(packageBuf, packageNode.callConv)
    CompilerCsgAppendU32BE(packageBuf, packageNode.entryFlag)
    CompilerCsgAppendU32BE(packageBuf, packageNode.exportedFlag)
    CompilerCsgAppendText(packageBuf, packageNode.exportSymbolName)
    packageNode.factCid = CompilerCsgBufCid(packageBuf)
    add(nodes, packageNode)
    let packageNodeId = packageNode.nodeId
    var moduleNodeIds: int32[]
    for i in 0..<modules.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        var moduleNode: CompilerCsgNode
        moduleNode.nodeId = nodes.len + 1
        moduleNode.nodeKind = CompilerCsgNodeKindModule
        moduleNode.ownerNodeId = packageNodeId
        moduleNode.modulePath = modules[i]
        moduleNode.symbolText = ""
        moduleNode.factText = modules[i]
        moduleNode.resultLayoutKind = 0
        moduleNode.effectKind = 0
        moduleNode.capabilityKind = 0
        moduleNode.callConv = 0
        moduleNode.entryFlag = 0
        moduleNode.exportedFlag = 0
        moduleNode.exportSymbolName = ""
        var moduleBuf: layout.ByteBuf = layout.ByteBufInit(256)
        CompilerCsgAppendText(moduleBuf, "cheng.compiler.csg.node")
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.nodeKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.ownerNodeId)
        CompilerCsgAppendText(moduleBuf, moduleNode.modulePath)
        CompilerCsgAppendText(moduleBuf, moduleNode.symbolText)
        CompilerCsgAppendText(moduleBuf, moduleNode.factText)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.resultLayoutKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.effectKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.capabilityKind)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.callConv)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.entryFlag)
        CompilerCsgAppendU32BE(moduleBuf, moduleNode.exportedFlag)
        CompilerCsgAppendText(moduleBuf, moduleNode.exportSymbolName)
        moduleNode.factCid = CompilerCsgBufCid(moduleBuf)
        add(nodes, moduleNode)
        add(moduleNodeIds, moduleNode.nodeId)
        CompilerCsgAddEdge(edges, packageNodeId, moduleNode.nodeId, CompilerCsgEdgeKindContains)
    for i in 0..<importPairs.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let pair = importPairs[i]
        let fromNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                        moduleNodeIds,
                                                        pair.ownerModulePath)
        let toNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                      moduleNodeIds,
                                                      pair.targetModulePath)
        if fromNodeId <= 0 || toNodeId <= 0:
            continue
        CompilerCsgAddEdge(edges, fromNodeId, toNodeId, CompilerCsgEdgeKindImports)
    var orderedSources: str[]
    var orderedSourceModules: str[]
    var typedSourceTexts: TypedExprSourceText[]
    var exprCallProfiles: parser.NormalizedExprCallProfile[]
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    let sourceTextLookup = CompilerCsgSourceTextLookupBuild(sourceTextOverrides)
    for i in 0..<linkPlan.sourceClosurePaths.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = linkPlan.sourceClosurePaths[i]
        add(orderedSources, sourcePath)
        add(orderedSourceModules,
            CompilerCsgSourceModulePathFast(linkPlan.workspaceRoot,
                                             linkPlan.packageRoot,
                                             externalPackageRoots,
                                             sourceTextLookup,
                                             sourcePath))
    CompilerCsgSortSourcePathModulePairs(orderedSources, orderedSourceModules)
    for sourceIndex in 0..<orderedSources.len:
        if sourceIndex % 16 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = orderedSources[sourceIndex]
        let ownerModulePath = orderedSourceModules[sourceIndex]
        let ownerModuleNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                               moduleNodeIds,
                                                               ownerModulePath)
        if ownerModuleNodeId <= 0:
            continue
        var text = ""
        let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
        if !CompilerCsgSourceTextLookupFast(sourceTextLookup, sourcePath, normalizedSourcePath, text):
            text = chengpath.ReadTextFile("", sourcePath)
        add(typedSourceTexts, texpr.TypedExprSourceTextNewWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                      linkPlan.packageRoot,
                                                                                      externalPackageRoots,
                                                                                      sourcePath,
                                                                                      text))
        var profile: parser.NormalizedExprCallProfile
        var profileErr = ""
        if !parser.ParserBuildExprCallProfileWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                        linkPlan.packageRoot,
                                                                        externalPackageRoots,
                                                                        sourcePath,
                                                                        text,
                                                                        profile,
                                                                        profileErr):
            err = " compiler csg: normalized decl read failed"
            return false
        add(exprCallProfiles, profile)
    let profileIndexLookup = parser.ParserSourcePathIndexLookupBuild(exprCallProfiles)
    parser.ParserBindImportEdgeTargetProfileIndices(exprCallProfiles, profileIndexLookup)
    var externalVisibleNameCache: parser.ParserTextSeqCacheEntry[]
    var externalQualifiedNameCache: parser.ParserQualifiedTextSeqCacheEntry[]
    var profileCallLookupCache = parser.ParserBuildProfileCallLookupCache(exprCallProfiles)
    for sourceIndex in 0..<exprCallProfiles.len:
        if sourceIndex % 16 == 0:
            os.ProcessResourceGuardCheck()
        var profile = exprCallProfiles[sourceIndex]
        let sourcePath = profile.sourcePath
        let ownerModulePath = orderedSourceModules[sourceIndex]
        let ownerModuleNodeId = CompilerCsgModuleNodeIdIndexed(modules,
                                                               moduleNodeIds,
                                                               ownerModulePath)
        if ownerModuleNodeId <= 0:
            continue
        var sourceExternalCalls: str[]
        parser.ParserCollectExternalCallNamesCached(exprCallProfiles,
                                                      profileIndexLookup,
                                                      sourceIndex,
                                                      externalVisibleNameCache,
                                                      externalQualifiedNameCache,
                                                      sourceExternalCalls)
        var sourceExprLayer = parser.NormalizedExprLayer()
        let sourceExprRes = CompilerCsgExprLayerForProfile(sourcePath,
                                                            profile.importcCallNames,
                                                            profile.localCallNames,
                                                            sourceExternalCalls,
                                                            profile,
                                                            exprCallProfiles,
                                                            profileIndexLookup,
                                                            profileCallLookupCache,
                                                            sourceExprLayer)
        if IsErr(sourceExprRes):
            err = Error(sourceExprRes)
            return false
        parser.NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
        let entrySourceFlag = sourcePath == linkPlan.entryPath
        var entryHasExplicitExports = false
        if entrySourceFlag && (linkPlan.emitKind == creq.EmitShared || linkPlan.emitKind == creq.EmitObj):
            for scanIndex in 0..<profile.decls.len:
                if scanIndex % 256 == 0:
                    os.ProcessResourceGuardCheck()
                if profile.decls[scanIndex].importc:
                    continue
                if profile.decls[scanIndex].explicitExportName.len > 0:
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<profile.decls.len:
            if declIndex % 64 == 0:
                os.ProcessResourceGuardCheck()
            let decl = profile.decls[declIndex]
            let functionName = decl.name
            if decl.importc:
                continue
            let pendingExportName = decl.explicitExportName
            var entryFlag = 0
            if sourcePath == linkPlan.entryPath && functionName == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if functionName == "main":
                resultLayoutKind = 5
            var effectKind = CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = CompilerCsgEffectProgramEntry
            var capabilityKind = CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = CompilerCsgCapabilityEntrypoint
            let callConv = 1
            let symbolText = parser.ParserConcat3(ownerModulePath, "::", functionName)
            var exportedFlag = 0
            if CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                               entrySourceFlag,
                                               entryHasExplicitExports,
                                               pendingExportName,
                                               functionName,
                                               entryFlag):
                exportedFlag = 1
            if exportedFlag != 0 &&
               !CompilerCsgExportRootSelected(linkPlan.exportRootSymbols,
                                               symbolText,
                                               pendingExportName,
                                               functionName):
                exportedFlag = 0
            var exportSymbolName = ""
            if exportedFlag != 0:
                exportSymbolName = CompilerCsgTargetExportName(symbolText,
                                                                 pendingExportName,
                                                                 functionName)
            var symbolNode: CompilerCsgNode
            symbolNode.nodeId = nodes.len + 1
            symbolNode.nodeKind = CompilerCsgNodeKindSymbol
            symbolNode.ownerNodeId = ownerModuleNodeId
            symbolNode.modulePath = ownerModulePath
            symbolNode.symbolText = symbolText
            symbolNode.factText = functionName
            symbolNode.resultLayoutKind = resultLayoutKind
            symbolNode.effectKind = effectKind
            symbolNode.capabilityKind = capabilityKind
            symbolNode.callConv = callConv
            symbolNode.entryFlag = entryFlag
            symbolNode.exportedFlag = exportedFlag
            symbolNode.exportSymbolName = exportSymbolName
            var symbolBuf: layout.ByteBuf = layout.ByteBufInit(256)
            CompilerCsgAppendText(symbolBuf, "cheng.compiler.csg.node")
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.nodeKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.ownerNodeId)
            CompilerCsgAppendText(symbolBuf, symbolNode.modulePath)
            CompilerCsgAppendText(symbolBuf, symbolNode.symbolText)
            CompilerCsgAppendText(symbolBuf, symbolNode.factText)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.resultLayoutKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.effectKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.capabilityKind)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.callConv)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.entryFlag)
            CompilerCsgAppendU32BE(symbolBuf, symbolNode.exportedFlag)
            CompilerCsgAppendText(symbolBuf, symbolNode.exportSymbolName)
            symbolNode.factCid = CompilerCsgBufCid(symbolBuf)
            add(nodes, symbolNode)
            let symbolNodeId = symbolNode.nodeId
            CompilerCsgAddEdge(edges, ownerModuleNodeId, symbolNodeId, CompilerCsgEdgeKindContains)
        profile.text = ""
        profile.lines = []
        exprCallProfiles[sourceIndex] = profile
    exprCallProfiles = []
    orderedSources = []
    orderedSourceModules = []
    var typedExprFacts: TypedExprFact[]
    var typedErr = ""
    os.ProcessResourceGuardCheck()
    if !texpr.TypedExprBuildFacts(typedSourceTexts, exprLayer, typedExprFacts, typedErr):
        if typedErr != "":
            err = typedErr
            return false
        err = " compiler csg: typed expr build failed"
        return false
    CompilerCsgRestoreSourceTextOverridesFast(sourceTextLookup, typedSourceTexts)
    var typedIr: texpr.TypedExprIr
    var typedIrErr = ""
    if !texpr.TypedExprBuildIrWithFactsAndExprLayer(typedSourceTexts,
                                                     typedExprFacts,
                                                     exprLayer,
                                                     typedIr,
                                                     typedIrErr):
        if typedIrErr != "":
            err = typedIrErr
            return false
        err = " compiler csg: typed ir build failed"
        return false
    typedSourceTexts = []
    os.ProcessResourceGuardCheck()
    let canonicalGraphCid = CompilerCsgCanonicalGraphCid(linkPlan.packageId,
                                                          sourceBundleCid,
                                                          linkPlan.workspaceRoot,
                                                          linkPlan.packageRoot,
                                                          externalPackageRoots,
                                                          sourceTextOverrides,
                                                          exprLayer,
                                                          typedExprFacts,
                                                          nodes,
                                                          edges)
    os.ProcessResourceGuardCheck()
    let graphCid = CompilerCsgGraphCid(linkPlan.packageId,
                                        sourceBundleCid,
                                        linkPlan.workspaceRoot,
                                        linkPlan.packageRoot,
                                        externalPackageRoots,
                                        sourceTextOverrides,
                                        exprLayer,
                                        typedExprFacts,
                                        nodes,
                                        edges)
    out.version = 1
    out.packageId = linkPlan.packageId
    out.sourceBundleCid = sourceBundleCid
    out.exprLayer = exprLayer
    out.typedExprFacts = typedExprFacts
    out.typedIr = typedIr
    out.nodes = nodes
    out.edges = edges
    out.nodeCount = nodes.len
    out.edgeCount = edges.len
    out.canonicalGraphCid = canonicalGraphCid
    out.graphCid = graphCid
    return true

fn BuildCompilerCsgWithOverrides(linkPlan: slplan.SystemLinkPlanStub,
                                   sourceBundleCid: layout.FixedBytes32,
                                   sourceTextOverrides: CompilerCsgSourceText[]): Result[CompilerCsg] =
    var out: CompilerCsg
    var err = ""
    if !BuildCompilerCsgWithOverridesInto(linkPlan,
                                          sourceBundleCid,
                                          sourceTextOverrides,
                                          out,
                                          err):
        return Err[CompilerCsg](err)
    return Ok[CompilerCsg](out)

fn BuildCompilerCsgInto(linkPlan: slplan.SystemLinkPlanStub,
                         sourceBundleCid: layout.FixedBytes32,
                         out: var CompilerCsg,
                         err: var str): bool =
    var sourceTextOverrides: CompilerCsgSourceText[]
    sourceTextOverrides = []
    return BuildCompilerCsgWithOverridesInto(linkPlan,
                                             sourceBundleCid,
                                             sourceTextOverrides,
                                             out,
                                             err)

fn BuildCompilerCsg(linkPlan: slplan.SystemLinkPlanStub,
                      sourceBundleCid: layout.FixedBytes32): Result[CompilerCsg] =
    var sourceTextOverrides: CompilerCsgSourceText[]
    sourceTextOverrides = []
    return BuildCompilerCsgWithOverrides(linkPlan, sourceBundleCid, sourceTextOverrides)

fn CompilerExportSurfaceFromCsg(csg: CompilerCsg): CsgExportSurface =
    var out: CsgExportSurface
    out.version = 1
    out.packageId = csg.packageId
    out.exportedSymbols = []
    out.exportedTargetNames = []
    out.exportedLayouts = []
    out.exportedEffects = []
    out.exportedCapabilities = []
    for i in 0..<csg.nodes.len:
        let node = csg.nodes[i]
        if node.nodeKind != CompilerCsgNodeKindSymbol:
            continue
        if node.exportedFlag == 0:
            continue
        add(out.exportedSymbols, node.symbolText)
        add(out.exportedTargetNames, node.exportSymbolName)
        add(out.exportedLayouts, node.resultLayoutKind)
        add(out.exportedEffects, node.effectKind)
        add(out.exportedCapabilities, node.capabilityKind)
    out.exportedSymbolCount = out.exportedSymbols.len
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.export_surface")
    CompilerCsgAppendText(buf, out.packageId)
    CompilerCsgAppendU32BE(buf, out.exportedSymbolCount)
    for i in 0..<out.exportedSymbols.len:
        CompilerCsgAppendText(buf, out.exportedSymbols[i])
        CompilerCsgAppendText(buf, out.exportedTargetNames[i])
        CompilerCsgAppendU32BE(buf, out.exportedLayouts[i])
        CompilerCsgAppendU32BE(buf, out.exportedEffects[i])
        CompilerCsgAppendU32BE(buf, out.exportedCapabilities[i])
    out.surfaceCid = CompilerCsgBufCid(buf)
    return out

fn CompilerExportSurfaceCompatible(base: CsgExportSurface,
                                     next: CsgExportSurface): bool =
    if base.packageId != next.packageId:
        return false
    if base.exportedSymbolCount != next.exportedSymbolCount:
        return false
    for i in 0..<base.exportedSymbolCount:
        if base.exportedSymbols[i] != next.exportedSymbols[i]:
            return false
        if base.exportedTargetNames[i] != next.exportedTargetNames[i]:
            return false
        if base.exportedLayouts[i] != next.exportedLayouts[i]:
            return false
        if base.exportedEffects[i] != next.exportedEffects[i]:
            return false
        if base.exportedCapabilities[i] != next.exportedCapabilities[i]:
            return false
    return true

fn CompileReceiptMake(worldHeadCid: layout.FixedBytes32,
                        compilerCsgCid: layout.FixedBytes32,
                        canonicalCompilerCsgCid: layout.FixedBytes32,
                        targetTriple: str,
                        outputDigest: layout.FixedBytes32,
                        canonicalOutputDigest: layout.FixedBytes32,
                        bootstrapStage: str,
                        runtimeProviderSet: str[]): CompileReceipt =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.compile_receipt")
    CompilerCsgAppendFixed32(buf, worldHeadCid)
    CompilerCsgAppendFixed32(buf, compilerCsgCid)
    CompilerCsgAppendFixed32(buf, canonicalCompilerCsgCid)
    CompilerCsgAppendText(buf, targetTriple)
    CompilerCsgAppendFixed32(buf, outputDigest)
    CompilerCsgAppendFixed32(buf, canonicalOutputDigest)
    CompilerCsgAppendText(buf, bootstrapStage)
    CompilerCsgAppendU32BE(buf, runtimeProviderSet.len)
    for i in 0..<runtimeProviderSet.len:
        CompilerCsgAppendText(buf, runtimeProviderSet[i])
    var out: CompileReceipt
    out.version = 1
    out.worldHeadCid = worldHeadCid
    out.compilerCsgCid = compilerCsgCid
    out.canonicalCompilerCsgCid = canonicalCompilerCsgCid
    out.targetTriple = targetTriple
    out.outputDigest = outputDigest
    out.canonicalOutputDigest = canonicalOutputDigest
    out.bootstrapStage = bootstrapStage
    out.runtimeProviderSet = runtimeProviderSet
    out.receiptCid = CompilerCsgBufCid(buf)
    return out

fn CompileOutputDigest(outputPath: str,
                         targetTriple: str,
                         providerModules: str[],
                         csgCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerCsgAppendText(buf, "cheng.compiler.output_digest")
    let _ = outputPath
    CompilerCsgAppendText(buf, targetTriple)
    CompilerCsgAppendFixed32(buf, csgCid)
    CompilerCsgAppendU32BE(buf, providerModules.len)
    for i in 0..<providerModules.len:
        CompilerCsgAppendText(buf, providerModules[i])
    return CompilerCsgBufCid(buf)

fn CompilerColdCsgAppendLine(out: var str, line: str) =
    if len(out) > 0:
        out = Fmt"{out}\n"
    out = Fmt"{out}{line}"

fn CompilerColdCsgTextIsFactSafe(text: str): bool =
    for i in 0..<text.len:
        if text[i] == '\t' || text[i] == '\n' || text[i] == '\r':
            return false
    return true

fn CompilerColdCsgPayloadIsLineSafe(text: str): bool =
    for i in 0..<text.len:
        if text[i] == '\n' || text[i] == '\r':
            return false
    return true

fn CompilerColdCsgTailName(nameRaw: str): str =
    var tailStart: int32
    if nameRaw.len >= 2:
        for i in 0..<(nameRaw.len - 1):
            if nameRaw[i] == ':' && nameRaw[i + 1] == ':':
                tailStart = i + 2
    if tailStart > 0 && tailStart < nameRaw.len:
        return chengpath.TextSlice(nameRaw, tailStart, nameRaw.len - tailStart)
    return nameRaw

fn CompilerColdCsgFunctionIndex(csg: var CompilerCsg, nameRaw: str): int32 =
    let name = CompilerColdCsgTailName(nameRaw)
    for i in 0..<csg.typedIr.functions.len:
        if CompilerColdCsgTailName(csg.typedIr.functions[i].functionName) == name:
            return i
    return -1

fn CompilerColdCsgCallExpr(stmt: texpr.TypedExprIrStatement,
                            err: var str): str =
    if stmt.callTargetImportc:
        err = Fmt"cold csg export unsupported importc call: {stmt.callTarget}"
        return ""
    if stmt.callTarget == "":
        err = "cold csg export missing call target"
        return ""
    if !CompilerColdCsgTextIsFactSafe(stmt.callArgsText):
        err = "cold csg export unsafe call args"
        return ""
    return Fmt"{CompilerColdCsgTailName(stmt.callTarget)}({stmt.callArgsText})"

fn CompilerColdCsgStripTrailingColon(textRaw: str): str =
    var text = chengpath.PathTrim(textRaw)
    if text.len > 0 && text[text.len - 1] == ':':
        text = chengpath.PathTrim(chengpath.TextSlice(text, 0, text.len - 1))
    return text

fn CompilerColdCsgControlPayload(surfaceRaw: str, keyword: str): str =
    let surface = CompilerColdCsgStripTrailingColon(surfaceRaw)
    if !parser.ParserStartsWith(surface, keyword):
        return surface
    let start = keyword.len
    if surface.len <= start:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(surface, start, surface.len - start))

fn CompilerColdCsgReturnExpr(stmt: texpr.TypedExprIrStatement,
                              fnIr: texpr.TypedExprIrFunction,
                              err: var str): str =
    if stmt.callTarget != "":
        return CompilerColdCsgCallExpr(stmt, err)
    var expr = chengpath.PathTrim(stmt.surfaceText)
    if parser.ParserStartsWith(expr, "return "):
        expr = chengpath.PathTrim(chengpath.TextSlice(expr, 7, expr.len - 7))
    if expr == "":
        expr = chengpath.PathTrim(fnIr.returnExpr)
    if expr == "":
        err = Fmt"cold csg export empty return expression: {fnIr.functionName}"
        return ""
    if !CompilerColdCsgTextIsFactSafe(expr):
        err = "cold csg export unsafe return expression"
        return ""
    return expr

fn CompilerColdCsgTypeSupported(typeRaw: str): bool =
    let t = chengpath.PathTrim(typeRaw)
    if t == "" || t == "int32" || t == "int" || t == "bool" || t == "str" || t == "cstring" ||
       t == "int32[]" || t == "int[]":
        return true
    if t.len > 1 && t[0] >= 'A' && t[0] <= 'Z':
        return true
    return false

fn CompilerColdCsgParamSpec(name: str,
                             typeRaw: str,
                             err: var str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    if name == "" || !CompilerColdCsgTextIsFactSafe(name):
        err = Fmt"cold csg export unsafe param name: {name}"
        return ""
    if !CompilerColdCsgTypeSupported(typeText):
        err = Fmt"cold csg export unsupported param type: {name}:{typeText}"
        return ""
    if typeText == "" || typeText == "int32" || typeText == "int" || typeText == "bool":
        return Fmt"{name}:i"
    if typeText == "str" || typeText == "cstring":
        return Fmt"{name}:s"
    if typeText == "int32[]" || typeText == "int[]":
        return Fmt"{name}:{typeText}"
    return Fmt"{name}:{typeText}"

fn CompilerColdCsgFunctionParamsCsv(csg: var CompilerCsg,
                                     fnIr: texpr.TypedExprIrFunction,
                                     err: var str): str =
    var maxSlot = -1
    let nodeEnd = fnIr.nodeStart + fnIr.nodeCount
    for nodeIndex in fnIr.nodeStart..<nodeEnd:
        let node = csg.typedIr.nodes[nodeIndex]
        if node.opKind == texpr.TypedExprIrOpParamRef:
            if !CompilerColdCsgTypeSupported(node.resultType):
                err = Fmt"cold csg export unsupported param type: {fnIr.functionName}.{node.paramName}:{node.resultType}"
                return ""
            if node.paramSlot > maxSlot:
                maxSlot = node.paramSlot
    if maxSlot < 0:
        return ""
    if maxSlot >= 8:
        err = Fmt"cold csg export too many params: {fnIr.functionName}"
        return ""
    var out: str
    for slot in 0..maxSlot:
        var name: str
        for nodeIndex in fnIr.nodeStart..<nodeEnd:
            let node = csg.typedIr.nodes[nodeIndex]
            if node.opKind == texpr.TypedExprIrOpParamRef && node.paramSlot == slot:
                name = node.paramName
                break
        if name == "":
            err = Fmt"cold csg export sparse params: {fnIr.functionName}"
            return ""
        var typeText = "int32"
        for nodeIndex in fnIr.nodeStart..<nodeEnd:
            let node = csg.typedIr.nodes[nodeIndex]
            if node.opKind == texpr.TypedExprIrOpParamRef && node.paramSlot == slot:
                typeText = node.resultType
                break
        let spec = CompilerColdCsgParamSpec(name, typeText, err)
        if err != "":
            return ""
        if len(out) > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{spec}"
    return out

fn CompilerColdCsgAppendFunctionRows(csg: var CompilerCsg,
                                      out: var str,
                                      err: var str): bool =
    for i in 0..<csg.typedIr.functions.len:
        let fnIr = csg.typedIr.functions[i]
        if !CompilerColdCsgTypeSupported(fnIr.returnType):
            err = Fmt"cold csg export unsupported return type: {fnIr.functionName}:{fnIr.returnType}"
            return false
        let name = CompilerColdCsgTailName(fnIr.functionName)
        if !CompilerColdCsgTextIsFactSafe(name):
            err = Fmt"cold csg export unsafe function name: {name}"
            return false
        let params = CompilerColdCsgFunctionParamsCsv(csg, fnIr, err)
        if err != "":
            return false
        var returnType = fnIr.returnType
        if returnType == "":
            returnType = "int32"
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_function\t{IntToStr(i)}\t{name}\t{params}\t{returnType}")
    return true

fn CompilerColdCsgAppendTypedTypeRows(csg: var CompilerCsg,
                                       out: var str,
                                       err: var str): bool =
    for i in 0..<csg.typedIr.coldCsgTypeRows.len:
        let row = csg.typedIr.coldCsgTypeRows[i]
        if row.typeName == "" || row.specs == "" ||
           !CompilerColdCsgTextIsFactSafe(row.typeName) ||
           !CompilerColdCsgTextIsFactSafe(row.specs):
            err = "cold csg export unsafe typed type row"
            return false
        if row.rowKind == texpr.TypedExprColdCsgTypeObject:
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_object\t{row.typeName}\t{row.specs}")
        else:
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_type\t{row.typeName}\t{row.specs}")
    return true

fn CompilerColdCsgAppendTypedStatementRowsForFunction(csg: var CompilerCsg,
                                                       fnIr: texpr.TypedExprIrFunction,
                                                       out: var str,
                                                       emitted: var int32,
                                                       err: var str): bool =
    let fnIndex = CompilerColdCsgFunctionIndex(csg, fnIr.functionName)
    if fnIndex < 0:
        err = Fmt"cold csg export missing function index: {fnIr.functionName}"
        return false
    for i in 0..<csg.typedIr.coldCsgStatementRows.len:
        let row = csg.typedIr.coldCsgStatementRows[i]
        if CompilerColdCsgTailName(row.functionName) != CompilerColdCsgTailName(fnIr.functionName):
            continue
        if row.kind == "unsupported":
            err = Fmt"cold csg export unsupported typed statement at {row.sourcePath}:{IntToStr(row.lineNumber)}: {row.payloadText}"
            return false
        if row.payloadText == "" || !CompilerColdCsgPayloadIsLineSafe(row.payloadText):
            err = Fmt"cold csg export unsafe typed statement row at {row.sourcePath}:{IntToStr(row.lineNumber)}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(row.lineIndent)}\t{row.payloadText}")
        emitted = emitted + 1
    return true

fn CompilerColdCsgAppendForStmt(fnIndex: int32,
                                 stmt: texpr.TypedExprIrStatement,
                                 out: var str,
                                 err: var str): bool =
    let payload = CompilerColdCsgControlPayload(stmt.surfaceText, "for")
    let inPos = parser.ParserFindText(payload, " in ")
    if inPos <= 0:
        err = Fmt"cold csg export unsupported for header: {stmt.surfaceText}"
        return false
    let iterName = chengpath.PathTrim(chengpath.TextSlice(payload, 0, inPos))
    let rangeStart = inPos + 4
    let rangeText = chengpath.PathTrim(chengpath.TextSlice(payload,
                                                           rangeStart,
                                                           payload.len - rangeStart))
    var startExpr = ""
    var endExpr = ""
    var inclusive = false
    if !parser.ParserParseRangeExpr(rangeText, startExpr, endExpr, inclusive):
        err = Fmt"cold csg export unsupported for range: {stmt.surfaceText}"
        return false
    var mode = "lt"
    if inclusive:
        mode = "le"
    if !CompilerColdCsgTextIsFactSafe(iterName) ||
       !CompilerColdCsgTextIsFactSafe(startExpr) ||
       !CompilerColdCsgTextIsFactSafe(endExpr):
        err = "cold csg export unsafe for row"
        return false
    CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tfor_range\t{iterName}\t{startExpr}\t{endExpr}\t{mode}")
    return true

fn CompilerColdCsgHasLocalDeclAtLine(csg: var CompilerCsg,
                                      fnIr: texpr.TypedExprIrFunction,
                                      lineNumber: int32,
                                      bindingName: str): bool =
    if bindingName == "":
        return false
    let stmtEnd = fnIr.statementStart + fnIr.statementCount
    for stmtIndex in fnIr.statementStart..<stmtEnd:
        if stmtIndex < 0 || stmtIndex >= csg.typedIr.statements.len:
            continue
        let stmt = csg.typedIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtLocalDecl &&
           stmt.lineNumber == lineNumber &&
           stmt.bindingName == bindingName:
            return true
    return false

fn CompilerColdCsgHasNonCallStatementAtLine(csg: var CompilerCsg,
                                             fnIr: texpr.TypedExprIrFunction,
                                             lineNumber: int32): bool =
    let stmtEnd = fnIr.statementStart + fnIr.statementCount
    for stmtIndex in fnIr.statementStart..<stmtEnd:
        if stmtIndex < 0 || stmtIndex >= csg.typedIr.statements.len:
            continue
        let stmt = csg.typedIr.statements[stmtIndex]
        if stmt.lineNumber != lineNumber:
            continue
        if stmt.kind != texpr.TypedExprIrStmtCall:
            return true
    return false

fn CompilerColdCsgHasColdTypeRow(csg: var CompilerCsg,
                                  typeRaw: str): bool =
    let typeName = chengpath.PathTrim(typeRaw)
    if typeName == "":
        return false
    for i in 0..<csg.typedIr.coldCsgTypeRows.len:
        if csg.typedIr.coldCsgTypeRows[i].typeName == typeName:
            return true
    return false

fn CompilerColdCsgShouldEmitTypedLocal(csg: var CompilerCsg,
                                        typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    if typeText == "" ||
       typeText == "int32" ||
       typeText == "int" ||
       typeText == "str" ||
       typeText == "cstring" ||
       typeText == "int32[]" ||
       typeText == "int[]":
        return true
    if parser.ParserStartsWith(typeText, "int32["):
        return true
    return CompilerColdCsgHasColdTypeRow(csg, typeText)

fn CompilerColdCsgAppendStatementRow(csg: var CompilerCsg,
                                      fnIr: texpr.TypedExprIrFunction,
                                      stmt: texpr.TypedExprIrStatement,
                                      out: var str,
                                      err: var str): bool =
    let fnIndex = CompilerColdCsgFunctionIndex(csg, fnIr.functionName)
    if fnIndex < 0:
        err = Fmt"cold csg export missing function index: {fnIr.functionName}"
        return false
    if stmt.kind == texpr.TypedExprIrStmtLocalDecl:
        if !CompilerColdCsgTypeSupported(stmt.resultType):
            err = Fmt"cold csg export unsupported local type: {stmt.bindingName}:{stmt.resultType}"
            return false
        if stmt.bindingName == "" || stmt.surfaceText == "":
            if stmt.bindingName != "" && stmt.resultType != "":
                CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tdefault\t{stmt.bindingName}\t{stmt.resultType}")
                return true
            err = Fmt"cold csg export unsupported local decl: {fnIr.functionName}"
            return false
        if stmt.resultType != "" && CompilerColdCsgShouldEmitTypedLocal(csg, stmt.resultType):
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tvar_t\t{stmt.bindingName}\t{stmt.resultType}\t{stmt.surfaceText}")
            return true
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tvar\t{stmt.bindingName}\t{stmt.surfaceText}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtLetCall:
        if CompilerColdCsgHasLocalDeclAtLine(csg, fnIr, stmt.lineNumber, stmt.bindingName):
            return true
        if !CompilerColdCsgTypeSupported(stmt.resultType):
            err = Fmt"cold csg export unsupported let-call result type: {stmt.bindingName}:{stmt.resultType}"
            return false
        if stmt.bindingName == "":
            err = Fmt"cold csg export missing let-call binding: {fnIr.functionName}"
            return false
        let callExpr = CompilerColdCsgCallExpr(stmt, err)
        if err != "":
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tvar\t{stmt.bindingName}\t{callExpr}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtCall:
        if CompilerColdCsgHasNonCallStatementAtLine(csg, fnIr, stmt.lineNumber):
            return true
        if stmt.callTarget == "":
            err = Fmt"cold csg export missing call target: {fnIr.functionName}"
            return false
        if stmt.callTargetImportc:
            err = Fmt"cold csg export unsupported importc call: {stmt.callTarget}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tcall\t{CompilerColdCsgTailName(stmt.callTarget)}\t{stmt.callArgsText}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtAssign:
        if stmt.resultType != "int32":
            err = Fmt"cold csg export unsupported assign type: {stmt.bindingName}:{stmt.resultType}"
            return false
        if stmt.bindingName == "" || stmt.surfaceText == "":
            err = Fmt"cold csg export unsupported assign: {fnIr.functionName}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tassign\t{stmt.bindingName}\t{stmt.surfaceText}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtReturn:
        let expr = CompilerColdCsgReturnExpr(stmt, fnIr, err)
        if err != "":
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\treturn\t{expr}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtIf:
        let condition = CompilerColdCsgControlPayload(stmt.surfaceText, "if")
        if condition == "":
            err = Fmt"cold csg export empty if condition: {fnIr.functionName}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tif\t{condition}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtElif:
        let condition = CompilerColdCsgControlPayload(stmt.surfaceText, "elif")
        if condition == "":
            err = Fmt"cold csg export empty elif condition: {fnIr.functionName}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\telif\t{condition}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtElse:
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\telse")
        return true
    if stmt.kind == texpr.TypedExprIrStmtFor:
        return CompilerColdCsgAppendForStmt(fnIndex, stmt, out, err)
    if stmt.kind == texpr.TypedExprIrStmtMatch:
        let target = chengpath.PathTrim(stmt.surfaceText)
        if target == "" || !CompilerColdCsgTextIsFactSafe(target):
            err = Fmt"cold csg export unsupported match target: {fnIr.functionName}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tmatch\t{target}")
        return true
    if stmt.kind == texpr.TypedExprIrStmtCase:
        let arm = chengpath.PathTrim(stmt.surfaceText)
        var variant = arm
        var bind: str
        let open = parser.ParserFindText(arm, "(")
        if open > 0:
            if arm.len <= open + 1 || arm[arm.len - 1] != ')':
                err = Fmt"cold csg export malformed case arm: {arm}"
                return false
            variant = chengpath.PathTrim(chengpath.TextSlice(arm, 0, open))
            bind = chengpath.PathTrim(chengpath.TextSlice(arm, open + 1, arm.len - open - 2))
        if variant == "" ||
           !CompilerColdCsgTextIsFactSafe(variant) ||
           !CompilerColdCsgTextIsFactSafe(bind):
            err = Fmt"cold csg export unsupported case arm: {arm}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(stmt.lineIndent)}\tcase\t{variant}\t{bind}")
        return true
    err = Fmt"cold csg export unsupported statement kind: {texpr.TypedExprIrStatementKindText(stmt.kind)}"
    return false

fn CompilerColdCsgAppendExprCaseRow(fnIndex: int32,
                                     indent: int32,
                                     armRaw: str,
                                     out: var str,
                                     err: var str): bool =
    let arm = chengpath.PathTrim(armRaw)
    var variant = arm
    var bind: str
    let open = parser.ParserFindText(arm, "(")
    if open > 0:
        if arm.len <= open + 1 || arm[arm.len - 1] != ')':
            err = Fmt"cold csg export malformed case arm: {arm}"
            return false
        variant = chengpath.PathTrim(chengpath.TextSlice(arm, 0, open))
        bind = chengpath.PathTrim(chengpath.TextSlice(arm, open + 1, arm.len - open - 2))
    if variant == "" ||
       !CompilerColdCsgTextIsFactSafe(variant) ||
       !CompilerColdCsgTextIsFactSafe(bind):
        err = Fmt"cold csg export unsupported case arm: {arm}"
        return false
    CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tcase\t{variant}\t{bind}")
    return true

fn CompilerColdCsgAppendExprLayerStatementRow(fnIndex: int32,
                                               expr: parser.NormalizedExpr,
                                               out: var str,
                                               err: var str): bool =
    var indent = expr.columnNumber - 1
    if indent < 0:
        indent = 0
    if expr.kind == parser.NormalizedExprReturn:
        let exprText = chengpath.PathTrim(expr.surfaceText)
        if exprText == "" || !CompilerColdCsgTextIsFactSafe(exprText):
            err = "cold csg export unsafe normalized return"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\treturn\t{exprText}")
        return true
    if expr.kind == parser.NormalizedExprIfStmt:
        let payload = chengpath.PathTrim(expr.surfaceText)
        if payload == "" || !CompilerColdCsgTextIsFactSafe(payload):
            err = "cold csg export unsafe normalized if"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tif\t{payload}")
        return true
    if expr.kind == parser.NormalizedExprElifStmt:
        let payload = chengpath.PathTrim(expr.surfaceText)
        if payload == "" || !CompilerColdCsgTextIsFactSafe(payload):
            err = "cold csg export unsafe normalized elif"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\telif\t{payload}")
        return true
    if expr.kind == parser.NormalizedExprElseStmt:
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\telse")
        return true
    if expr.kind == parser.NormalizedExprForStmt:
        let payload = chengpath.PathTrim(expr.surfaceText)
        let inPos = parser.ParserFindText(payload, " in ")
        if inPos <= 0:
            err = Fmt"cold csg export unsupported normalized for: {payload}"
            return false
        let iterName = chengpath.PathTrim(chengpath.TextSlice(payload, 0, inPos))
        let rangeText = chengpath.PathTrim(chengpath.TextSlice(payload,
                                                               inPos + 4,
                                                               payload.len - inPos - 4))
        var startExpr: str
        var endExpr: str
        var inclusive = false
        if !parser.ParserParseRangeExpr(rangeText, startExpr, endExpr, inclusive):
            err = Fmt"cold csg export unsupported normalized range: {payload}"
            return false
        var mode = "lt"
        if inclusive:
            mode = "le"
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tfor_range\t{iterName}\t{startExpr}\t{endExpr}\t{mode}")
        return true
    if expr.kind == parser.NormalizedExprMatchStmt:
        let target = chengpath.PathTrim(expr.surfaceText)
        if target == "" || !CompilerColdCsgTextIsFactSafe(target):
            err = "cold csg export unsafe normalized match"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tmatch\t{target}")
        return true
    if expr.kind == parser.NormalizedExprCaseStmt:
        return CompilerColdCsgAppendExprCaseRow(fnIndex, indent, expr.surfaceText, out, err)
    if expr.kind == parser.NormalizedExprAssign:
        let lhs = chengpath.PathTrim(expr.surfaceText)
        let rhs = chengpath.PathTrim(expr.callArgsText)
        if lhs == "" || rhs == "" ||
           !CompilerColdCsgTextIsFactSafe(lhs) ||
           !CompilerColdCsgTextIsFactSafe(rhs):
            err = "cold csg export unsafe normalized assign"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tassign\t{lhs}\t{rhs}")
        return true
    return true

fn CompilerColdCsgExprIsStructuredStatement(expr: parser.NormalizedExpr): bool =
    return expr.kind == parser.NormalizedExprReturn ||
           expr.kind == parser.NormalizedExprAssign ||
           expr.kind == parser.NormalizedExprIfStmt ||
           expr.kind == parser.NormalizedExprElifStmt ||
           expr.kind == parser.NormalizedExprElseStmt ||
           expr.kind == parser.NormalizedExprForStmt ||
           expr.kind == parser.NormalizedExprMatchStmt ||
           expr.kind == parser.NormalizedExprCaseStmt

fn CompilerColdCsgStatementKindMatchesExpr(stmt: texpr.TypedExprIrStatement,
                                            expr: parser.NormalizedExpr): bool =
    if stmt.kind == texpr.TypedExprIrStmtReturn && expr.kind == parser.NormalizedExprReturn:
        return true
    if stmt.kind == texpr.TypedExprIrStmtAssign && expr.kind == parser.NormalizedExprAssign:
        return true
    if stmt.kind == texpr.TypedExprIrStmtIf && expr.kind == parser.NormalizedExprIfStmt:
        return true
    if stmt.kind == texpr.TypedExprIrStmtElif && expr.kind == parser.NormalizedExprElifStmt:
        return true
    if stmt.kind == texpr.TypedExprIrStmtElse && expr.kind == parser.NormalizedExprElseStmt:
        return true
    if stmt.kind == texpr.TypedExprIrStmtFor && expr.kind == parser.NormalizedExprForStmt:
        return true
    if stmt.kind == texpr.TypedExprIrStmtMatch && expr.kind == parser.NormalizedExprMatchStmt:
        return true
    if stmt.kind == texpr.TypedExprIrStmtCase && expr.kind == parser.NormalizedExprCaseStmt:
        return true
    return false

fn CompilerColdCsgFunctionHasStatementForExpr(csg: var CompilerCsg,
                                               fnIr: texpr.TypedExprIrFunction,
                                               expr: parser.NormalizedExpr): bool =
    let stmtEnd = fnIr.statementStart + fnIr.statementCount
    for stmtIndex in fnIr.statementStart..<stmtEnd:
        if stmtIndex < 0 || stmtIndex >= csg.typedIr.statements.len:
            continue
        let stmt = csg.typedIr.statements[stmtIndex]
        if stmt.lineNumber == expr.lineNumber &&
           CompilerColdCsgStatementKindMatchesExpr(stmt, expr):
            return true
    return false

fn CompilerColdCsgAppendFunctionStatementRows(csg: var CompilerCsg,
                                               fnIr: texpr.TypedExprIrFunction,
                                               out: var str,
                                               emitted: var int32,
                                               err: var str): bool =
    let fnIndex = CompilerColdCsgFunctionIndex(csg, fnIr.functionName)
    if fnIndex < 0:
        err = Fmt"cold csg export missing function index: {fnIr.functionName}"
        return false
    let firstLine = fnIr.signatureLineNumber + 1
    let lastLine = fnIr.endLineNumber
    if firstLine > lastLine:
        return true
    for lineNumber in firstLine..lastLine:
        let stmtEnd = fnIr.statementStart + fnIr.statementCount
        for stmtIndex in fnIr.statementStart..<stmtEnd:
            if stmtIndex < 0 || stmtIndex >= csg.typedIr.statements.len:
                continue
            let stmt = csg.typedIr.statements[stmtIndex]
            if stmt.lineNumber != lineNumber:
                continue
            if !CompilerColdCsgAppendStatementRow(csg, fnIr, stmt, out, err):
                return false
            emitted = emitted + 1
        for exprIndex in 0..<csg.exprLayer.exprs.len:
            let expr = csg.exprLayer.exprs[exprIndex]
            if expr.lineNumber != lineNumber:
                continue
            if parser.ParserNormalizePath(expr.sourcePath) != parser.ParserNormalizePath(fnIr.sourcePath):
                continue
            if !CompilerColdCsgExprIsStructuredStatement(expr):
                continue
            if CompilerColdCsgFunctionHasStatementForExpr(csg, fnIr, expr):
                continue
            if !CompilerColdCsgAppendExprLayerStatementRow(fnIndex, expr, out, err):
                return false
            emitted = emitted + 1
    if emitted <= 0:
        let returnExpr = chengpath.PathTrim(fnIr.returnExpr)
        if returnExpr == "" || !CompilerColdCsgTextIsFactSafe(returnExpr):
            err = Fmt"cold csg export function has no statements: {fnIr.functionName}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t4\treturn\t{returnExpr}")
        emitted = emitted + 1
    return true

fn CompilerColdCsgAppendTypeRowsFromSource(source: str,
                                             out: var str): bool =
    out = ""
    let lines = strutil.Split(source, '\n')
    var inTriple = false
    var i = 0
    while i < lines.len:
        let rawLine = lines[i]
        if inTriple:
            if CompilerColdCsgLineHasTripleQuote(rawLine):
                inTriple = false
            i = i + 1
            continue
        let line = std.strutils.TrimSpace(rawLine)
        if line == "":
            i = i + 1
            continue
        if !CompilerColdCsgLineTopLevel(rawLine):
            if CompilerColdCsgLineHasTripleQuote(rawLine):
                inTriple = true
            i = i + 1
            continue
        if line == "type":
            i = i + 1
            var blockIndent = -1
            while i < lines.len:
                let entryRaw = lines[i]
                let entryTrimmed = std.strutils.TrimSpace(entryRaw)
                if entryTrimmed == "":
                    i = i + 1
                    continue
                if CompilerColdCsgLineTopLevel(entryRaw):
                    break
                let entryIndent = CompilerColdCsgLineIndentWidth(entryRaw)
                if blockIndent < 0:
                    blockIndent = entryIndent
                if entryIndent < blockIndent:
                    break
                if entryIndent > blockIndent:
                    return false
                var typeName = ""
                var rhs = ""
                if !CompilerColdCsgTypeEntryParts(entryTrimmed, typeName, rhs):
                    return false
                var nextIndex = i + 1
                if !CompilerColdCsgAppendTypeEntryRows(lines,
                                                        i,
                                                        entryIndent,
                                                        typeName,
                                                        rhs,
                                                        out,
                                                        nextIndex):
                    return false
                i = nextIndex
            continue
        if !std.strutils.StartsWith(line, "type "):
            if CompilerColdCsgLineHasTripleQuote(rawLine):
                inTriple = true
            i = i + 1
            continue
        let tail = std.strutils.TrimSpace(chengpath.TextSlice(line, 5, line.len - 5))
        var typeName = ""
        var rhs = ""
        if !CompilerColdCsgTypeEntryParts(tail, typeName, rhs):
            i = i + 1
            continue
        var nextIndex = i + 1
        if !CompilerColdCsgAppendTypeEntryRows(lines,
                                                i,
                                                CompilerColdCsgLineIndentWidth(rawLine),
                                                typeName,
                                                rhs,
                                                out,
                                                nextIndex):
            return false
        i = nextIndex
    return true

fn CompilerColdCsgLineHasTripleQuote(line: str): bool =
    return std.strutils.Contains(line, "\"\"\"")

fn CompilerColdCsgBindingNameFromHead(headRaw: str): str =
    return parser.ParserIdentPrefix(parser.ParserFirstToken(std.strutils.TrimSpace(headRaw)))

fn CompilerColdCsgBindingTypeFromHead(headRaw: str): str =
    let head = std.strutils.TrimSpace(headRaw)
    let colon = parser.ParserFindText(head, ":")
    if colon <= 0:
        return ""
    return std.strutils.TrimSpace(chengpath.TextSlice(head, colon + 1, head.len - colon - 1))

fn CompilerColdCsgFindAssignEq(text: str): int32 =
    for i in 0..<text.len:
        if text[i] != '=':
            continue
        if i + 1 < text.len && text[i + 1] == '=':
            continue
        if i > 0 && (text[i - 1] == '!' || text[i - 1] == '<' || text[i - 1] == '>'):
            continue
        return i
    return -1

fn CompilerColdCsgExprHasQuestionSuffix(exprRaw: str,
                                         stripped: var str): bool =
    stripped = std.strutils.TrimSpace(exprRaw)
    if stripped.len <= 1 || stripped[stripped.len - 1] != '?':
        return false
    var depth = 0
    for i in 0..<(stripped.len - 1):
        if stripped[i] == '(':
            depth = depth + 1
        elif stripped[i] == ')':
            depth = depth - 1
    if depth != 0:
        return false
    stripped = std.strutils.TrimSpace(chengpath.TextSlice(stripped, 0, stripped.len - 1))
    return true

fn CompilerColdCsgStripTrailingOpenBrace(textRaw: str): str =
    var text = std.strutils.TrimSpace(textRaw)
    if text.len > 0 && text[text.len - 1] == '{':
        text = std.strutils.TrimSpace(chengpath.TextSlice(text, 0, text.len - 1))
    return text

fn CompilerColdCsgFunctionNameFromLine(lineRaw: str): str =
    let line = std.strutils.TrimSpace(lineRaw)
    if !parser.ParserStartsWith(line, "fn "):
        return ""
    let tail = std.strutils.TrimSpace(chengpath.TextSlice(line, 3, line.len - 3))
    let open = parser.ParserFindText(tail, "(")
    if open <= 0:
        return ""
    return parser.ParserIdentPrefix(std.strutils.TrimSpace(chengpath.TextSlice(tail, 0, open)))

fn CompilerColdCsgAppendSourceStatementRow(csg: var CompilerCsg,
                                            fnIndex: int32,
                                            indent: int32,
                                            trimmedRaw: str,
                                            out: var str,
                                            err: var str): bool =
    let _ = csg
    let trimmed = std.strutils.TrimSpace(trimmedRaw)
    if trimmed == "" || trimmed == "{" || trimmed == "}":
        return true
    let arrow = parser.ParserFindText(trimmed, "=>")
    if arrow > 0:
        let arm = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, 0, arrow))
        let body = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, arrow + 2, trimmed.len - arrow - 2))
        var variant = arm
        var bind = ""
        let open = parser.ParserFindText(arm, "(")
        if open > 0:
            if arm.len <= open + 1 || arm[arm.len - 1] != ')':
                err = Fmt"cold csg export malformed match arm: {trimmed}"
                return false
            variant = std.strutils.TrimSpace(chengpath.TextSlice(arm, 0, open))
            bind = std.strutils.TrimSpace(chengpath.TextSlice(arm, open + 1, arm.len - open - 2))
        if !CompilerColdCsgTextIsFactSafe(variant) || !CompilerColdCsgTextIsFactSafe(bind):
            err = "cold csg export unsafe match arm"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tcase\t{variant}\t{bind}")
        if body != "":
            return CompilerColdCsgAppendSourceStatementRow(csg, fnIndex, indent + 4, body, out, err)
        return true
    if parser.ParserStartsWith(trimmed, "match "):
        let restRaw = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, 6, trimmed.len - 6))
        let target = CompilerColdCsgStripTrailingColon(CompilerColdCsgStripTrailingOpenBrace(restRaw))
        if target == "" || !CompilerColdCsgTextIsFactSafe(target):
            err = Fmt"cold csg export unsupported match target: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tmatch\t{target}")
        return true
    if parser.ParserStartsWith(trimmed, "return "):
        var expr = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, 7, trimmed.len - 7))
        var qExpr = ""
        var kind = "return"
        if CompilerColdCsgExprHasQuestionSuffix(expr, qExpr):
            err = "cold csg export rejects return expr?; bind the unwrapped value before return"
            return false
        if expr == "" || !CompilerColdCsgTextIsFactSafe(expr):
            err = Fmt"cold csg export unsafe return: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\t{kind}\t{expr}")
        return true
    var bindingPrefixLen = 0
    if parser.ParserStartsWith(trimmed, "let ") || parser.ParserStartsWith(trimmed, "var "):
        bindingPrefixLen = 4
    elif parser.ParserStartsWith(trimmed, "const "):
        bindingPrefixLen = 6
    if bindingPrefixLen > 0:
        let rest = std.strutils.TrimSpace(chengpath.TextSlice(trimmed,
                                                              bindingPrefixLen,
                                                              trimmed.len - bindingPrefixLen))
        let eq = CompilerColdCsgFindAssignEq(rest)
        if eq <= 0:
            let colon = parser.ParserFindText(rest, ":")
            if colon <= 0:
                err = Fmt"cold csg export unsupported binding: {trimmed}"
                return false
            let name = CompilerColdCsgBindingNameFromHead(chengpath.TextSlice(rest, 0, colon))
            let typeText = std.strutils.TrimSpace(chengpath.TextSlice(rest, colon + 1, rest.len - colon - 1))
            if name == "" || typeText == "" ||
               !CompilerColdCsgTextIsFactSafe(name) ||
               !CompilerColdCsgTextIsFactSafe(typeText):
                err = Fmt"cold csg export unsafe default binding: {trimmed}"
                return false
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tdefault\t{name}\t{typeText}")
            return true
        let head = chengpath.TextSlice(rest, 0, eq)
        let name = CompilerColdCsgBindingNameFromHead(head)
        let typeText = CompilerColdCsgBindingTypeFromHead(head)
        var expr = std.strutils.TrimSpace(chengpath.TextSlice(rest, eq + 1, rest.len - eq - 1))
        var qExpr = ""
        var kind = "var"
        if CompilerColdCsgExprHasQuestionSuffix(expr, qExpr):
            expr = qExpr
            kind = "let_q"
        if typeText != "":
            if !CompilerColdCsgTypeSupported(typeText):
                err = Fmt"cold csg export unsupported binding type: {trimmed}"
                return false
            if kind == "var":
                kind = "var_t"
            else:
                kind = "let_q_t"
        if name == "" || expr == "" ||
           !CompilerColdCsgTextIsFactSafe(name) ||
           !CompilerColdCsgTextIsFactSafe(expr) ||
           !CompilerColdCsgTextIsFactSafe(typeText):
            err = Fmt"cold csg export unsafe binding row: {trimmed}"
            return false
        if typeText != "":
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\t{kind}\t{name}\t{typeText}\t{expr}")
        else:
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\t{kind}\t{name}\t{expr}")
        return true
    if parser.ParserStartsWith(trimmed, "if "):
        let condition = CompilerColdCsgControlPayload(trimmed, "if")
        if condition == "":
            err = Fmt"cold csg export empty if condition: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tif\t{condition}")
        return true
    if parser.ParserStartsWith(trimmed, "elif "):
        let condition = CompilerColdCsgControlPayload(trimmed, "elif")
        if condition == "":
            err = Fmt"cold csg export empty elif condition: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\telif\t{condition}")
        return true
    if CompilerColdCsgStripTrailingColon(trimmed) == "else":
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\telse")
        return true
    if parser.ParserStartsWith(trimmed, "while "):
        let condition = CompilerColdCsgControlPayload(trimmed, "while")
        if condition == "":
            err = Fmt"cold csg export empty while condition: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\twhile\t{condition}")
        return true
    if parser.ParserStartsWith(trimmed, "for "):
        let payload = CompilerColdCsgControlPayload(trimmed, "for")
        let inPos = parser.ParserFindText(payload, " in ")
        if inPos <= 0:
            err = Fmt"cold csg export unsupported for header: {trimmed}"
            return false
        let iterName = std.strutils.TrimSpace(chengpath.TextSlice(payload, 0, inPos))
        let rangeText = std.strutils.TrimSpace(chengpath.TextSlice(payload,
                                                                   inPos + 4,
                                                                   payload.len - inPos - 4))
        var startExpr = ""
        var endExpr = ""
        var inclusive = false
        if !parser.ParserParseRangeExpr(rangeText, startExpr, endExpr, inclusive):
            err = Fmt"cold csg export unsupported for range: {trimmed}"
            return false
        var mode = "lt"
        if inclusive:
            mode = "le"
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tfor_range\t{iterName}\t{startExpr}\t{endExpr}\t{mode}")
        return true
    if trimmed == "break" || trimmed == "continue":
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\t{trimmed}")
        return true
    let eq = CompilerColdCsgFindAssignEq(trimmed)
    if eq > 0:
        let name = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, 0, eq))
        let expr = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, eq + 1, trimmed.len - eq - 1))
        if name == "" || expr == "" ||
           !CompilerColdCsgTextIsFactSafe(name) ||
           !CompilerColdCsgTextIsFactSafe(expr):
            err = Fmt"cold csg export unsafe assign: {trimmed}"
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\tassign\t{name}\t{expr}")
        return true
    let open = parser.ParserFindText(trimmed, "(")
    if open > 0 && trimmed.len > open + 1:
        var close = trimmed.len - 1
        var kind = "call"
        if trimmed[close] == '?':
            kind = "call_q"
            close = close - 1
        if close > open && trimmed[close] == ')':
            let callee = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, 0, open))
            let args = std.strutils.TrimSpace(chengpath.TextSlice(trimmed, open + 1, close - open - 1))
            if callee == "" || !CompilerColdCsgTextIsFactSafe(callee) || !CompilerColdCsgTextIsFactSafe(args):
                err = Fmt"cold csg export unsafe call: {trimmed}"
                return false
            CompilerColdCsgAppendLine(out, Fmt"cold_csg_stmt\t{IntToStr(fnIndex)}\t{IntToStr(indent)}\t{kind}\t{callee}\t{args}")
            return true
    err = Fmt"cold csg export unsupported source statement: {trimmed}"
    return false

fn CompilerColdCsgAppendStatementRowsFromSource(csg: var CompilerCsg,
                                                 source: str,
                                                 out: var str,
                                                 err: var str): bool =
    let lines = strutil.Split(source, '\n')
    var fnIndex = -1
    var inTriple = false
    for i in 0..<lines.len:
        let rawLine = lines[i]
        if inTriple:
            if CompilerColdCsgLineHasTripleQuote(rawLine):
                inTriple = false
            continue
        if CompilerColdCsgLineTopLevel(rawLine):
            let name = CompilerColdCsgFunctionNameFromLine(rawLine)
            if name != "":
                fnIndex = CompilerColdCsgFunctionIndex(csg, name)
                if fnIndex < 0:
                    err = Fmt"cold csg export missing function for source row: {name}"
                    return false
            if CompilerColdCsgLineHasTripleQuote(rawLine):
                inTriple = true
            continue
        if fnIndex < 0:
            continue
        let trimmed = std.strutils.TrimSpace(rawLine)
        if trimmed == "" ||
           parser.ParserStartsWith(trimmed, "#") ||
           parser.ParserStartsWith(trimmed, "//"):
            continue
        let indent = CompilerColdCsgLineIndentWidth(rawLine)
        if !CompilerColdCsgAppendSourceStatementRow(csg, fnIndex, indent, trimmed, out, err):
            return false
    return true

fn CompilerColdCsgFieldKindCodeFromTypeName(typeName: str): str =
    var t = std.strutils.TrimSpace(typeName)
    if t == "str" || t == "cstring":
        return "s"
    if t == "int32[]" || t == "int[]":
        return ""
    if t.len > 1 && t[0] >= 'A' && t[0] <= 'Z':
        return "v"
    return "i"

fn CompilerColdCsgObjectFieldSpec(typeName: str): str =
    let t = std.strutils.TrimSpace(typeName)
    if t == "int32[]" || t == "int[]":
        return ""
    if parser.ParserStartsWith(t, "int32[") && t.len > 7 && t[t.len - 1] == ']':
        return Fmt"a{chengpath.TextSlice(t, 6, t.len - 7)}"
    return CompilerColdCsgFieldKindCodeFromTypeName(t)

fn CompilerColdCsgFieldDeclSpec(declRaw: str): str =
    let decl = std.strutils.TrimSpace(declRaw)
    let colon = parser.ParserFindText(decl, ":")
    if colon <= 0:
        return ""
    let name = std.strutils.TrimSpace(chengpath.TextSlice(decl, 0, colon))
    var typeText = std.strutils.TrimSpace(chengpath.TextSlice(decl, colon + 1, decl.len - colon - 1))
    let eq = parser.ParserFindText(typeText, "=")
    if eq >= 0:
        typeText = std.strutils.TrimSpace(chengpath.TextSlice(typeText, 0, eq))
    if name == "" || typeText == "":
        return ""
    let spec = CompilerColdCsgObjectFieldSpec(typeText)
    if spec == "":
        return ""
    return Fmt"{name}:{spec}"

fn CompilerColdCsgObjectSpecsFromLines(lines: str[],
                                        startIndex: int32,
                                        endIndex: int32): str =
    var out = ""
    for i in startIndex..<endIndex:
        let trimmed = std.strutils.TrimSpace(lines[i])
        if trimmed == "":
            continue
        let spec = CompilerColdCsgFieldDeclSpec(lines[i])
        if spec == "":
            return ""
        if out != "":
            out = Fmt"{out},"
        out = Fmt"{out}{spec}"
    return out

fn CompilerColdCsgTupleSpecsFromText(fieldsRaw: str): str =
    let parts = strutil.Split(fieldsRaw, ',')
    var out = ""
    for i in 0..<parts.len:
        let trimmed = std.strutils.TrimSpace(parts[i])
        if trimmed == "":
            continue
        let spec = CompilerColdCsgFieldDeclSpec(parts[i])
        if spec == "":
            return ""
        if out != "":
            out = Fmt"{out},"
        out = Fmt"{out}{spec}"
    return out

fn CompilerColdCsgTypeEntryParts(lineRaw: str,
                                  name: var str,
                                  rhs: var str): bool =
    name = ""
    rhs = ""
    let line = std.strutils.TrimSpace(lineRaw)
    let eq = parser.ParserFindText(line, "=")
    if eq <= 0:
        return false
    let left = std.strutils.TrimSpace(chengpath.TextSlice(line, 0, eq))
    name = parser.ParserIdentPrefix(parser.ParserFirstToken(left))
    rhs = std.strutils.TrimSpace(chengpath.TextSlice(line, eq + 1, line.len - eq - 1))
    return name != ""

fn CompilerColdCsgTupleObjectRow(typeName: str,
                                  rhsRaw: str): str =
    let rhs = std.strutils.TrimSpace(rhsRaw)
    let open = parser.ParserFindText(rhs, "[")
    if open <= 0 || rhs.len <= open + 1 || rhs[rhs.len - 1] != ']':
        return ""
    let fields = chengpath.TextSlice(rhs, open + 1, rhs.len - open - 2)
    let specs = CompilerColdCsgTupleSpecsFromText(fields)
    if specs == "":
        return ""
    return Fmt"cold_csg_object\t{typeName}\t{specs}"

fn CompilerColdCsgLineIndentWidth(line: str): int32 =
    var indent = 0
    for i in 0..<line.len:
        if line[i] == ' ':
            indent = indent + 1
        elif line[i] == '\t':
            indent = indent + 4
        else:
            break
    return indent

fn CompilerColdCsgLineTopLevel(line: str): bool =
    let trimmed = std.strutils.TrimSpace(line)
    if trimmed == "":
        return false
    return CompilerColdCsgLineIndentWidth(line) == 0

fn CompilerColdCsgJoinIndentedLines(lines: str[],
                                     startIndex: int32,
                                     endIndex: int32): str =
    var out = ""
    for i in startIndex..<endIndex:
        let part = std.strutils.TrimSpace(lines[i])
        if part == "":
            continue
        if out != "":
            out = Fmt"{out} "
        out = Fmt"{out}{part}"
    return out

fn CompilerColdCsgAppendAdtTypeRow(typeName: str,
                                    variants: str,
                                    out: var str): bool =
    let trimmedVariants = std.strutils.TrimSpace(variants)
    if typeName == "" || trimmedVariants == "":
        return false
    CompilerColdCsgAppendLine(out, Fmt"cold_csg_type\t{typeName}\t{CompilerColdCsgVariantSpecsFromText(trimmedVariants)}")
    return true

fn CompilerColdCsgAppendTypeEntryRows(lines: str[],
                                       entryIndex: int32,
                                       entryIndent: int32,
                                       typeName: str,
                                       rhs: str,
                                       out: var str,
                                       nextIndex: var int32): bool =
    nextIndex = entryIndex + 1
    if parser.ParserStartsWith(rhs, "object"):
        let fieldStart = nextIndex
        var fieldEnd = nextIndex
        while nextIndex < lines.len:
            let fieldLine = lines[nextIndex]
            let fieldTrimmed = std.strutils.TrimSpace(fieldLine)
            if fieldTrimmed == "":
                nextIndex = nextIndex + 1
                continue
            if CompilerColdCsgLineTopLevel(fieldLine) ||
               CompilerColdCsgLineIndentWidth(fieldLine) <= entryIndent:
                break
            fieldEnd = nextIndex + 1
            nextIndex = nextIndex + 1
        let specs = CompilerColdCsgObjectSpecsFromLines(lines, fieldStart, fieldEnd)
        if specs == "":
            return false
        CompilerColdCsgAppendLine(out, Fmt"cold_csg_object\t{typeName}\t{specs}")
        return true
    if parser.ParserStartsWith(rhs, "tuple["):
        let row = CompilerColdCsgTupleObjectRow(typeName, rhs)
        if row == "":
            return false
        CompilerColdCsgAppendLine(out, row)
        return true
    var variants = rhs
    if variants == "":
        let variantStart = nextIndex
        var variantEnd = nextIndex
        while nextIndex < lines.len:
            let variantLine = lines[nextIndex]
            let variantTrimmed = std.strutils.TrimSpace(variantLine)
            if variantTrimmed == "":
                nextIndex = nextIndex + 1
                continue
            if CompilerColdCsgLineTopLevel(variantLine) ||
               CompilerColdCsgLineIndentWidth(variantLine) <= entryIndent:
                break
            variantEnd = nextIndex + 1
            nextIndex = nextIndex + 1
        variants = CompilerColdCsgJoinIndentedLines(lines, variantStart, variantEnd)
    return CompilerColdCsgAppendAdtTypeRow(typeName, variants, out)

fn CompilerColdCsgVariantSpecsFromText(text: str): str =
    var out = ""
    var pos = 0
    var emitted = 0
    while pos < Len(text):
        while pos < Len(text) && (text[pos] == ' ' || text[pos] == '|'):
            pos = pos + 1
        if pos >= Len(text):
            break
        var nameEnd = pos
        while nameEnd < Len(text) && text[nameEnd] != ' ' && text[nameEnd] != '(' && text[nameEnd] != '|':
            nameEnd = nameEnd + 1
        if nameEnd <= pos:
            break
        let variantName = text[pos..<nameEnd]
        pos = nameEnd
        var fieldCount = 0
        var fieldKinds = ""
        while pos < Len(text) && text[pos] == ' ':
            pos = pos + 1
        if pos < Len(text) && text[pos] == '(':
            pos = pos + 1
            var depth = 1
            var fieldStart = pos
            while pos < Len(text) && depth > 0:
                if text[pos] == '(':
                    depth = depth + 1
                else if text[pos] == ')':
                    depth = depth - 1
                if depth > 0:
                    pos = pos + 1
            if depth == 0:
                var fields = text[fieldStart..<pos]
                pos = pos + 1
                var fp = 0
                while fp < Len(fields):
                    while fp < Len(fields) && fields[fp] == ' ':
                        fp = fp + 1
                    if fp >= Len(fields):
                        break
                    var fnEnd = fp
                    while fnEnd < Len(fields) && fields[fnEnd] != ' ' && fields[fnEnd] != ':':
                        fnEnd = fnEnd + 1
                    if fnEnd <= fp:
                        break
                    fp = fnEnd
                    while fp < Len(fields) && (fields[fp] == ' ' || fields[fp] == ':'):
                        fp = fp + 1
                    var ftEnd = fp
                    var ftDepth = 0
                    while ftEnd < Len(fields):
                        var c = fields[ftEnd]
                        if c == '[':
                            ftDepth = ftDepth + 1
                        else if c == ']':
                            ftDepth = ftDepth - 1
                        else if c == ',' && ftDepth == 0:
                            break
                        ftEnd = ftEnd + 1
                    let fieldType = std.strutils.TrimSpace(fields[fp..<ftEnd])
                    if Len(fieldType) > 0:
                        fieldKinds = Fmt"{fieldKinds}{CompilerColdCsgFieldKindCodeFromTypeName(fieldType)}"
                    fieldCount = fieldCount + 1
                    fp = ftEnd
                    while fp < Len(fields) && fields[fp] == ',':
                        fp = fp + 1
        if emitted > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{variantName}:{IntToStr(fieldCount)}"
        if Len(fieldKinds) > 0:
            out = Fmt"{out}:{fieldKinds}"
        emitted = emitted + 1
        while pos < Len(text) && text[pos] == ' ':
            pos = pos + 1
        if pos < Len(text) && text[pos] == '|':
            pos = pos + 1
    return out

fn CompilerColdCsgFactsFromCompilerCsgInto(csg: var CompilerCsg,
                                            entrySymbolRaw: str,
                                            out: var str,
                                            err: var str): bool =
    out = ""
    err = ""
    var entrySymbol = entrySymbolRaw
    if entrySymbol == "":
        entrySymbol = "main"
    entrySymbol = CompilerColdCsgTailName(entrySymbol)
    if CompilerColdCsgFunctionIndex(csg, entrySymbol) < 0:
        err = Fmt"cold csg export entry not found: {entrySymbol}"
        return false
    CompilerColdCsgAppendLine(out, "cold_csg_version=1")
    CompilerColdCsgAppendLine(out, Fmt"cold_csg_entry={entrySymbol}")
    if !CompilerColdCsgAppendTypedTypeRows(csg, out, err):
        return false
    if !CompilerColdCsgAppendFunctionRows(csg, out, err):
        return false
    if csg.typedIr.coldCsgStatementRows.len > 0:
        for fnIndex in 0..<csg.typedIr.functions.len:
            let fnIr = csg.typedIr.functions[fnIndex]
            var emitted = 0
            if !CompilerColdCsgAppendTypedStatementRowsForFunction(csg,
                                                                   fnIr,
                                                                   out,
                                                                   emitted,
                                                                   err):
                return false
            if emitted <= 0:
                err = Fmt"cold csg export function has no typed cold statements: {fnIr.functionName}"
                return false
        return true
    for fnIndex in 0..<csg.typedIr.functions.len:
        let fnIr = csg.typedIr.functions[fnIndex]
        var emitted = 0
        if !CompilerColdCsgAppendFunctionStatementRows(csg,
                                                       fnIr,
                                                       out,
                                                       emitted,
                                                       err):
            return false
    return true

fn CompilerColdCsgFactsFromCompilerCsgIntoWithSource(csg: var CompilerCsg,
                                                       entrySymbolRaw: str,
                                                       sourceText: str,
                                                       out: var str,
                                                       err: var str): bool =
    out = ""
    err = ""
    var entrySymbol = entrySymbolRaw
    if entrySymbol == "":
        entrySymbol = "main"
    entrySymbol = CompilerColdCsgTailName(entrySymbol)
    if CompilerColdCsgFunctionIndex(csg, entrySymbol) < 0:
        err = Fmt"cold csg export entry not found: {entrySymbol}"
        return false
    CompilerColdCsgAppendLine(out, "cold_csg_version=1")
    CompilerColdCsgAppendLine(out, Fmt"cold_csg_entry={entrySymbol}")
    var typeRows = ""
    if !CompilerColdCsgAppendTypeRowsFromSource(sourceText, typeRows):
        err = " cold csg exporter: type rows failed"
        return false
    if typeRows != "":
        out = Fmt"{out}\n{typeRows}"
    if !CompilerColdCsgAppendFunctionRows(csg, out, err):
        return false
    if !CompilerColdCsgAppendStatementRowsFromSource(csg, sourceText, out, err):
        return false
    return true

fn CompilerCsgReport(csg: CompilerCsg): str =
    var out = ""
    let typedExprFacts = csg.typedExprFacts
    let loweringRules = texpr.TypedExprLoweringRulesFromFacts(typedExprFacts)
    let exprCounts = parser.NormalizedExprLayerKindCountsBuild(csg.exprLayer)
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", csg.packageId, "\n"], "")
    out = strutil.Join([out, "source_bundle_cid=", layout.FixedBytes32Hex(csg.sourceBundleCid), "\n"], "")
    out = strutil.Join([out, "expr_surface_source_count=", IntToStr(csg.exprLayer.sourceCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_expr_count=", IntToStr(exprCounts.exprCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_if_count=", IntToStr(exprCounts.ifCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_range_count=", IntToStr(exprCounts.rangeCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_comprehension_count=", IntToStr(exprCounts.comprehensionCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_fmt_count=", IntToStr(exprCounts.strFormatCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_result_intrinsic_count=", IntToStr(exprCounts.resultIntrinsicCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_try_count=", IntToStr(exprCounts.tryCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_default_init_count=", IntToStr(exprCounts.defaultInitCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_constructor_count=", IntToStr(exprCounts.constructorCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_return_count=", IntToStr(exprCounts.returnCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_assign_count=", IntToStr(exprCounts.assignCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_if_stmt_count=", IntToStr(exprCounts.ifStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_elif_stmt_count=", IntToStr(exprCounts.elifStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_else_stmt_count=", IntToStr(exprCounts.elseStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_for_stmt_count=", IntToStr(exprCounts.forStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_match_stmt_count=", IntToStr(exprCounts.matchStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_case_stmt_count=", IntToStr(exprCounts.caseStmtCount), "\n"], "")
    out = strutil.Join([out, "expr_surface_question_residual_count=", IntToStr(csg.exprLayer.questionResidualCount), "\n"], "")
    out = strutil.Join([out, texpr.TypedExprReportText(typedExprFacts, loweringRules)], "")
    out = strutil.Join([out, CompilerCsgEgraphActiveContractReport(), "\n"], "")
    out = strutil.Join([out, "canonical_graph_cid=", layout.FixedBytes32Hex(csg.canonicalGraphCid), "\n"], "")
    out = strutil.Join([out, "graph_cid=", layout.FixedBytes32Hex(csg.graphCid), "\n"], "")
    out = strutil.Join([out, "node_count=", IntToStr(csg.nodeCount), "\n"], "")
    out = strutil.Join([out, "edge_count=", IntToStr(csg.edgeCount)], "")
    for i in 0..<csg.nodes.len:
        out = strutil.Join([out, "\n", CompilerCsgNodeReportLine(i, csg.nodes[i])], "")
    for i in 0..<csg.edges.len:
        out = strutil.Join([out, "\n", CompilerCsgEdgeReportLine(i, csg.edges[i])], "")
    return out

