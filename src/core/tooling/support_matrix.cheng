import std/strutils as strutil
import cheng/core/tooling/compiler_runtime as crun
import cheng/core/backend/build_plan as buildplan
import cheng/core/backend/system_link_plan as slplan

type
    SupportTargetRow =
        targetTriple: str
        objectFormat: str
        emitReady: bool
        runReady: bool
        debugReady: bool
        profileReady: bool
        releaseReady: bool
        nativeProvidersRequired: bool
        nativeProviderModulesRequired: bool
        linuxNolibcRuntime: bool

fn SupportMatrixBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn SupportMatrixAppendLine(out: var str,
                             key: str,
                             value: str) =
    if len(out) > 0:
        out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, key, "=", value], "")

fn SupportMatrixLanguageSurfaceText(): str =
    return "line_normalized_parser_stub"

fn SupportMatrixLanguageParsedText(): str =
    return "fn,import,let,var,const,type,if,for,while,case,range,comprehension,strformat,multiline_string,result_intrinsic,try"

fn SupportMatrixLanguageParsedUnsupportedText(): str =
    return "func,proc,method,converter,grouped_import_alias"

fn SupportMatrixOrdinaryPipelineText(): str =
    let contract = crun.CompilerRuntimeGetContract("")
    return contract.ordinaryPipelineState

// The target support matrix data below is intentionally hardcoded as literal struct
// initializers. This is a bootstrap constraint: the compiler must know its own
// targets at compile time because there is no runtime configuration mechanism
// available during the bootstrap phase. Once a stable configuration system exists,
// this data can be migrated to an external file (e.g. TOML/JSON) loaded at init.
// The target support matrix data below is intentionally hardcoded as literal struct
// initializers. This is a bootstrap constraint: the compiler must know its own
// targets at compile time because there is no runtime configuration mechanism
// available during the bootstrap phase. Once a stable configuration system exists,
// this data can be migrated to an external file (e.g. TOML/JSON) loaded at init.
fn SupportMatrixTargetRows(): SupportTargetRow[] =
    var out: SupportTargetRow[]
    add(out,
        SupportTargetRow(targetTriple: "arm64-apple-darwin",
                           objectFormat: "macho",
                           emitReady: true,
                           runReady: true,
                           debugReady: true,
                           profileReady: true,
                           releaseReady: true,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        SupportTargetRow(targetTriple: "x86_64-apple-darwin",
                           objectFormat: "macho",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        SupportTargetRow(targetTriple: "aarch64-unknown-linux-gnu",
                           objectFormat: "elf",
                           emitReady: true,
                           runReady: true,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: false,
                           linuxNolibcRuntime: true))
    add(out,
        SupportTargetRow(targetTriple: "x86_64-unknown-linux-gnu",
                           objectFormat: "elf",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        SupportTargetRow(targetTriple: "aarch64-pc-windows-msvc",
                           objectFormat: "coff",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        SupportTargetRow(targetTriple: "x86_64-pc-windows-msvc",
                           objectFormat: "coff",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        SupportTargetRow(targetTriple: "wasm32-unknown-unknown",
                           objectFormat: "wasm",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: false,
                           nativeProviderModulesRequired: false,
                           linuxNolibcRuntime: false))
    return out

fn SupportMatrixTargetSummary(rows: SupportTargetRow[]): str =
    var out = ""
    for i in 0..<rows.len:
        let row = rows[i]
        if len(out) > 0:
            out = strutil.Join([out, ","], "")
        out = strutil.Join([out, row.targetTriple], "")
    return out

fn SupportMatrixReport(rootDir: str): str =
    let _ = rootDir
    var out = ""
    let rows = SupportMatrixTargetRows()
    let compilerPlan = buildplan.BackendBuildPlanDefault(rootDir)
    let backendPlan = buildplan.BackendBuildPlanBackendDriver(rootDir)
    SupportMatrixAppendLine(out, "format", "cheng_support_matrix_v1")
    SupportMatrixAppendLine(out, "language_surface", SupportMatrixLanguageSurfaceText())
    SupportMatrixAppendLine(out, "language_ast_authority", "0")
    SupportMatrixAppendLine(out, "language_parsed_features", SupportMatrixLanguageParsedText())
    SupportMatrixAppendLine(out, "language_parsed_but_rejected_features", SupportMatrixLanguageParsedUnsupportedText())
    SupportMatrixAppendLine(out, "ordinary_pipeline_state", SupportMatrixOrdinaryPipelineText())
    SupportMatrixAppendLine(out, "ordinary_primary_object_codegen_ready", "1")
    SupportMatrixAppendLine(out, "typed_expr_unknown_gate", "0")
    SupportMatrixAppendLine(out, "typed_expr_deferred_gate", "0")
    SupportMatrixAppendLine(out, "target_count", IntToStr(rows.len))
    SupportMatrixAppendLine(out, "targets", SupportMatrixTargetSummary(rows))
    SupportMatrixAppendLine(out, "compiler_build_source_unit_count", IntToStr(compilerPlan.sourceUnits.len))
    SupportMatrixAppendLine(out, "backend_driver_build_source_unit_count", IntToStr(backendPlan.sourceUnits.len))
    for i in 0..<rows.len:
        let row = rows[i]
        let prefix = strutil.Join(["target[", IntToStr(i), "]"], "")
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".triple"], ""), row.targetTriple)
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".object_format"], ""), row.objectFormat)
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".emit_ready"], ""), SupportMatrixBoolText(row.emitReady))
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".run_ready"], ""), SupportMatrixBoolText(row.runReady))
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".debug_ready"], ""), SupportMatrixBoolText(row.debugReady))
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".profile_ready"], ""), SupportMatrixBoolText(row.profileReady))
        SupportMatrixAppendLine(out, strutil.Join([prefix, ".release_ready"], ""), SupportMatrixBoolText(row.releaseReady))
        SupportMatrixAppendLine(out,
                                  strutil.Join([prefix, ".native_providers_required"], ""),
                                  SupportMatrixBoolText(row.nativeProvidersRequired))
        SupportMatrixAppendLine(out,
                                  strutil.Join([prefix, ".native_provider_modules_required"], ""),
                                  SupportMatrixBoolText(row.nativeProviderModulesRequired))
        SupportMatrixAppendLine(out,
                                  strutil.Join([prefix, ".linux_nolibc_runtime"], ""),
                                  SupportMatrixBoolText(row.linuxNolibcRuntime))
    return out

fn SupportMatrixUsageLine(): str =
    return "  support-matrix               print the current language/target support matrix"

fn SupportMatrixHasCommand(text: str): bool =
    return strutil.Contains(text, "support-matrix")
