fn GateOracleBftPrintNodeStatus(status: OracleBftNodeStatus) =
    GatePrintLine("node=" + status.name)
    GatePrintLine("height=" + status.height)
    GatePrintLine("last_finalized_round_id=" + status.lastFinalizedRoundId)
    GatePrintLine("app_hash=" + status.appHash)
    GatePrintLine("latest_code=" + status.latestCode)
    GatePrintLine("latest_round_id=" + status.latestRoundId)
    GatePrintLine("latest_price_e8=" + status.latestPriceE8)
    GatePrintLine("twap_code=" + status.twapCode)
    GatePrintLine("twap_price_e8=" + status.twapPriceE8)

fn GateOracleBftClusterMatches(serverStatus: OracleBftNodeStatus,
                                 relayStatus: OracleBftNodeStatus,
                                 localStatus: OracleBftNodeStatus): bool =
    let wantHeight = "3"
    let wantRound = strings.Int64ToStr(GateOracleBftExpectedRound())
    let wantLatestPrice = strings.Int64ToStr(GateOracleBftExpectedLatestPrice())
    let wantTwapPrice = strings.Int64ToStr(GateOracleBftExpectedTwapPrice())
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           serverStatus.lastFinalizedRoundId == wantRound &&
           relayStatus.lastFinalizedRoundId == wantRound &&
           localStatus.lastFinalizedRoundId == wantRound &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.latestCode == "0" &&
           relayStatus.latestCode == "0" &&
           localStatus.latestCode == "0" &&
           serverStatus.latestRoundId == wantRound &&
           relayStatus.latestRoundId == wantRound &&
           localStatus.latestRoundId == wantRound &&
           serverStatus.latestPriceE8 == wantLatestPrice &&
           relayStatus.latestPriceE8 == wantLatestPrice &&
           localStatus.latestPriceE8 == wantLatestPrice &&
           serverStatus.twapCode == "0" &&
           relayStatus.twapCode == "0" &&
           localStatus.twapCode == "0" &&
           serverStatus.twapPriceE8 == wantTwapPrice &&
           relayStatus.twapPriceE8 == wantTwapPrice &&
           localStatus.twapPriceE8 == wantTwapPrice

fn GateOracleBftStatePath(dir: str): str =
    return os.JoinPath(dir, "oracle.state")

fn GateOracleBftInitCommand(binPath: str,
                              statePath: str,
                              appId: str): str =
    return GateShellArgv([binPath,
                            "init",
                            "--state:" + statePath,
                            "--app-id:" + appId,
                            "--force"])

fn GateOracleBftFixtureFinalizeCommand(binPath: str,
                                         statePath: str,
                                         height: int64,
                                         roundId: int64): str =
    return GateShellArgv([binPath,
                            "fixture-finalize",
                            "--state:" + statePath,
                            "--height:" + strings.Int64ToStr(height),
                            "--round:" + strings.Int64ToStr(roundId),
                            "--reporter-start:1",
                            "--reporter-end:5",
                            "--time-hint-ms:" + strings.Int64ToStr(oracle_types.OracleRoundEndMs(roundId) + int64(1))])

fn GateOracleBftDeployShell(binPath: str,
                              dir: str,
                              appId: str): str =
    let statePath = GateOracleBftStatePath(dir)
    return "set -eu && mkdir -p " + os.QuoteShell(dir) +
           " && " + GateOracleBftInitCommand(binPath, statePath, appId) +
           " && " + GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(1), int64(20)) +
           " && " + GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(2), int64(21)) +
           " && " + GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(3), int64(22))

fn GateOracleBftVerifyReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/verify_oracle_bft_three_node.report.txt")

fn GateOracleBftVerifyReportAppendNode(out: var str,
                                         prefix: str,
                                         status: OracleBftNodeStatus) =
    out = out + prefix + "_name=" + status.name + "\n"
    out = out + prefix + "_height=" + status.height + "\n"
    out = out + prefix + "_last_finalized_round_id=" + status.lastFinalizedRoundId + "\n"
    out = out + prefix + "_app_hash=" + status.appHash + "\n"
    out = out + prefix + "_latest_code=" + status.latestCode + "\n"
    out = out + prefix + "_latest_round_id=" + status.latestRoundId + "\n"
    out = out + prefix + "_latest_price_e8=" + status.latestPriceE8 + "\n"
    out = out + prefix + "_twap_code=" + status.twapCode + "\n"
    out = out + prefix + "_twap_price_e8=" + status.twapPriceE8 + "\n"

fn GateOracleBftVerifyReportText(cfg: OracleBftThreeNodeDeploy,
                                   verified: bool,
                                   serverStatus: OracleBftNodeStatus,
                                   relayStatus: OracleBftNodeStatus,
                                   localStatus: OracleBftNodeStatus): str =
    var out = ""
    out = out + "version=cheng.oracle_bft_three_node_verify.v1\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "pair=" + GateOracleBftPairText() + "\n"
    out = out + "want_height=3\n"
    out = out + "want_round=" + strings.Int64ToStr(GateOracleBftExpectedRound()) + "\n"
    out = out + "want_latest_price_e8=" + strings.Int64ToStr(GateOracleBftExpectedLatestPrice()) + "\n"
    out = out + "want_twap_price_e8=" + strings.Int64ToStr(GateOracleBftExpectedTwapPrice()) + "\n"
    GateOracleBftVerifyReportAppendNode(out, "server", serverStatus)
    GateOracleBftVerifyReportAppendNode(out, "relay", relayStatus)
    GateOracleBftVerifyReportAppendNode(out, "local", localStatus)
    if verified:
        out = out + "verified=true\n"
    else:
        out = out + "verified=false\n"
    return out

fn GateStopOracleBftThreeNode(root: str): int32 =
    let cfg = GateOracleBftConfigLoad(root)
    let serverDir = GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRun = GateRunRemoteShellLogged(root,
                                               "oracle_bft_stop_server",
                                               cfg.serverSsh,
                                               "set -eu && rm -rf " + os.QuoteShell(serverDir),
                                               "artifacts/gate/oracle_bft_stop_server.log",
                                               30)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = GateRunRemoteShellLogged(root,
                                              "oracle_bft_stop_relay",
                                              cfg.relaySsh,
                                              "set -eu && rm -rf " + os.QuoteShell(relayDir),
                                              "artifacts/gate/oracle_bft_stop_relay.log",
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = GateRunShellLogged(root,
                                        "oracle_bft_stop_local",
                                        "set -eu && rm -rf " + os.QuoteShell(localDir),
                                        "artifacts/gate/oracle_bft_stop_local.log",
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    GatePrintLine(" oracle bft deploy: stopped")
    return 0

fn GateDeployOracleBftThreeNode(root: str): int32 =
    let cfg = GateOracleBftThreeNodeConfig(root)
    if GateStopOracleBftThreeNode(root) != 0:
        return 1
    if !chengpath.MkdirP(root, cfg.localDeployDir):
        GatePrintErr(" oracle bft deploy: failed to create local deploy dir")
        return 1
    if !chengpath.WriteTextFile(root, GateOracleBftManifestPath(cfg), GateOracleBftManifestText(cfg)):
        GatePrintErr(" oracle bft deploy: failed to write manifest")
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.serverSsh,
                               cfg.serverRepoRoot,
                               "artifacts/gate/oracle_bft_sync_server.log") != 0:
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.relaySsh,
                               cfg.relayRepoRoot,
                               "artifacts/gate/oracle_bft_sync_relay.log") != 0:
        return 1
    if GateBuildOracleBftStateMachine(root) != 0:
        return 1
    if GateOracleBftBuildRemote(root,
                                  cfg.serverSsh,
                                  cfg.serverRepoRoot,
                                  "artifacts/gate/oracle_bft_build_server.log") != 0:
        return 1
    if GateOracleBftBuildRemote(root,
                                  cfg.relaySsh,
                                  cfg.relayRepoRoot,
                                  "artifacts/gate/oracle_bft_build_relay.log") != 0:
        return 1
    let serverDir = GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = GateOracleBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = GateOracleBftRemoteBin(cfg.relayRepoRoot)
    let localBin = GateOracleBftLocalBin(root)
    let serverRun = GateRunRemoteShellLogged(root,
                                               "oracle_bft_deploy_server",
                                               cfg.serverSsh,
                                               GateOracleBftDeployShell(serverBin, serverDir, cfg.appId),
                                               "artifacts/gate/oracle_bft_deploy_server.log",
                                               30)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = GateRunRemoteShellLogged(root,
                                              "oracle_bft_deploy_relay",
                                              cfg.relaySsh,
                                              GateOracleBftDeployShell(relayBin, relayDir, cfg.appId),
                                              "artifacts/gate/oracle_bft_deploy_relay.log",
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = GateRunShellLogged(root,
                                        "oracle_bft_deploy_local",
                                        GateOracleBftDeployShell(localBin, localDir, cfg.appId),
                                        "artifacts/gate/oracle_bft_deploy_local.log",
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    var serverStatus = GateOracleBftNodeStatusZero("server")
    var relayStatus = GateOracleBftNodeStatusZero("relay")
    var localStatus = GateOracleBftNodeStatusZero("local")
    let serverRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           GateOracleBftStatePath(serverDir),
                                                           "artifacts/gate/oracle_bft_server_status")
    if IsErr(serverRes):
        GatePrintErr(" oracle bft deploy: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    serverStatus = Value(serverRes)
    let relayRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          GateOracleBftStatePath(relayDir),
                                                          "artifacts/gate/oracle_bft_relay_status")
    if IsErr(relayRes):
        GatePrintErr(" oracle bft deploy: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    relayStatus = Value(relayRes)
    let localRes = GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         GateOracleBftStatePath(localDir),
                                                         "artifacts/gate/oracle_bft_local_status")
    if IsErr(localRes):
        GatePrintErr(" oracle bft deploy: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    localStatus = Value(localRes)
    if !GateOracleBftClusterMatches(serverStatus, relayStatus, localStatus):
        GatePrintErr(" oracle bft deploy: three-node cluster drifted")
        GateOracleBftPrintNodeStatus(serverStatus)
        GatePrintLine("---")
        GateOracleBftPrintNodeStatus(relayStatus)
        GatePrintLine("---")
        GateOracleBftPrintNodeStatus(localStatus)
        return 1
    GateOracleBftPrintNodeStatus(serverStatus)
    GatePrintLine("---")
    GateOracleBftPrintNodeStatus(relayStatus)
    GatePrintLine("---")
    GateOracleBftPrintNodeStatus(localStatus)
    return 0

fn GateStatusOracleBftThreeNode(root: str): int32 =
    let cfg = GateOracleBftConfigLoad(root)
    let serverDir = GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           GateOracleBftStatePath(serverDir),
                                                           "artifacts/gate/oracle_bft_server_live")
    if IsErr(serverRes):
        GatePrintErr(" oracle bft status: server failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    let relayRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          GateOracleBftStatePath(relayDir),
                                                          "artifacts/gate/oracle_bft_relay_live")
    if IsErr(relayRes):
        GatePrintErr(" oracle bft status: relay failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    let localRes = GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         GateOracleBftStatePath(localDir),
                                                         "artifacts/gate/oracle_bft_local_live")
    if IsErr(localRes):
        GatePrintErr(" oracle bft status: local failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    GateOracleBftPrintNodeStatus(Value(serverRes))
    GatePrintLine("---")
    GateOracleBftPrintNodeStatus(Value(relayRes))
    GatePrintLine("---")
    GateOracleBftPrintNodeStatus(Value(localRes))
    return 0

fn GateVerifyOracleBftThreeNode(root: str): int32 =
    if GateDeployOracleBftThreeNode(root) != 0:
        return 1
    let cfg = GateOracleBftConfigLoad(root)
    let serverDir = GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    var serverStatus = GateOracleBftNodeStatusZero("server")
    var relayStatus = GateOracleBftNodeStatusZero("relay")
    var localStatus = GateOracleBftNodeStatusZero("local")
    let serverRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           GateOracleBftStatePath(serverDir),
                                                           "artifacts/gate/oracle_bft_verify_server")
    let relayRes = GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          GateOracleBftStatePath(relayDir),
                                                          "artifacts/gate/oracle_bft_verify_relay")
    let localRes = GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         GateOracleBftStatePath(localDir),
                                                         "artifacts/gate/oracle_bft_verify_local")
    if !IsErr(serverRes):
        serverStatus = Value(serverRes)
    if !IsErr(relayRes):
        relayStatus = Value(relayRes)
    if !IsErr(localRes):
        localStatus = Value(localRes)
    var verified = false
    if !IsErr(serverRes) && !IsErr(relayRes) && !IsErr(localRes):
        verified = GateOracleBftClusterMatches(serverStatus, relayStatus, localStatus)
    let reportPath = GateOracleBftVerifyReportPath(root)
    let reportText = GateOracleBftVerifyReportText(cfg, verified, serverStatus, relayStatus, localStatus)
    if !chengpath.WriteTextFile(root, reportPath, reportText):
        GatePrintErr(" oracle bft verify: failed to write report")
        let _ = GateStopOracleBftThreeNode(root)
        return 1
    let stopCode = GateStopOracleBftThreeNode(root)
    if IsErr(serverRes):
        GatePrintErr(" oracle bft verify: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    if IsErr(relayRes):
        GatePrintErr(" oracle bft verify: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    if IsErr(localRes):
        GatePrintErr(" oracle bft verify: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    if !verified:
        GatePrintErr(" oracle bft verify: three-node cluster drifted")
        GateOracleBftPrintNodeStatus(serverStatus)
        GatePrintLine("---")
        GateOracleBftPrintNodeStatus(relayStatus)
        GatePrintLine("---")
        GateOracleBftPrintNodeStatus(localStatus)
        return 1
    if stopCode != 0:
        GatePrintErr(" oracle bft verify: stop failed after verification")
        return stopCode
    GatePrintLine(" oracle bft verify ok")
    GatePrintLine("report=" + reportPath)
    return 0

fn GateBuildBrowserHostWasm(root: str, args: str[]): int32 =
    let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_WASM_COMPILER", "", compiler) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/browser_host_wasm")
    let src: str = chengpath.PathAbsolute(root, "src/libp2p/browser/browser_host_wasm_probe.cheng")
    let positionals: str[] = GateCollectPositionals(args)
    var outWasm: str = os.GetEnvDefault("CHENG_BROWSER_HOST_WASM_OUT", "")
    if len(outWasm) <= 0 && positionals.len > 0:
        outWasm = positionals[0]
    if len(outWasm) <= 0:
        outWasm = os.JoinPath(outDir, "cheng_browser_host_abi.wasm")
    else:
        outWasm = chengpath.PathAbsolute(root, outWasm)
    let compileRun = GateCompileEmitEnv(root,
                                          "build_browser_host_wasm",
                                          compiler,
                                          src,
                                          "shared",
                                          outWasm,
                                          "wasm32-unknown-unknown",
                                          os.JoinPath(outDir, "cheng_browser_host_abi.compile.log"),
                                          [])
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outWasm):
        GatePrintErr(" browser host wasm: missing wasm output: " + outWasm)
        return 1
    GatePrintLine(" browser host wasm: build ok out=" + outWasm)
    return 0

fn GateBuildRwadBftStateMachine(root: str): int32 =
    var compiler = ""
    if GateResolveSmokeCompiler(root, "", "CHENG_RWAD_COMPILER", "", compiler) != 0:
        return 1
    let target: str = os.GetEnvDefault("RWAD_BFT_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = chengpath.PathAbsolute(root, "artifacts/rwad_bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("RWAD_BFT_OUT_DIR", defaultOutDir)
    let outBin: str = os.GetEnvDefault("RWAD_BFT_OUT_BIN", os.JoinPath(outDir, "rwad_bft_state_machine"))
    let src: str = chengpath.PathAbsolute(root, "src/apps/rwad/rwad_bft_state_machine_main.cheng")
    let compileRun = GateCompileExe(root,
                                      "build_rwad_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "rwad_bft_state_machine.compile.log"))
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    var runSelfTestDefault = "0"
    if target == GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest: str = os.GetEnvDefault("RWAD_BFT_RUN_SELF_TEST", runSelfTestDefault)
    if runSelfTest != "0":
        let run = GateRunBinary(root,
                                  "build_rwad_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  20,
                                  os.JoinPath(outDir, "rwad_bft_state_machine.self-test.log"))
        GateMaybePrintRunOutput(run)
        if GateRunFailed(run):
            return run.exitCode
    else:
        GatePrintLine(" rwad_bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn GateBuildPanicTrace(root: str): int32 =
    var compiler = ""
    if GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/panic_trace")
    let src: str = chengpath.PathAbsolute(root, "src/tests/ordinary_panic_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_panic_fixture")
    let reportPath: str = os.JoinPath(outDir, "ordinary_panic_fixture.report.txt")
    let compileLog = "artifacts/panic_trace/ordinary_panic_fixture.compile.log"
    let compileRun = GateCompileExe(root,
                                      "build_panic_trace",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    let lineMap: str = outBin + ".map"
    if !os.FileExists(lineMap):
        GatePrintErr(" panic-trace: missing line-map sidecar")
        return 1
    let lineMapText: str = chengpath.ReadTextFile("", lineMap)
    if !GateOutputContains(lineMapText, "cheng_line_map_v1") ||
       !GateOutputContains(lineMapText, "ordinary_panic_fixture.cheng"):
        GatePrintErr(" panic-trace: invalid line-map")
        return 1
    let run = GateRunBinary(root,
                              "build_panic_trace_run",
                              outBin,
                              [],
                              20,
                              "artifacts/panic_trace/ordinary_panic_fixture.run.log")
    GateMaybePrintRunOutput(run)
    if run.exitCode == 0:
        GatePrintErr(" panic-trace: expected non-zero exit")
        return 1
    let transformRun = hostops.RunFileLogged(root,
                                               "build_panic_trace_report",
                                               compiler,
                                               [
                                                   "crash-report",
                                                   "--in:" + run.logPath,
                                                   "--out:" + reportPath
                                               ],
                                               [],
                                               root,
                                               20,
                                               "artifacts/panic_trace/ordinary_panic_fixture.crash-report.log")
    if GateRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        GatePrintErr(" panic-trace: missing report")
        return 1
    let reportText: str = chengpath.ReadTextFile("", reportPath)
    if !GateRequireOutput(run, " panic fixture", " panic-trace") ||
       !GateRequireOutput(run, "cheng_crash_raw_v1", " panic-trace") ||
       !GateRequireOutput(run, "reason=panic mode=backtrace", " panic-trace") ||
       !GateRequireOutput(run, "ordinary_panic_fixture.cheng:", " panic-trace") ||
       !GateOutputContains(reportText, "[cheng] cheng_crash_report_v1") ||
       !GateOutputContains(reportText, "[cheng] reason=panic mode=backtrace") ||
       !GateOutputContains(reportText, "ordinary_panic_fixture.cheng:"):
        return 1
    GatePrintLine(strutil.Strip(reportText))
    return 0

