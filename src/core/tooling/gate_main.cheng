fn GateBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "src/apps/bft/bft_state_machine_main.cheng")
    let outBin = GateBftRemoteBin(repoRoot)
    let runLog = GateBftRemoteRunLog(repoRoot)
    var command = ""
    command = command + "test -x " + os.QuoteShell(outBin)
    command = command + " && test -x " + os.QuoteShell(compiler)
    command = command + " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin)
    command = command + " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    command = command + " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog)
    command = command + " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog)
    command = command + " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog)
    command = command + " && grep -qF " + os.QuoteShell(" bft_state_machine self-test ok")
    command = command + " " + os.QuoteShell(runLog)
    return command

fn GateBftRemoteStage3FreshCommand(repoRoot: str): str =
    let stage3 = GateBftRemoteStage3(repoRoot)
    let snapshot = GateBftRemoteSnapshot(repoRoot)
    let seed = os.JoinPath(repoRoot, "bootstrap/cheng_seed.c")
    let stage1 = contracts.BootstrapStage1SourcePath(repoRoot)
    let compilerMain = os.JoinPath(repoRoot, "src/core/tooling/compiler_main.cheng")
    let compilerRuntime = os.JoinPath(repoRoot, "src/core/tooling/compiler_runtime.cheng")
    let compilerRequest = os.JoinPath(repoRoot, "src/core/tooling/compiler_request.cheng")
    let gateMain = os.JoinPath(repoRoot, "src/core/tooling/gate_main.cheng")
    var command = ""
    command = command + "test -x " + os.QuoteShell(stage3)
    command = command + " && snapshot=" + os.QuoteShell(snapshot)
    command = command + " && stage3=" + os.QuoteShell(stage3)
    command = command + " && if [ -f \"$snapshot\" ]; then"
    command = command + " fresh=$(grep \"^fresh_input_paths=\" \"$snapshot\" | tail -n 1 | cut -d= -f2-);"
    command = command + " if [ -n \"$fresh\" ]; then"
    command = command + " old_ifs=\"$IFS\"; IFS=,; set -- $fresh; IFS=\"$old_ifs\";"
    command = command + " for input in \"$@\"; do"
    command = command + " if [ -n \"$input\" ] && ! test \"$input\" -ot \"$stage3\"; then exit 1; fi;"
    command = command + " done; exit 0; fi; fi"
    command = command + " && test " + os.QuoteShell(seed) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(stage1) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerMain) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRuntime) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRequest) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(gateMain) + " -ot \"$stage3\""
    return command

fn GateBftRemoteLockedShell(repoRoot: str,
                              innerCommand: str): str =
    var command = ""
    command = command + "set -eu && cd " + os.QuoteShell(repoRoot)
    command = command + " && mkdir -p artifacts/gate"
    command = command + " && lock_dir=artifacts/gate/bft_remote_build.lock"
    command = command + " && lock_pid=\"$lock_dir/pid\""
    command = command + " && while ! mkdir \"$lock_dir\" 2>/dev/null; do holder=\"\";"
    command = command + " if [ -f \"$lock_pid\" ]; then holder=$(cat \"$lock_pid\" 2>/dev/null || true); fi;"
    command = command + " if [ -z \"$holder\" ] || ! kill -0 \"$holder\" 2>/dev/null; then"
    command = command + " rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true; continue;"
    command = command + " fi; sleep 0.1; done"
    command = command + " && printf \"%s\\n\" \"$$\" > \"$lock_pid\""
    command = command + " && trap 'rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true' EXIT INT TERM"
    command = command + " && " + innerCommand
    return command

fn GateBftManifestText(cfg: BftThreeNodeDeploy): str =
    var out = ""
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "server_addr=" + cfg.serverAddress + "\n"
    out = out + "server_root=" + cfg.serverRepoRoot + "\n"
    out = out + "relay_root=" + cfg.relayRepoRoot + "\n"
    out = out + "local_deploy_dir=" + cfg.localDeployDir + "\n"
    out = out + "remote_deploy_rel=" + cfg.remoteDeployRel + "\n"
    out = out + "proposal_port=" + intToStr(cfg.proposalPort) + "\n"
    out = out + "commit_port=" + intToStr(cfg.commitPort) + "\n"
    out = out + "vote_port=" + intToStr(cfg.votePort) + "\n"
    out = out + "state_port=" + intToStr(cfg.statePort) + "\n"
    out = out + "proposer_interval_ms=" + intToStr(cfg.proposerIntervalMs) + "\n"
    out = out + "follower_interval_ms=" + intToStr(cfg.followerIntervalMs) + "\n"
    out = out + "proposal_window_ms=" + intToStr(cfg.proposalWindowMs) + "\n"
    out = out + "vote_window_ms=" + intToStr(cfg.voteWindowMs) + "\n"
    out = out + "commit_window_ms=" + intToStr(cfg.commitWindowMs) + "\n"
    out = out + "default_max_txs=" + intToStr(cfg.defaultMaxTxs) + "\n"
    out = out + "asset_id=" + intToStr(cfg.assetId) + "\n"
    out = out + "alice_id=" + intToStr(cfg.aliceId) + "\n"
    out = out + "bob_id=" + intToStr(cfg.bobId) + "\n"
    out = out + "mint_amount=" + strings.Int64ToStr(cfg.mintAmount) + "\n"
    out = out + "transfer_amount=" + strings.Int64ToStr(cfg.transferAmount) + "\n"
    return out

fn GateBftConfigLoad(root: str): BftThreeNodeDeploy =
    var cfg = GateBftThreeNodeConfig(root)
    let manifestPath = GateBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = chengpath.ReadTextFile("", manifestPath)
    let appId = GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverAddr = GateTextValue(text, "server_addr")
    if len(serverAddr) > 0:
        cfg.serverAddress = serverAddr
    let serverRoot = GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    let proposalPort = GateTextValue(text, "proposal_port")
    if len(proposalPort) > 0:
        cfg.proposalPort = int32(strutil.ParseInt(proposalPort))
    let commitPort = GateTextValue(text, "commit_port")
    if len(commitPort) > 0:
        cfg.commitPort = int32(strutil.ParseInt(commitPort))
    let votePort = GateTextValue(text, "vote_port")
    if len(votePort) > 0:
        cfg.votePort = int32(strutil.ParseInt(votePort))
    let statePort = GateTextValue(text, "state_port")
    if len(statePort) > 0:
        cfg.statePort = int32(strutil.ParseInt(statePort))
    let proposerIntervalMs = GateTextValue(text, "proposer_interval_ms")
    if len(proposerIntervalMs) > 0:
        cfg.proposerIntervalMs = int32(strutil.ParseInt(proposerIntervalMs))
    let followerIntervalMs = GateTextValue(text, "follower_interval_ms")
    if len(followerIntervalMs) > 0:
        cfg.followerIntervalMs = int32(strutil.ParseInt(followerIntervalMs))
    let proposalWindowMs = GateTextValue(text, "proposal_window_ms")
    if len(proposalWindowMs) > 0:
        cfg.proposalWindowMs = int32(strutil.ParseInt(proposalWindowMs))
    let voteWindowMs = GateTextValue(text, "vote_window_ms")
    if len(voteWindowMs) > 0:
        cfg.voteWindowMs = int32(strutil.ParseInt(voteWindowMs))
    let commitWindowMs = GateTextValue(text, "commit_window_ms")
    if len(commitWindowMs) > 0:
        cfg.commitWindowMs = int32(strutil.ParseInt(commitWindowMs))
    let defaultMaxTxs = GateTextValue(text, "default_max_txs")
    if len(defaultMaxTxs) > 0:
        cfg.defaultMaxTxs = int32(strutil.ParseInt(defaultMaxTxs))
    let assetId = GateTextValue(text, "asset_id")
    if len(assetId) > 0:
        cfg.assetId = int32(strutil.ParseInt(assetId))
    let aliceId = GateTextValue(text, "alice_id")
    if len(aliceId) > 0:
        cfg.aliceId = int32(strutil.ParseInt(aliceId))
    let bobId = GateTextValue(text, "bob_id")
    if len(bobId) > 0:
        cfg.bobId = int32(strutil.ParseInt(bobId))
    let mintAmount = GateTextValue(text, "mint_amount")
    if len(mintAmount) > 0:
        cfg.mintAmount = int64(strutil.ParseInt(mintAmount))
    let transferAmount = GateTextValue(text, "transfer_amount")
    if len(transferAmount) > 0:
        cfg.transferAmount = int64(strutil.ParseInt(transferAmount))
    return cfg

fn GateBftNodeStatusZero(name: str): BftNodeStatus =
    return BftNodeStatus(name: name,
                           summary: "",
                           aliceQuery: "",
                           bobQuery: "",
                           height: "",
                           appHash: "",
                           aliceBalance: "",
                           bobBalance: "")

fn GateBftCollectLocalNodeStatus(root: str,
                                   cfg: BftThreeNodeDeploy,
                                   nodeName: str,
                                   statePath: str,
                                   logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftLocalBin(root)
    let summaryRun = hostops.RunFileLogged(root,
                                             nodeName + "_show_state",
                                             binPath,
                                             ["show-state", "--state:" + statePath],
                                             [],
                                             root,
                                             20,
                                             logPrefix + ".show.log")
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = hostops.RunFileLogged(root,
                                           nodeName + "_alice_balance",
                                           binPath,
                                           ["query-balance",
                                            "--state:" + statePath,
                                            "--asset:" + intToStr(cfg.assetId),
                                            "--account:" + intToStr(cfg.aliceId)],
                                           [],
                                           root,
                                           20,
                                           logPrefix + ".alice.log")
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = hostops.RunFileLogged(root,
                                         nodeName + "_bob_balance",
                                         binPath,
                                         ["query-balance",
                                          "--state:" + statePath,
                                          "--asset:" + intToStr(cfg.assetId),
                                          "--account:" + intToStr(cfg.bobId)],
                                         [],
                                         root,
                                         20,
                                         logPrefix + ".bob.log")
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftCollectRemoteNodeStatus(root: str,
                                    cfg: BftThreeNodeDeploy,
                                    nodeName: str,
                                    sshHost: str,
                                    repoRoot: str,
                                    statePath: str,
                                    logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftRemoteBin(repoRoot)
    let summaryRun = GateRunRemoteShellLogged(root,
                                                nodeName + "_show_state",
                                                sshHost,
                                                "set -eu && " +
                                                    GateShellArgv([binPath,
                                                                     "show-state",
                                                                     "--state:" + statePath]),
                                                logPrefix + ".show.log",
                                                20)
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = GateRunRemoteShellLogged(root,
                                              nodeName + "_alice_balance",
                                              sshHost,
                                              "set -eu && " + GateShellArgv([binPath,
                                                                               "query-balance",
                                                                               "--state:" + statePath,
                                                                               "--asset:" + intToStr(cfg.assetId),
                                                                               "--account:" + intToStr(cfg.aliceId)]),
                                              logPrefix + ".alice.log",
                                              20)
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = GateRunRemoteShellLogged(root,
                                            nodeName + "_bob_balance",
                                            sshHost,
                                            "set -eu && " + GateShellArgv([binPath,
                                                                             "query-balance",
                                                                             "--state:" + statePath,
                                                                             "--asset:" + intToStr(cfg.assetId),
                                                                             "--account:" + intToStr(cfg.bobId)]),
                                            logPrefix + ".bob.log",
                                            20)
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftPrintNodeStatus(status: BftNodeStatus) =
    GatePrintLine("node=" + status.name)
    GatePrintLine("height=" + status.height)
    GatePrintLine("app_hash=" + status.appHash)
    GatePrintLine("alice_balance=" + status.aliceBalance)
    GatePrintLine("bob_balance=" + status.bobBalance)

fn GateBftClusterMatches(serverStatus: BftNodeStatus,
                           relayStatus: BftNodeStatus,
                           localStatus: BftNodeStatus,
                           wantHeight: str,
                           wantAlice: str,
                           wantBob: str): bool =
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.aliceBalance == wantAlice &&
           relayStatus.aliceBalance == wantAlice &&
           localStatus.aliceBalance == wantAlice &&
           serverStatus.bobBalance == wantBob &&
           relayStatus.bobBalance == wantBob &&
           localStatus.bobBalance == wantBob

fn GateBftVerifyReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/verify_bft_validator_three_node.report.txt")

fn GateBftVerifyReportAppendNode(out: var str,
                                   prefix: str,
                                   status: BftNodeStatus) =
    out = out + prefix + "_name=" + status.name + "\n"
    out = out + prefix + "_height=" + status.height + "\n"
    out = out + prefix + "_app_hash=" + status.appHash + "\n"
    out = out + prefix + "_alice_balance=" + status.aliceBalance + "\n"
    out = out + prefix + "_bob_balance=" + status.bobBalance + "\n"

fn GateBftVerifyReportText(cfg: BftThreeNodeDeploy,
                             verified: bool,
                             serverStatus: BftNodeStatus,
                             relayStatus: BftNodeStatus,
                             localStatus: BftNodeStatus): str =
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var out = ""
    out = out + "version=cheng.bft_three_node_verify.v1\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "want_height=" + wantHeight + "\n"
    out = out + "want_alice_balance=" + wantAlice + "\n"
    out = out + "want_bob_balance=" + wantBob + "\n"
    GateBftVerifyReportAppendNode(out, "server", serverStatus)
    GateBftVerifyReportAppendNode(out, "relay", relayStatus)
    GateBftVerifyReportAppendNode(out, "local", localStatus)
    out = out + "verified=" + (verified ? "true" : "false") + "\n"
    return out

fn GateFormatMilli(valueMilli: int64): str =
    let whole = valueMilli / int64(1000)
    let frac = valueMilli % int64(1000)
    var fracText = strings.Int64ToStr(frac)
    if len(fracText) == 1:
        fracText = "00" + fracText
    elif len(fracText) == 2:
        fracText = "0" + fracText
    return strings.Int64ToStr(whole) + "." + fracText

fn GateBftDaemonMaxTxs(cfg: BftThreeNodeDeploy): int32 =
    var text = ""
    text = os.GetEnvDefault("CHENG_BFT_MAX_TXS", intToStr(cfg.defaultMaxTxs))
    if len(text) <= 0:
        return cfg.defaultMaxTxs
    let value = int32(strutil.ParseInt(text))
    if value > 0:
        return value
    return cfg.defaultMaxTxs

fn GateBftWaitClusterState(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             wantHeight: str,
                             wantAlice: str,
                             wantBob: str,
                             logPrefix: str,
                             serverStatus: var BftNodeStatus,
                             relayStatus: var BftNodeStatus,
                             localStatus: var BftNodeStatus): bool =
    for i in 0..<300:
        i
        let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         logPrefix + "_server")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        logPrefix + "_relay")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       logPrefix + "_local")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        serverStatus = Value(serverRes)
        relayStatus = Value(relayRes)
        localStatus = Value(localRes)
        if GateBftClusterMatches(serverStatus,
                                   relayStatus,
                                   localStatus,
                                   wantHeight,
                                   wantAlice,
                                   wantBob):
            return true
        os.SleepMs(200)
    return false

fn GateBftBenchReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/bench_bft_validator_three_node.report.txt")

fn GateBftBenchRestartTargetValid(target: str): bool =
    return target == "none" || target == "server" || target == "relay" || target == "local"

fn GateBftBenchStartServer(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             serverBin: str,
                             localBin: str,
                             logPrefix: str): int32 =
    let proposerRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_start_server_proposer",
                                                 cfg.serverSsh,
                                                 GateBftStartDetachedShell(serverBin,
                                                                             ["validator-proposer-daemon",
                                                                              "--state:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.state"),
                                                                              "--queue:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.queue"),
                                                                              "--proposal-host:0.0.0.0",
                                                                              "--proposal-port:" +
                                                                                  intToStr(cfg.proposalPort),
                                                                              "--vote-host:0.0.0.0",
                                                                              "--vote-port:" +
                                                                                  intToStr(cfg.votePort),
                                                                              "--commit-host:0.0.0.0",
                                                                              "--commit-port:" +
                                                                                  intToStr(cfg.commitPort),
                                                                              "--proposal-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.proposal.hex"),
                                                                              "--commit-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.commit.hex"),
                                                                              "--state-sync-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.machine.hex"),
                                                                              "--proposal-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.proposal.ready"),
                                                                              "--vote-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.vote.ready"),
                                                                              "--commit-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.commit.ready"),
                                                                              "--interval-ms:" +
                                                                                  intToStr(cfg.proposerIntervalMs),
                                                                              "--proposal-window-ms:" +
                                                                                  intToStr(cfg.proposalWindowMs),
                                                                              "--vote-window-ms:" +
                                                                                  intToStr(cfg.voteWindowMs),
                                                                              "--commit-window-ms:" +
                                                                                  intToStr(cfg.commitWindowMs),
                                                                              "--max-txs:" +
                                                                                  intToStr(GateBftDaemonMaxTxs(cfg))],
                                                                             os.JoinPath(serverDir,
                                                                                         "server_proposer.pid"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.proposer.log"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.proposal.ready"),
                                                                             true),
                                                 logPrefix + ".server_proposer.log",
                                                 30)
    if GateRunFailed(proposerRun):
        return proposerRun.exitCode
    let stateRun = GateRunRemoteShellLogged(root,
                                              "bft_bench_start_server_state",
                                              cfg.serverSsh,
                                              GateBftStartDetachedShell(serverBin,
                                                                          ["state-serve-daemon",
                                                                           "--file:" +
                                                                               os.JoinPath(serverDir,
                                                                                           "server.machine.hex"),
                                                                           "--host:0.0.0.0",
                                                                           "--port:" + intToStr(cfg.statePort),
                                                                           "--interval-ms:" +
                                                                               intToStr(cfg.followerIntervalMs)],
                                                                          os.JoinPath(serverDir, "server_state.pid"),
                                                                          os.JoinPath(serverDir, "server.state.log"),
                                                                          "",
                                                                          true),
                                              logPrefix + ".server_state.log",
                                              30)
    if GateRunFailed(stateRun):
        return stateRun.exitCode
    let probeRun = GateRunShellLogged(root,
                                        "bft_bench_probe_server_proposal",
                                        GateShellArgv([localBin,
                                                         "probe-proposal",
                                                         "--host:" + cfg.serverAddress,
                                                         "--port:" + intToStr(cfg.proposalPort),
                                                         "--attempts:3",
                                                         "--interval-ms:100",
                                                         "--handshake-only:1"]),
                                        logPrefix + ".server_probe.log",
                                        30)
    if GateRunFailed(probeRun):
        return probeRun.exitCode
    return 0

fn GateBftBenchStartRelay(root: str,
                            cfg: BftThreeNodeDeploy,
                            relayDir: str,
                            relayBin: str,
                            logPrefix: str): int32 =
    let relayRun = GateRunRemoteShellLogged(root,
                                              "bft_bench_start_relay_follower",
                                              cfg.relaySsh,
                                              GateBftStartDetachedShell(relayBin,
                                                                          ["validator-follower-daemon",
                                                                           "--state:" +
                                                                               os.JoinPath(relayDir, "relay.state"),
                                                                           "--proposal-host:" + cfg.serverAddress,
                                                                           "--proposal-port:" +
                                                                               intToStr(cfg.proposalPort),
                                                                           "--vote-host:" + cfg.serverAddress,
                                                                           "--vote-port:" +
                                                                               intToStr(cfg.votePort),
                                                                           "--commit-host:" + cfg.serverAddress,
                                                                           "--commit-port:" +
                                                                               intToStr(cfg.commitPort),
                                                                           "--sync-host:" + cfg.serverAddress,
                                                                           "--sync-port:" +
                                                                               intToStr(cfg.statePort),
                                                                           "--interval-ms:" +
                                                                               intToStr(cfg.followerIntervalMs)],
                                                                          os.JoinPath(relayDir, "relay_follower.pid"),
                                                                          os.JoinPath(relayDir, "relay.follower.log"),
                                                                          "",
                                                                          true),
                                              logPrefix + ".relay_start.log",
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    return 0

fn GateBftBenchStartLocal(root: str,
                            cfg: BftThreeNodeDeploy,
                            localDir: str,
                            localBin: str,
                            logPrefix: str): int32 =
    let localRun = GateRunShellLogged(root,
                                        "bft_bench_start_local_follower",
                                        GateBftStartDetachedShell(localBin,
                                                                    ["validator-follower-daemon",
                                                                     "--state:" +
                                                                         os.JoinPath(localDir, "local.state"),
                                                                     "--proposal-host:" + cfg.serverAddress,
                                                                     "--proposal-port:" +
                                                                         intToStr(cfg.proposalPort),
                                                                     "--vote-host:" + cfg.serverAddress,
                                                                     "--vote-port:" + intToStr(cfg.votePort),
                                                                     "--commit-host:" + cfg.serverAddress,
                                                                     "--commit-port:" + intToStr(cfg.commitPort),
                                                                     "--sync-host:" + cfg.serverAddress,
                                                                     "--sync-port:" + intToStr(cfg.statePort),
                                                                     "--interval-ms:" +
                                                                         intToStr(cfg.followerIntervalMs)],
                                                                    os.JoinPath(localDir, "local_follower.pid"),
                                                                    os.JoinPath(localDir, "local.follower.log"),
                                                                    "",
                                                                    false),
                                        logPrefix + ".local_start.log",
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    return 0

fn GateBftBenchRestartNode(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             serverBin: str,
                             relayBin: str,
                             localBin: str,
                             restartNode: str,
                             restartPauseMs: int32,
                             logPrefix: str): int32 =
    if restartNode == "none":
        return 0
    if restartNode == "server":
        let stopRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_server_stop",
                                                 cfg.serverSsh,
                                                 GateBftStopShell([
                                                     os.JoinPath(serverDir, "server_proposer.pid"),
                                                     os.JoinPath(serverDir, "server_state.pid")
                                                 ], [
                                                     "[v]alidator-proposer-daemon --state:" +
                                                         os.JoinPath(serverDir, "server.state"),
                                                     "[s]tate-serve-daemon --file:" +
                                                         os.JoinPath(serverDir, "server.machine.hex")
                                                 ]),
                                                 logPrefix + ".server_stop.log",
                                                 30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartServer(root, cfg, serverDir, serverBin, localBin, logPrefix)
    if restartNode == "relay":
        let stopRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_relay_stop",
                                                 cfg.relaySsh,
                                                 GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                    [
                                                                        "[v]alidator-follower-daemon --state:" +
                                                                            os.JoinPath(relayDir, "relay.state")
                                                                    ]),
                                                 logPrefix + ".relay_stop.log",
                                                 30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartRelay(root, cfg, relayDir, relayBin, logPrefix)
    if restartNode == "local":
        let stopRun = GateRunShellLogged(root,
                                           "bft_bench_restart_local_stop",
                                           GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                              [
                                                                  "[v]alidator-follower-daemon --state:" +
                                                                      os.JoinPath(localDir, "local.state")
                                                              ]),
                                           logPrefix + ".local_stop.log",
                                           30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartLocal(root, cfg, localDir, localBin, logPrefix)
    GatePrintErr(" bft bench: invalid restart node: " + restartNode)
    return 1

fn GateBftBenchReportText(cfg: BftThreeNodeDeploy,
                            txCountPerWave: int64,
                            waveCount: int32,
                            transferAmount: int64,
                            maxTxsPerBlock: int32,
                            restartNode: str,
                            restartWave: int32,
                            restartPauseMs: int32,
                            totalTxCount: int64,
                            txWireBytes: int64,
                            committedBytes: int64,
                            blockCount: int64,
                            elapsedMs: int64,
                            tpsMilli: int64,
                            bytesPerSec: int64,
                            kibPerSecMilli: int64,
                            waveElapsed: int64[],
                            waveTps: int64[],
                            waveBlocks: int64[],
                            waveRestarted: bool[],
                            finalServer: BftNodeStatus): str =
    var out = ""
    out = out + "version=cheng.bft_three_node_bench.v2\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "tx_count_per_wave=" + strings.Int64ToStr(txCountPerWave) + "\n"
    out = out + "wave_count=" + intToStr(waveCount) + "\n"
    out = out + "transfer_amount=" + strings.Int64ToStr(transferAmount) + "\n"
    out = out + "max_txs_per_block=" + intToStr(maxTxsPerBlock) + "\n"
    out = out + "restart_node=" + restartNode + "\n"
    out = out + "restart_wave=" + intToStr(restartWave) + "\n"
    out = out + "restart_pause_ms=" + intToStr(restartPauseMs) + "\n"
    out = out + "tx_count=" + strings.Int64ToStr(totalTxCount) + "\n"
    out = out + "tx_wire_bytes=" + strings.Int64ToStr(txWireBytes) + "\n"
    out = out + "committed_bytes=" + strings.Int64ToStr(committedBytes) + "\n"
    out = out + "block_count=" + strings.Int64ToStr(blockCount) + "\n"
    out = out + "elapsed_ms=" + strings.Int64ToStr(elapsedMs) + "\n"
    out = out + "tps=" + GateFormatMilli(tpsMilli) + "\n"
    out = out + "throughput_bytes_per_sec=" + strings.Int64ToStr(bytesPerSec) + "\n"
    out = out + "throughput_kib_per_sec=" + GateFormatMilli(kibPerSecMilli) + "\n"
    out = out + "final_height=" + finalServer.height + "\n"
    out = out + "app_hash=" + finalServer.appHash + "\n"
    out = out + "alice_balance=" + finalServer.aliceBalance + "\n"
    out = out + "bob_balance=" + finalServer.bobBalance + "\n"
    for i in 0..<waveElapsed.len:
        let waveIndex = intToStr(i + 1)
        out = out + "wave_" + waveIndex + "_elapsed_ms=" + strings.Int64ToStr(waveElapsed[i]) + "\n"
        out = out + "wave_" + waveIndex + "_tps=" + GateFormatMilli(waveTps[i]) + "\n"
        out = out + "wave_" + waveIndex + "_block_count=" + strings.Int64ToStr(waveBlocks[i]) + "\n"
        out = out + "wave_" + waveIndex + "_restarted=" + (waveRestarted[i] ? "true" : "false") + "\n"
    return out

fn GateBftStopShell(pidPaths: str[], killPatterns: str[]): str =
    var out = "set -u"
    for i in 0..<pidPaths.len:
        let pidPath = pidPaths[i]
        out = out +
            " ; if [ -f " + os.QuoteShell(pidPath) + " ]; then" +
            " pid=$(cat " + os.QuoteShell(pidPath) + ");" +
            " if [ -n \"$pid\" ]; then" +
            " kill \"$pid\" >/dev/null 2>&1 || true;" +
            " sleep 1;" +
            " kill -9 \"$pid\" >/dev/null 2>&1 || true;" +
            " fi;" +
            " rm -f " + os.QuoteShell(pidPath) + ";" +
            " fi"
    for i in 0..<killPatterns.len:
        out = out + " ; pkill -f -- " + os.QuoteShell(killPatterns[i]) + " >/dev/null 2>&1 || true"
    return out

fn GateBftStartDetachedShell(binPath: str,
                               args: str[],
                               pidPath: str,
                               logPath: str,
                               readyPath: str,
                               useSetsid: bool): str =
    var out = "set -eu && mkdir -p " + os.QuoteShell(chengpath.PathParentDir(logPath))
    var inner = "echo $$ > " + os.QuoteShell(pidPath) +
        " && exec " + GateShellArgv([binPath]) +
        " " + GateShellArgv(args)
    inner = inner + " > " + os.QuoteShell(logPath) + " 2>&1 < /dev/null"
    if len(readyPath) > 0:
        out = out + " && rm -f " + os.QuoteShell(readyPath)
    out = out + " && rm -f " + os.QuoteShell(pidPath)
    if useSetsid:
        out = out + " && setsid -f sh -lc " + os.QuoteShell(inner)
    else:
        out = out + " && sh -lc " + os.QuoteShell(inner) + " &"
    out = out +
        " && i=0 && while [ ! -f " + os.QuoteShell(pidPath) +
        " ] && [ \"$i\" -lt 50 ]; do i=$((i + 1)); sleep 0.1; done"
    out = out + " && test -f " + os.QuoteShell(pidPath)
    return out

fn GateBftWaitReadyShell(paths: str[], timeoutSec: int32): str =
    var out = "set -eu && i=0 && while [ \"$i\" -lt " + intToStr(timeoutSec * 10) + " ]; do"
    var checks = ""
    for i in 0..<paths.len:
        if i > 0:
            checks = checks + " && "
        checks = checks + "[ -f " + os.QuoteShell(paths[i]) + " ]"
    out = out + " if " + checks + "; then exit 0; fi; i=$((i + 1)); sleep 0.1; done; exit 1"
    return out

fn GateBftSyncRemoteRepo(root: str,
                           sshHost: str,
                           remoteRoot: str,
                           logPath: str): int32 =
    let ensureRun = GateRunRemoteShellLogged(root,
                                               "bft_remote_repo_mkdir",
                                               sshHost,
                                               "set -eu && mkdir -p " + os.QuoteShell(remoteRoot),
                                               logPath + ".mkdir.log",
                                               20)
    if GateRunFailed(ensureRun):
        return ensureRun.exitCode
    let remoteShell = "ssh -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=5 -o ServerAliveCountMax=3"
    var lastRun = hostops.LoggedRunZero("bft_remote_rsync", "rsync", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.RunProgramLogged(root,
                                             "bft_remote_rsync",
                                             "rsync",
                                             ["-az",
                                              "-e", remoteShell,
                                              "--delete",
                                              "--exclude", ".git",
                                              "--exclude", "artifacts",
                                              "--exclude", "chengcache",
                                              "--exclude", "node_modules",
                                              root + "/",
                                              sshHost + ":" + remoteRoot + "/"],
                                             [],
                                             root,
                                             0,
                                             logPath)
        lastRun = run
        if !GateRunFailed(run):
            return 0
        if attempt >= 2 || !GateRemoteTransportRetryable(run.output):
            return run.exitCode
        GatePrintLine("[ gate] remote rsync retry " + intToStr(attempt + 1) + " " + sshHost)
        os.SleepMs((attempt + 1) * 1000)
    return lastRun.exitCode

fn GateBftBuildRemote(root: str,
                        sshHost: str,
                        remoteRoot: str,
                        logPath: str): int32 =
    let readyRun = GateRunRemoteShellLogged(root,
                                              "bft_remote_ready",
                                              sshHost,
                                              "set -eu && " + GateBftRemoteBuildReadyCommand(remoteRoot),
                                              logPath + ".ready.log",
                                              30)
    if !GateRunFailed(readyRun):
        GatePrintLine("[ gate] remote bft reuse " + sshHost)
        return 0
    let stage3FreshRun = GateRunRemoteShellLogged(root,
                                                    "bft_remote_stage3_fresh",
                                                    sshHost,
                                                    "set -eu && " + GateBftRemoteStage3FreshCommand(remoteRoot),
                                                    logPath + ".stage3.log",
                                                    30)
    if !GateRunFailed(stage3FreshRun):
        let incrementalCommand = GateBftRemoteLockedShell(
            remoteRoot,
            "BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
            " BFT_STATE_RUN_SELF_TEST=1" +
            " artifacts/bootstrap/cheng.stage3 build-bft-state-machine")
        let incrementalRun = GateRunRemoteShellLogged(root,
                                                        "bft_remote_build_incremental",
                                                        sshHost,
                                                        incrementalCommand,
                                                        logPath,
                                                        900)
        if GateRunFailed(incrementalRun):
            return incrementalRun.exitCode
        GatePrintLine("[ gate] remote bft incremental " + sshHost)
        return 0
    let fullCommand = GateBftRemoteLockedShell(
        remoteRoot,
        "mkdir -p artifacts/bootstrap" +
        " && cc -std=c11 -O2 -Wall -Wextra -pedantic" +
        " bootstrap/cheng_seed.c -o artifacts/bootstrap/cheng.stage0" +
        " && CHENG_ROOT=" + os.QuoteShell(remoteRoot) +
        " CHENG_TARGET=x86_64-unknown-linux-gnu" +
        " artifacts/bootstrap/cheng.stage0 bootstrap-bridge >/dev/null" +
        " && BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
        " BFT_STATE_RUN_SELF_TEST=1" +
        " artifacts/bootstrap/cheng.stage3 build-bft-state-machine")
    let run = GateRunRemoteShellLogged(root, "bft_remote_build", sshHost, fullCommand, logPath, 900)
    if GateRunFailed(run):
        return run.exitCode
    GatePrintLine("[ gate] remote bft rebuild " + sshHost)
    return 0

fn GateStatusBftValidatorThreeNode(root: str): int32 =
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/gate/bft_server_status")
    if IsErr(serverRes):
        GatePrintErr(" bft deploy: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/gate/bft_relay_status")
    if IsErr(relayRes):
        GatePrintErr(" bft deploy: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    let localRes = GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/gate/bft_local_status")
    if IsErr(localRes):
        GatePrintErr(" bft deploy: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    GateBftPrintNodeStatus(Value(serverRes))
    GatePrintLine("---")
    GateBftPrintNodeStatus(Value(relayRes))
    GatePrintLine("---")
    GateBftPrintNodeStatus(Value(localRes))
    return 0

fn GateStopBftValidatorThreeNode(root: str): int32 =
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRun = GateRunRemoteShellLogged(root,
                                               "bft_stop_server",
                                               cfg.serverSsh,
                                               GateBftStopShell([
                                                   os.JoinPath(serverDir, "server_proposer.pid"),
                                                   os.JoinPath(serverDir, "server_state.pid")
                                               ], [
                                                   "[v]alidator-proposer-daemon --state:" +
                                                       os.JoinPath(serverDir, "server.state"),
                                                   "[s]tate-serve-daemon --file:" +
                                                       os.JoinPath(serverDir, "server.machine.hex")
                                               ]),
                                               "artifacts/gate/bft_stop_server.log",
                                               30)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = GateRunRemoteShellLogged(root,
                                              "bft_stop_relay",
                                              cfg.relaySsh,
                                              GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                 [
                                                                     "[v]alidator-follower-daemon --state:" +
                                                                         os.JoinPath(relayDir, "relay.state")
                                                                 ]),
                                              "artifacts/gate/bft_stop_relay.log",
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = GateRunShellLogged(root,
                                        "bft_stop_local",
                                        GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                           [
                                                               "[v]alidator-follower-daemon --state:" +
                                                                   os.JoinPath(localDir, "local.state")
                                                           ]),
                                        "artifacts/gate/bft_stop_local.log",
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    GatePrintLine(" bft deploy: stopped")
    return 0

fn GateDeployBftValidatorThreeNode(root: str): int32 =
    let cfg = GateBftThreeNodeConfig(root)
    if !chengpath.MkdirP(root, cfg.localDeployDir):
        GatePrintErr(" bft deploy: failed to create local deploy dir")
        return 1
    if !chengpath.WriteTextFile(root, GateBftManifestPath(cfg), GateBftManifestText(cfg)):
        GatePrintErr(" bft deploy: failed to write manifest")
        return 1
    if GateStopBftValidatorThreeNode(root) != 0:
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.serverSsh,
                               cfg.serverRepoRoot,
                               "artifacts/gate/bft_sync_server.log") != 0:
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.relaySsh,
                               cfg.relayRepoRoot,
                               "artifacts/gate/bft_sync_relay.log") != 0:
        return 1
    if GateBuildBftStateMachine(root) != 0:
        return 1
    if GateBftBuildRemote(root,
                            cfg.serverSsh,
                            cfg.serverRepoRoot,
                            "artifacts/gate/bft_build_server.log") != 0:
        return 1
    if GateBftBuildRemote(root,
                            cfg.relaySsh,
                            cfg.relayRepoRoot,
                            "artifacts/gate/bft_build_relay.log") != 0:
        return 1
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = GateBftLocalBin(root)
    let serverInit = GateRunRemoteShellLogged(root,
                                                "bft_init_server",
                                                cfg.serverSsh,
                                                "set -eu && mkdir -p " + os.QuoteShell(serverDir) +
                                                " && rm -f " +
                                                os.QuoteShell(os.JoinPath(serverDir, "server.proposal.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.commit.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.vote.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.state.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.state.vote_lock")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.queue.cursor")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.machine.hex")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server_state.pid")) +
                                                " && rm -rf " +
                                                    os.QuoteShell(os.JoinPath(serverDir,
                                                                              "server.machine.hex.snapshots")) +
                                                " && : > " + os.QuoteShell(os.JoinPath(serverDir, "server.queue")) +
                                                " && : > " +
                                                    os.QuoteShell(os.JoinPath(serverDir, "server.proposal.hex")) +
                                                " && : > " +
                                                    os.QuoteShell(os.JoinPath(serverDir, "server.commit.hex")) +
                                                " && : > " + os.QuoteShell(os.JoinPath(serverDir, "server.votes")) +
                                                " && " + GateShellArgv([serverBin,
                                                                          "init",
                                                                          "--state:" +
                                                                              os.JoinPath(serverDir, "server.state"),
                                                                          "--app-id:" + cfg.appId,
                                                                          "--validator-slot:1",
                                                                          "--force"]),
                                                "artifacts/gate/bft_init_server.log",
                                                30)
    if GateRunFailed(serverInit):
        return serverInit.exitCode
    let relayInit = GateRunRemoteShellLogged(root,
                                               "bft_init_relay",
                                               cfg.relaySsh,
                                               "set -eu && mkdir -p " + os.QuoteShell(relayDir) +
                                               " && " + GateShellArgv([relayBin,
                                                                         "init",
                                                                         "--state:" +
                                                                             os.JoinPath(relayDir, "relay.state"),
                                                                         "--app-id:" + cfg.appId,
                                                                         "--validator-slot:2",
                                                                         "--force"]),
                                               "artifacts/gate/bft_init_relay.log",
                                               30)
    if GateRunFailed(relayInit):
        return relayInit.exitCode
    let localInit = GateRunShellLogged(root,
                                         "bft_init_local",
                                         "set -eu && mkdir -p " + os.QuoteShell(localDir) +
                                         " && " + GateShellArgv([localBin,
                                                                   "init",
                                                                   "--state:" + os.JoinPath(localDir, "local.state"),
                                                                   "--app-id:" + cfg.appId,
                                                                   "--validator-slot:3",
                                                                   "--force"]),
                                         "artifacts/gate/bft_init_local.log",
                                         30)
    if GateRunFailed(localInit):
        return localInit.exitCode
    let queueRun = GateRunRemoteShellLogged(root,
                                              "bft_seed_queue",
                                              cfg.serverSsh,
                                              "set -eu && " +
                                              GateShellArgv([serverBin,
                                                               "submit-mint",
                                                               "--queue:" + os.JoinPath(serverDir, "server.queue"),
                                                               "--asset:" + intToStr(cfg.assetId),
                                                               "--account:" + intToStr(cfg.aliceId),
                                                               "--amount:" + strings.Int64ToStr(cfg.mintAmount)]) +
                                              " && " +
                                              GateShellArgv([serverBin,
                                                               "submit-transfer",
                                                               "--queue:" + os.JoinPath(serverDir, "server.queue"),
                                                               "--asset:" + intToStr(cfg.assetId),
                                                               "--from:" + intToStr(cfg.aliceId),
                                                               "--to:" + intToStr(cfg.bobId),
                                                               "--amount:" + strings.Int64ToStr(cfg.transferAmount)]),
                                              "artifacts/gate/bft_seed_queue.log",
                                              30)
    if GateRunFailed(queueRun):
        return queueRun.exitCode
    let serverProposerRun = GateRunRemoteShellLogged(root,
                                                       "bft_start_server_proposer",
                                                       cfg.serverSsh,
                                                       GateBftStartDetachedShell(serverBin,
                                                                                ["validator-proposer-daemon",
                                                                                 "--state:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.state"),
                                                                                 "--queue:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.queue"),
                                                                                 "--proposal-host:0.0.0.0",
                                                                                 "--proposal-port:" +
                                                                                     intToStr(cfg.proposalPort),
                                                                                 "--vote-host:0.0.0.0",
                                                                                 "--vote-port:" +
                                                                                     intToStr(cfg.votePort),
                                                                                 "--commit-host:0.0.0.0",
                                                                                 "--commit-port:" +
                                                                                     intToStr(cfg.commitPort),
                                                                                 "--proposal-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.proposal." +
                                                                                                     "hex"),
                                                                                 "--commit-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.commit.hex"),
                                                                                 "--state-sync-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.machine.hex"),
                                                                                 "--proposal-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.proposal.ready"),
                                                                                 "--vote-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.vote.ready"),
                                                                                 "--commit-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.commit.ready"),
                                                                                 "--interval-ms:" +
                                                                                     intToStr(cfg.proposerIntervalMs),
                                                                                 "--proposal-window-ms:" +
                                                                                     intToStr(cfg.proposalWindowMs),
                                                                                 "--vote-window-ms:" +
                                                                                     intToStr(cfg.voteWindowMs),
                                                                                 "--commit-window-ms:" +
                                                                                     intToStr(cfg.commitWindowMs),
                                                                                 "--max-txs:" +
                                                                                     intToStr(
                                                                                         GateBftDaemonMaxTxs(cfg))],
                                                                                os.JoinPath(serverDir,
                                                                                            "server_proposer.pid"),
                                                                                os.JoinPath(serverDir,
                                                                                            "server.proposer.log"),
                                                                                os.JoinPath(serverDir,
                                                                                            "server.proposal.ready"),
                                                                                true),
                                                       "artifacts/gate/bft_start_server_proposer.log",
                                                       30)
    if GateRunFailed(serverProposerRun):
        return serverProposerRun.exitCode
    let serverStateRun = GateRunRemoteShellLogged(root,
                                                    "bft_start_server_state",
                                                    cfg.serverSsh,
                                                    GateBftStartDetachedShell(serverBin,
                                                                             ["state-serve-daemon",
                                                                              "--file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.machine.hex"),
                                                                              "--host:0.0.0.0",
                                                                              "--port:" +
                                                                                  intToStr(cfg.statePort),
                                                                              "--interval-ms:" +
                                                                                  intToStr(cfg.followerIntervalMs)],
                                                                             os.JoinPath(serverDir,
                                                                                         "server_state.pid"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.state.log"),
                                                                             "",
                                                                             true),
                                                    "artifacts/gate/bft_start_server_state.log",
                                                    30)
    if GateRunFailed(serverStateRun):
        return serverStateRun.exitCode
    let serverReadyRun = GateRunRemoteShellLogged(root,
                                                    "bft_wait_server_ready",
                                                    cfg.serverSsh,
                                                    "set -eu && i=0 && while { [ ! -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")) +
                                                        " ] || [ ! -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready")) +
                                                        " ]; } && [ \"$i\" -lt 200 ]; do i=$((i + 1)); sleep 0.05; done && test -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")) +
                                                        " && test -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready")),
                                                    "artifacts/gate/bft_wait_server_ready.log",
                                                    30)
    if GateRunFailed(serverReadyRun):
        return serverReadyRun.exitCode
    let relayFollowerRun = GateRunRemoteShellLogged(root,
                                                      "bft_start_relay_follower",
                                                      cfg.relaySsh,
                                                      GateBftStartDetachedShell(relayBin,
                                                                               ["validator-follower-daemon",
                                                                                "--state:" +
                                                                                    os.JoinPath(relayDir,
                                                                                                "relay.state"),
                                                                                "--proposal-host:" + cfg.serverAddress,
                                                                                 "--proposal-port:" +
                                                                                     intToStr(cfg.proposalPort),
                                                                                "--vote-host:" + cfg.serverAddress,
                                                                                "--vote-port:" +
                                                                                    intToStr(cfg.votePort),
                                                                                "--commit-host:" + cfg.serverAddress,
                                                                                "--commit-port:" +
                                                                                    intToStr(cfg.commitPort),
                                                                                "--sync-host:" + cfg.serverAddress,
                                                                                "--sync-port:" +
                                                                                    intToStr(cfg.statePort),
                                                                                "--interval-ms:" +
                                                                                    intToStr(cfg.followerIntervalMs)],
                                                                               os.JoinPath(relayDir,
                                                                                           "relay_follower.pid"),
                                                                               os.JoinPath(relayDir,
                                                                                           "relay.follower.log"),
                                                                               "",
                                                                               true),
                                                      "artifacts/gate/bft_start_relay_follower.log",
                                                      30)
    if GateRunFailed(relayFollowerRun):
        return relayFollowerRun.exitCode
    let localFollowerRun = GateRunShellLogged(root,
                                                "bft_start_local_follower",
                                                GateBftStartDetachedShell(localBin,
                                                                         ["validator-follower-daemon",
                                                                          "--state:" +
                                                                              os.JoinPath(localDir, "local.state"),
                                                                          "--proposal-host:" + cfg.serverAddress,
                                                                          "--proposal-port:" +
                                                                              intToStr(cfg.proposalPort),
                                                                          "--vote-host:" + cfg.serverAddress,
                                                                          "--vote-port:" + intToStr(cfg.votePort),
                                                                          "--commit-host:" + cfg.serverAddress,
                                                                          "--commit-port:" + intToStr(cfg.commitPort),
                                                                          "--sync-host:" + cfg.serverAddress,
                                                                          "--sync-port:" +
                                                                              intToStr(cfg.statePort),
                                                                          "--interval-ms:" +
                                                                              intToStr(cfg.followerIntervalMs)],
                                                                         os.JoinPath(localDir, "local_follower.pid"),
                                                                         os.JoinPath(localDir, "local.follower.log"),
                                                                         "",
                                                                         false),
                                                "artifacts/gate/bft_start_local_follower.log",
                                                30)
    if GateRunFailed(localFollowerRun):
        return localFollowerRun.exitCode
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var converged = false
    var lastServer = GateBftNodeStatusZero("server")
    var lastRelay = GateBftNodeStatusZero("relay")
    var lastLocal = GateBftNodeStatusZero("local")
    for i in 0..<200:
        i
        let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         "artifacts/gate/bft_server_wait")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        "artifacts/gate/bft_relay_wait")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       "artifacts/gate/bft_local_wait")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        lastServer = Value(serverRes)
        lastRelay = Value(relayRes)
        lastLocal = Value(localRes)
        if lastServer.height == wantHeight &&
           lastRelay.height == wantHeight &&
           lastLocal.height == wantHeight &&
           len(lastServer.appHash) > 0 &&
           lastServer.appHash == lastRelay.appHash &&
           lastServer.appHash == lastLocal.appHash &&
           lastServer.aliceBalance == wantAlice &&
           lastRelay.aliceBalance == wantAlice &&
           lastLocal.aliceBalance == wantAlice &&
           lastServer.bobBalance == wantBob &&
           lastRelay.bobBalance == wantBob &&
           lastLocal.bobBalance == wantBob:
            converged = true
            break
        os.SleepMs(200)
    if !converged:
        GatePrintErr(" bft deploy: three-node cluster did not converge")
        GateBftPrintNodeStatus(lastServer)
        GatePrintLine("---")
        GateBftPrintNodeStatus(lastRelay)
        GatePrintLine("---")
        GateBftPrintNodeStatus(lastLocal)
        return 1
    let ueRun = GateRunShellLogged(root,
                                     "bft_ue_check",
                                     "ps -Ao pid=,ppid=,state=,etime=,command= |" +
                                         " awk '$2==1 && $3 ~ /^U/ && $5 ~ /bft_state_machine/'",
                                     "artifacts/gate/bft_ue_check.log",
                                     10)
    if GateRunFailed(ueRun):
        return ueRun.exitCode
    GateBftPrintNodeStatus(lastServer)
    GatePrintLine("---")
    GateBftPrintNodeStatus(lastRelay)
    GatePrintLine("---")
    GateBftPrintNodeStatus(lastLocal)
    let ueText = strutil.Strip(ueRun.output)
    if len(ueText) > 0:
        GatePrintErr(" bft deploy: unexpected UE process")
        GatePrintErr(ueText)
        return 1
    return 0

fn GateVerifyBftValidatorThreeNode(root: str): int32 =
    if GateDeployBftValidatorThreeNode(root) != 0:
        return 1
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var serverStatus = GateBftNodeStatusZero("server")
    var relayStatus = GateBftNodeStatusZero("relay")
    var localStatus = GateBftNodeStatusZero("local")
    var verified = false
    let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/gate/bft_verify_server")
    let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/gate/bft_verify_relay")
    let localRes = GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/gate/bft_verify_local")
    if !IsErr(serverRes):
        serverStatus = Value(serverRes)
    if !IsErr(relayRes):
        relayStatus = Value(relayRes)
    if !IsErr(localRes):
        localStatus = Value(localRes)
    if !IsErr(serverRes) && !IsErr(relayRes) && !IsErr(localRes):
        verified = GateBftClusterMatches(serverStatus,
                                           relayStatus,
                                           localStatus,
                                           wantHeight,
                                           wantAlice,
                                           wantBob)
    let reportPath = GateBftVerifyReportPath(root)
    let reportText = GateBftVerifyReportText(cfg,
                                               verified,
                                               serverStatus,
                                               relayStatus,
                                               localStatus)
    if !chengpath.WriteTextFile(root, reportPath, reportText):
        GatePrintErr(" bft verify: failed to write report: " + reportPath)
        let _ = GateStopBftValidatorThreeNode(root)
        return 1
    let stopCode = GateStopBftValidatorThreeNode(root)
    if IsErr(serverRes):
        GatePrintErr(" bft verify: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    if IsErr(relayRes):
        GatePrintErr(" bft verify: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    if IsErr(localRes):
        GatePrintErr(" bft verify: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    if !verified:
        GatePrintErr(" bft verify: three-node cluster drifted")
        GateBftPrintNodeStatus(serverStatus)
        GatePrintLine("---")
        GateBftPrintNodeStatus(relayStatus)
        GatePrintLine("---")
        GateBftPrintNodeStatus(localStatus)
        return 1
    if stopCode != 0:
        GatePrintErr(" bft verify: stop failed after verification")
        return stopCode
    GatePrintLine(" bft verify ok")
    GatePrintLine("report=" + reportPath)
    return 0

fn GateBenchBftValidatorThreeNode(root: str,
                                    args: str[]): int32 =
    let txCountText = GateReadFlag(args, "--tx-count", "64")
    let waveCountText = GateReadFlag(args, "--wave-count", "1")
    let transferAmountText = GateReadFlag(args, "--transfer-amount", "1")
    let txCount = int32(strutil.ParseInt(txCountText))
    let waveCount = int32(strutil.ParseInt(waveCountText))
    let transferAmount = int64(strutil.ParseInt(transferAmountText))
    let maxTxsText = GateReadFlag(args, "--max-txs-per-block", intToStr(txCount))
    let maxTxsPerBlock = int32(strutil.ParseInt(maxTxsText))
    let restartNode = strutil.Strip(GateReadFlag(args, "--restart-node", "none"))
    let restartPauseMsText = GateReadFlag(args, "--restart-pause-ms", "1000")
    let restartPauseMs = int32(strutil.ParseInt(restartPauseMsText))
    let defaultRestartWave = waveCount >= 2 ? 2 : 1
    let restartWaveText = GateReadFlag(args, "--restart-wave", intToStr(defaultRestartWave))
    var restartWave = int32(strutil.ParseInt(restartWaveText))
    if txCount <= 0 || waveCount <= 0 || transferAmount <= int64(0) || maxTxsPerBlock <= 0 || restartPauseMs < 0:
        GatePrintErr(" bft bench: --tx-count --wave-count --transfer-amount --max-txs-per-block must be positive, --restart-pause-ms must be non-negative")
        return 1
    if !GateBftBenchRestartTargetValid(restartNode):
        GatePrintErr(" bft bench: --restart-node must be none/server/relay/local")
        return 1
    if restartNode == "none":
        restartWave = 0
    elif restartWave <= 0 || restartWave > waveCount:
        GatePrintErr(" bft bench: --restart-wave must be within 1..wave-count when restart is enabled")
        return 1
    var savedMaxTxs = ""
    savedMaxTxs = os.GetEnvDefault("CHENG_BFT_MAX_TXS", "")
    os.SetEnv("CHENG_BFT_MAX_TXS", intToStr(maxTxsPerBlock))
    if GateDeployBftValidatorThreeNode(root) != 0:
        os.SetEnv("CHENG_BFT_MAX_TXS", savedMaxTxs)
        return 1
    os.SetEnv("CHENG_BFT_MAX_TXS", savedMaxTxs)
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = GateBftLocalBin(root)
    var baseServer = GateBftNodeStatusZero("server")
    var baseRelay = GateBftNodeStatusZero("relay")
    var baseLocal = GateBftNodeStatusZero("local")
    if !GateBftWaitClusterState(root,
                                  cfg,
                                  serverDir,
                                  relayDir,
                                  localDir,
                                  "1",
                                  strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount),
                                  strings.Int64ToStr(cfg.transferAmount),
                                  "artifacts/gate/bft_bench_bootstrap_wait",
                                  baseServer,
                                  baseRelay,
                                  baseLocal):
        GatePrintErr(" bft bench: baseline cluster wait failed")
        return 1
    var baseHeight = int64(strutil.ParseInt(baseServer.height))
    var baseAlice = int64(strutil.ParseInt(baseServer.aliceBalance))
    var baseBob = int64(strutil.ParseInt(baseServer.bobBalance))
    let totalRequiredAmount = int64(txCount) * int64(waveCount) * transferAmount
    if baseAlice < totalRequiredAmount:
        let topupAmount = totalRequiredAmount - baseAlice + transferAmount
        let topupRun = GateRunRemoteShellLogged(root,
                                                  "bft_bench_topup",
                                                  cfg.serverSsh,
                                                  "set -eu && " + GateShellArgv([serverBin,
                                                                                   "submit-mint",
                                                                                   "--queue:" +
                                                                                       os.JoinPath(serverDir,
                                                                                                   "server.queue"),
                                                                                   "--asset:" + intToStr(cfg.assetId),
                                                                                   "--account:" +
                                                                                       intToStr(cfg.aliceId),
                                                                                   "--amount:" +
                                                                                       strings.Int64ToStr(
                                                                                           topupAmount)]),
                                                  "artifacts/gate/bft_bench_topup.log",
                                                  30)
        if GateRunFailed(topupRun):
            return topupRun.exitCode
        baseHeight = baseHeight + int64(1)
        baseAlice = baseAlice + topupAmount
        if !GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(baseHeight),
                                      strings.Int64ToStr(baseAlice),
                                      strings.Int64ToStr(baseBob),
                                      "artifacts/gate/bft_bench_topup_wait",
                                      baseServer,
                                      baseRelay,
                                      baseLocal):
            GatePrintErr(" bft bench: topup did not converge")
            return 1
    let benchStart = monotimes.GetMonoTime()
    var waveElapsedMs: int64[]
    var waveTpsMilli: int64[]
    var waveBlockCounts: int64[]
    var waveRestarted: bool[]
    var totalQueuedCount = int64(0)
    var totalQueuedBytes = int64(0)
    var txWireBytes = int64(0)
    var totalBlocks = int64(0)
    var expectedHeight = baseHeight
    var expectedAlice = baseAlice
    var expectedBob = baseBob
    var finalServer = baseServer
    var finalRelay = baseRelay
    var finalLocal = baseLocal
    let requiredPerWave = int64(txCount) * transferAmount
    for wave in 0..<waveCount:
        let waveIndex = wave + 1
        let waveStart = monotimes.GetMonoTime()
        let wavePrefix = "artifacts/gate/bft_bench_wave_" + intToStr(waveIndex)
        let queueRun = GateRunRemoteShellLogged(root,
                                                  "bft_bench_submit_series_wave_" + intToStr(waveIndex),
                                                  cfg.serverSsh,
                                                  "set -eu && " + GateShellArgv([serverBin,
                                                                                   "submit-transfer-series",
                                                                                   "--queue:" +
                                                                                       os.JoinPath(serverDir,
                                                                                                   "server.queue"),
                                                                                   "--asset:" +
                                                                                       intToStr(cfg.assetId),
                                                                                   "--from:" +
                                                                                       intToStr(cfg.aliceId),
                                                                                   "--to:" +
                                                                                       intToStr(cfg.bobId),
                                                                                   "--amount:" +
                                                                                       strings.Int64ToStr(
                                                                                           transferAmount),
                                                                                   "--count:" +
                                                                                       intToStr(txCount)]),
                                                  wavePrefix + ".submit.log",
                                                  30)
        if GateRunFailed(queueRun):
            return queueRun.exitCode
        let queuedCount = int64(strutil.ParseInt(GateTextValue(queueRun.output, "queued_count")))
        let queuedBytes = int64(strutil.ParseInt(GateTextValue(queueRun.output, "queued_bytes")))
        let txWireBytesWave = int64(strutil.ParseInt(GateTextValue(queueRun.output, "tx_wire_bytes")))
        if queuedCount != int64(txCount) || queuedBytes <= 0 || txWireBytesWave <= 0:
            GatePrintErr(" bft bench: invalid submit-transfer-series report")
            GatePrintErr(strutil.Strip(queueRun.output))
            return 1
        if txWireBytes <= int64(0):
            txWireBytes = txWireBytesWave
        let blocksNeeded = int64((txCount + maxTxsPerBlock - 1) / maxTxsPerBlock)
        totalQueuedCount = totalQueuedCount + queuedCount
        totalQueuedBytes = totalQueuedBytes + queuedBytes
        totalBlocks = totalBlocks + blocksNeeded
        expectedHeight = expectedHeight + blocksNeeded
        expectedAlice = expectedAlice - requiredPerWave
        expectedBob = expectedBob + requiredPerWave
        var restarted = false
        if restartNode != "none" && waveIndex == restartWave:
            if GateBftBenchRestartNode(root,
                                         cfg,
                                         serverDir,
                                         relayDir,
                                         localDir,
                                         serverBin,
                                         relayBin,
                                         localBin,
                                         restartNode,
                                         restartPauseMs,
                                         wavePrefix + ".restart") != 0:
                return 1
            restarted = true
        if !GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(expectedHeight),
                                      strings.Int64ToStr(expectedAlice),
                                      strings.Int64ToStr(expectedBob),
                                      wavePrefix + ".wait",
                                      finalServer,
                                      finalRelay,
                                      finalLocal):
            GatePrintErr(" bft bench: benchmark transactions did not converge")
            GatePrintErr("wave=" + intToStr(waveIndex))
            return 1
        var waveElapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(waveStart)
        var waveElapsed = waveElapsedNs / 1000000
        if waveElapsed <= int64(0):
            waveElapsed = int64(1)
        let waveTps = queuedCount * int64(1000000) / waveElapsed
        add(waveElapsedMs, waveElapsed)
        add(waveTpsMilli, waveTps)
        add(waveBlockCounts, blocksNeeded)
        add(waveRestarted, restarted)
    var elapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(benchStart)
    var elapsedMs = elapsedNs / 1000000
    if elapsedMs <= int64(0):
        elapsedMs = int64(1)
    let tpsMilli = totalQueuedCount * int64(1000000) / elapsedMs
    let bytesPerSec = totalQueuedBytes * int64(1000) / elapsedMs
    let kibPerSecMilli = totalQueuedBytes * int64(1000 * 1000) / (elapsedMs * int64(1024))
    let ueRun = GateRunShellLogged(root,
                                     "bft_bench_ue_check",
                                     "ps -Ao pid=,ppid=,state=,etime=,command= |" +
                                         " awk '$2==1 && $3 ~ /^U/ && $5 ~ /bft_state_machine/'",
                                     "artifacts/gate/bft_bench_ue_check.log",
                                     10)
    if GateRunFailed(ueRun):
        return ueRun.exitCode
    let ueText = strutil.Strip(ueRun.output)
    if len(ueText) > 0:
        GatePrintErr(" bft bench: unexpected UE process")
        GatePrintErr(ueText)
        return 1
    let reportPath = GateBftBenchReportPath(root)
    let reportText = GateBftBenchReportText(cfg,
                                              int64(txCount),
                                              waveCount,
                                              transferAmount,
                                              maxTxsPerBlock,
                                              restartNode,
                                              restartWave,
                                              restartPauseMs,
                                              totalQueuedCount,
                                              txWireBytes,
                                              totalQueuedBytes,
                                              totalBlocks,
                                              elapsedMs,
                                              tpsMilli,
                                              bytesPerSec,
                                              kibPerSecMilli,
                                              waveElapsedMs,
                                              waveTpsMilli,
                                              waveBlockCounts,
                                              waveRestarted,
                                              finalServer)
    if !chengpath.WriteTextFile(root, reportPath, reportText):
        GatePrintErr(" bft bench: failed to write report: " + reportPath)
        return 1
    GatePrintLine("tx_count_per_wave=" + strings.Int64ToStr(int64(txCount)))
    GatePrintLine("wave_count=" + intToStr(waveCount))
    GatePrintLine("restart_node=" + restartNode)
    GatePrintLine("restart_wave=" + intToStr(restartWave))
    GatePrintLine("restart_pause_ms=" + intToStr(restartPauseMs))
    GatePrintLine("tx_count=" + strings.Int64ToStr(totalQueuedCount))
    GatePrintLine("tx_wire_bytes=" + strings.Int64ToStr(txWireBytes))
    GatePrintLine("committed_bytes=" + strings.Int64ToStr(totalQueuedBytes))
    GatePrintLine("block_count=" + strings.Int64ToStr(totalBlocks))
    GatePrintLine("elapsed_ms=" + strings.Int64ToStr(elapsedMs))
    GatePrintLine("tps=" + GateFormatMilli(tpsMilli))
    GatePrintLine("throughput_bytes_per_sec=" + strings.Int64ToStr(bytesPerSec))
    GatePrintLine("throughput_kib_per_sec=" + GateFormatMilli(kibPerSecMilli))
    GatePrintLine("final_height=" + finalServer.height)
    GatePrintLine("app_hash=" + finalServer.appHash)
    GatePrintLine("alice_balance=" + finalServer.aliceBalance)
    GatePrintLine("bob_balance=" + finalServer.bobBalance)
    for i in 0..<waveElapsedMs.len:
        let waveIndex = intToStr(i + 1)
        GatePrintLine("wave_" + waveIndex + "_elapsed_ms=" + strings.Int64ToStr(waveElapsedMs[i]))
        GatePrintLine("wave_" + waveIndex + "_tps=" + GateFormatMilli(waveTpsMilli[i]))
        GatePrintLine("wave_" + waveIndex + "_block_count=" + strings.Int64ToStr(waveBlockCounts[i]))
        GatePrintLine("wave_" + waveIndex + "_restarted=" + (waveRestarted[i] ? "true" : "false"))
    GatePrintLine("report=" + reportPath)
    return 0

fn GateRequireFile(path: str, context: str): bool =
    if os.FileExists(path):
        return true
    GatePrintErr(context + ": missing file: " + path)
    return false

fn GateRequireFileContains(path: str,
                             needle: str,
                             context: str): bool =
    if !GateRequireFile(path, context):
        return false
    let text: str = chengpath.ReadTextFile("", path)
    if GateOutputContains(text, needle):
        return true
    GatePrintErr(context + ": missing output: " + needle)
    let outputText = strutil.Strip(text)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return false

fn GateRequirePrefixArtifacts(prefix: str,
                                suffixes: str[],
                                context: str): bool =
    for i in 0..<suffixes.len:
        if !GateRequireFile(prefix + suffixes[i], context):
            return false
    return true

fn GateRequireAnyOutput(text: str,
                          needles: str[],
                          context: str): bool =
    if GateTextContainsAny(text, needles):
        return true
    GatePrintErr(context + ": missing expected output set")
    let outputText = strutil.Strip(text)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return false

fn GateResolveSmokeCompiler(root: str,
                              explicitPath: str,
                              primaryEnvKey: str,
                              fallbackEnvKey: str,
                              outCompiler: var str): int32 =
    outCompiler = strutil.Strip(explicitPath)
    if len(outCompiler) <= 0 && len(primaryEnvKey) > 0:
        let envCompiler = os.GetEnvDefault(primaryEnvKey, "")
        outCompiler = strutil.Strip(envCompiler)
    if len(outCompiler) <= 0 && len(fallbackEnvKey) > 0:
        let envCompiler = os.GetEnvDefault(fallbackEnvKey, "")
        outCompiler = strutil.Strip(envCompiler)
    if len(outCompiler) <= 0:
        return GateEnsureBackendDriverReady(root, outCompiler)
    outCompiler = chengpath.PathAbsolute(root, outCompiler)
    if !os.FileExists(outCompiler):
        GatePrintErr(" gate: missing compiler: " + outCompiler)
        return 1
    return 0

fn GateResolveSmokeLabel(args: str[],
                           envKey: str,
                           defaultLabel: str): str =
    let explicit = strutil.Strip(GateReadFlag(args, "--label", ""))
    if len(explicit) > 0:
        return explicit
    let keyedEnv = os.GetEnvDefault(envKey, "")
    let keyed = strutil.Strip(keyedEnv)
    if len(keyed) > 0:
        return keyed
    let sharedEnv = os.GetEnvDefault("CHENG_SMOKE_LABEL", "")
    let shared = strutil.Strip(sharedEnv)
    if len(shared) > 0:
        return shared
    return defaultLabel

fn GateTextContainsAny(text: str, needles: str[]): bool =
    for i in 0..<needles.len:
        if chengpath.TextContains(text, needles[i]):
            return true
    return false

fn GateAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn GateOrphanSnapshotKey(lineRaw: str): str =
    let line = strutil.Strip(lineRaw)
    if len(line) <= 0:
        return ""
    let total = len(line)
    var cursor = 0
    while cursor < total:
        if !GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let pidStart = cursor
    while cursor < total:
        if GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= pidStart:
        return ""
    let pidText = chengpath.TextSlice(line, pidStart, cursor - pidStart)
    for skip in 0..<3:
        let _ = skip
        while cursor < total:
            if !GateAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        let fieldStart = cursor
        while cursor < total:
            if GateAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        if cursor <= fieldStart:
            return ""
    while cursor < total:
        if !GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor >= total:
        return ""
    let commandText = chengpath.TextSlice(line, cursor, total - cursor)
    return pidText + "|" + commandText

fn GateNormalizeOrphanSnapshot(text: str): str[] =
    var out: str[]
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let key = GateOrphanSnapshotKey(lines[i])
        if len(key) > 0:
            add(out, key)
    return out

fn GateSeqContainsStr(items: str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn GateCollectNewOrphanKeys(before: str[], after: str[]): str[] =
    var out: str[]
    for i in 0..<after.len:
        let key = after[i]
        if !GateSeqContainsStr(before, key) && !GateSeqContainsStr(out, key):
            add(out, key)
    return out

fn GateReadChengOrphanSnapshot(root: str,
                                 label: str,
                                 logPath: str,
                                 outLines: var str[]): int32 =
    let command = "ps -Ao pid=,ppid=,state=,etime=,command= | " +
                  "awk -v root=" + os.QuoteShell(root) +
                  " '$2==1 && $3 ~ /^U/ && index($0, root) > 0'"
    let run = GateRunShellLogged(root, label, command, logPath, 10)
    if GateRunFailed(run):
        outLines = []
        return run.exitCode
    outLines = GateNormalizeOrphanSnapshot(run.output)
    return 0

fn GateVerifyOrphanGuard(root: str): int32 =
    let toolingDir: str = chengpath.PathAbsolute(root, "tools")
    let bannedEntries: str[] = [
        "guarded_exec.py",
        "orphan_guard_run.sh",
        "failfast_parallel.sh",
        "bootstrap_bridge.sh",
        "build_bft_state_machine.sh",
        "build_backend_driver.sh",
        "build_bounds_trace.sh",
        "build_browser_host_wasm.sh",
        "browser_host_wasm_runner.js",
        "build_call_chain.sh",
        "build_chain_node_linux_obj.sh",
        "build_chain_node_linux.sh",
        "build_chain_node.sh",
        "build_ffi_handle.sh",
        "build_linux_nolibc_exe.sh",
        "build_panic_trace.sh",
        "build_program_selfhost.sh",
        "build_rwad_bft_state_machine_linux_obj.sh",
        "build_rwad_bft_state_machine_linux.sh",
        "build_rwad_bft_state_machine.sh",
        "build_signal_trace.sh",
        "build_twoway_search_smoke.sh",
        "build_zero_exit.sh",
        "cheng_tooling_repo_dispatch.sh",
        "cheng.sh",
        "compare_bench.sh",
        "profile_run.sh",
        "r2c_react_fresh_clean_gate.sh",
        "run_slice_gate.sh",
        "run_browser_host_wasm_smoke.sh",
        "run_browser_webrtc_smokes.sh",
        "run_chain_node_cli_smoke.sh",
        "run_chain_node_process_smoke.sh",
        "run_chain_node_three_node_smoke.sh",
        "run_compile_exe.sh",
        "run_fresh_node_selfhost_gate.sh",
        "run_host_smokes.sh",
        "run_linux_object_smokes.sh",
        "run_migration_gate.sh",
        "run_single_smoke.sh",
        "run_stage23_libp2p_smokes.sh",
        "run_tailnet_control_smoke.sh",
        "run_tcp_twoproc_smoke.sh",
        "run_quic_twoproc_smoke.sh",
        "run_udp_importc_smoke.sh",
        "run_wasm_smokes.sh",
        "run_windows_riscv_builtin_smokes.sh",
        "scan_forbidden_hotpath.sh",
        "verify_debug_profile.sh",
        "verify_debug_runtime.sh",
        "verify_debug_tools.sh",
        "verify_orphan_guard.sh",
        "verify_riscv64_builtin_linker.sh",
        "verify_windows_builtin_linker.sh"
    ]
    let entries: str[] = os.WalkDir(toolingDir)
    for i in 0..<entries.len:
        let entry: os.WalkDirEntry = os.WalkDirEntry(entries, i)
        let kind: os.PathComponent = os.WalkDirEntryKind(entry)
        if kind != os.PathComponent(0) &&
           kind != os.PathComponent(2):
            continue
        let path: str = os.WalkDirEntryPath(entry)
        let parts: os.SplitFileResult = os.SplitFile(path)
        let fileName: str = parts.name + parts.ext
        if GateTextContainsAny(fileName, bannedEntries):
            GatePrintErr("verify_orphan_guard: banned tooling entry name: " + path)
            return 1
        if parts.ext == ".sh":
            GatePrintErr("verify_orphan_guard: shell tooling entry not allowed: " + path)
            return 1
        if parts.ext != ".py":
            continue
        let text: str = chengpath.ReadTextFile("", path)
        if GateTextContainsAny(text, bannedEntries):
            GatePrintErr("verify_orphan_guard: banned direct process guard ref in " + path)
            return 1
    var orphanBefore: str[]
    if GateReadChengOrphanSnapshot(root,
                                     "orphan_guard_before",
                                     "artifacts/gate/orphan_guard_before.log",
                                     orphanBefore) != 0:
        return 1
    if GateBootstrapBridge(root) != 0:
        return 1
    if GateBuildBackendDriver(root) != 0:
        return 1
    var orphanAfter: str[]
    if GateReadChengOrphanSnapshot(root,
                                     "orphan_guard_after",
                                     "artifacts/gate/orphan_guard_after.log",
                                     orphanAfter) != 0:
        return 1
    let orphanDelta = GateCollectNewOrphanKeys(orphanBefore, orphanAfter)
    if orphanDelta.len > 0:
        GatePrintErr("verify_orphan_guard: new Cheng U/UE process leaked after bootstrap/build")
        for i in 0..<orphanDelta.len:
            GatePrintErr(orphanDelta[i])
        return 1
    GatePrintLine("verify_orphan_guard ok")
    return 0

