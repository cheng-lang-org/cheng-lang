fn GatePrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn GatePrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn GatePrintBlock(text: str) =
    var start: int32
    var i: int32
    while i <= text.len:
        let atEnd: bool = i == text.len
        if atEnd:
            let line: str = strings.SliceBytes(text, start, i - start)
            GatePrintLine(line)
            start = i + 1
        elif text[i] == '\n':
            let line: str = strings.SliceBytes(text, start, i - start)
            GatePrintLine(line)
            start = i + 1
        i = i + 1

fn GateRoot(): str =
    let fallbackRoot = os.GetCurrentDir()
    var rootDir = fallbackRoot
    let envRoot = os.GetEnv("CHENG_ROOT")
    if len(envRoot) > 0:
        rootDir = envRoot
    return rootDir

fn GateJoin2(a: str, b: str): str =
    return a + b

fn GateJoin3(a: str, b: str, c: str): str =
    return a + b + c

fn GateVerifyExportVisibility(root: str): int32 =
    var compiler = ""
    if GateResolveSmokeCompiler(root, "", "CHENG_SMOKE_COMPILER", "", compiler) != 0:
        return 1
    if GateRunStage3CommandWithEnv(root,
                                     "verify_export_visibility",
                                     "verify-export-visibility",
                                     ["--compiler:" + compiler],
                                     "verify-export-visibility.log",
                                     false,
                                     ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"]) != 0:
        GatePrintErr(" gate: verify-export-visibility failed")
        return 1
    GatePrintLine(" verify-export-visibility ok")
    return 0

fn GateVerifyExportVisibilityParallel(root: str): int32 =
    return GateRunStage3Command(root,
                                  "verify_export_visibility_parallel",
                                  "verify-export-visibility-parallel",
                                  [],
                                  "verify-export-visibility-parallel.log",
                                  false)

fn GateBootstrapBin(root: str, name: str): str =
    return chengpath.PathAbsolute(root, "artifacts/bootstrap/" + name)

fn GateArtifactsDir(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate")

fn GateEnsureArtifactsDir(root: str): bool =
    return chengpath.MkdirP(root, GateArtifactsDir(root))

fn GateUsage() =
    let lines: str[] = GateUsageLines()
    for i in 0..<lines.len:
        GatePrintLine(lines[i])

