fn GateBuildFfiHandle(root: str): int32 =
    var compiler = ""
    if GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/ffi_handle")
    let okSrc: str = chengpath.PathAbsolute(root, "src/tests/ffi_handle_smoke.cheng")
    let reuseSrc: str = chengpath.PathAbsolute(root, "src/tests/ffi_handle_generation_reuse_smoke.cheng")
    let trapSrc: str = chengpath.PathAbsolute(root, "src/tests/ffi_handle_stale_trap_smoke.cheng")
    let staleReuseSrc: str = chengpath.PathAbsolute(root, "src/tests/ffi_handle_generation_stale_trap_smoke.cheng")
    let okBin: str = os.JoinPath(outDir, "ffi_handle_smoke")
    let reuseBin: str = os.JoinPath(outDir, "ffi_handle_generation_reuse_smoke")
    let trapBin: str = os.JoinPath(outDir, "ffi_handle_stale_trap_smoke")
    let staleReuseBin: str = os.JoinPath(outDir, "ffi_handle_generation_stale_trap_smoke")
    let okCompileLog = "artifacts/ffi_handle/ffi_handle_smoke.compile.log"
    let okCompile = GateCompileExe(root,
                                     "build_ffi_handle_ok",
                                     compiler,
                                     okSrc,
                                     okBin,
                                     "arm64-apple-darwin",
                                     okCompileLog)
    if GateRunFailed(okCompile):
        return okCompile.exitCode
    let reuseCompileLog = "artifacts/ffi_handle/ffi_handle_generation_reuse_smoke.compile.log"
    let reuseCompile = GateCompileExe(root,
                                        "build_ffi_handle_generation_reuse",
                                        compiler,
                                        reuseSrc,
                                        reuseBin,
                                        "arm64-apple-darwin",
                                        reuseCompileLog)
    if GateRunFailed(reuseCompile):
        return reuseCompile.exitCode
    let trapCompileLog = "artifacts/ffi_handle/ffi_handle_stale_trap_smoke.compile.log"
    let trapCompile = GateCompileExe(root,
                                       "build_ffi_handle_trap",
                                       compiler,
                                       trapSrc,
                                       trapBin,
                                       "arm64-apple-darwin",
                                       trapCompileLog)
    if GateRunFailed(trapCompile):
        return trapCompile.exitCode
    let staleReuseCompileLog = "artifacts/ffi_handle/ffi_handle_generation_stale_trap_smoke.compile.log"
    let staleReuseCompile = GateCompileExe(root,
                                             "build_ffi_handle_stale_reuse_trap",
                                             compiler,
                                             staleReuseSrc,
                                             staleReuseBin,
                                             "arm64-apple-darwin",
                                             staleReuseCompileLog)
    if GateRunFailed(staleReuseCompile):
        return staleReuseCompile.exitCode
    if !os.FileExists(okBin + ".map") || !os.FileExists(reuseBin + ".map") ||
       !os.FileExists(trapBin + ".map") ||
       !os.FileExists(staleReuseBin + ".map"):
        GatePrintErr(" ffi-handle: missing line-map sidecar")
        return 1
    let okRun = GateRunBinary(root,
                                "build_ffi_handle_ok_run",
                                okBin,
                                [],
                                20,
                                "artifacts/ffi_handle/ffi_handle_smoke.run.log")
    GateMaybePrintRunOutput(okRun)
    if GateRunFailed(okRun):
        return okRun.exitCode
    let reuseRun = GateRunBinary(root,
                                   "build_ffi_handle_generation_reuse_run",
                                   reuseBin,
                                   [],
                                   20,
                                   "artifacts/ffi_handle/ffi_handle_generation_reuse_smoke.run.log")
    GateMaybePrintRunOutput(reuseRun)
    if GateRunFailed(reuseRun):
        return reuseRun.exitCode
    let trapRun = GateRunBinary(root,
                                  "build_ffi_handle_trap_run",
                                  trapBin,
                                  [],
                                  20,
                                  "artifacts/ffi_handle/ffi_handle_stale_trap_smoke.run.log")
    GateMaybePrintRunOutput(trapRun)
    if trapRun.exitCode == 0:
        GatePrintErr(" ffi-handle: stale trap unexpectedly exited 0")
        return 1
    if !GateRequireOutput(trapRun, "ffi handle invalid", " ffi-handle") ||
       !GateRequireOutput(trapRun, "reason=ffi_handle", " ffi-handle") ||
       !GateRequireOutput(trapRun, "ffi_handle_stale_trap_smoke.cheng:", " ffi-handle"):
        return 1
    let staleReuseRun = GateRunBinary(root,
                                        "build_ffi_handle_stale_reuse_trap_run",
                                        staleReuseBin,
                                        [],
                                        20,
                                        "artifacts/ffi_handle/ffi_handle_generation_stale_trap_smoke.run.log")
    GateMaybePrintRunOutput(staleReuseRun)
    if staleReuseRun.exitCode == 0:
        GatePrintErr(" ffi-handle: stale reuse trap unexpectedly exited 0")
        return 1
    if !GateRequireOutput(staleReuseRun, "ffi handle invalid", " ffi-handle") ||
       !GateRequireOutput(staleReuseRun, "detail=stale", " ffi-handle") ||
       !GateRequireOutput(staleReuseRun, "reason=ffi_handle", " ffi-handle") ||
       !GateRequireOutput(staleReuseRun, "ffi_handle_generation_stale_trap_smoke.cheng:", " ffi-handle"):
        return 1
    return 0

fn GateReadProgramTrim(root: str,
                         label: str,
                         programName: str,
                         args: str[],
                         logRelPath: str): str =
    let run: hostops.LoggedRun = hostops.RunProgramLogged(root,
                                                              label,
                                                              programName,
                                                              args,
                                                              [],
                                                              root,
                                                              20,
                                                              logRelPath)
    if GateRunFailed(run):
        return ""
    return strutil.Strip(run.output)

fn GateHostTarget(root: str): str =
    let hostOs: str = GateReadProgramTrim(root, " host uname-s", "uname", ["-s"], "artifacts/gate/uname_s.log")
    let hostArch: str = GateReadProgramTrim(root,
                                              " host uname-m",
                                              "uname",
                                              ["-m"],
                                              "artifacts/gate/uname_m.log")
    if hostOs == "Darwin" && hostArch == "arm64":
        return "arm64-apple-darwin"
    if hostOs == "Linux" && hostArch == "x86_64":
        return "x86_64-unknown-linux-gnu"
    if hostOs == "Linux" && (hostArch == "aarch64" || hostArch == "arm64"):
        return "aarch64-unknown-linux-gnu"
    return ""

fn GateCompileExeFromEnv(root: str): int32 =
    let explicitCompiler: str = os.GetEnvDefault("CHENG_COMPILE_COMPILER", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_COMPILE_COMPILER", "", compiler) != 0:
        return 1
    let packageRoot: str = chengpath.PathAbsolute(root, os.GetEnvDefault("CHENG_COMPILE_ROOT", "."))
    let src: str = chengpath.PathAbsolute(root, os.GetEnvDefault("CHENG_COMPILE_SOURCE", ""))
    let outBin: str = chengpath.PathAbsolute(root, os.GetEnvDefault("CHENG_COMPILE_OUT", ""))
    let target: str = strutil.Strip(os.GetEnvDefault("CHENG_COMPILE_TARGET", "arm64-apple-darwin"))
    let label: str = os.GetEnvDefault("CHENG_COMPILE_LABEL", " compile-exe")
    let logPath: str = os.GetEnvDefault("CHENG_COMPILE_LOG", outBin + ".compile.log")
    let reportPath: str = strutil.Strip(os.GetEnvDefault("CHENG_COMPILE_REPORT", ""))
    if len(src) <= 0 || !os.FileExists(src):
        GatePrintErr(" compile-exe: missing source: " + src)
        return 1
    if len(outBin) <= 0:
        GatePrintErr(" compile-exe: missing out path")
        return 1
    var args: str[] = [
        "system-link-exec",
        "--root", packageRoot,
        "--in", src,
        "--emit", "exe",
        "--target", target,
        "--out", outBin
    ]
    if len(reportPath) > 0:
        add(args, "--report-out")
        add(args, chengpath.PathAbsolute(root, reportPath))
    let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                           label,
                                                           compiler,
                                                           args,
                                                           [],
                                                           root,
                                                           int32(strutil.ParseInt(
                                                               os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC",
                                                                                "300"))),
                                                           logPath)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateBuildLinuxNolibcExe(root: str): int32 =
    let targetRaw: str = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_TARGET", "aarch64-unknown-linux-gnu"))
    let sourcePath: str = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_SOURCE", ""))
    let outBin: str = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_OUT", ""))
    if len(sourcePath) <= 0:
        GatePrintErr(" linux exe: missing CHENG_LINUX_EXE_SOURCE")
        return 1
    if len(outBin) <= 0:
        GatePrintErr(" linux exe: missing CHENG_LINUX_EXE_OUT")
        return 1
    var target = targetRaw
    if target == "arm64-unknown-linux-gnu":
        target = "aarch64-unknown-linux-gnu"
    if target != "aarch64-unknown-linux-gnu":
        GatePrintErr(" linux exe: unsupported target=" + targetRaw)
        return 1
    let explicitCompiler: str = os.GetEnvDefault("CHENG_LINUX_EXE_COMPILER", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_LINUX_EXE_COMPILER", "", compiler) != 0:
        return 1
    let packageRoot: str = root
    let reportPath: str = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_REPORT", ""))
    var args: str[] = [
        "system-link-exec",
        "--root", packageRoot,
        "--in", chengpath.PathAbsolute(root, sourcePath),
        "--emit", "exe",
        "--target", target,
        "--out", chengpath.PathAbsolute(root, outBin)
    ]
    if len(reportPath) > 0:
        add(args, "--report-out")
        add(args, chengpath.PathAbsolute(root, reportPath))
    let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                           " linux exe",
                                                           compiler,
                                                           args,
                                                           [],
                                                           root,
                                                           int32(strutil.ParseInt(
                                                               os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC",
                                                                                "300"))),
                                                           chengpath.PathAbsolute(root, outBin) + ".compile.log")
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateBuildBftStateMachine(root: str): int32 =
    var compiler = ""
    if GateResolveSmokeCompiler(root, "", "CHENG_BFT_COMPILER", "", compiler) != 0:
        return 1
    let target: str = os.GetEnvDefault("BFT_STATE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = chengpath.PathAbsolute(root, "artifacts/bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("BFT_STATE_OUT_DIR", defaultOutDir)
    let src: str = chengpath.PathAbsolute(root, "src/apps/bft/bft_state_machine_main.cheng")
    let outBin: str = os.GetEnvDefault("BFT_STATE_OUT_BIN", os.JoinPath(outDir, "bft_state_machine"))
    var runSelfTestDefault = "0"
    if target == GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest: str = os.GetEnvDefault("BFT_STATE_RUN_SELF_TEST", runSelfTestDefault)
    let runLog = os.JoinPath(outDir, "bft_state_machine.self-test.log")
    if GateBftBuildReady(root, compiler, src, outBin, runLog, runSelfTest):
        if runSelfTest != "0":
            let cached = chengpath.ReadTextFile("", runLog)
            if len(cached) > 0:
                GatePrintLine(strutil.Strip(cached))
            else:
                GatePrintLine(" bft_state_machine self-test ok")
        else:
            GatePrintLine(" bft_state_machine: build ok target=" + target + " out=" + outBin)
        return 0
    let compileRun = GateCompileExe(root,
                                      "build_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "bft_state_machine.compile.log"))
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if runSelfTest != "0":
        let run = GateRunBinary(root,
                                  "build_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  60,
                                  runLog)
        GateMaybePrintRunOutput(run)
        if GateRunFailed(run):
            return run.exitCode
    else:
        GatePrintLine(" bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn GateOracleBftPairText(): str =
    return "BTC/USD"

fn GateOracleBftQueryNowRound(): int64 =
    return int64(22)

fn GateOracleBftTwapWindowRounds(): int32 =
    return 3

fn GateOracleBftExpectedRound(): int64 =
    return int64(22)

fn GateOracleBftPairId(): int32 =
    return oracle_fixture.oracleSmokePairId(oracle_types.OracleAssetBtc, oracle_types.OracleQuoteUsd)

fn GateOracleBftExpectedLatestPrice(): int64 =
    let pairIndex = oracle_types.OraclePairIndex(GateOracleBftPairId())
    return oracle_fixture.oracleSmokePrice(GateOracleBftExpectedRound(), pairIndex, 3)

fn GateOracleBftExpectedTwapPrice(): int64 =
    let pairIndex = oracle_types.OraclePairIndex(GateOracleBftPairId())
    return (oracle_fixture.oracleSmokePrice(int64(20), pairIndex, 3) +
            oracle_fixture.oracleSmokePrice(int64(21), pairIndex, 3) +
            oracle_fixture.oracleSmokePrice(int64(22), pairIndex, 3)) / int64(3)

fn GateOracleBftThreeNodeConfig(root: str): OracleBftThreeNodeDeploy =
    var deployRel = ""
    var remoteDeployRel = ""
    var out: OracleBftThreeNodeDeploy
    deployRel = os.GetEnvDefault("CHENG_ORACLE_BFT_DEPLOY_DIR", "artifacts/oracle_bft_deploy")
    remoteDeployRel = os.GetEnvDefault("CHENG_ORACLE_BFT_REMOTE_DEPLOY_REL", "artifacts/oracle_bft_deploy")
    out.appId = os.GetEnvDefault("CHENG_ORACLE_BFT_APP_ID", "cheng-oracle-live-20260419")
    out.serverSsh = os.GetEnvDefault("CHENG_ORACLE_BFT_SERVER_SSH", "root@64.176.84.12")
    out.relaySsh = os.GetEnvDefault("CHENG_ORACLE_BFT_RELAY_SSH", "dmit")
    out.serverRepoRoot = os.GetEnvDefault("CHENG_ORACLE_BFT_SERVER_ROOT", "/root/cheng-lang-deploy")
    out.relayRepoRoot = os.GetEnvDefault("CHENG_ORACLE_BFT_RELAY_ROOT", "/root/cheng-lang-deploy")
    out.localDeployDir = chengpath.PathAbsolute(root, deployRel)
    out.remoteDeployRel = remoteDeployRel
    return out

fn GateOracleBftManifestPath(cfg: OracleBftThreeNodeDeploy): str =
    return os.JoinPath(cfg.localDeployDir, "deploy.env")

fn GateOracleBftManifestText(cfg: OracleBftThreeNodeDeploy): str =
    var out = ""
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "server_root=" + cfg.serverRepoRoot + "\n"
    out = out + "relay_root=" + cfg.relayRepoRoot + "\n"
    out = out + "local_deploy_dir=" + cfg.localDeployDir + "\n"
    out = out + "remote_deploy_rel=" + cfg.remoteDeployRel + "\n"
    return out

fn GateOracleBftConfigLoad(root: str): OracleBftThreeNodeDeploy =
    var cfg = GateOracleBftThreeNodeConfig(root)
    let manifestPath = GateOracleBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = chengpath.ReadTextFile("", manifestPath)
    let appId = GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverRoot = GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    return cfg

fn GateOracleBftRemoteDeployDir(repoRoot: str, cfg: OracleBftThreeNodeDeploy): str =
    return chengpath.PathAbsolute(repoRoot, cfg.remoteDeployRel)

fn GateOracleBftRemoteBin(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_oracle_bft_state_machine"),
                       os.JoinPath("x86_64-unknown-linux-gnu", "oracle_bft_state_machine"))

fn GateOracleBftLocalBin(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/oracle_bft_state_machine/oracle_bft_state_machine")

fn GateOracleBftRemoteRunLog(repoRoot: str): str =
    let outDir = os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_oracle_bft_state_machine"),
                             "x86_64-unknown-linux-gnu")
    return os.JoinPath(outDir, "oracle_bft_state_machine.self-test.log")

fn GateOracleBftBuildReady(root: str,
                             compiler: str,
                             src: str,
                             outBin: str,
                             runLog: str,
                             runSelfTest: str): bool =
    if !os.FileExists(outBin):
        return false
    var command = "test -x " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    if runSelfTest != "0":
        if !os.FileExists(runLog):
            return false
        command = command +
                  " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
                  " && grep -q " + os.QuoteShell(" oracle_bft_state_machine self-test ok") + " " + os.QuoteShell(runLog)
    return GateShellCheckOk(root, command)

fn GateBuildOracleBftStateMachine(root: str): int32 =
    var compiler = ""
    if GateResolveSmokeCompiler(root, "", "CHENG_ORACLE_BFT_COMPILER", "", compiler) != 0:
        return 1
    let target = os.GetEnvDefault("ORACLE_BFT_STATE_TARGET", "arm64-apple-darwin")
    var defaultOutDir = chengpath.PathAbsolute(root, "artifacts/oracle_bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir = os.GetEnvDefault("ORACLE_BFT_STATE_OUT_DIR", defaultOutDir)
    let src = chengpath.PathAbsolute(root, "src/oracle/oracle_bft_state_machine_main.cheng")
    let outBin = os.GetEnvDefault("ORACLE_BFT_STATE_OUT_BIN", os.JoinPath(outDir, "oracle_bft_state_machine"))
    var runSelfTestDefault = "0"
    if target == GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest = os.GetEnvDefault("ORACLE_BFT_STATE_RUN_SELF_TEST", runSelfTestDefault)
    let runLog = os.JoinPath(outDir, "oracle_bft_state_machine.self-test.log")
    if GateOracleBftBuildReady(root, compiler, src, outBin, runLog, runSelfTest):
        if runSelfTest != "0":
            let cached = chengpath.ReadTextFile("", runLog)
            if len(cached) > 0:
                GatePrintLine(strutil.Strip(cached))
            else:
                GatePrintLine(" oracle_bft_state_machine self-test ok")
        else:
            GatePrintLine(" oracle_bft_state_machine: build ok target=" + target + " out=" + outBin)
        return 0
    let compileRun = GateCompileExe(root,
                                      "build_oracle_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "oracle_bft_state_machine.compile.log"))
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if runSelfTest != "0":
        let run = GateRunBinary(root,
                                  "build_oracle_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  60,
                                  runLog)
        GateMaybePrintRunOutput(run)
        if GateRunFailed(run):
            return run.exitCode
    else:
        GatePrintLine(" oracle_bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn GateOracleBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "src/oracle/oracle_bft_state_machine_main.cheng")
    let outBin = GateOracleBftRemoteBin(repoRoot)
    let runLog = GateOracleBftRemoteRunLog(repoRoot)
    return "test -x " + os.QuoteShell(outBin) +
           " && test -x " + os.QuoteShell(compiler) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
           " && grep -qF " + os.QuoteShell(" oracle_bft_state_machine self-test ok") +
           " " + os.QuoteShell(runLog)

fn GateOracleBftBuildRemote(root: str,
                              sshHost: str,
                              remoteRoot: str,
                              logPath: str): int32 =
    let readyRun = GateRunRemoteShellLogged(root,
                                              "oracle_bft_remote_ready",
                                              sshHost,
                                              "set -eu && " + GateOracleBftRemoteBuildReadyCommand(remoteRoot),
                                              logPath + ".ready.log",
                                              30)
    if !GateRunFailed(readyRun):
        GatePrintLine("[ gate] remote oracle bft reuse " + sshHost)
        return 0
    let stage3FreshRun = GateRunRemoteShellLogged(root,
                                                    "oracle_bft_remote_stage3_fresh",
                                                    sshHost,
                                                    "set -eu && " + GateBftRemoteStage3FreshCommand(remoteRoot),
                                                    logPath + ".stage3.log",
                                                    30)
    if !GateRunFailed(stage3FreshRun):
        let incrementalCommand = GateBftRemoteLockedShell(
            remoteRoot,
            "ORACLE_BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
            " ORACLE_BFT_STATE_RUN_SELF_TEST=1" +
            " artifacts/bootstrap/cheng.stage3 build-oracle-bft-state-machine")
        let incrementalRun = GateRunRemoteShellLogged(root,
                                                        "oracle_bft_remote_build_incremental",
                                                        sshHost,
                                                        incrementalCommand,
                                                        logPath,
                                                        900)
        if GateRunFailed(incrementalRun):
            return incrementalRun.exitCode
        GatePrintLine("[ gate] remote oracle bft incremental " + sshHost)
        return 0
    let fullCommand = GateBftRemoteLockedShell(
        remoteRoot,
        "mkdir -p artifacts/bootstrap" +
        " && cc -std=c11 -O2 -Wall -Wextra -pedantic" +
        " bootstrap/cheng_seed.c -o artifacts/bootstrap/cheng.stage0" +
        " && CHENG_ROOT=" + os.QuoteShell(remoteRoot) +
        " CHENG_TARGET=x86_64-unknown-linux-gnu" +
        " artifacts/bootstrap/cheng.stage0 bootstrap-bridge >/dev/null" +
        " && ORACLE_BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
        " ORACLE_BFT_STATE_RUN_SELF_TEST=1" +
        " artifacts/bootstrap/cheng.stage3 build-oracle-bft-state-machine")
    let run = GateRunRemoteShellLogged(root, "oracle_bft_remote_build", sshHost, fullCommand, logPath, 900)
    if GateRunFailed(run):
        return run.exitCode
    GatePrintLine("[ gate] remote oracle bft rebuild " + sshHost)
    return 0

fn GateOracleBftNodeStatusZero(name: str): OracleBftNodeStatus =
    var out: OracleBftNodeStatus
    out.name = name
    out.summary = ""
    out.latestQuery = ""
    out.twapQuery = ""
    out.height = ""
    out.lastFinalizedRoundId = ""
    out.appHash = ""
    out.latestCode = ""
    out.latestRoundId = ""
    out.latestPriceE8 = ""
    out.twapCode = ""
    out.twapPriceE8 = ""
    return out

fn GateOracleBftCollectLocalNodeStatus(root: str,
                                         nodeName: str,
                                         statePath: str,
                                         logPrefix: str): Result[OracleBftNodeStatus] =
    let binPath = GateOracleBftLocalBin(root)
    let summaryRun = hostops.RunFileLogged(root,
                                             nodeName + "_oracle_show_state",
                                             binPath,
                                             ["show-state", "--state:" + statePath],
                                             [],
                                             root,
                                             20,
                                             logPrefix + ".show.log")
    if !hostops.LoggedRunOk(summaryRun):
        return Err[OracleBftNodeStatus](summaryRun.output)
    let latestRun = hostops.RunFileLogged(root,
                                            nodeName + "_oracle_latest",
                                            binPath,
                                            ["query-latest",
                                             "--state:" + statePath,
                                             "--pair:" + GateOracleBftPairText(),
                                             "--now-round:" + strings.Int64ToStr(GateOracleBftQueryNowRound())],
                                            [],
                                            root,
                                            20,
                                            logPrefix + ".latest.log")
    if !hostops.LoggedRunOk(latestRun):
        return Err[OracleBftNodeStatus](latestRun.output)
    let twapRun = hostops.RunFileLogged(root,
                                          nodeName + "_oracle_twap",
                                          binPath,
                                          ["query-twap",
                                           "--state:" + statePath,
                                           "--pair:" + GateOracleBftPairText(),
                                           "--window-rounds:" + intToStr(GateOracleBftTwapWindowRounds()),
                                           "--now-round:" + strings.Int64ToStr(GateOracleBftQueryNowRound())],
                                          [],
                                          root,
                                          20,
                                          logPrefix + ".twap.log")
    if !hostops.LoggedRunOk(twapRun):
        return Err[OracleBftNodeStatus](twapRun.output)
    return Ok[OracleBftNodeStatus](OracleBftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        latestQuery: latestRun.output,
        twapQuery: twapRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        lastFinalizedRoundId: strutil.Strip(GateTextValue(summaryRun.output, "last_finalized_round_id")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        latestCode: strutil.Strip(GateTextValue(latestRun.output, "code")),
        latestRoundId: strutil.Strip(GateTextValue(latestRun.output, "round_id")),
        latestPriceE8: strutil.Strip(GateTextValue(latestRun.output, "price_e8")),
        twapCode: strutil.Strip(GateTextValue(twapRun.output, "code")),
        twapPriceE8: strutil.Strip(GateTextValue(twapRun.output, "price_e8"))
    ))

