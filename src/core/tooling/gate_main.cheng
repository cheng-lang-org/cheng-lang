fn GateStage23EnvOverrides(): str[] =
    return ["BACKEND_INCREMENTAL=0", "BACKEND_MULTI_MODULE_CACHE=0"]

fn GateHostSmokeCompileEnv(extra: str[]): str[] =
    var out: str[]
    add(out, "BACKEND_INCREMENTAL=0")
    add(out, "BACKEND_MULTI_MODULE_CACHE=0")
    add(out, "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    add(out, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(out, "CHENG_PROGRESS=1")
    add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    for i in 0..<extra.len:
        add(out, extra[i])
    return out

fn GateSmokeRunTimeoutSec(): int32 =
    let timeoutTextRaw: str = os.GetEnv("CHENG_SMOKE_RUN_TIMEOUT_SEC")
    let timeoutText: str = strutil.Strip(timeoutTextRaw)
    if len(timeoutText) > 0:
        return int32(strutil.ParseInt(timeoutText))
    return 60

fn GateSmokeMinTimeoutSecFor(smokeName: str): int32 =
    if smokeName == "build_backend_driver_report_smoke":
        return 900
    if smokeName == "runtime_zero_c_surface_smoke":
        return 180
    if smokeName == "backend_driver_command_surface_smoke":
        return 420
    if smokeName == "backend_driver_selfhost_progress_smoke":
        return 240
    return 60

fn GateSmokeRunTimeoutSecFor(smokeName: str): int32 =
    let minTimeoutSec: int32 = GateSmokeMinTimeoutSecFor(smokeName)
    let requestedTimeoutSec: int32 = GateSmokeRunTimeoutSec()
    if requestedTimeoutSec > minTimeoutSec:
        return requestedTimeoutSec
    return minTimeoutSec

fn GateRunSingleFixtureSmoke(root: str,
                               suiteLabel: str,
                               compilerPath: str,
                               smokeName: str,
                               outBin: str,
                               stageLabel: str,
                               envOverrides: str[]): int32 =
    let src: str = chengpath.PathAbsolute(root, "src/tests/" + smokeName + ".cheng")
    if !os.FileExists(src):
        GatePrintErr(suiteLabel + ": missing source: " + src)
        return 1
    let compileLabel: str = suiteLabel + " compile " + stageLabel + " " + smokeName
    let runLabel: str = suiteLabel + " run " + stageLabel + " " + smokeName
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(outBin + ".map"):
        os.RemoveFile(outBin + ".map")
    if chengpath.PathFileExists(outBin + ".compile.log"):
        os.RemoveFile(outBin + ".compile.log")
    if chengpath.PathFileExists(outBin + ".run.log"):
        os.RemoveFile(outBin + ".run.log")
    let compileRun = GateCompileExeEnv(root,
                                         compileLabel,
                                         compilerPath,
                                         src,
                                         outBin,
                                         "arm64-apple-darwin",
                                         outBin + ".compile.log",
                                         GateHostSmokeCompileEnv(envOverrides))
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = GateRunBinary(root,
                              runLabel,
                              outBin,
                              [],
                              GateSmokeRunTimeoutSecFor(smokeName),
                              outBin + ".run.log")
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateRunTcpTwoprocSmoke(root: str,
                            compilerPath: str,
                            stageName: str,
                            envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/tcp_twoproc")
    let serverSrc: str = chengpath.PathAbsolute(root, "src/tests/libp2p_tcp_twoproc_server_smoke.cheng")
    let clientSrc: str = chengpath.PathAbsolute(root, "src/tests/libp2p_tcp_twoproc_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "libp2p_tcp_twoproc_server." + stageName)
    let clientBin: str = os.JoinPath(outDir, "libp2p_tcp_twoproc_client." + stageName)
    let readyPath: str = os.JoinPath(outDir, "libp2p_tcp_twoproc_server." + stageName + ".ready")
    let _ = os.RemoveFile(readyPath)
    if !os.FileExists(serverSrc) || !os.FileExists(clientSrc):
        GatePrintErr(" libp2p tcp twoproc: missing source fixture")
        return 1
    let serverCompile = GateCompileExeEnv(root,
                                            " libp2p tcp twoproc compile " + stageName + " server",
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            serverBin + ".compile.log",
                                            envOverrides)
    if GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = GateCompileExeEnv(root,
                                            " libp2p tcp twoproc compile " + stageName + " client",
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            clientBin + ".compile.log",
                                            envOverrides)
    if GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverSpawn = hostops.SpawnFile(root,
                                          " libp2p tcp twoproc server " + stageName,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + readyPath],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var port = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, serverBin + ".run.log", 1)
        GatePrintErr(" libp2p tcp twoproc: invalid ready port: " + port)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let clientRun = GateRunBinary(root,
                                    " libp2p tcp twoproc client " + stageName,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    clientBin + ".run.log")
    if GateRunFailed(clientRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, serverBin + ".run.log")
        GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, serverBin + ".run.log")
    GateMaybePrintRunOutput(serverRun)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    GateMaybePrintRunOutput(clientRun)
    GatePrintLine(" libp2p_tcp_twoproc_smoke ok")
    return 0

fn GateRunQuicTwoprocSmoke(root: str,
                             compilerPath: str,
                             stageName: str,
                             envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/quic_twoproc")
    let serverSrc: str = chengpath.PathAbsolute(root, "src/tests/libp2p_quic_twoproc_server_smoke.cheng")
    let clientSrc: str = chengpath.PathAbsolute(root, "src/tests/libp2p_quic_twoproc_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "libp2p_quic_twoproc_server." + stageName)
    let clientBin: str = os.JoinPath(outDir, "libp2p_quic_twoproc_client." + stageName)
    let readyPath: str = os.JoinPath(outDir, "libp2p_quic_twoproc_server." + stageName + ".ready")
    let _ = os.RemoveFile(readyPath)
    if !os.FileExists(serverSrc) || !os.FileExists(clientSrc):
        GatePrintErr(" libp2p quic twoproc: missing source fixture")
        return 1
    let serverCompile = GateCompileExeEnv(root,
                                            " libp2p quic twoproc compile " + stageName + " server",
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            serverBin + ".compile.log",
                                            envOverrides)
    if GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = GateCompileExeEnv(root,
                                            " libp2p quic twoproc compile " + stageName + " client",
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            clientBin + ".compile.log",
                                            envOverrides)
    if GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverSpawn = hostops.SpawnFile(root,
                                          " libp2p quic twoproc server " + stageName,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + readyPath],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var port = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, serverBin + ".run.log", 1)
        GatePrintErr(" libp2p quic twoproc: invalid ready port: " + port)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let clientRun = GateRunBinary(root,
                                    " libp2p quic twoproc client " + stageName,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    clientBin + ".run.log")
    if GateRunFailed(clientRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, serverBin + ".run.log")
        GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, serverBin + ".run.log")
    GateMaybePrintRunOutput(serverRun)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    GateMaybePrintRunOutput(clientRun)
    GatePrintLine(" libp2p_quic_twoproc_smoke ok")
    return 0

fn GateRunDiLoCoSingleSmoke(root: str,
                              compilerPath: str,
                              stageName: str,
                              packageRoot: str,
                              smokeName: str,
                              envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/diloco")
    let src: str = chengpath.PathAbsolute(root, "src/src/tests/" + smokeName + ".cheng")
    let outBin: str = os.JoinPath(outDir, smokeName + "." + stageName)
    if !os.FileExists(src):
        GatePrintErr(" diloco verify: missing source: " + src)
        return 1
    let compileRun = GateCompileExeEnvAtRoot(root,
                                               " diloco compile " + smokeName + " " + stageName,
                                               compilerPath,
                                               packageRoot,
                                               src,
                                               outBin,
                                               "arm64-apple-darwin",
                                               outBin + ".compile.log",
                                               envOverrides)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    let runRun = GateRunBinary(root,
                                 " diloco run " + smokeName + " " + stageName,
                                 outBin,
                                 [],
                                 GateSmokeRunTimeoutSec(),
                                 outBin + ".run.log")
    GateMaybePrintRunOutput(runRun)
    if GateRunFailed(runRun):
        return runRun.exitCode
    return 0

fn GateRunDiLoCoQuicTwoprocSmoke(root: str,
                                   compilerPath: str,
                                   stageName: str,
                                   packageRoot: str,
                                   envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/diloco")
    let serverSrc: str = chengpath.PathAbsolute(root, "src/src/tests/diloco_quic_twoproc_server_smoke.cheng")
    let clientSrc: str = chengpath.PathAbsolute(root, "src/src/tests/diloco_quic_twoproc_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "diloco_quic_twoproc_server." + stageName)
    let clientBin: str = os.JoinPath(outDir, "diloco_quic_twoproc_client." + stageName)
    let readyPath: str = os.JoinPath(outDir, "diloco_quic_twoproc_server." + stageName + ".ready")
    let _ = os.RemoveFile(readyPath)
    if !os.FileExists(serverSrc) || !os.FileExists(clientSrc):
        GatePrintErr(" diloco quic twoproc: missing source fixture")
        return 1
    let serverCompile = GateCompileExeEnvAtRoot(root,
                                                  " diloco quic twoproc compile " + stageName + " server",
                                                  compilerPath,
                                                  packageRoot,
                                                  serverSrc,
                                                  serverBin,
                                                  "arm64-apple-darwin",
                                                  serverBin + ".compile.log",
                                                  envOverrides)
    if GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = GateCompileExeEnvAtRoot(root,
                                                  " diloco quic twoproc compile " + stageName + " client",
                                                  compilerPath,
                                                  packageRoot,
                                                  clientSrc,
                                                  clientBin,
                                                  "arm64-apple-darwin",
                                                  clientBin + ".compile.log",
                                                  envOverrides)
    if GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverSpawn = hostops.SpawnFile(root,
                                          " diloco quic twoproc server " + stageName,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + readyPath],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var port = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, serverBin + ".run.log", 1)
        GatePrintErr(" diloco quic twoproc: invalid ready port: " + port)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let clientRun = GateRunBinary(root,
                                    " diloco quic twoproc client " + stageName,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    clientBin + ".run.log")
    if GateRunFailed(clientRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, serverBin + ".run.log")
        GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, serverBin + ".run.log")
    GateMaybePrintRunOutput(serverRun)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    GateMaybePrintRunOutput(clientRun)
    GatePrintLine(" diloco_quic_twoproc_smoke ok (" + stageName + ")")
    return 0

fn GateVerifyDiLoCoStage(root: str,
                           compilerPath: str,
                           stageName: str,
                           packageRoot: str,
                           envOverrides: str[]): int32 =
    GatePrintLine(" verify-diloco stage begin (" + stageName + ")")
    let singleSmokes = ["diloco_state_smoke", "diloco_wire_smoke"]
    for i in 0..<singleSmokes.len:
        let smokeName = singleSmokes[i]
        if GateRunDiLoCoSingleSmoke(root,
                                      compilerPath,
                                      stageName,
                                      packageRoot,
                                      smokeName,
                                      envOverrides) != 0:
            return 1
    if GateRunDiLoCoQuicTwoprocSmoke(root,
                                       compilerPath,
                                       stageName,
                                       packageRoot,
                                       envOverrides) != 0:
        return 1
    GatePrintLine(" verify-diloco stage ok (" + stageName + ")")
    return 0

fn GateVerifyDiLoCo(root: str): int32 =
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let packageRoot: str = chengpath.PathAbsolute(root, "src")
    if !os.FileExists(os.JoinPath(packageRoot, "cheng-package.toml")):
        GatePrintErr(" diloco verify: missing package root: " + packageRoot)
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/diloco")
    if !chengpath.MkdirP(root, outDir):
        GatePrintErr(" diloco verify: failed to create out dir")
        return 1
    let stage2: str = contracts.BootstrapStage2Path(root)
    let stage3: str = contracts.BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        GatePrintErr(" diloco verify: missing bootstrap compiler")
        return 1
    if GateVerifyDiLoCoStage(root, stage3, "host", packageRoot, []) != 0:
        return 1
    let stage23Env: str[] = GateStage23EnvOverrides()
    if GateVerifyDiLoCoStage(root, stage2, "stage2", packageRoot, stage23Env) != 0:
        return 1
    if GateVerifyDiLoCoStage(root, stage3, "stage3", packageRoot, stage23Env) != 0:
        return 1
    GatePrintLine(" verify-diloco ok")
    return 0

fn GateRequireWasmAudit(label: str,
                          wasmPath: str,
                          expectedExports: str[],
                          expectedImports: str[],
                          minExportCount: int32): bool =
    let infoRes = wasmaudit.WasmBinaryInspect(wasmPath)
    if IsErr(infoRes):
        GatePrintErr(label + ": " + Error(infoRes))
        return false
    let info = Value(infoRes)
    if info.exportNames.len < minExportCount:
        GatePrintErr(label + ": wasm export count too small: " + strings.IntToStr(info.exportNames.len))
        return false
    for i in 0..<expectedExports.len:
        if !wasmaudit.WasmBinaryHasExport(info, expectedExports[i]):
            GatePrintErr(label + ": missing wasm export: " + expectedExports[i])
            return false
    for i in 0..<expectedImports.len:
        if !wasmaudit.WasmBinaryHasImport(info, expectedImports[i]):
            GatePrintErr(label + ": missing wasm import: " + expectedImports[i])
            return false
    return true

fn GateRunWasmSmokes(root: str,
                       compilerPath: str,
                       label: str,
                       envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/wasm_smokes")
    let names: str[] = [
        "wasm_zero_smoke",
        "wasm_internal_call_smoke",
        "wasm_importc_noarg_i32_smoke",
        "wasm_shadowed_local_scope_smoke",
        "wasm_composite_field_smoke"
    ]
    var jobs: hostops.ParallelJob[]
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let src: str = chengpath.PathAbsolute(root, "src/tests/" + smokeName + ".cheng")
        let outWasm: str = os.JoinPath(outDir, smokeName + "." + label + ".wasm")
        let spawnRes = GateCompileExeSpawnEnv(root,
                                                " wasm smokes compile " + smokeName + " " + label,
                                                compilerPath,
                                                src,
                                                outWasm,
                                                "wasm32-unknown-unknown",
                                                os.JoinPath(outDir, smokeName + "." + label + ".compile.log"),
                                                envOverrides)
        if IsErr(spawnRes):
            GatePrintErr(Error(spawnRes))
            hostops.ParallelStopAll(root, jobs, 124)
            return 1
        add(jobs, Value(spawnRes))
    var failedRun = hostops.LoggedRunZero("", "", "", 0, "")
    if !hostops.ParallelWaitFailfast(root,
                                       jobs,
                                       int32(strutil.ParseInt(
                                           os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC",
                                                            "300"))),
                                       failedRun):
        if GateRunFailed(failedRun):
            return failedRun.exitCode
        return 1
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let outWasm: str = os.JoinPath(outDir, smokeName + "." + label + ".wasm")
        if !os.FileExists(outWasm):
            GatePrintErr(" wasm smokes: missing wasm output: " + outWasm)
            return 1
    var expectedExports: str[]
    add(expectedExports, "main")
    if !GateRequireWasmAudit(" wasm audit zero",
                               os.JoinPath(outDir, "wasm_zero_smoke." + label + ".wasm"),
                               expectedExports,
                               [],
                               1):
        return 1
    if !GateRequireWasmAudit(" wasm audit internal",
                               os.JoinPath(outDir, "wasm_internal_call_smoke." + label + ".wasm"),
                               expectedExports,
                               [],
                               1):
        return 1
    if !GateRequireWasmAudit(" wasm audit importc",
                               os.JoinPath(outDir, "wasm_importc_noarg_i32_smoke." + label + ".wasm"),
                               expectedExports,
                               ["env.cheng_test_zero"],
                               1):
        return 1
    if !GateRequireWasmAudit(" wasm audit shadowed",
                               os.JoinPath(outDir, "wasm_shadowed_local_scope_smoke." + label + ".wasm"),
                               expectedExports,
                               [],
                               1):
        return 1
    var compositeExports: str[]
    add(compositeExports, "main")
    add(compositeExports, "bytesLen")
    add(compositeExports, "textLen")
    add(compositeExports, "seqLen")
    add(compositeExports, "resultOk")
    add(compositeExports, "resultValue")
    add(compositeExports, "echoBytes")
    add(compositeExports, "echoText")
    add(compositeExports, "echoSeq")
    add(compositeExports, "echoResult")
    if !GateRequireWasmAudit(" wasm audit composite",
                               os.JoinPath(outDir, "wasm_composite_field_smoke." + label + ".wasm"),
                               compositeExports,
                               [],
                               compositeExports.len):
        return 1
    let hostTarget = GateHostTarget(root)
    if len(hostTarget) <= 0:
        GatePrintErr(" wasm smokes: unsupported host target")
        return 1
    for i in 0..<names.len:
        let smokeName: str = names[i]
        if smokeName == "wasm_importc_noarg_i32_smoke":
            GatePrintLine(smokeName + ": ok")
            continue
        var hostSrc: str = chengpath.PathAbsolute(root, "src/tests/" + smokeName + ".cheng")
        let hostBin = os.JoinPath(outDir, smokeName + "." + label + ".host")
        let hostCompile = GateCompileExeEnv(root,
                                              " wasm host compile " + smokeName + " " + label,
                                              compilerPath,
                                              hostSrc,
                                              hostBin,
                                              hostTarget,
                                              os.JoinPath(outDir, smokeName + "." + label + ".host.compile.log"),
                                              envOverrides)
        if GateRunFailed(hostCompile):
            return hostCompile.exitCode
        let run = hostops.RunFileLogged(root,
                                          " wasm host run " + smokeName + " " + label,
                                          hostBin,
                                          [],
                                          [],
                                          root,
                                          0,
                                          os.JoinPath(outDir, smokeName + "." + label + ".host.run.log"))
        if GateRunFailed(run):
            return run.exitCode
        GatePrintLine(smokeName + ": ok")
    GatePrintLine(" wasm smokes: ok")
    return 0

fn GateRunBrowserHostWasmSmoke(root: str,
                                 compilerPath: str,
                                 label: str,
                                 envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/browser_host_wasm")
    let src: str = chengpath.PathAbsolute(root, "src/libp2p/browser/browser_host_wasm_surface_probe.cheng")
    let outWasm: str = os.JoinPath(outDir, "cheng_browser_host_abi." + label + ".wasm")
    let compileRun = GateCompileEmitEnv(root,
                                          " browser host wasm compile " + label,
                                          compilerPath,
                                          src,
                                          "shared",
                                          outWasm,
                                          "wasm32-unknown-unknown",
                                          os.JoinPath(outDir, "cheng_browser_host_abi." + label + ".compile.log"),
                                          envOverrides)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outWasm):
        GatePrintErr(" browser host wasm smoke: missing wasm output: " + outWasm)
        return 1
    var expectedExports: str[]
    add(expectedExports, "main")
    add(expectedExports, "browserNowMs")
    add(expectedExports, "browserEchoI32")
    add(expectedExports, "browserPeerHandle")
    add(expectedExports, "browserDistributedVideoBuild")
    add(expectedExports, "browserDistributedVideoRebuild")
    add(expectedExports, "browserMoqFountainBuild")
    add(expectedExports, "browserMoqFountainBuildBytes")
    add(expectedExports, "browserMoqFountainRebuild")
    add(expectedExports, "browserMoqBuildLongBlobComputedBundleCidLenProbe")
    add(expectedExports, "browserMoqPeerCsvCountProbe")
    var expectedImports: str[]
    add(expectedImports, "env.cheng_browser_now_ms_bridge")
    add(expectedImports, "env.cheng_browser_echo_i32_bridge")
    add(expectedImports, "env.cheng_browser_peer_handle_bridge")
    add(expectedImports, "env.cheng_browser_did_handle_bridge")
    add(expectedImports, "env.cheng_browser_dm_active_count_bridge")
    add(expectedImports, "env.cheng_browser_dm_connect_start_bridge")
    add(expectedImports, "env.cheng_browser_dm_wait_start_bridge")
    add(expectedImports, "env.cheng_browser_dm_send_start_bridge")
    add(expectedImports, "env.cheng_browser_distributed_video_build_bridge")
    add(expectedImports, "env.cheng_browser_distributed_video_rebuild_bridge")
    add(expectedImports, "env.cheng_browser_distributed_video_last_error_handle_bridge")
    add(expectedImports, "env.cheng_browser_input_len_bridge")
    add(expectedImports, "env.cheng_browser_input_copy_bridge")
    add(expectedImports, "env.cheng_browser_buffer_handle_from_raw_bridge")
    add(expectedImports, "env.cheng_browser_buffer_handle_from_text_bridge")
    add(expectedImports, "env.cheng_browser_buffer_handle_len_bridge")
    add(expectedImports, "env.cheng_browser_buffer_handle_byte_bridge")
    add(expectedImports, "env.cheng_browser_buffer_handle_release_bridge")
    add(expectedImports, "env.cheng_browser_moq_fountain_last_error_store_bridge")
    add(expectedImports, "env.cheng_browser_moq_fountain_last_error_handle_bridge")
    if !GateRequireWasmAudit(" browser host wasm audit",
                               outWasm,
                               expectedExports,
                               expectedImports,
                               expectedExports.len):
        return 1
    let hostTarget = GateHostTarget(root)
    if len(hostTarget) <= 0:
        GatePrintErr(" browser host wasm smoke: unsupported host target")
        return 1
    let hostSrc = chengpath.PathAbsolute(root, "src/tests/browser_host_native_runtime_smoke.cheng")
    let hostBin = os.JoinPath(outDir, "browser_host_native_runtime_smoke." + label)
    let hostCompile = GateCompileExeEnv(root,
                                          " browser host native compile " + label,
                                          compilerPath,
                                          hostSrc,
                                          hostBin,
                                          hostTarget,
                                          os.JoinPath(outDir, "browser_host_native_runtime_smoke." + label + ".compile.log"),
                                          envOverrides)
    if GateRunFailed(hostCompile):
        return hostCompile.exitCode
    let run = hostops.RunFileLogged(root,
                                      " browser host wasm smoke run " + label,
                                      hostBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      os.JoinPath(outDir, "browser_host_wasm." + label + ".run.log"))
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    if !GateRequireOutput(run, " browser host wasm smoke: ok", " browser host wasm smoke"):
        return 1
    return 0

fn GateRunUdpImportcSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_SMOKE_COMPILER", "", compiler) != 0:
        return 1
    let label: str = GateResolveSmokeLabel(args, "CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/udp_importc")
    let src: str = chengpath.PathAbsolute(root, "src/tests/udp_importc_smoke.cheng")
    let bin: str = os.JoinPath(outDir, "udp_importc_smoke." + label)
    let compileRun = GateCompileExeEnv(root,
                                         " udp importc compile " + label,
                                         compiler,
                                         src,
                                         bin,
                                         "arm64-apple-darwin",
                                         os.JoinPath(outDir, "udp_importc_smoke." + label + ".compile.log"),
                                         [])
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = GateRunBinary(root,
                              " udp importc run " + label,
                              bin,
                              [],
                              20,
                              os.JoinPath(outDir, "udp_importc_smoke." + label + ".run.log"))
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    if !GateRequireOutput(run, " udp_importc_smoke ok", " udp importc smoke"):
        return 1
    return 0

fn GateBuildChainNodeBinary(root: str,
                              compilerPath: str,
                              outDir: str,
                              label: str,
                              envOverrides: str[],
                              outBin: var str): int32 =
    let src: str = chengpath.PathAbsolute(root, "src/apps/chain_node/cheng_node_main.cheng")
    outBin = os.JoinPath(outDir, "cheng_node_main")
    let compileRun = GateCompileExeEnv(root,
                                         label,
                                         compilerPath,
                                         src,
                                         outBin,
                                         "arm64-apple-darwin",
                                         os.JoinPath(outDir, "cheng_node_main.compile.log"),
                                         envOverrides)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin):
        GatePrintErr(" chain_node cli smoke: missing cheng_node_main binary: " + outBin)
        return 1
    return 0

fn GateChainNodeRequireTextValue(text: str,
                                   key: str,
                                   expected: str,
                                   context: str): bool =
    let actual: str = strutil.Strip(GateTextValue(text, key))
    if actual == expected:
        return true
    GatePrintErr(context + ": expected " + key + "=" + expected + ", got " + actual)
    return false

fn GateChainNodeRequireRunValue(run: hostops.LoggedRun,
                                  key: str,
                                  expected: str,
                                  context: str): bool =
    return GateChainNodeRequireTextValue(run.output, key, expected, context)

fn GateChainNodeRequireMatchingRunValue(leftRun: hostops.LoggedRun,
                                          rightRun: hostops.LoggedRun,
                                          key: str,
                                          context: str): bool =
    let leftValue: str = strutil.Strip(GateTextValue(leftRun.output, key))
    let rightValue: str = strutil.Strip(GateTextValue(rightRun.output, key))
    if len(leftValue) > 0:
        if leftValue == rightValue:
            return true
    GatePrintErr(context + ": mismatched " + key + ": left=" + leftValue + " right=" + rightValue)
    return false

fn GateChainNodeRequireStateParity(authorRun: hostops.LoggedRun,
                                     replicaRun: hostops.LoggedRun,
                                     context: str): bool =
    if !GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "event_count", context):
        return false
    if !GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "tip_event_cid", context):
        return false
    if !GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "forest_cid", context):
        return false
    return true

