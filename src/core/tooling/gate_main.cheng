    let reportText: str = chengpath.ReadTextFile("", reportPath)
    if !GateRequireOutput(run, "cheng_crash_raw_v1", " signal-trace") ||
       !GateRequireOutput(run, "reason=signal mode=signal", " signal-trace") ||
       !GateRequireOutput(run, "ordinary_signal_trace_fixture.cheng:", " signal-trace") ||
       !GateOutputContains(reportText, "[cheng] cheng_crash_report_v1") ||
       !GateOutputContains(reportText, "[cheng] reason=signal mode=signal") ||
       !GateOutputContains(reportText, "ordinary_signal_trace_fixture.cheng:"):
        return 1
    GatePrintLine(strutil.Strip(reportText))
    return 0

fn GateVerifyDebugRuntime(root: str): int32 =
    let hostTarget: str = GateHostTarget(root)
    if len(hostTarget) <= 0:
        GatePrintErr(" debug runtime: unsupported host target")
        return 1
    let packageRoot: str = root
    let ordinarySource: str = chengpath.PathAbsolute(root, "src/tests/ordinary_panic_fixture.cheng")
    let toolingSource: str = chengpath.PathAbsolute(root, "src/core/tooling/compiler_main.cheng")
    let ordinaryOutput: str = chengpath.PathAbsolute(root, "artifacts/debug_runtime_verify/provider_plan_ordinary")
    let toolingOutput: str = chengpath.PathAbsolute(root, "artifacts/debug_runtime_verify/provider_plan_tooling")
    var expectedCoreSource: str = chengpath.PathAbsolute(root, "src/core/runtime/core_runtime_provider_linux.cheng")
    if hostTarget == "arm64-apple-darwin":
        expectedCoreSource = chengpath.PathAbsolute(root, "src/core/runtime/core_runtime_provider_darwin.cheng")
    let expectedDebugSource: str = chengpath.PathAbsolute(root, "src/core/runtime/debug_runtime_stub.cheng")
    let expectedProgramSupportSource: str =
        chengpath.PathAbsolute(root, "src/core/runtime/program_support_backend.cheng")
    let expectedProgramSupportHostSource: str =
        chengpath.PathAbsolute(root, "src/core/runtime/program_support_host_runtime.cheng")
    let expectedProgramArgvSource: str =
        chengpath.PathAbsolute(root, "src/core/runtime/compiler_runtime_program_entry_provider.cheng")
    let expectedToolingArgvSource: str =
        chengpath.PathAbsolute(root, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng")
    if !GateVerifyPureChengProviderPlan(root,
                                          packageRoot,
                                          ordinarySource,
                                          ordinaryOutput,
                                          hostTarget,
                                          [
                                              expectedProgramArgvSource,
                                              expectedCoreSource,
                                              expectedDebugSource,
                                              expectedProgramSupportSource,
                                              expectedProgramSupportHostSource
                                          ]):
        return 1
    if !GateVerifyPureChengProviderPlan(root,
                                          packageRoot,
                                          toolingSource,
                                          toolingOutput,
                                          hostTarget,
                                          [
                                              expectedToolingArgvSource,
                                              expectedCoreSource,
                                              expectedDebugSource,
                                              expectedProgramSupportSource,
                                              expectedProgramSupportHostSource
                                          ]):
        return 1
    if GateBuildPanicTrace(root) != 0:
        return 1
    if GateBuildBoundsTrace(root) != 0:
        return 1
    if GateBuildSignalTrace(root) != 0:
        return 1
    GatePrintLine(" debug runtime: ok")
    return 0

fn GateVerifyDebugProfile(root: str): int32 =
    var compiler = ""
    if GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/debug_profile_verify")
    let src: str = chengpath.PathAbsolute(root, "src/tests/ordinary_profile_hotspots_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_profile_hotspots_fixture")
    let report: str = os.JoinPath(outDir, "profile.txt")
    let rawReport: str = os.JoinPath(outDir, "profile.raw.txt")
    let compileLog = "artifacts/debug_profile_verify/ordinary_profile_hotspots_fixture.compile.log"
    let compileRun = GateCompileExe(root,
                                      "verify_debug_profile",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = hostops.RunFileLogged(root,
                                      "verify_debug_profile_run",
                                      outBin,
                                      [],
                                      [
                                          "CHENG_PROFILE_ENABLE=1",
                                          "CHENG_PROFILE_HZ=200",
                                          "CHENG_PROFILE_RAW_OUT=" + rawReport
                                      ],
                                      root,
                                      20,
                                      "artifacts/debug_profile_verify/ordinary_profile_hotspots_fixture.run.log")
    if GateRunFailed(run):
        return run.exitCode
    if !os.FileExists(rawReport):
        GatePrintErr(" debug profile: missing raw report")
        return 1
    let rawReportText: str = chengpath.ReadTextFile("", rawReport)
    if !GateOutputContains(rawReportText, "cheng_profile_raw_v1") ||
       !GateOutputContains(rawReportText, "sample\t0x"):
        GatePrintErr(" debug profile: invalid raw report")
        return 1
    let transformRun = hostops.RunFileLogged(root,
                                               "verify_debug_profile_transform",
                                               compiler,
                                               [
                                                   "profile-report",
                                                   "--in:" + rawReport,
                                                   "--out:" + report
                                               ],
                                               [],
                                               root,
                                               20,
                                               "artifacts/debug_profile_verify/profile-report.run.log")
    if GateRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(report):
        GatePrintErr(" debug profile: missing report")
        return 1
    let reportText: str = chengpath.ReadTextFile("", report)
    if !GateOutputContains(reportText, "cheng_profile_v1") ||
       !GateOutputContains(reportText, "hot_function[0]=") ||
       !GateOutputContains(reportText, "hot_pc[0]=") ||
       !GateOutputContains(reportText, "ordinary_profile_hotspots_fixture.cheng"):
        GatePrintErr(" debug profile: invalid report")
        return 1
    GatePrintLine(strutil.Strip(reportText))
    GatePrintLine(" debug profile: ok")
    return 0

fn GateBuildChainNode(root: str): int32 =
    var compiler = os.GetEnvDefault("CHENG_CHAIN_NODE_COMPILER", "")
    if len(compiler) <= 0:
        if GateEnsureBootstrapBridge(root) != 0:
            return 1
        compiler = contracts.BootstrapStage3Path(root)
    else:
        compiler = chengpath.PathAbsolute(root, compiler)
    let src: str = contracts.BootstrapChainNodeEntrySourcePath(root)
    let target: str = os.GetEnvDefault("CHAIN_NODE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = chengpath.PathAbsolute(root, "artifacts/cheng_node_main")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("CHAIN_NODE_OUT_DIR", defaultOutDir)
    let outBin: str = os.GetEnvDefault("CHAIN_NODE_OUT_BIN", os.JoinPath(outDir, "cheng_node_main"))
    let compileLogPath: str = os.JoinPath(outDir, "cheng_node_main.compile.log")
    let buildStampPath: str = GateChainNodeBuildStampPath(outBin)
    let compileTimeoutText: str = strutil.Strip(os.GetEnvDefault("CHENG_CHAIN_NODE_COMPILE_TIMEOUT_SEC", ""))
    var compileTimeoutSec: int32 = 600
    if len(compileTimeoutText) > 0:
        compileTimeoutSec = int32(strutil.ParseInt(compileTimeoutText))
    if !GateChainNodeFresh(root, compiler, src, outBin, target):
        let compileRun = GateCompileExeEnvWithTimeout(root,
                                                        "build_chain_node",
                                                        compiler,
                                                        src,
                                                        outBin,
                                                        target,
                                                        compileLogPath,
                                                        [],
                                                        compileTimeoutSec)
        if GateRunFailed(compileRun):
            return compileRun.exitCode
        let buildStampText: str = GateChainNodeBuildStampText(src, outBin, target, compiler)
        if !chengpath.WriteTextFile(root, buildStampPath, buildStampText):
            GatePrintErr(" chain_node build: failed to write build stamp: " + buildStampPath)
            return 1
    else:
        GatePrintLine(" chain_node: fresh target=" + target + " out=" + outBin)
    var runSelfTestDefault = "0"
    if target == "arm64-apple-darwin":
        runSelfTestDefault = "1"
    let runSelfTestText: str = os.GetEnvDefault("CHAIN_NODE_RUN_SELF_TEST", runSelfTestDefault)
    if runSelfTestText != "0":
        let run = GateRunBinary(root,
                                  "build_chain_node_self_test",
                                  outBin,
                                  GateChainSelfTestArgs(),
                                  20,
                                  os.JoinPath(outDir, "cheng_node_main.self-test.log"))
        GateMaybePrintRunOutput(run)
        if GateRunFailed(run):
            return run.exitCode
    else:
        GatePrintLine(" chain_node: build ok target=" + target + " out=" + outBin)
    return 0

fn GateRunChainNodeProcessSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root,
                                  explicitCompiler,
                                  "CHENG_CHAIN_NODE_COMPILER",
                                  "CHENG_SMOKE_COMPILER",
                                  compiler) != 0:
        return 1
    let label: str = GateResolveSmokeLabel(args, "CHENG_CHAIN_NODE_LABEL", "host")
    return GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, [])

fn GateRunChainNodeThreeNodeSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root,
                                  explicitCompiler,
                                  "CHENG_CHAIN_NODE_COMPILER",
                                  "CHENG_SMOKE_COMPILER",
                                  compiler) != 0:
        return 1
    let label: str = GateResolveSmokeLabel(args, "CHENG_CHAIN_NODE_LABEL", "host")
    return GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, [])

fn GateSlice(root: str): int32 =
    GatePrintLine("[ gate] hot-path forbidden scan")
    if GateScanHotpath(root) != 0:
        return 1
    GatePrintLine("[ gate] orphan guard + bootstrap path")
    if GateVerifyOrphanGuard(root) != 0:
        return 1
    GatePrintLine("[ gate] zero-exit ordinary compile")
    if GateBuildZeroExit(root) != 0:
        return 1
    GatePrintLine("[ gate] panic-trace ordinary compile")
    if GateBuildPanicTrace(root) != 0:
        return 1
    GatePrintLine("[ gate] bounds-trace ordinary compile")
    if GateBuildBoundsTrace(root) != 0:
        return 1
    GatePrintLine("[ gate] signal-trace ordinary compile")
    if GateBuildSignalTrace(root) != 0:
        return 1
    GatePrintLine("[ gate] debug tools")
    if GateRunStage3Command(root,
                              "verify_debug_tools",
                              "verify-debug-tools",
                              [],
                              "verify-debug-tools.log",
                              false) != 0:
        return 1
    GatePrintLine("[ gate] debug runtime")
    if GateVerifyDebugRuntime(root) != 0:
        return 1
    GatePrintLine("[ gate] debug profile")
    if GateVerifyDebugProfile(root) != 0:
        return 1
    GatePrintLine("[ gate] call-chain ordinary compile")
    if GateBuildCallChain(root) != 0:
        return 1
    GatePrintLine("[ gate] ffi-handle ordinary compile")
    if GateBuildFfiHandle(root) != 0:
        return 1
    GatePrintLine("[ gate] program-selfhost")
    if GateBuildProgramSelfhost(root) != 0:
        return 1
    if GateVerifyTcpBioLinuxRegression(root) != 0:
        return 1
    GatePrintLine("[ gate] bootstrap subset self-checks")
    if GateRunSmokes(root) != 0:
        return 1
    GatePrintLine("[ gate] host fixed256 sha256 smoke")
    if GateRunHostSmokes(root, ["fixed256_sha256_smoke"]) != 0:
        return 1
    GatePrintLine("[ gate] host default-init literals smoke")
    if GateRunHostSmokes(root, ["default_init_literals_smoke"]) != 0:
        return 1
    GatePrintLine("[ gate] backend_driver command surface")
    if GateRunHostSmokes(root, ["backend_driver_command_surface_smoke"]) != 0:
        return 1
    GatePrintLine("[ gate] cross-target builtin smokes")
    if GateRunStage3Command(root,
                              "run_cross_target_smokes",
                              "run-cross-target-smokes",
                              [],
                              "run-cross-target-smokes.log",
                              false) != 0:
        return 1
    GatePrintLine("[ gate]  host smokes")
    if GateRunHostSmokes(root, []) != 0:
        return 1
    GatePrintLine("[ gate] stage2/stage3 libp2p smokes")
    if GateRunStage23Libp2pSmokes(root, []) != 0:
        return 1
    GatePrintLine("[ gate] remote x86 linux release gate")
    if GateVerifyX86LinuxRemote(root) != 0:
        return 1
    GatePrintLine("[ gate] bft three-node verify")
    if GateVerifyBftValidatorThreeNode(root) != 0:
        return 1
    GatePrintLine("[ gate] ok")
    return 0

fn GateHandlesCommandBase(cmd: str): bool =
    return cmd == "scan-hotpath" ||
           cmd == "bootstrap-bridge" ||
           cmd == "build-backend-driver" ||
           cmd == "run-production-regression" ||
           cmd == "run-smokes" ||
           cmd == "print-bootstrap" ||
           cmd == "support-matrix" ||
           cmd == "print-build-plan" ||
           cmd == "slice-gate" ||
           cmd == "debug-report" ||
           cmd == "print-symbols" ||
           cmd == "print-line-map" ||
           cmd == "print-object" ||
           cmd == "print-elf" ||
           cmd == "print-asm" ||
           cmd == "profile-run" ||
           cmd == "crash-report" ||
           cmd == "verify-orphan-guard" ||
           cmd == "verify-export-visibility" ||
           cmd == "verify-export-visibility-parallel" ||
           cmd == "verify-backend-driver-command-surface" ||
           cmd == "verify-mobile-shell-build-probe" ||
           cmd == "verify-chain-node-resilience" ||
           cmd == "verify-oracle-resilience" ||
           cmd == "verify-oracle-bft-three-node" ||
           cmd == "verify-r2c-react-surface" ||
           cmd == "verify-debug-tools" ||
           cmd == "verify-debug-runtime" ||
           cmd == "verify-debug-profile" ||
           cmd == "verify-diloco" ||
           cmd == "verify-windows-builtin" ||
           cmd == "verify-riscv64-builtin" ||
           cmd == "run-cross-target-smokes" ||
           cmd == "run-host-smokes" ||
           cmd == "run-stage23-libp2p-smokes" ||
           cmd == "compile-exe"

fn GateHandlesCommandBuild(cmd: str): bool =
    return cmd == "build-zero-exit" ||
           cmd == "build-panic-trace" ||
           cmd == "build-bounds-trace" ||
           cmd == "build-signal-trace" ||
           cmd == "build-call-chain" ||
           cmd == "build-ffi-handle" ||
           cmd == "build-bft-state-machine" ||
           cmd == "deploy-bft-validator-three-node" ||
           cmd == "verify-bft-validator-three-node" ||
           cmd == "status-bft-validator-three-node" ||
           cmd == "stop-bft-validator-three-node" ||
           cmd == "bench-bft-validator-three-node" ||
           cmd == "build-oracle-bft-state-machine" ||
           cmd == "deploy-oracle-bft-three-node" ||
           cmd == "status-oracle-bft-three-node" ||
           cmd == "stop-oracle-bft-three-node" ||
           cmd == "build-rwad-bft-state-machine" ||
           cmd == "build-program-selfhost" ||
           cmd == "build-chain-node" ||
           cmd == "build-linux-nolibc-exe" ||
           cmd == "build-chain-node-linux" ||
           cmd == "build-rwad-bft-linux"

fn GateHandlesCommandRuntime(cmd: str): bool =
    return cmd == "run-linux-object-smokes" ||
           cmd == "run-tcp-twoproc-smoke" ||
           cmd == "run-quic-twoproc-smoke" ||
           cmd == "run-udp-importc-smoke" ||
           cmd == "run-wasm-smokes" ||
           cmd == "run-browser-host-wasm-smoke" ||
           cmd == "run-chain-node-cli-smoke" ||
           cmd == "run-chain-node-process-smoke" ||
           cmd == "run-chain-node-three-node-smoke" ||
           cmd == "run-chain-node-resilience-smoke" ||
           cmd == "run-oracle-resilience-smoke" ||
           cmd == "oracle-fixture-query" ||
           cmd == "run-tailnet-control-smoke" ||
           cmd == "run-fresh-node-selfhost-gate" ||
           cmd == "run-migration-gate" ||
           cmd == "run-browser-webrtc-smokes" ||
           cmd == "r2c-react" ||
           cmd == "r2c-react-controller" ||
           cmd == "vpn-gui" ||
           cmd == "vpn-proxy"

fn GateHandlesCommand(cmd: str): bool =
    return GateHandlesCommandBase(cmd) ||
           GateHandlesCommandBuild(cmd) ||
           GateHandlesCommandRuntime(cmd)

fn GateMain(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let count: int32 = cmdline.ParamCount()
    if count <= 0:
        GateUsage()
        return 1
    let root: str = GateRoot()
    let cmd: str = cmdline.ParamStr(1)
    let args: str[] = GateCollectArgsFrom(2, count)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        GateUsage()
        return 0
    if cmd == "scan-hotpath":
        return GateScanHotpath(root)
    if cmd == "bootstrap-bridge":
        return GateBootstrapBridge(root)
    if cmd == "build-backend-driver":
        return GateBuildBackendDriver(root)
    if cmd == "run-production-regression":
        return GateRunProductionRegression(root)
    if cmd == "run-smokes":
        return GateRunSmokes(root)
    if cmd == "print-bootstrap":
        let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
        GatePrintLine(strutil.Strip(contracts.BootstrapSnapshotReport(snapshot)))
        return 0
    if cmd == "support-matrix":
        GatePrintLine(strutil.Strip(smatrix.SupportMatrixReport(root)))
        return 0
    if cmd == "print-build-plan":
        let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanDefault(root)
        GatePrintLine(strutil.Strip(buildplan.BackendBuildPlanReport(plan)))
        return 0
    if cmd == "slice-gate":
        return GateSlice(root)
    if cmd == "debug-report":
        return GateRunStage3Command(root, "debug_report", cmd, args, "debug-report.log", true)
    if cmd == "print-symbols":
        return GateRunStage3Command(root, "print_symbols", cmd, args, "print-symbols.log", true)
    if cmd == "print-line-map":
        return GateRunStage3Command(root, "print_line_map", cmd, args, "print-line-map.log", true)
    if cmd == "print-object":
        return GateRunStage3Command(root, "print_object", cmd, args, "print-object.log", false)
    if cmd == "print-elf":
        return GateRunStage3Command(root, "print_elf", cmd, args, "print-elf.log", false)
    if cmd == "print-asm":
        return GateRunStage3Command(root, "print_asm", cmd, args, "print-asm.log", true)
    if cmd == "profile-run":
        return GateRunStage3Command(root, "profile_run", cmd, args, "profile-run.log", true)
    if cmd == "crash-report":
        return GateRunStage3Command(root, "crash_report", cmd, args, "crash-report.log", false)
    if cmd == "verify-orphan-guard":
        return GateVerifyOrphanGuard(root)
    if cmd == "verify-export-visibility":
        return GateVerifyExportVisibility(root)
    if cmd == "verify-export-visibility-parallel":
        return GateVerifyExportVisibilityParallel(root)
    if cmd == "verify-backend-driver-command-surface":
        return GateRunHostSmokes(root, ["backend_driver_command_surface_smoke"])
    if cmd == "verify-mobile-shell-build-probe":
        return GateRunStage3Command(root,
                                      "verify_mobile_shell_build_probe",
                                      cmd,
                                      args,
                                      "verify-mobile-shell-build-probe.log",
                                      false)
    if cmd == "verify-chain-node-resilience":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_CHAIN_NODE_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_CHAIN_NODE_LABEL", "host_resilience_gate")
        return GateRunChainNodeResilienceSmoke(root, compiler, label, [])
    if cmd == "verify-oracle-resilience":
        return GateRunStage3Command(root,
                                      "verify_oracle_resilience",
                                      cmd,
                                      args,
                                      "verify-oracle-resilience.log",
                                      true)
    if cmd == "verify-oracle-bft-three-node":
        return GateVerifyOracleBftThreeNode(root)
    if cmd == "verify-r2c-react-surface":
        return GateVerifyR2cReactSurface(root)
    if cmd == "verify-debug-tools":
        return GateRunStage3Command(root, "verify_debug_tools", cmd, args, "verify-debug-tools.log", false)
    if cmd == "verify-debug-runtime":
        return GateVerifyDebugRuntime(root)
    if cmd == "verify-debug-profile":
        return GateVerifyDebugProfile(root)
    if cmd == "verify-diloco":
        return GateVerifyDiLoCo(root)
    if cmd == "verify-windows-builtin":
        return GateRunStage3Command(root, "verify_windows_builtin", cmd, args, "verify-windows-builtin.log", false)
    if cmd == "verify-riscv64-builtin":
        return GateRunStage3Command(root, "verify_riscv64_builtin", cmd, args, "verify-riscv64-builtin.log", false)
    if cmd == "run-cross-target-smokes":
        return GateRunStage3Command(root, "run_cross_target_smokes", cmd, args, "run-cross-target-smokes.log", false)
    if cmd == "run-host-smokes":
        return GateRunHostSmokes(root, args)
    if cmd == "run-stage23-libp2p-smokes":
        return GateRunStage23Libp2pSmokes(root, args)
    if cmd == "compile-exe":
        return GateCompileExeFromEnv(root)
    if cmd == "build-zero-exit":
        return GateBuildZeroExit(root)
    if cmd == "build-panic-trace":
        return GateBuildPanicTrace(root)
    if cmd == "build-bounds-trace":
        return GateBuildBoundsTrace(root)
    if cmd == "build-signal-trace":
        return GateBuildSignalTrace(root)
    if cmd == "build-call-chain":
        return GateBuildCallChain(root)
    if cmd == "build-ffi-handle":
        return GateBuildFfiHandle(root)
    if cmd == "build-bft-state-machine":
        return GateBuildBftStateMachine(root)
    if cmd == "deploy-bft-validator-three-node":
        return GateDeployBftValidatorThreeNode(root)
    if cmd == "verify-bft-validator-three-node":
        return GateVerifyBftValidatorThreeNode(root)
    if cmd == "status-bft-validator-three-node":
        return GateStatusBftValidatorThreeNode(root)
    if cmd == "stop-bft-validator-three-node":
        return GateStopBftValidatorThreeNode(root)
    if cmd == "bench-bft-validator-three-node":
        return GateBenchBftValidatorThreeNode(root, args)
    if cmd == "build-oracle-bft-state-machine":
        return GateBuildOracleBftStateMachine(root)
    if cmd == "deploy-oracle-bft-three-node":
        return GateDeployOracleBftThreeNode(root)
    if cmd == "status-oracle-bft-three-node":
        return GateStatusOracleBftThreeNode(root)
    if cmd == "stop-oracle-bft-three-node":
        return GateStopOracleBftThreeNode(root)
    if cmd == "build-browser-host-wasm":
        return GateBuildBrowserHostWasm(root, args)
    if cmd == "build-rwad-bft-state-machine":
        return GateBuildRwadBftStateMachine(root)
    if cmd == "build-program-selfhost":
        return GateBuildProgramSelfhost(root)
    if cmd == "build-chain-node":
        return GateBuildChainNode(root)
    if cmd == "build-linux-nolibc-exe":
        return GateBuildLinuxNolibcExe(root)
    if cmd == "build-chain-node-linux":
        return GateRunStage3Command(root,
                                      "build_chain_node_linux",
                                      cmd,
                                      args,
                                      "build_chain_node_linux.log",
                                      false)
    if cmd == "build-rwad-bft-linux":
        return GateRunStage3Command(root, "build_rwad_bft_linux", cmd, args, "build_rwad_bft_linux.log", false)
    if cmd == "run-linux-object-smokes":
        return GateRunStage3Command(root,
                                      "run_linux_object_smokes",
                                      cmd,
                                      args,
                                      "run_linux_object_smokes.log",
                                      false)
    if cmd == "run-tcp-twoproc-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_SMOKE_COMPILER", "", compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_SMOKE_LABEL", "host")
        return GateRunTcpTwoprocSmoke(root, compiler, label, [])
    if cmd == "run-quic-twoproc-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_SMOKE_COMPILER", "", compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_SMOKE_LABEL", "host")
        return GateRunQuicTwoprocSmoke(root, compiler, label, [])
    if cmd == "run-udp-importc-smoke":
        return GateRunUdpImportcSmoke(root, args)
    if cmd == "run-wasm-smokes":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_WASM_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_WASM_LABEL", "host")
        return GateRunWasmSmokes(root, compiler, label, [])
    if cmd == "run-browser-host-wasm-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_WASM_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_WASM_LABEL", "host")
        return GateRunBrowserHostWasmSmoke(root, compiler, label, [])
    if cmd == "run-chain-node-cli-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_CHAIN_NODE_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_CHAIN_NODE_LABEL", "host")
        return GateRunChainNodeCliSmoke(root, compiler, label, [])
    if cmd == "run-chain-node-process-smoke":
        return GateRunChainNodeProcessSmoke(root, args)
    if cmd == "run-chain-node-three-node-smoke":
        return GateRunChainNodeThreeNodeSmoke(root, args)
    if cmd == "run-chain-node-resilience-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_CHAIN_NODE_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_CHAIN_NODE_LABEL", "host")
        return GateRunChainNodeResilienceSmoke(root, compiler, label, [])
    if cmd == "run-oracle-resilience-smoke":
        return GateRunStage3Command(root,
                                      "run_oracle_resilience_smoke",
                                      cmd,
                                      args,
                                      "run-oracle-resilience-smoke.log",
                                      true)
    if cmd == "oracle-fixture-query":
        return GateRunStage3Command(root,
                                      "oracle_fixture_query",
                                      cmd,
                                      args,
                                      "oracle-fixture-query.log",
                                      true)
    if cmd == "run-tailnet-control-smoke":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_TAILNET_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_TAILNET_LABEL", "host")
        return GateRunTailnetControlSmoke(root, compiler, label, [])
    if cmd == "run-fresh-node-selfhost-gate":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_FRESH_NODE_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_FRESH_NODE_LABEL", "host")
        return GateRunFreshNodeSelfhostGate(root, compiler, label, [])
    if cmd == "run-migration-gate":
        let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if GateResolveSmokeCompiler(root,
                                      explicitCompiler,
                                      "CHENG_MIGRATION_COMPILER",
                                      "CHENG_SMOKE_COMPILER",
                                      compiler) != 0:
            return 1
        let label: str = GateResolveSmokeLabel(args, "CHENG_MIGRATION_LABEL", "host")
        return GateRunMigrationGate(root, compiler, label, [])
    if cmd == "run-browser-webrtc-smokes":
        return GateRunBrowserWebrtcSmokes(root, GateCollectPositionals(args), GateStage23EnvOverrides())
    if cmd == "r2c-react":
        return r2c.R2cReactMain(root, args)
    if cmd == "r2c-react-controller":
        return r2c.R2cReactMain(root, args)
    if cmd == "vpn-gui":
        return GateRunStage3Command(root, "vpn-gui", cmd, args, "vpn_gui.log", false)
    if cmd == "vpn-proxy":
        return GateRunStage3Command(root, "vpn-proxy", cmd, args, "vpn_proxy.log", false)
    GateUsage()
    return 1

fn main(argc: int32, argv: str*): int32 =
    return GateMain(argc, argv)
