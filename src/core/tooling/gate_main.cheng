fn GateReadFlag(args: str[], key: str, defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, key + ":"):
            return strings.DropPrefix(arg, key + ":")
        if strutil.StartsWith(arg, key + "="):
            return strings.DropPrefix(arg, key + "=")
    return defaultValue

fn GateCollectArgsFrom(startIndex: int32, count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        add(out, cmdline.ParamStr(i))
    return out

fn GateRunFailed(run: hostops.LoggedRun): bool =
    if hostops.LoggedRunOk(run):
        return false
    GatePrintErr(hostops.LoggedRunSummary(run))
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return true

fn GateTextEndsWith(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn GateProviderSourcesAllPureCheng(paths: str[]): bool =
    if paths.len <= 0:
        return false
    for i in 0..<paths.len:
        if !GateTextEndsWith(paths[i], ".cheng"):
            return false
    return true

fn GateProviderSourcesContain(paths: str[], expected: str): bool =
    for i in 0..<paths.len:
        if paths[i] == expected:
            return true
    return false

fn GateVerifyPureChengProviderPlan(root: str,
                                     packageRoot: str,
                                     sourcePath: str,
                                     outputPath: str,
                                     target: str,
                                     expectedSources: str[]): bool =
    let req = creq.CompilerRequestNew(packageRoot,
                                        sourcePath,
                                        outputPath,
                                        target,
                                        creq.EmitExe,
                                        "")
    let planRes = sexec.BuildSystemLinkExecPlan(root, req)
    if IsErr(planRes):
        GatePrintErr(" pure provider plan: " + Error(planRes))
        return false
    let plan = Value(planRes)
    if !GateProviderSourcesAllPureCheng(plan.objectPlan.providerSourcePaths):
        GatePrintErr(" pure provider plan: non-Cheng provider source detected")
        return false
    for i in 0..<expectedSources.len:
        if !GateProviderSourcesContain(plan.objectPlan.providerSourcePaths, expectedSources[i]):
            GatePrintErr(" pure provider plan: missing provider source: " + expectedSources[i])
            return false
    return true

fn GateMaybePrintRunOutput(run: hostops.LoggedRun) =
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintLine(outputText)

fn GateBootstrapLog(root: str, name: str): str =
    return chengpath.PathAbsolute(root, "artifacts/bootstrap/" + name)

fn GateBootstrapTarget(): str =
    var target = contracts.BootstrapDefaultTarget()
    let envTarget = os.GetEnv("CHENG_TARGET")
    if len(envTarget) > 0:
        target = envTarget
    return target

fn GateBootstrapEnvText(root: str,
                          snapshot: contracts.BootstrapSnapshot): str =
    let outDir = contracts.BootstrapOutDir(root)
    var out = ""
    out = out + "CHENG_ROOT=" + root + "\n"
    out = out + "CHENG_TARGET=" + GateBootstrapTarget() + "\n"
    out = out + "CHENG_BOOTSTRAP_KIND=" + snapshot.bootstrapMode + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1_SOURCE=" + snapshot.stage1Source.path + "\n"
    out = out + "CHENG_COMPILER_ENTRY_SOURCE=" + contracts.BootstrapCompilerEntrySourcePath(root) + "\n"
    out = out + "CHENG_COMPILER_RUNTIME_SOURCE=" + contracts.BootstrapCompilerRuntimeSourcePath(root) + "\n"
    out = out + "CHENG_COMPILER_REQUEST_SOURCE=" + contracts.BootstrapCompilerRequestSourcePath(root) + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_ENV=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "CHENG_BOOTSTRAP_SNAPSHOT=" + contracts.BootstrapSnapshotPath(root) + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1_REPORT=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE2_REPORT=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE3_REPORT=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n"
    return out

fn GateBootstrapSnapshotText(root: str,
                               snapshot: contracts.BootstrapSnapshot): str =
    let outDir = contracts.BootstrapOutDir(root)
    var out = ""
    var freshErr = ""
    let freshInputPaths = contracts.BootstrapFreshInputPathsCsv(root, freshErr)
    out = out + "target=" + GateBootstrapTarget() + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "fresh_input_paths=" + freshInputPaths + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + contracts.BootstrapCompilerEntrySourcePath(root) + "\n"
    out = out + "compiler_runtime_source=" + contracts.BootstrapCompilerRuntimeSourcePath(root) + "\n"
    out = out + "compiler_request_source=" + contracts.BootstrapCompilerRequestSourcePath(root) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "stage1_report=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n"
    out = out + "stage2_report=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n"
    out = out + "stage3_report=" + chengpath.PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n"
    out = out + "stage0_build_log=" + GateBootstrapLog(root, "cheng.stage0.build.log") + "\n"
    out = out + "stage0_self_check_log=" + GateBootstrapLog(root, "cheng.stage0.self-check.log") + "\n"
    out = out + "stage1_build_log=" + GateBootstrapLog(root, "cheng.stage1.compile.log") + "\n"
    out = out + "stage1_self_check_log=" + GateBootstrapLog(root, "cheng.stage1.self-check.log") + "\n"
    out = out + "stage2_build_log=" + GateBootstrapLog(root, "cheng.stage2.compile.log") + "\n"
    out = out + "stage2_self_check_log=" + GateBootstrapLog(root, "cheng.stage2.self-check.log") + "\n"
    out = out + "stage3_build_log=" + GateBootstrapLog(root, "cheng.stage3.compile.log") + "\n"
    out = out + "stage3_self_check_log=" + GateBootstrapLog(root, "cheng.stage3.self-check.log") + "\n"
    out = out + "stage2_contract_log=" + GateBootstrapLog(root, "cheng.stage2.contract.txt") + "\n"
    out = out + "stage3_contract_log=" + GateBootstrapLog(root, "cheng.stage3.contract.txt") + "\n"
    out = out + "fixed_point=stage2_stage3_contract_match\n"
    return out

fn GateBootstrapStageRun(root: str,
                           label: str,
                           binPath: str,
                           args: str[],
                           logPath: str): int32 =
    let run: hostops.LoggedRun = hostops.RunFileLogged(root, label, binPath, args, [], root, 0, logPath)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateBootstrapCompilerPath(root: str,
                               snapshot: contracts.BootstrapSnapshot): str =
    let current: str = hostops.ResolveProgram(root, cmdline.ProgramName())
    if chengpath.FileExistsNonEmpty(root, current):
        return current
    if contracts.BootstrapArtifactReady(snapshot.stage3Compiler):
        return snapshot.stage3Compiler.path
    if contracts.BootstrapArtifactReady(snapshot.stage2Compiler):
        return snapshot.stage2Compiler.path
    if contracts.BootstrapArtifactReady(snapshot.stage1Compiler):
        return snapshot.stage1Compiler.path
    if contracts.BootstrapArtifactReady(snapshot.stage0Compiler):
        return snapshot.stage0Compiler.path
    return ""

fn GateBootstrapMaterializeStage0(root: str,
                                    snapshot: contracts.BootstrapSnapshot,
                                    compilerPath: str): bool =
    if !chengpath.PathNonEmpty(compilerPath):
        return false
    if compilerPath == snapshot.stage0Compiler.path &&
       contracts.BootstrapArtifactReady(snapshot.stage0Compiler):
        let reusedText: str = GateJoin3("stage0_reused_from=", compilerPath, "\n")
        return chengpath.WriteTextFile(root,
                                      "artifacts/bootstrap/cheng.stage0.build.log",
                                      reusedText)
    let copyRun = hostops.RunProgramLogged(root,
                                             "bootstrap_stage0_copy",
                                             "cp",
                                             [compilerPath, snapshot.stage0Compiler.path],
                                             [],
                                             root,
                                             0,
                                             "artifacts/bootstrap/cheng.stage0.materialize.log")
    if GateRunFailed(copyRun):
        return false
    let chmodRun = hostops.RunProgramLogged(root,
                                              "bootstrap_stage0_chmod",
                                              "chmod",
                                              ["755", snapshot.stage0Compiler.path],
                                              [],
                                              root,
                                              0,
                                              "artifacts/bootstrap/cheng.stage0.materialize.log")
    if GateRunFailed(chmodRun):
        return false
    if !contracts.BootstrapArtifactReady(snapshot.stage0Compiler):
        return false
    let materializedText: str = GateJoin3("stage0_materialized_from=", compilerPath, "\n")
    return chengpath.WriteTextFile(root,
                                  "artifacts/bootstrap/cheng.stage0.build.log",
                                  materializedText)

fn GateBootstrapBridge(root: str): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
    let outDir: str = contracts.BootstrapOutDir(root)
    let bootstrapCompiler: str = GateBootstrapCompilerPath(root, snapshot)
    if !chengpath.MkdirP(root, outDir):
        GatePrintErr(" gate: failed to create bootstrap dir")
        return 1
    if !chengpath.PathFileExists(snapshot.stage1Source.path):
        GatePrintErr(" gate: missing stage1 source: " + snapshot.stage1Source.path)
        return 1
    if !chengpath.PathNonEmpty(bootstrapCompiler):
        GatePrintErr(" gate: missing live bootstrap compiler")
        return 1
    if !GateBootstrapMaterializeStage0(root, snapshot, bootstrapCompiler):
        GatePrintErr(" gate: failed to materialize stage0 compiler: " + bootstrapCompiler)
        return 1
    if !contracts.BootstrapArtifactReady(snapshot.stage0Compiler):
        GatePrintErr(" gate: missing stage0 compiler: " + snapshot.stage0Compiler.path)
        return 1
    if GateBootstrapStageRun(root,
                               "stage0_self_check",
                               snapshot.stage0Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage0.self-check.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage1_compile",
                               snapshot.stage0Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage1Compiler.path
                               ],
                               "artifacts/bootstrap/cheng.stage1.compile.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage1_self_check",
                               snapshot.stage1Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage1.self-check.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage2_compile",
                               snapshot.stage1Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage2Compiler.path
                               ],
                               "artifacts/bootstrap/cheng.stage2.compile.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage2_self_check",
                               snapshot.stage2Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage2.self-check.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage3_compile",
                               snapshot.stage2Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage3Compiler.path
                               ],
                               "artifacts/bootstrap/cheng.stage3.compile.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage3_self_check",
                               snapshot.stage3Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage3.self-check.log") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage2_contract",
                               snapshot.stage2Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage2.contract.txt") != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "stage3_contract",
                               snapshot.stage3Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/bootstrap/cheng.stage3.contract.txt") != 0:
        return 1
    let stage2Contract: str = chengpath.ReadTextFile(root, "artifacts/bootstrap/cheng.stage2.contract.txt")
    let stage3Contract: str = chengpath.ReadTextFile(root, "artifacts/bootstrap/cheng.stage3.contract.txt")
    if stage2Contract != stage3Contract:
        GatePrintErr(" gate: fixed point mismatch stage2/stage3 contract drift")
        return 1
    if !chengpath.WriteTextFile(root, snapshot.bootstrapEnv.path, GateBootstrapEnvText(root, snapshot)):
        GatePrintErr(" gate: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
        return 1
    if !chengpath.WriteTextFile(root,
                               contracts.BootstrapSnapshotPath(root),
                               GateBootstrapSnapshotText(root, snapshot)):
        GatePrintErr(" gate: failed to write bootstrap snapshot: " + contracts.BootstrapSnapshotPath(root))
        return 1
    GatePrintLine("bootstrap bridge ok: " + snapshot.stage2Compiler.path)
    return 0

fn GateEnsureBootstrapBridge(root: str): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
    let stage3Mtime: int64 = os.FileMtime(snapshot.stage3Compiler.path)
    if contracts.BootstrapBridgeReady(snapshot) &&
       stage3Mtime > int64(0) &&
       GateBootstrapFreshInputsReady(root, stage3Mtime):
        return 0
    return GateBootstrapBridge(root)

fn GateBootstrapFreshInputsReady(root: str, stage3Mtime: int64): bool =
    var freshInputs: str[]
    if contracts.BootstrapCachedFreshInputPaths(root, freshInputs):
        for i in 0..<freshInputs.len:
            if os.FileMtime(freshInputs[i]) > stage3Mtime:
                return false
        return true
    return os.FileMtime(contracts.BootstrapSeedSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapStage1SourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapCompilerEntrySourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapCompilerRuntimeSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapCompilerSupportMatrixSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapCompilerRequestSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BootstrapGateMainSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BackendPrimaryObjectEmitSourcePath(root)) <= stage3Mtime &&
           os.FileMtime(contracts.BackendSystemLinkExecRuntimeSourcePath(root)) <= stage3Mtime

fn GatePathNewerThan(leftPath: str,
                       rightPath: str): bool =
    if !chengpath.PathFileExists(leftPath) || !chengpath.PathFileExists(rightPath):
        return false
    return os.FileMtime(leftPath) > os.FileMtime(rightPath)

fn GateChainNodeBuildStampPath(outBin: str): str =
    return outBin + ".build.txt"

fn GateChainNodeBuildStampText(sourcePath: str,
                                 outBin: str,
                                 target: str,
                                 compilerPath: str): str =
    var out = "format=cheng_chain_node_build_v1\n"
    out = out + "entry=" + sourcePath + "\n"
    out = out + "output=" + outBin + "\n"
    out = out + "target=" + target + "\n"
    out = out + "compiler=" + compilerPath + "\n"
    return out

fn GateChainNodeFresh(root: str,
                        compilerPath: str,
                        sourcePath: str,
                        outBin: str,
                        target: str): bool =
    if !chengpath.FileExistsNonEmpty(root, outBin):
        return false
    if !chengpath.PathFileExists(outBin + ".map"):
        return false
    let buildStampPath: str = GateChainNodeBuildStampPath(outBin)
    if !chengpath.FileExistsNonEmpty(root, buildStampPath):
        return false
    let buildStampText: str = chengpath.ReadTextFile("", buildStampPath)
    if !chengpath.TextContains(buildStampText, "format=cheng_chain_node_build_v1") ||
       !chengpath.TextContains(buildStampText, "entry=" + sourcePath) ||
       !chengpath.TextContains(buildStampText, "output=" + outBin) ||
       !chengpath.TextContains(buildStampText, "target=" + target) ||
       !chengpath.TextContains(buildStampText, "compiler=" + compilerPath):
        return false
    if len(compilerPath) > 0 && GatePathNewerThan(compilerPath, outBin):
        return false
    var freshInputs: str[]
    var freshErr = ""
    if !contracts.BootstrapChainNodeFreshInputPaths(root, freshInputs, freshErr):
        return false
    var i: int32
    while i < freshInputs.len:
        if GatePathNewerThan(freshInputs[i], outBin):
            return false
        i = i + 1
    return true

fn GateBackendDriverFresh(root: str,
                            backendDriverPath: str): bool =
    if !chengpath.FileExistsNonEmpty(root, backendDriverPath):
        return false
    if !chengpath.PathFileExists(backendDriverPath + ".map"):
        return false
    let freshInputs = [
        contracts.BootstrapStage3Path(root),
        contracts.BootstrapBackendDriverEntrySourcePath(root),
        contracts.BootstrapCompilerRuntimeSourcePath(root),
        contracts.BootstrapCompilerRequestSourcePath(root),
        chengpath.PathAbsolute(root, "src/core/tooling/compiler_world.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/compiler_csg.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/compiler_world_libp2p.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/compiler_equivalence.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/compiler_publish_gate.cheng"),
        chengpath.PathAbsolute(root, "src/core/lang/parser.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/system_link_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/lowering_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/primary_object_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/primary_object_emit.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/object_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/native_link_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/system_link_exec.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/system_link_exec_runtime.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/core_runtime.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/compiler_runtime.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/debug_runtime.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/bootstrap_contracts.cheng"),
        chengpath.PathAbsolute(root, "src/core/backend/build_plan.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/core_runtime_provider_darwin.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/compiler_runtime_program_entry_provider.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/program_support_backend.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/program_support_host_runtime.cheng"),
        chengpath.PathAbsolute(root, "src/core/runtime/debug_runtime_stub.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/host_ops.cheng"),
        chengpath.PathAbsolute(root, "src/core/tooling/path.cheng"),
        chengpath.PathAbsolute(root, "src/std/os_host_process.cheng"),
        chengpath.PathAbsolute(root, "src/std/os.cheng")
    ]
    for i in 0..<freshInputs.len:
        if GatePathNewerThan(freshInputs[i], backendDriverPath):
            return false
    return true

fn GateBuildBackendDriver(root: str): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/backend_driver")
    let packageRoot: str = root
    let compilerEntrySource: str = contracts.BootstrapBackendDriverEntrySourcePath(root)
    let compileReportPath: str = chengpath.PathAbsolute(root, "artifacts/backend_driver/build_backend_driver.compile.report.txt")
    let compileLogPath: str = "artifacts/backend_driver/build_backend_driver.log"
    let compileReceiptLogPath: str = "artifacts/backend_driver/build_backend_driver.compile.receipt.log"
    let statusLogPath: str = "artifacts/backend_driver/build_backend_driver.status.txt"
    let verifyExportLogPath: str = "artifacts/backend_driver/build_backend_driver.verify_export_visibility.txt"
    let verifyExportParallelLogPath: str = "artifacts/backend_driver/build_backend_driver.verify_export_visibility_parallel.txt"
    let planLogPath: str = "artifacts/backend_driver/build_backend_driver.plan.txt"
    let referencePlanLogPath: str = "artifacts/backend_driver/reference_stage3.plan.txt"
    let smokeSource: str = chengpath.PathAbsolute(root, "src/tests/ordinary_zero_exit_fixture.cheng")
    let smokeOut: str = chengpath.PathAbsolute(root, "artifacts/backend_driver/ordinary_zero_exit_fixture.selftest")
    let smokeCompileReportPath: str = smokeOut + ".report.txt"
    let smokeCompileLogPath: str =
        "artifacts/backend_driver/ordinary_zero_exit_fixture.selftest.compile.log"
    let smokeReceiptLogPath: str =
        "artifacts/backend_driver/ordinary_zero_exit_fixture.selftest.receipt.log"
    let smokeRunLogPath: str =
        "artifacts/backend_driver/ordinary_zero_exit_fixture.selftest.run.log"
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    if !chengpath.MkdirP(root, outDir):
        GatePrintErr(" gate: failed to create backend driver dir")
        return 1
    if !contracts.BootstrapArtifactReady(snapshot.stage2Compiler):
        GatePrintErr(" gate: missing stage2 compiler: " + snapshot.stage2Compiler.path)
        return 1
    if !chengpath.PathFileExists(compilerEntrySource):
        GatePrintErr(" gate: missing compiler entry source: " + compilerEntrySource)
        return 1
    if chengpath.PathFileExists(compileReportPath):
        let _ = os.RemoveFile(compileReportPath)
    if GateBootstrapStageRun(root,
                               "build_backend_driver",
                               snapshot.stage2Compiler.path,
                               [
                                   "system-link-exec",
                                   "--root:" + root,
                                   "--in:" + compilerEntrySource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + snapshot.backendDriverOut.path
                               ],
                               compileLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "build_backend_driver_receipt",
                               snapshot.stage2Compiler.path,
                               [
                                   "world-receipt",
                                   "--root:" + root,
                                   "--in:" + compilerEntrySource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + snapshot.backendDriverOut.path,
                                   "--report-out:" + compileReportPath
                               ],
                               compileReceiptLogPath) != 0:
        return 1
    if !chengpath.PathFileExists(compileReportPath):
        GatePrintErr(" gate: missing backend driver compile report: " + compileReportPath)
        return 1
    if !contracts.BootstrapArtifactReady(snapshot.backendDriverOut):
        GatePrintErr(" gate: missing backend driver output: " + snapshot.backendDriverOut.path)
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_status",
                               snapshot.backendDriverOut.path,
                               ["status"],
                               statusLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_verify_export_visibility",
                               snapshot.backendDriverOut.path,
                               ["verify-export-visibility"],
                               verifyExportLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_verify_export_visibility_parallel",
                               snapshot.backendDriverOut.path,
                               ["verify-export-visibility-parallel"],
                               verifyExportParallelLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_plan",
                               snapshot.backendDriverOut.path,
                               ["print-build-plan"],
                               planLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "reference_stage3_plan",
                               snapshot.stage3Compiler.path,
                               ["print-build-plan"],
                               referencePlanLogPath) != 0:
        return 1
    let builtPlan: str = chengpath.ReadTextFile(root, planLogPath)
    let stage3Plan: str = chengpath.ReadTextFile(root, referencePlanLogPath)
    if GateBuildPlanComparableText(builtPlan) != GateBuildPlanComparableText(stage3Plan):
        GatePrintErr(" gate: backend driver build plan drift vs stage3: " + snapshot.backendDriverOut.path)
        return 1
    if chengpath.PathFileExists(smokeCompileReportPath):
        let _ = os.RemoveFile(smokeCompileReportPath)
    if GateBootstrapStageRun(root,
                               "backend_driver_zero_exit_compile",
                               snapshot.backendDriverOut.path,
                               [
                                   "system-link-exec",
                                   "--root:" + packageRoot,
                                   "--in:" + smokeSource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + smokeOut
                               ],
                               smokeCompileLogPath) != 0:
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_zero_exit_receipt",
                               snapshot.backendDriverOut.path,
                               [
                                   "world-receipt",
                                   "--root:" + packageRoot,
                                   "--in:" + smokeSource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + smokeOut,
                                   "--report-out:" + smokeCompileReportPath
                               ],
                               smokeReceiptLogPath) != 0:
        return 1
    if !chengpath.PathFileExists(smokeCompileReportPath):
        GatePrintErr(" gate: missing backend driver zero-exit receipt report: " + smokeCompileReportPath)
        return 1
    if !chengpath.PathFileExists(smokeOut) || !chengpath.PathFileExists(smokeOut + ".map"):
        GatePrintErr(" gate: backend driver zero-exit smoke missing output: " + smokeOut)
        return 1
    if GateBootstrapStageRun(root,
                               "backend_driver_zero_exit_run",
                               smokeOut,
                               [],
                               smokeRunLogPath) != 0:
        return 1
    if chengpath.ReadTextFile(root, smokeRunLogPath) != "":
        GatePrintErr(" gate: backend driver zero-exit smoke expected empty stdout: " + smokeRunLogPath)
        return 1
    var report = ""
    report = report + "target=" + GateBootstrapTarget() + "\n"
    report = report + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    report = report + "compiler_class=ordinary_compiler\n"
    report = report + "stage0_compiler=" + snapshot.stage0Compiler.path + "\n"
    report = report + "stage1_compiler=" + snapshot.stage1Compiler.path + "\n"
    report = report + "stage2_compiler=" + snapshot.stage2Compiler.path + "\n"
    report = report + "stage3_compiler=" + snapshot.stage3Compiler.path + "\n"
    report = report + "bootstrap_contract_source=" + snapshot.stage1Source.path + "\n"
    report = report + "planned_entry_source=" + compilerEntrySource + "\n"
    report = report + "planned_runtime_source=" + contracts.BootstrapCompilerRuntimeSourcePath(root) + "\n"
    report = report + "planned_request_source=" + contracts.BootstrapCompilerRequestSourcePath(root) + "\n"
    report = report + "materialized_source=" + compilerEntrySource + "\n"
    report = report + "output=" + snapshot.backendDriverOut.path + "\n"
    report = report + "status_log=" + chengpath.PathAbsolute(root, statusLogPath) + "\n"
    report = report + "verify_export_visibility_log=" + chengpath.PathAbsolute(root, verifyExportLogPath) + "\n"
    report = report + "plan_log=" + chengpath.PathAbsolute(root, planLogPath) + "\n"
    report = report + "reference_plan_log=" + chengpath.PathAbsolute(root, referencePlanLogPath) + "\n"
    report = report + "log=" + chengpath.PathAbsolute(root, compileLogPath) + "\n"
    report = report + "zero_exit_smoke_source=" + smokeSource + "\n"
    report = report + "zero_exit_smoke_output=" + smokeOut + "\n"
    report = report + "zero_exit_smoke_report=" + smokeCompileReportPath + "\n"
    report = report + "zero_exit_smoke_compile_log=" + chengpath.PathAbsolute(root, smokeCompileLogPath) + "\n"
    report = report + "zero_exit_smoke_run_log=" + chengpath.PathAbsolute(root, smokeRunLogPath) + "\n"
    if !chengpath.WriteTextFile(root,
                               "artifacts/backend_driver/build_backend_driver.report.txt",
                               report):
        GatePrintErr(" gate: failed to write backend driver report")
        return 1
    GatePrintLine("backend driver ok: " + snapshot.backendDriverOut.path)
    return 0

fn GateScanHotpath(root: str): int32 =
    let hits: hotscan.ForbiddenHit[] = hotscan.ScanForbiddenSourceDir(root, "src")
    let report: str = hotscan.ForbiddenHitReport(hits)
    GatePrintLine(strutil.Strip(report))
    if hotscan.ForbiddenHitsOk(hits):
        return 0
    return 1

fn GateArgsContainFlag(args: str[], key: str): bool =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key:
            return true
        if strutil.StartsWith(arg, key + ":"):
            return true
        if strutil.StartsWith(arg, key + "="):
            return true
    return false

fn GateRunStage3Command(root: str,
                          label: str,
                          cmd: str,
                          args: str[],
                          logName: str,
                          injectContract: bool): int32 =
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage3: str = contracts.BootstrapStage3Path(root)
    if !os.FileExists(stage3):
        GatePrintErr(" gate: missing stage3 compiler: " + stage3)
        return 1
    var stageArgs: str[]
    add(stageArgs, cmd)
    if injectContract && !GateArgsContainFlag(args, "--contract-in"):
        add(stageArgs, "--contract-in:" + contracts.BootstrapStage1SourcePath(root))
    for i in 0..<args.len:
        add(stageArgs, args[i])
    let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                           label,
                                                           stage3,
                                                           stageArgs,
                                                           [],
                                                           root,
                                                           0,
                                                           "artifacts/gate/" + logName)
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateRunStage3CommandWithEnv(root: str,
                                 label: str,
                                 cmd: str,
                                 args: str[],
                                 logName: str,
                                 injectContract: bool,
                                 envOverrides: str[]): int32 =
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage3: str = contracts.BootstrapStage3Path(root)
    if !os.FileExists(stage3):
        GatePrintErr(" gate: missing stage3 compiler: " + stage3)
        return 1
    var stageArgs: str[]
    add(stageArgs, cmd)
    if injectContract && !GateArgsContainFlag(args, "--contract-in"):
        add(stageArgs, "--contract-in:" + contracts.BootstrapStage1SourcePath(root))
    for i in 0..<args.len:
        add(stageArgs, args[i])
    let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                           label,
                                                           stage3,
                                                           stageArgs,
                                                           envOverrides,
                                                           root,
                                                           0,
                                                           "artifacts/gate/" + logName)
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateRunSmokes(root: str): int32 =
    if !GateEnsureArtifactsDir(root):
        GatePrintErr(" gate: failed to create artifacts dir")
        return 1
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage1Source: str = contracts.BootstrapStage1SourcePath(root)
    var bins: str[]
    add(bins, contracts.BootstrapStage0Path(root))
    add(bins, contracts.BootstrapStage1Path(root))
    add(bins, contracts.BootstrapStage2Path(root))
    add(bins, contracts.BootstrapStage3Path(root))
    for i in 0..<bins.len:
        let binPath: str = bins[i]
        if !os.FileExists(binPath):
            GatePrintErr(" gate: missing bootstrap compiler: " + binPath)
            return 1
        let binParts: os.SplitFileResult = os.SplitFile(binPath)
        let logRelPath: str = GateJoin3("artifacts/gate/", binParts.name, ".self-check.log")
        let logPath: str = chengpath.PathAbsolute(root, logRelPath)
        var args: str[]
        add(args, "self-check")
        add(args, "--in:" + stage1Source)
        let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                               binParts.name,
                                                               binPath,
                                                               args,
                                                               [],
                                                               root,
                                                               0,
                                                               logPath)
        let outputText = strutil.Strip(run.output)
        if len(outputText) > 0:
            GatePrintLine(outputText)
        if !hostops.LoggedRunOk(run):
            GatePrintErr(hostops.LoggedRunSummary(run))
            return run.exitCode
    return 0

fn GateRunProductionRegression(root: str): int32 =
    GatePrintLine("[ gate] production regression: build-backend-driver")
    if GateBuildBackendDriver(root) != 0:
        return 1
    GatePrintLine("[ gate] production regression: command-surface/perf/skill smokes")
    if GateRunHostSmokes(root,
                           [
                               "stage3_command_surface_smoke",
                               "backend_driver_command_surface_smoke",
                               "build_backend_driver_report_smoke",
                               "perf_memory_gate_contract_smoke",
                               "perf_memory_contract_smoke",
                               "cheng_skill_consistency_smoke",
                               "explicit_default_init_positive_smoke",
                               "explicit_default_init_negative_smoke",
                               "explicit_default_init_gate_smoke",
                               "composite_zero_helper_gate_smoke",
                               "latest_snapshot_port_preserves_live_str_smoke",
                               "list_literal_nested_call_depth_smoke",
                               "libp2p_quic_twoproc_server_pre_quic_smoke"
                           ]) != 0:
        return 1
    GatePrintLine("[ gate] production regression: r2c-react surface")
    if GateVerifyR2cReactSurface(root) != 0:
        return 1
    GatePrintLine("[ gate] production regression: cross-target smokes")
    if GateRunStage3Command(root,
                              "run_production_regression_cross_target",
                              "run-cross-target-smokes",
                              [],
                              "run-production-regression.cross-target.log",
                              false) != 0:
        return 1
    GatePrintLine("[ gate] production regression: stage2/stage3 libp2p smokes")
    if GateRunStage23Libp2pSmokes(root, []) != 0:
        return 1
    GatePrintLine("[ gate] production regression: ok")
    return 0

fn GateVerifyTcpBioLinuxRegression(root: str): int32 =
    GatePrintLine("[ gate] tcp/bio/linux early regression: bio_same_person_smoke")
    if GateRunHostSmokes(root, ["bio_same_person_smoke"]) != 0:
        return 1
    return 0

fn GateEnsureBackendDriverReady(root: str, outCompiler: var str): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
    outCompiler = snapshot.backendDriverOut.path
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    if GateBackendDriverFresh(root, snapshot.backendDriverOut.path):
        return 0
    return GateBuildBackendDriver(root)

fn GateVerifyR2cReactSurface(root: str): int32 =
    var smokes: str[]
    if os.GetEnv("R2C_REACT_HEAVY_CONTROLLER_SMOKE") == "1":
        add(smokes, "r2c_react_surface_smoke")
        add(smokes, "r2c_react_publish_selector_bundle_smoke")
        add(smokes, "r2c_react_run_native_gui_controller_smoke")
        add(smokes, "r2c_react_discover_truth_routes_controller_smoke")
        add(smokes, "r2c_react_truth_compare_controller_smoke")
        add(smokes, "r2c_react_exec_route_matrix_controller_smoke")
    add(smokes, "r2c_react_render_compare_direct_smoke")
    if os.GetEnv("R2C_REACT_HEAVY_CONTROLLER_SMOKE") == "1":
        add(smokes, "r2c_react_render_compare_controller_smoke")
        add(smokes, "r2c_react_render_compare_matrix_controller_smoke")
    return GateRunHostSmokes(root, smokes)

fn GateVerifyX86LinuxRemote(root: str): int32 =
    var compiler = ""
    if GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let run = GateRunBinary(root,
                              "verify_x86_linux_remote",
                              compiler,
                              ["verify-x86-linux-remote"],
                              1800,
                              "artifacts/gate/verify_x86_linux_remote.log")
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    return 0

fn GateEnsureCompilerReady(root: str, compilerPath: str, outCompiler: var str): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(root)
    outCompiler = chengpath.PathAbsolute(root, compilerPath)
    if outCompiler == snapshot.backendDriverOut.path:
        return GateEnsureBackendDriverReady(root, outCompiler)
    if outCompiler == snapshot.stage0Compiler.path ||
       outCompiler == snapshot.stage1Compiler.path ||
       outCompiler == snapshot.stage2Compiler.path ||
       outCompiler == snapshot.stage3Compiler.path:
        if GateEnsureBootstrapBridge(root) != 0:
            return 1
        if os.FileExists(outCompiler):
            return 0
        GatePrintErr(" gate: missing compiler: " + outCompiler)
        return 1
    if os.FileExists(outCompiler):
        return 0
    GatePrintErr(" gate: missing compiler: " + outCompiler)
    return 1

fn GateCompileEmitEnv(root: str,
                        label: str,
                        compilerPath: str,
                        sourcePath: str,
                        emitKind: str,
                        outPath: str,
                        target: str,
                        logRelPath: str,
                        envOverrides: str[]): hostops.LoggedRun =
    let timeoutText = os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec = int32(strutil.ParseInt(timeoutText))
    return GateCompileEmitEnvWithTimeout(root,
                                           label,
                                           compilerPath,
                                           sourcePath,
                                           emitKind,
                                           outPath,
                                           target,
                                           logRelPath,
                                           envOverrides,
                                           timeoutSec)

fn GateCompileEmitEnvWithTimeout(root: str,
                                   label: str,
                                   compilerPath: str,
                                   sourcePath: str,
                                   emitKind: str,
                                   outPath: str,
                                   target: str,
                                   logRelPath: str,
                                   envOverrides: str[],
                                   timeoutSec: int32): hostops.LoggedRun =
    let packageRoot = root
    var compilerAbs: str
    let outParts: os.SplitFileResult = os.SplitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = chengpath.MkdirP(root, outParts.dir)
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    if GateEnsureCompilerReady(root, compilerPath, compilerAbs) != 0:
        let missingText: str = GateJoin3(" gate: compiler missing during compile: ", compilerAbs, "\n")
        return hostops.LoggedRunZero(label,
                                       compilerAbs,
                                       logAbs,
                                       1,
                                       missingText)
    let run = hostops.RunFileLogged(root,
                                      label,
                                      compilerAbs,
                                      [
                                          "system-link-exec",
                                          "--root", packageRoot,
                                          "--in", sourcePath,
                                          "--emit", emitKind,
                                          "--target", target,
                                          "--out", outPath
                                      ],
                                      envOverrides,
                                      root,
                                      timeoutSec,
                                      logRelPath)
    if hostops.LoggedRunOk(run) && !os.FileExists(outPath):
        let outputText = run.output + " gate: compile missing output: " + outPath + "\n"
        let _logged: bool = chengpath.WriteTextFile(root, logAbs, outputText)
        return hostops.LoggedRunZero(label, compilerAbs, logAbs, 1, outputText)
    return run

fn GateCompileExeEnv(root: str,
                       label: str,
                       compilerPath: str,
                       sourcePath: str,
                       outPath: str,
                       target: str,
                       logRelPath: str,
                       envOverrides: str[]): hostops.LoggedRun =
    return GateCompileEmitEnv(root,
                                label,
                                compilerPath,
                                sourcePath,
                                "exe",
                                outPath,
                                target,
                                logRelPath,
                                envOverrides)

fn GateCompileExeEnvWithTimeout(root: str,
                                  label: str,
                                  compilerPath: str,
                                  sourcePath: str,
                                  outPath: str,
                                  target: str,
                                  logRelPath: str,
                                  envOverrides: str[],
                                  timeoutSec: int32): hostops.LoggedRun =
    return GateCompileEmitEnvWithTimeout(root,
                                           label,
                                           compilerPath,
                                           sourcePath,
                                           "exe",
                                           outPath,
                                           target,
                                           logRelPath,
                                           envOverrides,
                                           timeoutSec)

fn GateCompileExe(root: str,
                    label: str,
                    compilerPath: str,
                    sourcePath: str,
                    outPath: str,
                    target: str,
                    logRelPath: str): hostops.LoggedRun =
    return GateCompileExeEnv(root, label, compilerPath, sourcePath, outPath, target, logRelPath, [])

fn GateCompileExeEnvAtRoot(root: str,
                             label: str,
                             compilerPath: str,
                             packageRoot: str,
                             sourcePath: str,
                             outPath: str,
                             target: str,
                             logRelPath: str,
                             envOverrides: str[]): hostops.LoggedRun =
    var compilerAbs: str
    let outParts: os.SplitFileResult = os.SplitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = chengpath.MkdirP(root, outParts.dir)
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    if GateEnsureCompilerReady(root, compilerPath, compilerAbs) != 0:
        let missingText: str = GateJoin3(" gate: compiler missing during compile: ", compilerAbs, "\n")
        return hostops.LoggedRunZero(label,
                                       compilerAbs,
                                       logAbs,
                                       1,
                                       missingText)
    let timeoutText = os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec = int32(strutil.ParseInt(timeoutText))
    let run = hostops.RunFileLogged(root,
                                      label,
                                      compilerAbs,
                                      [
                                          "system-link-exec",
                                          "--root", packageRoot,
                                          "--in", sourcePath,
                                          "--emit", "exe",
                                          "--target", target,
                                          "--out", outPath
                                      ],
                                      envOverrides,
                                      root,
                                      timeoutSec,
                                      logRelPath)
    if hostops.LoggedRunOk(run) && !os.FileExists(outPath):
        let outputText = run.output + " gate: compile missing output: " + outPath + "\n"
        let _logged: bool = chengpath.WriteTextFile(root, logAbs, outputText)
        return hostops.LoggedRunZero(label, compilerAbs, logAbs, 1, outputText)
    return run

fn GateCompileExeSpawnEnv(root: str,
                            label: str,
                            compilerPath: str,
                            sourcePath: str,
                            outPath: str,
                            target: str,
                            logRelPath: str,
                            envOverrides: str[]): Result[hostops.ParallelJob] =
    let packageRoot: str = root
    let outParts: os.SplitFileResult = os.SplitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = chengpath.MkdirP(root, outParts.dir)
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    return hostops.ParallelSpawnFile(root,
                                       label,
                                       compilerPath,
                                       [
                                           "system-link-exec",
                                           "--root", packageRoot,
                                           "--in", sourcePath,
                                           "--emit", "exe",
                                           "--target", target,
                                           "--out", outPath
                                       ],
                                       envOverrides,
                                       root,
                                       logRelPath)

fn GateRunBinary(root: str,
                   label: str,
                   binPath: str,
                   args: str[],
                   timeoutSec: int32,
                   logRelPath: str): hostops.LoggedRun =
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    return hostops.RunFileLogged(root, label, binPath, args, [], root, timeoutSec, logRelPath)

fn GateWriteProcessSnapshot(root: str,
                              proc: hostops.SpawnedProcess,
                              logRelPath: str,
                              exitCode: int32): hostops.LoggedRun =
    let logPath: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logPath)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    let _logged: bool = chengpath.WriteTextFile(root, logRelPath, proc.output)
    return hostops.LoggedRun(label: proc.label,
                               filePath: proc.filePath,
                               logPath: logPath,
                               exitCode: exitCode,
                               output: proc.output)

fn GateIsDigits(text: str): bool =
    if len(text) <= 0:
        return false
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
    return true

fn GateWaitReadyPort(root: str,
                       readyPath: str,
                       proc: var hostops.SpawnedProcess,
                       outPort: var str): bool =
    outPort = ""
    root
    for i in 0..<400:
        i
        hostops.SpawnedProcessDrain(proc, 0)
        if os.FileExists(readyPath):
            let candidate = strutil.Strip(chengpath.ReadTextFile("", readyPath))
            if GateIsDigits(candidate):
                outPort = candidate
                return true
        if !hostops.SpawnedProcessRunning(proc):
            return false
        os.SleepMs(50)
    return false

fn GateOutputContains(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn GateOutputLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32
    var i: int32
    while i <= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if strutil.StartsWith(line, prefix):
                return strings.SliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
        i = i + 1
    return ""

fn GateBuildPlanLineRelevant(line: str): bool =
    return strutil.StartsWith(line, "target=") ||
           strutil.StartsWith(line, "linker=") ||
           strutil.StartsWith(line, "stage2_compiler=") ||
           strutil.StartsWith(line, "entry=") ||
           strutil.StartsWith(line, "output=") ||
           strutil.StartsWith(line, "source[")

fn GateBuildPlanComparableText(text: str): str =
    var out = ""
    var start: int32
    var i: int32
    while i <= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if GateBuildPlanLineRelevant(line):
                out = out + line + "\n"
            start = i + 1
        i = i + 1
    return out

fn GateRequireOutput(run: hostops.LoggedRun,
                       needle: str,
                       context: str): bool =
    if GateOutputContains(run.output, needle):
        return true
    GatePrintErr(context + ": missing output: " + needle)
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return false

fn GateCollectPositionals(args: str[]): str[] =
    var out: str[]
    for i in 0..<args.len:
        let arg: str = args[i]
        if !strutil.StartsWith(arg, "--"):
            add(out, arg)
    return out

fn GateShellArgv(args: str[]): str =
    var out = ""
    for i in 0..<args.len:
        if i > 0:
            out = out + " "
        out = out + os.QuoteShell(args[i])
    return out

fn GateTextValue(text: str, key: str): str =
    let prefix = key + "="
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text):
            if text[end] == '\n':
                break
            if text[end] == '\r':
                break
            end = end + 1
        let line = chengpath.TextSlice(text, start, end - start)
        if chengpath.TextStartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
        start = end + 1
        while start < len(text):
            if text[start] != '\n':
                if text[start] != '\r':
                    break
            start = start + 1
    return ""

fn GateRunShellLogged(root: str,
                        label: str,
                        command: str,
                        logPath: str,
                        timeoutSec: int32): hostops.LoggedRun =
    return hostops.RunProgramLogged(root,
                                      label,
                                      "sh",
                                      ["-lc", command],
                                      [],
                                      root,
                                      timeoutSec,
                                      logPath)

fn GateRemoteTransportRetryable(text: str): bool =
    let trimmed = strutil.Strip(text)
    return strutil.Contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.Contains(trimmed, "Connection to ") && strutil.Contains(trimmed, " timed out")) ||
           strutil.Contains(trimmed, "No route to host") ||
           strutil.Contains(trimmed, "Connection reset by peer") ||
           strutil.Contains(trimmed, "kex_exchange_identification") ||
           strutil.Contains(trimmed, "Connection closed by remote host")

fn GateRemoteSshArgv(sshHost: str, remoteCmd: str): str[] =
    return [
        "-n",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        sshHost,
        remoteCmd
    ]

fn GateRemoteScriptSafeToken(text: str): str =
    if len(text) == 0:
        return "x"
    var out = ""
    for i in 0..<len(text):
        let part = strings.SliceBytes(text, i, 1)
        let ch = part[0]
        if (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           (ch >= '0' && ch <= '9'):
            out = out + part
        else:
            out = out + "_"
    if len(out) == 0:
        return "x"
    return out

fn GateRemoteScriptLocalPath(root: str, logPath: str): str =
    let localPath = chengpath.PathAbsolute(root, logPath + ".remote.sh")
    let _ = chengpath.MkdirP(root, chengpath.PathParentDir(localPath))
    return localPath

fn GateRemoteScriptPath(label: str): str =
    return "/tmp/cheng_gate_" + GateRemoteScriptSafeToken(label) + ".sh"

fn GateRemoteScpArgv(sshHost: str, localPath: str, remotePath: str): str[] =
    return [
        "-q",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        localPath,
        sshHost + ":" + remotePath
    ]

fn GateRunRemoteShellLogged(root: str,
                              label: str,
                              sshHost: str,
                              command: str,
                              logPath: str,
                              timeoutSec: int32): hostops.LoggedRun =
    let localScript = GateRemoteScriptLocalPath(root, logPath)
    let scriptText = "#!/bin/sh\n" + command + "\n"
    if !chengpath.WriteTextFile(root, localScript, scriptText):
        let writeFailText: str = GateJoin3(" gate: remote script write failed: ", localScript, "\n")
        return hostops.LoggedRunZero(label,
                                       "ssh",
                                       chengpath.PathAbsolute(root, logPath),
                                       1,
                                       writeFailText)
    var lastRun = hostops.LoggedRunZero(label, "ssh", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.RunProgramLoggedWithInputText(root,
                                                          label,
                                                          "ssh",
                                                          [
                                                              "-T",
                                                              "-o", "BatchMode=yes",
                                                              "-o", "ConnectTimeout=20",
                                                              "-o", "ServerAliveInterval=5",
                                                              "-o", "ServerAliveCountMax=3",
                                                              sshHost,
                                                              "sh"
                                                          ],
                                                          [],
                                                          root,
                                                          timeoutSec,
                                                          logPath,
                                                          scriptText)
        lastRun = run
        if !GateRunFailed(run):
            return run
        if attempt >= 2 || !GateRemoteTransportRetryable(run.output):
            return run
        GatePrintLine("[ gate] remote ssh retry " + intToStr(attempt + 1) + " " + label)
        os.SleepMs((attempt + 1) * 1000)
    return lastRun

fn GateShellCheckOk(root: str, command: str): bool =
    let run = hostops.RunProgramLogged(root,
                                         "gate_shell_check",
                                         "sh",
                                         ["-lc", command],
                                         [],
                                         root,
                                         7,
                                         "/tmp/cheng_gate_shell_check.log")
    return hostops.LoggedRunOk(run)

fn GateBftBuildReady(root: str,
                       compiler: str,
                       src: str,
                       outBin: str,
                       runLog: str,
                       runSelfTest: str): bool =
    if !os.FileExists(outBin):
        return false
    var command = "test -x " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    if runSelfTest != "0":
        if !os.FileExists(runLog):
            return false
        command = command + " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog)
        command = command + " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog)
        command = command + " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog)
        command = command + " && grep -q " + os.QuoteShell(" bft_state_machine self-test ok")
        command = command + " " + os.QuoteShell(runLog)
    return GateShellCheckOk(root, command)

