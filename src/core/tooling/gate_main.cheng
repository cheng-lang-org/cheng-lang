fn GateChainDaemonSyncArgs(statePath: str,
                             nodeId: str,
                             addressSeed: str,
                             serverPort: str): str[] =
    var out: str[]
    add(out, "chain")
    add(out, "daemon")
    add(out, "sync")
    add(out, "--state:" + statePath)
    if len(nodeId) > 0:
        add(out, "--node-id:" + nodeId)
    if len(addressSeed) > 0:
        add(out, "--address-seed:" + addressSeed)
    add(out, "--host:127.0.0.1")
    add(out, "--port:" + serverPort)
    return out

fn GateChainSelfTestArgs(): str[] =
    return ["chain", "self", "test"]

fn GateRunChainNodeServeAndSync(root: str,
                                  label: str,
                                  chainNodeBin: str,
                                  serverState: str,
                                  clientState: str,
                                  clientNodeId: str,
                                  clientAddressSeed: str,
                                  outDir: str,
                                  roundTag: str,
                                  expectChanged: bool): int32 =
    let readyPath: str = os.JoinPath(outDir, roundTag + ".ready")
    let serverLog: str = os.JoinPath(outDir, roundTag + ".server.log")
    let syncLog: str = os.JoinPath(outDir, roundTag + ".sync.log")
    let _ = os.RemoveFile(readyPath)
    let serverSpawn = hostops.SpawnFile(root,
                                          " chain_node resilience serve " + label + " " + roundTag,
                                          chainNodeBin,
                                          GateChainDaemonServeArgs(serverState, readyPath),
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, serverPort):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, serverLog, 1)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let syncArgs: str[] = GateChainDaemonSyncArgs(clientState,
                                                    clientNodeId,
                                                    clientAddressSeed,
                                                    serverPort)
    let syncRun = GateRunBinary(root,
                                  " chain_node resilience sync " + label + " " + roundTag,
                                  chainNodeBin,
                                  syncArgs,
                                  20,
                                  syncLog)
    if GateRunFailed(syncRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, serverLog)
        GateMaybePrintRunOutput(serverRun)
        return syncRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, serverLog)
    GateMaybePrintRunOutput(serverRun)
    GateMaybePrintRunOutput(syncRun)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    if expectChanged:
        if !GateRequireOutput(syncRun, "changed=1", " chain_node resilience smoke"):
            return 1
    else:
        if !GateRequireOutput(syncRun, "changed=0", " chain_node resilience smoke"):
            return 1
    return 0

fn GateRunChainNodeCliSmoke(root: str,
                              compilerPath: str,
                              label: str,
                              envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/chain_node_cli/" + label)
    let tmpDir: str = os.JoinPath(outDir, "cli_smoke")
    if !chengpath.MkdirP(root, tmpDir):
        GatePrintErr(" chain_node cli smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var chainNodeBin = ""
    if GateBuildChainNodeBinary(root,
                                  compilerPath,
                                  outDir,
                                  " chain_node cli unified compile " + label,
                                  envOverrides,
                                  chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let readyPath: str = os.JoinPath(tmpDir, "server.ready")
    let serverLog: str = os.JoinPath(outDir, "server." + label + ".log")
    let syncLog: str = os.JoinPath(outDir, "sync." + label + ".log")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(clientState)
    let _ = os.RemoveFile(readyPath)
    let initRun = GateRunBinary(root,
                                  " chain_node cli init " + label,
                                  chainNodeBin,
                                  GateChainInitArgs(serverState, "node-a", "chain-node-a"),
                                  20,
                                  os.JoinPath(outDir, "init." + label + ".log"))
    if GateRunFailed(initRun):
        return initRun.exitCode
    let mintRun = GateRunBinary(root,
                                  " chain_node cli mint " + label,
                                  chainNodeBin,
                                  GateChainMintArgs(serverState, "1001", "100"),
                                  20,
                                  os.JoinPath(outDir, "mint." + label + ".log"))
    if GateRunFailed(mintRun):
        return mintRun.exitCode
    let transferRun = GateRunBinary(root,
                                      " chain_node cli transfer " + label,
                                      chainNodeBin,
                                      GateChainTransferArgs(serverState, "1001", "2002", "40"),
                                      20,
                                      os.JoinPath(outDir, "transfer." + label + ".log"))
    if GateRunFailed(transferRun):
        return transferRun.exitCode
    let balanceARun = GateRunBinary(root,
                                      " chain_node cli balance-a " + label,
                                      chainNodeBin,
                                      GateChainBalanceArgs(serverState, "1001"),
                                      20,
                                      os.JoinPath(outDir, "balance_a." + label + ".log"))
    if GateRunFailed(balanceARun):
        return balanceARun.exitCode
    let balanceBRun = GateRunBinary(root,
                                      " chain_node cli balance-b " + label,
                                      chainNodeBin,
                                      GateChainBalanceArgs(serverState, "2002"),
                                      20,
                                      os.JoinPath(outDir, "balance_b." + label + ".log"))
    if GateRunFailed(balanceBRun):
        return balanceBRun.exitCode
    let showRun = GateRunBinary(root,
                                  " chain_node cli show-state " + label,
                                  chainNodeBin,
                                  GateChainShowStateArgs(serverState),
                                  20,
                                  os.JoinPath(outDir, "show." + label + ".log"))
    if GateRunFailed(showRun):
        return showRun.exitCode
    let snapshotRun = GateRunBinary(root,
                                      " chain_node cli dump-snapshot " + label,
                                      chainNodeBin,
                                      GateChainSnapshotDumpArgs(serverState),
                                      20,
                                      os.JoinPath(outDir, "snapshot." + label + ".log"))
    if GateRunFailed(snapshotRun):
        return snapshotRun.exitCode
    let serverSpawn = hostops.SpawnFile(root,
                                          " chain_node cli daemon-serve " + label,
                                          chainNodeBin,
                                          GateChainDaemonServeArgs(serverState, readyPath),
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, serverPort):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, serverLog, 1)
        GatePrintErr(" chain_node cli smoke: invalid ready port: " + serverPort)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let syncRun = GateRunBinary(root,
                                  " chain_node cli daemon-sync " + label,
                                  chainNodeBin,
                                  GateChainDaemonSyncArgs(clientState,
                                                            "node-b",
                                                            "chain-node-b",
                                                            serverPort),
                                  20,
                                  syncLog)
    if GateRunFailed(syncRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, serverLog)
        GateMaybePrintRunOutput(serverRun)
        return syncRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, serverLog)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    let clientBalanceARun = GateRunBinary(root,
                                            " chain_node cli client-balance-a " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(clientState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "client_balance_a." + label + ".log"))
    if GateRunFailed(clientBalanceARun):
        return clientBalanceARun.exitCode
    let clientBalanceBRun = GateRunBinary(root,
                                            " chain_node cli client-balance-b " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(clientState, "2002"),
                                            20,
                                            os.JoinPath(outDir, "client_balance_b." + label + ".log"))
    if GateRunFailed(clientBalanceBRun):
        return clientBalanceBRun.exitCode
    let clientShowRun = GateRunBinary(root,
                                        " chain_node cli client-show " + label,
                                        chainNodeBin,
                                        GateChainShowStateArgs(clientState),
                                        20,
                                        os.JoinPath(outDir, "client_show." + label + ".log"))
    if GateRunFailed(clientShowRun):
        return clientShowRun.exitCode
    if !GateRequireOutput(initRun, "node_id=node-a", " chain_node cli smoke") ||
       !GateRequireOutput(balanceARun, "balance=60", " chain_node cli smoke") ||
       !GateRequireOutput(balanceBRun, "balance=40", " chain_node cli smoke") ||
       !GateRequireOutput(showRun, "node_id=node-a", " chain_node cli smoke") ||
       !GateRequireOutput(snapshotRun, "payload_hex=", " chain_node cli smoke") ||
       !GateRequireOutput(syncRun, "changed=1", " chain_node cli smoke") ||
       !GateRequireOutput(clientBalanceARun, "balance=60", " chain_node cli smoke") ||
       !GateRequireOutput(clientBalanceBRun, "balance=40", " chain_node cli smoke") ||
       !GateRequireOutput(clientShowRun, "node_id=node-b", " chain_node cli smoke"):
        return 1
    GateMaybePrintRunOutput(initRun)
    GateMaybePrintRunOutput(mintRun)
    GateMaybePrintRunOutput(transferRun)
    GateMaybePrintRunOutput(balanceARun)
    GateMaybePrintRunOutput(balanceBRun)
    GateMaybePrintRunOutput(showRun)
    GateMaybePrintRunOutput(snapshotRun)
    GateMaybePrintRunOutput(serverRun)
    GateMaybePrintRunOutput(syncRun)
    GateMaybePrintRunOutput(clientBalanceARun)
    GateMaybePrintRunOutput(clientBalanceBRun)
    GateMaybePrintRunOutput(clientShowRun)
    GatePrintLine(" chain_node cli smoke ok (" + label + ")")
    return 0

fn GateRunChainNodeResilienceSmoke(root: str,
                                     compilerPath: str,
                                     label: str,
                                     envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/chain_node_resilience/" + label)
    let tmpDir: str = os.JoinPath(outDir, "resilience_smoke")
    if !chengpath.MkdirP(root, tmpDir):
        GatePrintErr(" chain_node resilience smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var chainNodeBin = ""
    if GateBuildChainNodeBinary(root,
                                  compilerPath,
                                  outDir,
                                  " chain_node resilience compile " + label,
                                  envOverrides,
                                  chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let relayState: str = os.JoinPath(tmpDir, "relay.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(relayState)
    let _ = os.RemoveFile(clientState)

    let initRun = GateRunBinary(root,
                                  " chain_node resilience init " + label,
                                  chainNodeBin,
                                  GateChainInitArgs(serverState, "node-a", "chain-node-a"),
                                  20,
                                  os.JoinPath(outDir, "init." + label + ".log"))
    if GateRunFailed(initRun):
        return initRun.exitCode
    if !GateRequireOutput(initRun, "node_id=node-a", " chain_node resilience smoke"):
        return 1

    let round1MintRun = GateRunBinary(root,
                                        " chain_node resilience round1 mint " + label,
                                        chainNodeBin,
                                        GateChainMintArgs(serverState, "1001", "100"),
                                        20,
                                        os.JoinPath(outDir, "round1_mint." + label + ".log"))
    if GateRunFailed(round1MintRun):
        return round1MintRun.exitCode
    let round1TransferRun = GateRunBinary(root,
                                            " chain_node resilience round1 transfer " + label,
                                            chainNodeBin,
                                            GateChainTransferArgs(serverState, "1001", "2002", "40"),
                                            20,
                                            os.JoinPath(outDir, "round1_transfer." + label + ".log"))
    if GateRunFailed(round1TransferRun):
        return round1TransferRun.exitCode
    let serverAliceRound1 = GateRunBinary(root,
                                            " chain_node resilience round1 server alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(serverState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round1_server_alice." + label + ".log"))
    if GateRunFailed(serverAliceRound1):
        return serverAliceRound1.exitCode
    let serverBobRound1 = GateRunBinary(root,
                                          " chain_node resilience round1 server bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(serverState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round1_server_bob." + label + ".log"))
    if GateRunFailed(serverBobRound1):
        return serverBobRound1.exitCode
    let serverShowRound1 = GateRunBinary(root,
                                           " chain_node resilience round1 server show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(serverState),
                                           20,
                                           os.JoinPath(outDir, "round1_server_show." + label + ".log"))
    if GateRunFailed(serverShowRound1):
        return serverShowRound1.exitCode
    let serverSnapshotRound1 = GateRunBinary(root,
                                               " chain_node resilience round1 server snapshot " + label,
                                               chainNodeBin,
                                               GateChainSnapshotDumpArgs(serverState),
                                               20,
                                               os.JoinPath(outDir, "round1_server_snapshot." + label + ".log"))
    if GateRunFailed(serverSnapshotRound1):
        return serverSnapshotRound1.exitCode
    if !GateChainNodeRequireRunValue(serverAliceRound1, "balance", "60", " chain_node resilience round1 server alice") ||
       !GateChainNodeRequireRunValue(serverBobRound1, "balance", "40", " chain_node resilience round1 server bob") ||
       !GateChainNodeRequireRunValue(serverShowRound1, "node_id", "node-a", " chain_node resilience round1 server show") ||
       !GateChainNodeRequireRunValue(serverShowRound1, "event_count", "2", " chain_node resilience round1 server show") ||
       !GateRequireOutput(serverSnapshotRound1, "payload_hex=", " chain_node resilience smoke"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round1_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound1 = GateRunBinary(root,
                                          " chain_node resilience round1 relay show " + label,
                                          chainNodeBin,
                                          GateChainShowStateArgs(relayState),
                                          20,
                                          os.JoinPath(outDir, "round1_relay_show." + label + ".log"))
    if GateRunFailed(relayShowRound1):
        return relayShowRound1.exitCode
    let relayAliceRound1 = GateRunBinary(root,
                                           " chain_node resilience round1 relay alice " + label,
                                           chainNodeBin,
                                           GateChainBalanceArgs(relayState, "1001"),
                                           20,
                                           os.JoinPath(outDir, "round1_relay_alice." + label + ".log"))
    if GateRunFailed(relayAliceRound1):
        return relayAliceRound1.exitCode
    let relayBobRound1 = GateRunBinary(root,
                                         " chain_node resilience round1 relay bob " + label,
                                         chainNodeBin,
                                         GateChainBalanceArgs(relayState, "2002"),
                                         20,
                                         os.JoinPath(outDir, "round1_relay_bob." + label + ".log"))
    if GateRunFailed(relayBobRound1):
        return relayBobRound1.exitCode
    if !GateChainNodeRequireRunValue(relayShowRound1, "node_id", "node-b", " chain_node resilience round1 relay show") ||
       !GateChainNodeRequireRunValue(relayAliceRound1, "balance", "60", " chain_node resilience round1 relay alice") ||
       !GateChainNodeRequireRunValue(relayBobRound1, "balance", "40", " chain_node resilience round1 relay bob") ||
       !GateChainNodeRequireStateParity(serverShowRound1,
                                          relayShowRound1,
                                          " chain_node resilience round1 server relay parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round1_server_to_relay_idle",
                                      false) != 0:
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round1_relay_to_client",
                                      true) != 0:
        return 1
    let clientShowRound1 = GateRunBinary(root,
                                           " chain_node resilience round1 client show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(clientState),
                                           20,
                                           os.JoinPath(outDir, "round1_client_show." + label + ".log"))
    if GateRunFailed(clientShowRound1):
        return clientShowRound1.exitCode
    let clientAliceRound1 = GateRunBinary(root,
                                            " chain_node resilience round1 client alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(clientState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round1_client_alice." + label + ".log"))
    if GateRunFailed(clientAliceRound1):
        return clientAliceRound1.exitCode
    let clientBobRound1 = GateRunBinary(root,
                                          " chain_node resilience round1 client bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(clientState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round1_client_bob." + label + ".log"))
    if GateRunFailed(clientBobRound1):
        return clientBobRound1.exitCode
    if !GateChainNodeRequireRunValue(clientShowRound1, "node_id", "node-c", " chain_node resilience round1 client show") ||
       !GateChainNodeRequireRunValue(clientAliceRound1, "balance", "60", " chain_node resilience round1 client alice") ||
       !GateChainNodeRequireRunValue(clientBobRound1, "balance", "40", " chain_node resilience round1 client bob") ||
       !GateChainNodeRequireStateParity(relayShowRound1,
                                          clientShowRound1,
                                          " chain_node resilience round1 relay client parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round1_relay_to_client_idle",
                                      false) != 0:
        return 1

    let round2MintRun = GateRunBinary(root,
                                        " chain_node resilience round2 mint " + label,
                                        chainNodeBin,
                                        GateChainMintArgs(serverState, "2002", "25"),
                                        20,
                                        os.JoinPath(outDir, "round2_mint." + label + ".log"))
    if GateRunFailed(round2MintRun):
        return round2MintRun.exitCode
    let round2TransferRun = GateRunBinary(root,
                                            " chain_node resilience round2 transfer " + label,
                                            chainNodeBin,
                                            GateChainTransferArgs(serverState, "2002", "1001", "15"),
                                            20,
                                            os.JoinPath(outDir, "round2_transfer." + label + ".log"))
    if GateRunFailed(round2TransferRun):
        return round2TransferRun.exitCode
    let serverShowRound2 = GateRunBinary(root,
                                           " chain_node resilience round2 server show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(serverState),
                                           20,
                                           os.JoinPath(outDir, "round2_server_show." + label + ".log"))
    if GateRunFailed(serverShowRound2):
        return serverShowRound2.exitCode
    let serverAliceRound2 = GateRunBinary(root,
                                            " chain_node resilience round2 server alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(serverState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round2_server_alice." + label + ".log"))
    if GateRunFailed(serverAliceRound2):
        return serverAliceRound2.exitCode
    let serverBobRound2 = GateRunBinary(root,
                                          " chain_node resilience round2 server bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(serverState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round2_server_bob." + label + ".log"))
    if GateRunFailed(serverBobRound2):
        return serverBobRound2.exitCode
    if !GateChainNodeRequireRunValue(serverShowRound2, "event_count", "4", " chain_node resilience round2 server show") ||
       !GateChainNodeRequireRunValue(serverAliceRound2, "balance", "75", " chain_node resilience round2 server alice") ||
       !GateChainNodeRequireRunValue(serverBobRound2, "balance", "50", " chain_node resilience round2 server bob"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round2_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound2 = GateRunBinary(root,
                                          " chain_node resilience round2 relay show " + label,
                                          chainNodeBin,
                                          GateChainShowStateArgs(relayState),
                                          20,
                                          os.JoinPath(outDir, "round2_relay_show." + label + ".log"))
    if GateRunFailed(relayShowRound2):
        return relayShowRound2.exitCode
    let relayAliceRound2 = GateRunBinary(root,
                                           " chain_node resilience round2 relay alice " + label,
                                           chainNodeBin,
                                           GateChainBalanceArgs(relayState, "1001"),
                                           20,
                                           os.JoinPath(outDir, "round2_relay_alice." + label + ".log"))
    if GateRunFailed(relayAliceRound2):
        return relayAliceRound2.exitCode
    let relayBobRound2 = GateRunBinary(root,
                                         " chain_node resilience round2 relay bob " + label,
                                         chainNodeBin,
                                         GateChainBalanceArgs(relayState, "2002"),
                                         20,
                                         os.JoinPath(outDir, "round2_relay_bob." + label + ".log"))
    if GateRunFailed(relayBobRound2):
        return relayBobRound2.exitCode
    if !GateChainNodeRequireRunValue(relayAliceRound2, "balance", "75", " chain_node resilience round2 relay alice") ||
       !GateChainNodeRequireRunValue(relayBobRound2, "balance", "50", " chain_node resilience round2 relay bob") ||
       !GateChainNodeRequireStateParity(serverShowRound2,
                                          relayShowRound2,
                                          " chain_node resilience round2 server relay parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round2_server_to_relay_idle",
                                      false) != 0:
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round2_relay_to_client",
                                      true) != 0:
        return 1
    let clientShowRound2 = GateRunBinary(root,
                                           " chain_node resilience round2 client show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(clientState),
                                           20,
                                           os.JoinPath(outDir, "round2_client_show." + label + ".log"))
    if GateRunFailed(clientShowRound2):
        return clientShowRound2.exitCode
    let clientAliceRound2 = GateRunBinary(root,
                                            " chain_node resilience round2 client alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(clientState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round2_client_alice." + label + ".log"))
    if GateRunFailed(clientAliceRound2):
        return clientAliceRound2.exitCode
    let clientBobRound2 = GateRunBinary(root,
                                          " chain_node resilience round2 client bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(clientState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round2_client_bob." + label + ".log"))
    if GateRunFailed(clientBobRound2):
        return clientBobRound2.exitCode
    if !GateChainNodeRequireRunValue(clientAliceRound2, "balance", "75", " chain_node resilience round2 client alice") ||
       !GateChainNodeRequireRunValue(clientBobRound2, "balance", "50", " chain_node resilience round2 client bob") ||
       !GateChainNodeRequireStateParity(relayShowRound2,
                                          clientShowRound2,
                                          " chain_node resilience round2 relay client parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round2_relay_to_client_idle",
                                      false) != 0:
        return 1

    let round3TransferRun = GateRunBinary(root,
                                            " chain_node resilience round3 transfer " + label,
                                            chainNodeBin,
                                            GateChainTransferArgs(serverState, "1001", "2002", "20"),
                                            20,
                                            os.JoinPath(outDir, "round3_transfer." + label + ".log"))
    if GateRunFailed(round3TransferRun):
        return round3TransferRun.exitCode
    let round3MintRun = GateRunBinary(root,
                                        " chain_node resilience round3 mint " + label,
                                        chainNodeBin,
                                        GateChainMintArgs(serverState, "1001", "30"),
                                        20,
                                        os.JoinPath(outDir, "round3_mint." + label + ".log"))
    if GateRunFailed(round3MintRun):
        return round3MintRun.exitCode
    let serverShowRound3 = GateRunBinary(root,
                                           " chain_node resilience round3 server show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(serverState),
                                           20,
                                           os.JoinPath(outDir, "round3_server_show." + label + ".log"))
    if GateRunFailed(serverShowRound3):
        return serverShowRound3.exitCode
    let serverAliceRound3 = GateRunBinary(root,
                                            " chain_node resilience round3 server alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(serverState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round3_server_alice." + label + ".log"))
    if GateRunFailed(serverAliceRound3):
        return serverAliceRound3.exitCode
    let serverBobRound3 = GateRunBinary(root,
                                          " chain_node resilience round3 server bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(serverState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round3_server_bob." + label + ".log"))
    if GateRunFailed(serverBobRound3):
        return serverBobRound3.exitCode
    let serverSnapshotRound3 = GateRunBinary(root,
                                               " chain_node resilience round3 server snapshot " + label,
                                               chainNodeBin,
                                               GateChainSnapshotDumpArgs(serverState),
                                               20,
                                               os.JoinPath(outDir, "round3_server_snapshot." + label + ".log"))
    if GateRunFailed(serverSnapshotRound3):
        return serverSnapshotRound3.exitCode
    if !GateChainNodeRequireRunValue(serverShowRound3, "event_count", "6", " chain_node resilience round3 server show") ||
       !GateChainNodeRequireRunValue(serverAliceRound3, "balance", "85", " chain_node resilience round3 server alice") ||
       !GateChainNodeRequireRunValue(serverBobRound3, "balance", "70", " chain_node resilience round3 server bob") ||
       !GateRequireOutput(serverSnapshotRound3, "payload_hex=", " chain_node resilience smoke"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round3_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound3 = GateRunBinary(root,
                                          " chain_node resilience round3 relay show " + label,
                                          chainNodeBin,
                                          GateChainShowStateArgs(relayState),
                                          20,
                                          os.JoinPath(outDir, "round3_relay_show." + label + ".log"))
    if GateRunFailed(relayShowRound3):
        return relayShowRound3.exitCode
    let relayAliceRound3 = GateRunBinary(root,
                                           " chain_node resilience round3 relay alice " + label,
                                           chainNodeBin,
                                           GateChainBalanceArgs(relayState, "1001"),
                                           20,
                                           os.JoinPath(outDir, "round3_relay_alice." + label + ".log"))
    if GateRunFailed(relayAliceRound3):
        return relayAliceRound3.exitCode
    let relayBobRound3 = GateRunBinary(root,
                                         " chain_node resilience round3 relay bob " + label,
                                         chainNodeBin,
                                         GateChainBalanceArgs(relayState, "2002"),
                                         20,
                                         os.JoinPath(outDir, "round3_relay_bob." + label + ".log"))
    if GateRunFailed(relayBobRound3):
        return relayBobRound3.exitCode
    if !GateChainNodeRequireRunValue(relayAliceRound3, "balance", "85", " chain_node resilience round3 relay alice") ||
       !GateChainNodeRequireRunValue(relayBobRound3, "balance", "70", " chain_node resilience round3 relay bob") ||
       !GateChainNodeRequireStateParity(serverShowRound3,
                                          relayShowRound3,
                                          " chain_node resilience round3 server relay parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round3_server_to_relay_idle",
                                      false) != 0:
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round3_relay_to_client",
                                      true) != 0:
        return 1
    let clientShowRound3 = GateRunBinary(root,
                                           " chain_node resilience round3 client show " + label,
                                           chainNodeBin,
                                           GateChainShowStateArgs(clientState),
                                           20,
                                           os.JoinPath(outDir, "round3_client_show." + label + ".log"))
    if GateRunFailed(clientShowRound3):
        return clientShowRound3.exitCode
    let clientAliceRound3 = GateRunBinary(root,
                                            " chain_node resilience round3 client alice " + label,
                                            chainNodeBin,
                                            GateChainBalanceArgs(clientState, "1001"),
                                            20,
                                            os.JoinPath(outDir, "round3_client_alice." + label + ".log"))
    if GateRunFailed(clientAliceRound3):
        return clientAliceRound3.exitCode
    let clientBobRound3 = GateRunBinary(root,
                                          " chain_node resilience round3 client bob " + label,
                                          chainNodeBin,
                                          GateChainBalanceArgs(clientState, "2002"),
                                          20,
                                          os.JoinPath(outDir, "round3_client_bob." + label + ".log"))
    if GateRunFailed(clientBobRound3):
        return clientBobRound3.exitCode
    if !GateChainNodeRequireRunValue(clientAliceRound3, "balance", "85", " chain_node resilience round3 client alice") ||
       !GateChainNodeRequireRunValue(clientBobRound3, "balance", "70", " chain_node resilience round3 client bob") ||
       !GateChainNodeRequireStateParity(relayShowRound3,
                                          clientShowRound3,
                                          " chain_node resilience round3 relay client parity"):
        return 1
    if GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round3_relay_to_client_idle",
                                      false) != 0:
        return 1
    GatePrintLine(" chain_node resilience smoke ok (" + label + ")")
    return 0

fn GateRunTailnetControlSmoke(root: str,
                                compilerPath: str,
                                stageName: str,
                                envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/tailnet_control")
    let controlProbeEndpoint: str = chengpath.PathAbsolute(root, "testdata/tailnet/headscale_control_ready.json")
    let relayProbeEndpoint: str = chengpath.PathAbsolute(root, "testdata/tailnet/derp_ready.json")
    let baselineSrc: str = chengpath.PathAbsolute(root, "src/tests/libp2p_tailnet_transport_smoke.cheng")
    let baselineBin: str = os.JoinPath(outDir, "libp2p_tailnet_transport_smoke." + stageName)
    let baselineRun = GateCompileExeEnv(root,
                                          " tailnet control compile baseline " + stageName,
                                          compilerPath,
                                          baselineSrc,
                                          baselineBin,
                                          "arm64-apple-darwin",
                                          baselineBin + ".compile.log",
                                          envOverrides)
    if GateRunFailed(baselineRun):
        return baselineRun.exitCode
    let baselineExec = GateRunBinary(root,
                                       " tailnet control run baseline " + stageName,
                                       baselineBin,
                                       [],
                                       20,
                                       os.JoinPath(outDir, "libp2p_tailnet_transport_smoke." + stageName + ".run.log"))
    if GateRunFailed(baselineExec):
        return baselineExec.exitCode
    let coreSmokeSrc: str = chengpath.PathAbsolute(root, "src/tests/tailnet_control_core_smoke.cheng")
    let coreSmokeBin: str = os.JoinPath(outDir, "tailnet_control_core_smoke." + stageName)
    let coreSmokeCompile = GateCompileExeEnv(root,
                                               " tailnet control compile decode smoke " + stageName,
                                               compilerPath,
                                               coreSmokeSrc,
                                               coreSmokeBin,
                                               "arm64-apple-darwin",
                                               coreSmokeBin + ".compile.log",
                                               envOverrides)
    if GateRunFailed(coreSmokeCompile):
        return coreSmokeCompile.exitCode
    let coreSmokeRun = GateRunBinary(root,
                                       " tailnet control run decode smoke " + stageName,
                                       coreSmokeBin,
                                       [],
                                       20,
                                       os.JoinPath(outDir, "tailnet_control_core_smoke." + stageName + ".run.log"))
    if GateRunFailed(coreSmokeRun):
        return coreSmokeRun.exitCode
    let coreSrc: str = chengpath.PathAbsolute(root, "src/apps/tailnet/tailnet_control_core.cheng")
    let coreBin: str = os.JoinPath(outDir, "tailnet_control_core." + stageName)
    let coreCompile = GateCompileExeEnv(root,
                                          " tailnet control compile core " + stageName,
                                          compilerPath,
                                          coreSrc,
                                          coreBin,
                                          "arm64-apple-darwin",
                                          coreBin + ".compile.log",
                                          envOverrides)
    if GateRunFailed(coreCompile):
        return coreCompile.exitCode
    let configureRun = GateRunBinary(root,
                                       " tailnet control configure " + stageName,
                                       coreBin,
                                       [
                                           "--command", "configure",
                                           "--provider-headscale", "1",
                                           "--control-url", "https://headscale.example",
                                           "--control-endpoint", "https://headscale.example/control",
                                           "--relay-endpoint", "https://derp.sfo.example:443",
                                           "--control-probe-endpoint", controlProbeEndpoint,
                                           "--relay-probe-endpoint", relayProbeEndpoint,
                                           "--namespace", "infra",
                                           "--noise-public-key", "noise-pub-cli",
                                           "--derp-region-code", "sfo",
                                           "--derp-region-name", "SanFrancisco",
                                           "--derp-hostname", "derp.sfo.example",
                                           "--synthetic-ipv4", "100.64.0.44",
                                           "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                           "--local-peer-id", "tailnet-control-test",
                                           "--exact-routing", "1",
                                           "--provider-ready", "1",
                                           "--proxy-ready", "1"
                                       ],
                                       20,
                                       os.JoinPath(outDir, "tailnet_control_configure." + stageName + ".run.log"))
    if GateRunFailed(configureRun):
        return configureRun.exitCode
    if !GateRequireOutput(configureRun, "configured=1", " tailnet control") ||
       !GateRequireOutput(configureRun, "providerKind=headscale", " tailnet control") ||
       !GateRequireOutput(configureRun, "controlProbeEndpoint=" + controlProbeEndpoint, " tailnet control") ||
       !GateRequireOutput(configureRun, "controlPlane=headscale", " tailnet control") ||
       !GateRequireOutput(configureRun, "providerReady=1", " tailnet control") ||
       !GateRequireOutput(configureRun, "proxyListenersReady=1", " tailnet control") ||
       !GateRequireOutput(configureRun, "providerRuntimeActive=1", " tailnet control"):
        return 1
    let listenRun = GateRunBinary(root,
                                    " tailnet control listen " + stageName,
                                    coreBin,
                                    [
                                        "--command", "listen",
                                        "--provider-headscale", "1",
                                        "--control-url", "https://headscale.example",
                                        "--control-endpoint", "https://headscale.example/control",
                                        "--relay-endpoint", "https://derp.sfo.example:443",
                                        "--control-probe-endpoint", controlProbeEndpoint,
                                        "--relay-probe-endpoint", relayProbeEndpoint,
                                        "--namespace", "infra",
                                        "--noise-public-key", "noise-pub-cli",
                                        "--derp-region-code", "sfo",
                                        "--derp-region-name", "SanFrancisco",
                                        "--derp-hostname", "derp.sfo.example",
                                        "--synthetic-ipv4", "100.64.0.44",
                                        "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                        "--local-peer-id", "tailnet-control-test",
                                        "--exact-routing", "1",
                                        "--provider-ready", "1",
                                        "--proxy-ready", "1",
                                        "--host", "127.0.0.1",
                                        "--port", "7101",
                                        "--transport", "tcp"
                                    ],
                                    20,
                                    os.JoinPath(outDir, "tailnet_control_listen." + stageName + ".run.log"))
    if GateRunFailed(listenRun):
        return listenRun.exitCode
    if !GateRequireOutput(listenRun, "publishedAddr=/ip4/100.64.0.44/tcp/7101", " tailnet control") ||
       !GateRequireOutput(listenRun, "listener.0.raw=/ip4/127.0.0.1/tcp/7101", " tailnet control") ||
       !GateRequireOutput(listenRun, "providerKind=headscale", " tailnet control") ||
       !GateRequireOutput(listenRun,
                            "tailnetDerpMapSummary=headscale/infra@https://headscale.example#sfo/derp.sfo.example",
                            " tailnet control") ||
       !GateRequireOutput(listenRun, "providerRuntimeActive=1", " tailnet control"):
        return 1
    let dialRun = GateRunBinary(root,
                                  " tailnet control dial-plan " + stageName,
                                  coreBin,
                                  [
                                      "--command", "dial-plan",
                                      "--provider-headscale", "1",
                                      "--control-url", "https://headscale.example",
                                      "--control-endpoint", "https://headscale.example/control",
                                      "--relay-endpoint", "https://derp.sfo.example:443",
                                      "--control-probe-endpoint", controlProbeEndpoint,
                                      "--relay-probe-endpoint", relayProbeEndpoint,
                                      "--namespace", "infra",
                                      "--noise-public-key", "noise-pub-cli",
                                      "--derp-region-code", "sfo",
                                      "--derp-region-name", "SanFrancisco",
                                      "--derp-hostname", "derp.sfo.example",
                                      "--synthetic-ipv4", "100.64.0.44",
                                      "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                      "--local-peer-id", "tailnet-control-test",
                                      "--exact-routing", "1",
                                      "--provider-ready", "1",
                                      "--proxy-ready", "1",
                                      "--derp-healthy", "1",
                                      "--bootstrap-listen-count", "1",
                                      "--bootstrap-listen-raw-0", "/ip4/127.0.0.1/tcp/7101",
                                      "--bootstrap-peer-count", "1",
                                      "--bootstrap-peer-id-0", "peer-direct",
                                      "--bootstrap-peer-remote-tailnet-ip-0", "100.64.0.88",
                                      "--bootstrap-peer-direct-reachable-0", "1",
                                      "--bootstrap-peer-relay-allowed-0", "1",
                                      "--bootstrap-peer-relay-only-0", "0",
                                      "--bootstrap-peer-derp-region-code-0", "sfo",
                                      "--bootstrap-peer-signed-preface-0", "test-preface",
                                      "--bootstrap-peer-bound-addr-text-0", "/ip4/127.0.0.1/tcp/7101",
                                      "--bootstrap-peer-last-path-0", "direct",
                                      "--bootstrap-peer-last-error-0", "",
                                      "--peer-id", "peer-direct",
                                      "--addr", "/ip4/100.64.0.44/tcp/7101"
                                  ],
                                  20,
                                  os.JoinPath(outDir, "tailnet_control_dial." + stageName + ".run.log"))
    if GateRunFailed(dialRun):
        return dialRun.exitCode
    if !GateRequireOutput(dialRun, "dial.pathKind=direct", " tailnet control") ||
       !GateRequireOutput(dialRun, "dial.routeText=/ip4/127.0.0.1/tcp/7101", " tailnet control") ||
       !GateRequireOutput(dialRun, "sessionCount=1", " tailnet control") ||
       !GateRequireOutput(dialRun, "relayHealthy=1", " tailnet control") ||
       !GateRequireOutput(dialRun, "startupStage=derp-ready", " tailnet control") ||
       !GateRequireOutput(dialRun,
                            "tailnetDerpMapSummary=headscale/infra@https://headscale.example#sfo/derp.sfo.example",
                            " tailnet control") ||
       !GateRequireOutput(dialRun, "peer.0.lastPath=direct", " tailnet control") ||
       !GateRequireOutput(dialRun, "providerRuntimeActive=1", " tailnet control") ||
       !GateRequireOutput(dialRun, "providerRuntimeCommands=3", " tailnet control"):
        return 1
    GateMaybePrintRunOutput(baselineExec)
    GateMaybePrintRunOutput(coreSmokeRun)
    GateMaybePrintRunOutput(configureRun)
    GateMaybePrintRunOutput(listenRun)
    GateMaybePrintRunOutput(dialRun)
    GatePrintLine(" tailnet_control_smoke ok")
    return 0

fn GateRunFreshNodeSelfhostGate(root: str,
                                  compilerPath: str,
                                  label: str,
                                  envOverrides: str[]): int32 =
    let src: str = chengpath.PathAbsolute(root, "src/tests/program_selfhost_smoke.cheng")
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/fresh_node_gate/" + label)
    let syncPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.sync")
    let freshPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.fresh")
    if !os.FileExists(src):
        GatePrintErr(" fresh-node selfhost gate: missing source: " + src)
        return 1
    let syncRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                               " fresh-node selfhost world-sync " + label,
                                                               compilerPath,
                                                               [
                                                                   "world-sync",
                                                                   "--root:" + root,
                                                                   "--in:" + src,
                                                                   "--target:arm64-apple-darwin",
                                                                   "--out:" + syncPrefix,
                                                                   "--channel:stable"
                                                               ],
                                                               envOverrides,
                                                               root,
                                                               0,
                                                               os.JoinPath(outDir, "world_sync.log"))
    if GateRunFailed(syncRun):
        return syncRun.exitCode
    if !GateRequirePrefixArtifacts(syncPrefix,
                                     [
                                         ".world.txt",
                                         ".manifest.txt",
                                         ".compiler.snapshot.txt",
                                         ".std.snapshot.txt",
                                         ".runtime.snapshot.txt",
                                         ".csg.txt",
                                         ".surface.txt",
                                         ".receipt.txt",
                                         ".lock.toml"
                                     ],
                                     " fresh-node selfhost gate"):
        return 1
    let freshRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                                " fresh-node selfhost fresh " + label,
                                                                compilerPath,
                                                                [
                                                                    "fresh-node-selfhost",
                                                                    "--root:" + root,
                                                                    "--in:" + src,
                                                                    "--target:arm64-apple-darwin",
                                                                    "--out:" + freshPrefix,
                                                                    "--channel:stable",
                                                                    "--baseline-csg:" + syncPrefix + ".csg.txt",
                                                                    "--baseline-surface:" +
                                                                        syncPrefix + ".surface.txt",
                                                                    "--baseline-receipt:" + syncPrefix + ".receipt.txt"
                                                                ],
                                                                envOverrides,
                                                                root,
                                                                0,
                                                                os.JoinPath(outDir, "fresh_node.log"))
    if GateRunFailed(freshRun):
        return freshRun.exitCode
    if !GateRequireOutput(freshRun, "equivalence_passed=1", " fresh-node selfhost gate") ||
       !GateRequireOutput(freshRun, "publish_allowed=1", " fresh-node selfhost gate") ||
       !GateRequireOutput(freshRun, "receipt_equivalent=1", " fresh-node selfhost gate") ||
       !GateRequireOutput(freshRun, "receipt_cid_match=1", " fresh-node selfhost gate") ||
       !GateRequireFileContains(freshPrefix + ".fresh.txt", "receipt_equivalent=1", " fresh-node selfhost gate") ||
       !GateRequireFileContains(freshPrefix + ".fresh.txt", "receipt_cid_match=1", " fresh-node selfhost gate"):
        return 1
    GateMaybePrintRunOutput(syncRun)
    GateMaybePrintRunOutput(freshRun)
    GatePrintLine(" fresh-node selfhost gate ok (" + label + ")")
    return 0

fn GateRunMigrationGate(root: str,
                          compilerPath: str,
                          label: str,
                          envOverrides: str[]): int32 =
    let currentSrc: str = chengpath.PathAbsolute(root, "src/tests/compiler_migration_fixture.cheng")
    let legacySrc: str = chengpath.PathAbsolute(root,
                                               "testdata/compiler_migration/" +
                                                   "compiler_migration_fixture_legacy.cheng")
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/migration_gate/" + label)
    let migratePrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.migrate")
    let proofPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.prove")
    let blockedPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.blocked")
    let publishPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.publish")
    if !os.FileExists(currentSrc) || !os.FileExists(legacySrc):
        GatePrintErr(" migration gate: missing fixture sources")
        return 1
    let migrateRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                                  " migration gate migrate-csg " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "migrate-csg",
                                                                      "--root:" + root,
                                                                      "--in:" + currentSrc,
                                                                      "--legacy-in:" + legacySrc,
                                                                      "--out:" + migratePrefix
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "migrate_csg.log"))
    if GateRunFailed(migrateRun):
        return migrateRun.exitCode
    if !GateRequirePrefixArtifacts(migratePrefix,
                                     [".migration.txt",
                                      ".migration.csg.txt",
                                      ".migration.surface.txt",
                                      ".migration.receipt.txt"],
                                     " migration gate") ||
       !GateRequireOutput(migrateRun, "canonical_graph_cid=", " migration gate"):
        return 1
    let proveRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                                " migration gate prove-migration " + label,
                                                                compilerPath,
                                                                [
                                                                    "prove-migration",
                                                                    "--root:" + root,
                                                                    "--in:" + currentSrc,
                                                                    "--legacy-in:" + legacySrc,
                                                                    "--target:arm64-apple-darwin",
                                                                    "--channel:stable",
                                                                    "--out:" + proofPrefix
                                                                ],
                                                                envOverrides,
                                                                root,
                                                                0,
                                                                os.JoinPath(outDir, "prove_migration.log"))
    if GateRunFailed(proveRun):
        return proveRun.exitCode
    if !GateRequirePrefixArtifacts(proofPrefix,
                                     [".migration.txt",
                                      ".migration.csg.txt",
                                      ".migration.surface.txt",
                                      ".migration.receipt.txt",
                                      ".proof.txt"],
                                     " migration gate") ||
       !GateRequireOutput(proveRun, "equivalence_kind=canonical_semantic_identity", " migration gate") ||
       !GateRequireOutput(proveRun, "graph_equivalent=1", " migration gate") ||
       !GateRequireOutput(proveRun, "export_surface_compatible=1", " migration gate") ||
       !GateRequireOutput(proveRun, "compile_receipt_equivalent=1", " migration gate"):
        return 1
    let blockedRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                                  " migration gate publish-blocked " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "publish-world",
                                                                      "--root:" + root,
                                                                      "--in:" + currentSrc,
                                                                      "--target:arm64-apple-darwin",
                                                                      "--out:" + blockedPrefix,
                                                                      "--channel:stable"
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_blocked.log"))
    if blockedRun.exitCode == 0:
        GatePrintErr(" migration gate: stable publish unexpectedly passed without proof")
        return 1
    if !GateRequireAnyOutput(blockedRun.output,
                               ["stable requires", "publish blocked", "missing --baseline"],
                               " migration gate"):
        return 1
    let publishRun: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                                  " migration gate publish-world " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "publish-world",
                                                                      "--root:" + root,
                                                                      "--in:" + currentSrc,
                                                                      "--legacy-in:" + legacySrc,
                                                                      "--target:arm64-apple-darwin",
                                                                      "--out:" + publishPrefix,
                                                                      "--channel:stable"
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_migration.log"))
    if GateRunFailed(publishRun):
        return publishRun.exitCode
    if !GateRequirePrefixArtifacts(publishPrefix,
                                     [
                                         ".world.txt",
                                         ".manifest.txt",
                                         ".compiler.snapshot.txt",
                                         ".std.snapshot.txt",
                                         ".runtime.snapshot.txt",
                                         ".csg.txt",
                                         ".surface.txt",
                                         ".receipt.txt",
                                         ".lock.toml",
                                         ".migration.txt",
                                         ".migration.csg.txt",
                                         ".migration.surface.txt",
                                         ".migration.receipt.txt",
                                         ".proof.txt",
                                         ".fresh.txt",
                                         ".publish.txt"
                                     ],
                                     " migration gate") ||
       !GateRequireOutput(publishRun, "proof_mode=migration", " migration gate") ||
       !GateRequireOutput(publishRun, "equivalence_passed=1", " migration gate") ||
       !GateRequireOutput(publishRun, "publish_allowed=1", " migration gate") ||
       !GateRequireOutput(publishRun, "receipt_cid_match=1", " migration gate"):
        return 1
    GateMaybePrintRunOutput(migrateRun)
    GateMaybePrintRunOutput(proveRun)
    GateMaybePrintRunOutput(blockedRun)
    GateMaybePrintRunOutput(publishRun)
    GatePrintLine(" migration gate ok (" + label + ")")
    return 0

fn GateRunBrowserWebrtcSmokes(root: str,
                                tests: str[],
                                envOverrides: str[]): int32 =
    let browserDir: str = chengpath.PathAbsolute(root, "tools/browser_webrtc")
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/browser_webrtc")
    var hostCompiler = ""
    if GateResolveSmokeCompiler(root, "", "CHENG_SMOKE_COMPILER", "", hostCompiler) != 0:
        return 1
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage2: str = contracts.BootstrapStage2Path(root)
    let stage3: str = contracts.BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        GatePrintErr(" browser webrtc smokes: missing bootstrap compiler")
        return 1
    if !os.DirExists(os.JoinPath(browserDir, "node_modules/playwright")):
        let npmRun: hostops.LoggedRun = hostops.RunProgramLogged(root,
                                                                     " browser webrtc npm-install",
                                                                     "npm",
                                                                     ["install", "--no-fund", "--no-audit"],
                                                                     [],
                                                                     browserDir,
                                                                     600,
                                                                     os.JoinPath(outDir, "npm_install.log"))
        if GateRunFailed(npmRun):
            return npmRun.exitCode
    let playwrightRun: hostops.LoggedRun = hostops.RunProgramLogged(root,
                                                                        " browser webrtc playwright-install",
                                                                        "npx",
                                                                        ["playwright", "install", "chromium"],
                                                                        [],
                                                                        browserDir,
                                                                        600,
                                                                        os.JoinPath(outDir, "playwright_install.log"))
    if GateRunFailed(playwrightRun):
        return playwrightRun.exitCode
    var names: str[] = GateDefaultBrowserWebrtcSmokes()
    if tests.len > 0:
        names = tests
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let hostBin: str = os.JoinPath(outDir, smokeName + ".host")
        if GateRunSingleFixtureSmoke(root,
                                       " browser webrtc",
                                       hostCompiler,
                                       smokeName,
                                       hostBin,
                                       "host",
                                       envOverrides) != 0:
            return 1
        let stage2Bin: str = os.JoinPath(outDir, smokeName + ".stage2")
        if GateRunSingleFixtureSmoke(root,
                                       " browser webrtc",
                                       stage2,
                                       smokeName,
                                       stage2Bin,
                                       "stage2",
                                       envOverrides) != 0:
            return 1
        let stage3Bin: str = os.JoinPath(outDir, smokeName + ".stage3")
        if GateRunSingleFixtureSmoke(root,
                                       " browser webrtc",
                                       stage3,
                                       smokeName,
                                       stage3Bin,
                                       "stage3",
                                       envOverrides) != 0:
            return 1
    GatePrintLine(" browser webrtc smokes: ok")
    return 0

fn GateRunChainNodeProcessSmokeWithCompiler(root: str,
                                              compilerPath: str,
                                              label: str,
                                              envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/chain_node_process/" + label)
    let serverSrc: str = chengpath.PathAbsolute(root, "src/tests/chain_node_process_server_smoke.cheng")
    let clientSrc: str = chengpath.PathAbsolute(root, "src/tests/chain_node_process_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "chain_node_process_server")
    let clientBin: str = os.JoinPath(outDir, "chain_node_process_client")
    let serverCompile = GateCompileExeEnv(root,
                                            "run_chain_node_process_server_build " + label,
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_server.compile.log"),
                                            envOverrides)
    if GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = GateCompileExeEnv(root,
                                            "run_chain_node_process_client_build " + label,
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_client.compile.log"),
                                            envOverrides)
    if GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let readyPath: str = os.JoinPath(outDir, "server.ready")
    let _ = os.RemoveFile(readyPath)
    let spawnRes = hostops.SpawnFile(root,
                                       "chain_node_process_server " + label,
                                       serverBin,
                                       ["--port:0", "--ready-path:" + readyPath],
                                       [],
                                       root)
    if IsErr(spawnRes):
        GatePrintErr(Error(spawnRes))
        return 1
    var serverProc = Value(spawnRes)
    var port = ""
    if !GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, os.JoinPath(outDir, "server.log"), 1)
        GatePrintErr(" chain_node process smoke: invalid ready port")
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let clientRun = GateRunBinary(root,
                                    "chain_node_process_client " + label,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    os.JoinPath(outDir, "client.log"))
    if GateRunFailed(clientRun):
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, os.JoinPath(outDir, "server.log"))
        GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, os.JoinPath(outDir, "server.log"))
    GateMaybePrintRunOutput(serverRun)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    GateMaybePrintRunOutput(clientRun)
    GatePrintLine(" chain_node process smoke ok (" + label + ")")
    return 0

fn GateRunChainNodeThreeNodeSmokeWithCompiler(root: str,
                                                compilerPath: str,
                                                label: str,
                                                envOverrides: str[]): int32 =
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/chain_node_three_node/" + label)
    let serverSrc: str = chengpath.PathAbsolute(root, "src/tests/chain_node_process_server_smoke.cheng")
    let relaySrc: str = chengpath.PathAbsolute(root, "src/tests/chain_node_process_relay_smoke.cheng")
    let clientSrc: str = chengpath.PathAbsolute(root, "src/tests/chain_node_process_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "chain_node_process_server")
    let relayBin: str = os.JoinPath(outDir, "chain_node_process_relay")
    let clientBin: str = os.JoinPath(outDir, "chain_node_process_client")
    let serverCompile = GateCompileExeEnv(root,
                                            "run_chain_node_three_node_server_build " + label,
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_server.compile.log"),
                                            envOverrides)
    if GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let relayCompile = GateCompileExeEnv(root,
                                           "run_chain_node_three_node_relay_build " + label,
                                           compilerPath,
                                           relaySrc,
                                           relayBin,
                                           "arm64-apple-darwin",
                                           os.JoinPath(outDir, "chain_node_process_relay.compile.log"),
                                           envOverrides)
    if GateRunFailed(relayCompile):
        return relayCompile.exitCode
    let clientCompile = GateCompileExeEnv(root,
                                            "run_chain_node_three_node_client_build " + label,
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_client.compile.log"),
                                            envOverrides)
    if GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverReady: str = os.JoinPath(outDir, "server.ready")
    let relayReady: str = os.JoinPath(outDir, "relay.ready")
    let _ = os.RemoveFile(serverReady)
    let _ = os.RemoveFile(relayReady)
    let serverArgs = ["--port:0", "--ready-path:" + serverReady]
    let serverSpawn = hostops.SpawnFile(root,
                                          "chain_node_three_node_server " + label,
                                          serverBin,
                                          serverArgs,
                                          [],
                                          root)
    if IsErr(serverSpawn):
        GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !GateWaitReadyPort(root, serverReady, serverProc, serverPort):
        let serverRun = GateWriteProcessSnapshot(root, serverProc, os.JoinPath(outDir, "server.log"), 1)
        GateMaybePrintRunOutput(serverRun)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let relayArgs = ["--upstream-port:" + serverPort,
                     "--port:0",
                     "--ready-path:" + relayReady]
    let relaySpawn = hostops.SpawnFile(root,
                                         "chain_node_three_node_relay " + label,
                                         relayBin,
                                         relayArgs,
                                         [],
                                         root)
    if IsErr(relaySpawn):
        GatePrintErr(Error(relaySpawn))
        hostops.SpawnedProcessKill(serverProc)
        return 1
    var relayProc = Value(relaySpawn)
    var relayPort = ""
    if !GateWaitReadyPort(root, relayReady, relayProc, relayPort):
        let relayRun = GateWriteProcessSnapshot(root, relayProc, os.JoinPath(outDir, "relay.log"), 1)
        GateMaybePrintRunOutput(relayRun)
        hostops.SpawnedProcessKill(relayProc)
        hostops.SpawnedProcessKill(serverProc)
        return 1
    let clientRun = GateRunBinary(root,
                                    "chain_node_three_node_client " + label,
                                    clientBin,
                                    ["--port:" + relayPort],
                                    20,
                                    os.JoinPath(outDir, "client.log"))
    if GateRunFailed(clientRun):
        let relayRun = hostops.SpawnedProcessWaitLogged(root, relayProc, 1, os.JoinPath(outDir, "relay.log"))
        let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 1, os.JoinPath(outDir, "server.log"))
        GateMaybePrintRunOutput(serverRun)
        GateMaybePrintRunOutput(relayRun)
        return clientRun.exitCode
    let relayRun = hostops.SpawnedProcessWaitLogged(root, relayProc, 20, os.JoinPath(outDir, "relay.log"))
    let serverRun = hostops.SpawnedProcessWaitLogged(root, serverProc, 20, os.JoinPath(outDir, "server.log"))
    GateMaybePrintRunOutput(serverRun)
    GateMaybePrintRunOutput(relayRun)
    GateMaybePrintRunOutput(clientRun)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    GatePrintLine(" chain_node three-node smoke ok (" + label + ")")
    return 0

fn GateRunHostSmokes(root: str, args: str[]): int32 =
    if GateVerifyExportVisibility(root) != 0:
        return 1
    let explicitCompiler: str = GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_SMOKE_COMPILER", "", compiler) != 0:
        return 1
    let tailOnly: str = strutil.Strip(GateReadFlag(args, "--tail-only", ""))
    let positionals: str[] = GateCollectPositionals(args)
    let label: str = GateResolveSmokeLabel(args, "CHENG_SMOKE_LABEL", "host")
    let hostrunRoot: str = chengpath.PathAbsolute(root, "artifacts/hostrun")
    var outDir: str = hostrunRoot
    if label != "host":
        outDir = os.JoinPath(hostrunRoot, label)
    if len(tailOnly) > 0:
        if tailOnly == "wasm":
            return GateRunWasmSmokes(root, compiler, label, [])
        if tailOnly == "browser_host_wasm":
            return GateRunBrowserHostWasmSmoke(root, compiler, label, [])
        if tailOnly == "chain_node_cli":
            return GateRunChainNodeCliSmoke(root, compiler, label, [])
        if tailOnly == "chain_node_process":
            return GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, [])
        if tailOnly == "chain_node_three_node":
            return GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, [])
        if tailOnly == "chain_node_resilience":
            return GateRunChainNodeResilienceSmoke(root, compiler, label, [])
        if tailOnly == "tailnet_control":
            return GateRunTailnetControlSmoke(root, compiler, label, [])
        if tailOnly == "fresh_node_selfhost":
            return GateRunFreshNodeSelfhostGate(root, compiler, label, [])
        if tailOnly == "migration":
            return GateRunMigrationGate(root, compiler, label, [])
        GatePrintErr("cheng host smokes: unknown --tail-only: " + tailOnly)
        return 1
    var tests: str[] = GateDefaultHostSmokes()
    var runTail: bool = true
    if positionals.len > 0:
        tests = positionals
        runTail = false
    for i in 0..<tests.len:
        let smokeName: str = tests[i]
        let outBin: str = os.JoinPath(outDir, smokeName)
        if GateRunSingleFixtureSmoke(root, " host smokes", compiler, smokeName, outBin, label, []) != 0:
            return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if GateRunQuicTwoprocSmoke(root, compiler, label, []) != 0:
                return 1
    if runTail:
        if GateRunTailnetControlSmoke(root, compiler, label, []) != 0:
            return 1
        if GateRunFreshNodeSelfhostGate(root, compiler, label, []) != 0:
            return 1
        if GateRunMigrationGate(root, compiler, label, []) != 0:
            return 1
    GatePrintLine("cheng host smokes: ok")
    return 0

fn GateRunStage23Libp2pSmokes(root: str, args: str[]): int32 =
    if GateEnsureBootstrapBridge(root) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/stage23_libp2p")
    let stage2: str = contracts.BootstrapStage2Path(root)
    let stage3: str = contracts.BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        GatePrintErr(" stage2/stage3 libp2p: missing bootstrap compiler")
        return 1
    let envOverrides: str[] = GateStage23EnvOverrides()
    let tailOnly: str = strutil.Strip(GateReadFlag(args, "--tail-only", ""))
    let positionals: str[] = GateCollectPositionals(args)
    if tailOnly == "browser_webrtc":
        return GateRunBrowserWebrtcSmokes(root, positionals, envOverrides)
    if len(tailOnly) > 0:
        GatePrintErr(" stage2/stage3 libp2p: unknown --tail-only: " + tailOnly)
        return 1
    var tests: str[] = GateDefaultStage23Smokes()
    var runTail: bool = true
    if positionals.len > 0:
        tests = positionals
        runTail = false
    for i in 0..<tests.len:
        let smokeName: str = tests[i]
        let stage2Bin: str = os.JoinPath(outDir, smokeName + ".stage2")
        if GateRunSingleFixtureSmoke(root,
                                       " stage2/stage3 libp2p",
                                       stage2,
                                       smokeName,
                                       stage2Bin,
                                       "stage2",
                                       envOverrides) != 0:
            return 1
        if smokeName == "libp2p_tcp_smoke":
            if GateRunTcpTwoprocSmoke(root, stage2, "stage2", envOverrides) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if GateRunQuicTwoprocSmoke(root, stage2, "stage2", envOverrides) != 0:
                return 1
        let stage3Bin: str = os.JoinPath(outDir, smokeName + ".stage3")
        if GateRunSingleFixtureSmoke(root,
                                       " stage2/stage3 libp2p",
                                       stage3,
                                       smokeName,
                                       stage3Bin,
                                       "stage3",
                                       envOverrides) != 0:
            return 1
        if smokeName == "libp2p_tcp_smoke":
            if GateRunTcpTwoprocSmoke(root, stage3, "stage3", envOverrides) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if GateRunQuicTwoprocSmoke(root, stage3, "stage3", envOverrides) != 0:
                return 1
    if runTail:
        if GateRunTailnetControlSmoke(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if GateRunTailnetControlSmoke(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if GateRunFreshNodeSelfhostGate(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if GateRunFreshNodeSelfhostGate(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if GateRunMigrationGate(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if GateRunMigrationGate(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if GateRunBrowserWebrtcSmokes(root, [], envOverrides) != 0:
            return 1
    GatePrintLine(" stage2/stage3 libp2p: ok")
    return 0

fn GateBuildZeroExit(root: str): int32 =
    var compiler = ""
    if GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/zero_exit")
    let src: str = chengpath.PathAbsolute(root, "src/tests/ordinary_zero_exit_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_zero_exit_fixture")
    let compileLog = "artifacts/zero_exit/ordinary_zero_exit_fixture.compile.log"
    let compileRun = GateCompileExe(root,
                                      "build_zero_exit",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin) || !os.FileExists(outBin + ".map"):
        GatePrintErr(" zero-exit: missing output or line-map")
        return 1
    let run = GateRunBinary(root,
                              "build_zero_exit_run",
                              outBin,
                              [],
                              20,
                              "artifacts/zero_exit/ordinary_zero_exit_fixture.run.log")
    GateMaybePrintRunOutput(run)
    if GateRunFailed(run):
        return run.exitCode
    return 0

