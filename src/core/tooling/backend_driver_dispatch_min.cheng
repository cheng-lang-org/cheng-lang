fn BackendDriverDispatchMinHelp(): int32 =
    BackendDriverDispatchMinPutsBridge("usage: cheng <command> [args]")
    BackendDriverDispatchMinPutsBridge("core commands: status, print-build-plan, system-link-exec")
    return 0

fn BackendDriverDispatchMinCurrentCompiler(rootDir: str): str =
    let raw = cmdline.ProgramName()
    if Len(raw) <= 0:
        return ""
    return chengpath.PathAbsolute(rootDir, raw)

fn BackendDriverDispatchMinArtifactsDir(rootDir: str): str =
    let custom = os.GetEnv("CHENG_VERIFY_EXPORT_VISIBILITY_DIR")
    if Len(custom) > 0:
        return chengpath.PathAbsolute(rootDir, custom)
    return chengpath.PathAbsolute(rootDir, "artifacts/forward/verify_export_visibility")

fn BackendDriverDispatchMinEnsureDir(rootDir: str,
                                      dirPath: str): bool =
    if chengpath.MkdirP(rootDir, dirPath):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: failed to create dir: {dirPath}")
    return false

fn BackendDriverDispatchMinWriteManifest(rootDir: str,
                                          packageRoot: str,
                                          packageId: str,
                                          modulePrefix: str): bool =
    let manifestPath = chengpath.PathJoin(packageRoot, "cheng-package.toml")
    let manifestText = Fmt"package_id = \"{packageId}\"\nmodule_prefix = \"{modulePrefix}\"\n"
    if chengpath.WriteTextFile(rootDir, manifestPath, manifestText):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: failed to write manifest: {manifestPath}")
    return false

fn BackendDriverDispatchMinCompileFixture(rootDir: str,
                                           compilerPath: str,
                                           packageRoot: str,
                                           inputPath: str,
                                           outPath: str,
                                           logPath: str,
                                           outOutput: var str): int32 =
    let reportPath = Fmt"{outPath}.report.txt"
    let command = Fmt"CHENG_PARENT_RSS_GUARD=1 CHENG_PROGRESS=1 CHENG_PROCESS_MAX_RSS_BYTES=8589934592 {os.QuoteShell(compilerPath)} system-link-exec --root:{os.QuoteShell(packageRoot)} --in:{os.QuoteShell(inputPath)} --emit:exe --target:arm64-apple-darwin --out:{os.QuoteShell(outPath)} --report-out:{os.QuoteShell(reportPath)}"
    let run = os.ExecShellCmdEx(command, UInt64(1), rootDir)
    outOutput = os.ExecCmdResultOutput(run)
    let _ = chengpath.WriteTextFile(rootDir, logPath, outOutput)
    return os.ExecCmdResultExitCode(run)

fn BackendDriverDispatchMinRunExecutable(rootDir: str,
                                          exePath: str,
                                          logPath: str): int32 =
    let command = os.QuoteShell(exePath)
    let run = os.ExecShellCmdEx(command, UInt64(1), rootDir)
    let _ = chengpath.WriteTextFile(rootDir, logPath, os.ExecCmdResultOutput(run))
    return os.ExecCmdResultExitCode(run)

fn BackendDriverDispatchMinCheckNegative(rootDir: str,
                                          label: str,
                                          exitCode: int32,
                                          output: str,
                                          reportPath: str,
                                          outputNeedle: str,
                                          reportNeedle: str): bool =
    if exitCode == 0:
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: verify-export-visibility unexpected success: {label}")
        return false
    if chengpath.TextContains(output, outputNeedle):
        return true
    let reportText = chengpath.ReadTextFile(rootDir, reportPath)
    if chengpath.TextContains(reportText, reportNeedle):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: verify-export-visibility missing diagnostic: {label}")
    return false

fn BackendDriverDispatchMinVerifyExportPositive(rootDir: str,
                                                 compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "positive_smoke")
    if !BackendDriverDispatchMinEnsureDir(rootDir, caseDir):
        return false
    let srcPath = chengpath.PathAbsolute(rootDir, "src/tests/export_visibility_smoke.cheng")
    let outPath = chengpath.PathJoin(caseDir, "export_visibility_smoke")
    let logPath = chengpath.PathJoin(caseDir, "export_visibility_smoke.compile.log")
    var output = ""
    let compileCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                              compilerPath,
                                                              rootDir,
                                                              srcPath,
                                                              outPath,
                                                              logPath,
                                                              output)
    if compileCode != 0:
        BackendDriverDispatchMinPrintErr("backend driver direct: verify-export-visibility positive compile failed")
        return false
    let runLogPath = chengpath.PathJoin(caseDir, "export_visibility_smoke.run.log")
    let runCode = BackendDriverDispatchMinRunExecutable(rootDir, outPath, runLogPath)
    if runCode != 0:
        BackendDriverDispatchMinPrintErr("backend driver direct: verify-export-visibility positive run failed")
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility export smoke ok")
    return true

fn BackendDriverDispatchMinVerifyPrivateNegative(rootDir: str,
                                                  compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "private_symbol")
    let packageRoot = chengpath.PathJoin(caseDir, "workspace")
    let helperSrcDir = chengpath.PathJoin(packageRoot, "src/private_helper_pkg")
    let consumerSrcDir = chengpath.PathJoin(packageRoot, "src/private_consumer_pkg")
    if !BackendDriverDispatchMinEnsureDir(rootDir, helperSrcDir):
        return false
    if !BackendDriverDispatchMinEnsureDir(rootDir, consumerSrcDir):
        return false
    if !BackendDriverDispatchMinWriteManifest(rootDir,
                                               packageRoot,
                                               "pkg://cheng",
                                               "cheng"):
        return false
    let helperSrcPath = chengpath.PathJoin(helperSrcDir, "helper.cheng")
    let consumerSrcPath = chengpath.PathJoin(consumerSrcDir, "main.cheng")
    let importKw = "import"
    let helperSource = "fn privateFn(): int32 =\n    return 1\n\nfn PublicFn(): int32 =\n    return 2\n"
    let consumerSource = Fmt"{importKw} cheng/private_helper_pkg/helper as helper\n\nfn main(): int32 =\n    let x = helper.privateFn()\n    return x\n"
    if !chengpath.WriteTextFile(rootDir, helperSrcPath, helperSource):
        return false
    if !chengpath.WriteTextFile(rootDir, consumerSrcPath, consumerSource):
        return false
    let outPath = chengpath.PathJoin(caseDir, "private_symbol")
    let logPath = chengpath.PathJoin(caseDir, "private_symbol.compile.log")
    let reportPath = Fmt"{outPath}.report.txt"
    var output = ""
    let exitCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                           compilerPath,
                                                           packageRoot,
                                                           consumerSrcPath,
                                                           outPath,
                                                           logPath,
                                                           output)
    if !BackendDriverDispatchMinCheckNegative(rootDir,
                                               "private symbol",
                                               exitCode,
                                               output,
                                               reportPath,
                                               "imported private symbol 'privateFn' is not exported",
                                               "unknown_qualified_target:helper:privateFn"):
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility private symbol ok")
    return true

fn BackendDriverDispatchMinVerifyStrformatCase(rootDir: str,
                                                compilerPath: str,
                                                packageRoot: str,
                                                caseDir: str,
                                                stem: str,
                                                sourceText: str,
                                                outputNeedle: str,
                                                reportNeedle: str): bool =
    let srcDir = chengpath.PathJoin(packageRoot, "src")
    if !BackendDriverDispatchMinEnsureDir(rootDir, srcDir):
        return false
    let srcPath = chengpath.PathJoin(srcDir, Fmt"{stem}.cheng")
    if !chengpath.WriteTextFile(rootDir, srcPath, sourceText):
        return false
    let outPath = chengpath.PathJoin(caseDir, stem)
    let logPath = chengpath.PathJoin(caseDir, Fmt"{stem}.compile.log")
    let reportPath = Fmt"{outPath}.report.txt"
    var output = ""
    let exitCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                           compilerPath,
                                                           packageRoot,
                                                           srcPath,
                                                           outPath,
                                                           logPath,
                                                           output)
    return BackendDriverDispatchMinCheckNegative(rootDir,
                                                  stem,
                                                  exitCode,
                                                  output,
                                                  reportPath,
                                                  outputNeedle,
                                                  reportNeedle)

fn BackendDriverDispatchMinVerifyStrformatNegative(rootDir: str,
                                                    compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "strformat_private")
    let packageRoot = chengpath.PathJoin(caseDir, "strformat_negative_pkg")
    if !BackendDriverDispatchMinWriteManifest(rootDir,
                                               packageRoot,
                                               "pkg://cheng/strformat_negative_pkg",
                                               "strformat_negative_pkg"):
        return false
    let importKw = "import"
    let fmtSource = Fmt"{importKw} std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.fmt(\"bad\")\n    echo(text)\n    return 0\n"
    if !BackendDriverDispatchMinVerifyStrformatCase(rootDir,
                                                     compilerPath,
                                                     packageRoot,
                                                     caseDir,
                                                     "fmt_private_main",
                                                     fmtSource,
                                                     "imported private symbol 'fmt' is not exported",
                                                     "unknown_qualified_target:strfmt:fmt"):
        return false
    let linesSource = Fmt"{importKw} std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.lines(\"bad\")\n    echo(text)\n    return 0\n"
    if !BackendDriverDispatchMinVerifyStrformatCase(rootDir,
                                                     compilerPath,
                                                     packageRoot,
                                                     caseDir,
                                                     "lines_private_main",
                                                     linesSource,
                                                     "imported private symbol 'lines' is not exported",
                                                     "unknown_qualified_target:strfmt:lines"):
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility strformat ok")
    return true

fn BackendDriverDispatchMinVerifyExportVisibility(rootDir: str): int32 =
    let compilerPath = BackendDriverDispatchMinCurrentCompiler(rootDir)
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct: missing compiler: {compilerPath}")
    if !BackendDriverDispatchMinVerifyExportPositive(rootDir, compilerPath):
        return 1
    if !BackendDriverDispatchMinVerifyPrivateNegative(rootDir, compilerPath):
        return 1
    if !BackendDriverDispatchMinVerifyStrformatNegative(rootDir, compilerPath):
        return 1
    os.WriteLine(os.Get_stdout(), "verify-export-visibility ok")
    return 0

fn BackendDriverDispatchMinVerifyExportVisibilityFromCmdline(): int32 =
    return 2

fn BackendDriverDispatchMinVerifyExportVisibilityParallelFromCmdline(): int32 =
    return 2

fn BackendDriverDispatchMinRunSystemLinkExecWithRequest(rootDir: str,
                                                         reqRes: Result[creq.CompilerRequest]): int32 =
    if IsErr(reqRes):
        return BackendDriverDispatchMinUnsupported(Error(reqRes))
    let reqBase = Value(reqRes)
    return BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(creq.CompilerRequestRootDir(reqBase), reqBase)

fn BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(driverRoot: str,
                                                             reqBase: creq.CompilerRequest): int32 =
    return BackendDriverDispatchMinRunSystemLinkExecConcreteFields(driverRoot,
                                                                   creq.CompilerRequestRootDir(reqBase),
                                                                   creq.CompilerRequestSourcePath(reqBase),
                                                                   creq.CompilerRequestOutputPath(reqBase),
                                                                   creq.CompilerRequestTargetTriple(reqBase),
                                                                   creq.CompilerRequestEmitKind(reqBase),
                                                                   creq.CompilerRequestReportPath(reqBase),
                                                                   creq.CompilerRequestSymbolVisibility(reqBase),
                                                                   creq.CompilerRequestBrowserBridgeObjectPath(reqBase))

fn BackendDriverDispatchMinRunSystemLinkExecConcreteFields(driverRoot: str,
                                                            packageRoot: str,
                                                            sourcePath: str,
                                                            outputPath: str,
                                                            targetTriple: str,
                                                            emitKind: creq.CompilerEmit,
                                                            reportPath: str,
                                                            symbolVisibility: str,
                                                            browserBridgeObjectPath: str): int32 =
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    BackendDriverDispatchMinProgress("system_link_plan", "begin")
    if !slplan.BuildSystemLinkPlanStubWithFields(driverRoot,
                                                  packageRoot,
                                                  sourcePath,
                                                  outputPath,
                                                  targetTriple,
                                                  emitKind,
                                                  symbolVisibility,
                                                  browserBridgeObjectPath,
                                                  linkPlan,
                                                  err):
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    Fmt"system_link_exec_runtime_execute=error\nerror={err}\n")
        return BackendDriverDispatchMinUnsupported(err)
    BackendDriverDispatchMinProgress("system_link_plan", "done")
    BackendDriverDispatchMinProgress("compiler_csg", "begin")
    let sourceBundleRes = linkPlan.sourceBundleCid
    if IsErr(sourceBundleRes):
        let sourceBundleErr = Error(sourceBundleRes)
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    Fmt"system_link_exec_runtime_execute=error\nerror={sourceBundleErr}\n")
        return BackendDriverDispatchMinUnsupported(sourceBundleErr)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, Value(sourceBundleRes))
    if IsErr(csgRes):
        let csgErr = Error(csgRes)
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    Fmt"system_link_exec_runtime_execute=error\nerror={csgErr}\n")
        return BackendDriverDispatchMinUnsupported(csgErr)
    var csg = Value(csgRes)
    BackendDriverDispatchMinProgress("compiler_csg", "done")
    var loweringPlan: lower.LoweringPlanStub
    BackendDriverDispatchMinProgress("lowering_plan", "begin")
    if !lower.BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, loweringPlan, err):
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    Fmt"system_link_exec_runtime_execute=error\nerror={err}\n")
        return BackendDriverDispatchMinUnsupported(err)
    BackendDriverDispatchMinProgress("lowering_plan", "done")
    BackendDriverDispatchMinProgress("primary_object_plan", "begin")
    let primaryRes = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    if IsErr(primaryRes):
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    Fmt"system_link_exec_runtime_execute=error\nerror={Error(primaryRes)}\n")
        return BackendDriverDispatchMinUnsupported(Error(primaryRes))
    let primaryPlan = Value(primaryRes)
    BackendDriverDispatchMinProgress("primary_object_plan", "done")
    if linkPlan.missingReasons.len > 0 ||
       loweringPlan.missingReasons.len > 0 ||
       primaryPlan.missingReasons.len > 0:
        var notReadyReport = ""
        BackendDriverDispatchMinAppendLine(notReadyReport, "system_link_exec_runtime_execute=0")
        BackendDriverDispatchMinAppendLine(notReadyReport, "error=plan_not_ready")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"system_link_plan_missing_count={linkPlan.missingReasons.len}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"lowering_plan_missing_count={loweringPlan.missingReasons.len}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"primary_object_missing_count={primaryPlan.missingReasons.len}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"primary_object_first_missing_function={primaryPlan.firstMissingFunction}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"primary_object_first_missing_body_kind={primaryPlan.firstMissingBodyKind}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"primary_object_first_missing_typed_ir_kind={primaryPlan.firstMissingTypedIrKind}")
        BackendDriverDispatchMinAppendLine(notReadyReport, Fmt"primary_object_first_missing_line_number={primaryPlan.firstMissingLineNumber}")
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    reportPath,
                                                    notReadyReport)
        BackendDriverDispatchMinPrintErr("backend driver direct system-link-exec: plan not ready")
        return 2
    let planBrowserBridgeObjectPath = slplan.SystemLinkPlanBrowserBridgeObjectPath(linkPlan)
    if Len(planBrowserBridgeObjectPath) > 0:
        return BackendDriverDispatchMinUnsupported("backend driver direct system-link-exec: browser bridge object not yet in direct runtime")
    if linkPlan.targetTriple == "wasm32-unknown-unknown":
        if linkPlan.emitKind != creq.EmitExe:
            let reason = Fmt"backend driver direct system-link-exec: unsupported wasm emit kind: {creq.CompilerEmitText(linkPlan.emitKind)}"
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=0\nerror={reason}\n")
            return BackendDriverDispatchMinUnsupported(reason)
        if !direct.DirectObjectEmitCanWasmMainModule(primaryPlan, linkPlan.outputPath):
            let validRes = direct.DirectObjectEmitValidateWasmMainModule(primaryPlan, linkPlan.outputPath)
            var reason = "backend driver direct system-link-exec: wasm direct emit not ready"
            if IsErr(validRes):
                reason = Error(validRes)
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=0\nerror={reason}\n")
            return BackendDriverDispatchMinUnsupported(reason)
        BackendDriverDispatchMinProgress("direct_wasm_emit", "begin")
        let wasmRes = direct.DirectObjectEmitWasmMainModule(driverRoot, primaryPlan, linkPlan.outputPath)
        if IsErr(wasmRes):
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=error\nerror={Error(wasmRes)}\n")
            return BackendDriverDispatchMinUnsupported(Error(wasmRes))
        let wasm = Value(wasmRes)
        BackendDriverDispatchMinProgress("direct_wasm_emit", "done")
        var wasmReport = ""
        BackendDriverDispatchMinAppendLine(wasmReport, "system_link_exec_runtime_execute=1")
        BackendDriverDispatchMinAppendLine(wasmReport, "system_link_exec_runtime_wasm_direct=1")
        BackendDriverDispatchMinAppendLine(wasmReport, "system_link_exec_runtime_standalone_no_runtime=1")
        BackendDriverDispatchMinAppendLine(wasmReport, Fmt"primary_object={wasm.objectPath}")
        BackendDriverDispatchMinAppendLine(wasmReport, "primary_object_format=wasm")
        BackendDriverDispatchMinAppendLine(wasmReport, "provider_object_count=0")
        BackendDriverDispatchMinAppendLine(wasmReport, "native_link_log=-")
        BackendDriverDispatchMinAppendLine(wasmReport, "line_map=-")
        BackendDriverDispatchMinAppendLine(wasmReport, "primary_object_direct=1")
        BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_bytes={wasm.bytesWritten}")
        BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_symbol_count={wasm.symbolCount}")
        BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_reloc_count={wasm.relocCount}")
        if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, wasmReport):
            return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
        return 0
    if linkPlan.emitKind == creq.EmitObj:
        if !direct.DirectObjectEmitCanPlanObject(primaryPlan):
            let validRes = direct.DirectObjectEmitValidatePlanObject(primaryPlan)
            var reason = "backend driver direct system-link-exec: object direct emit not ready"
            if IsErr(validRes):
                reason = Error(validRes)
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=0\nerror={reason}\n")
            return BackendDriverDispatchMinUnsupported(reason)
        BackendDriverDispatchMinProgress("direct_object_emit", "begin")
        let objectRes = direct.DirectObjectEmitPlanObject(driverRoot, primaryPlan)
        if IsErr(objectRes):
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=error\nerror={Error(objectRes)}\n")
            return BackendDriverDispatchMinUnsupported(Error(objectRes))
        let object = Value(objectRes)
        BackendDriverDispatchMinProgress("direct_object_emit", "done")
        var objectReport = ""
        BackendDriverDispatchMinAppendLine(objectReport, "system_link_exec_runtime_execute=1")
        BackendDriverDispatchMinAppendLine(objectReport, "system_link_exec_runtime_standalone_no_runtime=0")
        BackendDriverDispatchMinAppendLine(objectReport, "system_link_exec_runtime_standalone_direct_entry=0")
        BackendDriverDispatchMinAppendLine(objectReport, Fmt"primary_object={object.objectPath}")
        BackendDriverDispatchMinAppendLine(objectReport, "provider_object_count=0")
        BackendDriverDispatchMinAppendLine(objectReport, "native_link_log=-")
        BackendDriverDispatchMinAppendLine(objectReport, "line_map=-")
        BackendDriverDispatchMinAppendLine(objectReport, "primary_object_direct=1")
        BackendDriverDispatchMinAppendLine(objectReport, Fmt"direct_object_bytes={object.bytesWritten}")
        BackendDriverDispatchMinAppendLine(objectReport, Fmt"direct_object_symbol_count={object.symbolCount}")
        BackendDriverDispatchMinAppendLine(objectReport, Fmt"direct_object_reloc_count={object.relocCount}")
        if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, objectReport):
            return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
        return 0
    if linkPlan.emitKind == creq.EmitExe:
        if !direct.DirectObjectEmitCanStandaloneMain(primaryPlan):
            let validRes = direct.DirectObjectEmitValidateStandaloneMain(primaryPlan)
            var reason = "backend driver direct system-link-exec: non-standalone runtime path not ready"
            if IsErr(validRes):
                reason = Error(validRes)
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=0\nerror={reason}\n")
            return BackendDriverDispatchMinUnsupported(reason)
        BackendDriverDispatchMinProgress("direct_object_emit", "begin")
        let objectRes = direct.DirectObjectEmitStandaloneMain(driverRoot, primaryPlan)
        if IsErr(objectRes):
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=error\nerror={Error(objectRes)}\n")
            return BackendDriverDispatchMinUnsupported(Error(objectRes))
        let object = Value(objectRes)
        BackendDriverDispatchMinProgress("direct_object_emit", "done")
        let nativeLinkLogPath = Fmt"{linkPlan.outputPath}.native_link.log"
        let objectPath = chengpath.PathAbsolute(driverRoot, object.objectPath)
        let outputPath = chengpath.PathAbsolute(driverRoot, linkPlan.outputPath)
        let nativeCommand = Fmt"cc -arch arm64 {os.QuoteShell(objectPath)} -o {os.QuoteShell(outputPath)}"
        let nativeOptions: uint64 = 1
        BackendDriverDispatchMinProgress("native_link", "begin")
        let nativeRun = os.ExecShellCmdEx(nativeCommand, nativeOptions, driverRoot)
        BackendDriverDispatchMinProgress("native_link", "done")
        let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                    nativeLinkLogPath,
                                                    os.ExecCmdResultOutput(nativeRun))
        if os.ExecCmdResultExitCode(nativeRun) != 0:
            let reason = Fmt"backend driver direct system-link-exec: native link failed rc={os.ExecCmdResultExitCode(nativeRun)} log={nativeLinkLogPath}"
            let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                        reportPath,
                                                        Fmt"system_link_exec_runtime_execute=error\nerror={reason}\n")
            return BackendDriverDispatchMinUnsupported(reason)
        var exeReport = ""
        BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_execute=1")
        BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_no_runtime=1")
        BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_direct_entry=1")
        BackendDriverDispatchMinAppendLine(exeReport, Fmt"primary_object={object.objectPath}")
        BackendDriverDispatchMinAppendLine(exeReport, "provider_object_count=0")
        BackendDriverDispatchMinAppendLine(exeReport, Fmt"native_link_log={nativeLinkLogPath}")
        BackendDriverDispatchMinAppendLine(exeReport, "line_map=-")
        BackendDriverDispatchMinAppendLine(exeReport, "primary_object_direct=1")
        BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_bytes={object.bytesWritten}")
        BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_symbol_count={object.symbolCount}")
        BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_reloc_count={object.relocCount}")
        if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, exeReport):
            return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
        return 0
    let reason = Fmt"backend driver direct system-link-exec: unsupported emit kind: {creq.CompilerEmitText(linkPlan.emitKind)}"
    let _ = BackendDriverDispatchMinWriteReport(driverRoot,
                                                reportPath,
                                                Fmt"system_link_exec_runtime_execute=0\nerror={reason}\n")
    return BackendDriverDispatchMinUnsupported(reason)

fn BackendDriverDispatchMinReadFlagOrDefault(args: str[],
                                              key: str,
                                              defaultValue: str): str =
    for i in 0..<args.len:
        let arg = args[i]
        let colonKey = Fmt"{key}:"
        let eqKey = Fmt"{key}="
        if strings.HasPrefix(arg, colonKey):
            return strings.DropPrefix(arg, colonKey)
        if strings.HasPrefix(arg, eqKey):
            return strings.DropPrefix(arg, eqKey)
        if arg == key && i + 1 < args.len:
            return args[i + 1]
    return defaultValue

fn BackendDriverDispatchMinReadEmitKind(raw: str,
                                         emitKind: var creq.CompilerEmit,
                                         err: var str): bool =
    if Len(raw) <= 0 || raw == "exe":
        emitKind = creq.EmitExe
        err = ""
        return true
    if raw == "obj":
        emitKind = creq.EmitObj
        err = ""
        return true
    if raw == "shared":
        emitKind = creq.EmitShared
        err = ""
        return true
    err = Fmt" compiler: unsupported --emit: {raw}"
    return false

fn BackendDriverDispatchMinReadSymbolVisibility(raw: str,
                                                  visibility: var str,
                                                  err: var str): bool =
    if Len(raw) <= 0 || raw == "public":
        visibility = "public"
        err = ""
        return true
    if raw == "internal":
        visibility = "internal"
        err = ""
        return true
    err = Fmt" compiler: unsupported --symbol-visibility: {raw}"
    return false

fn BackendDriverDispatchMinRunSystemLinkExec(rootDir: str,
                                              args: str[]): int32 =
    let sourcePath = BackendDriverDispatchMinReadFlagOrDefault(args, "--in", "")
    if Len(sourcePath) <= 0:
        return BackendDriverDispatchMinUnsupported(" compiler: missing --in")
    var packageRoot = BackendDriverDispatchMinReadFlagOrDefault(args, "--root", "")
    if Len(packageRoot) <= 0:
        packageRoot = rootDir
    else:
        packageRoot = chengpath.PathAbsolute(rootDir, packageRoot)
    let outputPath = BackendDriverDispatchMinReadFlagOrDefault(args, "--out", "")
    if Len(outputPath) <= 0:
        return BackendDriverDispatchMinUnsupported(" compiler: missing --out")
    var targetTriple = BackendDriverDispatchMinReadFlagOrDefault(args, "--target", "")
    if Len(targetTriple) <= 0:
        targetTriple = "arm64-apple-darwin"
    var emitKind: creq.CompilerEmit
    var emitErr = ""
    let emitRaw = BackendDriverDispatchMinReadFlagOrDefault(args, "--emit", "exe")
    if !BackendDriverDispatchMinReadEmitKind(emitRaw, emitKind, emitErr):
        return BackendDriverDispatchMinUnsupported(emitErr)
    var symbolVisibility = ""
    var visibilityErr = ""
    let visibilityRaw = BackendDriverDispatchMinReadFlagOrDefault(args, "--symbol-visibility", "public")
    if !BackendDriverDispatchMinReadSymbolVisibility(visibilityRaw, symbolVisibility, visibilityErr):
        return BackendDriverDispatchMinUnsupported(visibilityErr)
    let reportPath = BackendDriverDispatchMinReadFlagOrDefault(args, "--report-out", "")
    let browserBridgeObjectPath = BackendDriverDispatchMinReadFlagOrDefault(args, "--browser-bridge-object", "")
    return BackendDriverDispatchMinRunSystemLinkExecConcreteFields(rootDir,
                                                                  packageRoot,
                                                                  sourcePath,
                                                                  outputPath,
                                                                  targetTriple,
                                                                  emitKind,
                                                                  reportPath,
                                                                  symbolVisibility,
                                                                  browserBridgeObjectPath)

fn BackendDriverDispatchMinRunSystemLinkExecFromCmdlineCount(rootDir: str,
                                                              count: int32): int32 =
    let args = BackendDriverDispatchMinCollectArgsFrom(2, count)
    return BackendDriverDispatchMinRunSystemLinkExec(rootDir, args)

fn BackendDriverDispatchMinRunSystemLinkExecFromCmdline(rootDir: str): int32 =
    let args: str[] = BackendDriverDispatchMinCollectArgsAfterCommandBridge()
    return BackendDriverDispatchMinRunSystemLinkExec(rootDir, args)

fn BackendDriverDispatchMinRunSystemLinkExecCommandFromCmdline(): int32 =
    let rootDir: str = BackendDriverDispatchMinCurrentDirBridge()
    return BackendDriverDispatchMinRunSystemLinkExecFromCmdline(rootDir)

fn BackendDriverDispatchMinRunCommandWithCmd(cmd: str): int32 =
    if cmd == "help" || cmd == "-h" || cmd == "--help":
        return BackendDriverDispatchMinHelp()
    if cmd == "status":
        return BackendDriverDispatchMinStatusFromCmdline()
    if cmd == "print-build-plan":
        return BackendDriverDispatchMinPrintBuildPlanCommandFromCmdline()
    if cmd == "verify-export-visibility":
        return BackendDriverDispatchMinVerifyExportVisibilityFromCmdline()
    if cmd == "verify-export-visibility-parallel":
        return BackendDriverDispatchMinVerifyExportVisibilityParallelFromCmdline()
    if cmd == "system-link-exec":
        return BackendDriverDispatchMinRunSystemLinkExecCommandFromCmdline()
    return 2

fn BackendDriverDispatchMinRunCommand(): int32 =
    let cmd: str = BackendDriverDispatchMinCliParam1Bridge()
    return BackendDriverDispatchMinRunCommandWithCmd(cmd)

fn BackendDriverDispatchMinRun(): int32 =
    let count: int32 = BackendDriverDispatchMinParamCountBridge()
    if count <= 0:
        return 0
    return BackendDriverDispatchMinRunCommand()

fn main(argc: int32, argv: str*): int32 =
    let code: int32 = BackendDriverDispatchMinRun()
    return code
