type
    BackendDriverDispatchMinTimeval =
        tv_sec: int64
        tv_usec: int64

    BackendDriverDispatchMinRusage =
        ru_utime: BackendDriverDispatchMinTimeval
        ru_stime: BackendDriverDispatchMinTimeval
        ru_maxrss: int64
        ru_ixrss: int64
        ru_idrss: int64
        ru_isrss: int64
        ru_minflt: int64
        ru_majflt: int64
        ru_nswap: int64
        ru_inblock: int64
        ru_oublock: int64
        ru_msgsnd: int64
        ru_msgrcv: int64
        ru_nsignals: int64
        ru_nvcsw: int64
        ru_nivcsw: int64

    BackendDriverDispatchMinPhaseProfile =
        totalStartNs: int64
        systemLinkPlanNs: int64
        compilerCsgNs: int64
        loweringPlanNs: int64
        primaryObjectPlanNs: int64
        directObjectEmitNs: int64
        providerObjectNs: int64
        nativeLinkNs: int64
        lineMapNs: int64
        totalNs: int64

@importc("cheng_monotime_ns")
fn BackendDriverDispatchMinMonoTimeNsBridge(): int64

@importc("getrusage")
fn BackendDriverDispatchMinGetrusageBridge(who: int32,
                                           usage: var BackendDriverDispatchMinRusage): int32

@importc("exit")
fn BackendDriverDispatchMinExitBridge(code: int32)

@importc("driver_c_write_error_report_bridge")
fn BackendDriverDispatchMinWriteErrorReportBridge(rootDir: str,
                                                   reportPath: str,
                                                   reason: str): int32

@importc("driver_c_read_flag_or_default_bridge")
fn BackendDriverDispatchMinReadFlagOrDefaultBridge(key: str,
                                                    defaultValue: str): str

@importc("paramCount")
fn BackendDriverDispatchMinParamCountBridge(): int32

@importc("__cheng_rt_paramStr")
fn BackendDriverDispatchMinParamStrRawBridge(i: int32): cstring

const
    BackendDriverDispatchMinProcessMemoryExceeded = 125
    BackendDriverDispatchMinRusageSelf = 0

fn BackendDriverDispatchMinPrintErr(text: str) =
    os.WriteLine(os.GetStderr(), text)

fn BackendDriverDispatchMinPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn BackendDriverDispatchMinParamCount(): int32 =
    return BackendDriverDispatchMinParamCountBridge()

fn BackendDriverDispatchMinParamStr(index: int32): str =
    let raw = BackendDriverDispatchMinParamStrRawBridge(index)
    if raw == nil:
        return ""
    return system.strFromCStringBorrow(raw)

fn BackendDriverDispatchMinEnsureParentDir(rootDir: str,
                                            pathRaw: str): bool =
    let parent = chengpath.PathParentDir(chengpath.PathAbsolute(rootDir, pathRaw))
    if len(parent) <= 0:
        return true
    return chengpath.MkdirP(rootDir, parent)

fn BackendDriverDispatchMinWriteReport(rootDir: str,
                                        reportPath: str,
                                        reportText: str): bool =
    if len(reportPath) <= 0:
        return true
    if !BackendDriverDispatchMinEnsureParentDir(rootDir, reportPath):
        return false
    return chengpath.WriteTextFile(rootDir, reportPath, reportText)

fn BackendDriverDispatchMinAppendLine(out: var str,
                                       line: str) =
    if len(out) > 0:
        out = Fmt"{out}\n"
    out = Fmt"{out}{line}"

fn BackendDriverDispatchMinNowNs(): int64 =
    return BackendDriverDispatchMinMonoTimeNsBridge()

fn BackendDriverDispatchMinPhaseMsText(ns: int64): str =
    if ns <= int64(0):
        return "0"
    return int64ToStr(ns / int64(1000000))

fn BackendDriverDispatchMinRefreshPhaseProfile(profile: var BackendDriverDispatchMinPhaseProfile) =
    if profile.totalStartNs > int64(0):
        profile.totalNs = BackendDriverDispatchMinNowNs() - profile.totalStartNs

fn BackendDriverDispatchMinAppendPhaseReport(out: var str,
                                              profile: var BackendDriverDispatchMinPhaseProfile) =
    BackendDriverDispatchMinRefreshPhaseProfile(profile)
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_system_link_plan_ms={BackendDriverDispatchMinPhaseMsText(profile.systemLinkPlanNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_compiler_csg_ms={BackendDriverDispatchMinPhaseMsText(profile.compilerCsgNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_lowering_plan_ms={BackendDriverDispatchMinPhaseMsText(profile.loweringPlanNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_primary_object_plan_ms={BackendDriverDispatchMinPhaseMsText(profile.primaryObjectPlanNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_direct_object_emit_ms={BackendDriverDispatchMinPhaseMsText(profile.directObjectEmitNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_provider_objects_ms={BackendDriverDispatchMinPhaseMsText(profile.providerObjectNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_native_link_ms={BackendDriverDispatchMinPhaseMsText(profile.nativeLinkNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_line_map_ms={BackendDriverDispatchMinPhaseMsText(profile.lineMapNs)}")
    BackendDriverDispatchMinAppendLine(out, Fmt"exec_phase_total_ms={BackendDriverDispatchMinPhaseMsText(profile.totalNs)}")
    var functionTaskJobCount = 1
    let backendJobsRaw = os.GetEnv("BACKEND_JOBS")
    if len(backendJobsRaw) > 0:
        let parsed = strutil.ParseInt(backendJobsRaw)
        if parsed > 0:
            functionTaskJobCount = parsed
    BackendDriverDispatchMinAppendLine(out, Fmt"function_task_job_count={functionTaskJobCount}")
    BackendDriverDispatchMinAppendLine(out, "function_task_schedule=serial")

fn BackendDriverDispatchMinAppendResourceReport(out: var str) =
    let cpuUs = BackendDriverDispatchMinCurrentCpuUs()
    let rssBytes = BackendDriverDispatchMinCurrentRssBytes()
    BackendDriverDispatchMinAppendLine(out, Fmt"report_cpu_us={cpuUs}")
    BackendDriverDispatchMinAppendLine(out, Fmt"report_rss_bytes={rssBytes}")

fn BackendDriverDispatchMinAppendOutputFileSizeReport(out: var str,
                                                       rootDir: str,
                                                       outputPath: str) =
    let outputAbs = chengpath.PathAbsolute(rootDir, outputPath)
    var outputBytes: int64
    if chengpath.PathFileExists(outputAbs):
        outputBytes = chengpath.PathFileSize(outputAbs)
    BackendDriverDispatchMinAppendLine(out, Fmt"output_file_size_bytes={outputBytes}")

fn BackendDriverDispatchMinAppendPrimaryPlanReport(out: var str,
                                                    primaryPlan: pobj.PrimaryObjectPlan) =
    var missingReasons = "-"
    if primaryPlan.missingReasons.len > 0:
        missingReasons = BackendDriverDispatchMinCsv(primaryPlan.missingReasons)
    var firstMissingFunction = "-"
    if len(primaryPlan.firstMissingFunction) > 0:
        firstMissingFunction = primaryPlan.firstMissingFunction
    var firstMissingBodyKind = "-"
    if len(primaryPlan.firstMissingBodyKind) > 0:
        firstMissingBodyKind = primaryPlan.firstMissingBodyKind
    var firstMissingTypedIrKind = "-"
    if len(primaryPlan.firstMissingTypedIrKind) > 0:
        firstMissingTypedIrKind = primaryPlan.firstMissingTypedIrKind
    BackendDriverDispatchMinAppendLine(out, "primary_object_probe_summary=-")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_missing_reasons={missingReasons}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_item_count={primaryPlan.itemIds.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_symbol_count={primaryPlan.symbolNames.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_function_word_offset_count={primaryPlan.functionWordOffsets.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_function_word_count_count={primaryPlan.functionWordCounts.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_body_kind_count={primaryPlan.functionBodyKinds.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_instruction_word_count={primaryPlan.instructionWords.len}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_function={firstMissingFunction}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_kind={firstMissingBodyKind}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_typed_ir_kind={firstMissingTypedIrKind}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_line_number={primaryPlan.firstMissingLineNumber}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_call_target_ordinal={primaryPlan.firstMissingCallTargetOrdinal}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_call_target={primaryPlan.firstMissingCallTarget}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_call_target_source_path={primaryPlan.firstMissingCallTargetSourcePath}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_word_offset={primaryPlan.firstMissingWordOffset}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_word_rel_offset={primaryPlan.firstMissingWordRelOffset}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_word_count={primaryPlan.firstMissingWordCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_op_count={primaryPlan.firstMissingBodyIrOpCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_term_count={primaryPlan.firstMissingBodyIrTermCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_block_count={primaryPlan.firstMissingBodyIrBlockCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_call_count={primaryPlan.firstMissingBodyIrCallCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_slot_count={primaryPlan.firstMissingBodyIrSlotCount}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_term_kind={primaryPlan.firstMissingBodyIrLastTermKind}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_term_result_slot={primaryPlan.firstMissingBodyIrLastTermResultSlot}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_term_operand0={primaryPlan.firstMissingBodyIrLastTermOperand0}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_term_result_type={primaryPlan.firstMissingBodyIrLastTermResultType}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_call_result_slot={primaryPlan.firstMissingBodyIrLastCallResultSlot}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_call_result_type={primaryPlan.firstMissingBodyIrLastCallResultType}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_call_target={primaryPlan.firstMissingBodyIrLastCallTarget}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_last_call_target_source_path={primaryPlan.firstMissingBodyIrLastCallTargetSourcePath}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_index={primaryPlan.firstMissingBodyIrFirstZeroOpIndex}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_kind={primaryPlan.firstMissingBodyIrFirstZeroOpKind}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_target={primaryPlan.firstMissingBodyIrFirstZeroOpTarget}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_operand0={primaryPlan.firstMissingBodyIrFirstZeroOpOperand0}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_operand1={primaryPlan.firstMissingBodyIrFirstZeroOpOperand1}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_op_operand2={primaryPlan.firstMissingBodyIrFirstZeroOpOperand2}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_term_index={primaryPlan.firstMissingBodyIrFirstZeroTermIndex}")
    BackendDriverDispatchMinAppendLine(out, Fmt"primary_object_first_missing_body_ir_first_zero_term_kind={primaryPlan.firstMissingBodyIrFirstZeroTermKind}")
