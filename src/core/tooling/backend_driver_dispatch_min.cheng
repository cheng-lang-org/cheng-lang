    BackendDriverDispatchMinAppendLine(out, "primary_object_first_call_sequence_drift_ordinal=0")
    BackendDriverDispatchMinAppendLine(out, "primary_object_first_call_sequence_drift_legacy_count=0")
    BackendDriverDispatchMinAppendLine(out, "primary_object_first_call_sequence_drift_body_ir_count=0")
    BackendDriverDispatchMinAppendLine(out, "primary_object_first_call_sequence_drift_reason=-")

fn BackendDriverDispatchMinCsv(items: str[]): str =
    return strutil.Join(items, ",")

fn BackendDriverDispatchMinSplitCsv(text: str): str[] =
    var out: str[]
    let parts = strutil.Split(text, ',')
    for i in 0..<parts.len:
        let item = strutil.Strip(parts[i])
        if len(item) > 0:
            add(out, item)
    return out

fn BackendDriverDispatchMinAddRootUnique(out: var str[],
                                          seen: var ccsg.CompilerCsgTextSet,
                                          value: str) =
    if len(value) <= 0:
        return
    if ccsg.CompilerCsgTextSetInsert(seen, value):
        add(out, value)

fn BackendDriverDispatchMinParseUnsignedInt64(raw: str): int64 =
    if len(raw) <= 0:
        return int64(-1)
    var value: int64
    var hadDigit = false
    var trailingSpace = false
    for i in 0..<len(raw):
        let ch = raw[i]
        if ch >= '0' && ch <= '9':
            if trailingSpace:
                return int64(-1)
            value = value * int64(10) + int64(int32(ch) - int32('0'))
            hadDigit = true
        elif ch == ' ' || ch == '\n' || ch == '\t' || ch == '\r':
            if hadDigit:
                trailingSpace = true
        else:
            return int64(-1)
    if !hadDigit:
        return int64(-1)
    return value

fn BackendDriverDispatchMinDefaultMaxRssBytes(): int64 =
    return int64(8589934592)

fn BackendDriverDispatchMinConfiguredMaxRssBytes(): int64 =
    let parentGuardRaw = os.GetEnv("PARENT_RSS_GUARD")
    if strings.Len(parentGuardRaw) > 0:
        return int64(0)
    var raw = os.GetEnv("PROCESS_MAX_RSS_BYTES")
    if strings.Len(raw) <= 0:
        raw = os.GetEnv("MAX_RSS_BYTES")
    if strings.Len(raw) <= 0:
        return BackendDriverDispatchMinDefaultMaxRssBytes()
    let parsed = BackendDriverDispatchMinParseUnsignedInt64(raw)
    if parsed <= int64(0):
        return int64(-1)
    return parsed

fn BackendDriverDispatchMinCurrentRssBytes(): int64 =
    var usage: BackendDriverDispatchMinRusage
    if BackendDriverDispatchMinGetrusageBridge(BackendDriverDispatchMinRusageSelf, usage) != 0:
        return int64(-1)
    if usage.ru_maxrss <= int64(0):
        return int64(-1)
    return usage.ru_maxrss

fn BackendDriverDispatchMinCurrentCpuUs(): int64 =
    var usage: BackendDriverDispatchMinRusage
    if BackendDriverDispatchMinGetrusageBridge(BackendDriverDispatchMinRusageSelf, usage) != 0:
        return int64(-1)
    let userUs = usage.ru_utime.tv_sec * int64(1000000) + usage.ru_utime.tv_usec
    let sysUs = usage.ru_stime.tv_sec * int64(1000000) + usage.ru_stime.tv_usec
    return userUs + sysUs

fn BackendDriverDispatchMinMemoryLimitExceededLine(rssBytes: int64,
                                                    maxRssBytes: int64): str =
    return Fmt"compile_progress phase=resource_guard status=rss_limit_exceeded rss_bytes={rssBytes} limit_bytes={maxRssBytes}"

fn BackendDriverDispatchMinResourceGuardCheckWithMax(maxRssBytes: int64) =
    if maxRssBytes == int64(0):
        return
    if maxRssBytes < int64(0):
        BackendDriverDispatchMinPrintErr("compile_progress phase=resource_guard status=invalid_max_rss")
        BackendDriverDispatchMinExitBridge(2)
    let rssBytes = BackendDriverDispatchMinCurrentRssBytes()
    if rssBytes <= int64(0):
        BackendDriverDispatchMinPrintErr("compile_progress phase=resource_guard status=rss_unavailable")
        BackendDriverDispatchMinExitBridge(2)
    if rssBytes > maxRssBytes:
        BackendDriverDispatchMinPrintErr(BackendDriverDispatchMinMemoryLimitExceededLine(rssBytes, maxRssBytes))
        BackendDriverDispatchMinExitBridge(BackendDriverDispatchMinProcessMemoryExceeded)

fn BackendDriverDispatchMinProgressResourceGuardCheck() =
    let maxRssBytes = BackendDriverDispatchMinConfiguredMaxRssBytes()
    BackendDriverDispatchMinResourceGuardCheckWithMax(maxRssBytes)

fn BackendDriverDispatchMinProgressEnabled(): bool =
    let raw = os.GetEnv("PROGRESS")
    return len(raw) > 0 && raw != "0" && raw != "false"

fn BackendDriverDispatchMinTruthyEnv(name: str): bool =
    let raw = os.GetEnv(name)
    return len(raw) > 0 && raw != "0" && raw != "false"

fn BackendDriverDispatchMinRequirePureSystemLinkExec(): bool =
    return BackendDriverDispatchMinTruthyEnv("CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC")

fn BackendDriverDispatchMinProgress(phase: str,
                                     status: str): int32 =
    BackendDriverDispatchMinProgressResourceGuardCheck()
    return 0

fn BackendDriverDispatchMinUnsupported(reason: str): int32 =
    BackendDriverDispatchMinPrintErr(reason)
    return 2

fn BackendDriverDispatchMinStartsWith(text: str,
                                       prefix: str): bool =
    if len(prefix) > len(text):
        return false
    return strings.SliceBytes(text, 0, len(prefix)) == prefix

fn BackendDriverDispatchMinFlagValueExact(raw: str,
                                           key: str): str =
    let colonKey = Fmt"{key}:"
    if BackendDriverDispatchMinStartsWith(raw, colonKey):
        return strings.SliceBytes(raw, len(colonKey), len(raw) - len(colonKey))
    let eqKey = Fmt"{key}="
    if BackendDriverDispatchMinStartsWith(raw, eqKey):
        return strings.SliceBytes(raw, len(eqKey), len(raw) - len(eqKey))
    return ""

fn BackendDriverDispatchMinEmitKindFromText(raw: str,
                                             outKind: var creq.CompilerEmit): bool =
    if raw == "exe":
        outKind = creq.EmitExe
        return true
    if raw == "obj":
        outKind = creq.EmitObj
        return true
    if raw == "shared":
        outKind = creq.EmitShared
        return true
    return false

fn BackendDriverDispatchMinEmitTextSupported(raw: str): bool =
    let n = len(raw)
    if n == 3:
        if raw[0] == 'e' && raw[1] == 'x' && raw[2] == 'e':
            return true
        if raw[0] == 'o' && raw[1] == 'b' && raw[2] == 'j':
            return true
        return false
    if n == 6 &&
       raw[0] == 's' &&
       raw[1] == 'h' &&
       raw[2] == 'a' &&
       raw[3] == 'r' &&
       raw[4] == 'e' &&
       raw[5] == 'd':
        return true
    return false

fn BackendDriverDispatchMinEmitTextIsObj(raw: str): bool =
    let n = len(raw)
    return n == 3 && raw[0] == 'o' && raw[1] == 'b' && raw[2] == 'j'

fn BackendDriverDispatchMinEmitTextIsShared(raw: str): bool =
    let n = len(raw)
    return n == 6 &&
           raw[0] == 's' &&
           raw[1] == 'h' &&
           raw[2] == 'a' &&
           raw[3] == 'r' &&
           raw[4] == 'e' &&
           raw[5] == 'd'

fn BackendDriverDispatchMinSymbolVisibilityValue(raw: str): str =
    if len(raw) <= 0:
        return "public"
    return raw

fn BackendDriverDispatchMinSymbolVisibilitySupported(raw: str): bool =
    let value = BackendDriverDispatchMinSymbolVisibilityValue(raw)
    let n = len(value)
    if n == 6 &&
       value[0] == 'p' &&
       value[1] == 'u' &&
       value[2] == 'b' &&
       value[3] == 'l' &&
       value[4] == 'i' &&
       value[5] == 'c':
        return true
    if n == 8 &&
       value[0] == 'i' &&
       value[1] == 'n' &&
       value[2] == 't' &&
       value[3] == 'e' &&
       value[4] == 'r' &&
       value[5] == 'n' &&
       value[6] == 'a' &&
       value[7] == 'l':
        return true
    return false

fn BackendDriverDispatchMinUnsupportedEmitText(rootDir: str,
                                                reportPath: str,
                                                emitText: str): int32 =
    let reason = Fmt"backend driver direct system-link-exec: unsupported --emit: {emitText}"
    let _ = BackendDriverDispatchMinWriteErrorReportBridge(rootDir,
                                                           reportPath,
                                                           reason)
    return BackendDriverDispatchMinUnsupported(reason)

fn BackendDriverDispatchMinUnsupportedSymbolVisibility(rootDir: str,
                                                        reportPath: str,
                                                        symbolVisibility: str): int32 =
    let reason = Fmt"backend driver direct system-link-exec: unsupported --symbol-visibility: {symbolVisibility}"
    let _ = BackendDriverDispatchMinWriteErrorReportBridge(rootDir,
                                                           reportPath,
                                                           reason)
    return BackendDriverDispatchMinUnsupported(reason)

fn BackendDriverDispatchMinCollectArgsFrom(startIndex: int32,
                                            count: int32): str[] =
    var out: str[]
    if startIndex <= 0:
        return out
    if count < startIndex:
        return out
    for i in startIndex..count:
        add(out, BackendDriverDispatchMinParamStr(i))
    return out

fn BackendDriverDispatchMinReadFlagOrDefault(key: str,
                                              defaultValue: str): str =
    return BackendDriverDispatchMinReadFlagOrDefaultBridge(key, defaultValue)

fn BackendDriverDispatchMinStatus(): int32 =
    BackendDriverDispatchMinPrintLine("cheng")
    BackendDriverDispatchMinPrintLine("version=cheng.compiler_runtime.v1")
    BackendDriverDispatchMinPrintLine("execution=argv_control_plane")
    BackendDriverDispatchMinPrintLine("bootstrap_mode=selfhost")
    BackendDriverDispatchMinPrintLine("compiler_entry=src/core/tooling/backend_driver_dispatch_min.cheng")
    BackendDriverDispatchMinPrintLine("ordinary_command=system-link-exec")
    BackendDriverDispatchMinPrintLine("ordinary_pipeline=canonical_csg_verified_primary_object_codegen_ready")
    BackendDriverDispatchMinPrintLine("stage3=artifacts/bootstrap/cheng.stage3")
    return 0

fn BackendDriverDispatchMinStatusFromCmdline(): int32 =
    let statusCode = BackendDriverDispatchMinStatus()
    let packageRoot = BackendDriverDispatchMinReadFlagOrDefault("--root", "")
    let sourcePath = BackendDriverDispatchMinReadFlagOrDefault("--in", "")
    let outputPath = BackendDriverDispatchMinReadFlagOrDefault("--out", "")
    if packageRoot == "" && sourcePath == "" && outputPath == "":
        return statusCode
    BackendDriverDispatchMinPrintLine(Fmt"flag_root={packageRoot}")
    BackendDriverDispatchMinPrintLine(Fmt"flag_in={sourcePath}")
    if packageRoot == "" || sourcePath == "" || outputPath == "":
        BackendDriverDispatchMinPrintLine("flag_exec_edges=err")
        BackendDriverDispatchMinPrintLine("flag_exec_unresolved=missing_required_status_flag")
        return 2
    var linkPlan: slplan.SystemLinkPlanStub
    var err: str
    if !slplan.BuildSystemLinkPlanStubWithFields(packageRoot,
                                                  packageRoot,
                                                  sourcePath,
                                                  outputPath,
                                                  "arm64-apple-darwin",
                                                  creq.EmitExe,
                                                  "public",
                                                  "",
                                                  linkPlan,
                                                  err):
        BackendDriverDispatchMinPrintLine("flag_exec_edges=err")
        BackendDriverDispatchMinPrintLine(Fmt"flag_exec_unresolved={err}")
        return 2
    if linkPlan.missingReasons.len > 0:
        let missingText = strutil.Join(linkPlan.missingReasons, ",")
        BackendDriverDispatchMinPrintLine("flag_exec_edges=err")
        BackendDriverDispatchMinPrintLine(Fmt"flag_exec_unresolved={missingText}")
        return 2
    BackendDriverDispatchMinPrintLine(Fmt"flag_exec_edges={linkPlan.importEdgeCount}")
    BackendDriverDispatchMinPrintLine(Fmt"flag_exec_unresolved={linkPlan.unresolvedImportCount}")
    return statusCode

fn BackendDriverDispatchMinPrintBuildPlan(): int32 =
    BackendDriverDispatchMinPrintLine("target=arm64-apple-darwin")
    BackendDriverDispatchMinPrintLine("linker=system_link")
    BackendDriverDispatchMinPrintLine("stage2_compiler=artifacts/bootstrap/cheng.stage2")
    BackendDriverDispatchMinPrintLine("entry=src/core/tooling/backend_driver_dispatch_min.cheng")
    BackendDriverDispatchMinPrintLine("output=artifacts/backend_driver/cheng")
    BackendDriverDispatchMinPrintLine("source[0]=backend_driver_entry_source:src/core/tooling/backend_driver_dispatch_min.cheng")
    BackendDriverDispatchMinPrintLine("source[1]=backend_system_link_plan_source:src/core/backend/system_link_plan.cheng")
    BackendDriverDispatchMinPrintLine("source[2]=backend_lowering_plan_source:src/core/backend/lowering_plan.cheng")
    BackendDriverDispatchMinPrintLine("source[3]=backend_primary_object_plan_source:src/core/backend/primary_object_plan.cheng")
    BackendDriverDispatchMinPrintLine("source[4]=backend_aarch64_encode_source:src/core/backend/aarch64_encode.cheng")
    BackendDriverDispatchMinPrintLine("source[5]=backend_direct_object_emit_source:src/core/backend/direct_object_emit.cheng")
    BackendDriverDispatchMinPrintLine("source[6]=backend_line_map_source:src/core/backend/line_map.cheng")
    BackendDriverDispatchMinPrintLine("source[7]=backend_system_link_exec_runtime_source:src/core/backend/system_link_exec_runtime.cheng")
    BackendDriverDispatchMinPrintLine("source[8]=backend_system_link_exec_runtime_direct_source:src/core/backend/system_link_exec_runtime_direct.cheng")
    BackendDriverDispatchMinPrintLine("source[9]=backend_build_plan_source:src/core/backend/build_plan.cheng")
    return 0

fn BackendDriverDispatchMinPrintBuildPlanFromCmdline(): int32 =
    return BackendDriverDispatchMinPrintBuildPlan()

fn BackendDriverDispatchMinPrintBuildPlanCommandFromCmdline(): int32 =
    return BackendDriverDispatchMinPrintBuildPlanFromCmdline()

fn BackendDriverDispatchMinHelp(): int32 =
    BackendDriverDispatchMinPrintLine("usage: cheng <command> [args]")
    BackendDriverDispatchMinPrintLine("core commands: status, print-build-plan, system-link-exec")
    return 0

fn BackendDriverDispatchMinCurrentCompiler(rootDir: str): str =
    let noHandoffText = strutil.Strip(os.GetEnv("CHENG_NO_BACKEND_DRIVER_HANDOFF"))
    let noHandoffForced = len(noHandoffText) > 0 && noHandoffText != "0"
    if noHandoffForced:
        let stage0 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage0")
        if chengpath.FileExistsNonEmpty(rootDir, stage0):
            return stage0
        let stage3 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")
        if chengpath.FileExistsNonEmpty(rootDir, stage3):
            return stage3
    let handoffText = strutil.Strip(os.GetEnv("CHENG_BACKEND_DRIVER_HANDOFF"))
    let handoffEnabled = len(handoffText) > 0 && handoffText != "0"
    let handoffDisabled = !handoffEnabled
    if handoffDisabled:
        let stage0 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage0")
        if chengpath.FileExistsNonEmpty(rootDir, stage0):
            return stage0
        let stage3 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")
        if chengpath.FileExistsNonEmpty(rootDir, stage3):
            return stage3
    let raw = BackendDriverDispatchMinParamStr(0)
    if len(raw) <= 0:
        return ""
    return chengpath.PathAbsolute(rootDir, raw)

fn BackendDriverDispatchMinArtifactsDir(rootDir: str): str =
    let custom = os.GetEnv("VERIFY_EXPORT_VISIBILITY_DIR")
    if len(custom) > 0:
        return chengpath.PathAbsolute(rootDir, custom)
    return chengpath.PathAbsolute(rootDir, "artifacts/forward/verify_export_visibility")

fn BackendDriverDispatchMinEnsureDir(rootDir: str,
                                      dirPath: str): bool =
    if chengpath.MkdirP(rootDir, dirPath):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: failed to create dir: {dirPath}")
    return false

fn BackendDriverDispatchMinWriteManifest(rootDir: str,
                                          packageRoot: str,
                                          packageId: str,
                                          modulePrefix: str): bool =
    let manifestPath = chengpath.PathJoin(packageRoot, "cheng-package.toml")
    let manifestText = Fmt"package_id = \"{packageId}\"\nmodule_prefix = \"{modulePrefix}\"\n"
    if chengpath.WriteTextFile(rootDir, manifestPath, manifestText):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: failed to write manifest: {manifestPath}")
    return false

fn BackendDriverDispatchMinCompileFixture(rootDir: str,
                                           compilerPath: str,
                                           packageRoot: str,
                                           inputPath: str,
                                           outPath: str,
                                           logPath: str,
                                           outOutput: var str): int32 =
    let reportPath = Fmt"{outPath}.report.txt"
    let command = Fmt"PARENT_RSS_GUARD=1 PROGRESS=1 PROCESS_MAX_RSS_BYTES=8589934592 {os.QuoteShell(compilerPath)} system-link-exec --root:{os.QuoteShell(packageRoot)} --in:{os.QuoteShell(inputPath)} --emit:exe --target:arm64-apple-darwin --out:{os.QuoteShell(outPath)} --report-out:{os.QuoteShell(reportPath)}"
    let run = os.ExecShellCmdEx(command, uint64(1), rootDir)
    outOutput = os.ExecCmdResultOutput(run)
    let _ = chengpath.WriteTextFile(rootDir, logPath, outOutput)
    return os.ExecCmdResultExitCode(run)

fn BackendDriverDispatchMinProviderModuleSafeName(modulePath: str): str =
    if modulePath == "runtime/compiler_runtime":
        return "runtime_compiler_runtime"
    if modulePath == "runtime/core_runtime":
        return "runtime_core_runtime"
    if modulePath == "runtime/debug_runtime":
        return "runtime_debug_runtime"
    if modulePath == "runtime/program_support":
        return "runtime_program_support"
    if modulePath == "runtime/program_support_get_env_bridge":
        return "runtime_program_support_get_env_bridge"
    if modulePath == "runtime/program_support_host_runtime":
        return "runtime_program_support_host_runtime"
    return "runtime_unknown"

fn BackendDriverDispatchMinProviderSourcePath(rootDir: str,
                                               linkPlan: slplan.SystemLinkPlanStub,
                                               modulePath: str): str =
    if modulePath == "runtime/compiler_runtime":
        if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
            return chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng")
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_program_entry_provider.cheng")
    if modulePath == "runtime/core_runtime":
        if linkPlan.targetTriple == "arm64-apple-darwin":
            return chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_darwin.cheng")
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_linux.cheng")
    if modulePath == "runtime/debug_runtime":
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/debug_runtime_stub.cheng")
    if modulePath == "runtime/program_support":
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_backend.cheng")
    if modulePath == "runtime/program_support_get_env_bridge":
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_get_env_bridge.cheng")
    if modulePath == "runtime/program_support_host_runtime":
        return chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_host_runtime.cheng")
    return ""

fn BackendDriverDispatchMinProgramSupportRootCandidate(symbol: str): bool =
    if chengpath.TextContains(symbol, "debug_profile_flush_from_argv0"):
        return false
    if chengpath.TextContains(symbol, "native_register_line_map_from_argv0"):
        return false
    if chengpath.TextContains(symbol, "driver_c_get_env_bridge"):
        return false
    if chengpath.TextContains(symbol, "driver_c_") ||
       chengpath.TextContains(symbol, "cheng_mem_") ||
       chengpath.TextContains(symbol, "alloc") ||
       chengpath.TextContains(symbol, "copyMem"):
        return true
    if chengpath.TextContains(symbol, "driver_c_"):
        return true
    if chengpath.TextContains(symbol, "__cheng"):
        return true
    if chengpath.TextContains(symbol, "alloc") ||
       chengpath.TextContains(symbol, "copyMem") ||
       chengpath.TextContains(symbol, "setMem") ||
       chengpath.TextContains(symbol, "ptr_add") ||
       chengpath.TextContains(symbol, "store_ptr") ||
       chengpath.TextContains(symbol, "load_ptr") ||
       chengpath.TextContains(symbol, "store_int32") ||
       chengpath.TextContains(symbol, "load_int32") ||
       chengpath.TextContains(symbol, "paramCount") ||
       chengpath.TextContains(symbol, "paramStr"):
        return true
    return false

fn BackendDriverDispatchMinProviderExportRoots(modulePath: str,
                                                primaryPlan: pobj.PrimaryObjectPlan): str =
    if modulePath == "runtime/compiler_runtime":
        return "main"
    if modulePath == "runtime/program_support_get_env_bridge":
        return "driver_c_get_env_bridge"
    if modulePath == "runtime/debug_runtime":
        return "cheng_debug_profile_flush_from_argv0,cheng_native_register_line_map_from_argv0,cheng_native_dump_backtrace_and_exit"
    var roots: str[]
    var seen = ccsg.CompilerCsgTextSetInit(primaryPlan.relocTargetSymbols.len + 32)
    if modulePath == "runtime/program_support_host_runtime":
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_program_support_host_trace")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_malloc")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_free")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_realloc")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_puts_runtime")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_fopen")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_fclose")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_exit_runtime")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_host_getenv")
        for i in 0..<primaryPlan.relocTargetSymbols.len:
            let symbol = primaryPlan.relocTargetSymbols[i]
            if chengpath.TextContains(symbol, "host_") ||
               symbol == "program_support_host_trace" ||
               symbol == "_program_support_host_trace":
                BackendDriverDispatchMinAddRootUnique(roots, seen, symbol)
        return BackendDriverDispatchMinCsv(roots)
    if modulePath == "runtime/program_support":
        BackendDriverDispatchMinAddRootUnique(roots, seen, "copyMem")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "setMem")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "ptr_add")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "store_ptr")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "load_ptr")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_malloc")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_free")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_mem_retain")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_mem_release")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_register_line_map_from_argv0")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_cstrlen")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "cheng_str_to_cstring_temp_bridge")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "driver_c_str_from_utf8_copy_bridge")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "paramCount")
        BackendDriverDispatchMinAddRootUnique(roots, seen, "paramStr")
        for i in 0..<primaryPlan.functionBodyKinds.len:
            if primaryPlan.functionBodyKinds[i] == "entry_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "__cheng_setCmdLine")
        for i in 0..<primaryPlan.relocTargetSymbols.len:
            let symbol = primaryPlan.relocTargetSymbols[i]
            if BackendDriverDispatchMinProgramSupportRootCandidate(symbol):
                BackendDriverDispatchMinAddRootUnique(roots, seen, symbol)
        return BackendDriverDispatchMinCsv(roots)
    if modulePath == "runtime/core_runtime":
        BackendDriverDispatchMinAddRootUnique(roots, seen, "core_runtime_stub_trace")
        for i in 0..<primaryPlan.relocTargetSymbols.len:
            let symbol = primaryPlan.relocTargetSymbols[i]
            if symbol == "core_runtime_stub_trace" || symbol == "_core_runtime_stub_trace":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "core_runtime_stub_trace")
            if symbol == "native_errno_code_bridge" || symbol == "_native_errno_code_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_errno_code_bridge")
            if symbol == "native_af_inet_bridge" || symbol == "_native_af_inet_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_af_inet_bridge")
            if symbol == "native_af_inet6_bridge" || symbol == "_native_af_inet6_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_af_inet6_bridge")
            if symbol == "native_sock_stream_bridge" || symbol == "_native_sock_stream_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_sock_stream_bridge")
            if symbol == "native_sock_dgram_bridge" || symbol == "_native_sock_dgram_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_sock_dgram_bridge")
            if symbol == "native_ipproto_ip_bridge" || symbol == "_native_ipproto_ip_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_ipproto_ip_bridge")
            if symbol == "native_sol_socket_bridge" || symbol == "_native_sol_socket_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_sol_socket_bridge")
            if symbol == "native_so_reuseaddr_bridge" || symbol == "_native_so_reuseaddr_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_so_reuseaddr_bridge")
            if symbol == "native_so_broadcast_bridge" || symbol == "_native_so_broadcast_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_so_broadcast_bridge")
            if symbol == "native_msg_waitall_bridge" || symbol == "_native_msg_waitall_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_msg_waitall_bridge")
            if symbol == "native_sockaddr_use_len_field_bridge" || symbol == "_native_sockaddr_use_len_field_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_sockaddr_use_len_field_bridge")
            if symbol == "native_system_cpu_logical_cores_value_bridge" || symbol == "_native_system_cpu_logical_cores_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_system_cpu_logical_cores_value_bridge")
            if symbol == "native_system_memory_total_bytes_value_bridge" || symbol == "_native_system_memory_total_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_system_memory_total_bytes_value_bridge")
            if symbol == "native_system_memory_available_bytes_value_bridge" || symbol == "_native_system_memory_available_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_system_memory_available_bytes_value_bridge")
            if symbol == "native_process_rss_bytes_value_bridge" || symbol == "_native_process_rss_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_process_rss_bytes_value_bridge")
            if symbol == "native_process_group_rss_bytes_value_bridge" || symbol == "_native_process_group_rss_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_process_group_rss_bytes_value_bridge")
            if symbol == "native_system_disk_total_bytes_value_bridge" || symbol == "_native_system_disk_total_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_system_disk_total_bytes_value_bridge")
            if symbol == "native_system_disk_available_bytes_value_bridge" || symbol == "_native_system_disk_available_bytes_value_bridge":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "native_system_disk_available_bytes_value_bridge")
            if symbol == "mobile_biometric_fingerprint_authorize_bridge_native" || symbol == "_mobile_biometric_fingerprint_authorize_bridge_native":
                BackendDriverDispatchMinAddRootUnique(roots, seen, "mobile_biometric_fingerprint_authorize_bridge_native")
        return BackendDriverDispatchMinCsv(roots)
    return ""

fn BackendDriverDispatchMinCompileProviderObject(rootDir: str,
                                                  compilerPath: str,
                                                  linkPlan: slplan.SystemLinkPlanStub,
                                                  primaryPlan: pobj.PrimaryObjectPlan,
                                                  modulePath: str,
                                                  sourcePath: str,
                                                  objectPath: str,
                                                  exportRootsText: str): bool =
    if len(sourcePath) <= 0:
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: provider source unsupported: {modulePath}")
        return false
    if !chengpath.FileExistsNonEmpty(rootDir, sourcePath):
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: provider source missing: {sourcePath}")
        return false
    let reportPath = Fmt"{objectPath}.report.txt"
    let logPath = Fmt"{objectPath}.compile.log"
    let _ = primaryPlan
    var command = Fmt"CHENG_NO_BACKEND_DRIVER_HANDOFF=1 CHENG_BACKEND_DRIVER_HANDOFF=0 PARENT_RSS_GUARD=1 PROGRESS=1 PROCESS_MAX_RSS_BYTES=8589934592 {os.QuoteShell(compilerPath)} system-link-exec --root:{os.QuoteShell(rootDir)} --in:{os.QuoteShell(sourcePath)} --emit:obj --target:{linkPlan.targetTriple} --out:{os.QuoteShell(objectPath)} --report-out:{os.QuoteShell(reportPath)}"
    if len(exportRootsText) > 0:
        command = Fmt"{command} --symbol-visibility:internal --export-roots:{os.QuoteShell(exportRootsText)}"
    let run = os.ExecShellCmdEx(command, uint64(1), rootDir)
    let output = os.ExecCmdResultOutput(run)
    let _ = chengpath.WriteTextFile(rootDir, logPath, output)
    if os.ExecCmdResultExitCode(run) != 0:
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: provider compile failed module={modulePath} log={logPath}")
        return false
    if !chengpath.FileExistsNonEmpty(rootDir, objectPath):
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: provider object missing: {objectPath}")
        return false
    if !chengpath.FileExistsNonEmpty(rootDir, reportPath):
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: provider report missing: {reportPath}")
        return false
    return true

fn BackendDriverDispatchMinRunExecutable(rootDir: str,
                                          exePath: str,
                                          logPath: str): int32 =
    let command = os.QuoteShell(exePath)
    let run = os.ExecShellCmdEx(command, uint64(1), rootDir)
    let _ = chengpath.WriteTextFile(rootDir, logPath, os.ExecCmdResultOutput(run))
    return os.ExecCmdResultExitCode(run)

fn BackendDriverDispatchMinCheckNegative(rootDir: str,
                                          label: str,
                                          exitCode: int32,
                                          output: str,
                                          reportPath: str,
                                          outputNeedle: str,
                                          reportNeedle: str): bool =
    if exitCode == 0:
        BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: verify-export-visibility unexpected success: {label}")
        return false
    if chengpath.TextContains(output, outputNeedle):
        return true
    let reportText = chengpath.ReadTextFile(rootDir, reportPath)
    if chengpath.TextContains(reportText, reportNeedle):
        return true
    BackendDriverDispatchMinPrintErr(Fmt"backend driver direct: verify-export-visibility missing diagnostic: {label}")
    return false

fn BackendDriverDispatchMinVerifyExportPositive(rootDir: str,
                                                 compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "positive_smoke")
    if !BackendDriverDispatchMinEnsureDir(rootDir, caseDir):
        return false
    let srcPath = chengpath.PathAbsolute(rootDir, "src/tests/export_visibility_smoke.cheng")
    let outPath = chengpath.PathJoin(caseDir, "export_visibility_smoke")
    let logPath = chengpath.PathJoin(caseDir, "export_visibility_smoke.compile.log")
    var output = ""
    let compileCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                              compilerPath,
                                                              rootDir,
                                                              srcPath,
                                                              outPath,
                                                              logPath,
                                                              output)
    if compileCode != 0:
        BackendDriverDispatchMinPrintErr("backend driver direct: verify-export-visibility positive compile failed")
        return false
    let runLogPath = chengpath.PathJoin(caseDir, "export_visibility_smoke.run.log")
    let runCode = BackendDriverDispatchMinRunExecutable(rootDir, outPath, runLogPath)
    if runCode != 0:
        BackendDriverDispatchMinPrintErr("backend driver direct: verify-export-visibility positive run failed")
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility export smoke ok")
    return true

fn BackendDriverDispatchMinVerifyPrivateNegative(rootDir: str,
                                                  compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "private_symbol")
    let packageRoot = chengpath.PathJoin(caseDir, "workspace")
    let helperSrcDir = chengpath.PathJoin(packageRoot, "src/private_helper_pkg")
    let consumerSrcDir = chengpath.PathJoin(packageRoot, "src/private_consumer_pkg")
    if !BackendDriverDispatchMinEnsureDir(rootDir, helperSrcDir):
        return false
    if !BackendDriverDispatchMinEnsureDir(rootDir, consumerSrcDir):
        return false
    if !BackendDriverDispatchMinWriteManifest(rootDir,
                                               packageRoot,
                                               "pkg://cheng",
                                               "cheng"):
        return false
    let helperSrcPath = chengpath.PathJoin(helperSrcDir, "helper.cheng")
    let consumerSrcPath = chengpath.PathJoin(consumerSrcDir, "main.cheng")
    let importKw = "import"
    let helperSource = "fn privateFn(): int32 =\n    return 1\n\nfn PublicFn(): int32 =\n    return 2\n"
    let consumerSource = Fmt"{importKw} cheng/private_helper_pkg/helper as helper\n\nfn main(): int32 =\n    let x = helper.privateFn()\n    return x\n"
    if !chengpath.WriteTextFile(rootDir, helperSrcPath, helperSource):
        return false
    if !chengpath.WriteTextFile(rootDir, consumerSrcPath, consumerSource):
        return false
    let outPath = chengpath.PathJoin(caseDir, "private_symbol")
    let logPath = chengpath.PathJoin(caseDir, "private_symbol.compile.log")
    let reportPath = Fmt"{outPath}.report.txt"
    var output = ""
    let exitCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                           compilerPath,
                                                           packageRoot,
                                                           consumerSrcPath,
                                                           outPath,
                                                           logPath,
                                                           output)
    if !BackendDriverDispatchMinCheckNegative(rootDir,
                                               "private symbol",
                                               exitCode,
                                               output,
                                               reportPath,
                                               "imported private symbol 'privateFn' is not exported",
                                               "unknown_qualified_target:helper:privateFn"):
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility private symbol ok")
    return true

fn BackendDriverDispatchMinVerifyStrformatCase(rootDir: str,
                                                compilerPath: str,
                                                packageRoot: str,
                                                caseDir: str,
                                                stem: str,
                                                sourceText: str,
                                                outputNeedle: str,
                                                reportNeedle: str): bool =
    let srcDir = chengpath.PathJoin(packageRoot, "src")
    if !BackendDriverDispatchMinEnsureDir(rootDir, srcDir):
        return false
    let srcPath = chengpath.PathJoin(srcDir, Fmt"{stem}.cheng")
    if !chengpath.WriteTextFile(rootDir, srcPath, sourceText):
        return false
    let outPath = chengpath.PathJoin(caseDir, stem)
    let logPath = chengpath.PathJoin(caseDir, Fmt"{stem}.compile.log")
    let reportPath = Fmt"{outPath}.report.txt"
    var output = ""
    let exitCode = BackendDriverDispatchMinCompileFixture(rootDir,
                                                           compilerPath,
                                                           packageRoot,
                                                           srcPath,
                                                           outPath,
                                                           logPath,
                                                           output)
    return BackendDriverDispatchMinCheckNegative(rootDir,
                                                  stem,
                                                  exitCode,
                                                  output,
                                                  reportPath,
                                                  outputNeedle,
                                                  reportNeedle)

fn BackendDriverDispatchMinVerifyStrformatNegative(rootDir: str,
                                                    compilerPath: str): bool =
    let caseDir = chengpath.PathJoin(BackendDriverDispatchMinArtifactsDir(rootDir), "strformat_private")
    let packageRoot = chengpath.PathJoin(caseDir, "strformat_negative_pkg")
    if !BackendDriverDispatchMinWriteManifest(rootDir,
                                               packageRoot,
                                               "pkg://cheng/strformat_negative_pkg",
                                               "strformat_negative_pkg"):
        return false
    let importKw = "import"
    let fmtSource = Fmt"{importKw} std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.fmt(\"bad\")\n    echo(text)\n    return 0\n"
    if !BackendDriverDispatchMinVerifyStrformatCase(rootDir,
                                                     compilerPath,
                                                     packageRoot,
                                                     caseDir,
                                                     "fmt_private_main",
                                                     fmtSource,
                                                     "imported private symbol 'fmt' is not exported",
                                                     "unknown_qualified_target:strfmt:fmt"):
        return false
    let linesSource = Fmt"{importKw} std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.lines(\"bad\")\n    echo(text)\n    return 0\n"
    if !BackendDriverDispatchMinVerifyStrformatCase(rootDir,
                                                     compilerPath,
                                                     packageRoot,
                                                     caseDir,
                                                     "lines_private_main",
                                                     linesSource,
                                                     "imported private symbol 'lines' is not exported",
                                                     "unknown_qualified_target:strfmt:lines"):
        return false
    os.WriteLine(os.Get_stdout(), "verify-export-visibility strformat ok")
    return true

fn BackendDriverDispatchMinVerifyExportVisibility(rootDir: str): int32 =
    let compilerPath = BackendDriverDispatchMinCurrentCompiler(rootDir)
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct: missing compiler: {compilerPath}")
    if !BackendDriverDispatchMinVerifyExportPositive(rootDir, compilerPath):
        return 1
    if !BackendDriverDispatchMinVerifyPrivateNegative(rootDir, compilerPath):
        return 1
    if !BackendDriverDispatchMinVerifyStrformatNegative(rootDir, compilerPath):
        return 1
    os.WriteLine(os.Get_stdout(), "verify-export-visibility ok")
    return 0

fn BackendDriverDispatchMinVerifyExportVisibilityFromCmdline(): int32 =
    return 2

fn BackendDriverDispatchMinVerifyExportVisibilityParallelFromCmdline(): int32 =
    return 2

fn BackendDriverDispatchMinRunSystemLinkExecWithRequest(rootDir: str,
                                                         reqRes: Result[creq.CompilerRequest]): int32 =
    return BackendDriverDispatchMinUnsupported("backend driver direct system-link-exec: request object path is not closed in dispatch_min")

fn BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(rootDir: str,
                                                             reqBase: creq.CompilerRequest): int32 =
    return BackendDriverDispatchMinUnsupported("backend driver direct system-link-exec: concrete request getter path is not closed in dispatch_min")

fn BackendDriverDispatchMinRunSystemLinkExecConcreteFields(driverRoot: str,
                                                            packageRoot: str,
                                                            sourcePath: str,
                                                            outputPath: str,
                                                            targetTriple: str,
                                                            emitKind: creq.CompilerEmit,
                                                            reportPath: str,
                                                            symbolVisibility: str,
                                                            browserBridgeObjectPath: str,
                                                            exportRootsText: str): int32 =
    var phaseProfile: BackendDriverDispatchMinPhaseProfile
    phaseProfile.totalStartNs = BackendDriverDispatchMinNowNs()
    let systemLinkPlanStartNs = BackendDriverDispatchMinNowNs()
    var linkPlan: slplan.SystemLinkPlanStub
    var err: str
    BackendDriverDispatchMinProgress("system_link_plan", "begin")
    if !slplan.BuildSystemLinkPlanStubWithFields(driverRoot,
                                                  packageRoot,
                                                  sourcePath,
                                                  outputPath,
                                                  targetTriple,
                                                  emitKind,
                                                  symbolVisibility,
                                                  browserBridgeObjectPath,
                                                  linkPlan,
                                                  err):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               err)
        return BackendDriverDispatchMinUnsupported(err)
    linkPlan.exportRootSymbols = BackendDriverDispatchMinSplitCsv(exportRootsText)
    phaseProfile.systemLinkPlanNs = BackendDriverDispatchMinNowNs() - systemLinkPlanStartNs
    BackendDriverDispatchMinProgress("system_link_plan", "done")
    phaseProfile.compilerCsgNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("compiler_csg", "begin")
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlan(driverRoot,
                                                                               reportPath,
                                                                               linkPlan,
                                                                               phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlan(driverRoot: str,
                                                          reportPath: str,
                                                          linkPlan: slplan.SystemLinkPlanStub,
                                                          phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    return BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterSourceBundle(driverRoot,
                                                                                  reportPath,
                                                                                  linkPlan,
                                                                                  phaseProfile)

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterSourceBundle(driverRoot: str,
                                                                           reportPath: str,
                                                                           linkPlan: slplan.SystemLinkPlanStub,
                                                                           phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    let sourceBundleCid = slplan.SystemLinkPlanSourceBundleCidValue(linkPlan)
    var csg: ccsg.CompilerCsg
    var csgErr: str
    if !ccsg.BuildCompilerCsgInto(linkPlan, sourceBundleCid, csg, csgErr):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               csgErr)
        return BackendDriverDispatchMinUnsupported(csgErr)
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterCsg(driverRoot,
                                                                                       reportPath,
                                                                                       linkPlan,
                                                                                       csg,
                                                                                       phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterCsg(driverRoot: str,
                                                                  reportPath: str,
                                                                  linkPlan: slplan.SystemLinkPlanStub,
                                                                  csg: var ccsg.CompilerCsg,
                                                                  phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    var err: str
    phaseProfile.compilerCsgNs = BackendDriverDispatchMinNowNs() - phaseProfile.compilerCsgNs
    BackendDriverDispatchMinProgress("compiler_csg", "done")
    var loweringPlan: lower.LoweringPlanStub
    phaseProfile.loweringPlanNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("lowering_plan", "begin")
    if !lower.BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, loweringPlan, err):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               err)
        return BackendDriverDispatchMinUnsupported(err)
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterLowering(driverRoot,
                                                                                            reportPath,
                                                                                            linkPlan,
                                                                                            loweringPlan,
                                                                                            phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterLowering(driverRoot: str,
                                                                       reportPath: str,
                                                                       linkPlan: slplan.SystemLinkPlanStub,
                                                                       loweringPlan: var lower.LoweringPlanStub,
                                                                       phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    phaseProfile.loweringPlanNs = BackendDriverDispatchMinNowNs() - phaseProfile.loweringPlanNs
    BackendDriverDispatchMinProgress("lowering_plan", "done")
    phaseProfile.primaryObjectPlanNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("primary_object_plan", "begin")
    let primaryPlan = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    phaseProfile.primaryObjectPlanNs = BackendDriverDispatchMinNowNs() - phaseProfile.primaryObjectPlanNs
    BackendDriverDispatchMinProgress("primary_object_plan", "done")
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckSystemReady(driverRoot,
                                                                                               reportPath,
                                                                                               linkPlan,
                                                                                               loweringPlan,
                                                                                               primaryPlan,
                                                                                               phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanNotReady(driverRoot: str,
                                                                  reportPath: str,
                                                                  linkPlan: slplan.SystemLinkPlanStub,
                                                                  loweringPlan: lower.LoweringPlanStub,
                                                                  primaryPlan: pobj.PrimaryObjectPlan,
                                                                  phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    var report = ""
    BackendDriverDispatchMinAppendLine(report, "system_link_exec_runtime_execute=error")
    BackendDriverDispatchMinAppendLine(report, "error=plan_not_ready")
    BackendDriverDispatchMinAppendLine(report, Fmt"system_missing_reason_count={linkPlan.missingReasons.len}")
    BackendDriverDispatchMinAppendLine(report, Fmt"lowering_missing_reason_count={loweringPlan.missingReasons.len}")
    BackendDriverDispatchMinAppendLine(report, Fmt"primary_object_missing_reason_count={primaryPlan.missingReasons.len}")
    BackendDriverDispatchMinAppendPrimaryPlanReport(report, primaryPlan)
    BackendDriverDispatchMinAppendPhaseReport(report, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(report)
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, report):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               "plan_not_ready")
    BackendDriverDispatchMinPrintErr("backend driver direct system-link-exec: plan not ready")
    return 2

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckSystemReady(driverRoot: str,
                                                                          reportPath: str,
                                                                          linkPlan: slplan.SystemLinkPlanStub,
                                                                          loweringPlan: lower.LoweringPlanStub,
                                                                          primaryPlan: pobj.PrimaryObjectPlan,
                                                                          phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    if linkPlan.missingReasons.len > 0:
        return BackendDriverDispatchMinRunSystemLinkExecConcretePlanNotReady(driverRoot,
                                                                             reportPath,
                                                                             linkPlan,
                                                                             loweringPlan,
                                                                             primaryPlan,
                                                                             phaseProfile)
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckLoweringReady(driverRoot,
                                                                                                 reportPath,
                                                                                                 linkPlan,
                                                                                                 loweringPlan,
                                                                                                 primaryPlan,
                                                                                                 phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckLoweringReady(driverRoot: str,
                                                                            reportPath: str,
                                                                            linkPlan: slplan.SystemLinkPlanStub,
                                                                            loweringPlan: lower.LoweringPlanStub,
                                                                            primaryPlan: pobj.PrimaryObjectPlan,
                                                                            phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    if loweringPlan.missingReasons.len > 0:
        return BackendDriverDispatchMinRunSystemLinkExecConcretePlanNotReady(driverRoot,
                                                                             reportPath,
                                                                             linkPlan,
                                                                             loweringPlan,
                                                                             primaryPlan,
                                                                             phaseProfile)
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckPrimaryReady(driverRoot,
                                                                                                reportPath,
                                                                                                linkPlan,
                                                                                                loweringPlan,
                                                                                                primaryPlan,
                                                                                                phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckPrimaryReady(driverRoot: str,
                                                                           reportPath: str,
                                                                           linkPlan: slplan.SystemLinkPlanStub,
                                                                           loweringPlan: lower.LoweringPlanStub,
                                                                           primaryPlan: pobj.PrimaryObjectPlan,
                                                                           phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    if primaryPlan.missingReasons.len > 0:
        return BackendDriverDispatchMinRunSystemLinkExecConcretePlanNotReady(driverRoot,
                                                                             reportPath,
                                                                             linkPlan,
                                                                             loweringPlan,
                                                                             primaryPlan,
                                                                             phaseProfile)
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterReady(driverRoot,
                                                                                        reportPath,
                                                                                        linkPlan,
                                                                                        loweringPlan,
                                                                                        primaryPlan,
                                                                                        phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterReady(driverRoot: str,
                                                                    reportPath: str,
                                                                    linkPlan: slplan.SystemLinkPlanStub,
                                                                    loweringPlan: lower.LoweringPlanStub,
                                                                    primaryPlan: pobj.PrimaryObjectPlan,
                                                                    phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    let planBrowserBridgeObjectPath = slplan.SystemLinkPlanBrowserBridgeObjectPath(linkPlan)
    if len(planBrowserBridgeObjectPath) > 0:
        return BackendDriverDispatchMinUnsupported("backend driver direct system-link-exec: browser bridge object not yet in direct runtime")
    let runCode: int32 = BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterBrowserReady(driverRoot,
                                                                                                reportPath,
                                                                                                linkPlan,
                                                                                                loweringPlan,
                                                                                                primaryPlan,
                                                                                                phaseProfile)
    return runCode

fn BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterBrowserReady(driverRoot: str,
                                                                           reportPath: str,
                                                                           linkPlan: slplan.SystemLinkPlanStub,
                                                                           loweringPlan: lower.LoweringPlanStub,
                                                                           primaryPlan: pobj.PrimaryObjectPlan,
                                                                           phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    if tmat.TargetIsWasm(linkPlan.targetTriple):
        return BackendDriverDispatchMinRunSystemLinkExecEmitWasm(driverRoot, reportPath, linkPlan, loweringPlan, primaryPlan, phaseProfile)
    if !BackendDriverDispatchMinIsTargetSupported(linkPlan.targetTriple):
        let reason = Fmt"backend driver direct system-link-exec: unsupported direct target: {linkPlan.targetTriple}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               reason)
        return BackendDriverDispatchMinUnsupported(reason)
    if linkPlan.emitKind == creq.EmitObj:
        return BackendDriverDispatchMinRunSystemLinkExecEmitObj(driverRoot, reportPath, linkPlan, primaryPlan, phaseProfile)
    if linkPlan.emitKind == creq.EmitShared:
        let reason = "backend driver direct system-link-exec: emit shared is not closed in dispatch_min"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let requirePureSystemLinkExec = BackendDriverDispatchMinRequirePureSystemLinkExec()
    if linkPlan.emitKind == creq.EmitExe && linkPlan.providerModules.len > 0:
        return BackendDriverDispatchMinRunSystemLinkExecEmitExeProviders(driverRoot, reportPath, linkPlan, loweringPlan, primaryPlan, phaseProfile)
    if linkPlan.emitKind == creq.EmitExe &&
       !requirePureSystemLinkExec &&
       tmat.TargetIsDarwinArm64(linkPlan.targetTriple) &&
       direct.DirectObjectEmitCanStandaloneMain(primaryPlan):
        return BackendDriverDispatchMinRunSystemLinkExecEmitExeStandalone(driverRoot, reportPath, linkPlan, loweringPlan, primaryPlan, phaseProfile)
    if linkPlan.emitKind == creq.EmitExe && requirePureSystemLinkExec:
        let reason = "backend driver direct system-link-exec: pure runtime requires provider modules"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               reason)
        return BackendDriverDispatchMinUnsupported(reason)
    return BackendDriverDispatchMinRunSystemLinkExecEmitExeStandalone(driverRoot, reportPath, linkPlan, loweringPlan, primaryPlan, phaseProfile)

fn BackendDriverDispatchMinIsTargetSupported(triple: str): bool =
    return tmat.TargetIsDarwinArm64(triple) ||
           tmat.TargetIsLinuxAarch64(triple) ||
           tmat.TargetIsAndroidAarch64(triple) ||
           tmat.TargetIsOhosAarch64(triple) ||
           tmat.TargetIsWasm(triple)

fn BackendDriverDispatchMinBaseName(path: str): str =
    var lastSep = -1
    for i in 0..<len(path):
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    return strings.SliceBytes(path, lastSep + 1, len(path) - lastSep - 1)

fn BackendDriverDispatchMinOhosClang(): str =
    let configured = os.GetEnv("OHOS_AARCH64_CLANG")
    if len(configured) > 0:
        return configured
    return "/Applications/DevEco-Studio.app/Contents/sdk/default/openharmony/native/llvm/bin/aarch64-unknown-linux-ohos-clang"

fn BackendDriverDispatchMinSharedLinkCommand(targetTriple: str,
                                              objectPath: str,
                                              outputPath: str): str =
    if tmat.TargetIsOhosAarch64(targetTriple):
        let clang = BackendDriverDispatchMinOhosClang()
        let soname = BackendDriverDispatchMinBaseName(outputPath)
        return Fmt"{os.QuoteShell(clang)} -shared -fPIC {os.QuoteShell(objectPath)} -Wl,-soname,{os.QuoteShell(soname)} -ldl -lm -o {os.QuoteShell(outputPath)}"
    if tmat.TargetIsDarwinArm64(targetTriple):
        return Fmt"cc -arch arm64 -dynamiclib {os.QuoteShell(objectPath)} -o {os.QuoteShell(outputPath)}"
    return Fmt"cc -shared -fPIC {os.QuoteShell(objectPath)} -o {os.QuoteShell(outputPath)}"

fn BackendDriverDispatchMinNativeLinkAndLineMap(driverRoot: str, nativeCommand: str, outputPath: str, linkPlan: slplan.SystemLinkPlanStub, loweringPlan: lower.LoweringPlanStub, reportPath: str, phaseProfile: var BackendDriverDispatchMinPhaseProfile, lineMapPath: var str): int32 =
    let nativeLinkLogPath = Fmt"{linkPlan.outputPath}.native_link.log"
    phaseProfile.nativeLinkNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("native_link", "begin")
    let nativeRun = os.ExecShellCmdEx(nativeCommand, uint64(1), driverRoot)
    phaseProfile.nativeLinkNs = BackendDriverDispatchMinNowNs() - phaseProfile.nativeLinkNs
    BackendDriverDispatchMinProgress("native_link", "done")
    let _ = BackendDriverDispatchMinWriteReport(driverRoot, nativeLinkLogPath, os.ExecCmdResultOutput(nativeRun))
    if os.ExecCmdResultExitCode(nativeRun) != 0:
        let reason = Fmt"backend driver direct system-link-exec: native link failed log={nativeLinkLogPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    if !chengpath.FileExistsNonEmpty(driverRoot, outputPath):
        let reason = Fmt"backend driver direct system-link-exec: native output missing after link: {outputPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let _ = os.ExecShellCmdEx(Fmt"chmod 755 {os.QuoteShell(outputPath)}", uint64(0), driverRoot)
    phaseProfile.lineMapNs = BackendDriverDispatchMinNowNs()
    let lineMapRaw = linemap.LineMapPathForOutput(linkPlan.outputPath)
    if len(lineMapRaw) > 0:
        let lineMapText = linemap.LineMapText(linkPlan, loweringPlan)
        if !chengpath.WriteTextFile(driverRoot, lineMapRaw, lineMapText):
            let reason = Fmt"backend driver direct system-link-exec: failed to write line-map: {lineMapRaw}"
            let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
            return BackendDriverDispatchMinUnsupported(reason)
        lineMapPath = lineMapRaw
    phaseProfile.lineMapNs = BackendDriverDispatchMinNowNs() - phaseProfile.lineMapNs
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecEmitObj(driverRoot: str, reportPath: str, linkPlan: slplan.SystemLinkPlanStub, primaryPlan: pobj.PrimaryObjectPlan, phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("direct_object_emit", "begin")
    let objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    let objectRes = direct.DirectObjectEmitPlanObjectForTarget(driverRoot, primaryPlan, linkPlan.targetTriple, objectFormat)
    if IsErr(objectRes):
        let reason = Error(objectRes)
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let object = Value(objectRes)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs() - phaseProfile.directObjectEmitNs
    BackendDriverDispatchMinProgress("direct_object_emit", "done")
    var objReport = ""
    BackendDriverDispatchMinAppendLine(objReport, "system_link_exec_runtime_execute=0")
    BackendDriverDispatchMinAppendLine(objReport, "system_link_exec_emit=obj")
    BackendDriverDispatchMinAppendLine(objReport, Fmt"primary_object={object.objectPath}")
    BackendDriverDispatchMinAppendLine(objReport, "primary_object_direct=1")
    BackendDriverDispatchMinAppendPrimaryPlanReport(objReport, primaryPlan)
    BackendDriverDispatchMinAppendPhaseReport(objReport, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(objReport)
    BackendDriverDispatchMinAppendOutputFileSizeReport(objReport, driverRoot, object.objectPath)
    BackendDriverDispatchMinAppendLine(objReport, Fmt"direct_object_output_kind={object.outputKind}")
    BackendDriverDispatchMinAppendLine(objReport, Fmt"exec_phase_direct_object_layout_ms={strings.Int64ToStr(object.directObjectLayoutMs)}")
    BackendDriverDispatchMinAppendLine(objReport, Fmt"exec_phase_direct_object_emit_ms={strings.Int64ToStr(object.directObjectEmitMs)}")
    BackendDriverDispatchMinAppendLine(objReport, Fmt"direct_object_bytes={strings.IntToStr(object.bytesWritten)}")
    BackendDriverDispatchMinAppendLine(objReport, Fmt"direct_object_reloc_count={strings.IntToStr(object.relocCount)}")
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, objReport):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecEmitShared(driverRoot: str,
                                                       reportPath: str,
                                                       linkPlan: slplan.SystemLinkPlanStub,
                                                       primaryPlan: pobj.PrimaryObjectPlan,
                                                       phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("direct_object_emit", "begin")
    let objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    let objectRes = direct.DirectObjectEmitPlanObjectForTarget(driverRoot, primaryPlan, linkPlan.targetTriple, objectFormat)
    if IsErr(objectRes):
        let reason = Error(objectRes)
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let object = Value(objectRes)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs() - phaseProfile.directObjectEmitNs
    BackendDriverDispatchMinProgress("direct_object_emit", "done")
    let objectPath = chengpath.PathAbsolute(driverRoot, object.objectPath)
    let outputPath = chengpath.PathAbsolute(driverRoot, linkPlan.outputPath)
    let nativeCommand = BackendDriverDispatchMinSharedLinkCommand(linkPlan.targetTriple, objectPath, outputPath)
    let nativeLinkLogPath = Fmt"{linkPlan.outputPath}.native_link.log"
    phaseProfile.nativeLinkNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("native_link", "begin")
    let nativeRun = os.ExecShellCmdEx(nativeCommand, uint64(1), driverRoot)
    phaseProfile.nativeLinkNs = BackendDriverDispatchMinNowNs() - phaseProfile.nativeLinkNs
    BackendDriverDispatchMinProgress("native_link", "done")
    let _ = BackendDriverDispatchMinWriteReport(driverRoot, nativeLinkLogPath, os.ExecCmdResultOutput(nativeRun))
    if os.ExecCmdResultExitCode(nativeRun) != 0:
        let reason = Fmt"backend driver direct system-link-exec: native shared link failed log={nativeLinkLogPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    if !chengpath.FileExistsNonEmpty(driverRoot, outputPath):
        let reason = Fmt"backend driver direct system-link-exec: shared output missing after link: {outputPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    var sharedReport = ""
    BackendDriverDispatchMinAppendLine(sharedReport, "system_link_exec_runtime_execute=0")
    BackendDriverDispatchMinAppendLine(sharedReport, "system_link_exec_emit=shared")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"primary_object={object.objectPath}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"native_primary_object={objectPath}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"native_link_log={nativeLinkLogPath}")
    BackendDriverDispatchMinAppendLine(sharedReport, "primary_object_direct=1")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"direct_object_output_kind={object.outputKind}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"exec_phase_direct_object_layout_ms={strings.Int64ToStr(object.directObjectLayoutMs)}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"exec_phase_direct_object_emit_ms={strings.Int64ToStr(object.directObjectEmitMs)}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"direct_object_bytes={strings.IntToStr(object.bytesWritten)}")
    BackendDriverDispatchMinAppendLine(sharedReport, Fmt"direct_object_reloc_count={strings.IntToStr(object.relocCount)}")
    BackendDriverDispatchMinAppendPhaseReport(sharedReport, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(sharedReport)
    BackendDriverDispatchMinAppendOutputFileSizeReport(sharedReport, driverRoot, linkPlan.outputPath)
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, sharedReport):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecEmitExeProviders(driverRoot: str, reportPath: str, linkPlan: slplan.SystemLinkPlanStub, loweringPlan: lower.LoweringPlanStub, primaryPlan: pobj.PrimaryObjectPlan, phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("direct_object_emit", "begin")
    let objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    let objectRes = direct.DirectObjectEmitPlanObjectForTarget(driverRoot, primaryPlan, linkPlan.targetTriple, objectFormat)
    if IsErr(objectRes):
        let reason = Error(objectRes)
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let object = Value(objectRes)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs() - phaseProfile.directObjectEmitNs
    BackendDriverDispatchMinProgress("direct_object_emit", "done")
    let compilerPath = BackendDriverDispatchMinCurrentCompiler(driverRoot)
    if len(compilerPath) <= 0 || !chengpath.FileExistsNonEmpty(driverRoot, compilerPath):
        let reason = Fmt"backend driver direct system-link-exec: missing current compiler for provider objects: {compilerPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    var providerObjectPaths: str[]
    var providerSourcePaths: str[]
    var providerExportRootTexts: str[]
    var providerCompileReportPaths: str[]
    var providerCompileLogPaths: str[]
    phaseProfile.providerObjectNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("provider_object", "begin")
    for i in 0..<linkPlan.providerModules.len:
        let modulePath = linkPlan.providerModules[i]
        let providerSourcePath = BackendDriverDispatchMinProviderSourcePath(driverRoot, linkPlan, modulePath)
        let providerObjectPath = Fmt"{linkPlan.outputPath}.provider.{BackendDriverDispatchMinProviderModuleSafeName(modulePath)}.o"
        add(providerSourcePaths, providerSourcePath)
        add(providerCompileReportPaths, Fmt"{providerObjectPath}.report.txt")
        add(providerCompileLogPaths, Fmt"{providerObjectPath}.compile.log")
        let providerExportRoots = BackendDriverDispatchMinProviderExportRoots(modulePath, primaryPlan)
        add(providerExportRootTexts, providerExportRoots)
        if len(providerExportRoots) <= 0:
            continue
        if !BackendDriverDispatchMinCompileProviderObject(driverRoot, compilerPath, linkPlan, primaryPlan, modulePath, providerSourcePath, providerObjectPath, providerExportRoots):
            let reason = Fmt"backend driver direct system-link-exec: provider object failed: {modulePath}"
            let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
            return BackendDriverDispatchMinUnsupported(reason)
        add(providerObjectPaths, providerObjectPath)
    if providerObjectPaths.len != linkPlan.providerModules.len:
        let reason = Fmt"backend driver direct system-link-exec: provider object count mismatch modules={linkPlan.providerModules.len} objects={providerObjectPaths.len}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    phaseProfile.providerObjectNs = BackendDriverDispatchMinNowNs() - phaseProfile.providerObjectNs
    BackendDriverDispatchMinProgress("provider_object", "done")
    let primaryObjectPath = chengpath.PathAbsolute(driverRoot, object.objectPath)
    let outputPath = chengpath.PathAbsolute(driverRoot, linkPlan.outputPath)
    var nativeCommand = Fmt"cc -arch arm64 {os.QuoteShell(primaryObjectPath)}"
    for i in 0..<providerObjectPaths.len:
        nativeCommand = Fmt"{nativeCommand} {os.QuoteShell(chengpath.PathAbsolute(driverRoot, providerObjectPaths[i]))}"
    nativeCommand = Fmt"{nativeCommand} -o {os.QuoteShell(outputPath)}"
    var lineMapPath: str
    let linkCode = BackendDriverDispatchMinNativeLinkAndLineMap(driverRoot, nativeCommand, outputPath, linkPlan, loweringPlan, reportPath, phaseProfile, lineMapPath)
    if linkCode != 0:
        return linkCode
    var exeReport = ""
    let providerLinkInputCount = providerObjectPaths.len + 1
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_execute=1")
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_no_runtime=0")
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_direct_entry=0")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"primary_object={object.objectPath}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"native_primary_object={primaryObjectPath}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_compiler={compilerPath}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_modules={slplan.SystemLinkPlanListText(linkPlan.providerModules)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_source_paths={slplan.SystemLinkPlanListText(providerSourcePaths)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_export_roots={slplan.SystemLinkPlanListText(providerExportRootTexts)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_compile_reports={slplan.SystemLinkPlanListText(providerCompileReportPaths)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_compile_logs={slplan.SystemLinkPlanListText(providerCompileLogPaths)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_object_count={providerObjectPaths.len}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_object_paths={slplan.SystemLinkPlanListText(providerObjectPaths)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"provider_link_input_count={providerLinkInputCount}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"object_link_input_count={providerLinkInputCount}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"native_link_input_count={providerLinkInputCount}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"native_link_log={linkPlan.outputPath}.native_link.log")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"line_map={lineMapPath}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"debug_line_map_path={lineMapPath}")
    BackendDriverDispatchMinAppendLine(exeReport, "primary_object_direct=1")
    BackendDriverDispatchMinAppendPrimaryPlanReport(exeReport, primaryPlan)
    BackendDriverDispatchMinAppendPhaseReport(exeReport, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(exeReport)
    BackendDriverDispatchMinAppendOutputFileSizeReport(exeReport, driverRoot, linkPlan.outputPath)
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_output_kind={object.outputKind}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"exec_phase_direct_object_layout_ms={strings.Int64ToStr(object.directObjectLayoutMs)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"exec_phase_direct_object_emit_ms={strings.Int64ToStr(object.directObjectEmitMs)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_bytes={strings.IntToStr(object.bytesWritten)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_reloc_count={strings.IntToStr(object.relocCount)}")
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, exeReport):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecEmitExeStandalone(driverRoot: str, reportPath: str, linkPlan: slplan.SystemLinkPlanStub, loweringPlan: lower.LoweringPlanStub, primaryPlan: pobj.PrimaryObjectPlan, phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    if !tmat.TargetIsDarwinArm64(linkPlan.targetTriple):
        let reason = Fmt"backend driver direct system-link-exec: standalone linkerless exe unsupported target: {linkPlan.targetTriple}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot,
                                                               reportPath,
                                                               reason)
        return BackendDriverDispatchMinUnsupported(reason)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("direct_object_emit", "begin")
    let objectRes = direct.DirectObjectEmitStandaloneExecutable(driverRoot, primaryPlan, linkPlan.outputPath)
    if IsErr(objectRes):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, Error(objectRes))
        return BackendDriverDispatchMinUnsupported(Error(objectRes))
    let object = Value(objectRes)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs() - phaseProfile.directObjectEmitNs
    BackendDriverDispatchMinProgress("direct_object_emit", "done")
    let outputPath = chengpath.PathAbsolute(driverRoot, linkPlan.outputPath)
    var lineMapPath: str
    if !chengpath.FileExistsNonEmpty(driverRoot, linkPlan.outputPath):
        let reason = Fmt"backend driver direct system-link-exec: linkerless output missing after emit: {linkPlan.outputPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    let chmodRun = os.ExecShellCmdEx(Fmt"chmod 755 {os.QuoteShell(outputPath)}", uint64(0), driverRoot)
    if os.ExecCmdResultExitCode(chmodRun) != 0:
        let reason = Fmt"backend driver direct system-link-exec: chmod failed for linkerless output: {linkPlan.outputPath}"
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
        return BackendDriverDispatchMinUnsupported(reason)
    phaseProfile.lineMapNs = BackendDriverDispatchMinNowNs()
    let lineMapRaw = linemap.LineMapPathForOutput(linkPlan.outputPath)
    if len(lineMapRaw) > 0:
        let lineMapText = linemap.LineMapText(linkPlan, loweringPlan)
        if !chengpath.WriteTextFile(driverRoot, lineMapRaw, lineMapText):
            let reason = Fmt"backend driver direct system-link-exec: failed to write line-map: {lineMapRaw}"
            let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, reason)
            return BackendDriverDispatchMinUnsupported(reason)
        lineMapPath = lineMapRaw
    phaseProfile.lineMapNs = BackendDriverDispatchMinNowNs() - phaseProfile.lineMapNs
    var exeReport = ""
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_execute=1")
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_no_runtime=1")
    BackendDriverDispatchMinAppendLine(exeReport, "system_link_exec_runtime_standalone_direct_entry=1")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"primary_object={object.objectPath}")
    BackendDriverDispatchMinAppendLine(exeReport, "provider_object_count=0")
    BackendDriverDispatchMinAppendLine(exeReport, "native_link_log=-")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"line_map={lineMapPath}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"debug_line_map_path={lineMapPath}")
    BackendDriverDispatchMinAppendLine(exeReport, "primary_object_direct=1")
    BackendDriverDispatchMinAppendPrimaryPlanReport(exeReport, primaryPlan)
    BackendDriverDispatchMinAppendPhaseReport(exeReport, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(exeReport)
    BackendDriverDispatchMinAppendOutputFileSizeReport(exeReport, driverRoot, linkPlan.outputPath)
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_output_kind={object.outputKind}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_bytes={strings.IntToStr(object.bytesWritten)}")
    BackendDriverDispatchMinAppendLine(exeReport, Fmt"direct_object_reloc_count={strings.IntToStr(object.relocCount)}")
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, exeReport):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecEmitWasm(driverRoot: str,
                                                      reportPath: str,
                                                      linkPlan: slplan.SystemLinkPlanStub,
                                                      loweringPlan: lower.LoweringPlanStub,
                                                      primaryPlan: pobj.PrimaryObjectPlan,
                                                      phaseProfile: var BackendDriverDispatchMinPhaseProfile): int32 =
    let _ = loweringPlan
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs()
    BackendDriverDispatchMinProgress("direct_object_emit", "begin")
    let outputPath = linkPlan.outputPath
    let wasmRes = direct.DirectObjectEmitWasmMainModule(driverRoot, primaryPlan, outputPath)
    if IsErr(wasmRes):
        let _ = BackendDriverDispatchMinWriteErrorReportBridge(driverRoot, reportPath, Error(wasmRes))
        return BackendDriverDispatchMinUnsupported(Error(wasmRes))
    let wasmResult = Value(wasmRes)
    phaseProfile.directObjectEmitNs = BackendDriverDispatchMinNowNs() - phaseProfile.directObjectEmitNs
    BackendDriverDispatchMinProgress("direct_object_emit", "done")
    var wasmReport = ""
    BackendDriverDispatchMinAppendLine(wasmReport, "system_link_exec_runtime_execute=1")
    BackendDriverDispatchMinAppendLine(wasmReport, "system_link_exec_emit=wasm")
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"primary_object={wasmResult.objectPath}")
    BackendDriverDispatchMinAppendLine(wasmReport, "primary_object_direct=1")
    BackendDriverDispatchMinAppendLine(wasmReport, "native_link_log=-")
    BackendDriverDispatchMinAppendLine(wasmReport, "line_map=-")
    BackendDriverDispatchMinAppendPrimaryPlanReport(wasmReport, primaryPlan)
    BackendDriverDispatchMinAppendPhaseReport(wasmReport, phaseProfile)
    BackendDriverDispatchMinAppendResourceReport(wasmReport)
    BackendDriverDispatchMinAppendOutputFileSizeReport(wasmReport, driverRoot, outputPath)
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_output_kind={wasmResult.outputKind}")
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"exec_phase_direct_object_layout_ms={strings.Int64ToStr(wasmResult.directObjectLayoutMs)}")
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"exec_phase_direct_object_emit_ms={strings.Int64ToStr(wasmResult.directObjectEmitMs)}")
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_bytes={strings.IntToStr(wasmResult.bytesWritten)}")
    BackendDriverDispatchMinAppendLine(wasmReport, Fmt"direct_object_reloc_count={strings.IntToStr(wasmResult.relocCount)}")
    if !BackendDriverDispatchMinWriteReport(driverRoot, reportPath, wasmReport):
        return BackendDriverDispatchMinUnsupported(Fmt"backend driver direct system-link-exec: failed to write report: {reportPath}")
    return 0

fn BackendDriverDispatchMinRunSystemLinkExec(rootDir: str,
                                              args: str[]): int32 =
    return BackendDriverDispatchMinUnsupported("backend driver direct system-link-exec: argv array path is not closed in dispatch_min")

fn BackendDriverDispatchMinRunSystemLinkExecFromCmdline(): int32 =
    let packageRoot = BackendDriverDispatchMinReadFlagOrDefault("--root", "")
    let sourcePath = BackendDriverDispatchMinReadFlagOrDefault("--in", "")
    let targetTriple = BackendDriverDispatchMinReadFlagOrDefault("--target", "arm64-apple-darwin")
    let outputPath = BackendDriverDispatchMinReadFlagOrDefault("--out", "")
    let reportPath = BackendDriverDispatchMinReadFlagOrDefault("--report-out", "")
    let emitText = BackendDriverDispatchMinReadFlagOrDefault("--emit", "exe")
    var emitKind = creq.EmitExe
    if !BackendDriverDispatchMinEmitKindFromText(emitText, emitKind):
        return BackendDriverDispatchMinUnsupportedEmitText(packageRoot, reportPath, emitText)
    let symbolVisibilityRaw = BackendDriverDispatchMinReadFlagOrDefault("--symbol-visibility", "public")
    if !BackendDriverDispatchMinSymbolVisibilitySupported(symbolVisibilityRaw):
        return BackendDriverDispatchMinUnsupportedSymbolVisibility(packageRoot, reportPath, symbolVisibilityRaw)
    let symbolVisibility = BackendDriverDispatchMinSymbolVisibilityValue(symbolVisibilityRaw)
    let exportRootsText = BackendDriverDispatchMinReadFlagOrDefault("--export-roots", "")
    let browserBridgeObjectPath = BackendDriverDispatchMinReadFlagOrDefault("--browser-bridge-object", "")
    return BackendDriverDispatchMinRunSystemLinkExecConcreteFields(packageRoot,
                                                                   packageRoot,
                                                                   sourcePath,
                                                                   outputPath,
                                                                   targetTriple,
                                                                   emitKind,
                                                                   reportPath,
                                                                   symbolVisibility,
                                                                   browserBridgeObjectPath,
                                                                   exportRootsText)

fn BackendDriverDispatchMinRunSystemLinkExecCommandFromCmdline(): int32 =
    return BackendDriverDispatchMinRunSystemLinkExecFromCmdline()

fn BackendDriverDispatchMinCommandCode(cmd: str): int32 =
    let n = len(cmd)
    if n == 4 &&
       cmd[0] == 'h' &&
       cmd[1] == 'e' &&
       cmd[2] == 'l' &&
       cmd[3] == 'p':
        return int32(0)
    if n == 2 &&
       cmd[0] == '-' &&
       cmd[1] == 'h':
        return int32(0)
    if n == 6 &&
       cmd[0] == '-' &&
       cmd[1] == '-' &&
       cmd[2] == 'h' &&
       cmd[3] == 'e' &&
       cmd[4] == 'l' &&
       cmd[5] == 'p':
        return int32(0)
    if n == 6 &&
       cmd[0] == 's' &&
       cmd[1] == 't' &&
       cmd[2] == 'a' &&
       cmd[3] == 't' &&
       cmd[4] == 'u' &&
       cmd[5] == 's':
        return int32(1)
    if n == 16 &&
       cmd[0] == 'p' &&
       cmd[1] == 'r' &&
       cmd[2] == 'i' &&
       cmd[3] == 'n' &&
       cmd[4] == 't' &&
       cmd[5] == '-' &&
       cmd[6] == 'b' &&
       cmd[7] == 'u' &&
       cmd[8] == 'i' &&
       cmd[9] == 'l' &&
       cmd[10] == 'd' &&
       cmd[11] == '-' &&
       cmd[12] == 'p' &&
       cmd[13] == 'l' &&
       cmd[14] == 'a' &&
       cmd[15] == 'n':
        return int32(2)
    if n == 24 &&
       cmd[0] == 'v' &&
       cmd[1] == 'e' &&
       cmd[2] == 'r' &&
       cmd[3] == 'i' &&
       cmd[4] == 'f' &&
       cmd[5] == 'y' &&
       cmd[6] == '-' &&
       cmd[7] == 'e' &&
       cmd[8] == 'x' &&
       cmd[9] == 'p' &&
       cmd[10] == 'o' &&
       cmd[11] == 'r' &&
       cmd[12] == 't' &&
       cmd[13] == '-' &&
       cmd[14] == 'v' &&
       cmd[15] == 'i' &&
       cmd[16] == 's' &&
       cmd[17] == 'i' &&
       cmd[18] == 'b' &&
       cmd[19] == 'i' &&
       cmd[20] == 'l' &&
       cmd[21] == 'i' &&
       cmd[22] == 't' &&
       cmd[23] == 'y':
        return int32(3)
    if n == 33 &&
       cmd[0] == 'v' &&
       cmd[1] == 'e' &&
       cmd[2] == 'r' &&
       cmd[3] == 'i' &&
       cmd[4] == 'f' &&
       cmd[5] == 'y' &&
       cmd[6] == '-' &&
       cmd[7] == 'e' &&
       cmd[8] == 'x' &&
       cmd[9] == 'p' &&
       cmd[10] == 'o' &&
       cmd[11] == 'r' &&
       cmd[12] == 't' &&
       cmd[13] == '-' &&
       cmd[14] == 'v' &&
       cmd[15] == 'i' &&
       cmd[16] == 's' &&
       cmd[17] == 'i' &&
       cmd[18] == 'b' &&
       cmd[19] == 'i' &&
       cmd[20] == 'l' &&
       cmd[21] == 'i' &&
       cmd[22] == 't' &&
       cmd[23] == 'y' &&
       cmd[24] == '-' &&
       cmd[25] == 'p' &&
       cmd[26] == 'a' &&
       cmd[27] == 'r' &&
       cmd[28] == 'a' &&
       cmd[29] == 'l' &&
       cmd[30] == 'l' &&
       cmd[31] == 'e' &&
       cmd[32] == 'l':
        return int32(4)
    if n == 16 &&
       cmd[0] == 's' &&
       cmd[1] == 'y' &&
       cmd[2] == 's' &&
       cmd[3] == 't' &&
       cmd[4] == 'e' &&
       cmd[5] == 'm' &&
       cmd[6] == '-' &&
       cmd[7] == 'l' &&
       cmd[8] == 'i' &&
       cmd[9] == 'n' &&
       cmd[10] == 'k' &&
       cmd[11] == '-' &&
       cmd[12] == 'e' &&
       cmd[13] == 'x' &&
       cmd[14] == 'e' &&
       cmd[15] == 'c':
        return int32(5)
    return int32(-1)

fn BackendDriverDispatchMinRunCommandWithCmd(cmd: str): int32 =
    let code = BackendDriverDispatchMinCommandCode(cmd)
    if code == 0:
        return BackendDriverDispatchMinHelp()
    if code == 1:
        return BackendDriverDispatchMinStatusFromCmdline()
    if code == 2:
        return BackendDriverDispatchMinPrintBuildPlanCommandFromCmdline()
    if code == 3:
        return BackendDriverDispatchMinVerifyExportVisibilityFromCmdline()
    if code == 4:
        return BackendDriverDispatchMinVerifyExportVisibilityParallelFromCmdline()
    if code == 5:
        return BackendDriverDispatchMinRunSystemLinkExecCommandFromCmdline()
    return 2

fn ParamStr(index: int32): str =
    return BackendDriverDispatchMinParamStr(index)

fn BackendDriverDispatchMinRunCommand(): int32 =
    let count = BackendDriverDispatchMinParamCount()
    if count <= 0:
        return BackendDriverDispatchMinHelp()
    return BackendDriverDispatchMinRunCommandWithCmd(BackendDriverDispatchMinParamStr(1))

fn BackendDriverDispatchMinRun(): int32 =
    return BackendDriverDispatchMinRunCommand()

fn main(): int32 =
    return BackendDriverDispatchMinRunCommand()
