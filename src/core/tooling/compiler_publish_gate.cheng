import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_equivalence as ceq
import std/strutils as strutil

fn CompilerPublishDecisionProofPassed(proof: ceq.CompilerEquivalenceProof): bool =
    return proof.graphEquivalent != 0 &&
           proof.exportSurfaceCompatible != 0 &&
           proof.compileReceiptEquivalent != 0 &&
           proof.equivalenceLabel == "canonical_semantic_identity"

fn CompilerPublishDecisionEvaluate(channelRaw: str,
                                     worldHeadCid: layout.FixedBytes32,
                                     equivalenceChecked: bool,
                                     proof: ceq.CompilerEquivalenceProof,
                                     outChannel: var str,
                                     outStableGateRequired: var int32,
                                     outEquivalenceChecked: var int32,
                                     outEquivalencePassed: var int32,
                                     outPublishAllowed: var int32,
                                     outProofCid: var layout.FixedBytes32): Result[bool] =
    let channelRes = cworld.CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let channel = Value(channelRes)
    let stableGateRequired = channel == "stable" ? 1 : 0
    let equivalenceCheckedFlag = equivalenceChecked ? 1 : 0
    var equivalencePassed = 0
    if equivalenceChecked:
        if CompilerPublishDecisionProofPassed(proof):
            equivalencePassed = 1
    var publishAllowed = 1
    if stableGateRequired != 0:
        publishAllowed = equivalencePassed
    outChannel = channel
    outStableGateRequired = stableGateRequired
    outEquivalenceChecked = equivalenceCheckedFlag
    outEquivalencePassed = equivalencePassed
    outPublishAllowed = publishAllowed
    worldHeadCid
    if equivalenceChecked:
        outProofCid = proof.proofCid
    else:
        outProofCid = layout.FixedBytes32()
    return Ok[bool](true)

fn CompilerPublishDecisionReport(channel: str,
                                   stableGateRequired: int32,
                                   equivalenceChecked: int32,
                                   equivalencePassed: int32,
                                   publishAllowed: int32,
                                   worldHeadCid: layout.FixedBytes32,
                                   proofCid: layout.FixedBytes32): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "channel=", channel, "\n"], "")
    out = strutil.Join([out, "stable_gate_required=", IntToStr(stableGateRequired), "\n"], "")
    out = strutil.Join([out, "equivalence_checked=", IntToStr(equivalenceChecked), "\n"], "")
    out = strutil.Join([out, "equivalence_passed=", IntToStr(equivalencePassed), "\n"], "")
    out = strutil.Join([out, "publish_allowed=", IntToStr(publishAllowed), "\n"], "")
    out = strutil.Join([out, "world_head_cid=", layout.FixedBytes32Hex(worldHeadCid), "\n"], "")
    out = strutil.Join([out, "proof_cid=", layout.FixedBytes32Hex(proofCid)], "")
    return out
