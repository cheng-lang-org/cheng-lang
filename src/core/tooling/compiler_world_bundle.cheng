import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import std/strutils as strutil

type
    CompilerWorldBundle =
        bundlePrefix: str
        worldHead: cworld.CompilerWorldHead
        manifest: cworld.CompilerUniverseManifest
        compilerSnapshot: cworld.CompilerPackageSnapshot
        stdSnapshot: cworld.CompilerPackageSnapshot
        runtimeSnapshot: cworld.CompilerPackageSnapshot
        compilerCsgCid: layout.FixedBytes32
        compilerCanonicalCsgCid: layout.FixedBytes32
        exportSurface: ccsg.CsgExportSurface
        receipt: ccsg.CompileReceipt
        lock: cworld.CompilerLockSnapshot

fn CompilerWorldBundleUniverse(bundle: CompilerWorldBundle): cworld.CompilerLocalUniverse =
    var out: cworld.CompilerLocalUniverse
    out.compilerSnapshot = bundle.compilerSnapshot
    out.stdSnapshot = bundle.stdSnapshot
    out.runtimeSnapshot = bundle.runtimeSnapshot
    out.manifest = bundle.manifest
    out.worldHead = bundle.worldHead
    return out

fn CompilerWorldBundleReadText(rootDir: str,
                                 path: str,
                                 label: str): Result[str] =
    let absPath = chengpath.PathAbsolute(rootDir, path)
    if !chengpath.PathFileExists(absPath):
        return Err[str](strutil.Join([" compiler world bundle: missing ", label, ": ", absPath], ""))
    return Ok[str](chengpath.ReadTextFile("", absPath))

fn CompilerWorldBundleManifestEntry(manifest: cworld.CompilerUniverseManifest,
                                      packageId: str,
                                      outEntry: var cworld.CompilerUniverseManifestEntry): bool =
    for i in 0..<manifest.entries.len:
        if manifest.entries[i].packageId != packageId:
            continue
        outEntry = manifest.entries[i]
        return true
    return false

fn CompilerWorldBundleVerifyManifestBinding(manifest: cworld.CompilerUniverseManifest,
                                              snapshot: cworld.CompilerPackageSnapshot): Result[bool] =
    var entry: cworld.CompilerUniverseManifestEntry
    if !CompilerWorldBundleManifestEntry(manifest, snapshot.packageId, entry):
        return Err[bool](strutil.Join([" compiler world bundle: manifest missing package: ", snapshot.packageId], ""))
    if !layout.FixedBytes32Equal(entry.snapshotCid, snapshot.snapshotCid):
        return Err[bool](strutil.Join([" compiler world bundle: manifest snapshot mismatch: ", snapshot.packageId], ""))
    if !layout.FixedBytes32Equal(entry.syntaxSurfaceCid, snapshot.syntaxSurfaceCid):
        return Err[bool](strutil.Join([" compiler world bundle: manifest syntax mismatch: ", snapshot.packageId], ""))
    if !layout.FixedBytes32Equal(entry.migrationProofCid, snapshot.migrationProofCid):
        return Err[bool](strutil.Join([" compiler world bundle: manifest proof mismatch: ", snapshot.packageId], ""))
    return Ok[bool](true)

fn CompilerWorldBundleExpectedCompilerDeps(bundle: CompilerWorldBundle): layout.FixedBytes32 =
    var depsEntries: cworld.CompilerUniverseManifestEntry[]
    for i in 0..<bundle.manifest.entries.len:
        let entry = bundle.manifest.entries[i]
        if entry.packageId == bundle.compilerSnapshot.packageId:
            continue
        add(depsEntries, entry)
    return cworld.CompilerWorldDepsManifestCid(bundle.worldHead.channel, depsEntries)

fn CompilerWorldBundleRead(rootDir: str,
                             prefixRaw: str,
                             out: var CompilerWorldBundle): Result[bool] =
    let prefix = chengpath.PathAbsolute(rootDir, prefixRaw)
    let worldTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".world.txt"], ""), "world report")
    if IsErr(worldTextRes):
        return Err[bool](Error(worldTextRes))
    let manifestTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".manifest.txt"], ""), "manifest report")
    if IsErr(manifestTextRes):
        return Err[bool](Error(manifestTextRes))
    let compilerSnapshotTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".compiler.snapshot.txt"], ""), "compiler snapshot")
    if IsErr(compilerSnapshotTextRes):
        return Err[bool](Error(compilerSnapshotTextRes))
    let stdSnapshotTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".std.snapshot.txt"], ""), "std snapshot")
    if IsErr(stdSnapshotTextRes):
        return Err[bool](Error(stdSnapshotTextRes))
    let runtimeSnapshotTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".runtime.snapshot.txt"], ""), "runtime snapshot")
    if IsErr(runtimeSnapshotTextRes):
        return Err[bool](Error(runtimeSnapshotTextRes))
    let csgTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".csg.txt"], ""), "csg report")
    if IsErr(csgTextRes):
        return Err[bool](Error(csgTextRes))
    let surfaceTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".surface.txt"], ""), "export surface")
    if IsErr(surfaceTextRes):
        return Err[bool](Error(surfaceTextRes))
    let receiptTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".receipt.txt"], ""), "compile receipt")
    if IsErr(receiptTextRes):
        return Err[bool](Error(receiptTextRes))
    let lockTextRes = CompilerWorldBundleReadText("", strutil.Join([prefix, ".lock.toml"], ""), "lock")
    if IsErr(lockTextRes):
        return Err[bool](Error(lockTextRes))
    var worldHead: cworld.CompilerWorldHead
    let worldRes = cworld.CompilerWorldHeadFromReportText(Value(worldTextRes), worldHead)
    if IsErr(worldRes):
        return Err[bool](Error(worldRes))
    var manifest: cworld.CompilerUniverseManifest
    let manifestRes = cworld.CompilerUniverseManifestFromReportText(Value(manifestTextRes), manifest)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    var compilerSnapshot: cworld.CompilerPackageSnapshot
    let compilerSnapshotRes = cworld.CompilerPackageSnapshotFromReportText(Value(compilerSnapshotTextRes), compilerSnapshot)
    if IsErr(compilerSnapshotRes):
        return Err[bool](Error(compilerSnapshotRes))
    var stdSnapshot: cworld.CompilerPackageSnapshot
    let stdSnapshotRes = cworld.CompilerPackageSnapshotFromReportText(Value(stdSnapshotTextRes), stdSnapshot)
    if IsErr(stdSnapshotRes):
        return Err[bool](Error(stdSnapshotRes))
    var runtimeSnapshot: cworld.CompilerPackageSnapshot
    let runtimeSnapshotRes = cworld.CompilerPackageSnapshotFromReportText(Value(runtimeSnapshotTextRes), runtimeSnapshot)
    if IsErr(runtimeSnapshotRes):
        return Err[bool](Error(runtimeSnapshotRes))
    let csgCidRes = ccsg.CompilerCsgGraphCidFromReportText(Value(csgTextRes))
    if IsErr(csgCidRes):
        return Err[bool](Error(csgCidRes))
    let canonicalCsgCidRes = ccsg.CompilerCsgCanonicalGraphCidFromReportText(Value(csgTextRes))
    if IsErr(canonicalCsgCidRes):
        return Err[bool](Error(canonicalCsgCidRes))
    var exportSurface: ccsg.CsgExportSurface
    let exportSurfaceRes = ccsg.CompilerExportSurfaceFromReportText(Value(surfaceTextRes), exportSurface)
    if IsErr(exportSurfaceRes):
        return Err[bool](Error(exportSurfaceRes))
    var receipt: ccsg.CompileReceipt
    let receiptRes = ccsg.CompileReceiptFromReportText(Value(receiptTextRes), receipt)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let lockRes = cworld.CompilerLockSnapshotFromText(Value(lockTextRes), strutil.Join([prefix, ".lock.toml"], ""))
    if IsErr(lockRes):
        return Err[bool](Error(lockRes))
    out.bundlePrefix = prefix
    out.worldHead = worldHead
    out.manifest = manifest
    out.compilerSnapshot = compilerSnapshot
    out.stdSnapshot = stdSnapshot
    out.runtimeSnapshot = runtimeSnapshot
    out.compilerCsgCid = Value(csgCidRes)
    out.compilerCanonicalCsgCid = Value(canonicalCsgCidRes)
    out.exportSurface = exportSurface
    out.receipt = receipt
    out.lock = Value(lockRes)
    return Ok[bool](true)

fn CompilerWorldBundleVerify(bundle: CompilerWorldBundle): Result[bool] =
    if bundle.worldHead.universeId != cworld.CompilerWorldUniverseId():
        return Err[bool](" compiler world bundle: universe id mismatch")
    if bundle.worldHead.channel != bundle.manifest.channel:
        return Err[bool](" compiler world bundle: manifest channel mismatch")
    if bundle.worldHead.channel != bundle.compilerSnapshot.channel:
        return Err[bool](" compiler world bundle: compiler snapshot channel mismatch")
    if bundle.worldHead.channel != bundle.stdSnapshot.channel:
        return Err[bool](" compiler world bundle: std snapshot channel mismatch")
    if bundle.worldHead.channel != bundle.runtimeSnapshot.channel:
        return Err[bool](" compiler world bundle: runtime snapshot channel mismatch")
    if bundle.worldHead.channel != bundle.lock.channel:
        return Err[bool](" compiler world bundle: lock channel mismatch")
    if bundle.compilerSnapshot.packageId != "cheng/compiler":
        return Err[bool](" compiler world bundle: unexpected compiler package id")
    if bundle.stdSnapshot.packageId != "cheng/std":
        return Err[bool](" compiler world bundle: unexpected std package id")
    if bundle.runtimeSnapshot.packageId != "cheng/runtime":
        return Err[bool](" compiler world bundle: unexpected runtime package id")
    if !layout.FixedBytes32Equal(bundle.worldHead.manifestRootCid, bundle.manifest.manifestCid):
        return Err[bool](" compiler world bundle: manifest root mismatch")
    if !layout.FixedBytes32Equal(bundle.worldHead.compilerPkgCid, bundle.compilerSnapshot.snapshotCid):
        return Err[bool](" compiler world bundle: compiler snapshot cid mismatch")
    if !layout.FixedBytes32Equal(bundle.worldHead.stdPkgCid, bundle.stdSnapshot.snapshotCid):
        return Err[bool](" compiler world bundle: std snapshot cid mismatch")
    if !layout.FixedBytes32Equal(bundle.worldHead.runtimePkgCid, bundle.runtimeSnapshot.snapshotCid):
        return Err[bool](" compiler world bundle: runtime snapshot cid mismatch")
    let compilerManifestBindingRes = CompilerWorldBundleVerifyManifestBinding(bundle.manifest, bundle.compilerSnapshot)
    if IsErr(compilerManifestBindingRes):
        return Err[bool](Error(compilerManifestBindingRes))
    let stdManifestBindingRes = CompilerWorldBundleVerifyManifestBinding(bundle.manifest, bundle.stdSnapshot)
    if IsErr(stdManifestBindingRes):
        return Err[bool](Error(stdManifestBindingRes))
    let runtimeManifestBindingRes = CompilerWorldBundleVerifyManifestBinding(bundle.manifest, bundle.runtimeSnapshot)
    if IsErr(runtimeManifestBindingRes):
        return Err[bool](Error(runtimeManifestBindingRes))
    if !layout.FixedBytes32Equal(bundle.compilerSnapshot.csgRootCid, bundle.worldHead.csgRootCid):
        return Err[bool](" compiler world bundle: compiler csg root mismatch")
    if !layout.FixedBytes32Equal(bundle.stdSnapshot.csgRootCid, bundle.worldHead.csgRootCid):
        return Err[bool](" compiler world bundle: std csg root mismatch")
    if !layout.FixedBytes32Equal(bundle.runtimeSnapshot.csgRootCid, bundle.worldHead.csgRootCid):
        return Err[bool](" compiler world bundle: runtime csg root mismatch")
    if !layout.FixedBytes32Equal(bundle.compilerCanonicalCsgCid, bundle.worldHead.csgRootCid):
        return Err[bool](" compiler world bundle: csg report mismatch")
    if !layout.FixedBytes32Equal(bundle.exportSurface.surfaceCid, bundle.compilerSnapshot.exportSurfaceCid):
        return Err[bool](" compiler world bundle: export surface cid mismatch")
    let compilerDepsCid = CompilerWorldBundleExpectedCompilerDeps(bundle)
    if !layout.FixedBytes32Equal(bundle.compilerSnapshot.depsManifestCid, compilerDepsCid):
        return Err[bool](" compiler world bundle: compiler deps manifest mismatch")
    let emptyDepsCid = cworld.CompilerWorldEmptyManifestCid(bundle.worldHead.channel)
    if !layout.FixedBytes32Equal(bundle.stdSnapshot.depsManifestCid, emptyDepsCid):
        return Err[bool](" compiler world bundle: std deps manifest mismatch")
    if !layout.FixedBytes32Equal(bundle.runtimeSnapshot.depsManifestCid, emptyDepsCid):
        return Err[bool](" compiler world bundle: runtime deps manifest mismatch")
    if !layout.FixedBytes32Equal(bundle.receipt.worldHeadCid, bundle.worldHead.headCid):
        return Err[bool](" compiler world bundle: receipt world head mismatch")
    if !layout.FixedBytes32Equal(bundle.receipt.compilerCsgCid, bundle.compilerCsgCid):
        return Err[bool](" compiler world bundle: receipt csg mismatch")
    if !layout.FixedBytes32Equal(bundle.receipt.canonicalCompilerCsgCid, bundle.compilerCanonicalCsgCid):
        return Err[bool](" compiler world bundle: receipt canonical csg mismatch")
    let expectedHead = cworld.CompilerWorldHeadMake(bundle.worldHead.channel,
                                                      bundle.worldHead.headEpoch,
                                                      bundle.worldHead.prevHeadCid,
                                                      bundle.manifest,
                                                      bundle.compilerCanonicalCsgCid,
                                                      bundle.compilerSnapshot.snapshotCid,
                                                      bundle.stdSnapshot.snapshotCid,
                                                      bundle.runtimeSnapshot.snapshotCid,
                                                      bundle.worldHead.signature)
    if !layout.FixedBytes32Equal(expectedHead.headCid, bundle.worldHead.headCid):
        return Err[bool](" compiler world bundle: world head cid mismatch")
    let expectedReceipt = ccsg.CompileReceiptMake(bundle.worldHead.headCid,
                                                    bundle.compilerCsgCid,
                                                    bundle.compilerCanonicalCsgCid,
                                                    bundle.receipt.targetTriple,
                                                    bundle.receipt.outputDigest,
                                                    bundle.receipt.canonicalOutputDigest,
                                                    bundle.receipt.bootstrapStage,
                                                    bundle.receipt.runtimeProviderSet)
    if !layout.FixedBytes32Equal(expectedReceipt.receiptCid, bundle.receipt.receiptCid):
        return Err[bool](" compiler world bundle: receipt cid mismatch")
    let lockVerifyRes = cworld.CompilerWorldVerifyLock(CompilerWorldBundleUniverse(bundle), bundle.lock)
    if IsErr(lockVerifyRes):
        return Err[bool](Error(lockVerifyRes))
    return Ok[bool](true)

fn CompilerWorldBundleReadAndVerify(rootDir: str,
                                      prefixRaw: str,
                                      out: var CompilerWorldBundle): Result[bool] =
    let readRes = CompilerWorldBundleRead(rootDir, prefixRaw, out)
    if IsErr(readRes):
        return Err[bool](Error(readRes))
    return CompilerWorldBundleVerify(out)
