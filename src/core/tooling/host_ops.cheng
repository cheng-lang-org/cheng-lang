import std/os
import std/os_host_process as hostos
import std/buffer
import std/rawbytes
import std/result
import std/strutils as strutil
import std/strings
import std/monotimes
import cheng/core/tooling/path as chengpath

@importc("getpid")
fn HostOpsGetPidBridge(): int32

@importc("exit")
fn HostOpsExitBridge(code: int32)

type
    LoggedRun =
        label: str
        filePath: str
        logPath: str
        exitCode: int32
        output: str

    SpawnedProcess =
        label: str
        filePath: str
        readFd: int32
        writeFd: int32
        pid: int64
        output: str
        liveLogPath: str
        liveLogLen: int32

    ParallelJob =
        label: str
        logPath: str
        proc: SpawnedProcess

const
    ProcessSigTerm = 15
    ProcessSigKill = 9
    ProcessRunning = -2147483000
    ProcessMemoryExceeded = 125
    ProcessMemoryCheckIntervalNs = int64(500000000)

fn LoggedRunMake(label: str,
                   filePath: str,
                   logPath: str,
                   exitCode: int32,
                   output: str): LoggedRun =
    var out: LoggedRun
    out.label = label
    out.filePath = filePath
    out.logPath = logPath
    out.exitCode = exitCode
    out.output = output
    return out

fn SpawnedProcessMake(label: str,
                        filePath: str,
                        readFd: int32,
                        writeFd: int32,
                        pid: int64,
                        output: str,
                        liveLogPath: str,
                        liveLogLen: int32): SpawnedProcess =
    var out: SpawnedProcess
    out.label = label
    out.filePath = filePath
    out.readFd = readFd
    out.writeFd = writeFd
    out.pid = pid
    out.output = output
    out.liveLogPath = liveLogPath
    out.liveLogLen = liveLogLen
    return out

fn ParallelJobMake(label: str,
                     logPath: str,
                     proc: SpawnedProcess): ParallelJob =
    var out: ParallelJob
    out.label = label
    out.logPath = logPath
    out.proc = proc
    return out

fn HostOpsMissingExecutableText(programName: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    let prefix = "missing executable: "
    let newline = "\n"
    buffer.AppendBytes(out, prefix)
    buffer.AppendBytes(out, programName)
    buffer.AppendBytes(out, newline)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn ExecFileDirect(filePath: str, argv: str[], envOverrides: str[],
                    workingDir: str, timeoutSec: int32,
                    capturePreferred: bool): os.ExecCmdResult =
    let _ = capturePreferred
    return hostos.ExecFileCapture(filePath, argv, envOverrides, workingDir, true, timeoutSec)

fn ResolveProgram(root: str, nameRaw: str): str =
    let name: str = strutil.Strip(nameRaw)
    if len(name) <= 0:
        return ""
    if strutil.Contains(name, "/"):
        let absolute: str = chengpath.PathAbsolute(root, name)
        if chengpath.FileExistsNonEmpty(root, absolute):
            return absolute
        return ""
    let pathEnv: str = os.getEnv("PATH")
    let total: int32 = strings.Len(pathEnv)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif pathEnv[i] == ':':
            endHit = true
        if !endHit:
            continue
        let itemLen: int32 = i - start
        if itemLen > 0:
            let dirText: str = chengpath.TextSlice(pathEnv, start, itemLen)
            let candidate: str = os.JoinPath(dirText, name)
            if chengpath.FileExistsNonEmpty(root, candidate):
                return candidate
        start = i + 1
    return ""

fn RunFileLogged(root: str, label: str, filePathRaw: str, argv: str[], envOverrides: str[],
                   workingDirRaw: str, timeoutSec: int32, logPathRaw: str): LoggedRun =
    let filePath: str = chengpath.PathAbsolute(root, filePathRaw)
    var workingDir: str = chengpath.PathAbsolute(root, workingDirRaw)
    if !chengpath.PathNonEmpty(workingDirRaw):
        workingDir = root
    let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
    if !chengpath.FileExistsNonEmpty(root, filePath):
        let missingText = HostOpsMissingExecutableText(filePath)
        let _logged: bool = chengpath.WriteTextFile(root, logPath, missingText)
        return LoggedRunMake(label, filePath, logPath, 127, missingText)
    let maxRssBytes: int64 = HostOpsConfiguredMaxRssBytes(envOverrides)
    if maxRssBytes < int64(0):
        let configText = "invalid CHENG_PROCESS_MAX_RSS_BYTES\n"
        let _logged: bool = chengpath.WriteTextFile(root, logPath, configText)
        return LoggedRunMake(label, filePath, logPath, 2, configText)
    if HostOpsLiveProgressEnabled(envOverrides) || maxRssBytes > int64(0):
        let spawnRes = hostos.ExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)
        if !spawnRes.ok || spawnRes.pid <= 0 || spawnRes.readFd < 0:
            let outputText = strutil.Join(["spawn pid missing: ", filePath, "\n"], "")
            let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
            return LoggedRunMake(label, filePath, logPath, 1, outputText)
        var writeFd = spawnRes.writeFd
        if writeFd >= 0:
            hostos.PtyClose(writeFd)
            writeFd = -1
        var proc = SpawnedProcessMake(label,
                                        filePath,
                                        spawnRes.readFd,
                                        writeFd,
                                        spawnRes.pid,
                                        "",
                                        "",
                                        0)
        return SpawnedProcessWaitLoggedLive(root, proc, timeoutSec, maxRssBytes, logPathRaw)
    let res: os.ExecCmdResult = ExecFileDirect(filePath, argv, envOverrides, workingDir, timeoutSec, true)
    let outputText = res.output
    let exitCode = res.exitCode
    let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
    return LoggedRunMake(label, filePath, logPath, exitCode, outputText)

fn RunProgramLogged(root: str, label: str, programName: str, argv: str[], envOverrides: str[],
                      workingDirRaw: str, timeoutSec: int32, logPathRaw: str): LoggedRun =
    let programPath: str = ResolveProgram(root, programName)
    if !chengpath.PathNonEmpty(programPath):
        let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
        let missingText = HostOpsMissingExecutableText(programName)
        let _logged: bool = chengpath.WriteTextFile(root, logPath, missingText)
        return LoggedRunMake(label, programName, logPath, 127, missingText)
    return RunFileLogged(root, label, programPath, argv, envOverrides, workingDirRaw, timeoutSec, logPathRaw)

fn RunFileLoggedExitCode(root: str,
                           label: str,
                           filePathRaw: str,
                           argv: str[],
                           envOverrides: str[],
                           workingDirRaw: str,
                           timeoutSec: int32,
                           logPathRaw: str): int32 =
    let filePath: str = chengpath.PathAbsolute(root, filePathRaw)
    var workingDir: str = chengpath.PathAbsolute(root, workingDirRaw)
    if !chengpath.PathNonEmpty(workingDirRaw):
        workingDir = root
    let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
    if !chengpath.FileExistsNonEmpty(root, filePath):
        let missingText = HostOpsMissingExecutableText(filePath)
        let _logged: bool = chengpath.WriteTextFile(root, logPath, missingText)
        return 127
    let maxRssBytes: int64 = HostOpsConfiguredMaxRssBytes(envOverrides)
    if maxRssBytes < int64(0):
        let configText = "invalid CHENG_PROCESS_MAX_RSS_BYTES\n"
        let _logged: bool = chengpath.WriteTextFile(root, logPath, configText)
        return 2
    if HostOpsLiveProgressEnabled(envOverrides) || maxRssBytes > int64(0):
        let spawnRes = hostos.ExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)
        if !spawnRes.ok || spawnRes.pid <= 0 || spawnRes.readFd < 0:
            let outputText = strutil.Join(["spawn pid missing: ", filePath, "\n"], "")
            let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
            return 1
        var writeFd = spawnRes.writeFd
        if writeFd >= 0:
            hostos.PtyClose(writeFd)
            writeFd = -1
        var proc = SpawnedProcessMake(label,
                                        filePath,
                                        spawnRes.readFd,
                                        writeFd,
                                        spawnRes.pid,
                                        "",
                                        "",
                                        0)
        return SpawnedProcessWaitLoggedLiveExitCode(root,
                                                    proc,
                                                    timeoutSec,
                                                    maxRssBytes,
                                                    logPathRaw)
    let res: os.ExecCmdResult = ExecFileDirect(filePath, argv, envOverrides, workingDir, timeoutSec, true)
    let outputText = res.output
    let exitCode = res.exitCode
    let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
    return exitCode

fn RunFileLoggedWithInputText(root: str,
                                label: str,
                                filePathRaw: str,
                                argv: str[],
                                envOverrides: str[],
                                workingDirRaw: str,
                                timeoutSec: int32,
                                logPathRaw: str,
                                inputText: str): LoggedRun =
    let filePath: str = chengpath.PathAbsolute(root, filePathRaw)
    var workingDir: str = chengpath.PathAbsolute(root, workingDirRaw)
    if !chengpath.PathNonEmpty(workingDirRaw):
        workingDir = root
    let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
    if !chengpath.FileExistsNonEmpty(root, filePath):
        let missingText = HostOpsMissingExecutableText(filePath)
        let _logged: bool = chengpath.WriteTextFile(root, logPath, missingText)
        return LoggedRunMake(label, filePath, logPath, 127, missingText)
    let spawnRes = hostos.ExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)
    if !spawnRes.ok || spawnRes.pid <= 0 || spawnRes.readFd < 0:
        let outputText = strutil.Join(["spawn pid missing: ", filePath, "\n"], "")
        let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
        return LoggedRunMake(label, filePath, logPath, 1, outputText)
    var proc = SpawnedProcessMake(label,
                                    filePath,
                                    spawnRes.readFd,
                                    spawnRes.writeFd,
                                    spawnRes.pid,
                                    "",
                                    "",
                                    0)
    let writeOk: bool = SpawnedProcessWriteAll(proc, inputText)
    SpawnedProcessCloseWrite(proc)
    if !writeOk:
        proc.output = strutil.Join([proc.output, "write stdin failed\n"], "")
        SpawnedProcessKill(proc)
        return SpawnedProcessFinalize(root, proc, logPathRaw, 1)
    return SpawnedProcessWaitLogged(root, proc, timeoutSec, logPathRaw)

fn RunProgramLoggedWithInputText(root: str,
                                   label: str,
                                   programName: str,
                                   argv: str[],
                                   envOverrides: str[],
                                   workingDirRaw: str,
                                   timeoutSec: int32,
                                   logPathRaw: str,
                                   inputText: str): LoggedRun =
    let programPath: str = ResolveProgram(root, programName)
    if !chengpath.PathNonEmpty(programPath):
        let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
        let missingText = HostOpsMissingExecutableText(programName)
        let _logged: bool = chengpath.WriteTextFile(root, logPath, missingText)
        return LoggedRunMake(label, programName, logPath, 127, missingText)
    return RunFileLoggedWithInputText(root,
                                        label,
                                        programPath,
                                        argv,
                                        envOverrides,
                                        workingDirRaw,
                                        timeoutSec,
                                        logPathRaw,
                                        inputText)

fn LoggedRunOk(run: LoggedRun): bool =
    return run.exitCode == 0

fn HostOpsEnvOverrideValue(envOverrides: str[],
                             key: str): str =
    let n: int32 = envOverrides.len
    for ri in range(n):
        let i: int32 = n - 1 - ri
        let item: str = strutil.Strip(envOverrides[i])
        if strutil.StartsWith(item, strutil.Join([key, "="], "")):
            return strings.SliceBytes(item, len(key) + 1, len(item) - len(key) - 1)
    return ""

fn HostOpsParseUnsignedInt64(raw: str): int64 =
    let text: str = strutil.Strip(raw)
    if len(text) <= 0:
        return int64(-1)
    var value: int64
    var hadDigit: bool
    for i in 0..<len(text):
        let ch: char = text[i]
        if ch < '0' || ch > '9':
            return int64(-1)
        value = value * int64(10) + int64(int32(ch) - int32('0'))
        hadDigit = true
    if !hadDigit:
        return int64(-1)
    return value

fn HostOpsConfiguredMaxRssBytes(envOverrides: str[]): int64 =
    var raw: str = strutil.Strip(HostOpsEnvOverrideValue(envOverrides, "CHENG_PROCESS_MAX_RSS_BYTES"))
    if len(raw) <= 0:
        raw = strutil.Strip(HostOpsEnvOverrideValue(envOverrides, "CHENG_MAX_RSS_BYTES"))
    if len(raw) <= 0:
        raw = strutil.Strip(os.GetEnv("CHENG_PROCESS_MAX_RSS_BYTES"))
    if len(raw) <= 0:
        raw = strutil.Strip(os.GetEnv("CHENG_MAX_RSS_BYTES"))
    if len(raw) <= 0:
        return int64(0)
    let parsed: int64 = HostOpsParseUnsignedInt64(raw)
    if parsed <= int64(0):
        return int64(-1)
    return parsed

fn HostOpsLiveProgressEnabled(envOverrides: str[]): bool =
    let progressText = strutil.Strip(HostOpsEnvOverrideValue(envOverrides, "CHENG_PROGRESS"))
    if len(progressText) > 0 && progressText != "0" && progressText != "false":
        return true
    let pathText = strutil.Strip(HostOpsEnvOverrideValue(envOverrides, "CHENG_PROGRESS_OUT"))
    return len(pathText) > 0

fn HostOpsProcessGroupRssBytes(pid: int64): int64 =
    if pid <= 0:
        return int64(-1)
    let psRun: os.ExecCmdResult = hostos.ExecFileCapture("/bin/ps",
                                                         ["-g", strings.Int64ToStr(pid), "-o", "rss="],
                                                         [],
                                                         "",
                                                         true,
                                                         2)
    if psRun.exitCode != 0:
        return int64(-1)
    let text: str = psRun.output
    var totalKb: int64
    var lineStart: int32
    for i in range(len(text) + 1):
        let atEnd = i == len(text)
        var splitHere = false
        if atEnd:
            splitHere = true
        else:
            splitHere = text[i] == '\n'
        if splitHere:
            let line: str = strings.SliceBytes(text, lineStart, i - lineStart)
            let kb: int64 = HostOpsParseUnsignedInt64(line)
            if kb > int64(0):
                totalKb = totalKb + kb
            lineStart = i + 1
    if totalKb <= int64(0):
        return int64(-1)
    return totalKb * int64(1024)

fn HostOpsCurrentPid(): int64 =
    return int64(HostOpsGetPidBridge())

fn HostOpsCurrentRssBytes(): int64 =
    let pid: int64 = HostOpsCurrentPid()
    if pid <= int64(0):
        return int64(-1)
    let psRun: os.ExecCmdResult = hostos.ExecFileCapture("/bin/ps",
                                                         ["-p", strings.Int64ToStr(pid), "-o", "rss="],
                                                         [],
                                                         "",
                                                         true,
                                                         2)
    if psRun.exitCode != 0:
        return int64(-1)
    let kb: int64 = HostOpsParseUnsignedInt64(psRun.output)
    if kb <= int64(0):
        return int64(-1)
    return kb * int64(1024)

fn HostOpsExitProcess(code: int32) =
    HostOpsExitBridge(code)

fn HostOpsMemoryLimitExceededLine(rssBytes: int64,
                                    maxRssBytes: int64): str =
    return strutil.Join(["compile_progress phase=resource_guard status=rss_limit_exceeded rss_bytes=", strings.Int64ToStr(rssBytes), " limit_bytes=", strings.Int64ToStr(maxRssBytes)], "")

fn LoggedRunSignalName(exitCode: int32): str =
    if exitCode < 129:
        return ""
    let signalCode: int32 = exitCode - 128
    if signalCode == 1:
        return "SIGHUP"
    if signalCode == 2:
        return "SIGINT"
    if signalCode == 3:
        return "SIGQUIT"
    if signalCode == 4:
        return "SIGILL"
    if signalCode == 5:
        return "SIGTRAP"
    if signalCode == 6:
        return "SIGABRT"
    if signalCode == 7:
        return "SIGBUS"
    if signalCode == 8:
        return "SIGFPE"
    if signalCode == 9:
        return "SIGKILL"
    if signalCode == 10:
        return "SIGUSR1"
    if signalCode == 11:
        return "SIGSEGV"
    if signalCode == 12:
        return "SIGUSR2"
    if signalCode == 13:
        return "SIGPIPE"
    if signalCode == 14:
        return "SIGALRM"
    if signalCode == 15:
        return "SIGTERM"
    return ""

fn LoggedRunSummary(run: LoggedRun): str =
    var out = ""
    out = strutil.Join([out, run.label], "")
    out = strutil.Join([out, " exit="], "")
    out = strutil.Join([out, strings.IntToStr(run.exitCode)], "")
    let signalName: str = LoggedRunSignalName(run.exitCode)
    if len(signalName) > 0:
        out = strutil.Join([out, " signal="], "")
        out = strutil.Join([out, signalName], "")
    out = strutil.Join([out, " log="], "")
    out = strutil.Join([out, run.logPath], "")
    return out

fn LoggedRunZero(label: str,
                   filePath: str,
                   logPath: str,
                   exitCode: int32,
                   output: str): LoggedRun =
    return LoggedRunMake(label, filePath, logPath, exitCode, output)

fn HostOpsAppendLiveLog(proc: var SpawnedProcess) =
    let liveLogPath: str = proc.liveLogPath
    if len(liveLogPath) <= 0:
        return
    if !os.FileExists(liveLogPath):
        return
    let logText: str = chengpath.ReadTextFile("", liveLogPath)
    let logLen: int32 = len(logText)
    if logLen < proc.liveLogLen:
        proc.output = logText
        proc.liveLogLen = logLen
        return
    if logLen == proc.liveLogLen:
        return
    let chunk: str = strings.SliceBytes(logText, proc.liveLogLen, logLen - proc.liveLogLen)
    proc.output = strutil.Join([proc.output, chunk], "")
    proc.liveLogLen = logLen

fn SpawnedProcessAppendOutput(proc: var SpawnedProcess, chunk: str) =
    proc.output = strutil.Join([proc.output, chunk], "")

fn SpawnedProcessCloseRead(proc: var SpawnedProcess) =
    if proc.readFd >= 0:
        hostos.PtyClose(proc.readFd)
        proc.readFd = -1

fn SpawnedProcessCloseWrite(proc: var SpawnedProcess) =
    if proc.writeFd >= 0:
        hostos.PtyClose(proc.writeFd)
        proc.writeFd = -1

fn SpawnedProcessWriteAll(proc: var SpawnedProcess, data: str): bool =
    if len(data) <= 0:
        return true
    if proc.writeFd < 0:
        return false
    var cursor: int32
    let total: int32 = len(data)
    for _ in range(total - cursor):
        if cursor >= total:
            break
        let chunk: str = strings.SliceBytes(data, cursor, total - cursor)
        let wrote: int32 = hostos.ptyWrite(proc.writeFd, chunk)
        if wrote <= 0:
            return false
        cursor = cursor + wrote
    return true

fn SpawnedProcessCleanup(proc: var SpawnedProcess) =
    SpawnedProcessCloseRead(proc)
    SpawnedProcessCloseWrite(proc)
    proc.pid = 0
    proc.liveLogPath = ""
    proc.liveLogLen = 0

fn SpawnedProcessDrain(proc: var SpawnedProcess, timeoutMs: int32) =
    if len(proc.liveLogPath) > 0:
        HostOpsAppendLiveLog(proc)
        return
    if proc.readFd < 0:
        return
    var waitMs = timeoutMs
    while proc.readFd >= 0:
        let readRes = hostos.FdReadWait(proc.readFd, 65536, waitMs)
        let chunk = readRes.text
        let eof = readRes.eof
        if strings.Len(chunk) <= 0:
            if eof:
                SpawnedProcessCloseRead(proc)
            break
        SpawnedProcessAppendOutput(proc, chunk)
        waitMs = 0

fn SpawnedProcessSignal(proc: SpawnedProcess, signalCode: int32): bool =
    if proc.pid <= 0:
        return false
    return hostos.ProcessSignal(proc.pid, signalCode)

fn SpawnedProcessKill(proc: var SpawnedProcess) =
    if proc.pid <= 0:
        SpawnedProcessCleanup(proc)
        return
    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
    for i in 0..<20:
        i
        SpawnedProcessDrain(proc, 0)
        if !hostos.ProcessExists(proc.pid):
            SpawnedProcessCleanup(proc)
            return
        os.SleepMs(50)
    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
    for i in 0..<20:
        i
        SpawnedProcessDrain(proc, 0)
        if !hostos.ProcessExists(proc.pid):
            SpawnedProcessCleanup(proc)
            return
        os.SleepMs(50)
    SpawnedProcessDrain(proc, 0)
    SpawnedProcessCleanup(proc)

fn SpawnedProcessFinalize(root: str,
                            proc: var SpawnedProcess,
                            logPathRaw: str,
                            exitCode: int32): LoggedRun =
    let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
    let _logged: bool = chengpath.WriteTextFile(root, logPath, proc.output)
    let out = LoggedRunMake(proc.label,
                              proc.filePath,
                              logPath,
                              exitCode,
                              proc.output)
    proc = SpawnedProcess()
    return out

fn SpawnedProcessPoll(proc: var SpawnedProcess): int32 =
    if proc.pid <= 0:
        return 0
    SpawnedProcessDrain(proc, 0)
    if len(proc.liveLogPath) > 0:
        if hostos.ProcessExists(proc.pid):
            return ProcessRunning
        SpawnedProcessCleanup(proc)
        return 0
    let waitRes = hostos.PtyWait(proc.pid)
    let waitStatus = waitRes.waitStatus
    if waitStatus == 1:
        let exitCode = waitRes.exitCode
        SpawnedProcessDrain(proc, 0)
        SpawnedProcessCleanup(proc)
        return exitCode
    if waitStatus < 0:
        SpawnedProcessDrain(proc, 0)
        SpawnedProcessCleanup(proc)
        return -1
    return ProcessRunning

fn SpawnedProcessRunning(proc: var SpawnedProcess): bool =
    let exitCode = SpawnedProcessPoll(proc)
    return exitCode == ProcessRunning

fn HostOpsEchoProgressChunk(chunk: str) =
    var start: int32
    let n = len(chunk)
    for i in range(n + 1):
        if i == n:
            let line = strings.SliceBytes(chunk, start, i - start)
            if len(line) > 0 && strutil.StartsWith(line, "compile_progress "):
                os.WriteLine(os.Get_stderr(), line)
            start = i + 1
        elif chunk[i] == '\n':
            let line = strings.SliceBytes(chunk, start, i - start)
            if len(line) > 0 && strutil.StartsWith(line, "compile_progress "):
                os.WriteLine(os.Get_stderr(), line)
            start = i + 1

fn SpawnedProcessWaitLoggedLive(root: str,
                                  proc: var SpawnedProcess,
                                  timeoutSec: int32,
                                  maxRssBytes: int64,
                                  logPathRaw: str): LoggedRun =
    let start = monotimes.getMonoTime()
    let startNs: int64 = monotimes.monoTimeNs(start)
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut = false
    var memoryExceeded = false
    var termSent = false
    var termAtNs: int64
    var nextMemoryCheckNs: int64
    var exceededRssBytes: int64
    var exitCode = -1
    while proc.pid > 0:
        let beforeLen = len(proc.output)
        SpawnedProcessDrain(proc, 20)
        if len(proc.output) > beforeLen:
            let chunk = strings.SliceBytes(proc.output, beforeLen, len(proc.output) - beforeLen)
            HostOpsEchoProgressChunk(chunk)
        let nowTime = monotimes.getMonoTime()
        let nowNs: int64 = monotimes.monoTimeNs(nowTime) - startNs
        var checkMemory = false
        if maxRssBytes > int64(0):
            if nowNs >= nextMemoryCheckNs:
                checkMemory = true
        if checkMemory:
            nextMemoryCheckNs = nowNs + int64(500000000)
            let rssBytes: int64 = HostOpsProcessGroupRssBytes(proc.pid)
            if rssBytes > maxRssBytes:
                memoryExceeded = true
                exceededRssBytes = rssBytes
                let guardLine: str = HostOpsMemoryLimitExceededLine(rssBytes, maxRssBytes)
                proc.output = strutil.Join([proc.output, guardLine, "\n"], "")
                os.WriteLine(os.Get_stderr(), guardLine)
                if !termSent:
                    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
            if memoryExceeded && nowNs - termAtNs >= int64(500000000):
                let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
        if len(proc.liveLogPath) > 0:
            if !hostos.ProcessExists(proc.pid):
                exitCode = 0
                proc.pid = 0
                break
            if timeoutSec > 0:
                if nowNs >= timeoutNs:
                    timedOut = true
                    if !termSent:
                        let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                        termSent = true
                        termAtNs = nowNs
                    elif nowNs - termAtNs >= int64(500000000):
                        let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                    os.SleepMs(20)
                    continue
            os.SleepMs(10)
            continue
        let waitRes = hostos.PtyWait(proc.pid)
        let waitStatus = waitRes.waitStatus
        if waitStatus == 1:
            exitCode = waitRes.exitCode
            proc.pid = 0
            break
        if waitStatus < 0:
            exitCode = -1
            proc.pid = 0
            break
        if timeoutSec > 0:
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
        os.SleepMs(10)
    let beforeLen = len(proc.output)
    SpawnedProcessDrain(proc, 0)
    if len(proc.output) > beforeLen:
        let chunk = strings.SliceBytes(proc.output, beforeLen, len(proc.output) - beforeLen)
        HostOpsEchoProgressChunk(chunk)
    SpawnedProcessCloseWrite(proc)
    SpawnedProcessCloseRead(proc)
    if timedOut:
        exitCode = 124
    if memoryExceeded:
        exitCode = ProcessMemoryExceeded
        if exceededRssBytes > int64(0):
            let finalGuardLine: str = HostOpsMemoryLimitExceededLine(exceededRssBytes, maxRssBytes)
            if !strutil.Contains(proc.output, finalGuardLine):
                proc.output = strutil.Join([proc.output, finalGuardLine, "\n"], "")
    let logPathAbsRaw: str = chengpath.PathAbsolute(root, logPathRaw)
    let logPath: str = newStringCopy(strDataPtr(logPathAbsRaw), strLenFast(logPathAbsRaw))
    let outputText: str = proc.output
    let _logged: bool = chengpath.WriteTextFile(root, logPath, outputText)
    let out = LoggedRunMake(proc.label,
                              proc.filePath,
                              logPath,
                              exitCode,
                              proc.output)
    proc = SpawnedProcess()
    return out

fn SpawnedProcessWaitLoggedLiveExitCode(root: str,
                                          proc: var SpawnedProcess,
                                          timeoutSec: int32,
                                          maxRssBytes: int64,
                                          logPathRaw: str): int32 =
    let start = monotimes.getMonoTime()
    let startNs: int64 = monotimes.monoTimeNs(start)
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut = false
    var memoryExceeded = false
    var termSent = false
    var termAtNs: int64
    var nextMemoryCheckNs: int64
    var exceededRssBytes: int64
    var exitCode = -1
    while proc.pid > 0:
        let beforeLen = len(proc.output)
        SpawnedProcessDrain(proc, 20)
        if len(proc.output) > beforeLen:
            let chunk = strings.SliceBytes(proc.output, beforeLen, len(proc.output) - beforeLen)
            HostOpsEchoProgressChunk(chunk)
        let nowTime = monotimes.getMonoTime()
        let nowNs: int64 = monotimes.monoTimeNs(nowTime) - startNs
        var checkMemory = false
        if maxRssBytes > int64(0):
            if nowNs >= nextMemoryCheckNs:
                checkMemory = true
        if checkMemory:
            nextMemoryCheckNs = nowNs + int64(500000000)
            let rssBytes: int64 = HostOpsProcessGroupRssBytes(proc.pid)
            if rssBytes > maxRssBytes:
                memoryExceeded = true
                exceededRssBytes = rssBytes
                let guardLine: str = HostOpsMemoryLimitExceededLine(rssBytes, maxRssBytes)
                proc.output = strutil.Join([proc.output, guardLine, "\n"], "")
                os.WriteLine(os.Get_stderr(), guardLine)
                if !termSent:
                    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
            if memoryExceeded && nowNs - termAtNs >= int64(500000000):
                let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
        if len(proc.liveLogPath) > 0:
            if !hostos.ProcessExists(proc.pid):
                exitCode = 0
                proc.pid = 0
                break
            if timeoutSec > 0:
                if nowNs >= timeoutNs:
                    timedOut = true
                    if !termSent:
                        let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                        termSent = true
                        termAtNs = nowNs
                    elif nowNs - termAtNs >= int64(500000000):
                        let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                    os.SleepMs(20)
                    continue
            os.SleepMs(10)
            continue
        let waitRes = hostos.PtyWait(proc.pid)
        let waitStatus = waitRes.waitStatus
        if waitStatus == 1:
            exitCode = waitRes.exitCode
            proc.pid = 0
            break
        if waitStatus < 0:
            exitCode = -1
            proc.pid = 0
            break
        if timeoutSec > 0:
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
        os.SleepMs(10)
    let beforeLen = len(proc.output)
    SpawnedProcessDrain(proc, 0)
    if len(proc.output) > beforeLen:
        let chunk = strings.SliceBytes(proc.output, beforeLen, len(proc.output) - beforeLen)
        HostOpsEchoProgressChunk(chunk)
    SpawnedProcessCloseWrite(proc)
    SpawnedProcessCloseRead(proc)
    if timedOut:
        exitCode = 124
    if memoryExceeded:
        exitCode = ProcessMemoryExceeded
        if exceededRssBytes > int64(0):
            let finalGuardLine: str = HostOpsMemoryLimitExceededLine(exceededRssBytes, maxRssBytes)
            if !strutil.Contains(proc.output, finalGuardLine):
                proc.output = strutil.Join([proc.output, finalGuardLine, "\n"], "")
    let logPath: str = chengpath.PathAbsolute(root, logPathRaw)
    let _logged: bool = chengpath.WriteTextFile(root, logPath, proc.output)
    proc = SpawnedProcess()
    return exitCode

fn SpawnedProcessWaitLogged(root: str,
                              proc: var SpawnedProcess,
                              timeoutSec: int32,
                              logPathRaw: str): LoggedRun =
    let logPathAbsRaw: str = chengpath.PathAbsolute(root, logPathRaw)
    let logPath: str = newStringCopy(strDataPtr(logPathAbsRaw), strLenFast(logPathAbsRaw))
    let start = monotimes.getMonoTime()
    let startNs: int64 = monotimes.monoTimeNs(start)
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut = false
    var termSent = false
    var termAtNs: int64
    var exitCode = -1
    while proc.pid > 0:
        SpawnedProcessDrain(proc, 20)
        if len(proc.liveLogPath) > 0:
            if !hostos.ProcessExists(proc.pid):
                exitCode = 0
                proc.pid = 0
                break
            if timeoutSec > 0:
                let nowTime = monotimes.getMonoTime()
                let nowNs: int64 = monotimes.monoTimeNs(nowTime) - startNs
                if nowNs >= timeoutNs:
                    timedOut = true
                    if !termSent:
                        let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                        termSent = true
                        termAtNs = nowNs
                    elif nowNs - termAtNs >= int64(500000000):
                        let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                    os.SleepMs(20)
                    continue
            os.SleepMs(10)
            continue
        let waitRes = hostos.PtyWait(proc.pid)
        let waitStatus = waitRes.waitStatus
        if waitStatus == 1:
            exitCode = waitRes.exitCode
            proc.pid = 0
            break
        if waitStatus < 0:
            exitCode = -1
            proc.pid = 0
            break
        if timeoutSec > 0:
            let nowTime = monotimes.getMonoTime()
            let nowNs: int64 = monotimes.monoTimeNs(nowTime) - startNs
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term = SpawnedProcessSignal(proc, ProcessSigTerm)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = SpawnedProcessSignal(proc, ProcessSigKill)
                os.SleepMs(20)
                continue
        os.SleepMs(10)
    SpawnedProcessDrain(proc, 0)
    SpawnedProcessCloseWrite(proc)
    SpawnedProcessCloseRead(proc)
    if timedOut:
        exitCode = 124
    let outputText: str = proc.output
    let logPathText: str = logPath
    let _logged: bool = chengpath.WriteTextFile(root, logPathText, outputText)
    let out = LoggedRunMake(proc.label,
                              proc.filePath,
                              logPath,
                              exitCode,
                              proc.output)
    proc = SpawnedProcess()
    return out

fn SpawnFile(root: str,
               label: str,
               filePathRaw: str,
               argv: str[],
               envOverrides: str[],
               workingDirRaw: str): Result[SpawnedProcess] =
    let filePath: str = chengpath.PathAbsolute(root, filePathRaw)
    var workingDir: str = chengpath.PathAbsolute(root, workingDirRaw)
    if !chengpath.PathNonEmpty(workingDirRaw):
        workingDir = root
    if !chengpath.FileExistsNonEmpty(root, filePath):
        var err = "spawn failed: "
        err = strutil.Join([err, filePath], "")
        return Err[SpawnedProcess](err)
    let spawnRes = hostos.ExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)
    if !spawnRes.ok || spawnRes.pid <= 0 || spawnRes.readFd < 0:
        return Err[SpawnedProcess](strutil.Join(["spawn pid missing: ", filePath], ""))
    var writeFd = spawnRes.writeFd
    if writeFd >= 0:
        hostos.PtyClose(writeFd)
        writeFd = -1
    return Ok[SpawnedProcess](SpawnedProcessMake(label,
                                                     filePath,
                                                     spawnRes.readFd,
                                                     writeFd,
                                                     spawnRes.pid,
                                                     "",
                                                     "",
                                                     0))

fn SpawnProgram(root: str,
                  label: str,
                  programName: str,
                  argv: str[],
                  envOverrides: str[],
                  workingDirRaw: str): Result[SpawnedProcess] =
    let programPath: str = ResolveProgram(root, programName)
    if !chengpath.PathNonEmpty(programPath):
        return Err[SpawnedProcess](HostOpsMissingExecutableText(programName))
    return SpawnFile(root, label, programPath, argv, envOverrides, workingDirRaw)

fn ParallelSpawnFile(root: str,
                       label: str,
                       filePathRaw: str,
                       argv: str[],
                       envOverrides: str[],
                       workingDirRaw: str,
                       logPathRaw: str): Result[ParallelJob] =
    let spawnRes = SpawnFile(root, label, filePathRaw, argv, envOverrides, workingDirRaw)
    if IsErr(spawnRes):
        return Err[ParallelJob](Error(spawnRes))
    return Ok[ParallelJob](ParallelJobMake(label,
                                               chengpath.PathAbsolute(root, logPathRaw),
                                               Value(spawnRes)))

fn ParallelSpawnProgram(root: str,
                          label: str,
                          programName: str,
                          argv: str[],
                          envOverrides: str[],
                          workingDirRaw: str,
                          logPathRaw: str): Result[ParallelJob] =
    let spawnRes = SpawnProgram(root, label, programName, argv, envOverrides, workingDirRaw)
    if IsErr(spawnRes):
        return Err[ParallelJob](Error(spawnRes))
    return Ok[ParallelJob](ParallelJobMake(label,
                                               chengpath.PathAbsolute(root, logPathRaw),
                                               Value(spawnRes)))

fn ParallelStopAll(root: str,
                     jobs: var ParallelJob[],
                     exitCode: int32) =
    for i in 0..<jobs.len:
        if jobs[i].proc.pid <= 0:
            continue
        SpawnedProcessKill(jobs[i].proc)
        let _run = SpawnedProcessFinalize(root, jobs[i].proc, jobs[i].logPath, exitCode)
        jobs[i].proc = SpawnedProcess()

fn ParallelWaitFailfast(root: str,
                          jobs: var ParallelJob[],
                          timeoutSec: int32,
                          failedRun: var LoggedRun): bool =
    let start = monotimes.getMonoTime()
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    failedRun = LoggedRunZero("", "", "", 0, "")
    while true:
        var allDone = true
        for i in 0..<jobs.len:
            if jobs[i].proc.pid <= 0:
                continue
            allDone = false
            let exitCode = SpawnedProcessPoll(jobs[i].proc)
            if exitCode == ProcessRunning:
                continue
            let run = SpawnedProcessFinalize(root, jobs[i].proc, jobs[i].logPath, exitCode)
            if run.exitCode != 0:
                failedRun = run
                ParallelStopAll(root, jobs, 124)
                return false
        if allDone:
            return true
        if timeoutSec > 0:
            let elapsedNs: int64 = monotimes.monoTimeNs(monotimes.getMonoTime()) - monotimes.monoTimeNs(start)
            if elapsedNs >= timeoutNs:
                for i in 0..<jobs.len:
                    if jobs[i].proc.pid <= 0:
                        continue
                    failedRun = LoggedRunZero(jobs[i].label,
                                                jobs[i].proc.filePath,
                                                jobs[i].logPath,
                                                124,
                                                jobs[i].proc.output)
                    break
                ParallelStopAll(root, jobs, 124)
                if len(failedRun.label) <= 0:
                    failedRun = LoggedRunZero("parallel_timeout", "", "", 124, "parallel timeout\n")
                return false
        os.SleepMs(10)
