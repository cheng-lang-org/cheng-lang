-- Determinism driver: compiles source twice with different output paths,
-- compares SHA256, reloc, and cstring for deterministic output.

import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/determinism_gate as detgate
import cheng/core/tooling/gate_main as gateref

fn DeterminismGateVerifyBackendDriverOutput(root: str,
                                              sourcePath: str): int32 =
    if !os.FileExists(sourcePath):
        gateref.GatePrintErr(strutil.Join(["determinism_driver: source missing: ", sourcePath], ""))
        return 1
    let detDir = strutil.Join([root, "/artifacts/determinism"], "")
    os.MkdirAll(detDir, 0x1FF)
    let outPathA = strutil.Join([detDir, "/det_a"], "")
    let outPathB = strutil.Join([detDir, "/det_b"], "")
    let stageCmd = "compile-exe"
    var detArgs: str[]
    add(detArgs, strutil.Join(["--in:", sourcePath], ""))
    add(detArgs, strutil.Join(["--out:", outPathA], ""))
    let rcA = gateref.GateRunStage3Command(root,
        "determinism_a",
        stageCmd,
        detArgs,
        "determinism_a.log",
        false)
    if rcA != 0:
        gateref.GatePrintErr(strutil.Join(["determinism_driver: run A exit=", strings.IntToStr(rcA)], ""))
        return 1
    var detArgsB: str[]
    add(detArgsB, strutil.Join(["--in:", sourcePath], ""))
    add(detArgsB, strutil.Join(["--out:", outPathB], ""))
    let rcB = gateref.GateRunStage3Command(root,
        "determinism_b",
        stageCmd,
        detArgsB,
        "determinism_b.log",
        false)
    if rcB != 0:
        gateref.GatePrintErr(strutil.Join(["determinism_driver: run B exit=", strings.IntToStr(rcB)], ""))
        return 1
    var gate = detgate.DeterminismGateNew(outPathA, outPathB)
    if !detgate.DeterminismGateVerifyOutputDeterminism(gate):
        gateref.GatePrintErr("determinism_driver: binary SHA mismatch")
        gateref.GatePrintLine(strutil.Strip(gate.report))
        os.RemoveFile(outPathA)
        os.RemoveFile(outPathB)
        return 1
    let relocA = strutil.Join([outPathA, ".reloc"], "")
    let relocB = strutil.Join([outPathB, ".reloc"], "")
    if os.FileExists(relocA) || os.FileExists(relocB):
        if !detgate.DeterminismGateVerifyRelocDeterminism(relocA, relocB):
            gateref.GatePrintErr("determinism_driver: reloc SHA mismatch")
            os.RemoveFile(outPathA)
            os.RemoveFile(outPathB)
            os.RemoveFile(relocA)
            os.RemoveFile(relocB)
            return 1
        os.RemoveFile(relocA)
        os.RemoveFile(relocB)
    let cstringA = strutil.Join([outPathA, ".cstring"], "")
    let cstringB = strutil.Join([outPathB, ".cstring"], "")
    if os.FileExists(cstringA) || os.FileExists(cstringB):
        if !detgate.DeterminismGateVerifyCstringDeterminism(cstringA, cstringB):
            gateref.GatePrintErr("determinism_driver: cstring SHA mismatch")
            os.RemoveFile(outPathA)
            os.RemoveFile(outPathB)
            os.RemoveFile(cstringA)
            os.RemoveFile(cstringB)
            return 1
        os.RemoveFile(cstringA)
        os.RemoveFile(cstringB)
    os.RemoveFile(outPathA)
    os.RemoveFile(outPathB)
    gateref.GatePrintLine(" determinism_driver: PASS")
    return 0
