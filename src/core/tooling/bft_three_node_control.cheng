type
    BftThreeNodeDeploy =
        appId: str
        serverSsh: str
        relaySsh: str
        serverAddress: str
        serverRepoRoot: str
        relayRepoRoot: str
        localDeployDir: str
        remoteDeployRel: str
        proposalPort: int32
        commitPort: int32
        votePort: int32
        statePort: int32
        proposerIntervalMs: int32
        followerIntervalMs: int32
        proposalWindowMs: int32
        voteWindowMs: int32
        commitWindowMs: int32
        defaultMaxTxs: int32
        assetId: int32
        aliceId: int32
        bobId: int32
        mintAmount: int64
        transferAmount: int64

    BftNodeStatus =
        name: str
        summary: str
        aliceQuery: str
        bobQuery: str
        height: str
        appHash: str
        aliceBalance: str
        bobBalance: str

fn GatePrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn GatePrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn GatePrintKv(prefix: str, value: str) =
    GatePrintLine(prefix + value)

fn GateReadFlag(args: str[], key: str, defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, key + ":"):
            return strings.DropPrefix(arg, key + ":")
        if strutil.StartsWith(arg, key + "="):
            return strings.DropPrefix(arg, key + "=")
    return defaultValue

fn GateRunFailed(run: hostops.LoggedRun): bool =
    if hostops.LoggedRunOk(run):
        return false
    GatePrintErr(hostops.LoggedRunSummary(run))
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return true

fn GateMaybePrintRunOutput(run: hostops.LoggedRun) =
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintLine(outputText)

fn GateShellArgv(args: str[]): str =
    var out = ""
    for i in 0..<args.len:
        if i > 0:
            out = out + " "
        out = out + os.QuoteShell(args[i])
    return out

fn GateTextValue(text: str, key: str): str =
    let prefix = key + "="
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text):
            if text[end] == '\n':
                break
            if text[end] == '\r':
                break
            end = end + 1
        let line = chengpath.TextSlice(text, start, end - start)
        if chengpath.TextStartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
        start = end + 1
        while start < len(text):
            if text[start] != '\n':
                if text[start] != '\r':
                    break
            start = start + 1
    return ""

fn GateRunShellLogged(root: str,
                        label: str,
                        command: str,
                        logPath: str,
                        timeoutSec: int32): hostops.LoggedRun =
    return hostops.RunProgramLogged(root,
                                      label,
                                      "sh",
                                      ["-lc", command],
                                      [],
                                      root,
                                      timeoutSec,
                                      logPath)

fn GateRemoteTransportRetryable(text: str): bool =
    let trimmed = strutil.Strip(text)
    return strutil.Contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.Contains(trimmed, "Connection to ") && strutil.Contains(trimmed, " timed out")) ||
           strutil.Contains(trimmed, "No route to host") ||
           strutil.Contains(trimmed, "Connection reset by peer") ||
           strutil.Contains(trimmed, "kex_exchange_identification") ||
           strutil.Contains(trimmed, "Connection closed by remote host")

fn GateRemoteSshArgv(sshHost: str, remoteCmd: str): str[] =
    return [
        "-n",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        sshHost,
        remoteCmd
    ]

fn GateRemoteScriptSafeToken(text: str): str =
    if len(text) == 0:
        return "x"
    var out = ""
    for i in 0..<len(text):
        let part = strings.SliceBytes(text, i, 1)
        let ch = part[0]
        if (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           (ch >= '0' && ch <= '9'):
            out = out + part
        else:
            out = out + "_"
    if len(out) == 0:
        return "x"
    return out

fn GateRemoteScriptLocalPath(root: str, logPath: str): str =
    let localPath = chengpath.PathAbsolute(root, logPath + ".remote.sh")
    let _ = chengpath.MkdirP(root, chengpath.PathParentDir(localPath))
    return localPath

fn GateRemoteScriptPath(label: str): str =
    return "/tmp/cheng_gate_" + GateRemoteScriptSafeToken(label) + ".sh"

fn GateRemoteScpArgv(sshHost: str, localPath: str, remotePath: str): str[] =
    return [
        "-q",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        localPath,
        sshHost + ":" + remotePath
    ]

fn GateRunRemoteShellLogged(root: str,
                              label: str,
                              sshHost: str,
                              command: str,
                              logPath: str,
                              timeoutSec: int32): hostops.LoggedRun =
    let localScript = GateRemoteScriptLocalPath(root, logPath)
    let scriptText = "#!/bin/sh\n" + command + "\n"
    if !chengpath.WriteTextFile(root, localScript, scriptText):
        return hostops.LoggedRunZero(label,
                                       "ssh",
                                       chengpath.PathAbsolute(root, logPath),
                                       1,
                                       " gate: remote script write failed: " + localScript + "\n")
    var lastRun = hostops.LoggedRunZero(label, "ssh", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.RunProgramLoggedWithInputText(root,
                                                          label,
                                                          "ssh",
                                                          [
                                                              "-T",
                                                              "-o", "BatchMode=yes",
                                                              "-o", "ConnectTimeout=20",
                                                              "-o", "ServerAliveInterval=5",
                                                              "-o", "ServerAliveCountMax=3",
                                                              sshHost,
                                                              "sh"
                                                          ],
                                                          [],
                                                          root,
                                                          timeoutSec,
                                                          logPath,
                                                          scriptText)
        lastRun = run
        if !GateRunFailed(run):
            return run
        if attempt >= 2 || !GateRemoteTransportRetryable(run.output):
            return run
        GatePrintLine("[ gate] remote ssh retry " + intToStr(attempt + 1) + " " + label)
        os.SleepMs((attempt + 1) * 1000)
    return lastRun

fn GateShellCheckOk(root: str, command: str): bool =
    let run = hostops.RunProgramLogged(root,
                                         "gate_shell_check",
                                         "sh",
                                         ["-lc", command],
                                         [],
                                         root,
                                         7,
                                         "/tmp/cheng_gate_shell_check.log")
    return hostops.LoggedRunOk(run)

fn GateBftBuildReady(root: str,
                       compiler: str,
                       src: str,
                       outBin: str,
                       runLog: str,
                       runSelfTest: str): bool =
    if !os.FileExists(outBin):
        return false
    var command = "test -x " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    if runSelfTest != "0":
        if !os.FileExists(runLog):
            return false
        command = command +
                  " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
                  " && grep -q " + os.QuoteShell(" bft_state_machine self-test ok") + " " + os.QuoteShell(runLog)
    return GateShellCheckOk(root, command)

fn GateBftThreeNodeConfig(root: str): BftThreeNodeDeploy =
    var deployRel = ""
    var remoteDeployRel = ""
    var out: BftThreeNodeDeploy
    deployRel = os.GetEnvDefault("CHENG_BFT_DEPLOY_DIR", "artifacts/bft_validator_deploy")
    remoteDeployRel = os.GetEnvDefault("CHENG_BFT_REMOTE_DEPLOY_REL", "artifacts/bft_validator_deploy")
    out.appId = os.GetEnvDefault("CHENG_BFT_APP_ID", "cheng-bft-live-20260415")
    out.serverSsh = os.GetEnvDefault("CHENG_BFT_SERVER_SSH", "root@64.176.84.12")
    out.relaySsh = os.GetEnvDefault("CHENG_BFT_RELAY_SSH", "dmit")
    out.serverAddress = os.GetEnvDefault("CHENG_BFT_SERVER_ADDR", "64.176.84.12")
    out.serverRepoRoot = os.GetEnvDefault("CHENG_BFT_SERVER_ROOT", "/root/cheng-lang-deploy")
    out.relayRepoRoot = os.GetEnvDefault("CHENG_BFT_RELAY_ROOT", "/root/cheng-lang-deploy")
    out.localDeployDir = chengpath.PathAbsolute(root, deployRel)
    out.remoteDeployRel = remoteDeployRel
    out.proposalPort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_PROPOSAL_PORT", "42061")))
    out.commitPort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_COMMIT_PORT", "42062")))
    out.votePort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_VOTE_PORT", "42063")))
    out.statePort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_STATE_PORT", "42064")))
    out.proposerIntervalMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_PROPOSER_INTERVAL_MS", "20")))
    out.followerIntervalMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_FOLLOWER_INTERVAL_MS", "20")))
    out.proposalWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_PROPOSAL_WINDOW_MS", "1000")))
    out.voteWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_VOTE_WINDOW_MS", "1000")))
    out.commitWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_COMMIT_WINDOW_MS", "1000")))
    out.defaultMaxTxs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_DEFAULT_MAX_TXS", "128")))
    out.assetId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_ASSET_ID", "7")))
    out.aliceId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_ALICE_ID", "1001")))
    out.bobId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_BOB_ID", "2002")))
    out.mintAmount = int64(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_MINT_AMOUNT", "100")))
    out.transferAmount = int64(strutil.ParseInt(os.GetEnvDefault("CHENG_BFT_TRANSFER_AMOUNT", "33")))
    return out


fn GateReadProgramTrim(root: str,
                         label: str,
                         programName: str,
                         args: str[],
                         logRelPath: str): str =
    let run: hostops.LoggedRun = hostops.RunProgramLogged(root,
                                                              label,
                                                              programName,
                                                              args,
                                                              [],
                                                              root,
                                                              20,
                                                              logRelPath)
    if GateRunFailed(run):
        return ""
    return strutil.Strip(run.output)

fn GateHostTarget(root: str): str =
    let hostOs: str = GateReadProgramTrim(root, " host uname-s", "uname", ["-s"], "artifacts/gate/uname_s.log")
    let hostArch: str = GateReadProgramTrim(root,
                                              " host uname-m",
                                              "uname",
                                              ["-m"],
                                              "artifacts/gate/uname_m.log")
    if hostOs == "Darwin" && hostArch == "arm64":
        return "arm64-apple-darwin"
    if hostOs == "Linux" && hostArch == "x86_64":
        return "x86_64-unknown-linux-gnu"
    if hostOs == "Linux" && (hostArch == "aarch64" || hostArch == "arm64"):
        return "aarch64-unknown-linux-gnu"
    return ""

fn GateCompileExe(root: str,
                    label: str,
                    compilerPath: str,
                    sourcePath: str,
                    outPath: str,
                    target: str,
                    logRelPath: str): hostops.LoggedRun =
    let packageRoot = root
    let compilerAbs = chengpath.PathAbsolute(root, compilerPath)
    let outParts: os.SplitFileResult = os.SplitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = chengpath.MkdirP(root, outParts.dir)
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    if len(compilerPath) <= 0 || !os.FileExists(compilerAbs):
        return hostops.LoggedRunZero(label,
                                       compilerAbs,
                                       logAbs,
                                       1,
                                       " bft_state_machine: missing compiler: " + compilerAbs + "\n")
    let timeoutText = os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec = int32(strutil.ParseInt(timeoutText))
    let run = hostops.RunFileLogged(root,
                                      label,
                                      compilerAbs,
                                      [
                                          "system-link-exec",
                                          "--root", packageRoot,
                                          "--in", sourcePath,
                                          "--emit", "exe",
                                          "--target", target,
                                          "--out", outPath
                                      ],
                                      [],
                                      root,
                                      timeoutSec,
                                      logRelPath)
    if hostops.LoggedRunOk(run) && !os.FileExists(outPath):
        let outputText = run.output + " bft_state_machine: compile missing output: " + outPath + "\n"
        let _logged: bool = chengpath.WriteTextFile(root, logAbs, outputText)
        return hostops.LoggedRunZero(label, compilerAbs, logAbs, 1, outputText)
    return run

fn GateRunBinary(root: str,
                   label: str,
                   binPath: str,
                   args: str[],
                   timeoutSec: int32,
                   logRelPath: str): hostops.LoggedRun =
    let logAbs: str = chengpath.PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.SplitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = chengpath.MkdirP(root, logParts.dir)
    return hostops.RunFileLogged(root, label, binPath, args, [], root, timeoutSec, logRelPath)

fn GateBuildBftStateMachine(root: str,
                              compilerPath: str): int32 =
    let compiler: str = chengpath.PathAbsolute(root, compilerPath)
    if !os.FileExists(compiler):
        GatePrintErr(" bft_state_machine: missing compiler: " + compiler)
        return 1
    let target: str = os.GetEnvDefault("BFT_STATE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = chengpath.PathAbsolute(root, "artifacts/bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("BFT_STATE_OUT_DIR", defaultOutDir)
    let src: str = chengpath.PathAbsolute(root, "src/apps/bft/bft_state_machine_main.cheng")
    let outBin: str = os.GetEnvDefault("BFT_STATE_OUT_BIN", os.JoinPath(outDir, "bft_state_machine"))
    var runSelfTestDefault = "0"
    if target == GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest: str = os.GetEnvDefault("BFT_STATE_RUN_SELF_TEST", runSelfTestDefault)
    let runLog = os.JoinPath(outDir, "bft_state_machine.self-test.log")
    if GateBftBuildReady(root, compiler, src, outBin, runLog, runSelfTest):
        if runSelfTest != "0":
            let cached = chengpath.ReadTextFile("", runLog)
            if len(cached) > 0:
                GatePrintLine(strutil.Strip(cached))
            else:
                GatePrintLine(" bft_state_machine self-test ok")
        else:
            GatePrintLine(" bft_state_machine: build ok target=" + target + " out=" + outBin)
        return 0
    let compileRun = GateCompileExe(root,
                                      "build_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "bft_state_machine.compile.log"))
    if GateRunFailed(compileRun):
        return compileRun.exitCode
    if runSelfTest != "0":
        let run = GateRunBinary(root,
                                  "build_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  60,
                                  runLog)
        GateMaybePrintRunOutput(run)
        if GateRunFailed(run):
            return run.exitCode
    else:
        GatePrintLine(" bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn GateBftManifestPath(cfg: BftThreeNodeDeploy): str =
    return os.JoinPath(cfg.localDeployDir, "deploy.env")

fn GateBftRemoteDeployDir(repoRoot: str, cfg: BftThreeNodeDeploy): str =
    return chengpath.PathAbsolute(repoRoot, cfg.remoteDeployRel)

fn GateBftRemoteBin(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bft_state_machine"),
                       os.JoinPath("x86_64-unknown-linux-gnu", "bft_state_machine"))

fn GateBftLocalBin(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/bft_state_machine/bft_state_machine")

fn GateBftRemoteRunLog(repoRoot: str): str =
    let outDir = os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bft_state_machine"),
                             "x86_64-unknown-linux-gnu")
    return os.JoinPath(outDir, "bft_state_machine.self-test.log")

fn GateBftRemoteBackendDriver(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_backend_driver"), "cheng")

fn GateBftRemoteStage3(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bootstrap"), "cheng.stage3")

fn GateBftRemoteSnapshot(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bootstrap"), "bootstrap_snapshot.txt")

fn GateBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "src/apps/bft/bft_state_machine_main.cheng")
    let outBin = GateBftRemoteBin(repoRoot)
    let runLog = GateBftRemoteRunLog(repoRoot)
    return "test -x " + os.QuoteShell(outBin) +
           " && test -x " + os.QuoteShell(compiler) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
           " && grep -qF " + os.QuoteShell(" bft_state_machine self-test ok") +
           " " + os.QuoteShell(runLog)

fn GateBftRemoteStage3FreshCommand(repoRoot: str): str =
    let stage3 = GateBftRemoteStage3(repoRoot)
    let snapshot = GateBftRemoteSnapshot(repoRoot)
    let seed = os.JoinPath(repoRoot, "bootstrap/cheng_seed.c")
    let stage1 = contracts.BootstrapStage1SourcePath(repoRoot)
    let compilerMain = os.JoinPath(repoRoot, "src/core/tooling/compiler_main.cheng")
    let compilerRuntime = os.JoinPath(repoRoot, "src/core/tooling/compiler_runtime.cheng")
    let compilerRequest = os.JoinPath(repoRoot, "src/core/tooling/compiler_request.cheng")
    let gateMain = os.JoinPath(repoRoot, "src/core/tooling/gate_main.cheng")
    var command = ""
    command = command + "test -x " + os.QuoteShell(stage3)
    command = command + " && snapshot=" + os.QuoteShell(snapshot)
    command = command + " && stage3=" + os.QuoteShell(stage3)
    command = command + " && if [ -f \"$snapshot\" ]; then"
    command = command + " fresh=$(grep \"^fresh_input_paths=\" \"$snapshot\" | tail -n 1 | cut -d= -f2-);"
    command = command + " if [ -n \"$fresh\" ]; then"
    command = command + " old_ifs=\"$IFS\"; IFS=,; set -- $fresh; IFS=\"$old_ifs\";"
    command = command + " for input in \"$@\"; do"
    command = command + " if [ -n \"$input\" ] && ! test \"$input\" -ot \"$stage3\"; then exit 1; fi;"
    command = command + " done; exit 0; fi; fi"
    command = command + " && test " + os.QuoteShell(seed) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(stage1) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerMain) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRuntime) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRequest) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(gateMain) + " -ot \"$stage3\""
    return command

fn GateBftRemoteLockedShell(repoRoot: str,
                              innerCommand: str): str =
    var command = ""
    command = command + "set -eu && cd " + os.QuoteShell(repoRoot)
    command = command + " && mkdir -p artifacts/gate"
    command = command + " && lock_dir=artifacts/gate/bft_remote_build.lock"
    command = command + " && lock_pid=\"$lock_dir/pid\""
    command = command + " && while ! mkdir \"$lock_dir\" 2>/dev/null; do holder=\"\";"
    command = command + " if [ -f \"$lock_pid\" ]; then holder=$(cat \"$lock_pid\" 2>/dev/null || true); fi;"
    command = command + " if [ -z \"$holder\" ] || ! kill -0 \"$holder\" 2>/dev/null; then"
    command = command + " rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true; continue;"
    command = command + " fi; sleep 0.1; done"
    command = command + " && printf \"%s\\n\" \"$$\" > \"$lock_pid\""
    command = command + " && trap 'rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true' EXIT INT TERM"
    command = command + " && " + innerCommand
    return command

