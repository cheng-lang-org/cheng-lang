    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "server_addr=" + cfg.serverAddress + "\n"
    out = out + "server_root=" + cfg.serverRepoRoot + "\n"
    out = out + "relay_root=" + cfg.relayRepoRoot + "\n"
    out = out + "local_deploy_dir=" + cfg.localDeployDir + "\n"
    out = out + "remote_deploy_rel=" + cfg.remoteDeployRel + "\n"
    out = out + "proposal_port=" + intToStr(cfg.proposalPort) + "\n"
    out = out + "commit_port=" + intToStr(cfg.commitPort) + "\n"
    out = out + "vote_port=" + intToStr(cfg.votePort) + "\n"
    out = out + "state_port=" + intToStr(cfg.statePort) + "\n"
    out = out + "proposer_interval_ms=" + intToStr(cfg.proposerIntervalMs) + "\n"
    out = out + "follower_interval_ms=" + intToStr(cfg.followerIntervalMs) + "\n"
    out = out + "proposal_window_ms=" + intToStr(cfg.proposalWindowMs) + "\n"
    out = out + "vote_window_ms=" + intToStr(cfg.voteWindowMs) + "\n"
    out = out + "commit_window_ms=" + intToStr(cfg.commitWindowMs) + "\n"
    out = out + "default_max_txs=" + intToStr(cfg.defaultMaxTxs) + "\n"
    out = out + "asset_id=" + intToStr(cfg.assetId) + "\n"
    out = out + "alice_id=" + intToStr(cfg.aliceId) + "\n"
    out = out + "bob_id=" + intToStr(cfg.bobId) + "\n"
    out = out + "mint_amount=" + strings.Int64ToStr(cfg.mintAmount) + "\n"
    out = out + "transfer_amount=" + strings.Int64ToStr(cfg.transferAmount) + "\n"
    return out

fn GateBftConfigLoad(root: str): BftThreeNodeDeploy =
    var cfg = GateBftThreeNodeConfig(root)
    let manifestPath = GateBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = chengpath.ReadTextFile("", manifestPath)
    let appId = GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverAddr = GateTextValue(text, "server_addr")
    if len(serverAddr) > 0:
        cfg.serverAddress = serverAddr
    let serverRoot = GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    let proposalPort = GateTextValue(text, "proposal_port")
    if len(proposalPort) > 0:
        cfg.proposalPort = int32(strutil.ParseInt(proposalPort))
    let commitPort = GateTextValue(text, "commit_port")
    if len(commitPort) > 0:
        cfg.commitPort = int32(strutil.ParseInt(commitPort))
    let votePort = GateTextValue(text, "vote_port")
    if len(votePort) > 0:
        cfg.votePort = int32(strutil.ParseInt(votePort))
    let statePort = GateTextValue(text, "state_port")
    if len(statePort) > 0:
        cfg.statePort = int32(strutil.ParseInt(statePort))
    let proposerIntervalMs = GateTextValue(text, "proposer_interval_ms")
    if len(proposerIntervalMs) > 0:
        cfg.proposerIntervalMs = int32(strutil.ParseInt(proposerIntervalMs))
    let followerIntervalMs = GateTextValue(text, "follower_interval_ms")
    if len(followerIntervalMs) > 0:
        cfg.followerIntervalMs = int32(strutil.ParseInt(followerIntervalMs))
    let proposalWindowMs = GateTextValue(text, "proposal_window_ms")
    if len(proposalWindowMs) > 0:
        cfg.proposalWindowMs = int32(strutil.ParseInt(proposalWindowMs))
    let voteWindowMs = GateTextValue(text, "vote_window_ms")
    if len(voteWindowMs) > 0:
        cfg.voteWindowMs = int32(strutil.ParseInt(voteWindowMs))
    let commitWindowMs = GateTextValue(text, "commit_window_ms")
    if len(commitWindowMs) > 0:
        cfg.commitWindowMs = int32(strutil.ParseInt(commitWindowMs))
    let defaultMaxTxs = GateTextValue(text, "default_max_txs")
    if len(defaultMaxTxs) > 0:
        cfg.defaultMaxTxs = int32(strutil.ParseInt(defaultMaxTxs))
    let assetId = GateTextValue(text, "asset_id")
    if len(assetId) > 0:
        cfg.assetId = int32(strutil.ParseInt(assetId))
    let aliceId = GateTextValue(text, "alice_id")
    if len(aliceId) > 0:
        cfg.aliceId = int32(strutil.ParseInt(aliceId))
    let bobId = GateTextValue(text, "bob_id")
    if len(bobId) > 0:
        cfg.bobId = int32(strutil.ParseInt(bobId))
    let mintAmount = GateTextValue(text, "mint_amount")
    if len(mintAmount) > 0:
        cfg.mintAmount = int64(strutil.ParseInt(mintAmount))
    let transferAmount = GateTextValue(text, "transfer_amount")
    if len(transferAmount) > 0:
        cfg.transferAmount = int64(strutil.ParseInt(transferAmount))
    return cfg

fn GateBftNodeStatusZero(name: str): BftNodeStatus =
    return BftNodeStatus(name: name,
                           summary: "",
                           aliceQuery: "",
                           bobQuery: "",
                           height: "",
                           appHash: "",
                           aliceBalance: "",
                           bobBalance: "")

fn GateBftCollectLocalNodeStatus(root: str,
                                   cfg: BftThreeNodeDeploy,
                                   nodeName: str,
                                   statePath: str,
                                   logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftLocalBin(root)
    let summaryRun = hostops.RunFileLogged(root,
                                             nodeName + "_show_state",
                                             binPath,
                                             ["show-state", "--state:" + statePath],
                                             [],
                                             root,
                                             20,
                                             logPrefix + ".show.log")
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = hostops.RunFileLogged(root,
                                           nodeName + "_alice_balance",
                                           binPath,
                                           ["query-balance",
                                            "--state:" + statePath,
                                            "--asset:" + intToStr(cfg.assetId),
                                            "--account:" + intToStr(cfg.aliceId)],
                                           [],
                                           root,
                                           20,
                                           logPrefix + ".alice.log")
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = hostops.RunFileLogged(root,
                                         nodeName + "_bob_balance",
                                         binPath,
                                         ["query-balance",
                                          "--state:" + statePath,
                                          "--asset:" + intToStr(cfg.assetId),
                                          "--account:" + intToStr(cfg.bobId)],
                                         [],
                                         root,
                                         20,
                                         logPrefix + ".bob.log")
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftCollectRemoteNodeStatus(root: str,
                                    cfg: BftThreeNodeDeploy,
                                    nodeName: str,
                                    sshHost: str,
                                    repoRoot: str,
                                    statePath: str,
                                    logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftRemoteBin(repoRoot)
    let summaryRun = GateRunRemoteShellLogged(root,
                                                nodeName + "_show_state",
                                                sshHost,
                                                "set -eu && " +
                                                    GateShellArgv([binPath,
                                                                     "show-state",
                                                                     "--state:" + statePath]),
                                                logPrefix + ".show.log",
                                                20)
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = GateRunRemoteShellLogged(root,
                                              nodeName + "_alice_balance",
                                              sshHost,
                                              "set -eu && " + GateShellArgv([binPath,
                                                                               "query-balance",
                                                                               "--state:" + statePath,
                                                                               "--asset:" + intToStr(cfg.assetId),
                                                                               "--account:" + intToStr(cfg.aliceId)]),
                                              logPrefix + ".alice.log",
                                              20)
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = GateRunRemoteShellLogged(root,
                                            nodeName + "_bob_balance",
                                            sshHost,
                                            "set -eu && " + GateShellArgv([binPath,
                                                                             "query-balance",
                                                                             "--state:" + statePath,
                                                                             "--asset:" + intToStr(cfg.assetId),
                                                                             "--account:" + intToStr(cfg.bobId)]),
                                            logPrefix + ".bob.log",
                                            20)
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftPrintNodeStatus(status: BftNodeStatus) =
    GatePrintLine("node=" + status.name)
    GatePrintLine("height=" + status.height)
    GatePrintLine("app_hash=" + status.appHash)
    GatePrintLine("alice_balance=" + status.aliceBalance)
    GatePrintLine("bob_balance=" + status.bobBalance)

fn GateBftClusterMatches(serverStatus: BftNodeStatus,
                           relayStatus: BftNodeStatus,
                           localStatus: BftNodeStatus,
                           wantHeight: str,
                           wantAlice: str,
                           wantBob: str): bool =
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.aliceBalance == wantAlice &&
           relayStatus.aliceBalance == wantAlice &&
           localStatus.aliceBalance == wantAlice &&
           serverStatus.bobBalance == wantBob &&
           relayStatus.bobBalance == wantBob &&
           localStatus.bobBalance == wantBob

fn GateBftVerifyReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/verify_bft_validator_three_node.report.txt")

fn GateBftVerifyReportAppendNode(out: var str,
                                   prefix: str,
                                   status: BftNodeStatus) =
    out = out + prefix + "_name=" + status.name + "\n"
    out = out + prefix + "_height=" + status.height + "\n"
    out = out + prefix + "_app_hash=" + status.appHash + "\n"
    out = out + prefix + "_alice_balance=" + status.aliceBalance + "\n"
    out = out + prefix + "_bob_balance=" + status.bobBalance + "\n"

fn GateBftVerifyReportText(cfg: BftThreeNodeDeploy,
                             verified: bool,
                             serverStatus: BftNodeStatus,
                             relayStatus: BftNodeStatus,
                             localStatus: BftNodeStatus): str =
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var out = ""
    out = out + "version=cheng.bft_three_node_verify.v1\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "want_height=" + wantHeight + "\n"
    out = out + "want_alice_balance=" + wantAlice + "\n"
    out = out + "want_bob_balance=" + wantBob + "\n"
    GateBftVerifyReportAppendNode(out, "server", serverStatus)
    GateBftVerifyReportAppendNode(out, "relay", relayStatus)
    GateBftVerifyReportAppendNode(out, "local", localStatus)
    out = out + "verified=" + (verified ? "true" : "false") + "\n"
    return out

fn GateFormatMilli(valueMilli: int64): str =
    let whole = valueMilli / int64(1000)
    let frac = valueMilli % int64(1000)
    var fracText = strings.Int64ToStr(frac)
    if len(fracText) == 1:
        fracText = "00" + fracText
    elif len(fracText) == 2:
        fracText = "0" + fracText
    return strings.Int64ToStr(whole) + "." + fracText

fn GateBftDaemonMaxTxs(cfg: BftThreeNodeDeploy,
                         overrideMaxTxs: int32): int32 =
    if overrideMaxTxs > 0:
        return overrideMaxTxs
    return cfg.defaultMaxTxs

fn GateBftWaitClusterState(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             wantHeight: str,
                             wantAlice: str,
                             wantBob: str,
                             logPrefix: str,
                             serverStatus: var BftNodeStatus,
                             relayStatus: var BftNodeStatus,
                             localStatus: var BftNodeStatus): bool =
    for i in 0..<300:
        i
        let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         logPrefix + "_server")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        logPrefix + "_relay")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       logPrefix + "_local")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        serverStatus = Value(serverRes)
        relayStatus = Value(relayRes)
        localStatus = Value(localRes)
        if GateBftClusterMatches(serverStatus,
                                   relayStatus,
                                   localStatus,
                                   wantHeight,
                                   wantAlice,
                                   wantBob):
            return true
        os.SleepMs(200)
    return false

fn GateBftBenchReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/bench_bft_validator_three_node.report.txt")

fn GateBftBenchRestartTargetValid(target: str): bool =
    return target == "none" || target == "server" || target == "relay" || target == "local"

fn GateBftInitCommand(binPath: str,
                        statePath: str,
                        appId: str,
                        validatorSlot: int32): str =
    var argv: str[]
    add(argv, binPath)
    add(argv, "init")
    add(argv, "--state:" + statePath)
    add(argv, "--app-id:" + appId)
    add(argv, "--validator-slot:" + intToStr(validatorSlot))
    add(argv, "--force")
    return GateShellArgv(argv)

