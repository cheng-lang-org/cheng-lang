import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

type
    ForbiddenPatternKind = enum
        ForbiddenLocalPayload
        ForbiddenExecPlanPayload
        ForbiddenEntryBridge
        ForbiddenPayloadText
        ForbiddenRuntimeTargetStr
        ForbiddenOpNameStr
        ForbiddenKindStr
        ForbiddenBigintBox

    ForbiddenPattern =
        kind: ForbiddenPatternKind
        needle: str
        label: str

    ForbiddenHit =
        path: str
        kind: ForbiddenPatternKind
        label: str

fn ForbiddenPatternAdd(dst: var ForbiddenPattern[], kind: ForbiddenPatternKind, needle: str, label: str) =
    add(dst, ForbiddenPattern(kind: kind, needle: needle, label: label))

fn Pattern3(a: str, b: str, c: str): str =
    return a + b + c

fn Pattern2(a: str, b: str): str =
    return a + b

fn ForbiddenPatterns(): ForbiddenPattern[] =
    var out: ForbiddenPattern[]
    ForbiddenPatternAdd(out, ForbiddenLocalPayload,
                          Pattern3("local", "_", "payload"),
                          Pattern3("local", "_", "payload"))
    ForbiddenPatternAdd(out, ForbiddenExecPlanPayload,
                          Pattern3("exec", "_plan", "_payload"),
                          Pattern3("exec", "_plan", "_payload"))
    ForbiddenPatternAdd(out, ForbiddenEntryBridge,
                          Pattern3("entry", "_", "bridge"),
                          Pattern3("entry", "_", "bridge"))
    ForbiddenPatternAdd(out, ForbiddenPayloadText,
                          Pattern2("payload", "Text"),
                          Pattern2("payload", "Text"))
    ForbiddenPatternAdd(out, ForbiddenRuntimeTargetStr,
                          Pattern3("runtimeTarget", ":", " str"),
                          Pattern3("runtimeTarget", ":", " str"))
    ForbiddenPatternAdd(out, ForbiddenOpNameStr,
                          Pattern3("opName", ":", " str"),
                          Pattern3("opName", ":", " str"))
    ForbiddenPatternAdd(out, ForbiddenKindStr,
                          Pattern3("kind", ":", " str"),
                          Pattern3("kind", ":", " str"))
    ForbiddenPatternAdd(out, ForbiddenBigintBox,
                          Pattern2("Big", "Int"),
                          Pattern2("Big", "Int"))
    return out

fn ScanForbiddenSourceDir(rootDir: str, srcDirRaw: str): ForbiddenHit[] =
    let srcDir: str = chengpath.PathAbsolute(rootDir, srcDirRaw)
    let patterns: ForbiddenPattern[] = ForbiddenPatterns()
    let files: str[] = os.WalkDirRec(srcDir)
    var hits: ForbiddenHit[]
    for i in 0..<files.len:
        let filePath: str = files[i]
        let parts: os.SplitFileResult = os.SplitFile(filePath)
        if parts.ext != ".cheng":
            continue
        let text: str = os.ReadFile(filePath)
        for j in 0..<patterns.len:
            let pattern: ForbiddenPattern = patterns[j]
            if strutil.Contains(text, pattern.needle):
                add(hits, ForbiddenHit(path: filePath, kind: pattern.kind, label: pattern.label))
    return hits

fn ForbiddenHitsOk(hits: ForbiddenHit[]): bool =
    return hits.len == 0

fn ForbiddenHitReport(hits: ForbiddenHit[]): str =
    if hits.len == 0:
        return " scan: ok\n"
    var rows: str[]
    for i in 0..<hits.len:
        let hit: ForbiddenHit = hits[i]
        add(rows, " scan: hit forbidden pattern: " + hit.label + " @ " + hit.path)
    return strutil.Join(rows, "\n") + "\n"
