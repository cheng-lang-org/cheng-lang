import std/os
import std/strings
import std/strutils as strutil
import cheng/core/lang/intern as langintern

type
    DeterminismGate =
        pathA: str
        pathB: str
        pass: bool
        report: str

fn DeterminismGateNew(pathA: str, pathB: str): DeterminismGate =
    return DeterminismGate(pathA: pathA, pathB: pathB, pass: false, report: "")

fn DeterminismGateSha256File(path: str): str =
    if !os.FileExists(path):
        return ""
    let fh = os.OpenFile(path, 0)
    if fh < 0:
        return ""
    let content = os.ReadFile(fh)
    os.CloseFile(fh)
    if len(content) == 0 && os.FileSize(path) > 0:
        return ""
    var out: str = strings.Sha256(content)
    return out

fn DeterminismGateCompareShas(shaA: str, shaB: str): bool =
    return shaA == shaB

fn DeterminismGateVerifyOutputDeterminism(gate: var DeterminismGate): bool =
    let shaA = DeterminismGateSha256File(gate.pathA)
    let shaB = DeterminismGateSha256File(gate.pathB)
    let ok = DeterminismGateCompareShas(shaA, shaB)
    var report = ""
    report = strutil.Join([report, "output_determinism\n"], "")
    report = strutil.Join([report, strutil.Join(["path_a=", gate.pathA], ""), "\n"], "")
    report = strutil.Join([report, strutil.Join(["path_b=", gate.pathB], ""), "\n"], "")
    report = strutil.Join([report, strutil.Join(["sha_a=", shaA], ""), "\n"], "")
    report = strutil.Join([report, strutil.Join(["sha_b=", shaB], ""), "\n"], "")
    report = strutil.Join([report, strutil.Join(["pass=", boolToInt(ok)], ""), "\n"], "")
    gate.pass = ok
    gate.report = report
    return ok

fn DeterminismGateVerifyRelocDeterminism(relocPathA: str, relocPathB: str): bool =
    let shaA = DeterminismGateSha256File(relocPathA)
    let shaB = DeterminismGateSha256File(relocPathB)
    return DeterminismGateCompareShas(shaA, shaB)

fn DeterminismGateVerifyCstringDeterminism(cstringPathA: str, cstringPathB: str): bool =
    let shaA = DeterminismGateSha256File(cstringPathA)
    let shaB = DeterminismGateSha256File(cstringPathB)
    return DeterminismGateCompareShas(shaA, shaB)

fn boolToInt(b: bool): int32 =
    return 1 if b else 0
