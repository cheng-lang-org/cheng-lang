import std/os
import std/result
import std/strings
import std/strformat
import std/strutils as strutil
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

const
    SeedStage23Target = "arm64-apple-darwin"

fn SeedStage23PrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn SeedStage23PrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn SeedStage23StartsWith(text: str,
                           prefix: str): bool =
    if len(prefix) > len(text):
        return false
    return strings.SliceBytes(text, 0, len(prefix)) == prefix

fn SeedStage23ReadFlag(args: str[],
                         key: str,
                         defaultValue: str): str =
    var i: int32
    while i < args.len:
        let arg = args[i]
        if arg == key && i + 1 < args.len:
            return args[i + 1]
        if SeedStage23StartsWith(arg, strutil.Join([key, ":"], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
        if SeedStage23StartsWith(arg, strutil.Join([key, "="], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
        i = i + 1
    return defaultValue

fn SeedStage23CollectPositionals(args: str[]): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = args[i]
        if arg == "--compiler" || arg == "--label" || arg == "--tail-only":
            i = i + 2
        elif SeedStage23StartsWith(arg, "--compiler:") ||
             SeedStage23StartsWith(arg, "--compiler=") ||
             SeedStage23StartsWith(arg, "--label:") ||
             SeedStage23StartsWith(arg, "--label=") ||
             SeedStage23StartsWith(arg, "--tail-only:") ||
             SeedStage23StartsWith(arg, "--tail-only="):
            i = i + 1
        elif len(arg) > 0 && arg[0] == '-':
            i = i + 1
        else:
            add(out, arg)
            i = i + 1
    return out

