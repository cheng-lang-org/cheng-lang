    </resources>

    """

fn MobileShellAndroidActivity(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/runtime_bundle_payload.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    let importKw: str = "import"
    return Fmt"""
    package {opts.appId}

    {importKw} android.app.Activity
    {importKw} android.os.Bundle
    {importKw} android.os.SystemClock
    {importKw} android.view.MotionEvent
    {importKw} android.view.Surface
    {importKw} android.view.SurfaceHolder
    {importKw} android.view.SurfaceView
    {importKw} android.view.ViewGroup

    class ChengMainActivity : Activity(), SurfaceHolder.Callback {{
        companion object {{
            private const val CHENG_RUNTIME_MANIFEST = {MobileShellQuote(runtimeManifestRel)}
            private const val CHENG_RUNTIME_CONTRACT_PAYLOAD_REL = {MobileShellQuote(runtimeContractPayloadRel)}
            private const val CHENG_RUNTIME_BUNDLE_PAYLOAD_REL = {MobileShellQuote(runtimeBundlePayloadRel)}
            private const val CHENG_LAUNCH_ARGS_KV_REL = {MobileShellQuote(launchArgsKvRel)}
            private const val CHENG_LAUNCH_ARGS_JSON_REL = {MobileShellQuote(launchArgsJsonRel)}
            init {{
                System.loadLibrary({MobileShellQuote(opts.libName)})
                System.loadLibrary("cheng_generated_android_host")
            }}
        }}

        private external fun nativeCreate(surface: Surface, width: Int, height: Int, density: Float, assetRoot: String, runtimeManifestJson: String, runtimeContractPayloadJson: String, runtimeBundlePayloadJson: String, launchArgsKv: String, launchArgsJson: String): Long
        private external fun nativeResize(handle: Long, surface: Surface, width: Int, height: Int, density: Float)
        private external fun nativeTick(handle: Long, deltaSeconds: Float)
        private external fun nativeTouch(handle: Long, action: Int, pointerId: Int, x: Float, y: Float)
        private external fun nativePause(handle: Long)
        private external fun nativeResume(handle: Long)

        private lateinit var surfaceView: SurfaceView
        private var runtimeHandle: Long = 0L
        private var lastFrameMs: Long = 0L

        private fun readAssetText(relPath: String): String {{
            val stream = assets.open(relPath)
            val reader = stream.reader()
            return reader.readText()
        }}

        override fun onCreate(savedInstanceState: Bundle?) {{
            super.onCreate(savedInstanceState)
            surfaceView = SurfaceView(this)
            surfaceView.holder.addCallback(this)
            surfaceView.setOnTouchListener {{ _, event ->
                if (runtimeHandle != 0L) {{
                    val pointerId = event.getPointerId(event.actionIndex)
                    nativeTouch(runtimeHandle, event.actionMasked, pointerId, event.x, event.y)
                }}
                true
            }}
            setContentView(surfaceView, ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))
        }}

        override fun surfaceCreated(holder: SurfaceHolder) {{
            val density = resources.displayMetrics.density
            val runtimeManifestJson = readAssetText(CHENG_RUNTIME_MANIFEST)
            val runtimeContractPayloadJson = readAssetText(CHENG_RUNTIME_CONTRACT_PAYLOAD_REL)
            val runtimeBundlePayloadJson = readAssetText(CHENG_RUNTIME_BUNDLE_PAYLOAD_REL)
            val launchArgsKv = readAssetText(CHENG_LAUNCH_ARGS_KV_REL)
            val launchArgsJson = readAssetText(CHENG_LAUNCH_ARGS_JSON_REL)
            runtimeHandle = nativeCreate(holder.surface, surfaceView.width, surfaceView.height, density, filesDir.absolutePath, runtimeManifestJson, runtimeContractPayloadJson, runtimeBundlePayloadJson, launchArgsKv, launchArgsJson)
            lastFrameMs = SystemClock.uptimeMillis()
            surfaceView.post(framePump)
        }}

        override fun surfaceChanged(holder: SurfaceHolder, format: Int, width: Int, height: Int) {{
            if (runtimeHandle != 0L) {{
                nativeResize(runtimeHandle, holder.surface, width, height, resources.displayMetrics.density)
            }}
        }}

        override fun surfaceDestroyed(holder: SurfaceHolder) {{
            if (runtimeHandle != 0L) {{
                nativePause(runtimeHandle)
            }}
        }}

        override fun onResume() {{
            super.onResume()
            if (runtimeHandle != 0L) {{
                nativeResume(runtimeHandle)
            }}
        }}

        override fun onPause() {{
            if (runtimeHandle != 0L) {{
                nativePause(runtimeHandle)
            }}
            super.onPause()
        }}

        private val framePump = : Runnable {{
            override fun run() {{
                if (runtimeHandle == 0L || !surfaceView.holder.surface.isValid) {{
                    return
                }}
                val now = SystemClock.uptimeMillis()
                val deltaMs = now - lastFrameMs
                val safeDeltaMs = if (deltaMs < 1L) 1L else deltaMs
                val delta = safeDeltaMs.toFloat() / 1000.0f
                lastFrameMs = now
                nativeTick(runtimeHandle, delta)
                surfaceView.postOnAnimation(this)
            }}
        }}
    }}

    """

fn MobileShellAndroidCmake(opts: var MobileShellOptions): str =
    return Fmt"""
    cmake_minimum_required(VERSION 3.22.1)
    project(cheng_generated_android_host C)

    add_library(cheng_generated_android_host SHARED cheng_generated_android_host.c)
    target_compile_definitions(cheng_generated_android_host PRIVATE CHENG_APP_LIB_NAME=\"{opts.libName}\")
    find_library(log-lib log)
    find_library(android-lib android)
    target_link_libraries(cheng_generated_android_host ${{log-lib}} ${{android-lib}})

    """

fn MobileShellAndroidHostSource(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    return Fmt"""
    #include <jni.h>
    #include <android/log.h>
    #include <android/native_window_jni.h>
    #include <dlfcn.h>
    #include <stdio.h>
    #include <stdint.h>
    #include <stdlib.h>
    #include <string.h>

    #ifndef CHENG_APP_LIB_NAME
    #define CHENG_APP_LIB_NAME "{opts.libName}"
    #endif

    typedef uint64_t (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);
    typedef void (*cheng_app_tick_fn)(uint64_t, float);
    typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(uint64_t);
    typedef void (*cheng_app_resume_fn)(uint64_t);

    typedef void (*cheng_mobile_host_runtime_set_manifest_payloads_fn)(const char*, const char*, const char*);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    typedef struct ChengAndroidShellRuntime {{
      uint64_t app_id;
      ANativeWindow* window;
      int width;
      int height;
      float density;
    }} ChengAndroidShellRuntime;

    static void* s_app_handle = NULL;
    static cheng_app_init_fn s_app_init = NULL;
    static cheng_app_set_window_fn s_app_set_window = NULL;
    static cheng_app_tick_fn s_app_tick = NULL;
    static cheng_app_on_touch_fn s_app_on_touch = NULL;
    static cheng_app_pause_fn s_app_pause = NULL;
    static cheng_app_resume_fn s_app_resume = NULL;

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengRuntimeContractPayloadRel = "{runtimeContractPayloadRel}";
    static const char* kChengRuntimeBundlePayloadRel = "{runtimeBundlePayloadRel}";
    static const char* kChengLaunchArgsKvRel = "{launchArgsKvRel}";
    static const char* kChengLaunchArgsJsonRel = "{launchArgsJsonRel}";

    static void cheng_log(const char* msg) {{
      __android_log_print(ANDROID_LOG_INFO, "cheng-mobile-shell", "%s", msg);
    }}

    static int cheng_resolve_exports(void) {{
      if (s_app_init != NULL) {{
        return 1;
      }}
      char lib_path[256];
      snprintf(lib_path, sizeof(lib_path), "lib%s.so", CHENG_APP_LIB_NAME);
      s_app_handle = dlopen(lib_path, RTLD_NOW | RTLD_GLOBAL);
      if (s_app_handle == NULL) {{
        cheng_log(dlerror());
        return 0;
      }}
      s_app_init = (cheng_app_init_fn)dlsym(s_app_handle, "cheng_app_init");
      s_app_set_window = (cheng_app_set_window_fn)dlsym(s_app_handle, "cheng_app_set_window");
      s_app_tick = (cheng_app_tick_fn)dlsym(s_app_handle, "cheng_app_tick");
      s_app_on_touch = (cheng_app_on_touch_fn)dlsym(s_app_handle, "cheng_app_on_touch");
      s_app_pause = (cheng_app_pause_fn)dlsym(s_app_handle, "cheng_app_pause");
      s_app_resume = (cheng_app_resume_fn)dlsym(s_app_handle, "cheng_app_resume");
      return s_app_init && s_app_set_window && s_app_tick && s_app_on_touch && s_app_pause && s_app_resume;
    }}

    static void cheng_set_launch_args(JNIEnv* env, jstring launch_args_kv, jstring launch_args_json) {{
      if (env == NULL || s_app_handle == NULL) {{
        return;
      }}
      cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(s_app_handle, "cheng_mobile_host_runtime_set_launch_args");
      if (setLaunchArgs == NULL) {{
        return;
      }}
      const char* kv = NULL;
      const char* json = NULL;
      if (launch_args_kv != NULL) {{
        kv = (*env)->GetStringUTFChars(env, launch_args_kv, NULL);
      }}
      if (launch_args_json != NULL) {{
        json = (*env)->GetStringUTFChars(env, launch_args_json, NULL);
      }}
      setLaunchArgs(kv, json);
      if (launch_args_kv != NULL && kv != NULL) {{
        (*env)->ReleaseStringUTFChars(env, launch_args_kv, kv);
      }}
      if (launch_args_json != NULL && json != NULL) {{
        (*env)->ReleaseStringUTFChars(env, launch_args_json, json);
      }}
    }}

    static void cheng_set_runtime_payloads(JNIEnv* env, jstring runtime_manifest_json, jstring runtime_contract_payload_json, jstring runtime_bundle_payload_json) {{
      if (env == NULL || s_app_handle == NULL) {{
        return;
      }}
      cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads = (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(s_app_handle, "cheng_mobile_host_runtime_set_manifest_payloads");
      if (setRuntimePayloads == NULL) {{
        return;
      }}
      const char* manifest = NULL;
      const char* contractPayload = NULL;
      const char* bundlePayload = NULL;
      if (runtime_manifest_json != NULL) {{
        manifest = (*env)->GetStringUTFChars(env, runtime_manifest_json, NULL);
      }}
      if (runtime_contract_payload_json != NULL) {{
        contractPayload = (*env)->GetStringUTFChars(env, runtime_contract_payload_json, NULL);
      }}
      if (runtime_bundle_payload_json != NULL) {{
        bundlePayload = (*env)->GetStringUTFChars(env, runtime_bundle_payload_json, NULL);
      }}
      setRuntimePayloads(manifest, contractPayload, bundlePayload);
      if (runtime_manifest_json != NULL && manifest != NULL) {{
        (*env)->ReleaseStringUTFChars(env, runtime_manifest_json, manifest);
      }}
      if (runtime_contract_payload_json != NULL && contractPayload != NULL) {{
        (*env)->ReleaseStringUTFChars(env, runtime_contract_payload_json, contractPayload);
      }}
      if (runtime_bundle_payload_json != NULL && bundlePayload != NULL) {{
        (*env)->ReleaseStringUTFChars(env, runtime_bundle_payload_json, bundlePayload);
      }}
    }}

    static ChengAndroidShellRuntime* cheng_runtime_new(JNIEnv* env, jobject surface, jint width, jint height, jfloat density) {{
      env = env;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)calloc(1u, sizeof(ChengAndroidShellRuntime));
      if (runtime == NULL) {{
        return NULL;
      }}
      runtime->window = ANativeWindow_fromSurface(env, surface);
      runtime->width = (int)width;
      runtime->height = (int)height;
      runtime->density = density;
      runtime->app_id = s_app_init();
      s_app_set_window(runtime->app_id, 1u, runtime->width, runtime->height, runtime->density);
      return runtime;
    }}

    static jlong native_create(JNIEnv* env, jobject thiz, jobject surface, jint width, jint height, jfloat density, jstring assetRoot, jstring runtimeManifestJson, jstring runtimeContractPayloadJson, jstring runtimeBundlePayloadJson, jstring launchArgsKv, jstring launchArgsJson) {{
      thiz = thiz;
      assetRoot = assetRoot;
      if (!cheng_resolve_exports()) {{
        return 0;
      }}
      cheng_set_runtime_payloads(env, runtimeManifestJson, runtimeContractPayloadJson, runtimeBundlePayloadJson);
      cheng_set_launch_args(env, launchArgsKv, launchArgsJson);
      ChengAndroidShellRuntime* runtime = cheng_runtime_new(env, surface, width, height, density);
      return (jlong)(uintptr_t)runtime;
    }}

    static void native_resize(JNIEnv* env, jobject thiz, jlong handle, jobject surface, jint width, jint height, jfloat density) {{
      env = env;
      thiz = thiz;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;
      if (runtime == NULL) {{
        return;
      }}
      if (runtime->window != NULL) {{
        ANativeWindow_release(runtime->window);
      }}
      runtime->window = ANativeWindow_fromSurface(env, surface);
      runtime->width = (int)width;
      runtime->height = (int)height;
      runtime->density = density;
      s_app_set_window(runtime->app_id, 1u, runtime->width, runtime->height, runtime->density);
    }}

    static void native_tick(JNIEnv* env, jobject thiz, jlong handle, jfloat delta_seconds) {{
      env = env;
      thiz = thiz;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;
      if (runtime == NULL) {{
        return;
      }}
      s_app_tick(runtime->app_id, delta_seconds);
    }}

    static void native_touch(JNIEnv* env, jobject thiz, jlong handle, jint action, jint pointer_id, jfloat x, jfloat y) {{
      env = env;
      thiz = thiz;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;
      if (runtime == NULL) {{
        return;
      }}
      s_app_on_touch(runtime->app_id, action, pointer_id, x, y);
    }}

    static void native_pause(JNIEnv* env, jobject thiz, jlong handle) {{
      env = env;
      thiz = thiz;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;
      if (runtime == NULL) {{
        return;
      }}
      s_app_pause(runtime->app_id);
    }}

    static void native_resume(JNIEnv* env, jobject thiz, jlong handle) {{
      env = env;
      thiz = thiz;
      ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;
      if (runtime == NULL) {{
        return;
      }}
      s_app_resume(runtime->app_id);
    }}

    jint JNI_OnLoad(JavaVM* vm, void* reserved) {{
      reserved = reserved;
      JNIEnv* env = NULL;
      if ((*vm)->GetEnv(vm, (void**)&env, JNI_VERSION_1_6) != JNI_OK) {{
        return JNI_ERR;
      }}
      const char* class_name = "{MobileShellAndroidPackagePath(opts.appId)}/ChengMainActivity";
      jclass cls = (*env)->FindClass(env, class_name);
      if (cls == NULL) {{
        return JNI_ERR;
      }}
      const JNINativeMethod methods[] = {{
          {{"nativeCreate", "(Landroid/view/Surface;IIFLjava/lang/String;Ljava/lang/String;Ljava/lang/String;Ljava/lang/String;Ljava/lang/String;Ljava/lang/String;)J", (void*)native_create}},
          {{"nativeResize", "(JLandroid/view/Surface;IIF)V", (void*)native_resize}},
          {{"nativeTick", "(JF)V", (void*)native_tick}},
          {{"nativeTouch", "(JIIFF)V", (void*)native_touch}},
          {{"nativePause", "(J)V", (void*)native_pause}},
          {{"nativeResume", "(J)V", (void*)native_resume}},
      }};
      if ((*env)->RegisterNatives(env, cls, methods, (jint)(sizeof(methods) / sizeof(methods[0]))) != JNI_OK) {{
        return JNI_ERR;
      }}
      return JNI_VERSION_1_6;
    }}

    """

fn MobileShellIosInfoPlist(opts: var MobileShellOptions): str =
    let dollar: str = strings.CharToStr('$')
    return Fmt"""
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
        <key>CFBundleDevelopmentRegion</key>
        <string>en</string>
        <key>CFBundleExecutable</key>
        <string>{dollar}(EXECUTABLE_NAME)</string>
        <key>CFBundleIdentifier</key>
        <string>{dollar}(PRODUCT_BUNDLE_IDENTIFIER)</string>
        <key>CFBundleDisplayName</key>
        <string>{opts.appName}</string>
        <key>CFBundleName</key>
        <string>{dollar}(PRODUCT_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>LSRequiresIPhoneOS</key>
        <true/>
        <key>UIApplicationSceneManifest</key>
        <dict/>
        <key>UILaunchStoryboardName</key>
        <string></string>
    </dict>
    </plist>

    """

