fn MobileShellHarmonyIndexEts(opts: var MobileShellOptions): str =
    opts = opts
    let dot: str = strings.CharToStr('.')
    let importKw: str = "import"
    return Fmt"""
    {importKw} harmonyHost from 'libcheng_generated_harmony_host.so'

    @Entry
    @Component
    struct Index {{
      private surfaceController: XComponentController = new XComponentController()

      aboutToAppear(): void {{
        const context = getContext(this)
        harmonyHost.setResourceManager(context.resourceManager)
      }}

      build() {{
        Column() {{
          XComponent({{
            id: 'chengSurface',
            type: XComponentType.SURFACE,
            libraryname: 'cheng_generated_harmony_host',
            controller: this.surfaceController
          }})
            {dot}width('100%')
            {dot}height('100%')
        }}
        {dot}width('100%')
        {dot}height('100%')
        {dot}backgroundColor('#000000')
      }}
    }}

    """

fn MobileShellHarmonyEntryAbilityEts(): str =
    let importKw: str = "import"
    return Fmt"""
    {importKw} {{ UIAbility }} from '@kit.AbilityKit';
    {importKw} {{ window }} from '@kit.ArkUI';

    export default class EntryAbility extends UIAbility {{
      onWindowStageCreate(windowStage: window.WindowStage): void {{
        windowStage.loadContent('pages/Index', (err) => {{
          if (err && err.code) {{
            console.error('loadContent failed: ' + JSON.stringify(err))
          }}
        }})
      }}

      onWindowStageDestroy(): void {{
      }}

      onForeground(): void {{
      }}

      onBackground(): void {{
      }}
    }}

    """

