import std/os
import std/strings
import std/strutils as strutil
import std/json as json
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

type
    MobileShellOptions =
        rootDir: str
        outDir: str
        appId: str
        appName: str
        libName: str
        runtimeMode: str
        runtimeContractPath: str
        runtimeBundlePath: str
        routeState: str
        emitAndroid: bool
        emitIos: bool
        emitHarmony: bool

fn MobileShellQuote(text: str): str =
    return Fmt"\"{text}\""

fn MobileShellJsonDocument(node: json.JsonNode): str =
    let rendered: str = json.Stringify(node)
    return Fmt"{rendered}\n"

fn MobileShellJsonAppExports(): json.JsonNode =
    var exports: json.JsonNode = json.NewJArray()
    json.JsonAddStr(exports, "cheng_app_init")
    json.JsonAddStr(exports, "cheng_app_set_window")
    json.JsonAddStr(exports, "cheng_app_tick")
    json.JsonAddStr(exports, "cheng_app_on_touch")
    json.JsonAddStr(exports, "cheng_app_pause")
    json.JsonAddStr(exports, "cheng_app_resume")
    return exports

fn MobileShellJsonPlatforms(opts: MobileShellOptions): json.JsonNode =
    var platforms: json.JsonNode = json.NewJArray()
    if opts.emitAndroid:
        json.JsonAddStr(platforms, "android")
    if opts.emitIos:
        json.JsonAddStr(platforms, "ios")
    if opts.emitHarmony:
        json.JsonAddStr(platforms, "harmony")
    return platforms

fn MobileShellJsonStringArray(items: var str[]): json.JsonNode =
    var out: json.JsonNode = json.NewJArray()
    for i in 0..<items.len:
        json.JsonAddStr(out, items[i])
    return out

fn MobileShellAndroidPackagePath(appId: str): str =
    let parts: str[] = strutil.Split(appId, '.')
    return strutil.Join(parts, "/")

fn MobileShellDefaultOptions(rootDir: str): MobileShellOptions =
    var opts: MobileShellOptions
    opts.rootDir = rootDir
    opts.outDir = chengpath.PathAbsolute(rootDir, "artifacts/mobile_shell_export")
    opts.appId = "org.cheng.generated.app"
    opts.appName = "ChengGeneratedApp"
    opts.libName = "cheng_mobile_app"
    opts.runtimeMode = "cheng_app_exports_v1"
    opts.runtimeContractPath = ""
    opts.runtimeBundlePath = ""
    opts.routeState = ""
    opts.emitAndroid = true
    opts.emitIos = true
    opts.emitHarmony = true
    return opts

