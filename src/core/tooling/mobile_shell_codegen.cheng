    json.JsonAdd(targets, target)
    var moduleDoc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(moduleDoc, "name", "entry")
    json.JsonSetFieldStr(moduleDoc, "srcPath", "./entry")
    json.JsonSetField(moduleDoc, "targets", targets)
