fn MobileShellAndroidSettingsGradle(): str =
    var text: str = "pluginManagement {\n"
    text = strutil.Join([text, "    repositories {\n"], "")
    text = strutil.Join([text, "        google()\n"], "")
    text = strutil.Join([text, "        mavenCentral()\n"], "")
    text = strutil.Join([text, "        gradlePluginPortal()\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "}\n"], "")
    text = strutil.Join([text, "dependencyResolutionManagement {\n"], "")
    text = strutil.Join([text, "    repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)\n"], "")
    text = strutil.Join([text, "    repositories {\n"], "")
    text = strutil.Join([text, "        google()\n"], "")
    text = strutil.Join([text, "        mavenCentral()\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "}\n"], "")
    text = strutil.Join([text, "rootProject.name = \"cheng_mobile_shell\"\n"], "")
    text = strutil.Join([text, "include(\":app\")\n"], "")
    return text

fn MobileShellAndroidTopBuildGradle(): str =
    var text: str = "plugins {\n"
    text = strutil.Join([text, "    id(\"com.android.application\") version \"8.4.2\" apply false\n"], "")
    text = strutil.Join([text, "    id(\"org.jetbrains.kotlin.android\") version \"1.9.24\" apply false\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

fn MobileShellAndroidGradleProperties(): str =
    var text: str = "org.gradle.jvmargs=-Xmx2048m -Dfile.encoding=UTF-8\n"
    text = strutil.Join([text, "android.useAndroidX=true\n"], "")
    text = strutil.Join([text, "kotlin.code.style=official\n"], "")
    return text

fn MobileShellAndroidAppBuildGradle(opts: var MobileShellOptions): str =
    var text: str = "plugins {\n"
    text = strutil.Join([text, "    id(\"com.android.application\")\n"], "")
    text = strutil.Join([text, "    id(\"org.jetbrains.kotlin.android\")\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "android {\n"], "")
    text = strutil.Join([text, "    namespace = ", MobileShellQuote(opts.appId), "\n"], "")
    text = strutil.Join([text, "    compileSdk = 34\n\n"], "")
    text = strutil.Join([text, "    defaultConfig {\n"], "")
    text = strutil.Join([text, "        applicationId = ", MobileShellQuote(opts.appId), "\n"], "")
    text = strutil.Join([text, "        minSdk = 28\n"], "")
    text = strutil.Join([text, "        targetSdk = 34\n"], "")
    text = strutil.Join([text, "        versionCode = 1\n"], "")
    text = strutil.Join([text, "        versionName = ", MobileShellQuote("1.0"), "\n"], "")
    text = strutil.Join([text, "        externalNativeBuild {\n"], "")
    text = strutil.Join([text, "            cmake {\n"], "")
    text = strutil.Join([text, "                cppFlags += ", MobileShellQuote("-std=c17"), "\n"], "")
    text = strutil.Join([text, "            }\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    buildTypes {\n"], "")
    text = strutil.Join([text, "        release {\n"], "")
    text = strutil.Join([text, "            isMinifyEnabled = false\n"], "")
    text = strutil.Join([text, "            proguardFiles(\n"], "")
    text = strutil.Join([text, "                getDefaultProguardFile(\"proguard-android-optimize.txt\"),\n"], "")
    text = strutil.Join([text, "                \"proguard-rules.pro\"\n"], "")
    text = strutil.Join([text, "            )\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    externalNativeBuild {\n"], "")
    text = strutil.Join([text, "        cmake {\n"], "")
    text = strutil.Join([text, "            path = file(\"src/main/cpp/CMakeLists.txt\")\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    buildFeatures {\n"], "")
    text = strutil.Join([text, "        prefab = false\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "    compileOptions {\n"], "")
    text = strutil.Join([text, "        sourceCompatibility = JavaVersion.VERSION_17\n"], "")
    text = strutil.Join([text, "        targetCompatibility = JavaVersion.VERSION_17\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "    kotlinOptions {\n"], "")
    text = strutil.Join([text, "        jvmTarget = ", MobileShellQuote("17"), "\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "dependencies {\n"], "")
    text = strutil.Join([text, "    implementation(", MobileShellQuote("androidx.core:core-ktx:1.13.1"), ")\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

fn MobileShellAndroidManifest(opts: var MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n"
    text = strutil.Join([text, "<manifest xmlns:android=\"http://schemas.android.com/apk/res/android\">\n"], "")
    text = strutil.Join([text, "    <application\n"], "")
    text = strutil.Join([text, "        android:allowBackup=\"false\"\n"], "")
    text = strutil.Join([text, "        android:label=\"@string/app_name\">\n"], "")
    text = strutil.Join([text, "        <activity\n"], "")
    text = strutil.Join([text, "            android:name=\".ChengMainActivity\"\n"], "")
    text = strutil.Join([text, "            android:configChanges=\"keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode\"\n"], "")
    text = strutil.Join([text, "            android:exported=\"true\"\n"], "")
    text = strutil.Join([text, "            android:launchMode=\"singleTask\"\n"], "")
    text = strutil.Join([text, "            android:screenOrientation=\"portrait\">\n"], "")
    text = strutil.Join([text, "            <intent-filter>\n"], "")
    text = strutil.Join([text, "                <action android:name=\"android.intent.action.MAIN\" />\n"], "")
    text = strutil.Join([text, "                <category android:name=\"android.intent.category.LAUNCHER\" />\n"], "")
    text = strutil.Join([text, "            </intent-filter>\n"], "")
    text = strutil.Join([text, "        </activity>\n"], "")
    text = strutil.Join([text, "    </application>\n"], "")
    text = strutil.Join([text, "</manifest>\n"], "")
    return text

fn MobileShellAndroidProguardRules(opts: var MobileShellOptions): str =
    var text: str = "# Generated by cheng mobile-shell export.\n"
    text = strutil.Join([text, "-keep class ", opts.appId, ".** { *; }\n"], "")
    text = strutil.Join([text, "-keepclassmembers class * {\n"], "")
    text = strutil.Join([text, "    native <methods>;\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

fn MobileShellAndroidStringsXml(opts: var MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n"
    text = strutil.Join([text, "<resources>\n"], "")
    text = strutil.Join([text, "    <string name=\"app_name\">", opts.appName, "</string>\n"], "")
    text = strutil.Join([text, "</resources>\n"], "")
    return text

fn MobileShellAndroidActivity(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/runtime_bundle_payload.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    var text: str = strutil.Join(["package ", opts.appId, "\n\n"], "")
    text = strutil.Join([text, "import android.app.Activity\n"], "")
    text = strutil.Join([text, "import android.os.Bundle\n"], "")
    text = strutil.Join([text, "import android.os.SystemClock\n"], "")
    text = strutil.Join([text, "import android.view.MotionEvent\n"], "")
    text = strutil.Join([text, "import android.view.Surface\n"], "")
    text = strutil.Join([text, "import android.view.SurfaceHolder\n"], "")
    text = strutil.Join([text, "import android.view.SurfaceView\n"], "")
    text = strutil.Join([text, "import android.view.ViewGroup\n\n"], "")
    text = strutil.Join([text, "class ChengMainActivity : Activity(), SurfaceHolder.Callback {\n"], "")
    text = strutil.Join([text, "    companion object {\n"], "")
    text = strutil.Join([text, "        private const val CHENG_RUNTIME_MANIFEST = ", MobileShellQuote(runtimeManifestRel), "\n"], "")
    text = strutil.Join([text, "        private const val CHENG_RUNTIME_CONTRACT_PAYLOAD_REL = ", MobileShellQuote(runtimeContractPayloadRel), "\n"], "")
    text = strutil.Join([text, "        private const val CHENG_RUNTIME_BUNDLE_PAYLOAD_REL = ", MobileShellQuote(runtimeBundlePayloadRel), "\n"], "")
    text = strutil.Join([text, "        private const val CHENG_LAUNCH_ARGS_KV_REL = ", MobileShellQuote(launchArgsKvRel), "\n"], "")
    text = strutil.Join([text, "        private const val CHENG_LAUNCH_ARGS_JSON_REL = ", MobileShellQuote(launchArgsJsonRel), "\n"], "")
    text = strutil.Join([text, "        init {\n"], "")
    text = strutil.Join([text, "            System.loadLibrary(", MobileShellQuote(opts.libName), ")\n"], "")
    text = strutil.Join([text, "            System.loadLibrary(\"cheng_generated_android_host\")\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    private external fun nativeCreate(surface: Surface, width: Int, height: Int, density: Float, assetRoot: String, runtimeManifestJson: String, runtimeContractPayloadJson: String, runtimeBundlePayloadJson: String, launchArgsKv: String, launchArgsJson: String): Long\n"], "")
    text = strutil.Join([text, "    private external fun nativeResize(handle: Long, surface: Surface, width: Int, height: Int, density: Float)\n"], "")
    text = strutil.Join([text, "    private external fun nativeTick(handle: Long, deltaSeconds: Float)\n"], "")
    text = strutil.Join([text, "    private external fun nativeTouch(handle: Long, action: Int, pointerId: Int, x: Float, y: Float)\n"], "")
    text = strutil.Join([text, "    private external fun nativePause(handle: Long)\n"], "")
    text = strutil.Join([text, "    private external fun nativeResume(handle: Long)\n\n"], "")
    text = strutil.Join([text, "    private lateinit var surfaceView: SurfaceView\n"], "")
    text = strutil.Join([text, "    private var runtimeHandle: Long = 0L\n"], "")
    text = strutil.Join([text, "    private var lastFrameMs: Long = 0L\n\n"], "")
    text = strutil.Join([text, "    private fun readAssetText(relPath: String): String {\n"], "")
    text = strutil.Join([text, "        val stream = assets.open(relPath)\n"], "")
    text = strutil.Join([text, "        val reader = stream.reader()\n"], "")
    text = strutil.Join([text, "        return reader.readText()\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun onCreate(savedInstanceState: Bundle?) {\n"], "")
    text = strutil.Join([text, "        super.onCreate(savedInstanceState)\n"], "")
    text = strutil.Join([text, "        surfaceView = SurfaceView(this)\n"], "")
    text = strutil.Join([text, "        surfaceView.holder.addCallback(this)\n"], "")
    text = strutil.Join([text, "        surfaceView.setOnTouchListener { _, event ->\n"], "")
    text = strutil.Join([text, "            if (runtimeHandle != 0L) {\n"], "")
    text = strutil.Join([text, "                val pointerId = event.getPointerId(event.actionIndex)\n"], "")
    text = strutil.Join([text, "                nativeTouch(runtimeHandle, event.actionMasked, pointerId, event.x, event.y)\n"], "")
    text = strutil.Join([text, "            }\n"], "")
    text = strutil.Join([text, "            true\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "        setContentView(surfaceView, ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun surfaceCreated(holder: SurfaceHolder) {\n"], "")
    text = strutil.Join([text, "        val density = resources.displayMetrics.density\n"], "")
    text = strutil.Join([text, "        val runtimeManifestJson = readAssetText(CHENG_RUNTIME_MANIFEST)\n"], "")
    text = strutil.Join([text, "        val runtimeContractPayloadJson = readAssetText(CHENG_RUNTIME_CONTRACT_PAYLOAD_REL)\n"], "")
    text = strutil.Join([text, "        val runtimeBundlePayloadJson = readAssetText(CHENG_RUNTIME_BUNDLE_PAYLOAD_REL)\n"], "")
    text = strutil.Join([text, "        val launchArgsKv = readAssetText(CHENG_LAUNCH_ARGS_KV_REL)\n"], "")
    text = strutil.Join([text, "        val launchArgsJson = readAssetText(CHENG_LAUNCH_ARGS_JSON_REL)\n"], "")
    text = strutil.Join([text, "        runtimeHandle = nativeCreate(holder.surface, surfaceView.width, surfaceView.height, density, filesDir.absolutePath, runtimeManifestJson, runtimeContractPayloadJson, runtimeBundlePayloadJson, launchArgsKv, launchArgsJson)\n"], "")
    text = strutil.Join([text, "        lastFrameMs = SystemClock.uptimeMillis()\n"], "")
    text = strutil.Join([text, "        surfaceView.post(framePump)\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun surfaceChanged(holder: SurfaceHolder, format: Int, width: Int, height: Int) {\n"], "")
    text = strutil.Join([text, "        if (runtimeHandle != 0L) {\n"], "")
    text = strutil.Join([text, "            nativeResize(runtimeHandle, holder.surface, width, height, resources.displayMetrics.density)\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun surfaceDestroyed(holder: SurfaceHolder) {\n"], "")
    text = strutil.Join([text, "        if (runtimeHandle != 0L) {\n"], "")
    text = strutil.Join([text, "            nativePause(runtimeHandle)\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun onResume() {\n"], "")
    text = strutil.Join([text, "        super.onResume()\n"], "")
    text = strutil.Join([text, "        if (runtimeHandle != 0L) {\n"], "")
    text = strutil.Join([text, "            nativeResume(runtimeHandle)\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    override fun onPause() {\n"], "")
    text = strutil.Join([text, "        if (runtimeHandle != 0L) {\n"], "")
    text = strutil.Join([text, "            nativePause(runtimeHandle)\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "        super.onPause()\n"], "")
    text = strutil.Join([text, "    }\n\n"], "")
    text = strutil.Join([text, "    private val framePump = object : Runnable {\n"], "")
    text = strutil.Join([text, "        override fun run() {\n"], "")
    text = strutil.Join([text, "            if (runtimeHandle == 0L || !surfaceView.holder.surface.isValid) {\n"], "")
    text = strutil.Join([text, "                return\n"], "")
    text = strutil.Join([text, "            }\n"], "")
    text = strutil.Join([text, "            val now = SystemClock.uptimeMillis()\n"], "")
    text = strutil.Join([text, "            val deltaMs = now - lastFrameMs\n"], "")
    text = strutil.Join([text, "            val safeDeltaMs = if (deltaMs < 1L) 1L else deltaMs\n"], "")
    text = strutil.Join([text, "            val delta = safeDeltaMs.toFloat() / 1000.0f\n"], "")
    text = strutil.Join([text, "            lastFrameMs = now\n"], "")
    text = strutil.Join([text, "            nativeTick(runtimeHandle, delta)\n"], "")
    text = strutil.Join([text, "            surfaceView.postOnAnimation(this)\n"], "")
    text = strutil.Join([text, "        }\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

fn MobileShellAndroidCmake(opts: var MobileShellOptions): str =
    var text: str = "cmake_minimum_required(VERSION 3.22.1)\n"
    text = strutil.Join([text, "project(cheng_generated_android_host C)\n\n"], "")
    text = strutil.Join([text, "add_library(cheng_generated_android_host SHARED cheng_generated_android_host.c)\n"], "")
    text = strutil.Join([text, "target_compile_definitions(cheng_generated_android_host PRIVATE CHENG_APP_LIB_NAME=\\\"", opts.libName, "\\\")\n"], "")
    text = strutil.Join([text, "find_library(log-lib log)\n"], "")
    text = strutil.Join([text, "find_library(android-lib android)\n"], "")
    text = strutil.Join([text, "target_link_libraries(cheng_generated_android_host ${log-lib} ${android-lib})\n"], "")
    return text

fn MobileShellAndroidHostSource(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    var text: str = "#include <jni.h>\n"
    text = strutil.Join([text, "#include <android/log.h>\n"], "")
    text = strutil.Join([text, "#include <android/native_window_jni.h>\n"], "")
    text = strutil.Join([text, "#include <dlfcn.h>\n"], "")
    text = strutil.Join([text, "#include <stdio.h>\n"], "")
    text = strutil.Join([text, "#include <stdint.h>\n"], "")
    text = strutil.Join([text, "#include <stdlib.h>\n"], "")
    text = strutil.Join([text, "#include <string.h>\n\n"], "")
    text = strutil.Join([text, "#ifndef CHENG_APP_LIB_NAME\n"], "")
    text = strutil.Join([text, "#define CHENG_APP_LIB_NAME \"", opts.libName, "\"\n"], "")
    text = strutil.Join([text, "#endif\n\n"], "")
    text = strutil.Join([text, "typedef uint64_t (*cheng_app_init_fn)(void);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_pause_fn)(uint64_t);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_resume_fn)(uint64_t);\n\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_mobile_host_runtime_set_manifest_payloads_fn)(const char*, const char*, const char*);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"], "")
    text = strutil.Join([text, "typedef struct ChengAndroidShellRuntime {\n"], "")
    text = strutil.Join([text, "  uint64_t app_id;\n"], "")
    text = strutil.Join([text, "  ANativeWindow* window;\n"], "")
    text = strutil.Join([text, "  int width;\n"], "")
    text = strutil.Join([text, "  int height;\n"], "")
    text = strutil.Join([text, "  float density;\n"], "")
    text = strutil.Join([text, "} ChengAndroidShellRuntime;\n\n"], "")
    text = strutil.Join([text, "static void* s_app_handle = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_init_fn s_app_init = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_set_window_fn s_app_set_window = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_tick_fn s_app_tick = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_on_touch_fn s_app_on_touch = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_pause_fn s_app_pause = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_resume_fn s_app_resume = NULL;\n\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeManifest = \"", runtimeManifestRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeContractPayloadRel = \"", runtimeContractPayloadRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeBundlePayloadRel = \"", runtimeBundlePayloadRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengLaunchArgsKvRel = \"", launchArgsKvRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengLaunchArgsJsonRel = \"", launchArgsJsonRel, "\";\n"], "")
    text = strutil.Join([text, "\n"], "")
    text = strutil.Join([text, "static void cheng_log(const char* msg) {\n"], "")
    text = strutil.Join([text, "  __android_log_print(ANDROID_LOG_INFO, \"cheng-mobile-shell\", \"%s\", msg);\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static int cheng_resolve_exports(void) {\n"], "")
    text = strutil.Join([text, "  if (s_app_init != NULL) {\n"], "")
    text = strutil.Join([text, "    return 1;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  char lib_path[256];\n"], "")
    text = strutil.Join([text, "  snprintf(lib_path, sizeof(lib_path), \"lib%s.so\", CHENG_APP_LIB_NAME);\n"], "")
    text = strutil.Join([text, "  s_app_handle = dlopen(lib_path, RTLD_NOW | RTLD_GLOBAL);\n"], "")
    text = strutil.Join([text, "  if (s_app_handle == NULL) {\n"], "")
    text = strutil.Join([text, "    cheng_log(dlerror());\n"], "")
    text = strutil.Join([text, "    return 0;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  s_app_init = (cheng_app_init_fn)dlsym(s_app_handle, \"cheng_app_init\");\n"], "")
    text = strutil.Join([text, "  s_app_set_window = (cheng_app_set_window_fn)dlsym(s_app_handle, \"cheng_app_set_window\");\n"], "")
    text = strutil.Join([text, "  s_app_tick = (cheng_app_tick_fn)dlsym(s_app_handle, \"cheng_app_tick\");\n"], "")
    text = strutil.Join([text, "  s_app_on_touch = (cheng_app_on_touch_fn)dlsym(s_app_handle, \"cheng_app_on_touch\");\n"], "")
    text = strutil.Join([text, "  s_app_pause = (cheng_app_pause_fn)dlsym(s_app_handle, \"cheng_app_pause\");\n"], "")
    text = strutil.Join([text, "  s_app_resume = (cheng_app_resume_fn)dlsym(s_app_handle, \"cheng_app_resume\");\n"], "")
    text = strutil.Join([text, "  return s_app_init && s_app_set_window && s_app_tick && s_app_on_touch && s_app_pause && s_app_resume;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void cheng_set_launch_args(JNIEnv* env, jstring launch_args_kv, jstring launch_args_json) {\n"], "")
    text = strutil.Join([text, "  if (env == NULL || s_app_handle == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(s_app_handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"], "")
    text = strutil.Join([text, "  if (setLaunchArgs == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  const char* kv = NULL;\n"], "")
    text = strutil.Join([text, "  const char* json = NULL;\n"], "")
    text = strutil.Join([text, "  if (launch_args_kv != NULL) {\n"], "")
    text = strutil.Join([text, "    kv = (*env)->GetStringUTFChars(env, launch_args_kv, NULL);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (launch_args_json != NULL) {\n"], "")
    text = strutil.Join([text, "    json = (*env)->GetStringUTFChars(env, launch_args_json, NULL);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  setLaunchArgs(kv, json);\n"], "")
    text = strutil.Join([text, "  if (launch_args_kv != NULL && kv != NULL) {\n"], "")
    text = strutil.Join([text, "    (*env)->ReleaseStringUTFChars(env, launch_args_kv, kv);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (launch_args_json != NULL && json != NULL) {\n"], "")
    text = strutil.Join([text, "    (*env)->ReleaseStringUTFChars(env, launch_args_json, json);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void cheng_set_runtime_payloads(JNIEnv* env, jstring runtime_manifest_json, jstring runtime_contract_payload_json, jstring runtime_bundle_payload_json) {\n"], "")
    text = strutil.Join([text, "  if (env == NULL || s_app_handle == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads = (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(s_app_handle, \"cheng_mobile_host_runtime_set_manifest_payloads\");\n"], "")
    text = strutil.Join([text, "  if (setRuntimePayloads == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  const char* manifest = NULL;\n"], "")
    text = strutil.Join([text, "  const char* contractPayload = NULL;\n"], "")
    text = strutil.Join([text, "  const char* bundlePayload = NULL;\n"], "")
    text = strutil.Join([text, "  if (runtime_manifest_json != NULL) {\n"], "")
    text = strutil.Join([text, "    manifest = (*env)->GetStringUTFChars(env, runtime_manifest_json, NULL);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (runtime_contract_payload_json != NULL) {\n"], "")
    text = strutil.Join([text, "    contractPayload = (*env)->GetStringUTFChars(env, runtime_contract_payload_json, NULL);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (runtime_bundle_payload_json != NULL) {\n"], "")
    text = strutil.Join([text, "    bundlePayload = (*env)->GetStringUTFChars(env, runtime_bundle_payload_json, NULL);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  setRuntimePayloads(manifest, contractPayload, bundlePayload);\n"], "")
    text = strutil.Join([text, "  if (runtime_manifest_json != NULL && manifest != NULL) {\n"], "")
    text = strutil.Join([text, "    (*env)->ReleaseStringUTFChars(env, runtime_manifest_json, manifest);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (runtime_contract_payload_json != NULL && contractPayload != NULL) {\n"], "")
    text = strutil.Join([text, "    (*env)->ReleaseStringUTFChars(env, runtime_contract_payload_json, contractPayload);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (runtime_bundle_payload_json != NULL && bundlePayload != NULL) {\n"], "")
    text = strutil.Join([text, "    (*env)->ReleaseStringUTFChars(env, runtime_bundle_payload_json, bundlePayload);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static ChengAndroidShellRuntime* cheng_runtime_new(JNIEnv* env, jobject surface, jint width, jint height, jfloat density) {\n"], "")
    text = strutil.Join([text, "  env = env;\n"], "")
    text = strutil.Join([text, "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)calloc(1u, sizeof(ChengAndroidShellRuntime));\n"], "")
    text = strutil.Join([text, "  if (runtime == NULL) {\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  runtime->window = ANativeWindow_fromSurface(env, surface);\n"], "")
    text = strutil.Join([text, "  runtime->width = (int)width;\n"], "")
    text = strutil.Join([text, "  runtime->height = (int)height;\n"], "")
    text = strutil.Join([text, "  runtime->density = density;\n"], "")
    text = strutil.Join([text, "  runtime->app_id = s_app_init();\n"], "")
    text = strutil.Join([text, "  s_app_set_window(runtime->app_id, 1u, runtime->width, runtime->height, runtime->density);\n"], "")
    text = strutil.Join([text, "  return runtime;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static jlong native_create(JNIEnv* env, jobject thiz, jobject surface, jint width, jint height, jfloat density, jstring assetRoot, jstring runtimeManifestJson, jstring runtimeContractPayloadJson, jstring runtimeBundlePayloadJson, jstring launchArgsKv, jstring launchArgsJson) {\n"], "")
    text = strutil.Join([text, "  thiz = thiz;\n"], "")
    text = strutil.Join([text, "  assetRoot = assetRoot;\n"], "")
    text = strutil.Join([text, "  if (!cheng_resolve_exports()) {\n"], "")
    text = strutil.Join([text, "    return 0;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_set_runtime_payloads(env, runtimeManifestJson, runtimeContractPayloadJson, runtimeBundlePayloadJson);\n"], "")
    text = strutil.Join([text, "  cheng_set_launch_args(env, launchArgsKv, launchArgsJson);\n"], "")
    text = strutil.Join([text, "  ChengAndroidShellRuntime* runtime = cheng_runtime_new(env, surface, width, height, density);\n"], "")
    text = strutil.Join([text, "  return (jlong)(uintptr_t)runtime;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void native_resize(JNIEnv* env, jobject thiz, jlong handle, jobject surface, jint width, jint height, jfloat density) {\n"], "")
    text = strutil.Join([text, "  env = env;\n"], "")
    text = strutil.Join([text, "  thiz = thiz;\n"], "")
    text = strutil.Join([text, "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"], "")
    text = strutil.Join([text, "  if (runtime == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (runtime->window != NULL) {\n"], "")
    text = strutil.Join([text, "    ANativeWindow_release(runtime->window);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  runtime->window = ANativeWindow_fromSurface(env, surface);\n"], "")
    text = strutil.Join([text, "  runtime->width = (int)width;\n"], "")
    text = strutil.Join([text, "  runtime->height = (int)height;\n"], "")
    text = strutil.Join([text, "  runtime->density = density;\n"], "")
