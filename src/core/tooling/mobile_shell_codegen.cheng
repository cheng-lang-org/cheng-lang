        return false
    if !MobileShellWriteAndroidGradlePropertiesFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidAppBuildFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidManifestFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidProguardFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidStringsFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidActivityFile(opts, files, outError):
        return false
    if !MobileShellWriteAndroidCmakeFile(opts, files, outError):
        return false
    return MobileShellWriteAndroidHostFile(opts, files, outError)

fn MobileShellWriteIosInfoPlistFile(opts: var MobileShellOptions,
                                      files: var str[],
                                      outError: var str): bool =
    let rel: str = "ios/Info.plist"
    let full: str = chengpath.PathJoin(opts.outDir, rel)
    let parent: str = chengpath.PathParentDir(full)
    if !chengpath.MkdirP("", parent):
        outError = strutil.Join(["mobile-shell: mkdir failed: ", parent], "")
        return false
    let f: os.File = os.openImplWrite(full)
    if f == nil:
        outError = strutil.Join(["mobile-shell: open failed: ", full], "")
        return false
    let text: str = MobileShellIosInfoPlist(opts)
    os.Write(f, text)
    if len(text) <= 0 || text[text.len - 1] != '\n':
        os.Write(f, "\n")
    os.Close(f)
    if !chengpath.PathFileExists(full) || chengpath.PathFileSize(full) <= int64(0):
        outError = strutil.Join(["mobile-shell: write failed: ", full], "")
        return false
    add(files, rel)
    return true

