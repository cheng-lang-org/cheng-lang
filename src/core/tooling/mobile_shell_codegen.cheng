                                 runtimeManifestRel: str,
                                 runtimeContractPayloadRel: str,
                                 runtimeBundlePayloadRel: str): str =
    var text: str
    text = strutil.Join([text, "gate_mode=android-semantic-visual-1to1\n"], "")
    text = strutil.Join([text, "truth_mode=strict\n"], "")
    text = strutil.Join([text, "route_state=", opts.routeState, "\n"], "")
    text = strutil.Join([text, "route_lock=1\n"], "")
    text = strutil.Join([text, "runtime_mode=", opts.runtimeMode, "\n"], "")
    text = strutil.Join([text, "runtime_manifest=", runtimeManifestRel, "\n"], "")
    text = strutil.Join([text, "runtime_contract_payload=", runtimeContractPayloadRel, "\n"], "")
    text = strutil.Join([text, "runtime_bundle_payload=", runtimeBundlePayloadRel, "\n"], "")
    return text

