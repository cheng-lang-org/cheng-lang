fn MobileShellAndroidAssetMirrorRelPath(rel: str): str =
    return strutil.Join(["android/app/src/main/assets/", rel], "")

fn MobileShellIosAssetMirrorRelPath(rel: str): str =
    return strutil.Join(["ios/", rel], "")

fn MobileShellHarmonyAssetMirrorRelPath(rel: str): str =
    return strutil.Join(["harmony/entry/src/main/resources/rawfile/", rel], "")

fn MobileShellHelpText(): str =
    var text: str = "usage: cheng mobile-shell <subcommand> [args]\n"
    text = strutil.Join([text, "subcommands: help, export, build-probe\n"], "")
    text = strutil.Join([text, "export flags: [--platform android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]\n"], "")
    text = strutil.Join([text, "build-probe flags: [--platform none|android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]\n"], "")
    return text

fn MobileShellResolvePlatforms(platformText: str,
                                 out: var str[]): bool =
    out = []
    let raw: str = strutil.Strip(platformText)
    let normalized: str = if len(raw) > 0: raw else: "all"
    if normalized == "all":
        add(out, "android")
        add(out, "ios")
        add(out, "harmony")
        return true
    if normalized == "none":
        return true
    if normalized == "android":
        add(out, normalized)
        return true
    if normalized == "ios":
        add(out, normalized)
        return true
    if normalized == "harmony":
        add(out, normalized)
        return true
    return false

fn MobileShellWriteFile(fullPath: str,
                          text: str,
                          relPath: str,
                          files: var str[],
                          outError: var str): bool =
    var payload: str = text
    var needsNewline: bool
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = strutil.Join([payload, "\n"], "")
    if !chengpath.WriteTextFile("", fullPath, payload):
        outError = strutil.Join(["mobile-shell: write failed: ", fullPath], "")
        return false
    add(files, relPath)
    return true

fn MobileShellWriteRelativeFile(rootDir: str,
                                  relPath: str,
                                  text: str,
                                  files: var str[],
                                  outError: var str): bool =
    var payload: str = text
    var needsNewline: bool
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = strutil.Join([payload, "\n"], "")
    if !chengpath.WriteTextFile(rootDir, relPath, payload):
        outError = strutil.Join(["mobile-shell: write failed: ", chengpath.PathJoin(rootDir, relPath)], "")
        return false
    add(files, relPath)
    return true

fn MobileShellReadme(opts: MobileShellOptions,
                       runtimeManifestRel: str,
                       runtimeContractPayloadRel: str,
                       runtimeBundlePayloadRel: str,
                       runtimeSemanticNodesRel: str,
                       runtimeTruthRootRel: str,
                       launchArgsKvRel: str,
                       launchArgsJsonRel: str): str =
    var text: str = "# Cheng Mobile Shell Export\n\n"
    text = strutil.Join([text, "This bundle is emitted by `cheng mobile-shell export`.\n\n"], "")
    text = strutil.Join([text, "App contract:\n"], "")
    text = strutil.Join([text, "- The Cheng app binary exports `cheng_app_init`, `cheng_app_set_window`, `cheng_app_tick`, `cheng_app_on_touch`, `cheng_app_pause`, `cheng_app_resume`.\n"], "")
    text = strutil.Join([text, "- The generated native shell is responsible for platform lifecycle, window creation, and input forwarding.\n"], "")
    text = strutil.Join([text, "- The shell is generated by Cheng; platform source still targets Android NDK, UIKit/Metal, and Harmony XComponent APIs.\n\n"], "")
    text = strutil.Join([text, "app_id=", opts.appId, "\n"], "")
    text = strutil.Join([text, "app_name=", opts.appName, "\n"], "")
    text = strutil.Join([text, "lib_name=", opts.libName, "\n"], "")
    text = strutil.Join([text, "runtime_mode=", opts.runtimeMode, "\n"], "")
    text = strutil.Join([text, "runtime_manifest=", runtimeManifestRel, "\n"], "")
    text = strutil.Join([text, "runtime_contract_payload=", runtimeContractPayloadRel, "\n"], "")
    text = strutil.Join([text, "runtime_bundle_payload=", runtimeBundlePayloadRel, "\n"], "")
    text = strutil.Join([text, "semantic_nodes_path=", runtimeSemanticNodesRel, "\n"], "")
    text = strutil.Join([text, "truth_root_path=", runtimeTruthRootRel, "\n"], "")
    text = strutil.Join([text, "launch_args_kv=", launchArgsKvRel, "\n"], "")
    text = strutil.Join([text, "launch_args_json=", launchArgsJsonRel, "\n"], "")
    text = strutil.Join([text, "initial_route_state=", opts.routeState, "\n"], "")
    return text

fn MobileShellManifest(opts: MobileShellOptions,
                         runtimeManifestRel: str,
                         runtimeContractPayloadRel: str,
                         runtimeBundlePayloadRel: str,
                         runtimeSemanticNodesRel: str,
                         runtimeTruthRootRel: str,
                         launchArgsKvRel: str,
                         launchArgsJsonRel: str,
                         files: var str[]): str =
    var text: str = "{\n"
    text = strutil.Join([text, "  \"format\": \"mobile_shell_manifest_v1\",\n"], "")
    text = strutil.Join([text, "  \"generator\": \"cheng.cheng.mobile_shell_codegen\",\n"], "")
    text = strutil.Join([text, "  \"workspace_root\": ", MobileShellJsonQuote(opts.rootDir), ",\n"], "")
    text = strutil.Join([text, "  \"out_dir\": ", MobileShellJsonQuote(opts.outDir), ",\n"], "")
    text = strutil.Join([text, "  \"app_id\": ", MobileShellJsonQuote(opts.appId), ",\n"], "")
    text = strutil.Join([text, "  \"app_name\": ", MobileShellJsonQuote(opts.appName), ",\n"], "")
    text = strutil.Join([text, "  \"lib_name\": ", MobileShellJsonQuote(opts.libName), ",\n"], "")
    text = strutil.Join([text, "  \"runtime_mode\": ", MobileShellJsonQuote(opts.runtimeMode), ",\n"], "")
    text = strutil.Join([text, "  \"runtime_manifest\": ", MobileShellJsonQuote(runtimeManifestRel), ",\n"], "")
    text = strutil.Join([text, "  \"runtime_contract_payload\": ", MobileShellJsonQuote(runtimeContractPayloadRel), ",\n"], "")
    text = strutil.Join([text, "  \"runtime_bundle_payload\": ", MobileShellJsonQuote(runtimeBundlePayloadRel), ",\n"], "")
    text = strutil.Join([text, "  \"semantic_nodes_path\": ", MobileShellJsonQuote(runtimeSemanticNodesRel), ",\n"], "")
    text = strutil.Join([text, "  \"truth_root_path\": ", MobileShellJsonQuote(runtimeTruthRootRel), ",\n"], "")
    text = strutil.Join([text, "  \"launch_args_kv\": ", MobileShellJsonQuote(launchArgsKvRel), ",\n"], "")
    text = strutil.Join([text, "  \"launch_args_json\": ", MobileShellJsonQuote(launchArgsJsonRel), ",\n"], "")
    text = strutil.Join([text, "  \"initial_route_state\": ", MobileShellJsonQuote(opts.routeState), ",\n"], "")
    text = strutil.Join([text, "  \"app_exports\": [\n"], "")
    text = strutil.Join([text, "    \"cheng_app_init\",\n"], "")
    text = strutil.Join([text, "    \"cheng_app_set_window\",\n"], "")
    text = strutil.Join([text, "    \"cheng_app_tick\",\n"], "")
    text = strutil.Join([text, "    \"cheng_app_on_touch\",\n"], "")
    text = strutil.Join([text, "    \"cheng_app_pause\",\n"], "")
    text = strutil.Join([text, "    \"cheng_app_resume\"\n"], "")
    text = strutil.Join([text, "  ],\n"], "")
    text = strutil.Join([text, "  \"platforms\": [\n"], "")
    var emittedPlatformCount: int32
    if opts.emitAndroid:
        emittedPlatformCount = emittedPlatformCount + 1
    if opts.emitIos:
        emittedPlatformCount = emittedPlatformCount + 1
    if opts.emitHarmony:
        emittedPlatformCount = emittedPlatformCount + 1
    var emittedPlatformIndex: int32
    if opts.emitAndroid:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = strutil.Join([text, "    ", MobileShellJsonQuote("android")], "")
        if emittedPlatformIndex < emittedPlatformCount:
            text = strutil.Join([text, ","], "")
        text = strutil.Join([text, "\n"], "")
    if opts.emitIos:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = strutil.Join([text, "    ", MobileShellJsonQuote("ios")], "")
        if emittedPlatformIndex < emittedPlatformCount:
            text = strutil.Join([text, ","], "")
        text = strutil.Join([text, "\n"], "")
    if opts.emitHarmony:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = strutil.Join([text, "    ", MobileShellJsonQuote("harmony")], "")
        if emittedPlatformIndex < emittedPlatformCount:
            text = strutil.Join([text, ","], "")
        text = strutil.Join([text, "\n"], "")
    text = strutil.Join([text, "  ],\n"], "")
    text = strutil.Join([text, "  \"generated_files\": [\n"], "")
    for i in 0..<files.len:
        text = strutil.Join([text, "    ", MobileShellJsonQuote(files[i])], "")
        if i + 1 < files.len:
            text = strutil.Join([text, ","], "")
        text = strutil.Join([text, "\n"], "")
    text = strutil.Join([text, "  ]\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

