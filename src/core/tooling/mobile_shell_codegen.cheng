fn MobileShellWriteIosProjectFile(opts: var MobileShellOptions,
                                    files: var str[],
                                    outError: var str): bool =
    let rel: str = "ios/ChengGeneratedApp.xcodeproj/project.pbxproj"
    let full: str = chengpath.PathJoin(opts.outDir, rel)
    let parent: str = chengpath.PathParentDir(full)
    if !chengpath.MkdirP("", parent):
        outError = Fmt"mobile-shell: mkdir failed: {parent}"
        return false
    let f: os.File = os.openImplWrite(full)
    if f == nil:
        outError = Fmt"mobile-shell: open failed: {full}"
        return false
    let text: str = MobileShellIosProjectPbxproj(opts)
    os.Write(f, text)
    if len(text) <= 0 || text[text.len - 1] != '\n':
        os.Write(f, "\n")
    os.Close(f)
    if !chengpath.PathFileExists(full) || chengpath.PathFileSize(full) <= int64(0):
        outError = Fmt"mobile-shell: write failed: {full}"
        return false
    add(files, rel)
    return true

fn MobileShellWriteIosWorkspaceFile(opts: var MobileShellOptions,
                                      files: var str[],
                                      outError: var str): bool =
    let rel: str = "ios/ChengGeneratedApp.xcodeproj/project.xcworkspace/contents.xcworkspacedata"
    let full: str = chengpath.PathJoin(opts.outDir, rel)
    let parent: str = chengpath.PathParentDir(full)
    if !chengpath.MkdirP("", parent):
        outError = Fmt"mobile-shell: mkdir failed: {parent}"
        return false
    let f: os.File = os.openImplWrite(full)
    if f == nil:
        outError = Fmt"mobile-shell: open failed: {full}"
        return false
    let text: str = MobileShellIosWorkspaceData()
    os.Write(f, text)
    if len(text) <= 0 || text[text.len - 1] != '\n':
        os.Write(f, "\n")
    os.Close(f)
    if !chengpath.PathFileExists(full) || chengpath.PathFileSize(full) <= int64(0):
        outError = Fmt"mobile-shell: write failed: {full}"
        return false
    add(files, rel)
    return true

fn MobileShellWriteIos(opts: var MobileShellOptions,
                         files: var str[],
                         outError: var str): bool =
    if !MobileShellWriteIosInfoPlistFile(opts, files, outError):
        return false
    if !MobileShellWriteIosMainFile(opts, files, outError):
        return false
    if !MobileShellWriteIosAppDelegateHeaderFile(opts, files, outError):
        return false
    if !MobileShellWriteIosAppDelegateImplFile(opts, files, outError):
        return false
    if !MobileShellWriteIosViewControllerHeaderFile(opts, files, outError):
        return false
    if !MobileShellWriteIosViewControllerImplFile(opts, files, outError):
        return false
    if !MobileShellWriteIosProjectFile(opts, files, outError):
        return false
    return MobileShellWriteIosWorkspaceFile(opts, files, outError)

fn MobileShellWriteHarmony(opts: var MobileShellOptions,
                             files: var str[],
                             outError: var str): bool =
    let buildProfileRel: str = "harmony/build-profile.json5"
    let buildProfileFull: str = chengpath.PathJoin(opts.outDir, buildProfileRel)
    let buildProfileText: str = MobileShellHarmonyBuildProfile()
    if !MobileShellWriteFile(buildProfileFull, buildProfileText, buildProfileRel, files, outError):
        return false
    let hvigorRel: str = "harmony/hvigorfile.ts"
    let hvigorFull: str = chengpath.PathJoin(opts.outDir, hvigorRel)
    let hvigorText: str = MobileShellHarmonyHvigorFile()
    if !MobileShellWriteFile(hvigorFull, hvigorText, hvigorRel, files, outError):
        return false
    let hvigorConfigRel: str = "harmony/hvigor/hvigor-config.json5"
    let hvigorConfigFull: str = chengpath.PathJoin(opts.outDir, hvigorConfigRel)
    let hvigorConfigText: str = MobileShellHarmonyHvigorConfig()
    if !MobileShellWriteFile(hvigorConfigFull, hvigorConfigText, hvigorConfigRel, files, outError):
        return false
    let rootPackageRel: str = "harmony/oh-package.json5"
    let rootPackageFull: str = chengpath.PathJoin(opts.outDir, rootPackageRel)
    let rootPackageText: str = MobileShellHarmonyRootPackageJson()
    if !MobileShellWriteFile(rootPackageFull, rootPackageText, rootPackageRel, files, outError):
        return false
    let entryPackageRel: str = "harmony/entry/oh-package.json5"
    let entryPackageFull: str = chengpath.PathJoin(opts.outDir, entryPackageRel)
    let entryPackageText: str = MobileShellHarmonyEntryPackageJson()
    if !MobileShellWriteFile(entryPackageFull, entryPackageText, entryPackageRel, files, outError):
        return false
    let entryHvigorRel: str = "harmony/entry/hvigorfile.ts"
    let entryHvigorFull: str = chengpath.PathJoin(opts.outDir, entryHvigorRel)
    let entryHvigorText: str = MobileShellHarmonyEntryHvigorFile()
    if !MobileShellWriteFile(entryHvigorFull, entryHvigorText, entryHvigorRel, files, outError):
        return false
    let entryBuildProfileRel: str = "harmony/entry/build-profile.json5"
    let entryBuildProfileFull: str = chengpath.PathJoin(opts.outDir, entryBuildProfileRel)
    let entryBuildProfileText: str = MobileShellHarmonyEntryBuildProfile()
    if !MobileShellWriteFile(entryBuildProfileFull, entryBuildProfileText, entryBuildProfileRel, files, outError):
        return false
    let appScopeRel: str = "harmony/AppScope/app.json5"
    let appScopeFull: str = chengpath.PathJoin(opts.outDir, appScopeRel)
    let appScopeText: str = MobileShellHarmonyAppJson(opts)
    if !MobileShellWriteFile(appScopeFull, appScopeText, appScopeRel, files, outError):
        return false
    let moduleRel: str = "harmony/entry/src/main/module.json5"
    let moduleFull: str = chengpath.PathJoin(opts.outDir, moduleRel)
    let moduleText: str = MobileShellHarmonyModuleJson(opts)
    if !MobileShellWriteFile(moduleFull, moduleText, moduleRel, files, outError):
        return false
    let stringRel: str = "harmony/entry/src/main/resources/base/element/string.json"
    let stringFull: str = chengpath.PathJoin(opts.outDir, stringRel)
    let stringText: str = MobileShellHarmonyStringJson(opts)
    if !MobileShellWriteFile(stringFull, stringText, stringRel, files, outError):
        return false
    let colorRel: str = "harmony/entry/src/main/resources/base/element/color.json"
    let colorFull: str = chengpath.PathJoin(opts.outDir, colorRel)
    let colorText: str = MobileShellHarmonyColorJson()
    if !MobileShellWriteFile(colorFull, colorText, colorRel, files, outError):
        return false
    let appIconRel: str = "harmony/entry/src/main/resources/base/media/app_icon.svg"
    let appIconFull: str = chengpath.PathJoin(opts.outDir, appIconRel)
    let appIconText: str = MobileShellHarmonyAppIconSvg()
    if !MobileShellWriteFile(appIconFull, appIconText, appIconRel, files, outError):
        return false
    let indexRel: str = "harmony/entry/src/main/ets/pages/Index.ets"
    let indexFull: str = chengpath.PathJoin(opts.outDir, indexRel)
    let indexText: str = MobileShellHarmonyIndexEts(opts)
    if !MobileShellWriteFile(indexFull, indexText, indexRel, files, outError):
        return false
    let entryAbilityRel: str = "harmony/entry/src/main/ets/entryability/EntryAbility.ets"
    let entryAbilityFull: str = chengpath.PathJoin(opts.outDir, entryAbilityRel)
    let entryAbilityText: str = MobileShellHarmonyEntryAbilityEts()
    if !MobileShellWriteFile(entryAbilityFull, entryAbilityText, entryAbilityRel, files, outError):
        return false
    let mainPagesRel: str = "harmony/entry/src/main/resources/base/profile/main_pages.json"
    let mainPagesFull: str = chengpath.PathJoin(opts.outDir, mainPagesRel)
    let mainPagesText: str = MobileShellHarmonyMainPagesJson()
    if !MobileShellWriteFile(mainPagesFull, mainPagesText, mainPagesRel, files, outError):
        return false
    let cmakeRel: str = "harmony/entry/src/main/cpp/CMakeLists.txt"
    let cmakeFull: str = chengpath.PathJoin(opts.outDir, cmakeRel)
    let cmakeText: str = MobileShellHarmonyCmake()
    if !MobileShellWriteFile(cmakeFull, cmakeText, cmakeRel, files, outError):
        return false
    let hostRel: str = "harmony/entry/src/main/cpp/cheng_generated_harmony_host.cpp"
    let hostFull: str = chengpath.PathJoin(opts.outDir, hostRel)
    let hostText: str = MobileShellHarmonyHostSource(opts)
    return MobileShellWriteFile(hostFull, hostText, hostRel, files, outError)

fn MobileShellResolveOptions(rootDir: str,
                               args: str[],
                               outOpts: var MobileShellOptions,
                               outPlatforms: var str[],
                               outError: var str): bool =
    outOpts = MobileShellDefaultOptions(rootDir)
    outPlatforms = []
    outError = ""
    let outRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--out-dir", outOpts.outDir))
    if len(outRaw) > 0:
        outOpts.outDir = chengpath.PathAbsolute(rootDir, outRaw)
    let appIdRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--app-id", outOpts.appId))
    if len(appIdRaw) > 0:
        outOpts.appId = appIdRaw
    let appNameRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--app-name", outOpts.appName))
    if len(appNameRaw) > 0:
        outOpts.appName = appNameRaw
    let libNameRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--lib-name", outOpts.libName))
    if len(libNameRaw) > 0:
        outOpts.libName = libNameRaw
    let runtimeModeRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--runtime-mode", outOpts.runtimeMode))
    if len(runtimeModeRaw) > 0:
        outOpts.runtimeMode = runtimeModeRaw
    let runtimeContractRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--runtime-contract", ""))
    if len(runtimeContractRaw) > 0:
        outOpts.runtimeContractPath = chengpath.PathAbsolute(rootDir, runtimeContractRaw)
    let runtimeBundleRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--runtime-bundle", ""))
    if len(runtimeBundleRaw) > 0:
        outOpts.runtimeBundlePath = chengpath.PathAbsolute(rootDir, runtimeBundleRaw)
    let routeStateRaw: str = strutil.Strip(creq.CompilerReadFlagOrDefault(args, "--route-state", ""))
    if len(routeStateRaw) > 0:
        outOpts.routeState = routeStateRaw
    var platforms: str[]
    let platformText: str = creq.CompilerReadFlagOrDefault(args, "--platform", "all")
    if !MobileShellResolvePlatforms(platformText, platforms):
        outError = Fmt"mobile-shell: unsupported platform: {platformText}"
        return false
    outOpts.emitAndroid = false
    outOpts.emitIos = false
    outOpts.emitHarmony = false
    for i in 0..<platforms.len:
        if platforms[i] == "android":
            outOpts.emitAndroid = true
        elif platforms[i] == "ios":
            outOpts.emitIos = true
        elif platforms[i] == "harmony":
            outOpts.emitHarmony = true
    outPlatforms = platforms
    return true

fn MobileShellExportResolved(opts: var MobileShellOptions,
                               outManifestPath: var str,
                               outError: var str): bool =
    outManifestPath = ""
    outError = ""
    if !chengpath.MkdirP("", opts.outDir):
        outError = Fmt"mobile-shell: failed to create out dir: {opts.outDir}"
        return false
    var files: str[]
    var runtimeContractPayloadRel: str
    var runtimeBundlePayloadRel: str
    var runtimeSemanticNodesRel: str
    var runtimeTruthRootRel: str
    var launchArgsKvRel: str
    var launchArgsJsonRel: str
    let runtimeManifestRel: str = MobileShellRuntimeManifestRelPath()
    if !MobileShellWriteRuntimePayloadFile(opts,
                                             opts.runtimeContractPath,
                                             "runtime_contract_payload.json",
                                             files,
                                             runtimeContractPayloadRel,
                                             outError):
        return false
    if !MobileShellWriteRuntimePayloadFile(opts,
                                             opts.runtimeBundlePath,
                                             "runtime_bundle_payload.json",
                                             files,
                                             runtimeBundlePayloadRel,
                                             outError):
        return false
    if !MobileShellWriteOptionalRuntimeResources(opts,
                                                   files,
                                                   runtimeSemanticNodesRel,
                                                   runtimeTruthRootRel,
                                                   outError):
        return false
    let readmePath = chengpath.PathJoin(opts.outDir, "README.md")
    if !MobileShellWriteLaunchArgsFiles(opts,
                                          runtimeManifestRel,
                                          runtimeContractPayloadRel,
                                          runtimeBundlePayloadRel,
                                          files,
                                          launchArgsKvRel,
                                          launchArgsJsonRel,
                                          outError):
        return false
    if !MobileShellWriteFile(readmePath,
                               MobileShellReadme(opts,
                                                   runtimeManifestRel,
                                                   runtimeContractPayloadRel,
                                                   runtimeBundlePayloadRel,
                                                   runtimeSemanticNodesRel,
                                                   runtimeTruthRootRel,
                                                   launchArgsKvRel,
                                                   launchArgsJsonRel),
                               "README.md",
                               files,
                               outError):
        return false
    let runtimeManifestPath: str = chengpath.PathJoin(opts.outDir, runtimeManifestRel)
    if !MobileShellWriteFile(runtimeManifestPath,
                               MobileShellRuntimeManifest(opts,
                                                            runtimeContractPayloadRel,
                                                            runtimeBundlePayloadRel,
                                                            runtimeSemanticNodesRel,
                                                            runtimeTruthRootRel,
                                                            launchArgsKvRel,
                                                            launchArgsJsonRel),
                               runtimeManifestRel,
                               files,
                               outError):
        return false
    if !MobileShellWritePlatformRuntimeMirrors(opts,
                                                 runtimeManifestPath,
                                                 runtimeContractPayloadRel,
                                                 runtimeBundlePayloadRel,
                                                 runtimeSemanticNodesRel,
                                                 runtimeTruthRootRel,
                                                 launchArgsKvRel,
                                                 launchArgsJsonRel,
                                                 files,
                                                 outError):
        return false
    if opts.emitAndroid:
        if !MobileShellWriteAndroid(opts, files, outError):
            return false
    if opts.emitIos:
        if !MobileShellWriteIos(opts, files, outError):
            return false
    if opts.emitHarmony:
        if !MobileShellWriteHarmony(opts, files, outError):
            return false
    let manifestRel = "mobile_shell_manifest_v1.json"
    let manifestPath = chengpath.PathJoin(opts.outDir, manifestRel)
    if !MobileShellWriteFile(manifestPath,
                               MobileShellManifest(opts,
                                                     runtimeManifestRel,
                                                     runtimeContractPayloadRel,
                                                     runtimeBundlePayloadRel,
                                                     runtimeSemanticNodesRel,
                                                     runtimeTruthRootRel,
                                                     launchArgsKvRel,
                                                     launchArgsJsonRel,
                                                     files),
                               manifestRel,
                               files,
                               outError):
        return false
    outManifestPath = manifestPath
    return true

fn MobileShellExport(rootDir: str,
                       args: str[],
                       outOutput: var str,
                       outError: var str): int32 =
    outOutput = ""
    outError = ""
    var opts: MobileShellOptions
    var platforms: str[]
    if !MobileShellResolveOptions(rootDir, args, opts, platforms, outError):
        return 1
    var manifestPath: str
    if !MobileShellExportResolved(opts, manifestPath, outError):
        return 1
    outOutput = "mobile-shell export ok\n"
    return 0

fn MobileShellBoolEnv(value: bool): str =
    if value:
        return "1"
    return "0"

fn MobileShellQuoteShell(value: str): str =
    return os.QuoteShell(value)

fn MobileShellBuildCommand(program: str,
                             args: str[]): str =
    var text: str = MobileShellQuoteShell(program)
    for i in 0..<args.len:
        let quotedArg: str = MobileShellQuoteShell(args[i])
        text = Fmt"{text} {quotedArg}"
    return text

fn MobileShellRunCommandLogged(command: str,
                                 workingDir: str,
                                 logPath: str): os.ExecCmdResult =
    let res: os.ExecCmdResult = os.ExecShellCmdEx(command, uint64(1), workingDir)
    let output: str = os.ExecCmdResultOutput(res)
    let _logged: bool = chengpath.WriteTextFile("", logPath, output)
    return res

fn MobileShellWriteBuildProbeSummary(summaryPath: str,
                                       androidSelected: bool,
                                       iosSelected: bool,
                                       harmonySelected: bool): bool =
    let parent: str = chengpath.PathParentDir(summaryPath)
    if !chengpath.MkdirP("", parent):
        return false
    let f: os.File = os.openImplWrite(summaryPath)
    if f == nil:
        return false
    os.Write(f, "format=mobile_shell_build_probe_summary_v1\n")
    if androidSelected:
        os.Write(f, "android_exit_code=0\n")
        os.Write(f, "android_apk_exists=1\n")
    else:
        os.Write(f, "android_exit_code=-1\n")
        os.Write(f, "android_apk_exists=0\n")
    if iosSelected:
        os.Write(f, "ios_exit_code=0\n")
        os.Write(f, "ios_app_exists=1\n")
    else:
        os.Write(f, "ios_exit_code=-1\n")
        os.Write(f, "ios_app_exists=0\n")
    if harmonySelected:
        os.Write(f, "harmony_exit_code=0\n")
        os.Write(f, "harmony_app_exists=1\n")
        os.Write(f, "harmony_hap_exists=1\n")
    else:
        os.Write(f, "harmony_exit_code=-1\n")
        os.Write(f, "harmony_app_exists=0\n")
        os.Write(f, "harmony_hap_exists=0\n")
    os.Close(f)
    return chengpath.PathFileExists(summaryPath)

fn MobileShellBuildProbeFail(summaryPath: str,
                               message: str,
                               outError: var str): int32 =
    let _summaryPath = summaryPath
    outError = message
    return 1

fn MobileShellBuildProbe(rootDir: str,
                           args: str[],
                           outOutput: var str,
                           outError: var str): int32 =
    outOutput = ""
    outError = ""
    var opts: MobileShellOptions
    var platforms: str[]
    if !MobileShellResolveOptions(rootDir, args, opts, platforms, outError):
        return 1
    var manifestPath: str
    if !MobileShellExportResolved(opts, manifestPath, outError):
        return 1
    let runtimeManifestPath: str = chengpath.PathJoin(opts.outDir, MobileShellRuntimeManifestRelPath())
    let runtimeContractPayloadRel: str = MobileShellRuntimeContractPayloadRelPath()
    let runtimeBundlePayloadRel: str = MobileShellRuntimeBundlePayloadRelPath()
    let summaryPath: str = chengpath.PathJoin(opts.outDir, "mobile_shell_build_probe.summary.env")
    let androidLog: str = chengpath.PathJoin(opts.outDir, "android_build.log")
    let iosLog: str = chengpath.PathJoin(opts.outDir, "ios_build.log")
    let harmonyLog: str = chengpath.PathJoin(opts.outDir, "harmony_build.log")
    let androidApk: str = chengpath.PathJoin(opts.outDir, "android/app/build/outputs/apk/debug/app-debug.apk")
    let iosApp: str = chengpath.PathJoin(opts.outDir, "ios/.derived_data/Build/Products/Debug-iphonesimulator/ChengGeneratedApp.app/ChengGeneratedApp")
    let harmonyApp: str = chengpath.PathJoin(opts.outDir, "harmony/build/outputs/default/harmony-default-unsigned.app")
    let harmonyHap: str = chengpath.PathJoin(opts.outDir, "harmony/entry/build/default/outputs/default/app/entry-default.hap")
    let harmonyHvigorPath: str = "/Applications/DevEco-Studio.app/Contents/tools/hvigor/bin/hvigorw.js"
    var androidSelected: bool
    var iosSelected: bool
    var harmonySelected: bool
    var androidExitCode: int32 = -1
    var iosExitCode: int32 = -1
    var harmonyExitCode: int32 = -1
    for i in 0..<platforms.len:
        let platform: str = platforms[i]
        if platform == "android":
            androidSelected = true
            let command: str = MobileShellBuildCommand("gradle",
                                                         [
                                                             "-p",
                                                             chengpath.PathJoin(opts.outDir, "android"),
                                                             ":app:assembleDebug"
                                                         ])
            let run: os.ExecCmdResult = MobileShellRunCommandLogged(command, rootDir, androidLog)
            androidExitCode = os.ExecCmdResultExitCode(run)
            if androidExitCode != 0:
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: android build failed rc={IntToStr(androidExitCode)} log={androidLog}",
                                                   outError)
            if !os.FileExists(androidApk):
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: android artifact missing: {androidApk}",
                                                   outError)
        elif platform == "ios":
            iosSelected = true
            let command: str = MobileShellBuildCommand("xcodebuild",
                                                         [
                                                             "-project",
                                                             chengpath.PathJoin(opts.outDir, "ios/ChengGeneratedApp.xcodeproj"),
                                                             "-scheme",
                                                             "ChengGeneratedApp",
                                                             "-configuration",
                                                             "Debug",
                                                             "-sdk",
                                                             "iphonesimulator",
                                                             "-derivedDataPath",
                                                             chengpath.PathJoin(opts.outDir, "ios/.derived_data"),
                                                             "CODE_SIGNING_ALLOWED=NO",
                                                             "build"
                                                         ])
            let run: os.ExecCmdResult = MobileShellRunCommandLogged(command, rootDir, iosLog)
            iosExitCode = os.ExecCmdResultExitCode(run)
            if iosExitCode != 0:
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: ios build failed rc={IntToStr(iosExitCode)} log={iosLog}",
                                                   outError)
            if !os.FileExists(iosApp):
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: ios artifact missing: {iosApp}",
                                                   outError)
        elif platform == "harmony":
            harmonySelected = true
            let command: str = MobileShellBuildCommand("node",
                                                         [
                                                             harmonyHvigorPath,
                                                             "assembleApp",
                                                             "-p",
                                                             "product=default",
                                                             "-p",
                                                             "buildMode=debug",
                                                             "--no-daemon"
                                                         ])
            let run: os.ExecCmdResult = MobileShellRunCommandLogged(command,
                                                                      chengpath.PathJoin(opts.outDir, "harmony"),
                                                                      harmonyLog)
            harmonyExitCode = os.ExecCmdResultExitCode(run)
            if harmonyExitCode != 0:
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: harmony build failed rc={IntToStr(harmonyExitCode)} log={harmonyLog}",
                                                   outError)
            if !os.FileExists(harmonyApp):
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: harmony app artifact missing: {harmonyApp}",
                                                   outError)
            if !os.FileExists(harmonyHap):
                return MobileShellBuildProbeFail(summaryPath,
                                                   Fmt"mobile-shell: harmony hap artifact missing: {harmonyHap}",
                                                   outError)
    if !MobileShellWriteBuildProbeSummary(summaryPath,
                                            androidSelected,
                                            iosSelected,
                                            harmonySelected):
        outError = Fmt"mobile-shell: failed to write summary: {summaryPath}"
        return 1
    outOutput = "mobile-shell build-probe ok\n"
    return 0

fn MobileShellRun(rootDir: str,
                    args: str[],
                    outOutput: var str,
                    outError: var str): int32 =
    outOutput = ""
    outError = ""
    if args.len <= 0:
        outOutput = MobileShellHelpText()
        return 0
    let subcmd: str = strutil.Strip(args[0])
    if subcmd == "help":
        outOutput = MobileShellHelpText()
        return 0
    if subcmd == "--help":
        outOutput = MobileShellHelpText()
        return 0
    if subcmd == "-h":
        outOutput = MobileShellHelpText()
        return 0
    var tail: str[]
    for i in 1..<args.len:
        add(tail, args[i])
    if subcmd == "export":
        return MobileShellExport(rootDir, tail, outOutput, outError)
    if subcmd == "build-probe":
        return MobileShellBuildProbe(rootDir, tail, outOutput, outError)
    outOutput = MobileShellHelpText()
    outError = Fmt"mobile-shell: unknown subcommand: {subcmd}"
    return 2
