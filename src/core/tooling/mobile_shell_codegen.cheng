fn MobileShellHarmonyHostSource(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "rawfile/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "rawfile/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "rawfile/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKvRel: str = "rawfile/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "rawfile/mobile_shell_launch_args.json"
    var text: str = "#include <ace/xcomponent/native_interface_xcomponent.h>\n"
    text = strutil.Join([text, "#include <hilog/log.h>\n"], "")
    text = strutil.Join([text, "#include <native_window/external_window.h>\n"], "")
    text = strutil.Join([text, "#include <napi/native_api.h>\n"], "")
    text = strutil.Join([text, "#include <rawfile/raw_file.h>\n"], "")
    text = strutil.Join([text, "#include <rawfile/raw_file_manager.h>\n"], "")
    text = strutil.Join([text, "#include <dlfcn.h>\n"], "")
    text = strutil.Join([text, "#include <stdint.h>\n"], "")
    text = strutil.Join([text, "#include <stdlib.h>\n\n"], "")
    text = strutil.Join([text, "#include <string.h>\n\n"], "")
    text = strutil.Join([text, "typedef uint64_t (*cheng_app_init_fn)(void);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_pause_fn)(uint64_t);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_app_resume_fn)(uint64_t);\n\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_mobile_host_runtime_set_manifest_payloads_fn)(const char*, const char*, const char*);\n"], "")
    text = strutil.Join([text, "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"], "")
    text = strutil.Join([text, "typedef struct ChengHarmonyRuntime {\n"], "")
    text = strutil.Join([text, "  uint64_t app_id;\n"], "")
    text = strutil.Join([text, "  OHNativeWindow* window;\n"], "")
    text = strutil.Join([text, "  int width;\n"], "")
    text = strutil.Join([text, "  int height;\n"], "")
    text = strutil.Join([text, "} ChengHarmonyRuntime;\n\n"], "")
    text = strutil.Join([text, "static ChengHarmonyRuntime s_runtime = {0};\n"], "")
    text = strutil.Join([text, "static cheng_app_set_window_fn s_set_window = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_tick_fn s_tick = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_on_touch_fn s_touch = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_pause_fn s_pause = NULL;\n"], "")
    text = strutil.Join([text, "static cheng_app_resume_fn s_resume = NULL;\n\n"], "")
    text = strutil.Join([text, "static NativeResourceManager* s_resource_manager = NULL;\n"], "")
    text = strutil.Join([text, "static int s_runtime_payloads_applied = 0;\n"], "")
    text = strutil.Join([text, "static int s_launch_args_applied = 0;\n\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeManifest = \"", runtimeManifestRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeContractPayloadRel = \"", runtimeContractPayloadRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengRuntimeBundlePayloadRel = \"", runtimeBundlePayloadRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengLaunchArgsKvRel = \"", launchArgsKvRel, "\";\n"], "")
    text = strutil.Join([text, "static const char* kChengLaunchArgsJsonRel = \"", launchArgsJsonRel, "\";\n"], "")
    text = strutil.Join([text, "\n"], "")
    text = strutil.Join([text, "static const char* cheng_harmony_rawfile_path(const char* relPath) {\n"], "")
    text = strutil.Join([text, "  static const char* prefix = \"rawfile/\";\n"], "")
    text = strutil.Join([text, "  if (relPath == NULL) {\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (strncmp(relPath, prefix, 8u) == 0) {\n"], "")
    text = strutil.Join([text, "    return relPath + 8u;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  return relPath;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static char* cheng_harmony_read_raw_text(const char* relPath) {\n"], "")
    text = strutil.Join([text, "  if (s_resource_manager == NULL || relPath == NULL || relPath[0] == '\\0') {\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  const char* rawPath = cheng_harmony_rawfile_path(relPath);\n"], "")
    text = strutil.Join([text, "  RawFile* rawFile = OH_ResourceManager_OpenRawFile(s_resource_manager, rawPath);\n"], "")
    text = strutil.Join([text, "  if (rawFile == NULL) {\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  long rawSize = OH_ResourceManager_GetRawFileSize(rawFile);\n"], "")
    text = strutil.Join([text, "  if (rawSize < 0) {\n"], "")
    text = strutil.Join([text, "    OH_ResourceManager_CloseRawFile(rawFile);\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  size_t size = (size_t)rawSize;\n"], "")
    text = strutil.Join([text, "  char* textBuf = (char*)calloc(size + 1u, 1u);\n"], "")
    text = strutil.Join([text, "  if (textBuf == NULL) {\n"], "")
    text = strutil.Join([text, "    OH_ResourceManager_CloseRawFile(rawFile);\n"], "")
    text = strutil.Join([text, "    return NULL;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (size > 0u) {\n"], "")
    text = strutil.Join([text, "    int readLen = OH_ResourceManager_ReadRawFile(rawFile, textBuf, size);\n"], "")
    text = strutil.Join([text, "    if (readLen < 0) {\n"], "")
    text = strutil.Join([text, "      free(textBuf);\n"], "")
    text = strutil.Join([text, "      OH_ResourceManager_CloseRawFile(rawFile);\n"], "")
    text = strutil.Join([text, "      return NULL;\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "    if ((size_t)readLen < size) {\n"], "")
    text = strutil.Join([text, "      textBuf[(size_t)readLen] = '\\0';\n"], "")
    text = strutil.Join([text, "    } else {\n"], "")
    text = strutil.Join([text, "      textBuf[size] = '\\0';\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  OH_ResourceManager_CloseRawFile(rawFile);\n"], "")
    text = strutil.Join([text, "  return textBuf;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void cheng_harmony_apply_runtime_payloads(void* handle) {\n"], "")
    text = strutil.Join([text, "  if (s_runtime_payloads_applied != 0 || handle == NULL || s_resource_manager == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads =\n"], "")
    text = strutil.Join([text, "      (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_manifest_payloads\");\n"], "")
    text = strutil.Join([text, "  if (setRuntimePayloads == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  char* manifestJson = cheng_harmony_read_raw_text(kChengRuntimeManifest);\n"], "")
    text = strutil.Join([text, "  char* contractPayloadJson = cheng_harmony_read_raw_text(kChengRuntimeContractPayloadRel);\n"], "")
    text = strutil.Join([text, "  char* bundlePayloadJson = cheng_harmony_read_raw_text(kChengRuntimeBundlePayloadRel);\n"], "")
    text = strutil.Join([text, "  setRuntimePayloads(manifestJson, contractPayloadJson, bundlePayloadJson);\n"], "")
    text = strutil.Join([text, "  if (manifestJson != NULL) {\n"], "")
    text = strutil.Join([text, "    free(manifestJson);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (contractPayloadJson != NULL) {\n"], "")
    text = strutil.Join([text, "    free(contractPayloadJson);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (bundlePayloadJson != NULL) {\n"], "")
    text = strutil.Join([text, "    free(bundlePayloadJson);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  s_runtime_payloads_applied = 1;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void cheng_harmony_apply_launch_args(void* handle) {\n"], "")
    text = strutil.Join([text, "  if (s_launch_args_applied != 0 || handle == NULL || s_resource_manager == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs =\n"], "")
    text = strutil.Join([text, "      (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"], "")
    text = strutil.Join([text, "  if (setLaunchArgs == NULL) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  char* argsKv = cheng_harmony_read_raw_text(kChengLaunchArgsKvRel);\n"], "")
    text = strutil.Join([text, "  char* argsJson = cheng_harmony_read_raw_text(kChengLaunchArgsJsonRel);\n"], "")
    text = strutil.Join([text, "  setLaunchArgs(argsKv, argsJson);\n"], "")
    text = strutil.Join([text, "  if (argsKv != NULL) {\n"], "")
    text = strutil.Join([text, "    free(argsKv);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (argsJson != NULL) {\n"], "")
    text = strutil.Join([text, "    free(argsJson);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  s_launch_args_applied = 1;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static int cheng_harmony_init_runtime(void) {\n"], "")
    text = strutil.Join([text, "  if (s_runtime.app_id != 0u) {\n"], "")
    text = strutil.Join([text, "    return 1;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  if (s_resource_manager == NULL) {\n"], "")
    text = strutil.Join([text, "    return 0;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  void* handle = dlopen(NULL, RTLD_NOW);\n"], "")
    text = strutil.Join([text, "  if (handle == NULL) {\n"], "")
    text = strutil.Join([text, "    return 0;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  cheng_harmony_apply_runtime_payloads(handle);\n"], "")
    text = strutil.Join([text, "  cheng_harmony_apply_launch_args(handle);\n"], "")
    text = strutil.Join([text, "  cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, \"cheng_app_init\");\n"], "")
    text = strutil.Join([text, "  s_set_window = (cheng_app_set_window_fn)dlsym(handle, \"cheng_app_set_window\");\n"], "")
    text = strutil.Join([text, "  s_tick = (cheng_app_tick_fn)dlsym(handle, \"cheng_app_tick\");\n"], "")
    text = strutil.Join([text, "  s_touch = (cheng_app_on_touch_fn)dlsym(handle, \"cheng_app_on_touch\");\n"], "")
    text = strutil.Join([text, "  s_pause = (cheng_app_pause_fn)dlsym(handle, \"cheng_app_pause\");\n"], "")
    text = strutil.Join([text, "  s_resume = (cheng_app_resume_fn)dlsym(handle, \"cheng_app_resume\");\n"], "")
    text = strutil.Join([text, "  if (initFn == NULL || s_set_window == NULL || s_tick == NULL || s_touch == NULL || s_pause == NULL || s_resume == NULL) {\n"], "")
    text = strutil.Join([text, "    return 0;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  s_runtime.app_id = initFn();\n"], "")
    text = strutil.Join([text, "  return 1;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static napi_value ChengSetResourceManager(napi_env env, napi_callback_info info) {\n"], "")
    text = strutil.Join([text, "  size_t argc = 1u;\n"], "")
    text = strutil.Join([text, "  napi_value argv[1] = {0};\n"], "")
    text = strutil.Join([text, "  (void)napi_get_cb_info(env, info, &argc, argv, NULL, NULL);\n"], "")
    text = strutil.Join([text, "  if (argc >= 1u) {\n"], "")
    text = strutil.Join([text, "    if (s_resource_manager != NULL) {\n"], "")
    text = strutil.Join([text, "      OH_ResourceManager_ReleaseNativeResourceManager(s_resource_manager);\n"], "")
    text = strutil.Join([text, "      s_resource_manager = NULL;\n"], "")
    text = strutil.Join([text, "      s_runtime_payloads_applied = 0;\n"], "")
    text = strutil.Join([text, "      s_launch_args_applied = 0;\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "    s_resource_manager = OH_ResourceManager_InitNativeResourceManager(env, argv[0]);\n"], "")
    text = strutil.Join([text, "    if (s_resource_manager != NULL) {\n"], "")
    text = strutil.Join([text, "      (void)cheng_harmony_init_runtime();\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  napi_value result = NULL;\n"], "")
    text = strutil.Join([text, "  (void)napi_get_undefined(env, &result);\n"], "")
    text = strutil.Join([text, "  return result;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static napi_value ChengHarmonyHostNapiInit(napi_env env, napi_value exports) {\n"], "")
    text = strutil.Join([text, "  napi_property_descriptor props[1] = {\n"], "")
    text = strutil.Join([text, "      {\"setResourceManager\", NULL, ChengSetResourceManager, NULL, NULL, NULL, napi_default, NULL},\n"], "")
    text = strutil.Join([text, "  };\n"], "")
    text = strutil.Join([text, "  (void)napi_define_properties(env, exports, 1u, props);\n"], "")
    text = strutil.Join([text, "  return exports;\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static napi_module s_cheng_harmony_host_module = {0};\n\n"], "")
    text = strutil.Join([text, "extern \"C\" __attribute__((constructor)) void ChengHarmonyHostRegisterModule(void) {\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_version = 1;\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_flags = 0;\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_filename = NULL;\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_register_func = ChengHarmonyHostNapiInit;\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_modname = \"cheng_generated_harmony_host\";\n"], "")
    text = strutil.Join([text, "  s_cheng_harmony_host_module.nm_priv = NULL;\n"], "")
    text = strutil.Join([text, "  napi_module_register(&s_cheng_harmony_host_module);\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void OnSurfaceCreated(OH_NativeXComponent* component, void* window) {\n"], "")
    text = strutil.Join([text, "  component = component;\n"], "")
    text = strutil.Join([text, "  if (!cheng_harmony_init_runtime()) {\n"], "")
    text = strutil.Join([text, "    return;\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "  s_runtime.window = (OHNativeWindow*)window;\n"], "")
    text = strutil.Join([text, "  s_runtime.width = 1080;\n"], "")
    text = strutil.Join([text, "  s_runtime.height = 1920;\n"], "")
    text = strutil.Join([text, "  s_set_window(s_runtime.app_id, 1u, s_runtime.width, s_runtime.height, 1.0f);\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void OnSurfaceDestroyed(OH_NativeXComponent* component, void* window) {\n"], "")
    text = strutil.Join([text, "  component = component;\n"], "")
    text = strutil.Join([text, "  window = window;\n"], "")
    text = strutil.Join([text, "  if (s_runtime.app_id != 0u && s_pause != NULL) {\n"], "")
    text = strutil.Join([text, "    s_pause(s_runtime.app_id);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static void OnDispatchTouchEvent(OH_NativeXComponent* component, void* window) {\n"], "")
    text = strutil.Join([text, "  component = component;\n"], "")
    text = strutil.Join([text, "  window = window;\n"], "")
    text = strutil.Join([text, "  if (s_runtime.app_id != 0u && s_touch != NULL) {\n"], "")
    text = strutil.Join([text, "    s_touch(s_runtime.app_id, 0, 0, 0.0f, 0.0f);\n"], "")
    text = strutil.Join([text, "  }\n"], "")
    text = strutil.Join([text, "}\n\n"], "")
    text = strutil.Join([text, "static OH_NativeXComponent_Callback s_callback = {\n"], "")
    text = strutil.Join([text, "  ", strings.CharToStr('.'), "OnSurfaceCreated = OnSurfaceCreated,\n"], "")
    text = strutil.Join([text, "  ", strings.CharToStr('.'), "OnSurfaceChanged = NULL,\n"], "")
    text = strutil.Join([text, "  ", strings.CharToStr('.'), "OnSurfaceDestroyed = OnSurfaceDestroyed,\n"], "")
    text = strutil.Join([text, "  ", strings.CharToStr('.'), "DispatchTouchEvent = OnDispatchTouchEvent,\n"], "")
    text = strutil.Join([text, "};\n\n"], "")
    text = strutil.Join([text, "extern \"C\" __attribute__((visibility(\"default\"))) void OH_NativeXComponent_OnLoad(OH_NativeXComponent* component, void* reserved) {\n"], "")
    text = strutil.Join([text, "  reserved = reserved;\n"], "")
    text = strutil.Join([text, "  OH_NativeXComponent_RegisterCallback(component, &s_callback);\n"], "")
    text = strutil.Join([text, "}\n"], "")
    return text

fn MobileShellWriteRuntimePayloadFile(opts: MobileShellOptions,
                                        sourcePath: str,
                                        fallbackBaseName: str,
                                        files: var str[],
                                        outRelPath: var str,
                                        outError: var str): bool =
    outRelPath = ""
    let sourceAbs: str = chengpath.PathAbsolute(opts.rootDir, sourcePath)
    if len(sourceAbs) <= 0:
        return true
    if !chengpath.PathFileExists(sourceAbs):
        outError = strutil.Join(["mobile-shell: runtime payload missing: ", sourceAbs], "")
        return false
    var relPath: str = MobileShellRuntimeBundlePayloadRelPath()
    if fallbackBaseName == "runtime_contract_payload.json":
        relPath = MobileShellRuntimeContractPayloadRelPath()
    let targetPath: str = chengpath.PathJoin(opts.outDir, relPath)
    let payloadText: str = chengpath.ReadTextFile("", sourceAbs)
    if !MobileShellWriteFile(targetPath, payloadText, relPath, files, outError):
        return false
    outRelPath = relPath
    return true

fn MobileShellWriteRawFile(fullPath: str,
                             payload: str,
                             relPath: str,
                             files: var str[],
                             outError: var str): bool =
    let parent: str = chengpath.PathParentDir(fullPath)
    if len(parent) > 0 && !chengpath.MkdirP("", parent):
        outError = strutil.Join(["mobile-shell: failed to create dir: ", parent], "")
        return false
    os.WriteFile(fullPath, payload)
    if !chengpath.PathFileExists(fullPath):
        outError = strutil.Join(["mobile-shell: write failed: ", fullPath], "")
        return false
    add(files, relPath)
    return true

fn MobileShellCopyRawFile(opts: MobileShellOptions,
                            sourceFull: str,
                            targetRel: str,
                            files: var str[],
                            outError: var str): bool =
    if !chengpath.PathFileExists(sourceFull):
        outError = strutil.Join(["mobile-shell: runtime mirror source missing: ", sourceFull], "")
        return false
    let payloadText: str = os.ReadFile(sourceFull)
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteRawFile(targetFull, payloadText, targetRel, files, outError)

fn MobileShellSourceRoots(opts: MobileShellOptions): str[] =
    var roots: str[]
    let bundleSourceAbs: str = chengpath.PathAbsolute(opts.rootDir, opts.runtimeBundlePath)
    let contractSourceAbs: str = chengpath.PathAbsolute(opts.rootDir, opts.runtimeContractPath)
    if len(bundleSourceAbs) > 0:
        let bundleDir: str = chengpath.PathParentDir(bundleSourceAbs)
        if len(bundleDir) > 0:
            add(roots, bundleDir)
    if len(contractSourceAbs) > 0:
        let contractDir: str = chengpath.PathParentDir(contractSourceAbs)
        if len(contractDir) > 0:
            var seen: bool
            for i in 0..<roots.len:
                if roots[i] == contractDir:
                    seen = true
                    break
            if !seen:
                add(roots, contractDir)
    return roots

fn MobileShellCopyRawTreeRec(opts: MobileShellOptions,
                               sourceDir: str,
                               relPrefix: str,
                               targetRootRel: str,
                               files: var str[],
                               outCopiedCount: var int32,
                               outError: var str): bool =
    let names: str[] = os.ListDir(sourceDir)
    for i in 0..<names.len:
        let name: str = names[i]
        if len(name) <= 0:
            continue
        let sourceEntry: str = os.JoinPath(sourceDir, name)
        var nextRelPrefix: str = name
        if len(relPrefix) > 0:
            nextRelPrefix = strutil.Join([relPrefix, "/", name], "")
        if chengpath.PathDirExists(sourceEntry):
            if !MobileShellCopyRawTreeRec(opts,
                                            sourceEntry,
                                            nextRelPrefix,
                                            targetRootRel,
                                            files,
                                            outCopiedCount,
                                            outError):
                return false
        elif chengpath.PathFileExists(sourceEntry):
            let targetRel: str = strutil.Join([targetRootRel, "/", nextRelPrefix], "")
            if !MobileShellCopyRawFile(opts, sourceEntry, targetRel, files, outError):
                return false
            outCopiedCount = outCopiedCount + 1
    return true

fn MobileShellWriteOptionalRuntimeResources(opts: MobileShellOptions,
                                              files: var str[],
                                              outSemanticNodesRel: var str,
                                              outTruthRootRel: var str,
                                              outError: var str): bool =
    outSemanticNodesRel = ""
    outTruthRootRel = ""
    let sourceRoots: str[] = MobileShellSourceRoots(opts)
    for i in 0..<sourceRoots.len:
        let semanticSource: str = os.JoinPath(sourceRoots[i], "r2c_semantic_render_nodes.tsv")
        if len(outSemanticNodesRel) <= 0 && chengpath.PathFileExists(semanticSource):
            outSemanticNodesRel = MobileShellRuntimeSemanticNodesRelPath()
            if !MobileShellCopyRawFile(opts, semanticSource, outSemanticNodesRel, files, outError):
                return false
        let truthSourceRoot: str = os.JoinPath(sourceRoots[i], "truth")
        if len(outTruthRootRel) <= 0 && chengpath.PathDirExists(truthSourceRoot):
            var copiedCount: int32
            if !MobileShellCopyRawTreeRec(opts,
                                            truthSourceRoot,
                                            "",
                                            MobileShellRuntimeTruthRootRelPath(),
                                            files,
                                            copiedCount,
                                            outError):
                return false
            if copiedCount > 0:
                outTruthRootRel = MobileShellRuntimeTruthRootRelPath()
    return true

fn MobileShellMirrorRuntimeFile(opts: MobileShellOptions,
                                  sourceFull: str,
                                  targetRel: str,
                                  files: var str[],
                                  outError: var str): bool =
    if !chengpath.PathFileExists(sourceFull):
        outError = strutil.Join(["mobile-shell: runtime mirror source missing: ", sourceFull], "")
        return false
    let payloadText: str = chengpath.ReadTextFile("", sourceFull)
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteFile(targetFull, payloadText, targetRel, files, outError)

fn MobileShellMirrorRawTree(opts: MobileShellOptions,
                              sourceRoot: str,
                              targetRootRel: str,
                              files: var str[],
                              outError: var str): bool =
    var copiedCount: int32
    return MobileShellCopyRawTreeRec(opts,
                                       sourceRoot,
                                       "",
                                       targetRootRel,
                                       files,
                                       copiedCount,
                                       outError)

fn MobileShellWriteRuntimeStubFile(opts: MobileShellOptions,
                                     targetRel: str,
                                     files: var str[],
                                     outError: var str): bool =
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteFile(targetFull, "{\n}\n", targetRel, files, outError)

fn MobileShellWriteLaunchArgsFiles(opts: MobileShellOptions,
                                     runtimeManifestRel: str,
                                     runtimeContractPayloadRel: str,
                                     runtimeBundlePayloadRel: str,
                                     files: var str[],
                                     outLaunchArgsKvRel: var str,
                                     outLaunchArgsJsonRel: var str,
                                     outError: var str): bool =
    outLaunchArgsKvRel = MobileShellLaunchArgsKvRelPath()
    outLaunchArgsJsonRel = MobileShellLaunchArgsJsonRelPath()
    let kvPath: str = chengpath.PathJoin(opts.outDir, outLaunchArgsKvRel)
    let jsonPath: str = chengpath.PathJoin(opts.outDir, outLaunchArgsJsonRel)
    if !MobileShellWriteFile(kvPath,
                               MobileShellLaunchArgsKvText(opts,
                                                             runtimeManifestRel,
                                                             runtimeContractPayloadRel,
                                                             runtimeBundlePayloadRel),
                               outLaunchArgsKvRel,
                               files,
                               outError):
        return false
    if !MobileShellWriteFile(jsonPath,
                               MobileShellLaunchArgsJsonText(opts,
                                                               runtimeManifestRel,
                                                               runtimeContractPayloadRel,
                                                               runtimeBundlePayloadRel),
                               outLaunchArgsJsonRel,
                               files,
                               outError):
        return false
    return true

fn MobileShellWritePlatformRuntimeMirrors(opts: MobileShellOptions,
                                            runtimeManifestPath: str,
                                            runtimeContractPayloadRel: str,
                                            runtimeBundlePayloadRel: str,
                                            runtimeSemanticNodesRel: str,
                                            runtimeTruthRootRel: str,
                                            launchArgsKvRel: str,
                                            launchArgsJsonRel: str,
                                            files: var str[],
                                            outError: var str): bool =
    if opts.emitAndroid:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellAndroidRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellAndroidRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellAndroidRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellAndroidLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellAndroidLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellAndroidAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellAndroidAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    if opts.emitIos:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellIosRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellIosRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellIosRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellIosRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellIosRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellIosLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellIosLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellIosAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellIosAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    if opts.emitHarmony:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellHarmonyRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellHarmonyLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellHarmonyLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellHarmonyAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellHarmonyAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    return true

