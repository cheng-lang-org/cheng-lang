    text = strutil.Join([text, "        return nil;\n"], "")
    text = strutil.Join([text, "    }\n"], "")
    text = strutil.Join([text, "    return [NSString stringWithContentsOfFile:full encoding:NSUTF8StringEncoding error:nil];\n"], "")
