fn MobileShellIosWorkspaceData(): str =
    return Fmt"""
    <?xml version="1.0" encoding="UTF-8"?>
    <Workspace version="1.0">
       <FileRef location="self:"/>
    </Workspace>

    """

fn MobileShellIosMain(): str =
    return Fmt"""
    #import <UIKit/UIKit.h>
    #import "ChengGeneratedAppDelegate.h"

    int main(int argc, char* argv[]) {{
        @autoreleasepool {{
            return UIApplicationMain(argc, argv, nil, NSStringFromClass([ChengGeneratedAppDelegate class]));
        }}
    }}

    """

fn MobileShellIosAppDelegateHeader(): str =
    return Fmt"""
    #import <UIKit/UIKit.h>

    @interface ChengGeneratedAppDelegate : UIResponder <UIApplicationDelegate>
    @property(nonatomic, strong) UIWindow* window;
    @end

    """

fn MobileShellIosAppDelegateImpl(): str =
    return Fmt"""
    #import "ChengGeneratedAppDelegate.h"
    #import "ChengGeneratedMetalViewController.h"

    @implementation ChengGeneratedAppDelegate

    - (BOOL)application:(UIApplication*)application didFinishLaunchingWithOptions:(NSDictionary*)launchOptions {{
        application = application;
        launchOptions = launchOptions;
        self.window = [[UIWindow alloc] initWithFrame:[UIScreen mainScreen].bounds];
        self.window.rootViewController = [[ChengGeneratedMetalViewController alloc] init];
        [self.window makeKeyAndVisible];
        return YES;
    }}

    @end

    """

fn MobileShellIosViewControllerHeader(): str =
    return Fmt"""
    #import <UIKit/UIKit.h>

    @interface ChengGeneratedMetalViewController : UIViewController
    @end

    """

fn MobileShellIosViewControllerImpl(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "runtime/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    return Fmt"""
    #import "ChengGeneratedMetalViewController.h"
    #import <QuartzCore/CAMetalLayer.h>
    #import <Metal/Metal.h>
    #import <dlfcn.h>

    typedef unsigned long long (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(unsigned long long, unsigned long long, int, int, float);
    typedef void (*cheng_app_tick_fn)(unsigned long long, float);
    typedef void (*cheng_app_on_touch_fn)(unsigned long long, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(unsigned long long);
    typedef void (*cheng_app_resume_fn)(unsigned long long);

    typedef void (*cheng_mobile_host_runtime_set_manifest_payloads_fn)(const char*, const char*, const char*);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengRuntimeContractPayloadRel = "{runtimeContractPayloadRel}";
    static const char* kChengRuntimeBundlePayloadRel = "{runtimeBundlePayloadRel}";
    static const char* kChengLaunchArgsKvRel = "{launchArgsKvRel}";
    static const char* kChengLaunchArgsJsonRel = "{launchArgsJsonRel}";

    static NSString* cheng_load_bundle_text(const char* relPath) {{
        if (relPath == NULL || relPath[0] == '\0') {{
            return nil;
        }}
        NSString* rel = [NSString stringWithUTF8String:relPath];
        NSString* dir = [rel stringByDeletingLastPathComponent];
        NSString* file = [rel lastPathComponent];
        NSString* stem = [file stringByDeletingPathExtension];
        NSString* ext = [file pathExtension];
        NSString* full = [[NSBundle mainBundle] pathForResource:stem ofType:(ext.length > 0 ? ext : nil) inDirectory:(dir.length > 0 ? dir : nil)];
        if (full == nil) {{
            return nil;
        }}
        return [NSString stringWithContentsOfFile:full encoding:NSUTF8StringEncoding error:nil];
    }}

    @interface ChengGeneratedMetalView : UIView
    @property(nonatomic) unsigned long long appId;
    @property(nonatomic, strong) CADisplayLink* displayLink;
    @end

    @implementation ChengGeneratedMetalView {{
        cheng_app_set_window_fn _setWindow;
        cheng_app_tick_fn _tick;
        cheng_app_on_touch_fn _touch;
        cheng_app_pause_fn _pause;
        cheng_app_resume_fn _resume;
    }}

    + (Class)layerClass {{
        return [CAMetalLayer class];
    }}

    - (instancetype)initWithFrame:(CGRect)frame {{
        self = [super initWithFrame:frame];
        if (self == nil) {{
            return nil;
        }}
        CAMetalLayer* layer = (CAMetalLayer*)self.layer;
        layer.device = MTLCreateSystemDefaultDevice();
        layer.pixelFormat = MTLPixelFormatBGRA8Unorm;
        void* handle = dlopen(NULL, RTLD_NOW);
        cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, "cheng_app_init");
        _setWindow = (cheng_app_set_window_fn)dlsym(handle, "cheng_app_set_window");
        _tick = (cheng_app_tick_fn)dlsym(handle, "cheng_app_tick");
        _touch = (cheng_app_on_touch_fn)dlsym(handle, "cheng_app_on_touch");
        _pause = (cheng_app_pause_fn)dlsym(handle, "cheng_app_pause");
        _resume = (cheng_app_resume_fn)dlsym(handle, "cheng_app_resume");
        cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads = (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(handle, "cheng_mobile_host_runtime_set_manifest_payloads");
        cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, "cheng_mobile_host_runtime_set_launch_args");
        if (setRuntimePayloads != NULL) {{
            NSString* runtimeManifest = cheng_load_bundle_text(kChengRuntimeManifest);
            NSString* runtimeContractPayload = cheng_load_bundle_text(kChengRuntimeContractPayloadRel);
            NSString* runtimeBundlePayload = cheng_load_bundle_text(kChengRuntimeBundlePayloadRel);
            setRuntimePayloads(runtimeManifest != nil ? [runtimeManifest UTF8String] : NULL,
                              runtimeContractPayload != nil ? [runtimeContractPayload UTF8String] : NULL,
                              runtimeBundlePayload != nil ? [runtimeBundlePayload UTF8String] : NULL);
        }}
        if (setLaunchArgs != NULL) {{
            NSString* launchArgsKv = cheng_load_bundle_text(kChengLaunchArgsKvRel);
            NSString* launchArgsJson = cheng_load_bundle_text(kChengLaunchArgsJsonRel);
            setLaunchArgs(launchArgsKv != nil ? [launchArgsKv UTF8String] : NULL,
                          launchArgsJson != nil ? [launchArgsJson UTF8String] : NULL);
        }}
        if (initFn != NULL) {{
            self.appId = initFn();
        }}
        self.displayLink = [CADisplayLink displayLinkWithTarget:self selector:@selector(step:)];
        [self.displayLink addToRunLoop:[NSRunLoop mainRunLoop] forMode:NSDefaultRunLoopMode];
        return self;
    }}

    - (void)layoutSubviews {{
        [super layoutSubviews];
        if (_setWindow != NULL) {{
            CGFloat scale = self.window.screen.scale;
            CGSize size = self.bounds.size;
            _setWindow(self.appId, 1ull, (int)(size.width * scale), (int)(size.height * scale), (float)scale);
        }}
    }}

    - (void)step:(CADisplayLink*)displayLink {{
        if (_tick != NULL) {{
            _tick(self.appId, (float)displayLink.duration);
        }}
    }}

    - (void)touchesBegan:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {{
        event = event;
        UITouch* touch = [touches anyObject];
        CGPoint point = [touch locationInView:self];
        if (_touch != NULL) {{
            _touch(self.appId, 0, 0, (float)point.x, (float)point.y);
        }}
    }}

    - (void)touchesMoved:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {{
        event = event;
        UITouch* touch = [touches anyObject];
        CGPoint point = [touch locationInView:self];
        if (_touch != NULL) {{
            _touch(self.appId, 2, 0, (float)point.x, (float)point.y);
        }}
    }}

    - (void)touchesEnded:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {{
        event = event;
        UITouch* touch = [touches anyObject];
        CGPoint point = [touch locationInView:self];
        if (_touch != NULL) {{
            _touch(self.appId, 1, 0, (float)point.x, (float)point.y);
        }}
    }}

    - (void)didMoveToWindow {{
        [super didMoveToWindow];
        if (self.window == nil) {{
            if (_pause != NULL) {{
                _pause(self.appId);
            }}
        }} else {{
            if (_resume != NULL) {{
                _resume(self.appId);
            }}
        }}
    }}

    @end

    @implementation ChengGeneratedMetalViewController

    - (void)loadView {{
        self.view = [[ChengGeneratedMetalView alloc] initWithFrame:[UIScreen mainScreen].bounds];
    }}

    @end

    """

fn MobileShellHarmonyAppJson(opts: var MobileShellOptions): str =
    var app: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(app, "bundleName", opts.appId)
    json.JsonSetFieldStr(app, "vendor", "cheng")
    json.JsonSetFieldInt32(app, "versionCode", 1)
    json.JsonSetFieldStr(app, "versionName", "1.0.0")
    json.JsonSetFieldStr(app, "icon", "$media:app_icon")
    json.JsonSetFieldStr(app, "label", "$string:app_name")
    var root: json.JsonNode = json.NewJObject()
    json.JsonSetField(root, "app", app)
    return MobileShellJsonDocument(root)

fn MobileShellHarmonyModuleJson(opts: var MobileShellOptions): str =
    var deviceTypes: json.JsonNode = json.NewJArray()
    json.JsonAddStr(deviceTypes, "phone")
    json.JsonAddStr(deviceTypes, "tablet")
    var actions: json.JsonNode = json.NewJArray()
    json.JsonAddStr(actions, "ohos.want.action.home")
    var entities: json.JsonNode = json.NewJArray()
    json.JsonAddStr(entities, "entity.system.home")
    var skill: json.JsonNode = json.NewJObject()
    json.JsonSetField(skill, "actions", actions)
    json.JsonSetField(skill, "entities", entities)
    var skills: json.JsonNode = json.NewJArray()
    json.JsonAdd(skills, skill)
    var ability: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(ability, "name", "EntryAbility")
    json.JsonSetFieldStr(ability, "srcEntry", "./ets/entryability/EntryAbility.ets")
    json.JsonSetFieldStr(ability, "description", opts.appName)
    json.JsonSetFieldStr(ability, "label", "$string:app_name")
    json.JsonSetFieldStr(ability, "startWindowIcon", "$media:app_icon")
    json.JsonSetFieldStr(ability, "startWindowBackground", "$color:start_window_background")
    json.JsonSetFieldBool(ability, "exported", true)
    json.JsonSetField(ability, "skills", skills)
    var abilities: json.JsonNode = json.NewJArray()
    json.JsonAdd(abilities, ability)
    var moduleDoc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(moduleDoc, "name", "entry")
    json.JsonSetFieldStr(moduleDoc, "type", "entry")
    json.JsonSetFieldBool(moduleDoc, "deliveryWithInstall", true)
    json.JsonSetFieldStr(moduleDoc, "description", opts.appName)
    json.JsonSetFieldStr(moduleDoc, "mainElement", "EntryAbility")
    json.JsonSetField(moduleDoc, "deviceTypes", deviceTypes)
    json.JsonSetFieldStr(moduleDoc, "pages", "$profile:main_pages")
    json.JsonSetField(moduleDoc, "abilities", abilities)
    var root: json.JsonNode = json.NewJObject()
    json.JsonSetField(root, "module", moduleDoc)
    return MobileShellJsonDocument(root)

