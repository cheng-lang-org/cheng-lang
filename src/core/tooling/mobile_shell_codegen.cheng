fn MobileShellAndroidAppBuildGradle(opts: var MobileShellOptions): str =
    return Fmt"""
    plugins {{
        id("com.android.application")
        id("org.jetbrains.kotlin.android")
    }}

    android {{
        namespace = {MobileShellQuote(opts.appId)}
        compileSdk = 34

        defaultConfig {{
            applicationId = {MobileShellQuote(opts.appId)}
            minSdk = 28
            targetSdk = 34
            versionCode = 1
            versionName = {MobileShellQuote("1.0")}
            externalNativeBuild {{
                cmake {{
                    cppFlags += {MobileShellQuote("-std=c17")}
                }}
            }}
        }}

        buildTypes {{
            release {{
                isMinifyEnabled = false
                proguardFiles(
                    getDefaultProguardFile("proguard-android-optimize.txt"),
                    "proguard-rules.pro"
                )
            }}
        }}

        externalNativeBuild {{
            cmake {{
                path = file("src/main/cpp/CMakeLists.txt")
            }}
        }}

        buildFeatures {{
            prefab = false
        }}
        compileOptions {{
            sourceCompatibility = JavaVersion.VERSION_17
            targetCompatibility = JavaVersion.VERSION_17
        }}
        kotlinOptions {{
            jvmTarget = {MobileShellQuote("17")}
        }}
    }}

    dependencies {{
        implementation({MobileShellQuote("androidx.core:core-ktx:1.13.1")})
    }}

    """

fn MobileShellAndroidManifest(opts: var MobileShellOptions): str =
    opts = opts
    return Fmt"""
    <?xml version="1.0" encoding="utf-8"?>
    <manifest xmlns:android="http://schemas.android.com/apk/res/android">
        <application
            android:allowBackup="false"
            android:label="@string/app_name">
            <activity
                android:name=".ChengMainActivity"
                android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
                android:exported="true"
                android:launchMode="singleTask"
                android:screenOrientation="portrait">
                <intent-filter>
                    <action android:name="android.intent.action.MAIN" />
                    <category android:name="android.intent.category.LAUNCHER" />
                </intent-filter>
            </activity>
        </application>
    </manifest>

    """

