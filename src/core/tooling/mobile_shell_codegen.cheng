    text = strutil.Join([text, "    cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads = (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_manifest_payloads\");\n"], "")
    text = strutil.Join([text, "    cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"], "")
