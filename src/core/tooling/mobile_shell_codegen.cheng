fn MobileShellIosInfoPlist(opts: var MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    text = strutil.Join([text, "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"], "")
