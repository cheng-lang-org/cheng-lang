        return false
    if !MobileShellWriteIosAppDelegateHeaderFile(opts, files, outError):
        return false
    if !MobileShellWriteIosAppDelegateImplFile(opts, files, outError):
        return false
    if !MobileShellWriteIosViewControllerHeaderFile(opts, files, outError):
        return false
    if !MobileShellWriteIosViewControllerImplFile(opts, files, outError):
        return false
    if !MobileShellWriteIosProjectFile(opts, files, outError):
        return false
    return MobileShellWriteIosWorkspaceFile(opts, files, outError)

