    text = strutil.Join([text, "    <key>CFBundleExecutable</key>\n"], "")
    text = strutil.Join([text, "    <string>$(EXECUTABLE_NAME)</string>\n"], "")
    text = strutil.Join([text, "    <key>CFBundleIdentifier</key>\n"], "")
    text = strutil.Join([text, "    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>\n"], "")
    text = strutil.Join([text, "    <key>CFBundleDisplayName</key>\n"], "")
    text = strutil.Join([text, "    <string>", opts.appName, "</string>\n"], "")
    text = strutil.Join([text, "    <key>CFBundleName</key>\n"], "")
    text = strutil.Join([text, "    <string>$(PRODUCT_NAME)</string>\n"], "")
    text = strutil.Join([text, "    <key>CFBundlePackageType</key>\n"], "")
    text = strutil.Join([text, "    <string>APPL</string>\n"], "")
    text = strutil.Join([text, "    <key>LSRequiresIPhoneOS</key>\n"], "")
    text = strutil.Join([text, "    <true/>\n"], "")
    text = strutil.Join([text, "    <key>UIApplicationSceneManifest</key>\n"], "")
    text = strutil.Join([text, "    <dict/>\n"], "")
    text = strutil.Join([text, "    <key>UILaunchStoryboardName</key>\n"], "")
    text = strutil.Join([text, "    <string></string>\n"], "")
    text = strutil.Join([text, "</dict>\n"], "")
    text = strutil.Join([text, "</plist>\n"], "")
    return text

