fn MobileShellHarmonyCmake(): str =
    return Fmt"""
    cmake_minimum_required(VERSION 3.5.0)
    project(cheng_generated_harmony_host)

    add_library(cheng_generated_harmony_host SHARED cheng_generated_harmony_host.cpp)
    target_link_libraries(cheng_generated_harmony_host PUBLIC ace_napi.z ace_ndk.z hilog_ndk.z native_window rawfile.z)

    """

fn MobileShellHarmonyHostSource(opts: var MobileShellOptions): str =
    let runtimeManifestRel: str = "rawfile/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "rawfile/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "rawfile/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKvRel: str = "rawfile/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "rawfile/mobile_shell_launch_args.json"
    let dot: str = strings.CharToStr('.')
    return Fmt"""
    #include <ace/xcomponent/native_interface_xcomponent.h>
    #include <hilog/log.h>
    #include <native_window/external_window.h>
    #include <napi/native_api.h>
    #include <rawfile/raw_file.h>
    #include <rawfile/raw_file_manager.h>
    #include <dlfcn.h>
    #include <stdint.h>
    #include <stdlib.h>

    #include <string.h>

    typedef uint64_t (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);
    typedef void (*cheng_app_tick_fn)(uint64_t, float);
    typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(uint64_t);
    typedef void (*cheng_app_resume_fn)(uint64_t);

    typedef void (*cheng_mobile_host_runtime_set_manifest_payloads_fn)(const char*, const char*, const char*);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    typedef struct ChengHarmonyRuntime {{
      uint64_t app_id;
      OHNativeWindow* window;
      int width;
      int height;
    }} ChengHarmonyRuntime;

    static ChengHarmonyRuntime s_runtime = {{0}};
    static cheng_app_set_window_fn s_set_window = NULL;
    static cheng_app_tick_fn s_tick = NULL;
    static cheng_app_on_touch_fn s_touch = NULL;
    static cheng_app_pause_fn s_pause = NULL;
    static cheng_app_resume_fn s_resume = NULL;

    static NativeResourceManager* s_resource_manager = NULL;
    static int s_runtime_payloads_applied = 0;
    static int s_launch_args_applied = 0;

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengRuntimeContractPayloadRel = "{runtimeContractPayloadRel}";
    static const char* kChengRuntimeBundlePayloadRel = "{runtimeBundlePayloadRel}";
    static const char* kChengLaunchArgsKvRel = "{launchArgsKvRel}";
    static const char* kChengLaunchArgsJsonRel = "{launchArgsJsonRel}";

    static const char* cheng_harmony_rawfile_path(const char* relPath) {{
      static const char* prefix = "rawfile/";
      if (relPath == NULL) {{
        return NULL;
      }}
      if (strncmp(relPath, prefix, 8u) == 0) {{
        return relPath + 8u;
      }}
      return relPath;
    }}

    static char* cheng_harmony_read_raw_text(const char* relPath) {{
      if (s_resource_manager == NULL || relPath == NULL || relPath[0] == '\0') {{
        return NULL;
      }}
      const char* rawPath = cheng_harmony_rawfile_path(relPath);
      RawFile* rawFile = OH_ResourceManager_OpenRawFile(s_resource_manager, rawPath);
      if (rawFile == NULL) {{
        return NULL;
      }}
      long rawSize = OH_ResourceManager_GetRawFileSize(rawFile);
      if (rawSize < 0) {{
        OH_ResourceManager_CloseRawFile(rawFile);
        return NULL;
      }}
      size_t size = (size_t)rawSize;
      char* textBuf = (char*)calloc(size + 1u, 1u);
      if (textBuf == NULL) {{
        OH_ResourceManager_CloseRawFile(rawFile);
        return NULL;
      }}
      if (size > 0u) {{
        int readLen = OH_ResourceManager_ReadRawFile(rawFile, textBuf, size);
        if (readLen < 0) {{
          free(textBuf);
          OH_ResourceManager_CloseRawFile(rawFile);
          return NULL;
        }}
        if ((size_t)readLen < size) {{
          textBuf[(size_t)readLen] = '\0';
        }} else {{
          textBuf[size] = '\0';
        }}
      }}
      OH_ResourceManager_CloseRawFile(rawFile);
      return textBuf;
    }}

    static void cheng_harmony_apply_runtime_payloads(void* handle) {{
      if (s_runtime_payloads_applied != 0 || handle == NULL || s_resource_manager == NULL) {{
        return;
      }}
      cheng_mobile_host_runtime_set_manifest_payloads_fn setRuntimePayloads =
          (cheng_mobile_host_runtime_set_manifest_payloads_fn)dlsym(handle, "cheng_mobile_host_runtime_set_manifest_payloads");
      if (setRuntimePayloads == NULL) {{
        return;
      }}
      char* manifestJson = cheng_harmony_read_raw_text(kChengRuntimeManifest);
      char* contractPayloadJson = cheng_harmony_read_raw_text(kChengRuntimeContractPayloadRel);
      char* bundlePayloadJson = cheng_harmony_read_raw_text(kChengRuntimeBundlePayloadRel);
      setRuntimePayloads(manifestJson, contractPayloadJson, bundlePayloadJson);
      if (manifestJson != NULL) {{
        free(manifestJson);
      }}
      if (contractPayloadJson != NULL) {{
        free(contractPayloadJson);
      }}
      if (bundlePayloadJson != NULL) {{
        free(bundlePayloadJson);
      }}
      s_runtime_payloads_applied = 1;
    }}

    static void cheng_harmony_apply_launch_args(void* handle) {{
      if (s_launch_args_applied != 0 || handle == NULL || s_resource_manager == NULL) {{
        return;
      }}
      cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs =
          (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, "cheng_mobile_host_runtime_set_launch_args");
      if (setLaunchArgs == NULL) {{
        return;
      }}
      char* argsKv = cheng_harmony_read_raw_text(kChengLaunchArgsKvRel);
      char* argsJson = cheng_harmony_read_raw_text(kChengLaunchArgsJsonRel);
      setLaunchArgs(argsKv, argsJson);
      if (argsKv != NULL) {{
        free(argsKv);
      }}
      if (argsJson != NULL) {{
        free(argsJson);
      }}
      s_launch_args_applied = 1;
    }}

    static int cheng_harmony_init_runtime(void) {{
      if (s_runtime.app_id != 0u) {{
        return 1;
      }}
      if (s_resource_manager == NULL) {{
        return 0;
      }}
      void* handle = dlopen(NULL, RTLD_NOW);
      if (handle == NULL) {{
        return 0;
      }}
      cheng_harmony_apply_runtime_payloads(handle);
      cheng_harmony_apply_launch_args(handle);
      cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, "cheng_app_init");
      s_set_window = (cheng_app_set_window_fn)dlsym(handle, "cheng_app_set_window");
      s_tick = (cheng_app_tick_fn)dlsym(handle, "cheng_app_tick");
      s_touch = (cheng_app_on_touch_fn)dlsym(handle, "cheng_app_on_touch");
      s_pause = (cheng_app_pause_fn)dlsym(handle, "cheng_app_pause");
      s_resume = (cheng_app_resume_fn)dlsym(handle, "cheng_app_resume");
      if (initFn == NULL || s_set_window == NULL || s_tick == NULL || s_touch == NULL || s_pause == NULL || s_resume == NULL) {{
        return 0;
      }}
      s_runtime.app_id = initFn();
      return 1;
    }}

    static napi_value ChengSetResourceManager(napi_env env, napi_callback_info info) {{
      size_t argc = 1u;
      napi_value argv[1] = {{0}};
      (void)napi_get_cb_info(env, info, &argc, argv, NULL, NULL);
      if (argc >= 1u) {{
        if (s_resource_manager != NULL) {{
          OH_ResourceManager_ReleaseNativeResourceManager(s_resource_manager);
          s_resource_manager = NULL;
          s_runtime_payloads_applied = 0;
          s_launch_args_applied = 0;
        }}
        s_resource_manager = OH_ResourceManager_InitNativeResourceManager(env, argv[0]);
        if (s_resource_manager != NULL) {{
          (void)cheng_harmony_init_runtime();
        }}
      }}
      napi_value result = NULL;
      (void)napi_get_undefined(env, &result);
      return result;
    }}

    static napi_value ChengHarmonyHostNapiInit(napi_env env, napi_value exports) {{
      napi_property_descriptor props[1] = {{
          {{"setResourceManager", NULL, ChengSetResourceManager, NULL, NULL, NULL, napi_default, NULL}},
      }};
      (void)napi_define_properties(env, exports, 1u, props);
      return exports;
    }}

    static napi_module s_cheng_harmony_host_module = {{0}};

    extern "C" __attribute__((constructor)) void ChengHarmonyHostRegisterModule(void) {{
      s_cheng_harmony_host_module.nm_version = 1;
      s_cheng_harmony_host_module.nm_flags = 0;
      s_cheng_harmony_host_module.nm_filename = NULL;
      s_cheng_harmony_host_module.nm_register_func = ChengHarmonyHostNapiInit;
      s_cheng_harmony_host_module.nm_modname = "cheng_generated_harmony_host";
      s_cheng_harmony_host_module.nm_priv = NULL;
      napi_module_register(&s_cheng_harmony_host_module);
    }}

    static void OnSurfaceCreated(OH_NativeXComponent* component, void* window) {{
      component = component;
      if (!cheng_harmony_init_runtime()) {{
        return;
      }}
      s_runtime.window = (OHNativeWindow*)window;
      s_runtime.width = 1080;
      s_runtime.height = 1920;
      s_set_window(s_runtime.app_id, 1u, s_runtime.width, s_runtime.height, 1.0f);
    }}

    static void OnSurfaceDestroyed(OH_NativeXComponent* component, void* window) {{
      component = component;
      window = window;
      if (s_runtime.app_id != 0u && s_pause != NULL) {{
        s_pause(s_runtime.app_id);
      }}
    }}

    static void OnDispatchTouchEvent(OH_NativeXComponent* component, void* window) {{
      component = component;
      window = window;
      if (s_runtime.app_id != 0u && s_touch != NULL) {{
        s_touch(s_runtime.app_id, 0, 0, 0.0f, 0.0f);
      }}
    }}

    static OH_NativeXComponent_Callback s_callback = {{
      {dot}OnSurfaceCreated = OnSurfaceCreated,
      {dot}OnSurfaceChanged = NULL,
      {dot}OnSurfaceDestroyed = OnSurfaceDestroyed,
      {dot}DispatchTouchEvent = OnDispatchTouchEvent,
    }};

    extern "C" __attribute__((visibility("default"))) void OH_NativeXComponent_OnLoad(OH_NativeXComponent* component, void* reserved) {{
      reserved = reserved;
      OH_NativeXComponent_RegisterCallback(component, &s_callback);
    }}

    """

fn MobileShellWriteRuntimePayloadFile(opts: MobileShellOptions,
                                        sourcePath: str,
                                        fallbackBaseName: str,
                                        files: var str[],
                                        outRelPath: var str,
                                        outError: var str): bool =
    outRelPath = ""
    let sourceAbs: str = chengpath.PathAbsolute(opts.rootDir, sourcePath)
    if len(sourceAbs) <= 0:
        return true
    if !chengpath.PathFileExists(sourceAbs):
        outError = Fmt"mobile-shell: runtime payload missing: {sourceAbs}"
        return false
    var relPath: str = MobileShellRuntimeBundlePayloadRelPath()
    if fallbackBaseName == "runtime_contract_payload.json":
        relPath = MobileShellRuntimeContractPayloadRelPath()
    let targetPath: str = chengpath.PathJoin(opts.outDir, relPath)
    let payloadText: str = chengpath.ReadTextFile("", sourceAbs)
    if !MobileShellWriteFile(targetPath, payloadText, relPath, files, outError):
        return false
    outRelPath = relPath
    return true

fn MobileShellWriteRawFile(fullPath: str,
                             payload: str,
                             relPath: str,
                             files: var str[],
                             outError: var str): bool =
    let parent: str = chengpath.PathParentDir(fullPath)
    if len(parent) > 0 && !chengpath.MkdirP("", parent):
        outError = Fmt"mobile-shell: failed to create dir: {parent}"
        return false
    os.WriteFile(fullPath, payload)
    if !chengpath.PathFileExists(fullPath):
        outError = Fmt"mobile-shell: write failed: {fullPath}"
        return false
    add(files, relPath)
    return true

fn MobileShellCopyRawFile(opts: MobileShellOptions,
                            sourceFull: str,
                            targetRel: str,
                            files: var str[],
    outError: var str): bool =
    if !chengpath.PathFileExists(sourceFull):
        outError = Fmt"mobile-shell: runtime mirror source missing: {sourceFull}"
        return false
    let payloadText: str = os.ReadFile(sourceFull)
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteRawFile(targetFull, payloadText, targetRel, files, outError)

fn MobileShellSourceRoots(opts: MobileShellOptions): str[] =
    var roots: str[]
    let bundleSourceAbs: str = chengpath.PathAbsolute(opts.rootDir, opts.runtimeBundlePath)
    let contractSourceAbs: str = chengpath.PathAbsolute(opts.rootDir, opts.runtimeContractPath)
    if len(bundleSourceAbs) > 0:
        let bundleDir: str = chengpath.PathParentDir(bundleSourceAbs)
        if len(bundleDir) > 0:
            add(roots, bundleDir)
    if len(contractSourceAbs) > 0:
        let contractDir: str = chengpath.PathParentDir(contractSourceAbs)
        if len(contractDir) > 0:
            var seen: bool
            for i in 0..<roots.len:
                if roots[i] == contractDir:
                    seen = true
                    break
            if !seen:
                add(roots, contractDir)
    return roots

fn MobileShellCopyRawTreeRec(opts: MobileShellOptions,
                               sourceDir: str,
                               relPrefix: str,
                               targetRootRel: str,
                               files: var str[],
                               outCopiedCount: var int32,
                               outError: var str): bool =
    let names: str[] = os.ListDir(sourceDir)
    for i in 0..<names.len:
        let name: str = names[i]
        if len(name) <= 0:
            continue
        let sourceEntry: str = os.JoinPath(sourceDir, name)
        var nextRelPrefix: str = name
        if len(relPrefix) > 0:
            nextRelPrefix = Fmt"{relPrefix}/{name}"
        if chengpath.PathDirExists(sourceEntry):
            if !MobileShellCopyRawTreeRec(opts,
                                            sourceEntry,
                                            nextRelPrefix,
                                            targetRootRel,
                                            files,
                                            outCopiedCount,
                                            outError):
                return false
        elif chengpath.PathFileExists(sourceEntry):
            let targetRel: str = Fmt"{targetRootRel}/{nextRelPrefix}"
            if !MobileShellCopyRawFile(opts, sourceEntry, targetRel, files, outError):
                return false
            outCopiedCount = outCopiedCount + 1
    return true

fn MobileShellWriteOptionalRuntimeResources(opts: MobileShellOptions,
                                              files: var str[],
                                              outSemanticNodesRel: var str,
                                              outTruthRootRel: var str,
                                              outError: var str): bool =
    outSemanticNodesRel = ""
    outTruthRootRel = ""
    let sourceRoots: str[] = MobileShellSourceRoots(opts)
    for i in 0..<sourceRoots.len:
        let semanticSource: str = os.JoinPath(sourceRoots[i], "r2c_semantic_render_nodes.tsv")
        if len(outSemanticNodesRel) <= 0 && chengpath.PathFileExists(semanticSource):
            outSemanticNodesRel = MobileShellRuntimeSemanticNodesRelPath()
            if !MobileShellCopyRawFile(opts, semanticSource, outSemanticNodesRel, files, outError):
                return false
        let truthSourceRoot: str = os.JoinPath(sourceRoots[i], "truth")
        if len(outTruthRootRel) <= 0 && chengpath.PathDirExists(truthSourceRoot):
            var copiedCount: int32
            if !MobileShellCopyRawTreeRec(opts,
                                            truthSourceRoot,
                                            "",
                                            MobileShellRuntimeTruthRootRelPath(),
                                            files,
                                            copiedCount,
                                            outError):
                return false
            if copiedCount > 0:
                outTruthRootRel = MobileShellRuntimeTruthRootRelPath()
    return true

fn MobileShellMirrorRuntimeFile(opts: MobileShellOptions,
                                  sourceFull: str,
                                  targetRel: str,
                                  files: var str[],
    outError: var str): bool =
    if !chengpath.PathFileExists(sourceFull):
        outError = Fmt"mobile-shell: runtime mirror source missing: {sourceFull}"
        return false
    let payloadText: str = chengpath.ReadTextFile("", sourceFull)
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteFile(targetFull, payloadText, targetRel, files, outError)

fn MobileShellMirrorRawTree(opts: MobileShellOptions,
                              sourceRoot: str,
                              targetRootRel: str,
                              files: var str[],
                              outError: var str): bool =
    var copiedCount: int32
    return MobileShellCopyRawTreeRec(opts,
                                       sourceRoot,
                                       "",
                                       targetRootRel,
                                       files,
                                       copiedCount,
                                       outError)

fn MobileShellWriteRuntimeStubFile(opts: MobileShellOptions,
                                     targetRel: str,
                                     files: var str[],
                                     outError: var str): bool =
    let targetFull: str = chengpath.PathJoin(opts.outDir, targetRel)
    return MobileShellWriteFile(targetFull, "{\n}\n", targetRel, files, outError)

fn MobileShellWriteLaunchArgsFiles(opts: MobileShellOptions,
                                     runtimeManifestRel: str,
                                     runtimeContractPayloadRel: str,
                                     runtimeBundlePayloadRel: str,
                                     files: var str[],
                                     outLaunchArgsKvRel: var str,
                                     outLaunchArgsJsonRel: var str,
                                     outError: var str): bool =
    outLaunchArgsKvRel = MobileShellLaunchArgsKvRelPath()
    outLaunchArgsJsonRel = MobileShellLaunchArgsJsonRelPath()
    let kvPath: str = chengpath.PathJoin(opts.outDir, outLaunchArgsKvRel)
    let jsonPath: str = chengpath.PathJoin(opts.outDir, outLaunchArgsJsonRel)
    if !MobileShellWriteFile(kvPath,
                               MobileShellLaunchArgsKvText(opts,
                                                             runtimeManifestRel,
                                                             runtimeContractPayloadRel,
                                                             runtimeBundlePayloadRel),
                               outLaunchArgsKvRel,
                               files,
                               outError):
        return false
    if !MobileShellWriteFile(jsonPath,
                               MobileShellLaunchArgsJsonText(opts,
                                                               runtimeManifestRel,
                                                               runtimeContractPayloadRel,
                                                               runtimeBundlePayloadRel),
                               outLaunchArgsJsonRel,
                               files,
                               outError):
        return false
    return true

fn MobileShellWritePlatformRuntimeMirrors(opts: MobileShellOptions,
                                            runtimeManifestPath: str,
                                            runtimeContractPayloadRel: str,
                                            runtimeBundlePayloadRel: str,
                                            runtimeSemanticNodesRel: str,
                                            runtimeTruthRootRel: str,
                                            launchArgsKvRel: str,
                                            launchArgsJsonRel: str,
                                            files: var str[],
                                            outError: var str): bool =
    if opts.emitAndroid:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellAndroidRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellAndroidRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellAndroidRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellAndroidLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellAndroidLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellAndroidAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellAndroidAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    if opts.emitIos:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellIosRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellIosRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellIosRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellIosRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellIosRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellIosLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellIosLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellIosAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellIosAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    if opts.emitHarmony:
        if !MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           MobileShellHarmonyRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !MobileShellMirrorRuntimeFile(opts,
                                               chengpath.PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !MobileShellWriteRuntimeStubFile(opts,
                                                  MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsKvRel),
                                           MobileShellHarmonyLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !MobileShellMirrorRuntimeFile(opts,
                                           chengpath.PathJoin(opts.outDir, launchArgsJsonRel),
                                           MobileShellHarmonyLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeSemanticNodesRel) > 0:
            if !MobileShellCopyRawFile(opts,
                                         chengpath.PathJoin(opts.outDir, runtimeSemanticNodesRel),
                                         MobileShellHarmonyAssetMirrorRelPath(runtimeSemanticNodesRel),
                                         files,
                                         outError):
                return false
        if len(runtimeTruthRootRel) > 0:
            let truthSourceRoot: str = chengpath.PathJoin(opts.outDir, runtimeTruthRootRel)
            if !MobileShellMirrorRawTree(opts,
                                           truthSourceRoot,
                                           MobileShellHarmonyAssetMirrorRelPath(runtimeTruthRootRel),
                                           files,
                                           outError):
                return false
    return true

fn MobileShellWriteAndroidSettingsFile(opts: var MobileShellOptions,
