fn MobileShellHelpText(): str =
    return Fmt"""
    usage: cheng mobile-shell <subcommand> [args]
    subcommands: help, export, build-probe
    export flags: [--platform android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]
    build-probe flags: [--platform none|android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]

    """

fn MobileShellResolvePlatforms(platformText: str,
                                 out: var str[]): bool =
    out = []
    let raw: str = strutil.Strip(platformText)
    let normalized: str = if len(raw) > 0: raw else: "all"
    if normalized == "all":
        add(out, "android")
        add(out, "ios")
        add(out, "harmony")
        return true
    if normalized == "none":
        return true
    if normalized == "android":
        add(out, normalized)
        return true
    if normalized == "ios":
        add(out, normalized)
        return true
    if normalized == "harmony":
        add(out, normalized)
        return true
    return false

fn MobileShellWriteFile(fullPath: str,
                          text: str,
                          relPath: str,
                          files: var str[],
                          outError: var str): bool =
    var payload: str = text
    var needsNewline: bool
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = Fmt"{payload}\n"
    if !chengpath.WriteTextFile("", fullPath, payload):
        outError = Fmt"mobile-shell: write failed: {fullPath}"
        return false
    add(files, relPath)
    return true

fn MobileShellWriteRelativeFile(rootDir: str,
                                  relPath: str,
                                  text: str,
                                  files: var str[],
                                  outError: var str): bool =
    var payload: str = text
    var needsNewline: bool
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = Fmt"{payload}\n"
    if !chengpath.WriteTextFile(rootDir, relPath, payload):
        let fullPath: str = chengpath.PathJoin(rootDir, relPath)
        outError = Fmt"mobile-shell: write failed: {fullPath}"
        return false
    add(files, relPath)
    return true

fn MobileShellReadme(opts: MobileShellOptions,
                       runtimeManifestRel: str,
                       runtimeContractPayloadRel: str,
                       runtimeBundlePayloadRel: str,
                       runtimeSemanticNodesRel: str,
                       runtimeTruthRootRel: str,
                       launchArgsKvRel: str,
                       launchArgsJsonRel: str): str =
    return Fmt"""
    # Cheng Mobile Shell Export

    This bundle is emitted by `cheng mobile-shell export`.

    App contract:
    - The Cheng app binary exports `cheng_app_init`, `cheng_app_set_window`, `cheng_app_tick`, `cheng_app_on_touch`, `cheng_app_pause`, `cheng_app_resume`.
    - The generated native shell is responsible for platform lifecycle, window creation, and input forwarding.
    - The shell is generated by Cheng; platform source still targets Android NDK, UIKit/Metal, and Harmony XComponent APIs.

    app_id={opts.appId}
    app_name={opts.appName}
    lib_name={opts.libName}
    runtime_mode={opts.runtimeMode}
    runtime_manifest={runtimeManifestRel}
    runtime_contract_payload={runtimeContractPayloadRel}
    runtime_bundle_payload={runtimeBundlePayloadRel}
    semantic_nodes_path={runtimeSemanticNodesRel}
    truth_root_path={runtimeTruthRootRel}
    launch_args_kv={launchArgsKvRel}
    launch_args_json={launchArgsJsonRel}
    initial_route_state={opts.routeState}

    """

fn MobileShellManifest(opts: MobileShellOptions,
                         runtimeManifestRel: str,
                         runtimeContractPayloadRel: str,
                         runtimeBundlePayloadRel: str,
                         runtimeSemanticNodesRel: str,
                         runtimeTruthRootRel: str,
                         launchArgsKvRel: str,
                         launchArgsJsonRel: str,
                         files: var str[]): str =
    var doc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(doc, "format", "mobile_shell_manifest_v1")
    json.JsonSetFieldStr(doc, "generator", "cheng.cheng.mobile_shell_codegen")
    json.JsonSetFieldStr(doc, "workspace_root", opts.rootDir)
    json.JsonSetFieldStr(doc, "out_dir", opts.outDir)
    json.JsonSetFieldStr(doc, "app_id", opts.appId)
    json.JsonSetFieldStr(doc, "app_name", opts.appName)
    json.JsonSetFieldStr(doc, "lib_name", opts.libName)
    json.JsonSetFieldStr(doc, "runtime_mode", opts.runtimeMode)
    json.JsonSetFieldStr(doc, "runtime_manifest", runtimeManifestRel)
    json.JsonSetFieldStr(doc, "runtime_contract_payload", runtimeContractPayloadRel)
    json.JsonSetFieldStr(doc, "runtime_bundle_payload", runtimeBundlePayloadRel)
    json.JsonSetFieldStr(doc, "semantic_nodes_path", runtimeSemanticNodesRel)
    json.JsonSetFieldStr(doc, "truth_root_path", runtimeTruthRootRel)
    json.JsonSetFieldStr(doc, "launch_args_kv", launchArgsKvRel)
    json.JsonSetFieldStr(doc, "launch_args_json", launchArgsJsonRel)
    json.JsonSetFieldStr(doc, "initial_route_state", opts.routeState)
    json.JsonSetField(doc, "app_exports", MobileShellJsonAppExports())
    json.JsonSetField(doc, "platforms", MobileShellJsonPlatforms(opts))
    json.JsonSetField(doc, "generated_files", MobileShellJsonStringArray(files))
    return MobileShellJsonDocument(doc)

fn MobileShellRuntimeManifest(opts: MobileShellOptions,
                                runtimeContractPayloadRel: str,
                                runtimeBundlePayloadRel: str,
                                runtimeSemanticNodesRel: str,
                                runtimeTruthRootRel: str,
                                launchArgsKvRel: str,
                                launchArgsJsonRel: str): str =
    var doc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(doc, "format", "mobile_shell_runtime_contract_v1")
    json.JsonSetFieldStr(doc, "runtime_mode", opts.runtimeMode)
    json.JsonSetFieldStr(doc, "runtime_contract_payload", runtimeContractPayloadRel)
    json.JsonSetFieldStr(doc, "runtime_bundle_payload", runtimeBundlePayloadRel)
    json.JsonSetFieldStr(doc, "semantic_nodes_path", runtimeSemanticNodesRel)
    json.JsonSetFieldStr(doc, "truth_root_path", runtimeTruthRootRel)
    json.JsonSetFieldStr(doc, "launch_args_kv", launchArgsKvRel)
    json.JsonSetFieldStr(doc, "launch_args_json", launchArgsJsonRel)
    json.JsonSetFieldStr(doc, "initial_route_state", opts.routeState)
    json.JsonSetField(doc, "app_exports", MobileShellJsonAppExports())
    return MobileShellJsonDocument(doc)

fn MobileShellLaunchArgsKvText(opts: MobileShellOptions,
                                 runtimeManifestRel: str,
                                 runtimeContractPayloadRel: str,
                                 runtimeBundlePayloadRel: str): str =
    return Fmt"""
    gate_mode=android-semantic-visual-1to1
    truth_mode=strict
    route_state={opts.routeState}
    route_lock=1
    runtime_mode={opts.runtimeMode}
    runtime_manifest={runtimeManifestRel}
    runtime_contract_payload={runtimeContractPayloadRel}
    runtime_bundle_payload={runtimeBundlePayloadRel}

    """

fn MobileShellLaunchArgsJsonText(opts: MobileShellOptions,
                                   runtimeManifestRel: str,
                                   runtimeContractPayloadRel: str,
                                   runtimeBundlePayloadRel: str): str =
    var doc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(doc, "format", "mobile_shell_launch_args_v1")
    json.JsonSetFieldStr(doc, "gate_mode", "android-semantic-visual-1to1")
    json.JsonSetFieldStr(doc, "truth_mode", "strict")
    json.JsonSetFieldStr(doc, "route_state", opts.routeState)
    json.JsonSetFieldBool(doc, "route_lock", true)
    json.JsonSetFieldStr(doc, "runtime_mode", opts.runtimeMode)
    json.JsonSetFieldStr(doc, "runtime_manifest", runtimeManifestRel)
    json.JsonSetFieldStr(doc, "runtime_contract_payload", runtimeContractPayloadRel)
    json.JsonSetFieldStr(doc, "runtime_bundle_payload", runtimeBundlePayloadRel)
    return MobileShellJsonDocument(doc)

