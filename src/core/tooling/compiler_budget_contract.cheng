import std/strutils as strutil
import std/strings

type
    CompilerBudgetThreshold =
        maxCompileTimeMs: int64
        maxCompilePeakRssBytes: int64
        maxOutputFileSizeBytes: int64

    CompilerBudgetSample =
        label: str
        compileTimeMs: int64
        compilePeakRssBytes: int64
        outputFileSizeBytes: int64

fn CompilerBudgetThresholdNew(maxCompileTimeMs: int64,
                               maxCompilePeakRssBytes: int64,
                               maxOutputFileSizeBytes: int64): CompilerBudgetThreshold =
    return CompilerBudgetThreshold(maxCompileTimeMs: maxCompileTimeMs,
                                   maxCompilePeakRssBytes: maxCompilePeakRssBytes,
                                   maxOutputFileSizeBytes: maxOutputFileSizeBytes)

fn CompilerBudgetSampleNew(label: str,
                            compileTimeMs: int64,
                            compilePeakRssBytes: int64,
                            outputFileSizeBytes: int64): CompilerBudgetSample =
    return CompilerBudgetSample(label: label,
                                compileTimeMs: compileTimeMs,
                                compilePeakRssBytes: compilePeakRssBytes,
                                outputFileSizeBytes: outputFileSizeBytes)

fn CompilerBudgetLightSmokeThreshold(): CompilerBudgetThreshold =
    return CompilerBudgetThresholdNew(int64(5000),
                                      int64(134217728),
                                      int64(32768))

fn CompilerBudgetBackendDriverTargetThreshold(): CompilerBudgetThreshold =
    return CompilerBudgetThresholdNew(int64(1500),
                                      int64(268435456),
                                      int64(1572864))

fn CompilerBudgetCompileTimeOk(sample: CompilerBudgetSample,
                                threshold: CompilerBudgetThreshold): bool =
    if threshold.maxCompileTimeMs <= int64(0):
        return true
    return sample.compileTimeMs >= int64(0) &&
           sample.compileTimeMs <= threshold.maxCompileTimeMs

fn CompilerBudgetCompilePeakRssOk(sample: CompilerBudgetSample,
                                   threshold: CompilerBudgetThreshold): bool =
    if threshold.maxCompilePeakRssBytes <= int64(0):
        return true
    return sample.compilePeakRssBytes >= int64(0) &&
           sample.compilePeakRssBytes <= threshold.maxCompilePeakRssBytes

fn CompilerBudgetOutputFileSizeOk(sample: CompilerBudgetSample,
                                   threshold: CompilerBudgetThreshold): bool =
    if threshold.maxOutputFileSizeBytes <= int64(0):
        return true
    return sample.outputFileSizeBytes >= int64(0) &&
           sample.outputFileSizeBytes <= threshold.maxOutputFileSizeBytes

fn CompilerBudgetSampleOk(sample: CompilerBudgetSample,
                           threshold: CompilerBudgetThreshold): bool =
    return CompilerBudgetCompileTimeOk(sample, threshold) &&
           CompilerBudgetCompilePeakRssOk(sample, threshold) &&
           CompilerBudgetOutputFileSizeOk(sample, threshold)

fn CompilerBudgetReportRow(sample: CompilerBudgetSample,
                            threshold: CompilerBudgetThreshold): str =
    return strutil.Join([sample.label,
                         " compile_time_ms=",
                         strings.Int64ToStr(sample.compileTimeMs),
                         " compile_peak_rss_bytes=",
                         strings.Int64ToStr(sample.compilePeakRssBytes),
                         " output_file_size_bytes=",
                         strings.Int64ToStr(sample.outputFileSizeBytes),
                         " limit_compile_time_ms=",
                         strings.Int64ToStr(threshold.maxCompileTimeMs),
                         " limit_compile_peak_rss_bytes=",
                         strings.Int64ToStr(threshold.maxCompilePeakRssBytes),
                         " limit_output_file_size_bytes=",
                         strings.Int64ToStr(threshold.maxOutputFileSizeBytes)], "")
