import std/result
import std/system as system
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/lsmr_types as lt
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser

type
    CompilerPackageSnapshot =
        version: int32
        packageId: str
        channel: str
        sourceBundleCid: layout.FixedBytes32
        csgRootCid: layout.FixedBytes32
        exportSurfaceCid: layout.FixedBytes32
        syntaxSurfaceCid: layout.FixedBytes32
        migrationRulesCid: layout.FixedBytes32
        baselineSnapshotCid: layout.FixedBytes32
        baselineWorldHeadCid: layout.FixedBytes32
        depsManifestCid: layout.FixedBytes32
        migrationProofCid: layout.FixedBytes32
        signature: str
        snapshotCid: layout.FixedBytes32

    CompilerUniverseManifestEntry =
        packageId: str
        snapshotCid: layout.FixedBytes32
        syntaxSurfaceCid: layout.FixedBytes32
        migrationProofCid: layout.FixedBytes32

    CompilerUniverseManifest =
        version: int32
        channel: str
        entryCount: int32
        entries: CompilerUniverseManifestEntry[]
        manifestCid: layout.FixedBytes32

    CompilerWorldHead =
        version: int32
        universeId: str
        channel: str
        headEpoch: int32
        prevHeadCid: layout.FixedBytes32
        manifestRootCid: layout.FixedBytes32
        csgRootCid: layout.FixedBytes32
        compilerPkgCid: layout.FixedBytes32
        stdPkgCid: layout.FixedBytes32
        runtimePkgCid: layout.FixedBytes32
        signature: str
        headCid: layout.FixedBytes32

    CompilerLockSnapshot =
        version: int32
        channel: str
        worldHeadCid: layout.FixedBytes32
        manifestRootCid: layout.FixedBytes32
        compilerPkgCid: layout.FixedBytes32
        stdPkgCid: layout.FixedBytes32
        runtimePkgCid: layout.FixedBytes32
        entryCount: int32
        entries: CompilerUniverseManifestEntry[]
        lockPath: str

    CompilerLocalUniverse =
        compilerSnapshot: CompilerPackageSnapshot
        stdSnapshot: CompilerPackageSnapshot
        runtimeSnapshot: CompilerPackageSnapshot
        manifest: CompilerUniverseManifest
        worldHead: CompilerWorldHead

fn CompilerWorldUniverseId(): str =
    return "cheng/compiler_universe"

fn CompilerWorldDefaultChannel(): str =
    return "stable"

fn CompilerWorldOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn CompilerWorldNormalizeChannel(raw: str): Result[str] =
    let channel = strutil.Strip(raw)
    if len(channel) <= 0:
        return Ok[str](CompilerWorldDefaultChannel())
    if channel != "stable":
        if channel != "edge":
            return Err[str](" compiler world: unsupported channel: " + channel)
    return Ok[str](channel)

fn CompilerManagedMirrorKey(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_' || ch == '-' || ch == '.':
            out = out + chengpath.TextSlice(text, i, 1)
        else:
            out = out + "_"
    if len(out) <= 0:
        return "pkg"
    return out

fn CompilerManagedMirrorRel(channel: str,
                              packageId: str,
                              migrationProofCid: layout.FixedBytes32): str =
    let proofHex = layout.fixedBytes32Hex(migrationProofCid)
    return "chengcache/cheng_managed_dependency_mirror/" +
        CompilerManagedMirrorKey(channel) + "/" +
        CompilerManagedMirrorKey(packageId) + "/" +
        proofHex

fn CompilerManagedMirrorRoot(rootDir: str,
                               channel: str,
                               packageId: str,
                               migrationProofCid: layout.FixedBytes32): str =
    return chengpath.PathAbsolute(rootDir,
                                 CompilerManagedMirrorRel(channel,
                                                            packageId,
                                                            migrationProofCid))

fn CompilerWorldAppendText(buf: var layout.ByteBuf, text: str) =
    lt.AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)

fn CompilerWorldAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    lt.AppendFixed32(buf, value)

fn CompilerWorldBufCid(buf: var layout.ByteBuf): layout.FixedBytes32 =
    let data = layout.byteBufToBytes(buf)
    return hash256.sha256Fixed(layout.byteSpanFromBytes(data))

fn CompilerWorldStrLess(left: str,
                          right: str): bool =
    if left == right:
        return false
    let leftLen = len(left)
    let rightLen = len(right)
    let sharedLen = leftLen < rightLen ? leftLen : rightLen
    for i in 0..<sharedLen:
        if left[i] == right[i]:
            continue
        return left[i] < right[i]
    return leftLen < rightLen

fn CompilerWorldSortPaths(items: var str[]) =
    if items.len <= 1:
        return
    var i = 1
    while i < items.len:
        let value = items[i]
        var j = i
        while j > 0:
            if !CompilerWorldStrLess(value, items[j - 1]):
                break
            items[j] = items[j - 1]
            j = j - 1
        items[j] = value
        i = i + 1

fn CompilerWorldSortPathTextPairs(paths: var str[],
                                    texts: var str[]) =
    if paths.len <= 1:
        return
    var i = 1
    while i < paths.len:
        let valuePath = paths[i]
        let valueText = texts[i]
        var j = i
        while j > 0:
            if !CompilerWorldStrLess(valuePath, paths[j - 1]):
                break
            paths[j] = paths[j - 1]
            texts[j] = texts[j - 1]
            j = j - 1
        paths[j] = valuePath
        texts[j] = valueText
        i = i + 1

fn CompilerWorldHashText(tag: str, values: str[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, tag)
    lt.AppendU32BE(buf, values.len)
    for i in 0..<values.len:
        CompilerWorldAppendText(buf, values[i])
    return CompilerWorldBufCid(buf)

fn CompilerWorldDefaultSyntaxSurfaceCid(packageId: str,
                                          channel: str,
                                          exportSurfaceCid: layout.FixedBytes32): layout.FixedBytes32 =
    return CompilerWorldHashText("cheng.compiler.syntax_surface",
                                   [packageId,
                                    channel,
                                    layout.fixedBytes32Hex(exportSurfaceCid)])

fn CompilerWorldManifestEntryLess(left: CompilerUniverseManifestEntry,
                                    right: CompilerUniverseManifestEntry): bool =
    return CompilerWorldStrLess(left.packageId, right.packageId)

fn CompilerWorldSortManifestEntries(entries: var CompilerUniverseManifestEntry[]) =
    if entries.len <= 1:
        return
    var i = 1
    while i < entries.len:
        let value = entries[i]
        var j = i
        while j > 0:
            if !CompilerWorldManifestEntryLess(value, entries[j - 1]):
                break
            entries[j] = entries[j - 1]
            j = j - 1
        entries[j] = value
        i = i + 1

fn CompilerUniverseManifestEntryMake(packageId: str,
                                       snapshotCid: layout.FixedBytes32,
                                       syntaxSurfaceCid: layout.FixedBytes32,
                                       migrationProofCid: layout.FixedBytes32): CompilerUniverseManifestEntry =
    var out: CompilerUniverseManifestEntry
    out.packageId = CompilerWorldOwnText(packageId)
    out.snapshotCid = snapshotCid
    out.syntaxSurfaceCid = syntaxSurfaceCid
    out.migrationProofCid = migrationProofCid
    return out

fn CompilerWorldManifestEntryAppendOrReplace(entries: var CompilerUniverseManifestEntry[],
                                               entry: CompilerUniverseManifestEntry) =
    for i in 0..<entries.len:
        if entries[i].packageId != entry.packageId:
            continue
        entries[i] = entry
        return
    add(entries, entry)

fn CompilerWorldHashUniverseManifest(channel: str,
                                       entries: CompilerUniverseManifestEntry[]): layout.FixedBytes32 =
    var ordered: CompilerUniverseManifestEntry[]
    for i in 0..<entries.len:
        add(ordered, entries[i])
    CompilerWorldSortManifestEntries(ordered)
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.universe_manifest")
    CompilerWorldAppendText(buf, channel)
    lt.AppendU32BE(buf, ordered.len)
    for i in 0..<ordered.len:
        CompilerWorldAppendText(buf, ordered[i].packageId)
        CompilerWorldAppendFixed32(buf, ordered[i].snapshotCid)
        CompilerWorldAppendFixed32(buf, ordered[i].syntaxSurfaceCid)
        CompilerWorldAppendFixed32(buf, ordered[i].migrationProofCid)
    return CompilerWorldBufCid(buf)

fn CompilerUniverseManifestMake(channelRaw: str,
                                  entries: CompilerUniverseManifestEntry[]): Result[CompilerUniverseManifest] =
    let channelRes = CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[CompilerUniverseManifest](Error(channelRes))
    let channel = Value(channelRes)
    var ordered: CompilerUniverseManifestEntry[]
    for i in 0..<entries.len:
        add(ordered, entries[i])
    CompilerWorldSortManifestEntries(ordered)
    var out: CompilerUniverseManifest
    out.version = 1
    out.channel = CompilerWorldOwnText(channel)
    out.entryCount = ordered.len
    out.entries = ordered
    out.manifestCid = CompilerWorldHashUniverseManifest(channel, ordered)
    return Ok[CompilerUniverseManifest](out)

fn CompilerWorldEmptyManifestCid(channelRaw: str): layout.FixedBytes32 =
    let manifestRes = CompilerUniverseManifestMake(channelRaw, [])
    if IsErr(manifestRes):
        return layout.FixedBytes32()
    return Value(manifestRes).manifestCid

fn CompilerWorldDepsManifestCid(channelRaw: str,
                                  entries: CompilerUniverseManifestEntry[]): layout.FixedBytes32 =
    let manifestRes = CompilerUniverseManifestMake(channelRaw, entries)
    if IsErr(manifestRes):
        return layout.FixedBytes32()
    return Value(manifestRes).manifestCid

fn CompilerWorldHashPackageSnapshot(packageId: str,
                                      channel: str,
                                      sourceBundleCid: layout.FixedBytes32,
                                      csgRootCid: layout.FixedBytes32,
                                      exportSurfaceCid: layout.FixedBytes32,
                                      syntaxSurfaceCid: layout.FixedBytes32,
                                      migrationRulesCid: layout.FixedBytes32,
                                      baselineSnapshotCid: layout.FixedBytes32,
                                      baselineWorldHeadCid: layout.FixedBytes32,
                                      depsManifestCid: layout.FixedBytes32,
                                      migrationProofCid: layout.FixedBytes32,
                                      signature: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.package_snapshot")
    CompilerWorldAppendText(buf, packageId)
    CompilerWorldAppendText(buf, channel)
    CompilerWorldAppendFixed32(buf, sourceBundleCid)
    CompilerWorldAppendFixed32(buf, csgRootCid)
    CompilerWorldAppendFixed32(buf, exportSurfaceCid)
    CompilerWorldAppendFixed32(buf, syntaxSurfaceCid)
    CompilerWorldAppendFixed32(buf, migrationRulesCid)
    CompilerWorldAppendFixed32(buf, baselineSnapshotCid)
    CompilerWorldAppendFixed32(buf, baselineWorldHeadCid)
    CompilerWorldAppendFixed32(buf, depsManifestCid)
    CompilerWorldAppendFixed32(buf, migrationProofCid)
    CompilerWorldAppendText(buf, signature)
    return CompilerWorldBufCid(buf)

fn CompilerWorldManifestRootCid(manifest: CompilerUniverseManifest): layout.FixedBytes32 =
    return manifest.manifestCid

fn CompilerWorldHashHead(universeId: str,
                           channel: str,
                           headEpoch: int32,
                           prevHeadCid: layout.FixedBytes32,
                           manifestRootCid: layout.FixedBytes32,
                           csgRootCid: layout.FixedBytes32,
                           compilerPkgCid: layout.FixedBytes32,
                           stdPkgCid: layout.FixedBytes32,
                           runtimePkgCid: layout.FixedBytes32,
                           signature: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.world_head")
    CompilerWorldAppendText(buf, universeId)
    CompilerWorldAppendText(buf, channel)
    lt.AppendU32BE(buf, headEpoch)
    CompilerWorldAppendFixed32(buf, prevHeadCid)
    CompilerWorldAppendFixed32(buf, manifestRootCid)
    CompilerWorldAppendFixed32(buf, csgRootCid)
    CompilerWorldAppendFixed32(buf, compilerPkgCid)
    CompilerWorldAppendFixed32(buf, stdPkgCid)
    CompilerWorldAppendFixed32(buf, runtimePkgCid)
    CompilerWorldAppendText(buf, signature)
    return CompilerWorldBufCid(buf)

fn CompilerWorldOwnedBytesFromText(text: str): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(len(text) + 16)
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)
    return layout.byteBufToBytes(buf)

fn CompilerWorldSourceBundleCid(packageId: str,
                                  sourcePaths: str[]): layout.FixedBytes32 =
    var orderedPaths: str[]
    for i in 0..<sourcePaths.len:
        add(orderedPaths, sourcePaths[i])
    CompilerWorldSortPaths(orderedPaths)
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.source_bundle")
    CompilerWorldAppendText(buf, packageId)
    lt.AppendU32BE(buf, orderedPaths.len)
    for i in 0..<orderedPaths.len:
        let sourcePath = orderedPaths[i]
        CompilerWorldAppendText(buf, sourcePath)
        let text = chengpath.ReadTextFile("", sourcePath)
        CompilerWorldAppendText(buf, text)
    return CompilerWorldBufCid(buf)

fn CompilerWorldSourceBundleCidFromIdentityTexts(packageId: str,
                                                   identityPaths: str[],
                                                   sourceTexts: str[]): Result[layout.FixedBytes32] =
    if identityPaths.len != sourceTexts.len:
        return Err[layout.FixedBytes32](" compiler world: source bundle path/text count mismatch")
    var orderedPaths: str[]
    var orderedTexts: str[]
    for i in 0..<identityPaths.len:
        add(orderedPaths, identityPaths[i])
        add(orderedTexts, sourceTexts[i])
    CompilerWorldSortPathTextPairs(orderedPaths, orderedTexts)
    for i in 1..<orderedPaths.len:
        if orderedPaths[i] != orderedPaths[i - 1]:
            continue
        return Err[layout.FixedBytes32](" compiler world: duplicate source bundle identity path: " + orderedPaths[i])
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.source_bundle")
    CompilerWorldAppendText(buf, packageId)
    lt.AppendU32BE(buf, orderedPaths.len)
    for i in 0..<orderedPaths.len:
        CompilerWorldAppendText(buf, orderedPaths[i])
        CompilerWorldAppendText(buf, orderedTexts[i])
    return Ok[layout.FixedBytes32](CompilerWorldBufCid(buf))

fn CompilerWorldSourceBundleModulePath(workspaceRootRaw: str,
                                         packageRootRaw: str,
                                         externalPackageRoots: parser.ParserExternalPackageRoot[],
                                         sourcePathRaw: str): str =
    return parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRootRaw,
                                                                         packageRootRaw,
                                                                         externalPackageRoots,
                                                                         sourcePathRaw)

fn CompilerWorldSourceBundleCidWithExternalPackageRoots(packageId: str,
                                                          workspaceRootRaw: str,
                                                          packageRootRaw: str,
                                                          externalPackageRoots: parser.ParserExternalPackageRoot[],
                                                          sourcePaths: str[]): Result[layout.FixedBytes32] =
    var modulePaths: str[]
    var sourceTexts: str[]
    for i in 0..<sourcePaths.len:
        let sourcePath = sourcePaths[i]
        add(modulePaths,
            CompilerWorldSourceBundleModulePath(workspaceRootRaw,
                                                  packageRootRaw,
                                                  externalPackageRoots,
                                                  sourcePath))
        add(sourceTexts, chengpath.ReadTextFile("", sourcePath))
    return CompilerWorldSourceBundleCidFromIdentityTexts(packageId, modulePaths, sourceTexts)

fn CompilerWorldSourceBundleCidFromTexts(packageId: str,
                                           sourcePaths: str[],
                                           sourceTexts: str[]): Result[layout.FixedBytes32] =
    return CompilerWorldSourceBundleCidFromIdentityTexts(packageId, sourcePaths, sourceTexts)

fn CompilerWorldSourceBundleCidFromModuleTexts(packageId: str,
                                                 modulePaths: str[],
                                                 sourceTexts: str[]): Result[layout.FixedBytes32] =
    return CompilerWorldSourceBundleCidFromIdentityTexts(packageId, modulePaths, sourceTexts)

fn CompilerPackageSnapshotMake(packageId: str,
                                 channel: str,
                                 sourceBundleCid: layout.FixedBytes32,
                                 csgRootCid: layout.FixedBytes32,
                                 exportSurfaceCid: layout.FixedBytes32,
                                 syntaxSurfaceCid: layout.FixedBytes32,
                                 migrationRulesCid: layout.FixedBytes32,
                                 baselineSnapshotCid: layout.FixedBytes32,
                                 baselineWorldHeadCid: layout.FixedBytes32,
                                 depsManifestCid: layout.FixedBytes32,
                                 migrationProofCid: layout.FixedBytes32,
                                 signature: str): CompilerPackageSnapshot =
    let packageIdOwned = CompilerWorldOwnText(packageId)
    let channelOwned = CompilerWorldOwnText(channel)
    let signatureOwned = CompilerWorldOwnText(signature)
    var out: CompilerPackageSnapshot
    out.version = 1
    out.packageId = packageIdOwned
    out.channel = channelOwned
    out.sourceBundleCid = sourceBundleCid
    out.csgRootCid = csgRootCid
    out.exportSurfaceCid = exportSurfaceCid
    out.syntaxSurfaceCid = syntaxSurfaceCid
    out.migrationRulesCid = migrationRulesCid
    out.baselineSnapshotCid = baselineSnapshotCid
    out.baselineWorldHeadCid = baselineWorldHeadCid
    out.depsManifestCid = depsManifestCid
    out.migrationProofCid = migrationProofCid
    out.signature = signatureOwned
    out.snapshotCid = CompilerWorldHashPackageSnapshot(packageIdOwned,
                                                         channelOwned,
                                                         sourceBundleCid,
                                                         csgRootCid,
                                                         exportSurfaceCid,
                                                         syntaxSurfaceCid,
                                                         migrationRulesCid,
                                                         baselineSnapshotCid,
                                                         baselineWorldHeadCid,
                                                         depsManifestCid,
                                                         migrationProofCid,
                                                         signatureOwned)
    return out

fn CompilerWorldHeadMake(channel: str,
                           headEpoch: int32,
                           prevHeadCid: layout.FixedBytes32,
                           manifest: CompilerUniverseManifest,
                           csgRootCid: layout.FixedBytes32,
                           compilerPkgCid: layout.FixedBytes32,
                           stdPkgCid: layout.FixedBytes32,
                           runtimePkgCid: layout.FixedBytes32,
                           signature: str): CompilerWorldHead =
    let universeId = CompilerWorldOwnText(CompilerWorldUniverseId())
    let channelOwned = CompilerWorldOwnText(channel)
    let signatureOwned = CompilerWorldOwnText(signature)
    let manifestRootCid = CompilerWorldManifestRootCid(manifest)
    var out: CompilerWorldHead
    out.version = 1
    out.universeId = universeId
    out.channel = channelOwned
    out.headEpoch = headEpoch
    out.prevHeadCid = prevHeadCid
    out.manifestRootCid = manifestRootCid
    out.csgRootCid = csgRootCid
    out.compilerPkgCid = compilerPkgCid
    out.stdPkgCid = stdPkgCid
    out.runtimePkgCid = runtimePkgCid
    out.signature = signatureOwned
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    CompilerWorldAppendText(buf, "cheng.compiler.world_head")
    CompilerWorldAppendText(buf, universeId)
    CompilerWorldAppendText(buf, channelOwned)
    lt.AppendU32BE(buf, headEpoch)
    CompilerWorldAppendFixed32(buf, prevHeadCid)
    CompilerWorldAppendFixed32(buf, manifestRootCid)
    CompilerWorldAppendFixed32(buf, csgRootCid)
    CompilerWorldAppendFixed32(buf, compilerPkgCid)
    CompilerWorldAppendFixed32(buf, stdPkgCid)
    CompilerWorldAppendFixed32(buf, runtimePkgCid)
    CompilerWorldAppendText(buf, signatureOwned)
    out.headCid = CompilerWorldBufCid(buf)
    return out

fn CompilerLocalUniverseBuildForChannelWithManifestEntries(channelRaw: str,
                                                             sourceBundleCid: layout.FixedBytes32,
                                                             csgRootCid: layout.FixedBytes32,
                                                             exportSurfaceCid: layout.FixedBytes32,
                                                             compilerMigrationProofCid: layout.FixedBytes32,
                                                             extraManifestEntries: CompilerUniverseManifestEntry[]): Result[CompilerLocalUniverse] =
    let channelRes = CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[CompilerLocalUniverse](Error(channelRes))
    let channel = CompilerWorldOwnText(Value(channelRes))
    let compilerSyntaxCid = CompilerWorldDefaultSyntaxSurfaceCid("cheng/compiler", channel, exportSurfaceCid)
    let stdSyntaxCid = CompilerWorldDefaultSyntaxSurfaceCid("cheng/std", channel, exportSurfaceCid)
    let runtimeSyntaxCid = CompilerWorldDefaultSyntaxSurfaceCid("cheng/runtime", channel, exportSurfaceCid)
    let emptyDepsManifestCid = CompilerWorldEmptyManifestCid(channel)
    let stdSnapshot = CompilerPackageSnapshotMake("cheng/std",
                                                    channel,
                                                    sourceBundleCid,
                                                    csgRootCid,
                                                    exportSurfaceCid,
                                                    stdSyntaxCid,
                                                    layout.FixedBytes32(),
                                                    layout.FixedBytes32(),
                                                    layout.FixedBytes32(),
                                                    emptyDepsManifestCid,
                                                    layout.FixedBytes32(),
                                                    "local:std")
    let runtimeSnapshot = CompilerPackageSnapshotMake("cheng/runtime",
                                                        channel,
                                                        sourceBundleCid,
                                                        csgRootCid,
                                                        exportSurfaceCid,
                                                        runtimeSyntaxCid,
                                                        layout.FixedBytes32(),
                                                        layout.FixedBytes32(),
                                                        layout.FixedBytes32(),
                                                        emptyDepsManifestCid,
                                                        layout.FixedBytes32(),
                                                        "local:runtime")
    var compilerDepsEntries: CompilerUniverseManifestEntry[]
    CompilerWorldManifestEntryAppendOrReplace(compilerDepsEntries,
                                                CompilerUniverseManifestEntryMake(stdSnapshot.packageId,
                                                                                     stdSnapshot.snapshotCid,
                                                                                     stdSnapshot.syntaxSurfaceCid,
                                                                                     stdSnapshot.migrationProofCid))
    CompilerWorldManifestEntryAppendOrReplace(compilerDepsEntries,
                                                CompilerUniverseManifestEntryMake(runtimeSnapshot.packageId,
                                                                                     runtimeSnapshot.snapshotCid,
                                                                                     runtimeSnapshot.syntaxSurfaceCid,
                                                                                     runtimeSnapshot.migrationProofCid))
    for i in 0..<extraManifestEntries.len:
        let entry = extraManifestEntries[i]
        if entry.packageId == "cheng/compiler":
            continue
        if entry.packageId == "cheng/std":
            continue
        if entry.packageId == "cheng/runtime":
            continue
        CompilerWorldManifestEntryAppendOrReplace(compilerDepsEntries, entry)
    let compilerDepsManifestCid = CompilerWorldDepsManifestCid(channel,
                                                                 compilerDepsEntries)
    let compilerSnapshot = CompilerPackageSnapshotMake("cheng/compiler",
                                                         channel,
                                                         sourceBundleCid,
                                                         csgRootCid,
                                                         exportSurfaceCid,
                                                         compilerSyntaxCid,
                                                         layout.FixedBytes32(),
                                                         layout.FixedBytes32(),
                                                         layout.FixedBytes32(),
                                                         compilerDepsManifestCid,
                                                         compilerMigrationProofCid,
                                                         "local:compiler")
    var manifestEntries: CompilerUniverseManifestEntry[]
    CompilerWorldManifestEntryAppendOrReplace(manifestEntries,
                                                CompilerUniverseManifestEntryMake(compilerSnapshot.packageId,
                                                                                     compilerSnapshot.snapshotCid,
                                                                                     compilerSnapshot.syntaxSurfaceCid,
                                                                                     compilerSnapshot.migrationProofCid))
    CompilerWorldManifestEntryAppendOrReplace(manifestEntries,
                                                CompilerUniverseManifestEntryMake(stdSnapshot.packageId,
                                                                                     stdSnapshot.snapshotCid,
                                                                                     stdSnapshot.syntaxSurfaceCid,
                                                                                     stdSnapshot.migrationProofCid))
    CompilerWorldManifestEntryAppendOrReplace(manifestEntries,
                                                CompilerUniverseManifestEntryMake(runtimeSnapshot.packageId,
                                                                                     runtimeSnapshot.snapshotCid,
                                                                                     runtimeSnapshot.syntaxSurfaceCid,
                                                                                     runtimeSnapshot.migrationProofCid))
    for i in 0..<extraManifestEntries.len:
        let entry = extraManifestEntries[i]
        if entry.packageId == "cheng/compiler":
            continue
        if entry.packageId == "cheng/std":
            continue
        if entry.packageId == "cheng/runtime":
            continue
        CompilerWorldManifestEntryAppendOrReplace(manifestEntries, entry)
    let manifestRes = CompilerUniverseManifestMake(channel,
                                                     manifestEntries)
    if IsErr(manifestRes):
        return Err[CompilerLocalUniverse](Error(manifestRes))
    let manifest = Value(manifestRes)
    let worldHead = CompilerWorldHeadMake(channel,
                                            1,
                                            layout.FixedBytes32(),
                                            manifest,
                                            csgRootCid,
                                            compilerSnapshot.snapshotCid,
                                            stdSnapshot.snapshotCid,
                                            runtimeSnapshot.snapshotCid,
                                            "local:world_head")
    var out: CompilerLocalUniverse
    out.compilerSnapshot = compilerSnapshot
    out.stdSnapshot = stdSnapshot
    out.runtimeSnapshot = runtimeSnapshot
    out.manifest = manifest
    out.worldHead = worldHead
    return Ok[CompilerLocalUniverse](out)

fn CompilerLocalUniverseBuildForChannel(channelRaw: str,
                                          sourceBundleCid: layout.FixedBytes32,
                                          csgRootCid: layout.FixedBytes32,
                                          exportSurfaceCid: layout.FixedBytes32,
                                          compilerMigrationProofCid: layout.FixedBytes32): Result[CompilerLocalUniverse] =
    var extraManifestEntries: CompilerUniverseManifestEntry[]
    return CompilerLocalUniverseBuildForChannelWithManifestEntries(channelRaw,
                                                                     sourceBundleCid,
                                                                     csgRootCid,
                                                                     exportSurfaceCid,
                                                                     compilerMigrationProofCid,
                                                                     extraManifestEntries)

fn CompilerLocalUniverseBuild(sourceBundleCid: layout.FixedBytes32,
                                csgRootCid: layout.FixedBytes32,
                                exportSurfaceCid: layout.FixedBytes32): CompilerLocalUniverse =
    let universeRes = CompilerLocalUniverseBuildForChannel(CompilerWorldDefaultChannel(),
                                                             sourceBundleCid,
                                                             csgRootCid,
                                                             exportSurfaceCid,
                                                             layout.FixedBytes32())
    return Value(universeRes)

fn CompilerWorldQuotedValue(text: str): str =
    let value = strutil.Strip(text)
    if len(value) < 2:
        return value
    return chengpath.TextSlice(value, 1, len(value) - 2)

fn CompilerWorldLineValue(text: str, key: str): str =
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        var plainMatch = false
        if line.len > key.len:
            if int32(line[key.len]) == 61:
                plainMatch = true
        if plainMatch:
            for j in 0..<key.len:
                if line[j] != key[j]:
                    plainMatch = false
                    break
        if plainMatch:
            let rawValue = chengpath.TextSlice(line, key.len + 1, len(line) - (key.len + 1))
            return strutil.Strip(rawValue)
        var quotedMatch = false
        if line.len > key.len + 2:
            if int32(line[key.len]) == 32:
                if int32(line[key.len + 1]) == 61:
                    if int32(line[key.len + 2]) == 32:
                        quotedMatch = true
        if quotedMatch:
            for j in 0..<key.len:
                if line[j] != key[j]:
                    quotedMatch = false
                    break
        if quotedMatch:
            let rawValue = chengpath.TextSlice(line, key.len + 3, len(line) - (key.len + 3))
            return CompilerWorldQuotedValue(rawValue)
    return ""

fn CompilerWorldFixed32Value(text: str, key: str): Result[layout.FixedBytes32] =
    let value = CompilerWorldLineValue(text, key)
    if len(value) <= 0:
        return Err[layout.FixedBytes32](" compiler world: missing key: " + key)
    let valueRes = layout.fixedBytes32FromHex(value)
    if IsErr(valueRes):
        return Err[layout.FixedBytes32](" compiler world: invalid fixed32 for key: " + key)
    return Ok[layout.FixedBytes32](Value(valueRes))

fn CompilerWorldInt32Value(text: str, key: str): Result[int32] =
    let value = CompilerWorldLineValue(text, key)
    if len(value) <= 0:
        return Err[int32](" compiler world: missing key: " + key)
    return Ok[int32](int32(parseInt(value)))

fn CompilerUniverseManifestReport(manifest: CompilerUniverseManifest): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "channel=" + manifest.channel + "\n"
    out = out + "entry_count=" + intToStr(manifest.entryCount) + "\n"
    for i in 0..<manifest.entries.len:
        out = out + "entry[" + intToStr(i) + "].package_id=" + manifest.entries[i].packageId + "\n"
        out = out + "entry[" + intToStr(i) + "].snapshot_cid=" + layout.fixedBytes32Hex(manifest.entries[i].snapshotCid) + "\n"
        out = out + "entry[" + intToStr(i) + "].syntax_surface_cid=" + layout.fixedBytes32Hex(manifest.entries[i].syntaxSurfaceCid) + "\n"
        out = out + "entry[" + intToStr(i) + "].migration_proof_cid=" + layout.fixedBytes32Hex(manifest.entries[i].migrationProofCid) + "\n"
    out = out + "manifest_cid=" + layout.fixedBytes32Hex(manifest.manifestCid)
    return out

fn CompilerUniverseManifestFromReportText(text: str,
                                            out: var CompilerUniverseManifest): Result[bool] =
    let channelRes = CompilerWorldNormalizeChannel(CompilerWorldLineValue(text, "channel"))
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let entryCountRes = CompilerWorldInt32Value(text, "entry_count")
    if IsErr(entryCountRes):
        return Err[bool](Error(entryCountRes))
    let manifestCidRes = CompilerWorldFixed32Value(text, "manifest_cid")
    if IsErr(manifestCidRes):
        return Err[bool](Error(manifestCidRes))
    let entryCount = Value(entryCountRes)
    var entries: CompilerUniverseManifestEntry[]
    for i in 0..<entryCount:
        let prefix = "entry[" + intToStr(i) + "]."
        let packageId = CompilerWorldLineValue(text, prefix + "package_id")
        if len(packageId) <= 0:
            return Err[bool](" compiler world: manifest entry package_id missing")
        let snapshotRes = CompilerWorldFixed32Value(text, prefix + "snapshot_cid")
        if IsErr(snapshotRes):
            return Err[bool](Error(snapshotRes))
        let syntaxRes = CompilerWorldFixed32Value(text, prefix + "syntax_surface_cid")
        if IsErr(syntaxRes):
            return Err[bool](Error(syntaxRes))
        let proofValue = CompilerWorldLineValue(text, prefix + "migration_proof_cid")
        var proofCid = layout.FixedBytes32()
        if len(proofValue) > 0:
            let proofRes = layout.fixedBytes32FromHex(proofValue)
            if IsErr(proofRes):
                return Err[bool](" compiler world: invalid manifest migration proof cid")
            proofCid = Value(proofRes)
        add(entries, CompilerUniverseManifestEntryMake(packageId,
                                                         Value(snapshotRes),
                                                         Value(syntaxRes),
                                                         proofCid))
    let manifestRes = CompilerUniverseManifestMake(Value(channelRes), entries)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    if !layout.fixedBytes32Equal(manifest.manifestCid, Value(manifestCidRes)):
        return Err[bool](" compiler world: manifest cid mismatch")
    out = manifest
    return Ok[bool](true)

fn CompilerLockSnapshotFromText(text: str,
                                  lockPath: str): Result[CompilerLockSnapshot] =
    let channelRes = CompilerWorldNormalizeChannel(CompilerWorldLineValue(text, "channel"))
    if IsErr(channelRes):
        return Err[CompilerLockSnapshot](Error(channelRes))
    let worldHeadRes = CompilerWorldFixed32Value(text, "world_head_cid")
    if IsErr(worldHeadRes):
        return Err[CompilerLockSnapshot](Error(worldHeadRes))
    let manifestRootValue = CompilerWorldLineValue(text, "manifest_root_cid")
    var manifestRootCid = layout.FixedBytes32()
    if len(manifestRootValue) > 0:
        let manifestRootRes = layout.fixedBytes32FromHex(manifestRootValue)
        if IsErr(manifestRootRes):
            return Err[CompilerLockSnapshot](" compiler world: invalid lock manifest_root_cid")
        manifestRootCid = Value(manifestRootRes)
    let compilerRes = CompilerWorldFixed32Value(text, "compiler_pkg_cid")
    if IsErr(compilerRes):
        return Err[CompilerLockSnapshot](Error(compilerRes))
    let stdRes = CompilerWorldFixed32Value(text, "std_pkg_cid")
    if IsErr(stdRes):
        return Err[CompilerLockSnapshot](Error(stdRes))
    let runtimeRes = CompilerWorldFixed32Value(text, "runtime_pkg_cid")
    if IsErr(runtimeRes):
        return Err[CompilerLockSnapshot](Error(runtimeRes))
    let entryCountValue = CompilerWorldLineValue(text, "entry_count")
    var entryCount = 0
    if len(entryCountValue) > 0:
        entryCount = int32(parseInt(entryCountValue))
    var entries: CompilerUniverseManifestEntry[]
    if entryCount > 0:
        for i in 0..<entryCount:
            let prefix = "entry[" + intToStr(i) + "]."
            let packageId = CompilerWorldLineValue(text, prefix + "package_id")
            if len(packageId) <= 0:
                return Err[CompilerLockSnapshot](" compiler world: lock entry package_id missing")
            let snapshotRes = CompilerWorldFixed32Value(text, prefix + "snapshot_cid")
            if IsErr(snapshotRes):
                return Err[CompilerLockSnapshot](Error(snapshotRes))
            let syntaxRes = CompilerWorldFixed32Value(text, prefix + "syntax_surface_cid")
            if IsErr(syntaxRes):
                return Err[CompilerLockSnapshot](Error(syntaxRes))
            let proofValue = CompilerWorldLineValue(text, prefix + "migration_proof_cid")
            var proofCid = layout.FixedBytes32()
            if len(proofValue) > 0:
                let proofRes = layout.fixedBytes32FromHex(proofValue)
                if IsErr(proofRes):
                    return Err[CompilerLockSnapshot](" compiler world: invalid lock migration proof cid")
                proofCid = Value(proofRes)
            add(entries, CompilerUniverseManifestEntryMake(packageId,
                                                             Value(snapshotRes),
                                                             Value(syntaxRes),
                                                             proofCid))
    else:
        entryCount = 3
        add(entries, CompilerUniverseManifestEntryMake("cheng/compiler", Value(compilerRes), layout.FixedBytes32(), layout.FixedBytes32()))
        add(entries, CompilerUniverseManifestEntryMake("cheng/std", Value(stdRes), layout.FixedBytes32(), layout.FixedBytes32()))
        add(entries, CompilerUniverseManifestEntryMake("cheng/runtime", Value(runtimeRes), layout.FixedBytes32(), layout.FixedBytes32()))
    var out: CompilerLockSnapshot
    out.version = 1
    out.channel = Value(channelRes)
    out.worldHeadCid = Value(worldHeadRes)
    out.manifestRootCid = manifestRootCid
    out.compilerPkgCid = Value(compilerRes)
    out.stdPkgCid = Value(stdRes)
    out.runtimePkgCid = Value(runtimeRes)
    out.entryCount = entryCount
    out.entries = entries
    out.lockPath = lockPath
    return Ok[CompilerLockSnapshot](out)

fn CompilerLockSnapshotRead(rootDir: str,
                              rawPath: str): Result[CompilerLockSnapshot] =
    let path = chengpath.PathAbsolute(rootDir, rawPath)
    if !chengpath.PathFileExists(path):
        return Err[CompilerLockSnapshot](" compiler world: missing lock path: " + path)
    let text = chengpath.ReadTextFile("", path)
    return CompilerLockSnapshotFromText(text, path)

fn CompilerWorldVerifyLock(universe: CompilerLocalUniverse,
                             lock: CompilerLockSnapshot): Result[bool] =
    if universe.worldHead.channel != lock.channel:
        return Err[bool](" compiler world: lock channel mismatch")
    if !layout.fixedBytes32Equal(universe.worldHead.headCid, lock.worldHeadCid):
        return Err[bool](" compiler world: lock world head mismatch")
    if !layout.fixedBytes32Equal(lock.manifestRootCid, layout.FixedBytes32()) &&
       !layout.fixedBytes32Equal(universe.worldHead.manifestRootCid, lock.manifestRootCid):
        return Err[bool](" compiler world: lock manifest root mismatch")
    if !layout.fixedBytes32Equal(universe.compilerSnapshot.snapshotCid, lock.compilerPkgCid):
        return Err[bool](" compiler world: lock compiler snapshot mismatch")
    if !layout.fixedBytes32Equal(universe.stdSnapshot.snapshotCid, lock.stdPkgCid):
        return Err[bool](" compiler world: lock std snapshot mismatch")
    if !layout.fixedBytes32Equal(universe.runtimeSnapshot.snapshotCid, lock.runtimePkgCid):
        return Err[bool](" compiler world: lock runtime snapshot mismatch")
    if universe.manifest.entryCount != lock.entryCount:
        return Err[bool](" compiler world: lock manifest entry count mismatch")
    for i in 0..<universe.manifest.entries.len:
        if universe.manifest.entries[i].packageId != lock.entries[i].packageId:
            return Err[bool](" compiler world: lock manifest package mismatch")
        if !layout.fixedBytes32Equal(universe.manifest.entries[i].snapshotCid, lock.entries[i].snapshotCid):
            return Err[bool](" compiler world: lock manifest snapshot mismatch")
        if !layout.fixedBytes32Equal(lock.entries[i].syntaxSurfaceCid, layout.FixedBytes32()) &&
           !layout.fixedBytes32Equal(universe.manifest.entries[i].syntaxSurfaceCid, lock.entries[i].syntaxSurfaceCid):
            return Err[bool](" compiler world: lock manifest syntax mismatch")
        if !layout.fixedBytes32Equal(lock.entries[i].migrationProofCid, layout.FixedBytes32()) &&
           !layout.fixedBytes32Equal(universe.manifest.entries[i].migrationProofCid, lock.entries[i].migrationProofCid):
            return Err[bool](" compiler world: lock manifest proof mismatch")
    if !layout.fixedBytes32Equal(lock.manifestRootCid, layout.FixedBytes32()) &&
       !layout.fixedBytes32Equal(lock.manifestRootCid, universe.manifest.manifestCid):
        return Err[bool](" compiler world: lock manifest cid drift")
    return Ok[bool](true)

fn CompilerWorldHeadMatchesHex(head: CompilerWorldHead,
                                 rawHex: str): Result[bool] =
    let value = strutil.Strip(rawHex)
    if len(value) <= 0:
        return Ok[bool](true)
    let headRes = layout.fixedBytes32FromHex(value)
    if IsErr(headRes):
        return Err[bool](" compiler world: invalid world head hex")
    if !layout.fixedBytes32Equal(head.headCid, Value(headRes)):
        return Err[bool](" compiler world: requested world head mismatch")
    return Ok[bool](true)

fn CompilerPackageSnapshotReport(snapshot: CompilerPackageSnapshot): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "package_id=" + snapshot.packageId + "\n"
    out = out + "channel=" + snapshot.channel + "\n"
    out = out + "source_bundle_cid=" + layout.fixedBytes32Hex(snapshot.sourceBundleCid) + "\n"
    out = out + "csg_root_cid=" + layout.fixedBytes32Hex(snapshot.csgRootCid) + "\n"
    out = out + "export_surface_cid=" + layout.fixedBytes32Hex(snapshot.exportSurfaceCid) + "\n"
    out = out + "syntax_surface_cid=" + layout.fixedBytes32Hex(snapshot.syntaxSurfaceCid) + "\n"
    out = out + "migration_rules_cid=" + layout.fixedBytes32Hex(snapshot.migrationRulesCid) + "\n"
    out = out + "baseline_snapshot_cid=" + layout.fixedBytes32Hex(snapshot.baselineSnapshotCid) + "\n"
    out = out + "baseline_world_head_cid=" + layout.fixedBytes32Hex(snapshot.baselineWorldHeadCid) + "\n"
    out = out + "deps_manifest_cid=" + layout.fixedBytes32Hex(snapshot.depsManifestCid) + "\n"
    out = out + "migration_proof_cid=" + layout.fixedBytes32Hex(snapshot.migrationProofCid) + "\n"
    out = out + "signature=" + snapshot.signature + "\n"
    out = out + "snapshot_cid=" + layout.fixedBytes32Hex(snapshot.snapshotCid)
    return out

fn CompilerPackageSnapshotFromReportText(text: str,
                                           out: var CompilerPackageSnapshot): Result[bool] =
    let packageId = CompilerWorldLineValue(text, "package_id")
    if len(packageId) <= 0:
        return Err[bool](" compiler world: report package_id missing")
    let channelRes = CompilerWorldNormalizeChannel(CompilerWorldLineValue(text, "channel"))
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let sourceRes = CompilerWorldFixed32Value(text, "source_bundle_cid")
    if IsErr(sourceRes):
        return Err[bool](Error(sourceRes))
    let csgRes = CompilerWorldFixed32Value(text, "csg_root_cid")
    if IsErr(csgRes):
        return Err[bool](Error(csgRes))
    let exportRes = CompilerWorldFixed32Value(text, "export_surface_cid")
    if IsErr(exportRes):
        return Err[bool](Error(exportRes))
    let syntaxValue = CompilerWorldLineValue(text, "syntax_surface_cid")
    var syntaxSurfaceCid = layout.FixedBytes32()
    if len(syntaxValue) > 0:
        let syntaxRes = layout.fixedBytes32FromHex(syntaxValue)
        if IsErr(syntaxRes):
            return Err[bool](" compiler world: invalid syntax surface cid")
        syntaxSurfaceCid = Value(syntaxRes)
    else:
        syntaxSurfaceCid = CompilerWorldDefaultSyntaxSurfaceCid(packageId, Value(channelRes), Value(exportRes))
    let migrationRulesValue = CompilerWorldLineValue(text, "migration_rules_cid")
    var migrationRulesCid = layout.FixedBytes32()
    if len(migrationRulesValue) > 0:
        let rulesRes = layout.fixedBytes32FromHex(migrationRulesValue)
        if IsErr(rulesRes):
            return Err[bool](" compiler world: invalid migration rules cid")
        migrationRulesCid = Value(rulesRes)
    let baselineSnapshotValue = CompilerWorldLineValue(text, "baseline_snapshot_cid")
    var baselineSnapshotCid = layout.FixedBytes32()
    if len(baselineSnapshotValue) > 0:
        let baselineSnapshotRes = layout.fixedBytes32FromHex(baselineSnapshotValue)
        if IsErr(baselineSnapshotRes):
            return Err[bool](" compiler world: invalid baseline snapshot cid")
        baselineSnapshotCid = Value(baselineSnapshotRes)
    let baselineWorldValue = CompilerWorldLineValue(text, "baseline_world_head_cid")
    var baselineWorldCid = layout.FixedBytes32()
    if len(baselineWorldValue) > 0:
        let baselineWorldRes = layout.fixedBytes32FromHex(baselineWorldValue)
        if IsErr(baselineWorldRes):
            return Err[bool](" compiler world: invalid baseline world head cid")
        baselineWorldCid = Value(baselineWorldRes)
    let depsManifestValue = CompilerWorldLineValue(text, "deps_manifest_cid")
    var depsManifestCid = layout.FixedBytes32()
    if len(depsManifestValue) > 0:
        let depsManifestRes = layout.fixedBytes32FromHex(depsManifestValue)
        if IsErr(depsManifestRes):
            return Err[bool](" compiler world: invalid deps manifest cid")
        depsManifestCid = Value(depsManifestRes)
    let migrationProofValue = CompilerWorldLineValue(text, "migration_proof_cid")
    var migrationProofCid = layout.FixedBytes32()
    if len(migrationProofValue) > 0:
        let migrationProofRes = layout.fixedBytes32FromHex(migrationProofValue)
        if IsErr(migrationProofRes):
            return Err[bool](" compiler world: invalid migration proof cid")
        migrationProofCid = Value(migrationProofRes)
    let snapshotCidRes = CompilerWorldFixed32Value(text, "snapshot_cid")
    if IsErr(snapshotCidRes):
        return Err[bool](Error(snapshotCidRes))
    let snapshot = CompilerPackageSnapshotMake(packageId,
                                                Value(channelRes),
                                                Value(sourceRes),
                                                Value(csgRes),
                                                Value(exportRes),
                                                syntaxSurfaceCid,
                                                migrationRulesCid,
                                                baselineSnapshotCid,
                                                baselineWorldCid,
                                                depsManifestCid,
                                                migrationProofCid,
                                                CompilerWorldLineValue(text, "signature"))
    if !layout.fixedBytes32Equal(snapshot.snapshotCid, Value(snapshotCidRes)):
        return Err[bool](" compiler world: package snapshot cid mismatch")
    out = snapshot
    return Ok[bool](true)

fn CompilerWorldHeadReport(head: CompilerWorldHead): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "universe_id=" + head.universeId + "\n"
    out = out + "channel=" + head.channel + "\n"
    out = out + "head_epoch=" + intToStr(head.headEpoch) + "\n"
    out = out + "prev_head_cid=" + layout.fixedBytes32Hex(head.prevHeadCid) + "\n"
    out = out + "manifest_root_cid=" + layout.fixedBytes32Hex(head.manifestRootCid) + "\n"
    out = out + "csg_root_cid=" + layout.fixedBytes32Hex(head.csgRootCid) + "\n"
    out = out + "compiler_pkg_cid=" + layout.fixedBytes32Hex(head.compilerPkgCid) + "\n"
    out = out + "std_pkg_cid=" + layout.fixedBytes32Hex(head.stdPkgCid) + "\n"
    out = out + "runtime_pkg_cid=" + layout.fixedBytes32Hex(head.runtimePkgCid) + "\n"
    out = out + "signature=" + head.signature + "\n"
    out = out + "head_cid=" + layout.fixedBytes32Hex(head.headCid)
    return out

fn CompilerWorldHeadFromReportText(text: str,
                                     out: var CompilerWorldHead): Result[bool] =
    let headEpochText = CompilerWorldLineValue(text, "head_epoch")
    if len(headEpochText) <= 0:
        return Err[bool](" compiler world: report head_epoch missing")
    let prevHeadRes = CompilerWorldFixed32Value(text, "prev_head_cid")
    if IsErr(prevHeadRes):
        return Err[bool](Error(prevHeadRes))
    let manifestRes = CompilerWorldFixed32Value(text, "manifest_root_cid")
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let csgRes = CompilerWorldFixed32Value(text, "csg_root_cid")
    if IsErr(csgRes):
        return Err[bool](Error(csgRes))
    let compilerRes = CompilerWorldFixed32Value(text, "compiler_pkg_cid")
    if IsErr(compilerRes):
        return Err[bool](Error(compilerRes))
    let stdRes = CompilerWorldFixed32Value(text, "std_pkg_cid")
    if IsErr(stdRes):
        return Err[bool](Error(stdRes))
    let runtimeRes = CompilerWorldFixed32Value(text, "runtime_pkg_cid")
    if IsErr(runtimeRes):
        return Err[bool](Error(runtimeRes))
    let headCidRes = CompilerWorldFixed32Value(text, "head_cid")
    if IsErr(headCidRes):
        return Err[bool](Error(headCidRes))
    out.version = 1
    out.universeId = CompilerWorldLineValue(text, "universe_id")
    out.channel = CompilerWorldLineValue(text, "channel")
    out.headEpoch = int32(parseInt(headEpochText))
    out.prevHeadCid = Value(prevHeadRes)
    out.manifestRootCid = Value(manifestRes)
    out.csgRootCid = Value(csgRes)
    out.compilerPkgCid = Value(compilerRes)
    out.stdPkgCid = Value(stdRes)
    out.runtimePkgCid = Value(runtimeRes)
    out.signature = CompilerWorldLineValue(text, "signature")
    out.headCid = Value(headCidRes)
    return Ok[bool](true)

fn CompilerLockText(universe: CompilerLocalUniverse): str =
    var out = ""
    out = out + "channel = \"" + universe.worldHead.channel + "\"\n"
    out = out + "world_head_cid = \"" + layout.fixedBytes32Hex(universe.worldHead.headCid) + "\"\n"
    out = out + "manifest_root_cid = \"" + layout.fixedBytes32Hex(universe.worldHead.manifestRootCid) + "\"\n"
    out = out + "compiler_pkg_cid = \"" + layout.fixedBytes32Hex(universe.compilerSnapshot.snapshotCid) + "\"\n"
    out = out + "std_pkg_cid = \"" + layout.fixedBytes32Hex(universe.stdSnapshot.snapshotCid) + "\"\n"
    out = out + "runtime_pkg_cid = \"" + layout.fixedBytes32Hex(universe.runtimeSnapshot.snapshotCid) + "\"\n"
    out = out + "entry_count = \"" + intToStr(universe.manifest.entryCount) + "\"\n"
    for i in 0..<universe.manifest.entries.len:
        out = out + "entry[" + intToStr(i) + "].package_id = \"" + universe.manifest.entries[i].packageId + "\"\n"
        out = out + "entry[" + intToStr(i) + "].snapshot_cid = \"" + layout.fixedBytes32Hex(universe.manifest.entries[i].snapshotCid) + "\"\n"
        out = out + "entry[" + intToStr(i) + "].syntax_surface_cid = \"" + layout.fixedBytes32Hex(universe.manifest.entries[i].syntaxSurfaceCid) + "\"\n"
        out = out + "entry[" + intToStr(i) + "].migration_proof_cid = \"" + layout.fixedBytes32Hex(universe.manifest.entries[i].migrationProofCid) + "\"\n"
    return out

fn CompilerWorldSummaryReport(universe: CompilerLocalUniverse): str =
    var out = ""
    out = out + "channel=" + universe.worldHead.channel + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(universe.worldHead.headCid) + "\n"
    out = out + "manifest_root_cid=" + layout.fixedBytes32Hex(universe.worldHead.manifestRootCid) + "\n"
    out = out + "compiler_pkg_cid=" + layout.fixedBytes32Hex(universe.compilerSnapshot.snapshotCid) + "\n"
    out = out + "std_pkg_cid=" + layout.fixedBytes32Hex(universe.stdSnapshot.snapshotCid) + "\n"
    out = out + "runtime_pkg_cid=" + layout.fixedBytes32Hex(universe.runtimeSnapshot.snapshotCid) + "\n"
    out = out + "manifest_entry_count=" + intToStr(universe.manifest.entryCount)
    return out
