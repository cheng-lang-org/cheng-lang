import std/os
import std/system
import std/strings
import std/strutils as strutil

type
    PathSplitFileResult =
        dir: str
        name: str
        ext: str

fn PathSplitFileResultMake(dir: str, name: str, ext: str): PathSplitFileResult =
    var out: PathSplitFileResult
    out.dir = dir
    out.name = name
    out.ext = ext
    return out

fn PathTrim(raw: str): str =
    return strutil.Strip(raw)

fn PathNonEmpty(raw: str): bool =
    return PathTrim(raw) != ""

fn TextSlice(text: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    return NewStringCopy(SystemPtrAdd(StrDataPtr(text), start), count)

fn TextStartsWith(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn TextContains(text: str, sub: str): bool =
    if sub == "":
        return true
    if text.len < sub.len:
        return false
    for i in 0..<(text.len - sub.len + 1):
        var matched = true
        for j in 0..<sub.len:
            if text[i + j] != sub[j]:
                matched = false
                break
        if matched:
            return true
    return false

fn PathCurrentDir(): str =
    return os.GetCurrentDir()

@importc("cheng_os_is_absolute_bridge")
fn PathIsAbsolute(raw: str): bool

fn PathSegmentIsParent(path: str, start: int32, stop: int32): bool =
    if stop - start != 2:
        return false
    return path[start] == '.' && path[start + 1] == '.'

fn PathHasParentTraversal(raw: str): bool =
    let path = PathTrim(raw)
    if !PathNonEmpty(path):
        return false
    var segmentStart: int32
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            if PathSegmentIsParent(path, segmentStart, i):
                return true
            segmentStart = i + 1
    return PathSegmentIsParent(path, segmentStart, path.len)

fn PathJoin(left: str, right: str): str =
    let leftPath = PathTrim(left)
    let rightPath = PathTrim(right)
    return os.JoinPath(leftPath, rightPath)

fn PathRootedAbsolute(root: str, raw: str): str =
    let rootPath = PathTrim(root)
    let text = PathTrim(raw)
    if !PathNonEmpty(rootPath) || !PathNonEmpty(text):
        return ""
    if PathIsAbsolute(text):
        return ""
    if PathHasParentTraversal(text):
        return ""
    return PathJoin(rootPath, text)

fn PathAbsolute(root: str, raw: str): str =
    let text: str = PathTrim(raw)
    if !PathNonEmpty(text):
        return ""
    if PathIsAbsolute(text):
        return text
    return PathJoin(root, text)

fn PathFileExists(pathRaw: str): bool =
    let path = PathTrim(pathRaw)
    if !PathNonEmpty(path):
        return false
    return os.FileExists(path)

fn PathDirExists(pathRaw: str): bool =
    let path = PathTrim(pathRaw)
    if !PathNonEmpty(path):
        return false
    return os.DirExists(path)

fn PathFileSize(pathRaw: str): int64 =
    let path = PathTrim(pathRaw)
    if !PathNonEmpty(path):
        return Int64(0)
    return os.FileSize(path)

fn PathExists(root: str, raw: str): bool =
    let path: str = PathAbsolute(root, raw)
    if !PathNonEmpty(path):
        return false
    return PathFileExists(path) || PathDirExists(path)

fn FileExistsNonEmpty(root: str, raw: str): bool =
    let path: str = PathAbsolute(root, raw)
    if !PathFileExists(path):
        return false
    return PathFileSize(path) > Int64(0)

fn PathLastSep(path: str): int32 =
    var last: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            last = i
    return last

fn PathLastDot(name: str): int32 =
    var last: int32 = -1
    for i in 0..<name.len:
        if name[i] == '.':
            last = i
    return last

fn PathBaseName(pathRaw: str): str =
    let path = PathTrim(pathRaw)
    if !PathNonEmpty(path):
        return ""
    let lastSep = PathLastSep(path)
    if lastSep < 0:
        return path
    return TextSlice(path, lastSep + 1, path.len - (lastSep + 1))

fn PathParentDir(pathRaw: str): str =
    let path = PathTrim(pathRaw)
    if !PathNonEmpty(path):
        return ""
    let lastSep = PathLastSep(path)
    if lastSep < 0:
        return ""
    if lastSep == 0:
        return ""
    return TextSlice(path, 0, lastSep)

fn PathSplitFile(pathRaw: str): PathSplitFileResult =
    let path = PathTrim(pathRaw)
    let base = PathBaseName(path)
    let dir = PathParentDir(path)
    if !PathNonEmpty(base):
        return PathSplitFileResultMake(dir, "", "")
    let lastDot = PathLastDot(base)
    if lastDot <= 0:
        return PathSplitFileResultMake(dir, base, "")
    return PathSplitFileResultMake(dir,
                                   TextSlice(base, 0, lastDot),
                                   TextSlice(base, lastDot, base.len - lastDot))

fn PathCreateDirAll(path: str): bool =
    if !PathNonEmpty(path):
        return false
    if os.DirExists(path):
        return true
    let parent = os.ParentDir(path)
    if PathNonEmpty(parent) && parent != path && !os.DirExists(parent):
        if !PathCreateDirAll(parent):
            return false
    if !os.DirExists(path):
        os.CreateDir(path)
    return os.DirExists(path)

fn MkdirP(root: str, raw: str): bool =
    let path: str = PathAbsolute(root, raw)
    if !PathNonEmpty(path):
        return false
    return PathCreateDirAll(path)

fn MkdirRooted(root: str, raw: str): bool =
    let path: str = PathRootedAbsolute(root, raw)
    if !PathNonEmpty(path):
        return false
    return PathCreateDirAll(path)

fn WriteTextFile(root: str, raw: str, text: str): bool =
    let path: str = PathAbsolute(root, raw)
    if !PathNonEmpty(path):
        return false
    let parent: str = PathParentDir(path)
    if PathNonEmpty(parent):
        if !PathCreateDirAll(parent):
            return false
    os.WriteFile(path, text)
    return PathFileExists(path)

fn WriteRootedTextFile(root: str, raw: str, text: str): bool =
    let path: str = PathRootedAbsolute(root, raw)
    if !PathNonEmpty(path):
        return false
    let parent: str = PathParentDir(path)
    if PathNonEmpty(parent):
        if !PathCreateDirAll(parent):
            return false
    os.WriteFile(path, text)
    return PathFileExists(path)

fn ReadTextFile(root: str, raw: str): str =
    let path: str = PathAbsolute(root, raw)
    if !PathFileExists(path):
        return ""
    return os.ReadFile(path)

fn ReadRootedTextFile(root: str, raw: str): str =
    let path: str = PathRootedAbsolute(root, raw)
    if !PathFileExists(path):
        return ""
    return os.ReadFile(path)
