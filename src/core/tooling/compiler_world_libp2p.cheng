import std/result
import std/rawbytes
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as btypes
import cheng/chain/lsmr_types as lt
import cheng/chain/pubsub
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/libp2p/protocols/gossipsub as gossip
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/system_link_exec as sexec

type
    CompilerManagedMirrorBundleUnit =
        relSourcePath: str
        sourceText: str

    CompilerManagedMirrorBundle =
        version: int32
        channel: str
        packageId: str
        migrationProofCid: layout.FixedBytes32
        unitCount: int32
        units: CompilerManagedMirrorBundleUnit[]
        migrationText: str
        migrationCsgText: str
        migrationSurfaceText: str
        migrationReceiptText: str
        proofText: str
        lockText: str

    CompilerWorldFreshNodeSyncState =
        syncedEntryCount: int32
        syncedHead: cworld.CompilerWorldHead
        syncedManifest: cworld.CompilerUniverseManifest
        syncedReceipt: ccsg.CompileReceipt
        materializedMirrorCount: int32

fn CompilerWorldTopicScope(): overlay.OverlayTopicScope =
    return overlay.OverlayScopeGlobal

fn CompilerWorldAddress(): btypes.LsmrAddress =
    return btypes.LsmrAddress()

fn CompilerWorldQuery(sourcePeerId: core.Libp2pPeerId): overlay.StoreQuery =
    var query = overlay.StoreQuery()
    query.sourcePeerId = sourcePeerId.value
    query.topicScope = CompilerWorldTopicScope()
    query.address = CompilerWorldAddress()
    return query

fn CompilerWorldPayloadCid(payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(bytesLen(payload) + 32)
    layout.ByteBufAppendBytes(buf, payload)
    return lt.FixedCidFromBuf(buf)

fn CompilerWorldIngress(sourcePeerId: core.Libp2pPeerId,
                          payloadKind: int32,
                          payloadReport: str,
                          stampEpoch: int32,
                          stampGanzhi: int32): overlay.IngressEnvelope =
    let payload = cworld.CompilerWorldOwnedBytesFromText(payloadReport)
    var ingress = overlay.IngressEnvelope()
    ingress.sourcePeerId = sourcePeerId.value
    ingress.topicScope = CompilerWorldTopicScope()
    ingress.address = CompilerWorldAddress()
    ingress.payloadKind = payloadKind
    ingress.payload = payload
    ingress.payloadCid = CompilerWorldPayloadCid(payload)
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = stampEpoch
    ingress.stampGanzhi = stampGanzhi
    return ingress

fn CompilerWorldMirrorPackageManifestText(packageIdRaw: str): str =
    let packageId = chengpath.PathTrim(packageIdRaw)
    var modulePrefix = chengpath.PathBaseName(packageId)
    if len(modulePrefix) <= 0:
        modulePrefix = "pkg"
    return strutil.Join(["package_id = \"pkg://", packageId, "\"\nmodule_prefix = \"", modulePrefix, "\"\n"], "")

fn CompilerWorldHexTextEncode(text: str): str =
    return rawbytes.BytesToHex(rawbytes.BytesFromString(text))

fn CompilerWorldHexValue(ch: uint8): int32 =
    if ch >= uint8('0') && ch <= uint8('9'):
        return int32(ch) - int32('0')
    if ch >= uint8('a') && ch <= uint8('f'):
        return 10 + (int32(ch) - int32('a'))
    if ch >= uint8('A') && ch <= uint8('F'):
        return 10 + (int32(ch) - int32('A'))
    return -1

fn CompilerWorldHexTextDecode(textRaw: str,
                                outText: var str): Result[bool] =
    let text = chengpath.PathTrim(textRaw)
    if len(text) <= 0:
        outText = ""
        return Ok[bool](true)
    if (len(text) % 2) != 0:
        return Err[bool](" compiler world libp2p: invalid hex length")
    var outBytes = rawbytes.BytesAlloc(len(text) / 2)
    var i: int32
    while i < len(text):
        let hi = CompilerWorldHexValue(uint8(text[i]))
        let lo = CompilerWorldHexValue(uint8(text[i + 1]))
        if hi < 0 || lo < 0:
            return Err[bool](" compiler world libp2p: invalid hex payload")
        rawbytes.BytesSet(outBytes, i / 2, (hi * 16) + lo)
        i = i + 2
    outText = rawbytes.BytesToString(outBytes)
    return Ok[bool](true)

fn compilerWorldLibp2pLineValue(text: str,
                                  key: str): str =
    let lines = strutil.Split(text, '\n')
    let prefix = strutil.Join([key, "="], "")
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if !strutil.StartsWith(line, prefix):
            continue
        return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
    return ""

fn CompilerWorldManagedMirrorBundleReport(bundle: CompilerManagedMirrorBundle): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "channel=", bundle.channel, "\n"], "")
    out = strutil.Join([out, "package_id=", bundle.packageId, "\n"], "")
    out = strutil.Join([out, "migration_proof_cid=", layout.FixedBytes32Hex(bundle.migrationProofCid), "\n"], "")
    out = strutil.Join([out, "unit_count=", IntToStr(bundle.unitCount), "\n"], "")
    for i in 0..<bundle.units.len:
        out = Fmt"{out}unit[{IntToStr(i)}].rel_source_path={bundle.units[i].relSourcePath}\n"
        out = strutil.Join([out, "unit[", IntToStr(i), "].source_text_hex=", CompilerWorldHexTextEncode(bundle.units[i].sourceText), "\n"], "")
    out = strutil.Join([out, "migration_text_hex=", CompilerWorldHexTextEncode(bundle.migrationText), "\n"], "")
    out = strutil.Join([out, "migration_csg_text_hex=", CompilerWorldHexTextEncode(bundle.migrationCsgText), "\n"], "")
    out = strutil.Join([out, "migration_surface_text_hex=", CompilerWorldHexTextEncode(bundle.migrationSurfaceText), "\n"], "")
    out = strutil.Join([out, "migration_receipt_text_hex=", CompilerWorldHexTextEncode(bundle.migrationReceiptText), "\n"], "")
    out = strutil.Join([out, "proof_text_hex=", CompilerWorldHexTextEncode(bundle.proofText), "\n"], "")
    out = strutil.Join([out, "lock_text_hex=", CompilerWorldHexTextEncode(bundle.lockText)], "")
    return out

fn CompilerWorldManagedMirrorBundleFromReportText(text: str,
                                                    out: var CompilerManagedMirrorBundle): Result[bool] =
    let channelRes = cworld.CompilerWorldNormalizeChannel(compilerWorldLibp2pLineValue(text, "channel"))
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let packageId = compilerWorldLibp2pLineValue(text, "package_id")
    if len(packageId) <= 0:
        return Err[bool](" compiler world libp2p: mirror bundle package_id missing")
    let proofRes = layout.FixedBytes32FromHex(compilerWorldLibp2pLineValue(text, "migration_proof_cid"))
    if IsErr(proofRes):
        return Err[bool](" compiler world libp2p: invalid mirror bundle proof cid")
    let unitCountText = compilerWorldLibp2pLineValue(text, "unit_count")
    if len(unitCountText) <= 0:
        return Err[bool](" compiler world libp2p: mirror bundle unit_count missing")
    let unitCount = int32(strutil.ParseInt(unitCountText))
    var units: CompilerManagedMirrorBundleUnit[]
    for i in 0..<unitCount:
        let relSourcePath = compilerWorldLibp2pLineValue(text, strutil.Join(["unit[", IntToStr(i), "].rel_source_path"], ""))
        if len(relSourcePath) <= 0:
            return Err[bool](" compiler world libp2p: mirror bundle rel source path missing")
        var sourceText = ""
        let decodeSourceRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text,
                                                                                       strutil.Join(["unit[", IntToStr(i), "].source_text_hex"], "")),
                                                           sourceText)
        if IsErr(decodeSourceRes):
            return Err[bool](Error(decodeSourceRes))
        var unit: CompilerManagedMirrorBundleUnit
        unit.relSourcePath = relSourcePath
        unit.sourceText = sourceText
        add(units, unit)
    var migrationText = ""
    let migrationTextRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "migration_text_hex"),
                                                        migrationText)
    if IsErr(migrationTextRes):
        return Err[bool](Error(migrationTextRes))
    var migrationCsgText = ""
    let migrationCsgRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "migration_csg_text_hex"),
                                                       migrationCsgText)
    if IsErr(migrationCsgRes):
        return Err[bool](Error(migrationCsgRes))
    var migrationSurfaceText = ""
    let migrationSurfaceRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "migration_surface_text_hex"),
                                                           migrationSurfaceText)
    if IsErr(migrationSurfaceRes):
        return Err[bool](Error(migrationSurfaceRes))
    var migrationReceiptText = ""
    let migrationReceiptRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "migration_receipt_text_hex"),
                                                           migrationReceiptText)
    if IsErr(migrationReceiptRes):
        return Err[bool](Error(migrationReceiptRes))
    var proofText = ""
    let proofTextRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "proof_text_hex"),
                                                    proofText)
    if IsErr(proofTextRes):
        return Err[bool](Error(proofTextRes))
    var lockText = ""
    let lockTextRes = CompilerWorldHexTextDecode(compilerWorldLibp2pLineValue(text, "lock_text_hex"),
                                                   lockText)
    if IsErr(lockTextRes):
        return Err[bool](Error(lockTextRes))
    out.version = 1
    out.channel = Value(channelRes)
    out.packageId = packageId
    out.migrationProofCid = Value(proofRes)
    out.unitCount = unitCount
    out.units = units
    out.migrationText = migrationText
    out.migrationCsgText = migrationCsgText
    out.migrationSurfaceText = migrationSurfaceText
    out.migrationReceiptText = migrationReceiptText
    out.proofText = proofText
    out.lockText = lockText
    return Ok[bool](true)

fn CompilerWorldRegister(hostRef: var host.Libp2pHost) =
    host.Libp2pRegisterHandler(hostRef, core.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(hostRef, core.Libp2pProtocolIngress)

fn CompilerWorldPublishEntry(hostRef: var host.Libp2pHost,
                               ingress: overlay.IngressEnvelope,
                               announceHead: bool) =
    host.Libp2pStorePut(hostRef, ingress)
    host.Libp2pKadProvide(hostRef, ingress.payloadCid)
    if !announceHead:
        return
    let pubRecord = gossip.Libp2pPubRecordFromIngress(hostRef.selfPeerId, ingress)
    host.Libp2pPublish(hostRef, pubRecord)

fn CompilerWorldManagedMirrorProofCid(manifest: cworld.CompilerUniverseManifest,
                                        packageId: str): layout.FixedBytes32 =
    for i in 0..<manifest.entries.len:
        if manifest.entries[i].packageId == packageId:
            return manifest.entries[i].migrationProofCid
    return layout.FixedBytes32()

fn CompilerWorldManagedMirrorSourceList(rootDir: str,
                                          mirrorRoot: str): Result[str[]] =
    let sourceListPath = chengpath.PathJoin(mirrorRoot, "sources.list.txt")
    if !chengpath.PathFileExists(sourceListPath):
        return Err[str[]](strutil.Join([" compiler world libp2p: missing managed mirror sources list: ", sourceListPath], ""))
    let lines = strutil.Split(chengpath.ReadTextFile("", sourceListPath), '\n')
    var out: str[]
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if len(line) <= 0:
            continue
        add(out, line)
    return Ok[str[]](out)

fn CompilerWorldManagedMirrorOptionalText(path: str): str =
    if !chengpath.PathFileExists(path):
        return ""
    return chengpath.ReadTextFile("", path)

fn CompilerWorldManagedMirrorBundlesForPlan(plan: sexec.SystemLinkExecPlan): Result[CompilerManagedMirrorBundle[]] =
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(plan.systemLinkPlan)
    var out: CompilerManagedMirrorBundle[]
    for i in 0..<externalPackageRoots.len:
        let mirrorRoot = chengpath.PathAbsolute("", externalPackageRoots[i].packageRoot)
        let sourcesRes = CompilerWorldManagedMirrorSourceList("", mirrorRoot)
        if IsErr(sourcesRes):
            return Err[CompilerManagedMirrorBundle[]](Error(sourcesRes))
        let relSourcePaths = Value(sourcesRes)
        var units: CompilerManagedMirrorBundleUnit[]
        for j in 0..<relSourcePaths.len:
            let sourcePath = chengpath.PathJoin(mirrorRoot, relSourcePaths[j])
            if !chengpath.PathFileExists(sourcePath):
                return Err[CompilerManagedMirrorBundle[]](strutil.Join([" compiler world libp2p: missing managed mirror source: ", sourcePath], ""))
            var unit: CompilerManagedMirrorBundleUnit
            unit.relSourcePath = relSourcePaths[j]
            unit.sourceText = chengpath.ReadTextFile("", sourcePath)
            add(units, unit)
        var bundle: CompilerManagedMirrorBundle
        bundle.version = 1
        bundle.channel = plan.localUniverse.worldHead.channel
        bundle.packageId = externalPackageRoots[i].packageId
        bundle.migrationProofCid = CompilerWorldManagedMirrorProofCid(plan.localUniverse.manifest,
                                                                        bundle.packageId)
        bundle.unitCount = units.len
        bundle.units = units
        bundle.migrationText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "migration.txt"))
        bundle.migrationCsgText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "migration.csg.txt"))
        bundle.migrationSurfaceText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "migration.surface.txt"))
        bundle.migrationReceiptText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "migration.receipt.txt"))
        bundle.proofText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "proof.txt"))
        bundle.lockText = CompilerWorldManagedMirrorOptionalText(chengpath.PathJoin(mirrorRoot, "cheng.lock.toml"))
        add(out, bundle)
    return Ok[CompilerManagedMirrorBundle[]](out)

fn CompilerWorldWriteManagedMirrorBundleFiles(rootDir: str,
                                                prefix: str,
                                                bundles: CompilerManagedMirrorBundle[]): bool =
    if bundles.len <= 0:
        return true
    var indexText = strutil.Join(["count=", IntToStr(bundles.len)], "")
    for i in 0..<bundles.len:
        let bundlePath = strutil.Join([prefix, ".managed_mirror.", IntToStr(i), ".txt"], "")
        if !chengpath.WriteTextFile(rootDir,
                                   bundlePath,
                                   strutil.Join([CompilerWorldManagedMirrorBundleReport(bundles[i]), "\n"], "")):
            return false
        indexText = strutil.Join([indexText, "\npackage[", IntToStr(i), "].package_id=", bundles[i].packageId], "")
        indexText = strutil.Join([indexText, "\npackage[", IntToStr(i), "].migration_proof_cid=", layout.FixedBytes32Hex(bundles[i].migrationProofCid)], "")
        indexText = strutil.Join([indexText, "\npackage[", IntToStr(i), "].bundle_path=", bundlePath], "")
    return chengpath.WriteTextFile(rootDir, strutil.Join([prefix, ".managed_mirror.index.txt"], ""), strutil.Join([indexText, "\n"], ""))

fn CompilerWorldManagedMirrorBundlePathsFromIndexText(text: str): Result[str[]] =
    let countText = compilerWorldLibp2pLineValue(text, "count")
    if len(countText) <= 0:
        return Err[str[]](" compiler world libp2p: mirror bundle index count missing")
    let count = int32(strutil.ParseInt(countText))
    var out: str[]
    for i in 0..<count:
        let bundlePath = compilerWorldLibp2pLineValue(text, strutil.Join(["package[", IntToStr(i), "].bundle_path"], ""))
        if len(bundlePath) <= 0:
            return Err[str[]](" compiler world libp2p: mirror bundle index path missing")
        add(out, bundlePath)
    return Ok[str[]](out)

fn CompilerWorldManagedMirrorBundlesFromBundlePrefix(rootDir: str,
                                                       prefix: str): Result[CompilerManagedMirrorBundle[]] =
    let indexPath = strutil.Join([prefix, ".managed_mirror.index.txt"], "")
    if !chengpath.PathFileExists(chengpath.PathAbsolute(rootDir, indexPath)):
        var empty: CompilerManagedMirrorBundle[]
        return Ok[CompilerManagedMirrorBundle[]](empty)
    let bundlePathsRes = CompilerWorldManagedMirrorBundlePathsFromIndexText(chengpath.ReadTextFile(rootDir, indexPath))
    if IsErr(bundlePathsRes):
        return Err[CompilerManagedMirrorBundle[]](Error(bundlePathsRes))
    var out: CompilerManagedMirrorBundle[]
    let bundlePaths = Value(bundlePathsRes)
    for i in 0..<bundlePaths.len:
        if !chengpath.PathFileExists(chengpath.PathAbsolute(rootDir, bundlePaths[i])):
            return Err[CompilerManagedMirrorBundle[]](strutil.Join([" compiler world libp2p: missing mirror bundle file: ", bundlePaths[i]], ""))
        var bundle: CompilerManagedMirrorBundle
        let parseRes = CompilerWorldManagedMirrorBundleFromReportText(chengpath.ReadTextFile(rootDir, bundlePaths[i]),
                                                                        bundle)
        if IsErr(parseRes):
            return Err[CompilerManagedMirrorBundle[]](Error(parseRes))
        add(out, bundle)
    return Ok[CompilerManagedMirrorBundle[]](out)

fn CompilerWorldManagedMirrorMaterialize(rootDir: str,
                                           bundle: CompilerManagedMirrorBundle): Result[str] =
    let mirrorRoot = cworld.CompilerManagedMirrorRoot(rootDir,
                                                        bundle.channel,
                                                        bundle.packageId,
                                                        bundle.migrationProofCid)
    if !chengpath.MkdirP("", chengpath.PathJoin(mirrorRoot, "src")):
        return Err[str](strutil.Join([" compiler world libp2p: failed to mkdir managed mirror: ", mirrorRoot], ""))
    if !chengpath.WriteTextFile(rootDir,
                               chengpath.PathJoin(mirrorRoot, "cheng-package.toml"),
                               CompilerWorldMirrorPackageManifestText(bundle.packageId)):
        return Err[str](" compiler world libp2p: failed to write managed mirror manifest")
    var sourcesList = ""
    for i in 0..<bundle.units.len:
        let sourcePath = chengpath.PathJoin(mirrorRoot, bundle.units[i].relSourcePath)
        let sourceDir = chengpath.PathParentDir(sourcePath)
        if !chengpath.MkdirP("", sourceDir):
            return Err[str](" compiler world libp2p: failed to mkdir mirror source dir")
        if !chengpath.WriteTextFile(rootDir, sourcePath, bundle.units[i].sourceText):
            return Err[str](strutil.Join([" compiler world libp2p: failed to write mirror source: ", sourcePath], ""))
        if len(sourcesList) > 0:
            sourcesList = strutil.Join([sourcesList, "\n"], "")
        sourcesList = strutil.Join([sourcesList, bundle.units[i].relSourcePath], "")
    if !chengpath.WriteTextFile(rootDir,
                               chengpath.PathJoin(mirrorRoot, "sources.list.txt"),
                               strutil.Join([sourcesList, "\n"], "")):
        return Err[str](" compiler world libp2p: failed to write mirror source list")
    if len(bundle.migrationText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "migration.txt"), bundle.migrationText):
        return Err[str](" compiler world libp2p: failed to write mirror migration report")
    if len(bundle.migrationCsgText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "migration.csg.txt"), bundle.migrationCsgText):
        return Err[str](" compiler world libp2p: failed to write mirror migration csg")
    if len(bundle.migrationSurfaceText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "migration.surface.txt"), bundle.migrationSurfaceText):
        return Err[str](" compiler world libp2p: failed to write mirror migration surface")
    if len(bundle.migrationReceiptText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "migration.receipt.txt"), bundle.migrationReceiptText):
        return Err[str](" compiler world libp2p: failed to write mirror migration receipt")
    if len(bundle.proofText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "proof.txt"), bundle.proofText):
        return Err[str](" compiler world libp2p: failed to write mirror proof")
    if len(bundle.lockText) > 0 &&
       !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRoot, "cheng.lock.toml"), bundle.lockText):
        return Err[str](" compiler world libp2p: failed to write mirror lock")
    return Ok[str](mirrorRoot)

fn CompilerWorldManagedMirrorBundlesFromHost(hostRef: host.Libp2pHost): Result[CompilerManagedMirrorBundle[]] =
    var out: CompilerManagedMirrorBundle[]
    for i in 0..<hostRef.storeEntries.len:
        let ingress = hostRef.storeEntries[i].ingress
        if ingress.payloadKind != pubsub.PubSubPayloadKindCompilerManagedMirrorBundle:
            continue
        var bundle: CompilerManagedMirrorBundle
        let parseRes = CompilerWorldManagedMirrorBundleFromReportText(cworld.CompilerWorldOwnText(rawbytes.BytesToString(ingress.payload)),
                                                                        bundle)
        if IsErr(parseRes):
            return Err[CompilerManagedMirrorBundle[]](Error(parseRes))
        add(out, bundle)
    return Ok[CompilerManagedMirrorBundle[]](out)

fn CompilerWorldMaterializeManagedMirrorBundles(rootDir: str,
                                                  bundles: CompilerManagedMirrorBundle[]): Result[int32] =
    var count = 0
    for i in 0..<bundles.len:
        let materializeRes = CompilerWorldManagedMirrorMaterialize(rootDir, bundles[i])
        if IsErr(materializeRes):
            return Err[int32](Error(materializeRes))
        count = count + 1
    return Ok[int32](count)

fn CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir: str,
                                                                  prefix: str): Result[int32] =
    let bundlesRes = CompilerWorldManagedMirrorBundlesFromBundlePrefix(rootDir, prefix)
    if IsErr(bundlesRes):
        return Err[int32](Error(bundlesRes))
    return CompilerWorldMaterializeManagedMirrorBundles(rootDir, Value(bundlesRes))

fn CompilerWorldManagedMirrorMaterializeReport(prefix: str,
                                                 materializedMirrorCount: int32): str =
    var out = ""
    out = strutil.Join([out, "bundle_prefix=", prefix, "\n"], "")
    out = strutil.Join([out, "managed_mirror_count=", IntToStr(materializedMirrorCount)], "")
    return out

fn CompilerWorldPublishUniverseWithManagedMirrorBundles(hostRef: var host.Libp2pHost,
                                                          universe: cworld.CompilerLocalUniverse,
                                                          compilerCsg: ccsg.CompilerCsg,
                                                          exportSurface: ccsg.CsgExportSurface,
                                                          receipt: ccsg.CompileReceipt,
                                                          managedMirrorBundles: CompilerManagedMirrorBundle[]) =
    let stampEpoch = universe.worldHead.headEpoch
    let stampGanzhi = 1
    let worldIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                              pubsub.PubSubPayloadKindCompilerWorldHead,
                                              cworld.CompilerWorldHeadReport(universe.worldHead),
                                              stampEpoch,
                                              stampGanzhi)
    CompilerWorldPublishEntry(hostRef, worldIngress, true)
    let manifestIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                 pubsub.PubSubPayloadKindCompilerUniverseManifest,
                                                 cworld.CompilerUniverseManifestReport(universe.manifest),
                                                 stampEpoch,
                                                 stampGanzhi)
    CompilerWorldPublishEntry(hostRef, manifestIngress, false)
    let compilerIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                 pubsub.PubSubPayloadKindCompilerPackageSnapshot,
                                                 cworld.CompilerPackageSnapshotReport(universe.compilerSnapshot),
                                                 stampEpoch,
                                                 stampGanzhi)
    CompilerWorldPublishEntry(hostRef, compilerIngress, false)
    let stdIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                            pubsub.PubSubPayloadKindCompilerPackageSnapshot,
                                            cworld.CompilerPackageSnapshotReport(universe.stdSnapshot),
                                            stampEpoch,
                                            stampGanzhi)
    CompilerWorldPublishEntry(hostRef, stdIngress, false)
    let runtimeIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.PubSubPayloadKindCompilerPackageSnapshot,
                                                cworld.CompilerPackageSnapshotReport(universe.runtimeSnapshot),
                                                stampEpoch,
                                                stampGanzhi)
    CompilerWorldPublishEntry(hostRef, runtimeIngress, false)
    let csgIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                            pubsub.PubSubPayloadKindCompilerCsg,
                                            ccsg.CompilerCsgWireReport(compilerCsg),
                                            stampEpoch,
                                            stampGanzhi)
    CompilerWorldPublishEntry(hostRef, csgIngress, false)
    let surfaceIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.PubSubPayloadKindCompilerExportSurface,
                                                ccsg.CompilerExportSurfaceReport(exportSurface),
                                                stampEpoch,
                                                stampGanzhi)
    CompilerWorldPublishEntry(hostRef, surfaceIngress, false)
    let receiptIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.PubSubPayloadKindCompilerCompileReceipt,
                                                ccsg.CompileReceiptReport(receipt),
                                                stampEpoch,
                                                stampGanzhi)
    CompilerWorldPublishEntry(hostRef, receiptIngress, false)
    for i in 0..<managedMirrorBundles.len:
        let mirrorIngress = CompilerWorldIngress(hostRef.selfPeerId,
                                                   pubsub.PubSubPayloadKindCompilerManagedMirrorBundle,
                                                   CompilerWorldManagedMirrorBundleReport(managedMirrorBundles[i]),
                                                   stampEpoch,
                                                   stampGanzhi)
        CompilerWorldPublishEntry(hostRef, mirrorIngress, false)

fn CompilerWorldPublishUniverse(hostRef: var host.Libp2pHost,
                                  universe: cworld.CompilerLocalUniverse,
                                  compilerCsg: ccsg.CompilerCsg,
                                  exportSurface: ccsg.CsgExportSurface,
                                  receipt: ccsg.CompileReceipt) =
    var managedMirrorBundles: CompilerManagedMirrorBundle[]
    CompilerWorldPublishUniverseWithManagedMirrorBundles(hostRef,
                                                           universe,
                                                           compilerCsg,
                                                           exportSurface,
                                                           receipt,
                                                           managedMirrorBundles)

fn CompilerWorldStoredEntryCount(hostRef: host.Libp2pHost): int32 =
    let query = CompilerWorldQuery(hostRef.selfPeerId)
    return host.Libp2pStoreQueryCount(hostRef, query)

fn CompilerWorldPublishedHeadCount(hostRef: host.Libp2pHost): int32 =
    var out = 0
    for i in 0..<hostRef.publishLog.len:
        if hostRef.publishLog[i].payloadKind == pubsub.PubSubPayloadKindCompilerWorldHead:
            out = out + 1
    return out

fn CompilerWorldFirstPayloadTextByKind(hostRef: host.Libp2pHost,
                                         payloadKind: int32,
                                         outText: var str): bool =
    for i in 0..<hostRef.storeEntries.len:
        let ingress = hostRef.storeEntries[i].ingress
        if ingress.payloadKind != payloadKind:
            continue
        outText = cworld.CompilerWorldOwnText(rawbytes.BytesToString(ingress.payload))
        return true
    outText = ""
    return false

fn CompilerWorldSync(localHost: var host.Libp2pHost,
                       remoteHost: var host.Libp2pHost,
                       remotePeerId: core.Libp2pPeerId): Result[int32] =
    var entries: overlay.IngressEnvelope[]
    let query = CompilerWorldQuery(localHost.selfPeerId)
    let syncRes = host.Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(syncRes):
        return Err[int32](Error(syncRes))
    for i in 0..<entries.len:
        host.Libp2pStorePut(localHost, entries[i])
    return Ok[int32](entries.len)

fn CompilerWorldSyncSmokeReport(rootDir: str,
                                  sourcePath: str,
                                  outputPath: str): Result[str] =
    let packageRoot = rootDir
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(rootDir, req)
    if IsErr(planRes):
        return Err[str](Error(planRes))
    let plan = Value(planRes)
    let mirrorBundlesRes = CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(mirrorBundlesRes):
        return Err[str](Error(mirrorBundlesRes))
    let mirrorBundles = Value(mirrorBundlesRes)
    var seedHost = host.Libp2pHostInit("compiler-world-seed")
    var syncHost = host.Libp2pHostInit("compiler-world-sync")
    CompilerWorldRegister(seedHost)
    CompilerWorldRegister(syncHost)
    var seedAddr: core.Libp2pMultiaddr
    var syncAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", 6461)
    multiaddr.Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", 6462)
    let seedListenRes = host.Libp2pListen(seedHost, seedAddr)
    if IsErr(seedListenRes):
        return Err[str](Error(seedListenRes))
    let syncListenRes = host.Libp2pListen(syncHost, syncAddr)
    if IsErr(syncListenRes):
        return Err[str](Error(syncListenRes))
    let dialSeedRes = host.Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)
    if IsErr(dialSeedRes):
        return Err[str](Error(dialSeedRes))
    let dialSyncRes = host.Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)
    if IsErr(dialSyncRes):
        return Err[str](Error(dialSyncRes))
    CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                           plan.localUniverse,
                                                           plan.compilerCsg,
                                                           plan.exportSurface,
                                                           plan.compileReceipt,
                                                           mirrorBundles)
    let syncRes = CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    var worldText = ""
    if !CompilerWorldFirstPayloadTextByKind(syncHost,
                                              pubsub.PubSubPayloadKindCompilerWorldHead,
                                              worldText):
        return Err[str](" compiler world libp2p: missing synced world head")
    var parsedHead: cworld.CompilerWorldHead
    let parseHeadRes = cworld.CompilerWorldHeadFromReportText(worldText, parsedHead)
    if IsErr(parseHeadRes):
        return Err[str](Error(parseHeadRes))
    if !layout.FixedBytes32Equal(parsedHead.headCid, plan.localUniverse.worldHead.headCid):
        return Err[str](" compiler world libp2p: synced head cid mismatch")
    var manifestText = ""
    if !CompilerWorldFirstPayloadTextByKind(syncHost,
                                              pubsub.PubSubPayloadKindCompilerUniverseManifest,
                                              manifestText):
        return Err[str](" compiler world libp2p: missing synced manifest")
    var parsedManifest: cworld.CompilerUniverseManifest
    let parseManifestRes = cworld.CompilerUniverseManifestFromReportText(manifestText, parsedManifest)
    if IsErr(parseManifestRes):
        return Err[str](strutil.Join([" compiler world libp2p: parse manifest failed: ", Error(parseManifestRes)], ""))
    if !layout.FixedBytes32Equal(parsedManifest.manifestCid, plan.localUniverse.manifest.manifestCid):
        return Err[str](" compiler world libp2p: synced manifest cid mismatch")
    return Ok[str](Fmt"""
    seed_entries={IntToStr(CompilerWorldStoredEntryCount(seedHost))}
    sync_entries={IntToStr(CompilerWorldStoredEntryCount(syncHost))}
    published_heads={IntToStr(CompilerWorldPublishedHeadCount(seedHost))}
    synced_entries={IntToStr(Value(syncRes))}
    world_head_cid={layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid)}
    manifest_root_cid={layout.FixedBytes32Hex(parsedManifest.manifestCid)}
    manifest_entry_count={IntToStr(parsedManifest.entryCount)}
    managed_mirror_count={IntToStr(mirrorBundles.len)}
    receipt_cid={layout.FixedBytes32Hex(plan.compileReceipt.receiptCid)}
    """)

fn CompilerWorldFreshNodeSyncPublished(seedHost: var host.Libp2pHost,
                                         freshHost: var host.Libp2pHost,
                                         localUniverse: cworld.CompilerLocalUniverse,
                                         compilerCsg: ccsg.CompilerCsg,
                                         exportSurface: ccsg.CsgExportSurface,
                                         receipt: ccsg.CompileReceipt,
                                         mirrorBundles: CompilerManagedMirrorBundle[]): Result[int32] =
    CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                           localUniverse,
                                                           compilerCsg,
                                                           exportSurface,
                                                           receipt,
                                                           mirrorBundles)
    return CompilerWorldSync(freshHost, seedHost, seedHost.selfPeerId)

fn CompilerWorldFreshNodeSyncedState(rootDir: str,
                                       freshHost: host.Libp2pHost,
                                       localUniverse: cworld.CompilerLocalUniverse,
                                       receipt: ccsg.CompileReceipt,
                                       syncedEntryCount: int32): Result[CompilerWorldFreshNodeSyncState] =
    var worldText = ""
    if !CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.PubSubPayloadKindCompilerWorldHead,
                                              worldText):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: missing fresh world head")
    worldText = cworld.CompilerWorldOwnText(worldText)
    var receiptText = ""
    if !CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.PubSubPayloadKindCompilerCompileReceipt,
                                              receiptText):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: missing fresh receipt")
    receiptText = cworld.CompilerWorldOwnText(receiptText)
    var syncedHead: cworld.CompilerWorldHead
    let parseHeadRes = cworld.CompilerWorldHeadFromReportText(worldText, syncedHead)
    if IsErr(parseHeadRes):
        return Err[CompilerWorldFreshNodeSyncState](strutil.Join([" compiler world libp2p: parse fresh head failed: ", Error(parseHeadRes)], ""))
    if !layout.FixedBytes32Equal(syncedHead.headCid, localUniverse.worldHead.headCid):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: fresh node head cid mismatch")
    var manifestText = ""
    if !CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.PubSubPayloadKindCompilerUniverseManifest,
                                              manifestText):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: missing fresh manifest")
    manifestText = cworld.CompilerWorldOwnText(manifestText)
    var syncedManifest: cworld.CompilerUniverseManifest
    let parseManifestRes = cworld.CompilerUniverseManifestFromReportText(manifestText, syncedManifest)
    if IsErr(parseManifestRes):
        return Err[CompilerWorldFreshNodeSyncState](strutil.Join([" compiler world libp2p: parse fresh manifest failed: ", Error(parseManifestRes)], ""))
    if !layout.FixedBytes32Equal(syncedManifest.manifestCid, localUniverse.manifest.manifestCid):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: fresh manifest cid mismatch")
    var syncedReceipt: ccsg.CompileReceipt
    let parseReceiptRes = ccsg.CompileReceiptFromReportText(receiptText, syncedReceipt)
    if IsErr(parseReceiptRes):
        return Err[CompilerWorldFreshNodeSyncState](strutil.Join([" compiler world libp2p: parse fresh receipt failed: ", Error(parseReceiptRes)], ""))
    if !ccsg.CompileReceiptEquivalent(receipt, syncedReceipt):
        return Err[CompilerWorldFreshNodeSyncState](" compiler world libp2p: synced receipt drift")
    let syncedMirrorBundlesRes = CompilerWorldManagedMirrorBundlesFromHost(freshHost)
    if IsErr(syncedMirrorBundlesRes):
        return Err[CompilerWorldFreshNodeSyncState](Error(syncedMirrorBundlesRes))
    let materializeRes = CompilerWorldMaterializeManagedMirrorBundles(rootDir, Value(syncedMirrorBundlesRes))
    if IsErr(materializeRes):
        return Err[CompilerWorldFreshNodeSyncState](Error(materializeRes))
    var state: CompilerWorldFreshNodeSyncState
    state.syncedEntryCount = syncedEntryCount
    state.syncedHead = syncedHead
    state.syncedManifest = syncedManifest
    state.syncedReceipt = syncedReceipt
    state.materializedMirrorCount = Value(materializeRes)
    return Ok[CompilerWorldFreshNodeSyncState](state)

fn CompilerWorldFreshNodeRebuild(rootDir: str,
                                   req: creq.CompilerRequest,
                                   localUniverse: cworld.CompilerLocalUniverse,
                                   syncedHead: cworld.CompilerWorldHead,
                                   channelRaw: str): Result[ccsg.CompileReceipt] =
    let requestedWorldHead = cworld.CompilerWorldOwnText(layout.FixedBytes32Hex(syncedHead.headCid))
    let sourcePath = cworld.CompilerWorldOwnText(req.sourcePath)
    let freshOutputPath = cworld.CompilerWorldOwnText(strutil.Join([req.outputPath, ".fresh_node"], ""))
    let freshLockPath = cworld.CompilerWorldOwnText(strutil.Join([freshOutputPath, ".lock.toml"], ""))
    let targetTriple = cworld.CompilerWorldOwnText(req.targetTriple)
    if !chengpath.WriteTextFile(rootDir, freshLockPath, cworld.CompilerLockText(localUniverse)):
        return Err[ccsg.CompileReceipt](strutil.Join([" compiler world libp2p: failed to write fresh rebuild lock: ", freshLockPath], ""))
    let freshReq = creq.CompilerRequestNew(req.rootDir,
                                             sourcePath,
                                             freshOutputPath,
                                             targetTriple,
                                             req.emitKind,
                                             "")
    let freshPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                          freshReq,
                                                                          requestedWorldHead,
                                                                          freshLockPath,
                                                                          "",
                                                                          channelRaw)
    if IsErr(freshPlanRes):
        return Err[ccsg.CompileReceipt](strutil.Join([" compiler world libp2p: fresh rebuild plan failed: ", Error(freshPlanRes)], ""))
    return Ok[ccsg.CompileReceipt](Value(freshPlanRes).compileReceipt)

fn CompilerWorldFreshNodeReportText(seedHost: host.Libp2pHost,
                                      freshHost: host.Libp2pHost,
                                      receipt: ccsg.CompileReceipt,
                                      state: CompilerWorldFreshNodeSyncState,
                                      freshReceipt: ccsg.CompileReceipt): str =
    var out = ""
    out = strutil.Join([out, "seed_entries=", IntToStr(CompilerWorldStoredEntryCount(seedHost)), "\n"], "")
    out = strutil.Join([out, "fresh_entries=", IntToStr(CompilerWorldStoredEntryCount(freshHost)), "\n"], "")
    out = strutil.Join([out, "published_heads=", IntToStr(CompilerWorldPublishedHeadCount(seedHost)), "\n"], "")
    out = strutil.Join([out, "synced_entries=", IntToStr(state.syncedEntryCount), "\n"], "")
    out = strutil.Join([out, "world_head_cid=", layout.FixedBytes32Hex(state.syncedHead.headCid), "\n"], "")
    out = strutil.Join([out, "manifest_root_cid=", layout.FixedBytes32Hex(state.syncedManifest.manifestCid), "\n"], "")
    out = strutil.Join([out, "manifest_entry_count=", IntToStr(state.syncedManifest.entryCount), "\n"], "")
    out = strutil.Join([out, "managed_mirror_count=", IntToStr(state.materializedMirrorCount), "\n"], "")
    out = strutil.Join([out, "seed_receipt_cid=", layout.FixedBytes32Hex(receipt.receiptCid), "\n"], "")
    out = strutil.Join([out, "synced_receipt_cid=", layout.FixedBytes32Hex(state.syncedReceipt.receiptCid), "\n"], "")
    out = strutil.Join([out, "fresh_receipt_cid=", layout.FixedBytes32Hex(freshReceipt.receiptCid), "\n"], "")
    out = strutil.Join([out, "receipt_equivalent=1\n"], "")
    out = strutil.Join([out, "receipt_cid_match=1"], "")
    return out

fn CompilerWorldFreshNodeSelfhostReport(rootDir: str,
                                          req: creq.CompilerRequest,
                                          plan: sexec.SystemLinkExecPlan): Result[str] =
    var seedHost = host.Libp2pHostInit("compiler-world-seed")
    var freshHost = host.Libp2pHostInit("compiler-world-fresh")
    CompilerWorldRegister(seedHost)
    CompilerWorldRegister(freshHost)
    let localUniverse = plan.localUniverse
    let compilerCsg = plan.compilerCsg
    let exportSurface = plan.exportSurface
    let receipt = plan.compileReceipt
    let mirrorBundlesRes = CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(mirrorBundlesRes):
        return Err[str](Error(mirrorBundlesRes))
    let mirrorBundles = Value(mirrorBundlesRes)
    let channelRaw = localUniverse.worldHead.channel
    var seedAddr: core.Libp2pMultiaddr
    var freshAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", 6463)
    multiaddr.Libp2pMultiaddrFillTcp(freshAddr, "127.0.0.1", 6464)
    let seedListenRes = host.Libp2pListen(seedHost, seedAddr)
    if IsErr(seedListenRes):
        return Err[str](Error(seedListenRes))
    let freshListenRes = host.Libp2pListen(freshHost, freshAddr)
    if IsErr(freshListenRes):
        return Err[str](Error(freshListenRes))
    let dialSeedRes = host.Libp2pDial(freshHost, seedHost.selfPeerId, seedAddr, 1)
    if IsErr(dialSeedRes):
        return Err[str](Error(dialSeedRes))
    let dialFreshRes = host.Libp2pDial(seedHost, freshHost.selfPeerId, freshAddr, 1)
    if IsErr(dialFreshRes):
        return Err[str](Error(dialFreshRes))
    let syncRes = CompilerWorldFreshNodeSyncPublished(seedHost,
                                                        freshHost,
                                                        localUniverse,
                                                        compilerCsg,
                                                        exportSurface,
                                                        receipt,
                                                        mirrorBundles)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    let stateRes = CompilerWorldFreshNodeSyncedState(rootDir,
                                                       freshHost,
                                                       localUniverse,
                                                       receipt,
                                                       Value(syncRes))
    if IsErr(stateRes):
        return Err[str](Error(stateRes))
    let state = Value(stateRes)
    let freshReceiptRes = CompilerWorldFreshNodeRebuild(rootDir,
                                                          req,
                                                          localUniverse,
                                                          state.syncedHead,
                                                          channelRaw)
    if IsErr(freshReceiptRes):
        return Err[str](Error(freshReceiptRes))
    let freshReceipt = Value(freshReceiptRes)
    if !ccsg.CompileReceiptEquivalent(state.syncedReceipt, freshReceipt):
        return Err[str](" compiler world libp2p: fresh rebuild receipt drift")
    if !layout.FixedBytes32Equal(state.syncedReceipt.receiptCid, freshReceipt.receiptCid):
        return Err[str](" compiler world libp2p: fresh rebuild receipt cid mismatch")
    return Ok[str](CompilerWorldFreshNodeReportText(seedHost,
                                                      freshHost,
                                                      receipt,
                                                      state,
                                                      freshReceipt))
