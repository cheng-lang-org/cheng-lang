    return chengpath.PathAbsolute(rootDir, "src/core/runtime/debug_runtime.cheng")

fn BootstrapStage0Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage0")

fn BootstrapStage1Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage1")

fn BootstrapStage2Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage2")

fn BootstrapStage3Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")

fn BootstrapEnvPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/bootstrap.env")

fn BootstrapSnapshotPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/bootstrap_snapshot.txt")

fn BootstrapBackendDriverOutPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")

fn BootstrapChainNodeOutPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/cheng_node_main/cheng_node_main")

fn BootstrapArtifactNew(kind: BootstrapArtifactKind, stage: BootstrapStage,
                          path: str, executable: bool): BootstrapArtifact =
    return BootstrapArtifact(kind: kind, stage: stage, path: path, executable: executable)

fn BootstrapSnapshotDefault(rootDir: str): BootstrapSnapshot =
    return BootstrapSnapshot(
        rootDir: rootDir,
        targetTriple: BootstrapDefaultTarget(),
        bootstrapMode: "selfhost",
        stage1Source: BootstrapArtifactNew(
            ArtifactStage1Source, Stage1, BootstrapStage1SourcePath(rootDir), false),
        stage0Compiler: BootstrapArtifactNew(
            ArtifactStage0Compiler, Stage0, BootstrapStage0Path(rootDir), true),
        stage1Compiler: BootstrapArtifactNew(
            ArtifactStage1Compiler, Stage1, BootstrapStage1Path(rootDir), true),
        stage2Compiler: BootstrapArtifactNew(
            ArtifactStage2Compiler, Stage2, BootstrapStage2Path(rootDir), true),
        stage3Compiler: BootstrapArtifactNew(
            ArtifactStage3Compiler, Stage3, BootstrapStage3Path(rootDir), true),
        bootstrapEnv: BootstrapArtifactNew(
            ArtifactBootstrapEnv, Stage3, BootstrapEnvPath(rootDir), false),
        backendDriverOut: BootstrapArtifactNew(
            ArtifactBackendDriver, Stage2, BootstrapBackendDriverOutPath(rootDir), true),
        chainNodeOut: BootstrapArtifactNew(
            ArtifactChainNode, Stage2, BootstrapChainNodeOutPath(rootDir), true)
    )

fn BootstrapStageText(stage: BootstrapStage): str =
    if stage == Stage0:
        return "stage0"
    if stage == Stage1:
        return "stage1"
    if stage == Stage2:
        return "stage2"
    return "stage3"

fn BootstrapArtifactKindText(kind: BootstrapArtifactKind): str =
    if kind == ArtifactStage1Source:
        return "stage1_source"
    if kind == ArtifactStage0Compiler:
        return "stage0"
    if kind == ArtifactStage1Compiler:
        return "stage1"
    if kind == ArtifactStage2Compiler:
        return "stage2"
    if kind == ArtifactStage3Compiler:
        return "stage3"
    if kind == ArtifactBootstrapEnv:
        return "bootstrap_env"
    if kind == ArtifactBackendDriver:
        return "backend_driver"
    return "chain_node"

fn BootstrapArtifactReady(artifact: BootstrapArtifact): bool =
    if !os.FileExists(artifact.path):
        return false
    return os.FileSize(artifact.path) > int64(0)

fn BootstrapPathSetAdd(out: var str[], pathRaw: str) =
    let path: str = chengpath.PathTrim(pathRaw)
    if len(path) <= 0:
        return
    for i in 0..<out.len:
        if out[i] == path:
            return
    add(out, path)

fn BootstrapAppendOrdinaryClosure(packageRoot: str,
                                    sourcePath: str,
                                    out: var str[],
                                    err: var str): bool =
    var parsed: parser.ParsedSourceStub
    if !parser.ParseOrdinarySourceStub(packageRoot, sourcePath, parsed, err):
        return false
    for i in 0..<parsed.orderedClosureSourcePaths.len:
        BootstrapPathSetAdd(out, parsed.orderedClosureSourcePaths[i])
    err = ""
    return true

fn BootstrapOrdinaryClosurePaths(packageRoot: str,
                                   sourcePath: str,
                                   out: var str[],
                                   err: var str): bool =
    out = []
    err = ""
    return BootstrapAppendOrdinaryClosure(packageRoot, sourcePath, out, err)

fn BootstrapChainNodeFreshInputPaths(rootDir: str,
                                       out: var str[],
                                       err: var str): bool =
    let packageRoot: str = rootDir
    return BootstrapOrdinaryClosurePaths(packageRoot,
                                           BootstrapChainNodeEntrySourcePath(rootDir),
                                           out,
                                           err)

fn BootstrapFreshInputPaths(rootDir: str, out: var str[], err: var str): bool =
    out = []
    err = ""
    BootstrapPathSetAdd(out, BootstrapSeedSourcePath(rootDir))
    BootstrapPathSetAdd(out, BootstrapStage1SourcePath(rootDir))
    let packageRoot: str = rootDir
    if !BootstrapAppendOrdinaryClosure(packageRoot,
                                         BootstrapCompilerEntrySourcePath(rootDir),
                                         out,
                                         err):
        return false
    if !BootstrapAppendOrdinaryClosure(packageRoot,
                                         BootstrapGateMainSourcePath(rootDir),
                                         out,
                                         err):
        return false
    return true

fn BootstrapJoinCsv(items: str[]): str =
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = out + ","
        out = out + items[i]
    return out

fn BootstrapFreshInputPathsCsv(rootDir: str, err: var str): str =
    var paths: str[]
    if !BootstrapFreshInputPaths(rootDir, paths, err):
        return ""
    err = ""
    return BootstrapJoinCsv(paths)

fn BootstrapLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32
    var i: int32
    while i <= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if len(line) >= len(prefix):
                if strings.SliceBytes(line, 0, len(prefix)) == prefix:
                    return strings.SliceBytes(line, len(prefix), len(line) - len(prefix))
            start = i + 1
        i = i + 1
    return ""

fn BootstrapCachedFreshInputPaths(rootDir: str, out: var str[]): bool =
    out = []
    let snapshotPath: str = BootstrapSnapshotPath(rootDir)
    if !chengpath.PathFileExists(snapshotPath):
        return false
    let snapshotText: str = chengpath.ReadTextFile(rootDir, snapshotPath)
    let raw: str = strutil.Strip(BootstrapLineValue(snapshotText, "fresh_input_paths"))
    if len(raw) <= 0:
        return false
    var start: int32
    let n = len(raw)
    var i = 0
    while i <= n:
        var itemEnd = false
        if i == n:
            itemEnd = true
        elif raw[i] == ',':
            itemEnd = true
        if !itemEnd:
            i = i + 1
            continue
        let item: str = strutil.Strip(strings.SliceBytes(raw, start, i - start))
        if len(item) > 0:
            BootstrapPathSetAdd(out, item)
        start = i + 1
        i = i + 1
    return out.len > 0

fn BootstrapBridgeReady(snapshot: BootstrapSnapshot): bool =
    return BootstrapArtifactReady(snapshot.stage2Compiler) &&
           BootstrapArtifactReady(snapshot.stage3Compiler) &&
           BootstrapArtifactReady(snapshot.bootstrapEnv)

fn BootstrapSnapshotReport(snapshot: BootstrapSnapshot): str =
    var out = ""
    out = out + "target=" + snapshot.targetTriple + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + BootstrapCompilerEntrySourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_runtime_source=" + BootstrapCompilerRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_support_matrix_source=" + BootstrapCompilerSupportMatrixSourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_request_source=" + BootstrapCompilerRequestSourcePath(snapshot.rootDir) + "\n"
    out = out + "tooling_gate_source=" + BootstrapGateMainSourcePath(snapshot.rootDir) + "\n"
    out = out + "lang_parser_source=" + LangParserSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_system_link_plan_source=" + BackendSystemLinkPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_lowering_plan_source=" + BackendLoweringPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_primary_object_plan_source=" + BackendPrimaryObjectPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_object_plan_source=" + BackendObjectPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_native_link_plan_source=" + BackendNativeLinkPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_system_link_exec_source=" + BackendSystemLinkExecSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_core_runtime_source=" + RuntimeCoreRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_compiler_runtime_source=" + RuntimeCompilerRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_debug_runtime_source=" + RuntimeDebugRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "bootstrap_env=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "bootstrap_snapshot=" + BootstrapSnapshotPath(snapshot.rootDir) + "\n"
    out = out + "backend_driver_out=" + snapshot.backendDriverOut.path + "\n"
    out = out + "chain_node_out=" + snapshot.chainNodeOut.path + "\n"
    return out
