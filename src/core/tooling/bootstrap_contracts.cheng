import std/os
import std/strutils as strutil
import std/strings
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser as parser

type
    BootstrapStage = enum
        Stage0
        Stage1
        Stage2
        Stage3

    BootstrapArtifactKind = enum
        ArtifactStage1Source
        ArtifactStage0Compiler
        ArtifactStage1Compiler
        ArtifactStage2Compiler
        ArtifactStage3Compiler
        ArtifactBootstrapEnv
        ArtifactBackendDriver
        ArtifactChainNode

    BootstrapArtifact =
        kind: BootstrapArtifactKind
        stage: BootstrapStage
        path: str
        executable: bool

    BootstrapSnapshot =
        rootDir: str
        targetTriple: str
        bootstrapMode: str
        stage1Source: BootstrapArtifact
        stage0Compiler: BootstrapArtifact
        stage1Compiler: BootstrapArtifact
        stage2Compiler: BootstrapArtifact
        stage3Compiler: BootstrapArtifact
        bootstrapEnv: BootstrapArtifact
        backendDriverOut: BootstrapArtifact
        chainNodeOut: BootstrapArtifact

fn BootstrapDetectHostTarget(): str =
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = arm64", "") == 0:
        return "arm64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = aarch64", "") == 0:
        return "arm64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = x86_64", "") == 0:
        return "x86_64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = amd64", "") == 0:
        return "x86_64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = aarch64", "") == 0:
        return "aarch64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = arm64", "") == 0:
        return "aarch64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = x86_64", "") == 0:
        return "x86_64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = amd64", "") == 0:
        return "x86_64-unknown-linux-gnu"
    return ""

fn BootstrapNormalizeTargetAlias(targetRaw: str): str =
    let trimmed: str = strutil.Strip(targetRaw)
    if len(trimmed) <= 0 || trimmed == "auto" || trimmed == "host" || trimmed == "native":
        let detected = BootstrapDetectHostTarget()
        if len(detected) > 0:
            return detected
        return "arm64-apple-darwin"
    if trimmed == "darwin_arm64" || trimmed == "darwin_aarch64":
        return "arm64-apple-darwin"
    if trimmed == "darwin_x86_64" || trimmed == "darwin_amd64":
        return "x86_64-apple-darwin"
    if trimmed == "linux_arm64" || trimmed == "linux_aarch64":
        return "aarch64-unknown-linux-gnu"
    if trimmed == "linux_x86_64" || trimmed == "linux_amd64":
        return "x86_64-unknown-linux-gnu"
    if trimmed == "windows_arm64" || trimmed == "windows_aarch64":
        return "aarch64-pc-windows-msvc"
    if trimmed == "windows_x86_64" || trimmed == "windows_amd64":
        return "x86_64-pc-windows-msvc"
    return trimmed

fn BootstrapDefaultTarget(): str =
    if os.GetEnv("CHENG_TARGET") != "":
        return os.GetEnv("CHENG_TARGET")
    if os.GetEnv("BACKEND_TARGET") != "":
        return os.GetEnv("BACKEND_TARGET")
    if BootstrapDetectHostTarget() != "":
        return BootstrapDetectHostTarget()
    return "arm64-apple-darwin"

fn BootstrapOutDir(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap")

fn BootstrapSeedSourcePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "bootstrap/cheng_seed.c")

fn BootstrapStage1SourceRelPath(): str =
    return "bootstrap/stage1_bootstrap.cheng"

fn BootstrapStage1SourceDefaultPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, BootstrapStage1SourceRelPath())

fn BootstrapStage1SourcePath(rootDir: str): str =
    let snapshotPath: str = BootstrapSnapshotPath(rootDir)
    if chengpath.PathFileExists(snapshotPath):
        let snapshotText: str = chengpath.ReadTextFile(rootDir, snapshotPath)
        let stage1Path: str = strutil.Strip(BootstrapLineValue(snapshotText, "stage1_source"))
        if len(stage1Path) > 0:
            return stage1Path
    return BootstrapStage1SourceDefaultPath(rootDir)

fn BootstrapCompilerEntrySourcePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_main.cheng")

fn BootstrapBackendDriverEntrySourcePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "src/core/tooling/backend_driver_main.cheng")

fn BootstrapChainNodeEntrySourcePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "src/apps/chain_node/cheng_node_main.cheng")

fn BootstrapCompilerRuntimeSourcePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_runtime.cheng")

