fn SeedOrphanVerifyTooling(root: str): int32 =
    let toolingDir = chengpath.PathAbsolute(root, "tools")
    if !os.DirExists(toolingDir):
        SeedOrphanPrintErr("[cheng_seed] verify-orphan-guard open failed: " + toolingDir)
        return 1
    let bannedEntries = SeedOrphanBannedEntries()
    let entries = os.WalkDir(toolingDir)
    for i in 0..<entries.len:
        let entry = os.WalkDirEntry(entries, i)
        let path = os.WalkDirEntryPath(entry)
        let parts = os.SplitFile(path)
        let fileName = parts.name + parts.ext
        if SeedOrphanTextEqualsAny(fileName, bannedEntries):
            SeedOrphanPrintErr("verify_orphan_guard: banned tooling entry name: " + path)
            return 1
        if parts.ext == ".sh":
            SeedOrphanPrintErr("verify_orphan_guard: shell tooling entry not allowed: " + path)
            return 1
        if parts.ext != ".py":
            continue
        let kind = os.WalkDirEntryKind(entry)
        if kind != os.PathComponent(0) && kind != os.PathComponent(2):
            continue
        let text = chengpath.ReadTextFile("", path)
        if os.FileSize(path) > int64(0) && len(text) <= 0:
            SeedOrphanPrintErr("[cheng_seed] verify-orphan-guard read failed: " + path)
            return 1
        if SeedOrphanTextContainsAny(text, bannedEntries):
            SeedOrphanPrintErr("verify_orphan_guard: banned direct process guard ref in " + path)
            return 1
    return 0

fn SeedOrphanRunStage3(root: str,
                         label: str,
                         args: str[],
                         logPath: str): int32 =
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    if !chengpath.FileExistsNonEmpty(root, stage3):
        SeedOrphanPrintErr("verify_orphan_guard: missing stage3: " + stage3)
        return 1
    let run = hostops.RunFileLogged(root, label, stage3, args, [], root, 0, logPath)
    if !hostops.LoggedRunOk(run):
        SeedOrphanPrintErr(hostops.LoggedRunSummary(run))
        return run.exitCode
    return 0

fn SeedOrphanGuardRun(rootDir: str): int32 =
    let root = strutil.Strip(rootDir)
    if len(root) <= 0:
        SeedOrphanPrintErr("verify_orphan_guard: missing root")
        return 1
    if SeedOrphanVerifyTooling(root) != 0:
        return 1
    var orphanBefore: str[]
    if SeedOrphanReadSnapshot(root,
                               "orphan_guard_before",
                               "artifacts/gate/orphan_guard_before.log",
                               orphanBefore) != 0:
        return 1
    if SeedOrphanRunStage3(root,
                            "orphan_guard_bootstrap_bridge",
                            ["bootstrap-bridge"],
                            "artifacts/gate/orphan_guard_bootstrap_bridge.log") != 0:
        return 1
    if SeedOrphanRunStage3(root,
                            "orphan_guard_build_backend_driver",
                            ["build-backend-driver"],
                            "artifacts/gate/orphan_guard_build_backend_driver.log") != 0:
        return 1
    var orphanAfter: str[]
    if SeedOrphanReadSnapshot(root,
                               "orphan_guard_after",
                               "artifacts/gate/orphan_guard_after.log",
                               orphanAfter) != 0:
        return 1
    let orphanDelta = SeedOrphanCollectNew(orphanBefore, orphanAfter)
    if orphanDelta.len > 0:
        SeedOrphanPrintErr("verify_orphan_guard: new Cheng U/UE process leaked after bootstrap/build")
        for i in 0..<orphanDelta.len:
            SeedOrphanPrintErr(orphanDelta[i])
        return 1
    SeedOrphanPrintLine("verify_orphan_guard ok")
    return 0
