import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn SeedOrphanPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn SeedOrphanPrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn SeedOrphanTextContainsAny(text: str, needles: str[]): bool =
    for i in 0..<needles.len:
        if chengpath.TextContains(text, needles[i]):
            return true
    return false

fn SeedOrphanTextEqualsAny(text: str, needles: str[]): bool =
    for i in 0..<needles.len:
        if text == needles[i]:
            return true
    return false

fn SeedOrphanAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn SeedOrphanSkipSpaces(line: str, cursorRaw: int32): int32 =
    var cursor = cursorRaw
    while cursor < len(line):
        if !SeedOrphanAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    return cursor

fn SeedOrphanNextField(line: str,
                         cursorRaw: int32,
                         fieldOut: var str,
                         nextOut: var int32): bool =
    var cursor = SeedOrphanSkipSpaces(line, cursorRaw)
    if cursor >= len(line):
        fieldOut = ""
        nextOut = cursor
        return false
    let start = cursor
    while cursor < len(line):
        if SeedOrphanAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    fieldOut = strings.SliceBytes(line, start, cursor - start)
    nextOut = cursor
    return len(fieldOut) > 0

fn SeedOrphanSnapshotKey(root: str,
                           lineRaw: str): str =
    let line = strutil.Strip(lineRaw)
    if len(line) <= 0 || !chengpath.TextContains(line, root):
        return ""
    var cursor: int32
    var pid = ""
    var ppid = ""
    var state = ""
    var elapsed = ""
    if !SeedOrphanNextField(line, cursor, pid, cursor):
        return ""
    if !SeedOrphanNextField(line, cursor, ppid, cursor):
        return ""
    if !SeedOrphanNextField(line, cursor, state, cursor):
        return ""
    if !SeedOrphanNextField(line, cursor, elapsed, cursor):
        return ""
    if ppid != "1":
        return ""
    if len(state) <= 0 || state[0] != 'U':
        return ""
    cursor = SeedOrphanSkipSpaces(line, cursor)
    if cursor >= len(line):
        return ""
    let commandText = strings.SliceBytes(line, cursor, len(line) - cursor)
    return pid + "|" + commandText

fn SeedOrphanNormalizeSnapshot(root: str,
                                 text: str): str[] =
    var out: str[]
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let key = SeedOrphanSnapshotKey(root, lines[i])
        if len(key) > 0:
            add(out, key)
    return out

fn SeedOrphanFilterSnapshot(root: str,
                              text: str): str =
    var out = ""
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = lines[i]
        let key = SeedOrphanSnapshotKey(root, line)
        if len(key) > 0:
            out = out + line + "\n"
    return out

fn SeedOrphanSeqContains(items: str[],
                           value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn SeedOrphanCollectNew(before: str[],
                          after: str[]): str[] =
    var out: str[]
    for i in 0..<after.len:
        let key = after[i]
        if !SeedOrphanSeqContains(before, key) && !SeedOrphanSeqContains(out, key):
            add(out, key)
    return out

fn SeedOrphanReadSnapshot(root: str,
                            label: str,
                            logPath: str,
                            outLines: var str[]): int32 =
    let run = hostops.RunProgramLogged(root,
                                         label,
                                         "ps",
                                         ["-Ao", "pid=,ppid=,state=,etime=,command="],
                                         [],
                                         root,
                                         10,
                                         logPath)
    if !hostops.LoggedRunOk(run):
        SeedOrphanPrintErr(hostops.LoggedRunSummary(run))
        outLines = []
        return run.exitCode
    let filtered = SeedOrphanFilterSnapshot(root, run.output)
    if !chengpath.WriteTextFile(root, logPath, filtered):
        SeedOrphanPrintErr("[cheng_seed] verify-orphan-guard snapshot failed log=" + chengpath.PathAbsolute(root, logPath))
        outLines = []
        return 1
    outLines = SeedOrphanNormalizeSnapshot(root, filtered)
    return 0

