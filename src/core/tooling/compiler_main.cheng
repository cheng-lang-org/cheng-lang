@importc("get_stdout")
fn CompilerStdoutBridge(): os.File
@importc("get_stderr")
fn CompilerStderrBridge(): os.File
@importc("paramCount")
fn CompilerParamCountBridge(): int32

fn CompilerPrintLine(text: str) =
    os.WriteLine(CompilerStdoutBridge(), text)

fn CompilerPrintErr(text: str) =
    os.WriteLine(CompilerStderrBridge(), text)

fn CompilerConcat3(left: str, middle: str, right: str): str =
    return strutil.Join([left, middle, right], "")

fn CompilerPathSetAdd(out: var str[],
                        pathRaw: str) =
    let path = chengpath.PathTrim(pathRaw)
    if len(path) <= 0:
        return
    for i in 0..<out.len:
        if out[i] == path:
            return
    add(out, path)

fn CompilerPathSetHas(paths: str[],
                        pathRaw: str): bool =
    let path = chengpath.PathTrim(pathRaw)
    if len(path) <= 0:
        return false
    for i in 0..<paths.len:
        if paths[i] == path:
            return true
    return false

fn CompilerPathSetsEqual(left: str[],
                           right: str[]): bool =
    if left.len != right.len:
        return false
    for i in 0..<left.len:
        if !CompilerPathSetHas(right, left[i]):
            return false
    return true

fn CompilerAppendOrdinaryClosure(packageRoot: str,
                                   sourcePath: str,
                                   out: var str[],
                                   err: var str): bool =
    var parsed: parser.ParsedSourceStub
    if !parser.ParseOrdinarySourceStub(packageRoot, sourcePath, parsed, err):
        return false
    for i in 0..<parsed.orderedClosureSourcePaths.len:
        CompilerPathSetAdd(out, parsed.orderedClosureSourcePaths[i])
    err = ""
    return true

fn CompilerPrintBlock(text: str) =
    var start: int32
    var i: int32
    for i in i..<= text.len:
        let atEnd: bool = i == text.len
        if atEnd:
            let line: str = strings.SliceBytes(text, start, i - start)
            CompilerPrintLine(line)
            start = i + 1
        elif text[i] == '\n':
            let line: str = strings.SliceBytes(text, start, i - start)
            CompilerPrintLine(line)
            start = i + 1

fn CompilerRoot(): str =
    return rootdisco.CompilerRootAuto()

fn CompilerUsage(rootDir: str) =
    let lines = crun.CompilerUsageLines(rootDir)
    for i in 0..<lines.len:
        CompilerPrintLine(lines[i])

