fn CompilerTextContainsAll(text: str,
                             needles: str[]): bool =
    for i in 0..<needles.len:
        if !strutil.Contains(text, needles[i]):
            return false
    return true

fn CompilerBuildPlanCoreLine(line: str): bool =
    if strutil.StartsWith(line, "target="):
        return true
    if strutil.StartsWith(line, "linker="):
        return true
    if strutil.StartsWith(line, "stage2_compiler="):
        return true
    if strutil.StartsWith(line, "entry="):
        return true
    if strutil.StartsWith(line, "output="):
        return true
    if strutil.StartsWith(line, "source["):
        return true
    return false

fn CompilerBuildPlanCoreText(text: str): str =
    let lines = strutil.Split(text, '\n')
    var out: str[]
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if CompilerBuildPlanCoreLine(line):
            add(out, line)
    return strutil.Join(out, "\n")

fn CompilerRemovePathTree(path: str): bool =
    if !chengpath.PathNonEmpty(path):
        return true
    if os.FileExists(path):
        return os.RemoveFile(path)
    if !os.DirExists(path):
        return true
    let entries = os.WalkDir(path)
    for i in 0..<entries.len:
        let entry = os.WalkDirEntry(entries, i)
        let child = os.WalkDirEntryPath(entry)
        let kind = os.WalkDirEntryKind(entry)
        if kind == os.PcDir || kind == os.PcLinkToDir:
            if !CompilerRemovePathTree(child):
                return false
        elif kind == os.PcFile || kind == os.PcLinkToFile:
            if !os.RemoveFile(child):
                return false
    os.RemoveDir(path)
    return !os.DirExists(path)

fn CompilerCleanHostrunArtifacts(rootDir: str,
                                   smokeNames: str[]): bool =
    let hostrunDir = chengpath.PathAbsolute(rootDir, "artifacts/hostrun")
    if !os.DirExists(hostrunDir):
        return true
    let entries = os.WalkDir(hostrunDir)
    for i in 0..<entries.len:
        let entry = os.WalkDirEntry(entries, i)
        let child = os.WalkDirEntryPath(entry)
        let leaf = os.ExtractFilename(child)
        for j in 0..<smokeNames.len:
            if strutil.StartsWith(leaf, smokeNames[j]):
                if !CompilerRemovePathTree(child):
                    return false
                break
    return true

fn CompilerRequestFromRuntimeFlags(workspaceRoot: str,
                                     requireOutput: bool): Result[creq.CompilerRequest] =
    let sourcePath = cmdline.ReadFlagOrDefault("--in", "")
    if len(sourcePath) <= 0:
        return Err[creq.CompilerRequest](" compiler: missing --in")
    let packageRootRaw = cmdline.ReadFlagOrDefault("--root", creq.CompilerDefaultPackageRoot(workspaceRoot))
    let packageRoot = creq.CompilerResolvePackageRoot(workspaceRoot, sourcePath, packageRootRaw)
    let outputPath = cmdline.ReadFlagOrDefault("--out", "")
    if requireOutput && len(outputPath) <= 0:
        return Err[creq.CompilerRequest](" compiler: missing --out")
    let targetTriple = CompilerRequestedTarget()
    let emitText = cmdline.ReadFlagOrDefault("--emit", "exe")
    let emitKindRes = creq.CompilerEmitFromText(emitText)
    if IsErr(emitKindRes):
        return Err[creq.CompilerRequest](Error(emitKindRes))
    let reportPath = cmdline.ReadFlagOrDefault("--report-out", "")
    let symbolVisibilityRes = creq.CompilerSymbolVisibilityFromText(cmdline.ReadFlagOrDefault("--symbol-visibility", ""))
    if IsErr(symbolVisibilityRes):
        return Err[creq.CompilerRequest](Error(symbolVisibilityRes))
    return Ok[creq.CompilerRequest](creq.CompilerRequestWithSymbolVisibility(creq.CompilerRequestNew(packageRoot,
                                                                sourcePath,
                                                                outputPath,
                                                                targetTriple,
                                                                Value(emitKindRes),
                                                                reportPath),
                                                                Value(symbolVisibilityRes)))

fn CompilerBuildSystemPlanFromRuntimeFlags(rootDir: str,
                                             req: creq.CompilerRequest): Result[sexec.SystemLinkExecPlan] =
    CompilerApplyProgressEnvFromArgs(rootDir,
                                       CompilerCollectArgsFrom(2, CompilerParamCountBridge()))
    return sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              cmdline.ReadFlagOrDefault("--world-head", ""),
                                                              cmdline.ReadFlagOrDefault("--lock", ""),
                                                              cmdline.ReadFlagOrDefault("--baseline-surface", ""),
                                                              cmdline.ReadFlagOrDefault("--channel", "stable"))

fn CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir: str,
                                                           req: creq.CompilerRequest): Result[sexec.SystemLinkExecPlan] =
    CompilerApplyProgressEnvFromArgs(rootDir,
                                       CompilerCollectArgsFrom(2, CompilerParamCountBridge()))
    return sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              cmdline.ReadFlagOrDefault("--world-head", ""),
                                                              cmdline.ReadFlagOrDefault("--lock", ""),
                                                              "",
                                                              cmdline.ReadFlagOrDefault("--channel", "stable"))

fn CompilerCollectArgsFrom(startIndex: int32,
                             count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn CompilerBuildSystemPlan(rootDir: str,
                             req: creq.CompilerRequest,
                             args: str[]): Result[sexec.SystemLinkExecPlan] =
    CompilerApplyProgressEnvFromArgs(rootDir, args)
    return sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              creq.CompilerWorldHeadFromArgs(args),
                                                              creq.CompilerLockPathFromArgs(args),
                                                              creq.CompilerBaselineSurfacePathFromArgs(args),
                                                              creq.CompilerChannelFromArgs(args))

fn CompilerRequestWithAbsoluteSourcePath(rootDir: str,
                                          req: creq.CompilerRequest): creq.CompilerRequest =
    var out = req
    out.sourcePath = chengpath.PathAbsolute(rootDir, req.sourcePath)
    return out

fn CompilerRunSystemLinkExec(rootDir: str,
                               req: var creq.CompilerRequest,
                               args: str[]): int32 =
    req = CompilerRequestWithAbsoluteSourcePath(rootDir, req)
    let planRes: Result[sexec.SystemLinkExecPlan] = CompilerBuildSystemPlan(rootDir, req, args)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    var plan = Value(planRes)
    let bridgeCompiler = CompilerBridgeCompilerPath(rootDir)
    var progressText = ""
    var bridgeReport = ""
    if len(req.reportPath) > 0:
        bridgeReport = CompilerSystemLinkExecBridgeMergeReport(plan)
    let privateImportDiagnostics = CompilerSystemLinkExecPrivateImportDiagnostics(plan)
    if privateImportDiagnostics.len > 0:
        if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
            CompilerPrintErr(strutil.Join([" compiler: failed to write report: ", req.reportPath], ""))
            return 2
        for i in 0..<privateImportDiagnostics.len:
            CompilerPrintErr(privateImportDiagnostics[i])
        return 2
    CompilerProgressEmit(rootDir, progressText, "execute", "begin")
    CompilerProgressEmit(rootDir, progressText, "browser_bridge_prepare", "begin")
    if !CompilerMaterializeBrowserBridgeOutputs(rootDir, plan):
        if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
            CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
            return 2
        CompilerPrintErr(" compiler: failed to materialize browser bridge outputs")
        return 2
    CompilerProgressEmit(rootDir, progressText, "browser_bridge_prepare", "done")
    let browserBridgeObjectPath = sexec.SystemLinkExecBrowserBridgeObjectPath(plan)
    let pureRc = CompilerTryRunPureSystemLinkExec(rootDir, req, plan)
    if pureRc >= 0:
        CompilerProgressEmit(rootDir, progressText, "execute", "done")
        return pureRc
    if len(bridgeCompiler) > 0:
        CompilerProgressEmit(rootDir, progressText, "bridge_compile", "begin")
        let rc = CompilerForwardBootstrapBridge(rootDir,
                                                  bridgeCompiler,
                                                  "system-link-exec",
                                                  req,
                                                  args,
                                                  bridgeReport,
                                                  browserBridgeObjectPath)
        if rc != 0:
            return rc
        CompilerProgressEmit(rootDir, progressText, "bridge_compile", "done")
        CompilerProgressEmit(rootDir, progressText, "browser_bridge_restore", "begin")
        if !CompilerMaterializeBrowserBridgeOutputs(rootDir, plan):
            if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
                CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
                return 2
            CompilerPrintErr(" compiler: failed to restore browser bridge outputs")
            return 2
        CompilerProgressEmit(rootDir, progressText, "browser_bridge_restore", "done")
        CompilerProgressEmit(rootDir, progressText, "execute", "done")
        return 0
    if CompilerPlanNeedsBootstrapBridge(plan):
        let bootstrapBridge = CompilerBootstrapBridgePath(rootDir, "system-link-exec")
        if len(bootstrapBridge) > 0:
            CompilerProgressEmit(rootDir, progressText, "bridge_compile", "begin")
            let rc = CompilerForwardBootstrapBridge(rootDir,
                                                      bootstrapBridge,
                                                      "system-link-exec",
                                                      req,
                                                      args,
                                                      bridgeReport,
                                                      browserBridgeObjectPath)
            if rc != 0:
                return rc
            CompilerProgressEmit(rootDir, progressText, "bridge_compile", "done")
            CompilerProgressEmit(rootDir, progressText, "browser_bridge_restore", "begin")
            if !CompilerMaterializeBrowserBridgeOutputs(rootDir, plan):
                if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
                    CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
                    return 2
                CompilerPrintErr(" compiler: failed to restore browser bridge outputs")
                return 2
            CompilerProgressEmit(rootDir, progressText, "browser_bridge_restore", "done")
            CompilerProgressEmit(rootDir, progressText, "execute", "done")
            return 0
    let summary = CompilerSystemLinkExecSummary(plan)
    if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
        CompilerPrintErr(strutil.Join([" compiler: failed to write report: ", req.reportPath], ""))
        return 2
    if sexec.SystemLinkExecPlanReady(plan):
        CompilerPrintErr(" compiler: missing live Cheng bridge for system-link-exec")
        CompilerPrintErr(summary)
        return 2
    for i in 0..<privateImportDiagnostics.len:
        CompilerPrintErr(privateImportDiagnostics[i])
    if plan.primaryObjectPlan.missingReasons.len > 0:
        CompilerPrintErr(" compiler: primary object machine code not emitted")
    else:
        CompilerPrintErr(" compiler: ordinary pipeline blocked")
    CompilerPrintErr(summary)
    return 2

fn CompilerRunLegacyCompatSystemLinkExec(rootDir: str,
                                           req: var creq.CompilerRequest,
                                           rawArgs: str[]): int32 =
    CompilerApplyProgressEnvFromArgs(rootDir, rawArgs)
    let compatArgs = creq.CompilerSystemLinkCompatArgs(req)
    let planRes: Result[sexec.SystemLinkExecPlan] = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                                                          req,
                                                                                                          "",
                                                                                                          "",
                                                                                                          "",
                                                                                                          "stable")
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let bridgeCompiler = CompilerBridgeCompilerPath(rootDir)
    var bridgeReport = ""
    if len(req.reportPath) > 0:
        bridgeReport = CompilerSystemLinkExecBridgeMergeReport(plan)
    if !CompilerMaterializeBrowserBridgeOutputs(rootDir, plan):
        if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
            CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
            return 2
        CompilerPrintErr(" compiler: failed to materialize browser bridge outputs")
        return 2
    let browserBridgeObjectPath = sexec.SystemLinkExecBrowserBridgeObjectPath(plan)
    if len(bridgeCompiler) > 0:
        let rc = CompilerForwardBootstrapBridge(rootDir,
                                                  bridgeCompiler,
                                                  "system-link-exec",
                                                  req,
                                                  compatArgs,
                                                  bridgeReport,
                                                  browserBridgeObjectPath)
        if rc != 0:
            return rc
        if !CompilerMaterializeBrowserBridgeOutputs(rootDir, plan):
            if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
                CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
                return 2
            CompilerPrintErr(" compiler: failed to restore browser bridge outputs")
            return 2
        return 0
    let summary = CompilerSystemLinkExecSummary(plan)
    let privateImportDiagnostics = CompilerSystemLinkExecPrivateImportDiagnostics(plan)
    if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    if sexec.SystemLinkExecPlanReady(plan):
        CompilerPrintErr(" compiler: missing live Cheng bridge for system-link-exec")
        CompilerPrintErr(summary)
        return 2
    for i in 0..<privateImportDiagnostics.len:
        CompilerPrintErr(privateImportDiagnostics[i])
    if plan.primaryObjectPlan.missingReasons.len > 0:
        CompilerPrintErr(" compiler: primary object machine code not emitted")
    else:
        CompilerPrintErr(" compiler: ordinary pipeline blocked")
    CompilerPrintErr(summary)
    return 2

fn CompilerBuildSystemPlanForEquivalence(rootDir: str,
                                           req: creq.CompilerRequest,
                                           args: str[]): Result[sexec.SystemLinkExecPlan] =
    return sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              creq.CompilerWorldHeadFromArgs(args),
                                                              creq.CompilerLockPathFromArgs(args),
                                                              "",
                                                              creq.CompilerChannelFromArgs(args))

fn CompilerEquivalenceInputsReadyFromRuntimeFlags(required: bool): Result[bool] =
    let baselineCsgPath = cmdline.ReadFlagOrDefault("--baseline-csg", "")
    let baselineSurfacePath = cmdline.ReadFlagOrDefault("--baseline-surface", "")
    let baselineReceiptPath = cmdline.ReadFlagOrDefault("--baseline-receipt", "")
    let anyProvided = len(baselineCsgPath) > 0 ||
                      len(baselineSurfacePath) > 0 ||
                      len(baselineReceiptPath) > 0
    let allProvided = len(baselineCsgPath) > 0 &&
                      len(baselineSurfacePath) > 0 &&
                      len(baselineReceiptPath) > 0
    if anyProvided && !allProvided:
        return Err[bool](" compiler equivalence: require --baseline-csg --baseline-surface --baseline-receipt together")
    if required && !allProvided:
        return Err[bool](" compiler equivalence: missing --baseline-csg/--baseline-surface/--baseline-receipt")
    return Ok[bool](allProvided)

fn CompilerEquivalenceInputsReady(args: str[],
                                    required: bool): Result[bool] =
    let baselineCsgPath = creq.CompilerBaselineCsgPathFromArgs(args)
    let baselineSurfacePath = creq.CompilerBaselineSurfacePathFromArgs(args)
    let baselineReceiptPath = creq.CompilerBaselineReceiptPathFromArgs(args)
    let anyProvided = len(baselineCsgPath) > 0 ||
                      len(baselineSurfacePath) > 0 ||
                      len(baselineReceiptPath) > 0
    let allProvided = len(baselineCsgPath) > 0 &&
                      len(baselineSurfacePath) > 0 &&
                      len(baselineReceiptPath) > 0
    if anyProvided && !allProvided:
        return Err[bool](" compiler equivalence: require --baseline-csg --baseline-surface --baseline-receipt together")
    if required && !allProvided:
        return Err[bool](" compiler equivalence: missing --baseline-csg/--baseline-surface/--baseline-receipt")
    return Ok[bool](allProvided)

fn CompilerEquivalenceProofFromArgs(rootDir: str,
                                      args: str[],
                                      plan: sexec.SystemLinkExecPlan,
                                      out: var ceq.CompilerEquivalenceProof): Result[bool] =
    let baselineCsgPath = chengpath.PathAbsolute(rootDir, creq.CompilerBaselineCsgPathFromArgs(args))
    if !chengpath.PathFileExists(baselineCsgPath):
        return Err[bool](" compiler equivalence: missing baseline csg: " + baselineCsgPath)
    let baselineSurfacePath = chengpath.PathAbsolute(rootDir, creq.CompilerBaselineSurfacePathFromArgs(args))
    if !chengpath.PathFileExists(baselineSurfacePath):
        return Err[bool](" compiler equivalence: missing baseline surface: " + baselineSurfacePath)
    let baselineReceiptPath = chengpath.PathAbsolute(rootDir, creq.CompilerBaselineReceiptPathFromArgs(args))
    if !chengpath.PathFileExists(baselineReceiptPath):
        return Err[bool](" compiler equivalence: missing baseline receipt: " + baselineReceiptPath)
    let baselineCsgText = chengpath.ReadTextFile("", baselineCsgPath)
    let baselineSurfaceText = chengpath.ReadTextFile("", baselineSurfacePath)
    let baselineReceiptText = chengpath.ReadTextFile("", baselineReceiptPath)
    let migratedCsgText = ccsg.CompilerCsgReport(plan.compilerCsg)
    let migratedSurfaceText = ccsg.CompilerExportSurfaceReport(plan.exportSurface)
    let migratedReceiptText = ccsg.CompileReceiptReport(plan.compileReceipt)
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var graphEquivalent = 0
    let graphRes = ceq.CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn CompilerEquivalenceProofFromRuntimeFlags(rootDir: str,
