fn CompilerAsciiSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    if code == 10:
        return true
    if code == 13:
        return true
    return false

fn CompilerOrphanSnapshotKey(lineRaw: str): str =
    let line = strutil.Strip(lineRaw)
    if len(line) <= 0:
        return ""
    let total = len(line)
    var cursor = 0
    while cursor < total:
        if !CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let pidStart = cursor
    while cursor < total:
        if CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= pidStart:
        return ""
    let pidText = strings.SliceBytes(line, pidStart, cursor - pidStart)
    for skip in 0..<3:
        let _ = skip
        while cursor < total:
            if !CompilerAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        let fieldStart = cursor
        while cursor < total:
            if CompilerAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        if cursor <= fieldStart:
            return ""
    while cursor < total:
        if !CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor >= total:
        return ""
    let commandText = strings.SliceBytes(line, cursor, total - cursor)
    return pidText + "|" + commandText

fn CompilerNormalizeOrphanSnapshot(text: str): str[] =
    var out: str[]
    var start = 0
    var i = 0
    while i <= len(text):
        var lineEnd = false
        if i == len(text):
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        elif text[i] == '\r':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            let key = CompilerOrphanSnapshotKey(line)
            if len(key) > 0:
                add(out, key)
            start = i + 1
            while start < len(text):
                if text[start] != '\n' && text[start] != '\r':
                    break
                start = start + 1
            i = start
            continue
        i = i + 1
    return out

fn CompilerSeqContainsStr(items: str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn CompilerCollectNewOrphanKeys(before: str[], after: str[]): str[] =
    var out: str[]
    for i in 0..<after.len:
        let key = after[i]
        if !CompilerSeqContainsStr(before, key) && !CompilerSeqContainsStr(out, key):
            add(out, key)
    return out

fn CompilerRunShellLogged(rootDir: str,
                            label: str,
                            command: str,
                            logPath: str,
                            timeoutSec: int32): hostops.LoggedRun =
    let _ = timeoutSec
    return CompilerRunCommandCaptureLogged(rootDir, label, "sh", command, logPath)

fn CompilerPsLineTrackedOrphan(line: str, rootDir: str): bool =
    if !strutil.Contains(line, rootDir):
        return false
    let total = len(line)
    var cursor = 0
    while cursor < total:
        if !CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let pidStart = cursor
    while cursor < total:
        if CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= pidStart:
        return false
    while cursor < total:
        if !CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let ppidStart = cursor
    while cursor < total:
        if CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= ppidStart:
        return false
    let ppidText = strings.SliceBytes(line, ppidStart, cursor - ppidStart)
    if ppidText != "1":
        return false
    while cursor < total:
        if !CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let stateStart = cursor
    while cursor < total:
        if CompilerAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= stateStart:
        return false
    let stateText = strings.SliceBytes(line, stateStart, cursor - stateStart)
    if len(stateText) <= 0:
        return false
    return stateText[0] == 'U'

fn CompilerReadChengOrphanSnapshot(rootDir: str,
                                     label: str,
                                     logPath: str,
                                     outLines: var str[]): int32 =
    let run = CompilerRunShellLogged(rootDir,
                                       label,
                                       "ps -Ao pid=,ppid=,state=,etime=,command=",
                                       logPath,
                                       10)
    if CompilerLoggedRunFailed(run):
        outLines = []
        return run.exitCode
    var filtered = ""
    var start = 0
    var i = 0
    while i <= len(run.output):
        var lineEnd = false
        if i == len(run.output):
            lineEnd = true
        elif run.output[i] == '\n':
            lineEnd = true
        elif run.output[i] == '\r':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(run.output, start, i - start)
            if CompilerPsLineTrackedOrphan(line, rootDir):
                filtered = filtered + line
                filtered = filtered + "\n"
            start = i + 1
            while start < len(run.output):
                if run.output[start] != '\n' && run.output[start] != '\r':
                    break
                start = start + 1
            i = start
            continue
        i = i + 1
    outLines = CompilerNormalizeOrphanSnapshot(filtered)
    return 0

