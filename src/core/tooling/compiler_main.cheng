fn CompilerTextContainsLegacyToolingMarker(text: str): bool =
    let markers = CompilerLegacyToolingMarkers()
    var start = 0
    for i in 0..len(markers):
        var lineEnd = false
        if i == len(markers):
            lineEnd = true
        elif markers[i] == '\n':
            lineEnd = true
        if lineEnd:
            let marker = strings.SliceBytes(markers, start, i - start)
            if len(marker) > 0 && strutil.Contains(text, marker):
                return true
            start = i + 1
    return false

fn CompilerVerifyOrphanGuard(rootDir: str): int32 =
    let toolingDir = chengpath.PathAbsolute(rootDir, "tools")
    let shellScan = CompilerRunShellLogged(rootDir,
                                             "verify_orphan_guard_shell_scan",
                                             "find " + CompilerQuoteShell(toolingDir) + " -maxdepth 1 -type f -name '*.sh'",
                                             "artifacts/gate/orphan_guard_shell_scan.log",
                                             10)
    if CompilerLoggedRunFailed(shellScan):
        return shellScan.exitCode
    let shellText = strutil.Strip(shellScan.output)
    if len(shellText) > 0:
        CompilerPrintErr("verify_orphan_guard: shell tooling entry not allowed: " + shellText)
        return 1
    let pyScan = CompilerRunShellLogged(rootDir,
                                          "verify_orphan_guard_py_scan",
                                          "find " + CompilerQuoteShell(toolingDir) + " -maxdepth 1 -type f -name '*.py'",
                                          "artifacts/gate/orphan_guard_py_scan.log",
                                          10)
    if CompilerLoggedRunFailed(pyScan):
        return pyScan.exitCode
    var pathStart = 0
    let n = len(pyScan.output)
    var i = 0
    for i in i..<= n:
        var lineEnd = false
        if i == n:
            lineEnd = true
        elif pyScan.output[i] == '\n':
            lineEnd = true
        elif pyScan.output[i] == '\r':
            lineEnd = true
        if !lineEnd:
            continue
        let path = strutil.Strip(strings.SliceBytes(pyScan.output, pathStart, i - pathStart))
        if len(path) > 0:
            let parts = os.SplitFile(path)
            let fileName = parts.name + parts.ext
            if CompilerTextContainsLegacyToolingMarker(fileName):
                CompilerPrintErr("verify_orphan_guard: banned tooling entry name: " + path)
                return 1
            let text = chengpath.ReadTextFile("", path)
            if CompilerTextContainsLegacyToolingMarker(text):
                CompilerPrintErr("verify_orphan_guard: banned direct process guard ref in " + path)
                return 1
        pathStart = i + 1
                i = (n) + 1
    var orphanBefore: str[]
    if CompilerReadChengOrphanSnapshot(rootDir,
                                         "orphan_guard_before",
                                         "artifacts/gate/orphan_guard_before.log",
                                         orphanBefore) != 0:
        return 1
    if CompilerBootstrapBridge(rootDir) != 0:
        return 1
    if CompilerBuildBackendDriver(rootDir) != 0:
        return 1
    var orphanAfter: str[]
    if CompilerReadChengOrphanSnapshot(rootDir,
                                         "orphan_guard_after",
                                         "artifacts/gate/orphan_guard_after.log",
                                         orphanAfter) != 0:
        return 1
    let orphanDelta = CompilerCollectNewOrphanKeys(orphanBefore, orphanAfter)
    if orphanDelta.len > 0:
        CompilerPrintErr("verify_orphan_guard: new Cheng U/UE process leaked after bootstrap/build")
        for i in 0..<orphanDelta.len:
            CompilerPrintErr(orphanDelta[i])
        return 1
    CompilerPrintLine("verify_orphan_guard ok")
    return 0

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let rootDir = CompilerRoot()
    let rootEnvRaw = strutil.Strip(os.GetEnv("CHENG_ROOT"))
    if rootEnvRaw == "":
        if rootdisco.CompilerRootSeedExists(rootDir):
            os.SetEnv("CHENG_ROOT", rootDir)
    let count: int32 = CompilerParamCountBridge()
    if count <= 0:
        CompilerUsage(rootDir)
        return 0
    let cmd = cmdline.ParamStr(1)
    let args = CompilerCollectArgsFrom(2, count)
    let allArgs = CompilerCollectArgsFrom(1, count)
    CompilerApplyProgressEnvFromArgs(rootDir, allArgs)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        CompilerUsage(rootDir)
        return 0
    if cmd == "status":
        CompilerStatus(rootDir)
        return 0
    if cmd == "support-matrix":
        CompilerSupportMatrix(rootDir)
        return 0
    if cmd == "print-build-plan":
        return CompilerPrintBuildPlan(rootDir, args)
    if cmd == "verify-export-visibility":
        return evgate.ExportVisibilityGateRun(rootDir)
    if cmd == "verify-export-visibility-parallel":
        return evgate.ExportVisibilityGateRunParallel(rootDir)
    if cmd == "verify-mobile-shell-build-probe":
        return CompilerVerifyMobileShellBuildProbe(rootDir)
    if cmd == "host-bridge-audit":
        return hbagate.HostBridgeAuditGateRun(rootDir)
    if cmd == "mobile-shell":
        var outputText: str
        var errorText: str
        let mobileCode: int32 = mshell.MobileShellRun(rootDir, args, outputText, errorText)
        let outputTrimmed = strutil.Strip(outputText)
        if len(outputTrimmed) > 0:
            CompilerPrintBlock(outputTrimmed)
        let errorTrimmed = strutil.Strip(errorText)
        if len(errorTrimmed) > 0:
            CompilerPrintErr(errorTrimmed)
        return mobileCode
    if cmd == "r2c-react":
        if args.len <= 0:
            CompilerR2cReactHelp()
            return 0
        let subcmd = args[0]
        if subcmd == "help" || subcmd == "--help" || subcmd == "-h":
            CompilerR2cReactHelp()
            return 0
        if subcmd == "status":
            return CompilerR2cReactStatus(rootDir)
    if cmd == "system-link-exec":
        let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
        if IsErr(reqRes):
            CompilerPrintErr(Error(reqRes))
            return 2
        var req = Value(reqRes)
        if strutil.Strip(os.GetEnv("CHENG_DEBUG_REQ_PROBE")) != "":
            let planRes = CompilerBuildSystemPlan(rootDir, req, args)
            if IsErr(planRes):
                CompilerPrintErr(Error(planRes))
                return 2
            var plan = Value(planRes)
            CompilerPrintErr("debug_req_probe_edges=" + IntToStr(plan.systemLinkPlan.importEdgeCount))
            CompilerPrintErr("debug_req_probe_unresolved=" + IntToStr(plan.systemLinkPlan.unresolvedImportCount))
        return CompilerRunSystemLinkExec(rootDir, req, args)
    if cmd == "world-receipt":
        return CompilerWorldReceipt(rootDir, args)
    if cmd == "emit-csg":
        return CompilerEmitCsg(rootDir, args)
    if cmd == "verify-backend-egraph-cost" || cmd == "verify_backend_egraph_cost":
        return CompilerVerifyBackendEgraphCost(rootDir, args)
    if cmd == "migrate-csg":
        return CompilerMigrateCsg(rootDir, args)
    if cmd == "verify-world":
        return CompilerVerifyWorld(rootDir, args)
    if cmd == "world-sync":
        return compilerMainWorldSync(rootDir, args)
    if cmd == "materialize-world-mirrors":
        return CompilerMaterializeWorldMirrors(rootDir, args)
    if cmd == "prove-equivalence":
        return CompilerProveEquivalence(rootDir, args)
    if cmd == "prove-migration":
        return CompilerProveMigration(rootDir, args)
    if cmd == "publish-world":
        return CompilerPublishWorld(rootDir, args)
    if cmd == "fresh-node-selfhost":
        return CompilerFreshNodeSelfhost(rootDir, args)
    if cmd == "follow-world":
        return CompilerFollowWorld(rootDir, args)
    if cmd == "selfhost-build":
        return CompilerSelfhostBuild(rootDir, args)
    if cmd == "build-backend-driver":
        return CompilerBuildBackendDriver(rootDir)
    if cmd == "bootstrap-bridge":
        let currentPath = CompilerCurrentExecutablePath(rootDir)
        let stage3Path = contracts.BootstrapStage3Path(rootDir)
        if len(currentPath) > 0 && CompilerBootstrapStageVariantPath(currentPath, stage3Path):
            return CompilerBootstrapBridge(rootDir)
    if cmd == "verify-x86-linux-remote" ||
       cmd == "run-shared-emit-smokes" ||
       cmd == "r2c-react-fresh-clean-gate" ||
       cmd == "r2c-react-codegen-surface-smoke" ||
       cmd == "r2c-react-truth-compare-smoke" ||
       cmd == "r2c-react-compile-smoke" ||
       cmd == "r2c-react-native-gui-bundle-smoke":
        return CompilerUnavailableInBackendDriver(cmd)
    if CompilerForwardsToStage3(cmd):
        return CompilerForwardStage3Command(rootDir, cmd, args)
    CompilerPrintErr(" compiler: unknown command: " + cmd)
    CompilerUsage(rootDir)
    return 2
