    CompilerPrintLine("usage: cheng r2c-react <subcommand> [args]")
    CompilerPrintLine("subcommands: help, status, frontend, static-surface, semantic-surface, codegen-surface, discover-truth-routes, capture-truth, truth-compare, compare-truth, exec-route-matrix, compare-truth-matrix, native-gui-bundle, native-gui-runtime, run-native-gui, render-compare, render-compare-matrix, replay-hit-inspector, compile")
    CompilerPrintLine("frontend flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    CompilerPrintLine("static-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...] [--asset-root <dir> ...]")
    CompilerPrintLine("semantic-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...]")
    CompilerPrintLine("discover-truth-routes flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    CompilerPrintLine("capture-truth flags: --repo <path> --route <state> [--out-dir <dir>] [--base-url <url>] [--chrome <bin>] [--width <n>] [--height <n>] [--truth-flag <0|1>] [--debug-port <n>] [--wait-ms <n>]")
    CompilerPrintLine("compare-truth flags: --exec-snapshot <file> --truth-trace <file> [--codegen-manifest <file>] [--truth-state <state>] [--native-gui-summary <file>] [--out <file>]")
    CompilerPrintLine("exec-route-matrix flags: (--route-catalog <file> | --tsx-ast <file>) --exec-snapshot <file> --truth-routes-file <file> [--codegen-manifest <file>] [--truth-trace <file>] [--out <file>]")
    CompilerPrintLine("compare-truth-matrix flags: --exec-route-matrix <file> --truth-trace <file> [--codegen-manifest <file>] [--out <file>]")
    CompilerPrintLine("native-gui-runtime flags: --runtime-contract <file> [--state-* ...] [--event-* ...]")
    CompilerPrintLine("run-native-gui flags: --click x,y --resize WxH --scroll-y <n> --wait-after-click-ms <n> --focus-item-id <id> --type-text <text> --send-key <key> --inspector-state-out <file> --open-source-on-click")
    CompilerPrintLine("render-compare flags: --repo <path> --route <state> [--out-dir <dir>] [--base-url <url>] [--tooling-bin <file>] [--auto-close-ms <n>] [--resize WxH] [--wait-ms <n>] [--browser-width <n>] [--browser-height <n>] [--summary-out <file>] [--out <file>] [--native-summary <file>] [--truth-summary <file>] [--native-screenshot <file>] [--truth-screenshot <file>]")
    CompilerPrintLine("render-compare-matrix flags: --repo <path> --matrix <file> [--out-dir <dir>] [--summary-out <file>] [--out <file>]")
    CompilerPrintLine("replay-hit-inspector flags: --inspector-state <file> --out <file> --open-source")

fn CompilerStatus(rootDir: str) =
    let contract = crun.CompilerRuntimeContract(rootDir)
    let cwd = os.GetCurrentDir()
    let probeSourcePath = os.JoinPath(cwd, "src/main.cheng")
    let flagRoot = cmdline.ReadFlagOrDefault("--root", "")
    let flagIn = cmdline.ReadFlagOrDefault("--in", "")
    let flagOut = cmdline.ReadFlagOrDefault("--out", "")
    let flagReport = cmdline.ReadFlagOrDefault("--report-out", "")
    let flagSymbolRaw = cmdline.ReadFlagOrDefault("--symbol-visibility", "")
    let currentExecutablePath = CompilerCurrentExecutablePath(rootDir)
    let bridgeCompilerPath = CompilerBridgeCompilerPath(rootDir)
    var externalRoots: parser.ParserExternalPackageRoot[]
    var parsed: parser.ParsedSourceStub
    var probePlan: slplan.SystemLinkPlanStub
    var probeExecPlan: sexec.SystemLinkExecPlan
    var flagParsed: parser.ParsedSourceStub
    var flagPlan: slplan.SystemLinkPlanStub
    var flagExecPlan: sexec.SystemLinkExecPlan
    var flagWrappedExecPlan: sexec.SystemLinkExecPlan
    var probeErr = ""
    var probePlanErr = ""
    var probeExecErr = ""
    var flagErr = ""
    var flagPlanErr = ""
    var flagExecErr = ""
    var flagWrappedExecErr = ""
    var probeParseEdges = ""
    var probeParseUnresolved = ""
    var probePlanEdges = ""
    var probePlanUnresolved = ""
    var probeExecEdges = ""
    var probeExecUnresolved = ""
    var flagParseEdges = ""
    var flagParseUnresolved = ""
    var flagPlanEdges = ""
    var flagPlanUnresolved = ""
    var flagExecEdges = ""
    var flagExecUnresolved = ""
    var flagWrappedExecEdges = ""
    var flagWrappedExecUnresolved = ""
    if os.FileExists(probeSourcePath):
        if parser.ParseOrdinarySourceStubWithExternalPackageRoots(cwd,
                                                                    probeSourcePath,
                                                                    externalRoots,
                                                                    parsed,
                                                                    probeErr):
            probeParseEdges = IntToStr(parsed.importEdges.len)
            probeParseUnresolved = IntToStr(parsed.unresolvedImportCount)
        else:
            probeParseEdges = "err"
            probeParseUnresolved = probeErr
        let probeReq = creq.CompilerRequestNew(cwd,
                                                 probeSourcePath,
                                                 "/tmp/cheng_status_probe.out",
                                                 contracts.BootstrapDefaultTarget(),
                                                 creq.EmitExe,
                                                 "")
        if slplan.BuildSystemLinkPlanStubWithExternalPackageRoots(rootDir,
                                                                    probeReq,
                                                                    externalRoots,
                                                                    probePlan,
                                                                    probePlanErr):
            probePlanEdges = IntToStr(probePlan.importEdgeCount)
            probePlanUnresolved = IntToStr(probePlan.unresolvedImportCount)
        else:
            probePlanEdges = "err"
            probePlanUnresolved = probePlanErr
        let probeExecRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                              probeReq,
                                                                              "",
                                                                              "",
                                                                              "",
                                                                              "stable")
        if IsErr(probeExecRes):
            probeExecEdges = "err"
            probeExecUnresolved = Error(probeExecRes)
        else:
            probeExecPlan = Value(probeExecRes)
            probeExecEdges = IntToStr(probeExecPlan.systemLinkPlan.importEdgeCount)
            probeExecUnresolved = IntToStr(probeExecPlan.systemLinkPlan.unresolvedImportCount)
    if flagRoot != "" && flagIn != "":
        if parser.ParseOrdinarySourceStubWithExternalPackageRoots(flagRoot,
                                                                    flagIn,
                                                                    externalRoots,
                                                                    flagParsed,
                                                                    flagErr):
            flagParseEdges = IntToStr(flagParsed.importEdges.len)
            flagParseUnresolved = IntToStr(flagParsed.unresolvedImportCount)
        else:
            flagParseEdges = "err"
            flagParseUnresolved = flagErr
        let flagReq = creq.CompilerRequestNew(flagRoot,
                                                flagIn,
                                                flagOut != "" ? flagOut : "/tmp/cheng_status_flag_probe.out",
                                                contracts.BootstrapDefaultTarget(),
                                                creq.EmitExe,
                                                flagReport)
        if slplan.BuildSystemLinkPlanStubWithExternalPackageRoots(rootDir,
                                                                    flagReq,
                                                                    externalRoots,
                                                                    flagPlan,
                                                                    flagPlanErr):
            flagPlanEdges = IntToStr(flagPlan.importEdgeCount)
            flagPlanUnresolved = IntToStr(flagPlan.unresolvedImportCount)
        else:
            flagPlanEdges = "err"
            flagPlanUnresolved = flagPlanErr
        let flagExecRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                             flagReq,
                                                                             "",
                                                                             "",
                                                                             "",
                                                                             "stable")
        if IsErr(flagExecRes):
            flagExecEdges = "err"
            flagExecUnresolved = Error(flagExecRes)
        else:
            flagExecPlan = Value(flagExecRes)
            flagExecEdges = IntToStr(flagExecPlan.systemLinkPlan.importEdgeCount)
            flagExecUnresolved = IntToStr(flagExecPlan.systemLinkPlan.unresolvedImportCount)
        let flagSymbolRes = creq.CompilerSymbolVisibilityFromText(flagSymbolRaw)
        if IsErr(flagSymbolRes):
            flagWrappedExecEdges = "err"
            flagWrappedExecUnresolved = Error(flagSymbolRes)
        else:
            let flagWrappedReq = creq.CompilerRequestWithSymbolVisibility(flagReq,
                                                                            Value(flagSymbolRes))
            let flagWrappedExecRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                                        flagWrappedReq,
                                                                                        "",
                                                                                        "",
                                                                                        "",
                                                                                        "stable")
            if IsErr(flagWrappedExecRes):
                flagWrappedExecEdges = "err"
                flagWrappedExecUnresolved = Error(flagWrappedExecRes)
            else:
                flagWrappedExecPlan = Value(flagWrappedExecRes)
                flagWrappedExecEdges = IntToStr(flagWrappedExecPlan.systemLinkPlan.importEdgeCount)
                flagWrappedExecUnresolved = IntToStr(flagWrappedExecPlan.systemLinkPlan.unresolvedImportCount)
    CompilerPrintLine("cheng")
    CompilerPrintLine("version=" + contract.version)
    CompilerPrintLine("execution=" + contract.executionModel)
    CompilerPrintLine("bootstrap_mode=" + contract.bootstrapMode)
    CompilerPrintLine("compiler_entry=" + contract.compilerEntry)
    CompilerPrintLine("ordinary_command=" + contract.ordinaryCommand)
    CompilerPrintLine("ordinary_pipeline=" + contract.ordinaryPipelineState)
    CompilerPrintLine("root_dir=" + rootDir)
    CompilerPrintLine("cwd=" + cwd)
    CompilerPrintLine("program_name=" + cmdline.ProgramName())
    CompilerPrintLine("env_root=" + os.GetEnv("CHENG_ROOT"))
    CompilerPrintLine("current_executable_path=" + currentExecutablePath)
    CompilerPrintLine("bridge_compiler=" + bridgeCompilerPath)
    CompilerPrintLine("probe_std_strings=" + parser.ParserModulePathToSourcePathWithExternalPackageRoots(cwd,
                                                                                                               cwd,
                                                                                                               externalRoots,
                                                                                                               "std/strings"))
    if flagRoot != "" || flagIn != "":
        CompilerPrintLine("flag_root=" + flagRoot)
        CompilerPrintLine("flag_in=" + flagIn)
    if len(probeParseEdges) > 0:
        CompilerPrintLine("probe_parse_edges=" + probeParseEdges)
        CompilerPrintLine("probe_parse_unresolved=" + probeParseUnresolved)
    if len(probePlanEdges) > 0:
        CompilerPrintLine("probe_plan_edges=" + probePlanEdges)
        CompilerPrintLine("probe_plan_unresolved=" + probePlanUnresolved)
    if len(probeExecEdges) > 0:
        CompilerPrintLine("probe_exec_edges=" + probeExecEdges)
        CompilerPrintLine("probe_exec_unresolved=" + probeExecUnresolved)
    if len(flagParseEdges) > 0:
        CompilerPrintLine("flag_parse_edges=" + flagParseEdges)
        CompilerPrintLine("flag_parse_unresolved=" + flagParseUnresolved)
    if len(flagPlanEdges) > 0:
        CompilerPrintLine("flag_plan_edges=" + flagPlanEdges)
        CompilerPrintLine("flag_plan_unresolved=" + flagPlanUnresolved)
    if len(flagExecEdges) > 0:
        CompilerPrintLine("flag_exec_edges=" + flagExecEdges)
        CompilerPrintLine("flag_exec_unresolved=" + flagExecUnresolved)
    if len(flagWrappedExecEdges) > 0:
        CompilerPrintLine("flag_wrapped_exec_edges=" + flagWrappedExecEdges)
        CompilerPrintLine("flag_wrapped_exec_unresolved=" + flagWrappedExecUnresolved)

fn CompilerSupportMatrix(rootDir: str) =
    CompilerPrintBlock(smatrix.SupportMatrixReport(rootDir))

fn CompilerRequestedTarget(): str =
    var targetTriple: str
    if cmdline.ReadFirstFlagValue("--target", targetTriple):
        let trimmed = strutil.Strip(targetTriple)
        if len(trimmed) > 0:
            return trimmed
    return contracts.BootstrapDefaultTarget()

fn CompilerStage3CommandPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")

fn CompilerPrintBuildPlan(rootDir: str,
                            args: str[]): int32 =
    let stage3Path = CompilerStage3CommandPath(rootDir)
    let logPath = chengpath.PathAbsolute(rootDir, "artifacts/forward/print-build-plan.local.log")
    if !chengpath.FileExistsNonEmpty(rootDir, stage3Path):
        CompilerPrintErr(" compiler: missing stage3 compiler for command: print-build-plan")
        return 2
    var forwardArgs: str[] = ["print-build-plan"]
    for i in 0..<args.len:
        add(forwardArgs, args[i])
    if !CompilerRunFileEnvLogged(rootDir,
                                   stage3Path,
                                   forwardArgs,
                                   ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   logPath,
                                   "print-build-plan"):
        return 2
    let outputRaw = chengpath.ReadTextFile("", logPath)
    let outputText = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        CompilerPrintBlock(outputText)
    return 0

fn CompilerWriteOptionalReport(rootDir: str,
                                 rawPath: str,
                                 report: str): bool =
    if len(rawPath) <= 0:
        return true
    var text = report
    text = text + "\n"
    return chengpath.WriteTextFile(rootDir, rawPath, text)

fn CompilerBackendDriverHandoffDisabled(): bool =
    let handoffText = strutil.Strip(os.GetEnv("CHENG_BACKEND_DRIVER_HANDOFF"))
    let handoffEnabled = len(handoffText) > 0 && handoffText != "0"
    return !handoffEnabled

fn CompilerBridgeCandidateReady(rootDir: str,
                                  candidatePath: str): bool =
    if !chengpath.FileExistsNonEmpty(rootDir, candidatePath):
        return false
    let currentPath = CompilerCurrentExecutablePath(rootDir)
    if len(currentPath) > 0 && currentPath == candidatePath:
        return false
    return true

fn CompilerBridgeCompilerPath(rootDir: str): str =
    if !CompilerBackendDriverHandoffDisabled():
        let backendDriver = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
        if CompilerBridgeCandidateReady(rootDir, backendDriver):
            return backendDriver
    else:
        let currentPath = CompilerCurrentExecutablePath(rootDir)
        let stage3 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")
        let stage2 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage2")
        let stage1 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage1")
        let stage0 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage0")
        if CompilerBootstrapStageVariantPath(currentPath, stage3) ||
           CompilerBootstrapStageVariantPath(currentPath, stage2) ||
           CompilerBootstrapStageVariantPath(currentPath, stage1) ||
           CompilerBootstrapStageVariantPath(currentPath, stage0):
            return ""
    let stage3 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")
    if CompilerBridgeCandidateReady(rootDir, stage3):
        return stage3
    let stage2 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage2")
    if CompilerBridgeCandidateReady(rootDir, stage2):
        return stage2
    let stage1 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage1")
    if CompilerBridgeCandidateReady(rootDir, stage1):
        return stage1
    let stage0 = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage0")
    if CompilerBridgeCandidateReady(rootDir, stage0):
        return stage0
    return ""

fn CompilerBootstrapBridgePath(rootDir: str,
                                 context: str): str =
    let snapshot = contracts.BootstrapSnapshotDefault(rootDir)
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path):
        return snapshot.stage2Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage1Compiler.path):
        return snapshot.stage1Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage0Compiler.path):
        return snapshot.stage0Compiler.path
    if !CompilerEnsureBootstrapBridge(rootDir, context):
        return ""
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path):
        return snapshot.stage2Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage1Compiler.path):
        return snapshot.stage1Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage0Compiler.path):
        return snapshot.stage0Compiler.path
    CompilerPrintErr(" compiler: missing bootstrap bridge inside " + context)
    return ""

fn CompilerArgsWithoutReportOut(args: str[]): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = strutil.Strip(args[i])
        if arg == "--report-out":
            i = i + 2
            continue
        if strutil.StartsWith(arg, "--report-out:") || strutil.StartsWith(arg, "--report-out="):
            i = i + 1
            continue
        add(out, args[i])
        i = i + 1
    return out

fn CompilerReadFlagFromArgs(args: str[],
                              flagName: str,
                              defaultValue: str): str =
    var i: int32
    for i in i..<args.len:
        let arg = strutil.Strip(args[i])
        if arg == flagName:
            if i + 1 < args.len:
                return args[i + 1]
            return defaultValue
        if strutil.StartsWith(arg, flagName + ":") || strutil.StartsWith(arg, flagName + "="):
            return strings.SliceBytes(arg, len(flagName) + 1, len(arg) - len(flagName) - 1)
    return defaultValue

fn CompilerFlagEnabledFromArgs(args: str[],
                                 flagName: str): bool =
    var i: int32
    for i in i..<args.len:
        let arg = strutil.Strip(args[i])
        if arg == flagName:
            return true
        if strutil.StartsWith(arg, flagName + ":") || strutil.StartsWith(arg, flagName + "="):
            let value = strutil.Strip(strings.SliceBytes(arg, len(flagName) + 1, len(arg) - len(flagName) - 1))
            return len(value) <= 0 || (value != "0" && value != "false")
    return false

fn CompilerArgsWithoutProgress(args: str[]): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = strutil.Strip(args[i])
        if arg == "--progress":
            i = i + 1
            continue
        if arg == "--progress-out":
            i = i + 2
            continue
        if strutil.StartsWith(arg, "--progress:") || strutil.StartsWith(arg, "--progress="):
            i = i + 1
            continue
        if strutil.StartsWith(arg, "--progress-out:") || strutil.StartsWith(arg, "--progress-out="):
            i = i + 1
            continue
        add(out, args[i])
        i = i + 1
    return out

fn CompilerProgressRequestedFromArgs(args: str[]): bool =
    if CompilerFlagEnabledFromArgs(args, "--progress"):
        return true
    let progressOut = strutil.Strip(CompilerReadFlagFromArgs(args, "--progress-out", ""))
    return len(progressOut) > 0

fn CompilerProgressOutPathFromArgs(rootDir: str,
                                     args: str[]): str =
    let raw = strutil.Strip(CompilerReadFlagFromArgs(args, "--progress-out", ""))
    if len(raw) <= 0:
        return ""
    return chengpath.PathAbsolute(rootDir, raw)

fn CompilerApplyProgressEnvFromArgs(rootDir: str,
                                      args: str[]) =
    if CompilerProgressRequestedFromArgs(args):
        os.SetEnv("CHENG_PROGRESS", "1")
    let progressOut = CompilerProgressOutPathFromArgs(rootDir, args)
    if len(progressOut) > 0:
        os.SetEnv("CHENG_PROGRESS_OUT", progressOut)

fn CompilerProgressStdErrEnabled(): bool =
    let raw = strutil.Strip(os.GetEnv("CHENG_PROGRESS"))
    return len(raw) > 0 && raw != "0" && raw != "false"

fn CompilerProgressPath(): str =
    return strutil.Strip(os.GetEnv("CHENG_PROGRESS_OUT"))

fn CompilerProgressAppendEnabled(): bool =
    let raw = strutil.Strip(os.GetEnv("CHENG_PROGRESS_APPEND"))
    return len(raw) > 0 && raw != "0" && raw != "false"

fn CompilerProgressLine(phase: str,
                          status: str): str =
    return phase

fn CompilerProgressSyncExisting(progressPath: str,
                                  progressText: var str) =
    if len(progressPath) <= 0 || !os.FileExists(progressPath):
        return
    var existing = chengpath.ReadTextFile("", progressPath)
    if len(existing) > 0 && existing[len(existing) - 1] == '\n':
        existing = strings.SliceBytes(existing, 0, len(existing) - 1)
    if len(existing) <= 0:
        return
    if len(progressText) <= 0:
        progressText = existing
        return
    if existing == progressText:
        return
    if strutil.StartsWith(existing, progressText):
        progressText = existing
        return
    if strutil.StartsWith(progressText, existing):
        return
    progressText = existing

fn CompilerProgressWriteGuardLine(rootDir: str,
                                    progressPath: str,
                                    progressText: var str,
                                    line: str) =
    os.WriteLine(os.Get_stderr(), line)
    if len(progressPath) <= 0:
        return
    CompilerProgressSyncExisting(progressPath, progressText)
    if len(progressText) > 0:
        progressText = progressText + "\n"
    progressText = progressText + line
    let _ = chengpath.WriteTextFile(rootDir, progressPath, progressText + "\n")

fn CompilerProgressResourceGuardCheck(rootDir: str,
                                        progressText: var str) =
    let maxRssBytes: int64 = hostops.HostOpsConfiguredMaxRssBytes([])
    if maxRssBytes == int64(0):
        return
    let progressPath = CompilerProgressPath()
    if maxRssBytes < int64(0):
        CompilerProgressWriteGuardLine(rootDir,
                                       progressPath,
                                       progressText,
                                       "compile_progress phase=resource_guard status=invalid_max_rss")
        hostops.HostOpsExitProcess(2)
    let rssBytes: int64 = hostops.HostOpsCurrentRssBytes()
    if rssBytes <= maxRssBytes || rssBytes <= int64(0):
        return
    CompilerProgressWriteGuardLine(rootDir,
                                   progressPath,
                                   progressText,
                                   hostops.HostOpsMemoryLimitExceededLine(rssBytes, maxRssBytes))
    hostops.HostOpsExitProcess(hostops.ProcessMemoryExceeded)

fn CompilerProgressEmit(rootDir: str,
                          progressText: var str,
                          phase: str,
                          status: str) =
    CompilerProgressResourceGuardCheck(rootDir, progressText)
    let stderrEnabled = CompilerProgressStdErrEnabled()
    let progressPath = CompilerProgressPath()
    if !stderrEnabled && len(progressPath) <= 0:
        return
    let line = CompilerProgressLine(phase, status)
    if stderrEnabled:
        os.WriteLine(os.Get_stderr(), line)
    if len(progressPath) > 0:
        if len(progressText) <= 0 && CompilerProgressAppendEnabled() && os.FileExists(progressPath):
            progressText = chengpath.ReadTextFile("", progressPath)
            if len(progressText) > 0 && progressText[len(progressText) - 1] == '\n':
                progressText = strings.SliceBytes(progressText, 0, len(progressText) - 1)
        else:
            CompilerProgressSyncExisting(progressPath, progressText)
        if len(progressText) > 0:
            progressText = progressText + "\n"
        progressText = progressText + line
        let _ = chengpath.WriteTextFile(rootDir, progressPath, progressText + "\n")

fn CompilerProgressEnvOverrides(rootDir: str,
                                  args: str[]): str[] =
    var out: str[]
    if CompilerProgressRequestedFromArgs(args):
        add(out, "CHENG_PROGRESS=1")
    let progressOut = CompilerProgressOutPathFromArgs(rootDir, args)
    if len(progressOut) > 0:
        add(out, "CHENG_PROGRESS_OUT=" + progressOut)
    return out

fn CompilerActiveRuntimeEnvOverrides(rootDir: str): str[] =
    var out: str[]
    let rootEnv = strutil.Strip(os.GetEnv("CHENG_ROOT"))
    if len(rootEnv) > 0:
        add(out, "CHENG_ROOT=" + rootEnv)
    elif rootdisco.CompilerRootSeedExists(rootDir):
        add(out, "CHENG_ROOT=" + rootDir)
    let progressEnv = strutil.Strip(os.GetEnv("CHENG_PROGRESS"))
    if len(progressEnv) > 0:
        add(out, "CHENG_PROGRESS=" + progressEnv)
    let progressOutEnv = strutil.Strip(os.GetEnv("CHENG_PROGRESS_OUT"))
    if len(progressOutEnv) > 0:
        add(out, "CHENG_PROGRESS_OUT=" + progressOutEnv)
    return out

fn CompilerPlanNeedsBootstrapBridge(plan: sexec.SystemLinkExecPlan): bool =
    if plan.systemLinkPlan.missingReasons.len > 0:
        return false
    if plan.loweringPlan.missingReasons.len > 0:
        return false
    return plan.primaryObjectPlan.missingReasons.len > 0

fn CompilerArgsWithReportOut(args: str[],
                               reportPath: str): str[] =
    var out = CompilerArgsWithoutReportOut(args)
    if len(reportPath) > 0:
        add(out, "--report-out:" + reportPath)
    return out

fn CompilerArgsWithoutBrowserBridgeObject(args: str[]): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = strutil.Strip(args[i])
        if arg == "--browser-bridge-object":
            i = i + 2
            continue
        if strutil.StartsWith(arg, "--browser-bridge-object:") || strutil.StartsWith(arg, "--browser-bridge-object="):
            i = i + 1
            continue
        add(out, args[i])
        i = i + 1
    return out

fn CompilerArgsWithBrowserBridgeObject(args: str[],
                                         browserBridgeObjectPath: str): Result[str[]] =
    let explicitBrowserBridgeObject = creq.CompilerReadFlagOrDefault(args, "--browser-bridge-object", "")
    let explicitLinkInput = creq.CompilerReadFlagOrDefault(args, "--link-input", "")
    if len(browserBridgeObjectPath) > 0 && explicitLinkInput == browserBridgeObjectPath:
        return Err[str[]](" compiler: explicit --link-input conflicts with compiler-owned browser bridge object")
    if len(explicitBrowserBridgeObject) > 0 &&
       len(browserBridgeObjectPath) > 0 &&
       explicitBrowserBridgeObject != browserBridgeObjectPath:
        return Err[str[]](" compiler: explicit --browser-bridge-object conflicts with compiler-owned browser bridge object")
    var out = CompilerArgsWithoutBrowserBridgeObject(args)
    if len(explicitBrowserBridgeObject) > 0:
        add(out, "--browser-bridge-object:" + explicitBrowserBridgeObject)
    elif len(browserBridgeObjectPath) > 0:
        add(out, "--browser-bridge-object:" + browserBridgeObjectPath)
    return Ok[str[]](out)

fn CompilerBridgeTempReportPath(req: creq.CompilerRequest,
                                  label: str): str =
    if len(req.reportPath) <= 0:
        return ""
    return req.reportPath + "." + label + ".tmp"

fn CompilerAppendReportLine(out: var str,
                              line: str) =
    if len(line) <= 0:
        return
    if len(out) > 0 && out[len(out) - 1] != '\n':
        out = out + "\n"
    out = out + line

fn CompilerLinesWithPrefix(text: str,
                             prefix: str): str[] =
    var lines: str[]
    var start: int32
    var i: int32
    for i in i..<= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if !lineEnd:
            continue
        let line = strings.SliceBytes(text, start, i - start)
        if strutil.StartsWith(line, prefix):
            add(lines, line)
        start = i + 1
    return lines

fn CompilerMergeBridgeReport(sourceReport: str,
                               bridgeReport: str): str =
    let browserLines = CompilerLinesWithPrefix(sourceReport, "browser_bridge_plan")
    let artifactLines = CompilerLinesWithPrefix(sourceReport, "browser_bridge_artifact")
    let sourceLines = CompilerLinesWithPrefix(sourceReport, "browser_bridge_source")
    let objectLines = CompilerLinesWithPrefix(sourceReport, "browser_bridge_object")
    let execPhaseLines = CompilerLinesWithPrefix(sourceReport, "exec_phase_")
    let bridgeExecPhaseLines = CompilerLinesWithPrefix(bridgeReport, "exec_phase_")
    if browserLines.len <= 0:
        if artifactLines.len <= 0:
            if sourceLines.len <= 0:
                if objectLines.len <= 0:
                    if execPhaseLines.len <= 0:
                        return bridgeReport
    var merged = bridgeReport
    if bridgeExecPhaseLines.len <= 0:
        for i in 0..<execPhaseLines.len:
            CompilerAppendReportLine(merged, execPhaseLines[i])
    for i in 0..<artifactLines.len:
        CompilerAppendReportLine(merged, artifactLines[i])
    for i in 0..<sourceLines.len:
        CompilerAppendReportLine(merged, sourceLines[i])
    for i in 0..<objectLines.len:
        CompilerAppendReportLine(merged, objectLines[i])
    for i in 0..<browserLines.len:
        CompilerAppendReportLine(merged, browserLines[i])
    return merged

fn CompilerSystemLinkExecPhaseMsText(ns: int64): str =
    if ns < int64(0):
        return "-1"
    return strings.Int64ToStr(ns / int64(1000000))

fn CompilerAppendSystemLinkExecPhaseLines(report: str,
                                            plan: sexec.SystemLinkExecPlan): str =
    if strutil.Contains(report, "exec_phase_total_ms="):
        return report
    var out = report
    CompilerAppendReportLine(out, "exec_phase_system_link_plan_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.systemLinkPlanNs))
    CompilerAppendReportLine(out, "exec_phase_source_bundle_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.sourceBundleNs))
    CompilerAppendReportLine(out, "exec_phase_compiler_csg_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.compilerCsgNs))
    CompilerAppendReportLine(out, "exec_phase_world_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.worldNs))
    CompilerAppendReportLine(out, "exec_phase_lock_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.lockNs))
    CompilerAppendReportLine(out, "exec_phase_baseline_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.baselineNs))
    CompilerAppendReportLine(out, "exec_phase_lowering_plan_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.loweringPlanNs))
    CompilerAppendReportLine(out, "exec_phase_primary_object_plan_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.primaryObjectPlanNs))
    CompilerAppendReportLine(out, "exec_phase_provider_sources_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.providerSourcesNs))
    CompilerAppendReportLine(out, "exec_phase_object_plan_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.objectPlanNs))
    CompilerAppendReportLine(out, "exec_phase_native_link_plan_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.nativeLinkPlanNs))
    CompilerAppendReportLine(out, "exec_phase_compile_receipt_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.compileReceiptNs))
    CompilerAppendReportLine(out, "exec_phase_total_ms=" + CompilerSystemLinkExecPhaseMsText(plan.phaseProfile.totalNs))
    return out

fn CompilerSystemLinkExecSummary(plan: sexec.SystemLinkExecPlan): str =
    var worldHeadPinned = "0"
    var lockCheckEnabled = "0"
    var lockVerified = "0"
    var baselineSurfaceChecked = "0"
    var baselineSurfaceCompatible = "0"
    var lockPath = "-"
    var baselineSurfacePath = "-"
    if plan.worldHeadPinned:
        worldHeadPinned = "1"
    if plan.lockCheckEnabled:
        lockCheckEnabled = "1"
    if plan.lockVerified:
        lockVerified = "1"
    if plan.baselineSurfaceChecked:
        baselineSurfaceChecked = "1"
    if plan.baselineSurfaceCompatible:
        baselineSurfaceCompatible = "1"
    if len(plan.lockPath) > 0:
        lockPath = plan.lockPath
    if len(plan.baselineSurfacePath) > 0:
        baselineSurfacePath = plan.baselineSurfacePath
    var out = ""
    out = out + "entry=" + plan.compilerEntrySource + "\n"
    out = out + "target=" + plan.systemLinkPlan.targetTriple + "\n"
    out = out + "output=" + plan.systemLinkPlan.outputPath + "\n"
    out = out + "source_bundle_cid=" + layout.FixedBytes32Hex(plan.sourceBundleCid) + "\n"
    out = out + "canonical_compiler_csg_cid=" + layout.FixedBytes32Hex(plan.compilerCsg.canonicalGraphCid) + "\n"
    out = out + "compiler_csg_cid=" + layout.FixedBytes32Hex(plan.compilerCsg.graphCid) + "\n"
    out = out + "export_surface_cid=" + layout.FixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    out = out + "world_head_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    out = out + "manifest_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.manifest.manifestCid) + "\n"
    out = out + "manifest_entry_count=" + IntToStr(plan.localUniverse.manifest.entryCount) + "\n"
    out = out + "compiler_pkg_cid=" + layout.FixedBytes32Hex(plan.localUniverse.compilerSnapshot.snapshotCid) + "\n"
    out = out + "std_pkg_cid=" + layout.FixedBytes32Hex(plan.localUniverse.stdSnapshot.snapshotCid) + "\n"
    out = out + "runtime_pkg_cid=" + layout.FixedBytes32Hex(plan.localUniverse.runtimeSnapshot.snapshotCid) + "\n"
    out = out + "world_head_pinned=" + worldHeadPinned + "\n"
    out = out + "lock_check_enabled=" + lockCheckEnabled + "\n"
    out = out + "lock_verified=" + lockVerified + "\n"
    out = out + "lock_path=" + lockPath + "\n"
    out = out + "baseline_surface_checked=" + baselineSurfaceChecked + "\n"
    out = out + "baseline_surface_compatible=" + baselineSurfaceCompatible + "\n"
    out = out + "baseline_surface_path=" + baselineSurfacePath + "\n"
    out = out + "compile_receipt_cid=" + layout.FixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    out = out + "compile_canonical_output_digest=" + layout.FixedBytes32Hex(plan.compileReceipt.canonicalOutputDigest) + "\n"
    out = out + "compile_output_digest=" + layout.FixedBytes32Hex(plan.compileReceipt.outputDigest) + "\n"
    out = out + "compile_bootstrap_stage=" + plan.compileReceipt.bootstrapStage
    return CompilerAppendSystemLinkExecPhaseLines(out, plan)

fn CompilerIdentifierExportedByCase(nameRaw: str): bool =
    let name = strutil.Strip(nameRaw)
    if len(name) <= 0:
        return false
    return name[0] >= 'A' && name[0] <= 'Z'

fn CompilerPackageRootForSource(rootDir: str,
                                  sourcePath: str): str =
    return creq.CompilerResolvePackageRoot(rootDir,
                                             sourcePath,
                                             creq.CompilerDefaultPackageRoot(rootDir))

fn CompilerModulePackageKey(modulePathRaw: str): str =
    var modulePath = strutil.Strip(modulePathRaw)
    if len(modulePath) <= 0:
        return ""
    if strutil.StartsWith(modulePath, "pkg://"):
        modulePath = strings.SliceBytes(modulePath, 6, len(modulePath) - 6)
    if modulePath == "cheng":
        return "cheng"
    var firstSlash: int32 = -1
    for i in 0..<modulePath.len:
        if modulePath[i] == '/':
            firstSlash = i
            break
    if firstSlash < 0:
        return modulePath
    if strutil.StartsWith(modulePath, "cheng/"):
        var secondSlash: int32 = -1
        for i in firstSlash + 1..<modulePath.len:
            if modulePath[i] == '/':
                secondSlash = i
                break
        if secondSlash > 0:
            return strings.SliceBytes(modulePath, 0, secondSlash)
    return strings.SliceBytes(modulePath, 0, firstSlash)

fn CompilerModulePathsSharePackage(leftModulePath: str,
                                     rightModulePath: str): bool =
    let leftKey = CompilerModulePackageKey(leftModulePath)
    let rightKey = CompilerModulePackageKey(rightModulePath)
    if len(leftKey) <= 0 || len(rightKey) <= 0:
        return false
    let leftShared = leftKey == "cheng" || leftKey == "std" || leftKey == "stage1"
    let rightShared = rightKey == "cheng" || rightKey == "std" || rightKey == "stage1"
    if leftShared && rightShared:
        return true
    return leftKey == rightKey

fn CompilerBuildExprCallProfiles(plan: sexec.SystemLinkExecPlan,
                                   profiles: var parser.NormalizedExprCallProfile[],
                                   lookup: var parser.ParserSourcePathIndexLookup,
                                   err: var str): bool =
    var out: parser.NormalizedExprCallProfile[]
    let linkPlan = plan.systemLinkPlan
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let sourcePath = linkPlan.sourceClosurePaths[i]
        let sourceText = chengpath.ReadTextFile("", sourcePath)
        if sourceText == "":
            err = " compiler: failed to read source closure text"
            return false
        var profile: parser.NormalizedExprCallProfile
        var profileErr = ""
        if !parser.ParserBuildExprCallProfileWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                        linkPlan.packageRoot,
                                                                        externalPackageRoots,
                                                                        sourcePath,
                                                                        sourceText,
                                                                        profile,
                                                                        profileErr):
            err = profileErr
            return false
        add(out, profile)
    lookup = parser.ParserSourcePathIndexLookupBuild(out)
    parser.ParserBindImportEdgeTargetProfileIndices(out, lookup)
    profiles = out
    err = ""
    return true

fn CompilerImportQualifierTargetModulePath(profile: parser.NormalizedExprCallProfile,
                                             qualifierRaw: str): str =
    let qualifierFull = strutil.Strip(qualifierRaw)
    if qualifierFull == "":
        return ""
    var qualifier = qualifierFull
    for i in 0..<qualifierFull.len:
        if qualifierFull[i] == '.':
            qualifier = strings.SliceBytes(qualifierFull, 0, i)
            break
    for i in 0..<profile.importEdges.len:
        if strutil.Strip(profile.importEdges[i].qualifier) != qualifier:
            continue
        let targetModulePath = strutil.Strip(profile.importEdges[i].targetModulePath)
        if targetModulePath != "":
            return targetModulePath
    for i in 0..<profile.lines.len:
        if parser.ParserHasLeadingIndent(profile.lines[i]):
            continue
        let line = strutil.Strip(parser.ParserStripLineComment(profile.lines[i]))
        if !strutil.StartsWith(line, "import "):
            continue
        var asPos: int32 = -1
        var j: int32
        while j + 4 <= line.len:
            if strings.SliceBytes(line, j, 4) == " as ":
                asPos = j
            j = j + 1
        if asPos < 0:
            continue
        let aliasText = strutil.Strip(strings.SliceBytes(line, asPos + 4, line.len - asPos - 4))
        if aliasText != qualifier:
            continue
        return strutil.Strip(strings.SliceBytes(line, len("import "), asPos - len("import ")))
    return ""

fn CompilerAppendPrivateImportDiagnostic(out: var str[],
                                           memberNameRaw: str) =
    let memberName = strutil.Strip(memberNameRaw)
    if memberName == "" || CompilerIdentifierExportedByCase(memberName):
        return
    let diagnostic = strutil.Join([" compiler: imported private symbol '",
                          memberName,
                          "' is not exported; use uppercase initial"], "")
    if !parser.ParserStringSeqContainsExact(out, diagnostic):
        add(out, diagnostic)

fn CompilerScanAliasPrivateUsesInLines(lines: str[],
                                         alias: str,
                                         out: var str[]) =
    if alias == "":
        return
    for lineIndex in 0..<lines.len:
        let line = parser.ParserStripLineComment(lines[lineIndex])
        var pos: int32
        var inString = false
        var inChar = false
        while pos < line.len:
            let ch = line[pos]
            if !inChar && ch == char(34) && !parser.ParserQuoteIsEscaped(line, pos):
                inString = !inString
                pos = pos + 1
                continue
            if !inString && ch == char(39) && !parser.ParserQuoteIsEscaped(line, pos):
                inChar = !inChar
                pos = pos + 1
                continue
            if inString || inChar:
                pos = pos + 1
                continue
            if !parser.ParserTextEqualsAt(line, pos, alias):
                pos = pos + 1
                continue
            let aliasEnd = pos + alias.len
            if pos > 0 && parser.ParserIsIdentChar(line[pos - 1]):
                pos = pos + 1
                continue
            if aliasEnd >= line.len || line[aliasEnd] != '.':
                pos = pos + 1
                continue
            let memberStart = aliasEnd + 1
            if memberStart >= line.len || !parser.ParserIsIdentChar(line[memberStart]):
                pos = pos + 1
                continue
            var memberStop = memberStart
            while memberStop < line.len && parser.ParserIsIdentChar(line[memberStop]):
                memberStop = memberStop + 1
            CompilerAppendPrivateImportDiagnostic(out,
                                                    strings.SliceBytes(line,
                                                                       memberStart,
                                                                       memberStop - memberStart))
            pos = memberStop
    return

fn CompilerScanSourcePrivateImportDiagnostics(linkPlan: slplan.SystemLinkPlanStub,
                                                out: var str[]) =
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    for sourceIndex in 0..<linkPlan.sourceClosurePaths.len:
        let sourcePath = linkPlan.sourceClosurePaths[sourceIndex]
        let text = chengpath.ReadTextFile("", sourcePath)
        if text == "":
            continue
        let lines = parser.ParserSplitChar(text, '\n')
        let ownerModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(linkPlan.workspaceRoot,
                                                                                             linkPlan.packageRoot,
                                                                                             externalPackageRoots,
                                                                                             sourcePath)
        for lineIndex in 0..<lines.len:
            if parser.ParserHasLeadingIndent(lines[lineIndex]):
                continue
            let line = strutil.Strip(parser.ParserStripLineComment(lines[lineIndex]))
            if !strutil.StartsWith(line, "import "):
                continue
            var asPos: int32 = -1
            var i: int32
            while i + 4 <= line.len:
                if strings.SliceBytes(line, i, 4) == " as ":
                    asPos = i
                i = i + 1
            if asPos < 0:
                continue
            let modulePath = strutil.Strip(strings.SliceBytes(line,
                                                              len("import "),
                                                              asPos - len("import ")))
            let alias = strutil.Strip(strings.SliceBytes(line, asPos + 4, line.len - asPos - 4))
            if modulePath == "" || alias == "":
                continue
            if CompilerModulePathsSharePackage(ownerModulePath, modulePath):
                continue
            CompilerScanAliasPrivateUsesInLines(lines, alias, out)
    return

fn CompilerScanProfilePrivateAliasUses(profile: parser.NormalizedExprCallProfile,
                                         out: var str[]) =
    for edgeIndex in 0..<profile.importEdges.len:
        let alias = strutil.Strip(profile.importEdges[edgeIndex].qualifier)
        let targetModulePath = CompilerImportQualifierTargetModulePath(profile, alias)
        if alias == "" || targetModulePath == "":
            continue
        if CompilerModulePathsSharePackage(profile.ownerModulePath, targetModulePath):
            continue
        for lineIndex in 0..<profile.lines.len:
            let line = parser.ParserStripLineComment(profile.lines[lineIndex])
            var pos: int32
            while pos < line.len:
                if !parser.ParserTextEqualsAt(line, pos, alias):
                    pos = pos + 1
                    continue
                let aliasEnd = pos + alias.len
                if pos > 0 && parser.ParserIsIdentChar(line[pos - 1]):
                    pos = pos + 1
                    continue
                if aliasEnd >= line.len || line[aliasEnd] != '.':
                    pos = pos + 1
                    continue
                let memberStart = aliasEnd + 1
                if memberStart >= line.len || !parser.ParserIsIdentChar(line[memberStart]):
                    pos = pos + 1
                    continue
                var memberStop = memberStart
                while memberStop < line.len && parser.ParserIsIdentChar(line[memberStop]):
                    memberStop = memberStop + 1
                CompilerAppendPrivateImportDiagnostic(out,
                                                        strings.SliceBytes(line,
                                                                           memberStart,
                                                                           memberStop - memberStart))
                pos = memberStop
    return

fn CompilerSystemLinkExecPrivateImportDiagnostics(plan: sexec.SystemLinkExecPlan): str[] =
    var out: str[]
    let linkPlan = plan.systemLinkPlan
    if linkPlan.unresolvedImportCount <= 0 && linkPlan.exprLayer.exprs.len <= 0:
        return out
    if linkPlan.exprLayer.exprs.len <= 0:
        CompilerScanSourcePrivateImportDiagnostics(linkPlan, out)
        return out
    CompilerScanSourcePrivateImportDiagnostics(linkPlan, out)
    if out.len > 0:
        return out
    var profiles: parser.NormalizedExprCallProfile[]
    var lookup = parser.ParserSourcePathIndexLookup()
    var buildErr = ""
    if !CompilerBuildExprCallProfiles(plan, profiles, lookup, buildErr):
        let _ = buildErr
        return out
    for i in 0..<profiles.len:
        CompilerScanProfilePrivateAliasUses(profiles[i], out)
    for i in 0..<linkPlan.exprLayer.exprs.len:
        let expr = linkPlan.exprLayer.exprs[i]
        if expr.callSurfaceKind != parser.NormalizedExprSurfaceCallMember:
            continue
        if expr.callResolved:
            continue
        if expr.callReason != parser.NormalizedExprCallReasonUnknownQualifiedTarget:
            continue
        if expr.callQualifier == "" || expr.callCallee == "":
            continue
        if CompilerIdentifierExportedByCase(expr.callCallee):
            continue
        let currentProfileIndex = parser.ParserProfileIndexLookupForNormalizedSourcePathExact(lookup,
                                                                                                 parser.ParserNormalizePath(expr.sourcePath))
        if currentProfileIndex < 0 || currentProfileIndex >= profiles.len:
            continue
        let currentProfile = profiles[currentProfileIndex]
        let targetModulePath = CompilerImportQualifierTargetModulePath(currentProfile,
                                                                         expr.callQualifier)
        if targetModulePath == "":
            continue
        if CompilerModulePathsSharePackage(currentProfile.ownerModulePath, targetModulePath):
            continue
        CompilerAppendPrivateImportDiagnostic(out, expr.callCallee)
    return out

fn CompilerSystemLinkExecFullReport(plan: sexec.SystemLinkExecPlan): str =
    return CompilerAppendSystemLinkExecPhaseLines(sexec.SystemLinkExecPlanReport(plan), plan)

fn CompilerSystemLinkExecBridgeMergeReport(plan: sexec.SystemLinkExecPlan): str =
    return CompilerAppendSystemLinkExecPhaseLines(sexec.SystemLinkExecBrowserBridgeReport(plan), plan)

fn CompilerWriteSystemLinkExecFullReport(rootDir: str,
                                           reportPath: str,
                                           plan: sexec.SystemLinkExecPlan): bool =
    if len(reportPath) <= 0:
        return true
    if !CompilerWriteOptionalReport(rootDir, reportPath, CompilerSystemLinkExecSummary(plan)):
        return false
    return CompilerWriteOptionalReport(rootDir, reportPath, CompilerSystemLinkExecFullReport(plan))

fn CompilerRequirePureSystemLinkExec(): bool =
    let raw = strutil.Strip(os.GetEnv("CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC"))
    return len(raw) > 0 && raw != "0" && raw != "false"

fn CompilerWriteSystemLinkExecRuntimeReport(rootDir: str,
                                             reportPath: str,
                                             plan: sexec.SystemLinkExecPlan,
                                             runtimeReport: str): bool =
    if len(reportPath) <= 0:
        return true
    var report = CompilerSystemLinkExecFullReport(plan)
    if len(runtimeReport) > 0:
        report = report + "\n" + runtimeReport
    return CompilerWriteOptionalReport(rootDir, reportPath, report)

fn CompilerPureSystemLinkExecUnsupported(reason: str): int32 =
    if CompilerRequirePureSystemLinkExec():
        CompilerPrintErr(reason)
        return 2
    return -1

fn CompilerTryRunPureSystemLinkExec(rootDir: str,
                                      req: creq.CompilerRequest,
                                      plan: sexec.SystemLinkExecPlan): int32 =
    if !sexec.SystemLinkExecPlanReady(plan):
        return CompilerPureSystemLinkExecUnsupported(" compiler pure system-link-exec: plan not ready")
    let browserBridgeObjectPath = sexec.SystemLinkExecBrowserBridgeObjectPath(plan)
    if len(browserBridgeObjectPath) > 0:
        return CompilerPureSystemLinkExecUnsupported(" compiler pure system-link-exec: browser bridge object not yet in pure runtime")
    let providerCompilerPath: str = CompilerCurrentExecutablePath(rootDir)
    let execRes = sexecrt.SystemLinkExecRuntimeExecutePlanWithCompiler(rootDir,
                                                                       plan,
                                                                       providerCompilerPath)
    if IsErr(execRes):
        return CompilerPureSystemLinkExecUnsupported(Error(execRes))
    let runtimeReport = sexecrt.SystemLinkExecRuntimeResultReport(Value(execRes))
    if !CompilerWriteSystemLinkExecRuntimeReport(rootDir, req.reportPath, plan, runtimeReport):
        CompilerPrintErr(Fmt" compiler: failed to write pure system-link-exec report: {req.reportPath}")
        return 2
    return 0

fn CompilerBrowserBridgeCompilerPath(rootDir: str,
                                       plan: sexec.SystemLinkExecPlan): str =
    let bridgeCompiler = CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return bridgeCompiler
    if CompilerPlanNeedsBootstrapBridge(plan):
        let bootstrapBridge = CompilerBootstrapBridgePath(rootDir, "browser bridge object")
        if len(bootstrapBridge) > 0:
            return bootstrapBridge
    return CompilerCurrentExecutablePath(rootDir)

fn CompilerWriteBrowserBridgeArtifacts(rootDir: str,
                                         plan: sexec.SystemLinkExecPlan): bool =
    if !sexec.SystemLinkExecWriteBrowserBridgeArtifact(rootDir, plan):
        return false
    if !sexec.SystemLinkExecWriteBrowserBridgeSource(rootDir, plan):
        return false
    return true

fn CompilerMaterializeBrowserBridgeObject(rootDir: str,
                                            plan: sexec.SystemLinkExecPlan): bool =
    let bridgeObjectPath = sexec.SystemLinkExecBrowserBridgeObjectPath(plan)
    let bridgeObjectBasePath = sexec.SystemLinkExecBrowserBridgeObjectBasePath(plan.systemLinkPlan.outputPath)
    if len(bridgeObjectBasePath) > 0 && len(bridgeObjectPath) <= 0:
        if os.FileExists(bridgeObjectBasePath):
            let _ = os.RemoveFile(bridgeObjectBasePath)
        return true
    if len(bridgeObjectPath) <= 0:
        return true
    let bridgeSourcePath = sexec.SystemLinkExecBrowserBridgeSourcePath(plan)
    if len(bridgeSourcePath) <= 0 || !chengpath.FileExistsNonEmpty(rootDir, bridgeSourcePath):
        return false
    let compilerPath = CompilerBrowserBridgeCompilerPath(rootDir, plan)
    if len(compilerPath) <= 0:
        return false
    if os.FileExists(bridgeObjectPath):
        let _ = os.RemoveFile(bridgeObjectPath)
    let logPath = bridgeObjectPath + ".compile.log"
    let compileArgs = [
        "system-link-exec",
        "--root:" + plan.systemLinkPlan.packageRoot,
        "--in:" + bridgeSourcePath,
        "--emit:obj",
        "--target:" + plan.systemLinkPlan.targetTriple,
        "--symbol-visibility:" + creq.CompilerSymbolVisibilityInternal(),
        "--out:" + bridgeObjectPath
    ]
    if !CompilerRunFileEnvLogged(rootDir,
                                   compilerPath,
                                   compileArgs,
                                   ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   logPath,
                                   "browser bridge object compile"):
        return false
    return chengpath.FileExistsNonEmpty(rootDir, bridgeObjectPath)

fn CompilerMaterializeBrowserBridgeOutputs(rootDir: str,
                                             plan: sexec.SystemLinkExecPlan): bool =
    if !CompilerWriteBrowserBridgeArtifacts(rootDir, plan):
        return false
    return CompilerMaterializeBrowserBridgeObject(rootDir, plan)

fn CompilerForwardBootstrapBridge(rootDir: str,
                                    bridgeCompiler: str,
                                    cmd: str,
                                    req: creq.CompilerRequest,
                                    args: str[],
                                    sourceReport: str,
                                    browserBridgeObjectPath: str): int32 =
    let bridgeReportPath = CompilerBridgeTempReportPath(req, "bootstrap_bridge")
    if len(bridgeReportPath) > 0 && os.FileExists(bridgeReportPath):
        let _ = os.RemoveFile(bridgeReportPath)
    let baseBridgeArgsRes = CompilerArgsWithBrowserBridgeObject(CompilerArgsWithReportOut(args, bridgeReportPath),
                                                                  browserBridgeObjectPath)
    if IsErr(baseBridgeArgsRes):
        CompilerPrintErr(Error(baseBridgeArgsRes))
        return 2
    var bridgeArgs = Value(baseBridgeArgsRes)
    if cmd == "system-link-exec" && CompilerBridgeRequestNeedsSurfaceRewrite(rootDir, req):
        let stagedReqRes = CompilerBridgeSurfaceStageRequest(rootDir, req)
        if IsErr(stagedReqRes):
            CompilerPrintErr(Error(stagedReqRes))
            return 2
        bridgeArgs = CompilerArgsWithBridgeStagedRequest(bridgeArgs, Value(stagedReqRes))
    let rc = CompilerForwardToBridge(rootDir, bridgeCompiler, cmd, bridgeArgs)
    if rc != 0:
        return rc
    if len(req.reportPath) <= 0:
        return 0
    if !os.FileExists(bridgeReportPath):
        CompilerPrintErr(" compiler: bootstrap bridge report missing: " + bridgeReportPath)
        return 2
    let bridgeReport = chengpath.ReadTextFile("", bridgeReportPath)
    let mergedReport = CompilerMergeBridgeReport(sourceReport, bridgeReport)
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, mergedReport):
        CompilerPrintErr(" compiler: failed to write merged report: " + req.reportPath)
        return 2
    let _ = os.RemoveFile(bridgeReportPath)
    return 0

fn CompilerCurrentExecutablePath(rootDir: str): str =
    let raw = strutil.Strip(cmdline.ProgramName())
    if len(raw) <= 0:
        return ""
    let resolved = hostops.ResolveProgram(rootDir, raw)
    if len(resolved) > 0:
        return resolved
    return chengpath.PathAbsolute(rootDir, raw)

fn CompilerBootstrapStageVariantPath(currentPathRaw: str,
                                       basePathRaw: str): bool =
    let currentPath = strutil.Strip(currentPathRaw)
    let basePath = strutil.Strip(basePathRaw)
    if len(currentPath) <= 0 || len(basePath) <= 0:
        return false
    let currentParts = os.SplitFile(currentPath)
    let baseParts = os.SplitFile(basePath)
    if currentParts.dir != baseParts.dir:
        return false
    let currentName = currentParts.name + currentParts.ext
    let baseName = baseParts.name + baseParts.ext
    if currentName == baseName:
        return true
    return strutil.StartsWith(currentName, baseName + ".")

fn CompilerArtifactSetFreshAgainstOutput(rootDir: str,
                                           outputPath: str,
                                           artifacts: str[]): bool =
    for i in 0..<artifacts.len:
        let artifactPath = artifacts[i]
        if !chengpath.PathFileExists(artifactPath):
            return false
        if artifactPath != outputPath &&
           CompilerPathNewerThan(rootDir, outputPath, artifactPath):
            return false
    return true

fn CompilerBackendDriverReadyOverride(rootDir: str,
                                        backendDriverPath: str): bool =
    let readyText = strutil.Strip(os.GetEnv("CHENG_BACKEND_DRIVER_READY"))
    if len(readyText) <= 0 || readyText == "0":
        return false
    let currentPath = CompilerCurrentExecutablePath(rootDir)
    if len(currentPath) <= 0:
        return false
    return currentPath == backendDriverPath &&
           chengpath.FileExistsNonEmpty(rootDir, backendDriverPath)

fn CompilerEnsureBootstrapBridge(rootDir: str,
                                   context: str): bool =
    let snapshot = contracts.BootstrapSnapshotDefault(rootDir)
    if CompilerBootstrapBridgeFresh(rootDir, snapshot):
        return true
    if CompilerBootstrapBridge(rootDir) == 0:
        return true
    CompilerPrintErr(" compiler: bootstrap bridge failed inside " + context)
    return false

fn CompilerBackendDriverFreshForCompiler(rootDir: str,
                                           backendDriverPath: str,
                                           compilerPath: str): bool =
    if !chengpath.FileExistsNonEmpty(rootDir, backendDriverPath):
        return false
    if !chengpath.PathFileExists(backendDriverPath + ".map"):
        return false
    if len(compilerPath) > 0 &&
       compilerPath != backendDriverPath &&
       CompilerPathNewerThan(rootDir, compilerPath, backendDriverPath):
        return false
    let packageRoot = CompilerPackageRootForSource(rootDir,
                                                     buildplan.BackendBuildPlanBackendDriverEntryPath(rootDir))
    var freshInputs: str[]
    var freshErr = ""
    if !CompilerAppendOrdinaryClosure(packageRoot,
                                        buildplan.BackendBuildPlanBackendDriverEntryPath(rootDir),
                                        freshInputs,
                                        freshErr):
        return false
    let dynamicFreshInputs = [
        chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_program_entry_provider.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_darwin.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_linux.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/debug_runtime_stub.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_backend.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_get_env_bridge.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_host_runtime.cheng"),
        chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_main.cheng"),
        chengpath.PathAbsolute(rootDir, "src/std/os_host_process.cheng"),
        chengpath.PathAbsolute(rootDir, "src/std/os.cheng")
    ]
    for i in 0..<dynamicFreshInputs.len:
        CompilerPathSetAdd(freshInputs, dynamicFreshInputs[i])
    for i in 0..<freshInputs.len:
        if CompilerPathNewerThan(rootDir, freshInputs[i], backendDriverPath):
            return false
    return true

fn CompilerBackendDriverFresh(rootDir: str,
                                backendDriverPath: str): bool =
    return CompilerBackendDriverFreshForCompiler(rootDir,
                                                   backendDriverPath,
                                                   CompilerBridgeCompilerPath(rootDir))

fn CompilerEnsureBackendDriver(rootDir: str,
                                 context: str): bool =
    if !CompilerEnsureBootstrapBridge(rootDir, context):
        return false
    let backendDriver = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
    if CompilerBackendDriverReadyOverride(rootDir, backendDriver):
        return true
    if CompilerBackendDriverFresh(rootDir, backendDriver):
        return true
    if CompilerBuildBackendDriver(rootDir) == 0:
        return true
    CompilerPrintErr(" compiler: backend driver build failed inside " + context)
    return false

fn CompilerBootstrapFreshInputsReady(rootDir: str,
                                       stage3Path: str): bool =
    var currentFreshInputs: str[]
    var currentFreshErr = ""
    if contracts.BootstrapFreshInputPaths(rootDir, currentFreshInputs, currentFreshErr):
        var cachedFreshInputs: str[]
        if !contracts.BootstrapCachedFreshInputPaths(rootDir, cachedFreshInputs):
            return false
        if !CompilerPathSetsEqual(cachedFreshInputs, currentFreshInputs):
            return false
        for i in 0..<currentFreshInputs.len:
            if CompilerPathNewerThan(rootDir, currentFreshInputs[i], stage3Path):
                return false
        return true
    let snapshotPath = contracts.BootstrapSnapshotPath(rootDir)
    if chengpath.PathFileExists(snapshotPath):
        let snapshotText = chengpath.ReadTextFile(rootDir, snapshotPath)
        let raw = strutil.Strip(contracts.BootstrapLineValue(snapshotText, "fresh_input_paths"))
        if len(raw) > 0:
            var start: int32
            let n = len(raw)
            var i = 0
            for i in i..<= n:
                var itemEnd = false
                if i == n:
                    itemEnd = true
                elif raw[i] == ',':
                    itemEnd = true
                if !itemEnd:
                    continue
                let item = strutil.Strip(strings.SliceBytes(raw, start, i - start))
                if len(item) > 0 && CompilerPathNewerThan(rootDir, item, stage3Path):
                    return false
                start = i + 1
            return true
    return !CompilerPathNewerThan(rootDir, contracts.BootstrapSeedSourcePath(rootDir), stage3Path) &&
           !CompilerPathNewerThan(rootDir, contracts.BootstrapStage1SourcePath(rootDir), stage3Path) &&
           !CompilerPathNewerThan(rootDir,
                                    contracts.BootstrapCompilerEntrySourcePath(rootDir),
                                    stage3Path) &&
           !CompilerPathNewerThan(rootDir,
                                    contracts.BootstrapCompilerRuntimeSourcePath(rootDir),
                                    stage3Path) &&
           !CompilerPathNewerThan(rootDir,
                                    contracts.BootstrapCompilerRequestSourcePath(rootDir),
                                    stage3Path) &&
           !CompilerPathNewerThan(rootDir,
                                    contracts.BootstrapGateMainSourcePath(rootDir),
                                    stage3Path)

