    if cmd == "debug-report" || cmd == "print-symbols" || cmd == "print-line-map":
        return true
    if cmd == "print-object" || cmd == "print-elf" || cmd == "print-asm":
        return true
    if cmd == "verify-backend-driver-command-surface" ||
       cmd == "verify-chain-node-resilience" ||
       cmd == "verify-oracle-resilience" ||
       cmd == "oracle-fixture-query" ||
       cmd == "verify-r2c-react-surface" ||
       cmd == "verify-debug-tools" ||
       cmd == "verify-orphan-guard" ||
       cmd == "verify-debug-runtime" ||
       cmd == "verify-debug-profile":
        return true
    if cmd == "verify-diloco":
        return true
    if cmd == "profile-run" || cmd == "profile-report" || cmd == "crash-report":
        return true
    if cmd == "run-host-smokes" || cmd == "run-stage23-libp2p-smokes" || cmd == "slice-gate":
        return true
    if cmd == "build-zero-exit" || cmd == "build-panic-trace" || cmd == "build-bounds-trace":
        return true
    if cmd == "build-signal-trace" || cmd == "build-call-chain" || cmd == "build-ffi-handle":
        return true
    if cmd == "build-bft-state-machine" || cmd == "deploy-bft-validator-three-node":
        return true
    if cmd == "verify-bft-validator-three-node" || cmd == "status-bft-validator-three-node":
        return true
    if cmd == "stop-bft-validator-three-node" || cmd == "bench-bft-validator-three-node":
        return true
    if cmd == "build-oracle-bft-state-machine" || cmd == "deploy-oracle-bft-three-node":
        return true
    if cmd == "verify-oracle-bft-three-node" || cmd == "status-oracle-bft-three-node":
        return true
    if cmd == "stop-oracle-bft-three-node":
        return true
    if cmd == "build-browser-host-wasm" || cmd == "build-rwad-bft-state-machine":
        return true
    if cmd == "build-program-selfhost" || cmd == "build-chain-node":
        return true
    if cmd == "build-linux-nolibc-exe" || cmd == "build-chain-node-linux":
        return true
    if cmd == "build-rwad-bft-linux" || cmd == "run-linux-object-smokes":
        return true
    if cmd == "run-udp-importc-smoke" || cmd == "run-wasm-smokes":
        return true
    if cmd == "run-browser-host-wasm-smoke" || cmd == "run-chain-node-cli-smoke":
        return true
    if cmd == "run-chain-node-process-smoke" || cmd == "run-chain-node-three-node-smoke":
        return true
    if cmd == "run-chain-node-resilience-smoke":
        return true
    if cmd == "run-oracle-resilience-smoke":
        return true
    if cmd == "run-tailnet-control-smoke" || cmd == "run-fresh-node-selfhost-gate":
        return true
    if cmd == "run-migration-gate" || cmd == "run-browser-webrtc-smokes":
        return true
    if cmd == "r2c-react" || cmd == "r2c-react-controller" || cmd == "vpn-gui" || cmd == "vpn-proxy":
        return true
    if cmd == "run-tcp-twoproc-smoke" || cmd == "run-quic-twoproc-smoke":
        return true
    return false

fn CompilerForwardStage3Command(rootDir: str,
                                  cmd: str,
                                  args: str[]): int32 =
    let stage3Path = contracts.BootstrapStage3Path(rootDir)
    if !chengpath.FileExistsNonEmpty(rootDir, stage3Path):
        CompilerPrintErr(" compiler: missing stage3 compiler for command: " + cmd)
        return 2
    let currentPath = CompilerCurrentExecutablePath(rootDir)
    if len(currentPath) > 0 && currentPath == stage3Path:
        CompilerPrintErr(" compiler: command unavailable in bootstrap stage3: " + cmd)
        return 2
    return CompilerForwardToBridge(rootDir, stage3Path, cmd, args)

fn CompilerForwardToBridgeEnv(rootDir: str,
                                bridgeCompiler: str,
                                cmd: str,
                                args: str[],
                                envOverrides: str[]): int32 =
    let logDir = chengpath.PathAbsolute(rootDir, "artifacts/forward")
    if !chengpath.PathDirExists(logDir):
        let _ = chengpath.MkdirP(rootDir, logDir)
    var logName = "forward."
    logName = logName + cmd
    logName = logName + ".log"
    let logPath = os.JoinPath(logDir, logName)
    let cleanArgs = CompilerArgsWithoutProgress(args)
    var forwardArgs: str[]
    add(forwardArgs, cmd)
    for i in 0..<cleanArgs.len:
        add(forwardArgs, cleanArgs[i])
    var forwardEnv: str[]
    add(forwardEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    let progressEnv = CompilerProgressEnvOverrides(rootDir, args)
    for i in 0..<progressEnv.len:
        add(forwardEnv, progressEnv[i])
    if CompilerProgressRequestedFromArgs(args):
        add(forwardEnv, "CHENG_PROGRESS_APPEND=1")
    let backendDriverForwardLog = strutil.Strip(os.GetEnv("CHENG_BACKEND_DRIVER_FORWARD_LOG"))
    if len(backendDriverForwardLog) > 0:
        add(forwardEnv, "CHENG_BACKEND_DRIVER_FORWARD_LOG=" + backendDriverForwardLog)
    for i in 0..<envOverrides.len:
        add(forwardEnv, envOverrides[i])
    let run = hostops.RunFileLogged(rootDir,
                                      "forward_" + cmd,
                                      bridgeCompiler,
                                      forwardArgs,
                                      forwardEnv,
                                      rootDir,
                                      0,
                                      logPath)
    var output = run.output
    output = strutil.Strip(output)
    if len(output) > 0:
        if run.exitCode != 0 || cmd != "system-link-exec":
            CompilerPrintErr(output)
    elif run.exitCode != 0:
        CompilerPrintErr(" compiler: forward command failed: " + cmd)
    return run.exitCode

fn CompilerForwardToBridge(rootDir: str,
                             bridgeCompiler: str,
                             cmd: str,
                             args: str[]): int32 =
    return CompilerForwardToBridgeEnv(rootDir, bridgeCompiler, cmd, args, [])

fn CompilerQuoteShell(value: str): str =
    if len(value) <= 0:
        return "''"
    var out = "'"
    for i in 0..<len(value):
        if value[i] == char(39):
            out = out + "'\"'\"'"
        else:
            out = out + strings.CharToStr(value[i])
    out = out + "'"
    return out

fn CompilerFileCommand(filePath: str,
                         argv: str[]): str =
    var command = CompilerQuoteShell(filePath)
    for i in 0..<argv.len:
        command = command + " " + CompilerQuoteShell(argv[i])
    return command

fn CompilerEnvLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32
    var i: int32
    for i in i..<= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if line.len >= prefix.len:
                if strings.SliceBytes(line, 0, prefix.len) == prefix:
                    return strings.SliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
    return ""

fn CompilerAppendKeyValueLine(out: var str,
                                key: str,
                                value: str) =
    out = out + key
    out = out + "="
    out = out + value
    out = out + "\n"

fn CompilerAppendSectionLabel(out: var str,
                                label: str) =
    out = out + "\n["
    out = out + label
    out = out + "]\n"

fn CompilerPipePair(left: str,
                      right: str): str =
    var out = left
    out = out + "|"
    out = out + right
    return out

fn CompilerUnavailableInBackendDriver(cmd: str): int32 =
    CompilerPrintErr(" compiler: command unavailable in backend_driver: " + cmd)
    return 2

fn CompilerSmokeOkText(smokeName: str): str =
    var out = " "
    out = out + smokeName
    out = out + " ok"
    return out

fn CompilerJoinCsv(values: str[]): str =
    var out = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + ","
        out = out + values[i]
    return out

fn CompilerBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn CompilerJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    return quote + text + quote

fn CompilerR2cReactEffectiveRoot(rootDir: str): str =
    let rawRoot = strutil.Strip(cmdline.ReadFlagOrDefault("--root", rootDir))
    if len(rawRoot) <= 0:
        return rootDir
    return chengpath.PathAbsolute(rootDir, rawRoot)

fn CompilerWriteR2cReactStatusReport(reportPath: str,
                                         rootDir: str): bool =
    let effectiveRoot = CompilerR2cReactEffectiveRoot(rootDir)
    return r2cstatus.R2cReactWriteStatusReport(reportPath, effectiveRoot)

fn CompilerR2cReactStatus(rootDir: str): int32 =
    let effectiveRoot = CompilerR2cReactEffectiveRoot(rootDir)
    let outPathRaw = strutil.Strip(cmdline.ReadFlagOrDefault("--out", ""))
    if len(outPathRaw) > 0:
        let outPath = chengpath.PathAbsolute(effectiveRoot, outPathRaw)
        if !CompilerWriteR2cReactStatusReport(outPath, effectiveRoot):
            CompilerPrintErr(" compiler: failed to write r2c-react status report")
            return 1
        CompilerPrintLine(outPath)
        return 0
    let outPath = os.JoinPath(effectiveRoot, "artifacts/r2c_react_status_report_v1.json")
    if !CompilerWriteR2cReactStatusReport(outPath, effectiveRoot):
        CompilerPrintErr(" compiler: failed to write r2c-react status report")
        return 1
    let body = chengpath.ReadTextFile("", outPath)
    CompilerPrintLine(body)
    return 0

fn CompilerRemoteSummaryPath(outDir: str,
                               hostLabel: str): str =
    return os.JoinPath(outDir, hostLabel + ".summary.txt")

fn CompilerRemoteLogPath(outDir: str,
                           hostLabel: str,
                           stem: str): str =
    return os.JoinPath(outDir, hostLabel + "." + stem + ".log")

fn CompilerRemoteOrdinarySmokeNames(): str[] =
    let singleRaw = cmdline.ReadFlagOrDefault("--smoke-name", "")
    let singleSmoke = strutil.Strip(singleRaw)
    var out: str[]
    if len(singleSmoke) > 0:
        add(out, singleSmoke)
        return out
    add(out, "ordinary_zero_exit_fixture")
    add(out, "host_process_exec_file_direct_seq_smoke")
    add(out, "host_process_exec_file_capture_smoke")
    add(out, "msquic_bindtext_expr_smoke")
    return out

fn CompilerRemoteSmokeExpectedText(smokeName: str): str =
    if smokeName == "ordinary_zero_exit_fixture":
        return ""
    return CompilerSmokeOkText(smokeName)

fn CompilerRemoteSmokeRequireEmptyOutput(smokeName: str): bool =
    return smokeName == "ordinary_zero_exit_fixture"

fn CompilerRemotePlanMatches(stage3Text: str,
                               backendText: str): bool =
    let left = strutil.Strip(stage3Text)
    let right = strutil.Strip(backendText)
    return left == right

fn CompilerRunProgramCaptureLogged(rootDir: str,
                                     label: str,
                                     programName: str,
                                     argv: str[],
                                     logPath: str,
                                     context: str,
                                     outputOut: var str): bool =
    let run = hostops.RunProgramLogged(rootDir,
                                         label,
                                         programName,
                                         argv,
                                         [],
                                         rootDir,
                                         0,
                                         logPath)
    outputOut = run.output
    if hostops.LoggedRunOk(run):
        return true
    let output = strutil.Strip(run.output)
    if len(output) > 0:
        CompilerPrintErr(output)
    else:
        CompilerPrintErr(" compiler: " + context + " failed")
    return false

fn CompilerRemoteTransportRetryable(output: str): bool =
    let trimmed = strutil.Strip(output)
    return strutil.Contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.Contains(trimmed, "Connection to ") && strutil.Contains(trimmed, " timed out")) ||
           strutil.Contains(trimmed, "No route to host") ||
           strutil.Contains(trimmed, "Connection reset by peer") ||
           strutil.Contains(trimmed, "kex_exchange_identification") ||
           strutil.Contains(trimmed, "Connection closed by remote host")

fn CompilerRunRemoteTransportCommand(rootDir: str,
                                       label: str,
                                       programName: str,
                                       argv: str[],
                                       logPath: str,
                                       context: str,
                                       outputOut: var str): bool =
    var lastOutput = ""
    for attempt in 0..<3:
        if CompilerRunProgramCaptureLogged(rootDir,
                                             label,
                                             programName,
                                             argv,
                                             logPath,
                                             context,
                                             lastOutput):
            outputOut = lastOutput
            return true
        if attempt >= 2 || !CompilerRemoteTransportRetryable(lastOutput):
            outputOut = lastOutput
            return false
        CompilerPrintLine("remote transport retry " + IntToStr(attempt + 1) + " " + context)
        os.SleepMs((attempt + 1) * 1000)
    outputOut = lastOutput
    return false

fn CompilerRunRemoteCommand(rootDir: str,
                              sshTarget: str,
                              label: str,
                              remoteArgv: str[],
                              logPath: str,
                              context: str,
                              outputOut: var str): bool =
    var argv: str[]
    add(argv, "-n")
    add(argv, "-o")
    add(argv, "BatchMode=yes")
    add(argv, "-o")
    add(argv, "ConnectTimeout=8")
    add(argv, "-o")
    add(argv, "ServerAliveInterval=5")
    add(argv, "-o")
    add(argv, "ServerAliveCountMax=3")
    add(argv, sshTarget)
    for i in 0..<remoteArgv.len:
        add(argv, remoteArgv[i])
    return CompilerRunRemoteTransportCommand(rootDir,
                                               label,
                                               "ssh",
                                               argv,
                                               logPath,
                                               context,
                                               outputOut)

fn CompilerRunRemoteRsync(rootDir: str,
                            sshTarget: str,
                            label: str,
                            localSource: str,
                            remoteRoot: str,
                            logPath: str,
                            context: str,
                            outputOut: var str): bool =
    let remoteShell = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=3"
    let rsyncDest = sshTarget + ":" + remoteRoot + "/"
    let argv = [
        "-a",
        "-e", remoteShell,
        "--delete",
        "--exclude", ".git",
        "--exclude", "artifacts",
        "--exclude", "chengcache",
        "--exclude", "node_modules",
        localSource,
        rsyncDest
    ]
    return CompilerRunRemoteTransportCommand(rootDir,
                                               label,
                                               "rsync",
                                               argv,
                                               logPath,
                                               context,
                                               outputOut)

fn CompilerWriteRemoteSummary(rootDir: str,
                                summaryPath: str,
                                summaryText: str,
                                verified: bool): bool =
    var out = summaryText
    CompilerAppendKeyValueLine(out, "verified", CompilerBoolText(verified))
    return chengpath.WriteTextFile(rootDir, summaryPath, out)

fn CompilerVerifyRemoteExeSmoke(rootDir: str,
                                  outDir: str,
                                  hostLabel: str,
                                  sshTarget: str,
                                  remoteRoot: str,
                                  smokeName: str,
                                  summaryText: var str): bool =
    let remotePackageRoot = remoteRoot
    let remoteBackend = remoteRoot + "/artifacts/backend_driver/cheng"
    var remoteSmokeOut = remoteRoot
    remoteSmokeOut = remoteSmokeOut + "/artifacts/backend_driver/"
    remoteSmokeOut = remoteSmokeOut + smokeName
    remoteSmokeOut = remoteSmokeOut + ".selftest"
    let compileLogPath = CompilerRemoteLogPath(outDir, hostLabel, smokeName + ".compile")
    let runLogPath = CompilerRemoteLogPath(outDir, hostLabel, smokeName + ".run")
    var remoteSmokeSource = remotePackageRoot
    remoteSmokeSource = remoteSmokeSource + "/src/tests/"
    remoteSmokeSource = remoteSmokeSource + smokeName
    remoteSmokeSource = remoteSmokeSource + ".cheng"
    let remoteEnvRoot = "CHENG_ROOT=" + remoteRoot
    var compileLabel = hostLabel
    compileLabel = compileLabel + "_"
    compileLabel = compileLabel + smokeName
    compileLabel = compileLabel + "_compile"
    var runLabel = hostLabel
    runLabel = runLabel + "_"
    runLabel = runLabel + smokeName
    runLabel = runLabel + "_run"
    var compileArgv: str[]
    add(compileArgv, "env")
    add(compileArgv, remoteEnvRoot)
    add(compileArgv, remoteBackend)
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root:" + remotePackageRoot)
    add(compileArgv, "--contract-in:" + remoteRoot + "/" + contracts.BootstrapStage1SourceRelPath())
    add(compileArgv, "--in:" + remoteSmokeSource)
    add(compileArgv, "--emit:exe")
    add(compileArgv, "--target:x86_64-unknown-linux-gnu")
    add(compileArgv, "--out:" + remoteSmokeOut)
    var compileOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   compileLabel,
                                   compileArgv,
                                   compileLogPath,
                                   "remote x86 smoke compile " + smokeName,
                                   compileOut):
        CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    let runArgv = [remoteSmokeOut]
    var runOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   runLabel,
                                   runArgv,
                                   runLogPath,
                                   "remote x86 smoke run " + smokeName,
                                   runOut):
        CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    let runTrimmed = strutil.Strip(runOut)
    let requireEmpty = CompilerRemoteSmokeRequireEmptyOutput(smokeName)
    let expected = CompilerRemoteSmokeExpectedText(smokeName)
    if requireEmpty:
        if len(runTrimmed) > 0:
            CompilerPrintErr(" compiler: remote x86 smoke expected empty stdout: " + smokeName)
            CompilerPrintErr(runTrimmed)
            CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
            CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
            CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
            return false
    elif !strutil.Contains(runTrimmed, expected):
        CompilerPrintErr(" compiler: remote x86 smoke output drifted: " + smokeName)
        CompilerPrintErr(runTrimmed)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
    CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
    CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "true")
    return true

fn CompilerVerifyRemoteChainNodeSelfTest(rootDir: str,
                                           outDir: str,
                                           hostLabel: str,
                                           sshTarget: str,
                                           remoteRoot: str,
                                           summaryText: var str): bool =
    let remotePackageRoot = remoteRoot
    let remoteBackend = remoteRoot + "/artifacts/backend_driver/cheng"
    let remoteOut = remoteRoot + "/artifacts/backend_driver/cheng_node_main.remote_selftest"
    let compileLogPath = CompilerRemoteLogPath(outDir, hostLabel, "chain_node_self_test.compile")
    let runLogPath = CompilerRemoteLogPath(outDir, hostLabel, "chain_node_self_test.run")
    var remoteSource = remotePackageRoot
    remoteSource = remoteSource + "/src/apps/chain_node/cheng_node_main.cheng"
    let remoteEnvRoot = "CHENG_ROOT=" + remoteRoot
    var compileArgv: str[]
    add(compileArgv, "env")
    add(compileArgv, remoteEnvRoot)
    add(compileArgv, remoteBackend)
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root:" + remotePackageRoot)
    add(compileArgv, "--contract-in:" + remoteRoot + "/" + contracts.BootstrapStage1SourceRelPath())
    add(compileArgv, "--in:" + remoteSource)
    add(compileArgv, "--emit:exe")
    add(compileArgv, "--target:x86_64-unknown-linux-gnu")
    add(compileArgv, "--out:" + remoteOut)
    var compileOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_chain_node_compile",
                                   compileArgv,
                                   compileLogPath,
                                   "remote x86 chain_node compile",
                                   compileOut):
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    let runArgv = [remoteOut, "chain", "self", "test"]
    var runOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_chain_node_run",
                                   runArgv,
                                   runLogPath,
                                   "remote x86 chain_node self-test",
                                   runOut):
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    let runTrimmed = strutil.Strip(runOut)
    if !strutil.Contains(runTrimmed, "cheng chain_node self-test ok"):
        CompilerPrintErr(" compiler: remote x86 chain_node self-test drifted")
        CompilerPrintErr(runTrimmed)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
    CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
    CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "true")
    return true

fn CompilerVerifyX86RemoteHost(rootDir: str,
                                 outDir: str,
                                 hostLabel: str,
                                 sshTarget: str,
                                 remoteRoot: str,
                                 ordinarySmokes: str[],
                                 chainNodeSelfTest: bool): bool =
    let summaryPath = CompilerRemoteSummaryPath(outDir, hostLabel)
    let mkdirLogPath = CompilerRemoteLogPath(outDir, hostLabel, "mkdir")
    let rsyncLogPath = CompilerRemoteLogPath(outDir, hostLabel, "rsync")
    let cleanLogPath = CompilerRemoteLogPath(outDir, hostLabel, "clean")
    let stage0DirLogPath = CompilerRemoteLogPath(outDir, hostLabel, "stage0_dir")
    let stage0CcLogPath = CompilerRemoteLogPath(outDir, hostLabel, "stage0_cc")
    let bootstrapLogPath = CompilerRemoteLogPath(outDir, hostLabel, "bootstrap_bridge")
    let buildBackendLogPath = CompilerRemoteLogPath(outDir, hostLabel, "build_backend_driver")
    let stage3PlanLogPath = CompilerRemoteLogPath(outDir, hostLabel, "stage3_plan")
    let backendPlanLogPath = CompilerRemoteLogPath(outDir, hostLabel, "backend_plan")
    let smokeDirLogPath = CompilerRemoteLogPath(outDir, hostLabel, "smoke_mkdir")
    let remoteStage0 = remoteRoot + "/artifacts/bootstrap/cheng.stage0"
    let remoteStage3 = remoteRoot + "/artifacts/bootstrap/cheng.stage3"
    let remoteBackend = remoteRoot + "/artifacts/backend_driver/cheng"
    var summaryText = ""
    CompilerAppendKeyValueLine(summaryText, "host", hostLabel)
    CompilerAppendKeyValueLine(summaryText, "ssh_target", sshTarget)
    CompilerAppendKeyValueLine(summaryText, "remote_root", remoteRoot)
    CompilerAppendKeyValueLine(summaryText, "ordinary_smoke_count", IntToStr(ordinarySmokes.len))
    CompilerAppendKeyValueLine(summaryText, "ordinary_smoke_names", CompilerJoinCsv(ordinarySmokes))
    CompilerAppendKeyValueLine(summaryText, "chain_node_self_test", CompilerBoolText(chainNodeSelfTest))
    var mkdirOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_mkdir",
                                   ["mkdir", "-p", remoteRoot],
                                   mkdirLogPath,
                                   "remote x86 mkdir " + hostLabel,
                                   mkdirOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let rsyncSource = rootDir + "/"
    var rsyncOut = ""
    if !CompilerRunRemoteRsync(rootDir,
                                 sshTarget,
                                 hostLabel + "_rsync",
                                 rsyncSource,
                                 remoteRoot,
                                 rsyncLogPath,
                                 "remote x86 rsync " + hostLabel,
                                 rsyncOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let cleanArgv = [
        "rm",
        "-rf",
        remoteRoot + "/chengcache",
        remoteRoot + "/artifacts/backend_driver",
        remoteRoot + "/artifacts/bootstrap"
    ]
    var cleanOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_clean",
                                   cleanArgv,
                                   cleanLogPath,
                                   "remote x86 clean " + hostLabel,
                                   cleanOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var stage0DirOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage0_dir",
                                   ["mkdir", "-p", remoteRoot + "/artifacts/bootstrap"],
                                   stage0DirLogPath,
                                   "remote x86 stage0 dir " + hostLabel,
                                   stage0DirOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let ccArgv = [
        "cc",
        "-std=c11",
        "-O2",
        "-Wall",
        "-Wextra",
        "-pedantic",
        remoteRoot + "/bootstrap/cheng_seed.c",
        "-o",
        remoteStage0
    ]
    var stage0CcOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage0_cc",
                                   ccArgv,
                                   stage0CcLogPath,
                                   "remote x86 stage0 cc " + hostLabel,
                                   stage0CcOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let bootstrapArgv = [
        "env",
        "CHENG_ROOT=" + remoteRoot,
        "CHENG_TARGET=x86_64-unknown-linux-gnu",
        remoteStage0,
        "bootstrap-bridge"
    ]
    var bootstrapOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_bootstrap",
                                   bootstrapArgv,
                                   bootstrapLogPath,
                                   "remote x86 bootstrap-bridge " + hostLabel,
                                   bootstrapOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let backendBuildArgv = [
        "env",
        "CHENG_ROOT=" + remoteRoot,
        "CHENG_TARGET=x86_64-unknown-linux-gnu",
        remoteStage3,
        "build-backend-driver",
        "--target:x86_64-unknown-linux-gnu"
    ]
    var backendBuildOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_build_backend_driver",
                                   backendBuildArgv,
                                   buildBackendLogPath,
                                   "remote x86 build-backend-driver " + hostLabel,
                                   backendBuildOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let stage3PlanArgv = [
        "env",
        "CHENG_ROOT=" + remoteRoot,
        remoteStage3,
        "print-build-plan",
        "--target:x86_64-unknown-linux-gnu"
    ]
    var stage3PlanOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage3_plan",
                                   stage3PlanArgv,
                                   stage3PlanLogPath,
                                   "remote x86 stage3 plan " + hostLabel,
                                   stage3PlanOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var backendPlanOut = ""
    let backendPlanArgv = [
        "env",
        "CHENG_ROOT=" + remoteRoot,
        remoteBackend,
        "print-build-plan",
        "--target:x86_64-unknown-linux-gnu"
    ]
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_backend_plan",
                                   backendPlanArgv,
                                   backendPlanLogPath,
                                   "remote x86 backend plan " + hostLabel,
                                   backendPlanOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let planCoreMatch = CompilerRemotePlanMatches(stage3PlanOut, backendPlanOut)
    CompilerAppendKeyValueLine(summaryText, "stage3_plan_log", stage3PlanLogPath)
    CompilerAppendKeyValueLine(summaryText, "backend_plan_log", backendPlanLogPath)
    CompilerAppendKeyValueLine(summaryText, "plan_core_match", CompilerBoolText(planCoreMatch))
    if !planCoreMatch:
        CompilerPrintErr(" compiler: remote x86 plan drifted on " + hostLabel)
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var smokeDirOut = ""
    if !CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_smoke_dir",
                                   ["mkdir", "-p", remoteRoot + "/artifacts/backend_driver"],
                                   smokeDirLogPath,
                                   "remote x86 smoke dir " + hostLabel,
                                   smokeDirOut):
        let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    for i in 0..<ordinarySmokes.len:
        if !CompilerVerifyRemoteExeSmoke(rootDir,
                                           outDir,
                                           hostLabel,
                                           sshTarget,
                                           remoteRoot,
                                           ordinarySmokes[i],
                                           summaryText):
            let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
            return false
    if chainNodeSelfTest:
        if !CompilerVerifyRemoteChainNodeSelfTest(rootDir,
                                                    outDir,
                                                    hostLabel,
                                                    sshTarget,
                                                    remoteRoot,
                                                    summaryText):
            let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
            return false
    let _ = CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, true)
    return true

fn CompilerVerifyX86LinuxRemote(rootDir: str,
                                  args: str[]): int32 =
    args
    let outDir = chengpath.PathAbsolute(rootDir, "artifacts/x86_remote_gate")
    let reportPath = os.JoinPath(outDir, "verify_x86_linux_remote.report.txt")
    let dmitSsh = strutil.Strip(cmdline.ReadFlagOrDefault("--dmit-ssh", "dmit"))
    let dmitRoot = strutil.Strip(cmdline.ReadFlagOrDefault("--dmit-root", "/root/cheng-lang-deploy"))
    let host64Ssh = strutil.Strip(cmdline.ReadFlagOrDefault("--remote64-ssh", "root@64.176.84.12"))
    let host64Root = strutil.Strip(cmdline.ReadFlagOrDefault("--remote64-root", "/root/cheng-lang-deploy"))
    let chainNodeSelfTestText = strutil.Strip(cmdline.ReadFlagOrDefault("--chain-node-self-test", "1"))
    let chainNodeSelfTest = chainNodeSelfTestText != "0"
    let ordinarySmokes = CompilerRemoteOrdinarySmokeNames()
    if ordinarySmokes.len <= 0:
        CompilerPrintErr(" compiler: remote x86 smoke suite is empty")
        return 2
    if !CompilerRemovePathTree(outDir):
        CompilerPrintErr(" compiler: failed to clear remote x86 gate dir: " + outDir)
        return 2
    if !chengpath.MkdirP(rootDir, outDir):
        CompilerPrintErr(" compiler: failed to create remote x86 gate dir: " + outDir)
        return 2
    var reportText = ""
    CompilerAppendKeyValueLine(reportText, "host_count", "2")
    CompilerAppendKeyValueLine(reportText, "host_a", CompilerPipePair("dmit", dmitSsh))
    CompilerAppendKeyValueLine(reportText, "host_b", CompilerPipePair("64", host64Ssh))
    CompilerAppendKeyValueLine(reportText, "ordinary_smoke_count", IntToStr(ordinarySmokes.len))
    CompilerAppendKeyValueLine(reportText, "ordinary_smoke_names", CompilerJoinCsv(ordinarySmokes))
    CompilerAppendKeyValueLine(reportText, "chain_node_self_test", CompilerBoolText(chainNodeSelfTest))
    if !CompilerVerifyX86RemoteHost(rootDir,
                                      outDir,
                                      "dmit",
                                      dmitSsh,
                                      dmitRoot,
                                      ordinarySmokes,
                                      chainNodeSelfTest):
        let dmitSummaryPath = CompilerRemoteSummaryPath(outDir, "dmit")
        let dmitSummaryText = chengpath.ReadTextFile("", dmitSummaryPath)
        CompilerAppendSectionLabel(reportText, "dmit")
        reportText = reportText + dmitSummaryText
        let _ = chengpath.WriteTextFile(rootDir, reportPath, reportText)
        return 2
    let dmitSummaryPath = CompilerRemoteSummaryPath(outDir, "dmit")
    let dmitSummaryText = chengpath.ReadTextFile("", dmitSummaryPath)
    CompilerAppendSectionLabel(reportText, "dmit")
    reportText = reportText + dmitSummaryText
    if !CompilerVerifyX86RemoteHost(rootDir,
                                      outDir,
                                      "64",
                                      host64Ssh,
                                      host64Root,
                                      ordinarySmokes,
                                      chainNodeSelfTest):
        let host64SummaryPath = CompilerRemoteSummaryPath(outDir, "64")
        let host64SummaryText = chengpath.ReadTextFile("", host64SummaryPath)
        CompilerAppendSectionLabel(reportText, "64")
        reportText = reportText + host64SummaryText
        let _ = chengpath.WriteTextFile(rootDir, reportPath, reportText)
        return 2
    let host64SummaryPath = CompilerRemoteSummaryPath(outDir, "64")
    let host64SummaryText = chengpath.ReadTextFile("", host64SummaryPath)
    CompilerAppendSectionLabel(reportText, "64")
    reportText = reportText + host64SummaryText
    if !chengpath.WriteTextFile(rootDir, reportPath, reportText):
        CompilerPrintErr(" compiler: failed to write remote x86 report: " + reportPath)
        return 2
    CompilerPrintLine("verify-x86-linux-remote: ok")
    CompilerPrintLine("report=" + reportPath)
    return 0

fn CompilerRuntimeAbiContractText(rootDir: str): str =
    let relPath = "src/core/tooling/backend_runtime_abi_contract.env"
    let absPath = chengpath.PathAbsolute(rootDir, relPath)
    return chengpath.ReadTextFile("", absPath)

fn CompilerRuntimeAbiPath(rootDir: str,
                            contractText: str,
                            key: str,
                            fallbackRel: str): str =
    var relPath = CompilerEnvLineValue(contractText, key)
    relPath = strutil.Strip(relPath)
    if len(relPath) > 0:
        return chengpath.PathAbsolute(rootDir, relPath)
    return chengpath.PathAbsolute(rootDir, fallbackRel)

fn CompilerRunCommandLogged(rootDir: str,
                              command: str,
                              logPath: str,
                              context: str): bool =
    let fullCommand = strutil.Join([command, " > ", CompilerQuoteShell(logPath), " 2>&1"], "")
    let rc = os.ExecShellCmdStatus(fullCommand, rootDir)
    if rc == 0:
        return true
    let output = strutil.Strip(chengpath.ReadTextFile("", logPath))
    if len(output) > 0:
        CompilerPrintErr(output)
    else:
        CompilerPrintErr(strutil.Join([" compiler: ", context, " failed"], ""))
    return false

fn CompilerRunFileEnvLogged(rootDir: str,
                              filePath: str,
                              argv: str[],
                              envOverrides: str[],
                              logPath: str,
                              context: str): bool =
    var mergedEnv = CompilerActiveRuntimeEnvOverrides(rootDir)
    for i in 0..<envOverrides.len:
        add(mergedEnv, envOverrides[i])
    let run = hostops.RunFileLogged(rootDir,
                                      context,
                                      filePath,
                                      argv,
                                      mergedEnv,
                                      rootDir,
                                      0,
                                      logPath)
    if hostops.LoggedRunOk(run):
        return true
    let runOutputRaw = run.output
    let output = strutil.Strip(runOutputRaw)
    if len(output) > 0:
        CompilerPrintErr(output)
    else:
        let failText = CompilerConcat3(" compiler: ", context, " failed")
        CompilerPrintErr(failText)
    return false

fn CompilerRunFileLogged(rootDir: str,
                           filePath: str,
                           argv: str[],
                           logPath: str,
                           context: str): bool =
    return CompilerRunFileEnvLogged(rootDir, filePath, argv, [], logPath, context)

fn CompilerRunProgramLogged(rootDir: str,
                              programName: str,
                              argv: str[],
                              logPath: str,
                              context: str): bool =
    let run = hostops.RunProgramLogged(rootDir,
                                         context,
                                         programName,
                                         argv,
                                         CompilerActiveRuntimeEnvOverrides(rootDir),
                                         rootDir,
                                         0,
                                         logPath)
    if hostops.LoggedRunOk(run):
        return true
    let runOutputRaw = run.output
    let output = strutil.Strip(runOutputRaw)
    if len(output) > 0:
        CompilerPrintErr(output)
    else:
        let failText = CompilerConcat3(" compiler: ", context, " failed")
        CompilerPrintErr(failText)
    return false

fn CompilerSharedEmitExtension(targetTriple: str): str =
    if tmat.TargetIsWindows(targetTriple):
        return ".dll"
    if targetTriple == "arm64-apple-darwin":
        return ".dylib"
    return ".so"

fn CompilerSharedEmitFileHint(targetTriple: str): str =
    if tmat.TargetIsWindows(targetTriple):
        return "PE32+"
    if targetTriple == "arm64-apple-darwin":
        return "shared library"
    return "shared object"

fn CompilerSharedEmitRunDirRel(): str =
    var now: monotimes.MonoTime
    now = monotimes.GetMonoTime()
    let nowNs: int64 = monotimes.MonoTimeNs(now)
    return "artifacts/shared_emit_smokes/" + int64ToStr(nowNs)

fn CompilerRunSharedEmitSmokes(rootDir: str): int32 =
    let packageRoot = CompilerPackageRootForSource(rootDir, compilerEntrySource)
    let fixtureSource = chengpath.PathAbsolute(rootDir, "src/tests/shared_emit_fixture.cheng")
    let targetTriple = CompilerRequestedTarget()
    let extension = CompilerSharedEmitExtension(targetTriple)
    let outDirRelRaw = CompilerSharedEmitRunDirRel()
    let outDirRel = newStringCopy(strDataPtr(outDirRelRaw), strLenFast(outDirRelRaw))
    let outDir = chengpath.PathAbsolute(rootDir, outDirRel)
    let outLibRelRaw = outDirRel + "/shared_emit_fixture" + extension
    let outLibRel = newStringCopy(strDataPtr(outLibRelRaw), strLenFast(outLibRelRaw))
    let outLib = chengpath.PathAbsolute(rootDir, outLibRel)
    let reportRelRaw = outDirRel + "/shared_emit_fixture.report.txt"
    let compileLogRelRaw = outDirRel + "/shared_emit_fixture.compile.log"
    let fileLogRelRaw = outDirRel + "/shared_emit_fixture.file.txt"
    let reportRel = newStringCopy(strDataPtr(reportRelRaw), strLenFast(reportRelRaw))
    let compileLogRel = newStringCopy(strDataPtr(compileLogRelRaw), strLenFast(compileLogRelRaw))
    let fileLogRel = newStringCopy(strDataPtr(fileLogRelRaw), strLenFast(fileLogRelRaw))
    let reportPath = chengpath.PathAbsolute(rootDir, reportRel)
    let compileLogPath = chengpath.PathAbsolute(rootDir, compileLogRel)
    let fileLogPath = chengpath.PathAbsolute(rootDir, fileLogRel)
    var currentCompiler = cmdline.ProgramName()
    if len(currentCompiler) <= 0:
        currentCompiler = CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) <= 0:
        CompilerPrintErr(" compiler: missing current compiler for run-shared-emit-smokes")
        return 2
    if !chengpath.MkdirP(rootDir, outDir):
        CompilerPrintErr(" compiler: failed to create shared emit smoke dir")
        return 2
    if chengpath.PathFileExists(outLib):
        os.RemoveFile(outLib)
    if chengpath.PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    let compileArgs = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + fixtureSource,
        "--emit:shared",
        "--target:" + targetTriple,
        "--out:" + outLib,
        "--report-out:" + reportPath
    ]
    if !CompilerRunFileLogged(rootDir,
                                currentCompiler,
                                compileArgs,
                                compileLogPath,
                                "run-shared-emit-smokes compile"):
        return 2
    if !chengpath.FileExistsNonEmpty(rootDir, outLib):
        CompilerPrintErr(" compiler: shared emit smoke missing output: " + outLib)
        return 2
    if !chengpath.FileExistsNonEmpty(rootDir, reportPath):
        CompilerPrintErr(" compiler: shared emit smoke missing report: " + reportPath)
        return 2
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !chengpath.TextContains(reportText, "emit=shared") ||
       !chengpath.TextContains(reportText, "main_function_present=0") ||
       !chengpath.TextContains(reportText, "missing_reasons=-") ||
       !chengpath.TextContains(reportText, "native_link_missing_reasons=-"):
        CompilerPrintErr(" compiler: shared emit smoke report shape mismatch: " + reportPath)
        return 2
    if !CompilerRunProgramLogged(rootDir,
                                   "file",
                                   [outLib],
                                   fileLogPath,
                                   "run-shared-emit-smokes file"):
        return 2
    let fileText = chengpath.ReadTextFile("", fileLogPath)
    let expectedHint = CompilerSharedEmitFileHint(targetTriple)
    if len(expectedHint) > 0 && !chengpath.TextContains(fileText, expectedHint):
        CompilerPrintErr(" compiler: shared emit smoke expected `" + expectedHint + "` in file output")
        CompilerPrintErr(strutil.Strip(fileText))
        return 2
    CompilerPrintLine(" shared emit smokes: ok")
    CompilerPrintLine("target=" + targetTriple)
    CompilerPrintLine("out=" + outLib)
    CompilerPrintLine("report=" + reportPath)
    return 0

