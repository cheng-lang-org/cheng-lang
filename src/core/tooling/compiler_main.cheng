fn CompilerPackageRootFromArgs(rootDir: str,
                                 args: str[]): str =
    let sourcePath = creq.CompilerReadFlagOrDefault(args, "--in", creq.CompilerLegacyInPathFromArgs(args))
    let packageRootRaw = creq.CompilerReadFlagOrDefault(args,
                                                          "--root",
                                                          creq.CompilerDefaultPackageRoot(rootDir))
    return creq.CompilerResolvePackageRoot(rootDir, sourcePath, packageRootRaw)

fn CompilerPackageRootFromRuntimeFlags(rootDir: str): str =
    let sourcePath = cmdline.ReadFlagOrDefault("--in", cmdline.ReadFlagOrDefault("--legacy-in", ""))
    let packageRootRaw = cmdline.ReadFlagOrDefault("--root", creq.CompilerDefaultPackageRoot(rootDir))
    return creq.CompilerResolvePackageRoot(rootDir, sourcePath, packageRootRaw)

fn CompilerBackendDriverSelftestArtifactPaths(rootDir: str,
                                                stem: str,
                                                outBin: var str,
                                                outReportPath: var str,
                                                outCompileLogPath: var str,
                                                outRunLogPath: var str,
                                                outReceiptLogPath: var str) =
    var outBinRel = "artifacts/backend_driver/"
    outBinRel = outBinRel + stem
    outBinRel = outBinRel + ".selftest"
    outBin = chengpath.PathAbsolute(rootDir, outBinRel)
    outReportPath = outBin + ".report.txt"
    var outCompileLogRel = "artifacts/backend_driver/"
    outCompileLogRel = outCompileLogRel + stem
    outCompileLogRel = outCompileLogRel + ".selftest.compile.log"
    var outRunLogRel = "artifacts/backend_driver/"
    outRunLogRel = outRunLogRel + stem
    outRunLogRel = outRunLogRel + ".selftest.run.log"
    var outReceiptLogRel = "artifacts/backend_driver/"
    outReceiptLogRel = outReceiptLogRel + stem
    outReceiptLogRel = outReceiptLogRel + ".selftest.receipt.log"
    outCompileLogPath = chengpath.PathAbsolute(rootDir, outCompileLogRel)
    outRunLogPath = chengpath.PathAbsolute(rootDir, outRunLogRel)
    outReceiptLogPath = chengpath.PathAbsolute(rootDir, outReceiptLogRel)

fn CompilerBackendDriverSelftestBuildStampPath(outBin: str): str =
    return outBin + ".build.txt"

fn CompilerBackendDriverSelftestBuildStampText(sourcePath: str,
                                                 outBin: str,
                                                 outReportPath: str,
                                                 targetTriple: str,
                                                 compilerPath: str,
                                                 expectedOutput: str): str =
    return "format=cheng_backend_driver_selftest_build_v1\n" +
           "entry=" + sourcePath + "\n" +
           "output=" + outBin + "\n" +
           "report=" + outReportPath + "\n" +
           "target=" + targetTriple + "\n" +
           "compiler=" + compilerPath + "\n" +
           "expected_output=" + expectedOutput + "\n"

fn CompilerBackendDriverSelftestFresh(rootDir: str,
                                        packageRoot: str,
                                        compilerPath: str,
                                        targetTriple: str,
                                        sourcePath: str,
                                        expectedOutput: str,
                                        outBin: str,
                                        outReportPath: str,
                                        outCompileLogPath: str,
                                        outRunLogPath: str): bool =
    var freshInputPaths: str[]
    var freshErr = ""
    if !contracts.BootstrapOrdinaryClosurePaths(packageRoot,
                                                  sourcePath,
                                                  freshInputPaths,
                                                  freshErr):
        return false
    if !CompilerArtifactSetFreshAgainstOutput(rootDir,
                                                outBin,
                                                [
                                                    outBin,
                                                    outBin + ".map",
                                                    outReportPath,
                                                    outCompileLogPath,
                                                    outRunLogPath
                                                ]):
        return false
    if len(compilerPath) > 0 &&
       compilerPath != outBin &&
       CompilerPathNewerThan(rootDir, compilerPath, outBin):
        return false
    for i in 0..<freshInputPaths.len:
        if CompilerPathNewerThan(rootDir, freshInputPaths[i], outBin):
            return false
    let runText = strutil.Strip(chengpath.ReadTextFile("", outRunLogPath))
    if len(expectedOutput) <= 0:
        return len(runText) <= 0
    return runText == expectedOutput

fn CompilerRunBackendDriverSelftest(rootDir: str,
                                      packageRoot: str,
                                      compilerPath: str,
                                      targetTriple: str,
                                      sourcePath: str,
                                      stem: str,
                                      expectedOutput: str,
                                      outBin: var str,
                                      outReportPath: var str,
                                      outCompileLogPath: var str,
                                      outRunLogPath: var str): bool =
    var outReceiptLogPath = ""
    CompilerBackendDriverSelftestArtifactPaths(rootDir,
                                                 stem,
                                                 outBin,
                                                 outReportPath,
                                                 outCompileLogPath,
                                                 outRunLogPath,
                                                 outReceiptLogPath)
    let buildStampPath = CompilerBackendDriverSelftestBuildStampPath(outBin)
    let compileContext = CompilerConcat3("build-backend-driver ", stem, " compile")
    let receiptContext = CompilerConcat3("build-backend-driver ", stem, " receipt")
    let runContext = CompilerConcat3("build-backend-driver ", stem, " run")
    let seedDiagText = CompilerConcat3(" compiler: backend driver ", stem, " selftest emitted internal seed diagnostics")
    let emptyStdoutText = CompilerConcat3(" compiler: backend driver ", stem, " selftest expected empty stdout")
    let driftText = CompilerConcat3(" compiler: backend driver ", stem, " selftest output drifted")
    let missingOutputPrefix = CompilerConcat3(" compiler: backend driver ", stem, " selftest missing output: ")
    let missingOutputText = missingOutputPrefix + outBin
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, "--root:" + packageRoot)
    add(compileArgs, "--contract-in:" + contracts.BootstrapStage1SourcePath(rootDir))
    add(compileArgs, "--in:" + sourcePath)
    add(compileArgs, "--emit:exe")
    add(compileArgs, "--target:" + targetTriple)
    add(compileArgs, "--out:" + outBin)
    var compileEnv: str[]
    add(compileEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    if strutil.StartsWith(stem, "r2c_react_"):
        add(compileEnv, "BACKEND_INCREMENTAL=0")
        add(compileEnv, "BACKEND_MULTI_MODULE_CACHE=0")
        add(compileEnv, "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1")
        add(compileEnv, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
        add(compileEnv, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    let fresh = CompilerBackendDriverSelftestFresh(rootDir,
                                                     packageRoot,
                                                     compilerPath,
                                                     targetTriple,
                                                     sourcePath,
                                                     expectedOutput,
                                                     outBin,
                                                     outReportPath,
                                                     outCompileLogPath,
                                                     outRunLogPath)
    if !fresh:
        if !CompilerRunFileEnvLogged(rootDir,
                                       compilerPath,
                                       compileArgs,
                                       compileEnv,
                                       outCompileLogPath,
                                       compileContext):
            return false
        let compileText = chengpath.ReadTextFile("", outCompileLogPath)
        if strutil.Contains(compileText, "[cheng_seed]"):
            CompilerPrintErr(seedDiagText)
            return false
        if !chengpath.PathFileExists(outBin) || !chengpath.PathFileExists(outBin + ".map"):
            CompilerPrintErr(missingOutputText)
            return false
        if chengpath.PathFileExists(outReportPath):
            let _ = os.RemoveFile(outReportPath)
        let receiptArgs = [
            "world-receipt",
            "--root:" + packageRoot,
            "--contract-in:" + contracts.BootstrapStage1SourcePath(rootDir),
            "--in:" + sourcePath,
            "--emit:exe",
            "--target:" + targetTriple,
            "--out:" + outBin,
            "--report-out:" + outReportPath
        ]
        if !CompilerRunFileEnvLogged(rootDir,
                                       compilerPath,
                                       receiptArgs,
                                       compileEnv,
                                       outReceiptLogPath,
                                       receiptContext):
            return false
        if !chengpath.PathFileExists(outReportPath):
            CompilerPrintErr(" compiler: backend driver selftest missing receipt report: " + outReportPath)
            return false
    let runArgs: str[]
    if !fresh:
        if !CompilerRunFileLogged(rootDir,
                                    outBin,
                                    runArgs,
                                    outRunLogPath,
                                    runContext):
            return false
    let runText = strutil.Strip(chengpath.ReadTextFile("", outRunLogPath))
    if len(expectedOutput) <= 0:
        if len(runText) > 0:
            CompilerPrintErr(emptyStdoutText)
            return false
    elif runText != expectedOutput:
        CompilerPrintErr(driftText)
        if len(runText) > 0:
            CompilerPrintErr(runText)
        return false
    let buildStampText = CompilerBackendDriverSelftestBuildStampText(sourcePath,
                                                                       outBin,
                                                                       outReportPath,
                                                                       targetTriple,
                                                                       compilerPath,
                                                                       expectedOutput)
    if !chengpath.WriteTextFile(rootDir, buildStampPath, buildStampText):
        CompilerPrintErr(" compiler: failed to write backend driver selftest build stamp: " + buildStampPath)
        return false
    return true

fn CompilerBuildBackendDriverInstallReportText(mapRenameStatus: str,
                                                 binaryRenameStatus: str,
                                                 installedStatus: str,
                                                 verifyExportParallelStatus: str,
                                                 selfhostProgressStatus: str): str =
    var out = ""
    out = out + "map_rename=" + mapRenameStatus + "\n"
    out = out + "binary_rename=" + binaryRenameStatus + "\n"
    out = out + "installed_status=" + installedStatus + "\n"
    out = out + "installed_verify_export_parallel=" + verifyExportParallelStatus + "\n"
    out = out + "installed_selfhost_progress_smoke=" + selfhostProgressStatus + "\n"
    return out

fn CompilerBuildBackendDriverSmokeReport(prefix: str,
                                           sourcePath: str,
                                           outPath: str,
                                           reportPath: str,
                                           compileLogPath: str,
                                           runLogPath: str): str =
    var out = ""
    out = out + prefix + "_source=" + sourcePath + "\n"
    out = out + prefix + "_output=" + outPath + "\n"
    out = out + prefix + "_report=" + reportPath + "\n"
    out = out + prefix + "_compile_log=" + compileLogPath + "\n"
    out = out + prefix + "_run_log=" + runLogPath + "\n"
    return out

fn CompilerBuildBackendDriverStatusArgs(rootDir: str,
                                          packageRoot: str,
                                          compilerEntrySource: str): str[] =
    let statusOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.status_probe.out")
    return [
        "status",
        "--root:" + packageRoot,
        "--in:" + compilerEntrySource,
        "--out:" + statusOut
    ]

fn CompilerBuildBackendDriverStatusLogOk(logPath: str,
                                           packageRoot: str,
                                           compilerEntrySource: str): bool =
    let statusText = chengpath.ReadTextFile("", logPath)
    if strutil.Contains(statusText, "flag_root=" + packageRoot) &&
       strutil.Contains(statusText, "flag_in=" + compilerEntrySource) &&
       strutil.Contains(statusText, "execution=argv_control_plane") &&
       strutil.Contains(statusText, "flag_exec_edges=") &&
       !strutil.Contains(statusText, "flag_exec_edges=err"):
        return true
    return false

fn CompilerBuildBackendDriverInstalledPairOk(backendDriverOut: str,
                                               backendDriverMapOut: str,
                                               candidateBinarySize: int64,
                                               candidateMapSize: int64,
                                               candidateMapText: str,
                                               compilerEntrySource: str,
                                               installReport: var str): bool =
    if !chengpath.PathFileExists(backendDriverOut):
        installReport = installReport + "installed_pair_sync=missing_binary\n"
        return false
    if !chengpath.PathFileExists(backendDriverMapOut):
        installReport = installReport + "installed_pair_sync=missing_map\n"
        return false
    if chengpath.PathFileSize(backendDriverOut) != candidateBinarySize:
        installReport = installReport + "installed_pair_sync=binary_size_drift\n"
        return false
    if chengpath.PathFileSize(backendDriverMapOut) != candidateMapSize:
        installReport = installReport + "installed_pair_sync=map_size_drift\n"
        return false
    let installedMapText = chengpath.ReadTextFile("", backendDriverMapOut)
    if installedMapText != candidateMapText:
        installReport = installReport + "installed_pair_sync=map_content_drift\n"
        return false
    if !strutil.Contains(installedMapText, "cheng_line_map_v1") ||
       !strutil.Contains(installedMapText, compilerEntrySource):
        installReport = installReport + "installed_pair_sync=map_source_drift\n"
        return false
    installReport = installReport + "installed_pair_sync=ok\n"
    return true

fn CompilerBackendDriverDefaultMaxRssBytesText(): str =
    return "8589934592"

fn CompilerBuildBackendDriverMaxRssBytesText(): str =
    return CompilerBackendDriverDefaultMaxRssBytesText()

fn CompilerFollowWorldMaxRssBytesText(): str =
    return CompilerBackendDriverDefaultMaxRssBytesText()

fn CompilerBuildBackendDriverCompileLogText(targetTriple: str,
                                              currentCompiler: str,
                                              materializedSource: str,
                                              candidateOutput: str,
                                              candidateMap: str,
                                              compileReportPath: str): str =
    var out = ""
    CompilerAppendKeyValueLine(out, "target", targetTriple)
    CompilerAppendKeyValueLine(out, "current_compiler", currentCompiler)
    CompilerAppendKeyValueLine(out, "materialized_source", materializedSource)
    CompilerAppendKeyValueLine(out, "candidate_output", candidateOutput)
    CompilerAppendKeyValueLine(out, "candidate_map", candidateMap)
    CompilerAppendKeyValueLine(out, "compile_report", compileReportPath)
    return out

fn CompilerBuildBackendDriverReportText(targetTriple: str,
                                          currentCompiler: str,
                                          referenceCompiler: str,
                                          referencePlanCheck: str,
                                          plannedEntrySource: str,
                                          materializedSource: str,
                                          compilerRuntimeSource: str,
                                          compilerRequestSource: str,
                                          backendDriverCandidateOut: str,
                                          backendDriverCandidateMapOut: str,
                                          backendDriverOut: str,
                                          backendDriverMapOut: str,
                                          statusLogPath: str,
                                          verifyExportLogPath: str,
                                          verifyExportParallelLogPath: str,
                                          planLogPath: str,
                                          referencePlanLogPath: str,
                                          compileLogPath: str,
                                          installLogPath: str,
                                          installedStatusLogPath: str,
                                          installedSelfhostProgressSmokeLogPath: str,
                                          ordinarySmokeReport: str,
                                          runtimeSmokeReport: str,
                                          migrationSmokeReport: str,
                                          freshNodeSmokeReport: str): str =
    var report = ""
    CompilerAppendKeyValueLine(report, "target", targetTriple)
    CompilerAppendKeyValueLine(report, "bootstrap_kind", "selfhost")
    CompilerAppendKeyValueLine(report, "compiler_class", "ordinary_compiler")
    CompilerAppendKeyValueLine(report, "current_compiler", currentCompiler)
    CompilerAppendKeyValueLine(report, "reference_compiler", referenceCompiler)
    CompilerAppendKeyValueLine(report, "reference_plan_check", referencePlanCheck)
    CompilerAppendKeyValueLine(report, "planned_entry_source", plannedEntrySource)
    CompilerAppendKeyValueLine(report, "planned_runtime_source", compilerRuntimeSource)
    CompilerAppendKeyValueLine(report, "planned_request_source", compilerRequestSource)
    CompilerAppendKeyValueLine(report, "materialized_source", materializedSource)
    CompilerAppendKeyValueLine(report, "candidate_output", backendDriverCandidateOut)
    CompilerAppendKeyValueLine(report, "candidate_map", backendDriverCandidateMapOut)
    CompilerAppendKeyValueLine(report, "output", backendDriverOut)
    CompilerAppendKeyValueLine(report, "output_map", backendDriverMapOut)
    CompilerAppendKeyValueLine(report, "status_log", statusLogPath)
    CompilerAppendKeyValueLine(report, "verify_export_visibility_log", verifyExportLogPath)
    CompilerAppendKeyValueLine(report, "verify_export_visibility_parallel_log", verifyExportParallelLogPath)
    CompilerAppendKeyValueLine(report, "plan_log", planLogPath)
    CompilerAppendKeyValueLine(report, "reference_plan_log", referencePlanLogPath)
    CompilerAppendKeyValueLine(report, "log", compileLogPath)
    CompilerAppendKeyValueLine(report, "install_log", installLogPath)
    CompilerAppendKeyValueLine(report, "installed_status_log", installedStatusLogPath)
    CompilerAppendKeyValueLine(report, "installed_selfhost_progress_smoke_log", installedSelfhostProgressSmokeLogPath)
    report = report + ordinarySmokeReport
    report = report + runtimeSmokeReport
    report = report + migrationSmokeReport
    report = report + freshNodeSmokeReport
    return report

fn CompilerBuildBackendDriver(rootDir: str): int32 =
    let outDir = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver")
    if !chengpath.MkdirP(rootDir, outDir):
        CompilerPrintErr(" compiler: failed to create backend driver dir")
        return 2
    let buildMaxRssBytesText: str = CompilerBuildBackendDriverMaxRssBytesText()
    os.SetEnv("CHENG_PROGRESS", "1")
    os.SetEnv("CHENG_PROCESS_MAX_RSS_BYTES", buildMaxRssBytesText)
    let plannedEntrySource = buildplan.BackendBuildPlanBackendDriverEntryPath(rootDir)
    let compilerEntrySource = plannedEntrySource
    let packageRoot = CompilerPackageRootForSource(rootDir, compilerEntrySource)
    let compilerRuntimeSource = chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_runtime.cheng")
    let compilerRequestSource = chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_request.cheng")
    let backendDriverOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
    let backendDriverMapOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.map")
    let backendDriverCandidateOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.build_candidate")
    let backendDriverCandidateMapOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.build_candidate.map")
    let compileReportPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.compile.report.txt")
    let compileLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.log")
    let reportPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.report.txt")
    let statusLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.status.txt")
    let verifyExportLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.verify_export_visibility.txt")
    let verifyExportParallelLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.verify_export_visibility_parallel.txt")
    let planLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.plan.txt")
    let referencePlanLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/reference_backend_driver.plan.txt")
    let planCorePath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.plan.core.txt")
    let referencePlanCorePath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/reference_backend_driver.plan.core.txt")
    let installLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.install.txt")
    let installedStatusLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.installed.status.txt")
    let installedSelfhostProgressSmokeLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/build_backend_driver.installed.selfhost_progress_smoke.txt")
    let smokeSource = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng")
    let runtimeSmokeSource = chengpath.PathAbsolute(rootDir, "src/tests/compiler_runtime_smoke.cheng")
    let migrationSmokeSource = chengpath.PathAbsolute(rootDir, "src/tests/compiler_migration_publish_smoke.cheng")
    let freshNodeSmokeSource = chengpath.PathAbsolute(rootDir, "src/tests/compiler_world_fresh_node_selfhost_smoke.cheng")
    var smokeOut = ""
    var smokeCompileReportPath = ""
    var smokeCompileLogPath = ""
    var smokeRunLogPath = ""
    var runtimeSmokeOut = ""
    var runtimeSmokeCompileReportPath = ""
    var runtimeSmokeCompileLogPath = ""
    var runtimeSmokeRunLogPath = ""
    var migrationSmokeOut = ""
    var migrationSmokeCompileReportPath = ""
    var migrationSmokeCompileLogPath = ""
    var migrationSmokeRunLogPath = ""
    var freshNodeSmokeOut = ""
    var freshNodeSmokeCompileReportPath = ""
    var freshNodeSmokeCompileLogPath = ""
    var freshNodeSmokeRunLogPath = ""
    let targetTriple = CompilerRequestedTarget()
    let noHandoffEnv: str[] = [
        "CHENG_NO_BACKEND_DRIVER_HANDOFF=1",
        "CHENG_PROGRESS=1",
        strutil.Join(["CHENG_PROCESS_MAX_RSS_BYTES=", buildMaxRssBytesText], ""),
        "BACKEND_INCREMENTAL=0",
        "BACKEND_MULTI_MODULE_CACHE=0",
        "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1",
        "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0",
        "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0"
    ]
    var currentCompiler = CompilerCurrentExecutablePath(rootDir)
    if len(currentCompiler) > 0 && !chengpath.FileExistsNonEmpty(rootDir, currentCompiler):
        currentCompiler = ""
    if len(currentCompiler) <= 0:
        currentCompiler = CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) <= 0:
        CompilerPrintErr(" compiler: missing current compiler for build-backend-driver")
        return 2
    var ordinaryReceiptLogPath = ""
    CompilerBackendDriverSelftestArtifactPaths(rootDir,
                                                 "ordinary_zero_exit_fixture",
                                                 smokeOut,
                                                 smokeCompileReportPath,
                                                 smokeCompileLogPath,
                                                 smokeRunLogPath,
                                                 ordinaryReceiptLogPath)
    var runtimeReceiptLogPath = ""
    CompilerBackendDriverSelftestArtifactPaths(rootDir,
                                                 "compiler_runtime_smoke",
                                                 runtimeSmokeOut,
                                                 runtimeSmokeCompileReportPath,
                                                 runtimeSmokeCompileLogPath,
                                                 runtimeSmokeRunLogPath,
                                                 runtimeReceiptLogPath)
    var migrationReceiptLogPath = ""
    CompilerBackendDriverSelftestArtifactPaths(rootDir,
                                                 "compiler_migration_publish_smoke",
                                                 migrationSmokeOut,
                                                 migrationSmokeCompileReportPath,
                                                 migrationSmokeCompileLogPath,
                                                 migrationSmokeRunLogPath,
                                                 migrationReceiptLogPath)
    var freshNodeReceiptLogPath = ""
    CompilerBackendDriverSelftestArtifactPaths(rootDir,
                                                 "compiler_world_fresh_node_selfhost_smoke",
                                                 freshNodeSmokeOut,
                                                 freshNodeSmokeCompileReportPath,
                                                 freshNodeSmokeCompileLogPath,
                                                 freshNodeSmokeRunLogPath,
                                                 freshNodeReceiptLogPath)
    let ordinarySmokeReport = CompilerBuildBackendDriverSmokeReport("zero_exit_smoke",
                                                                      smokeSource,
                                                                      smokeOut,
                                                                      smokeCompileReportPath,
                                                                      smokeCompileLogPath,
                                                                      smokeRunLogPath)
    let runtimeSmokeReport = CompilerBuildBackendDriverSmokeReport("compiler_runtime_smoke",
                                                                     runtimeSmokeSource,
                                                                     runtimeSmokeOut,
                                                                     runtimeSmokeCompileReportPath,
                                                                     runtimeSmokeCompileLogPath,
                                                                     runtimeSmokeRunLogPath)
    let migrationSmokeReport = CompilerBuildBackendDriverSmokeReport("compiler_migration_publish_smoke",
                                                                       migrationSmokeSource,
                                                                       migrationSmokeOut,
                                                                       migrationSmokeCompileReportPath,
                                                                       migrationSmokeCompileLogPath,
                                                                       migrationSmokeRunLogPath)
    let freshNodeSmokeReport = CompilerBuildBackendDriverSmokeReport("compiler_world_fresh_node_selfhost_smoke",
                                                                       freshNodeSmokeSource,
                                                                       freshNodeSmokeOut,
                                                                       freshNodeSmokeCompileReportPath,
                                                                       freshNodeSmokeCompileLogPath,
                                                                       freshNodeSmokeRunLogPath)
    let mainArtifactsFresh = CompilerBackendDriverFreshForCompiler(rootDir,
                                                                     backendDriverOut,
                                                                     currentCompiler) &&
                             CompilerArtifactSetFreshAgainstOutput(rootDir,
                                                                     backendDriverOut,
                                                                     [
                                                                         backendDriverOut,
                                                                         backendDriverMapOut,
                                                                         compileLogPath,
                                                                         compileReportPath,
                                                                         reportPath,
                                                                         statusLogPath,
                                                                         verifyExportLogPath,
                                                                         verifyExportParallelLogPath,
                                                                         planLogPath,
                                                                         referencePlanLogPath,
                                                                         planCorePath,
                                                                         referencePlanCorePath,
                                                                         installLogPath,
                                                                         installedStatusLogPath,
                                                                         installedSelfhostProgressSmokeLogPath
                                                                     ])
    if mainArtifactsFresh &&
       CompilerBackendDriverSelftestFresh(rootDir,
                                            packageRoot,
                                            backendDriverOut,
                                            targetTriple,
                                            smokeSource,
                                            "",
                                            smokeOut,
                                            smokeCompileReportPath,
                                            smokeCompileLogPath,
                                            smokeRunLogPath) &&
       CompilerBackendDriverSelftestFresh(rootDir,
                                            packageRoot,
                                            backendDriverOut,
                                            targetTriple,
                                            runtimeSmokeSource,
                                            " compiler_runtime_smoke ok",
                                            runtimeSmokeOut,
                                            runtimeSmokeCompileReportPath,
                                            runtimeSmokeCompileLogPath,
                                            runtimeSmokeRunLogPath) &&
       CompilerBackendDriverSelftestFresh(rootDir,
                                            packageRoot,
                                            backendDriverOut,
                                            targetTriple,
                                            migrationSmokeSource,
                                            " compiler_migration_publish_smoke ok",
                                            migrationSmokeOut,
                                            migrationSmokeCompileReportPath,
                                            migrationSmokeCompileLogPath,
                                            migrationSmokeRunLogPath) &&
       CompilerBackendDriverSelftestFresh(rootDir,
                                            packageRoot,
                                            backendDriverOut,
                                            targetTriple,
                                            freshNodeSmokeSource,
                                            " compiler_world_fresh_node_selfhost_smoke ok",
                                            freshNodeSmokeOut,
                                            freshNodeSmokeCompileReportPath,
                                            freshNodeSmokeCompileLogPath,
                                            freshNodeSmokeRunLogPath):
        let freshInstallReport = CompilerBuildBackendDriverInstallReportText("fresh_reuse",
                                                                               "fresh_reuse",
                                                                               "ok",
                                                                               "ok",
                                                                               "ok")
        if !chengpath.WriteTextFile(rootDir, installLogPath, freshInstallReport):
            CompilerPrintErr(" compiler: failed to write backend driver install log: " + installLogPath)
            return 2
        let freshReport = CompilerBuildBackendDriverReportText(targetTriple,
                                                                 currentCompiler,
                                                                 currentCompiler,
                                                                 "fresh_reuse",
                                                                 plannedEntrySource,
                                                                 compilerEntrySource,
                                                                 compilerRuntimeSource,
                                                                 compilerRequestSource,
                                                                 backendDriverCandidateOut,
                                                                 backendDriverCandidateMapOut,
                                                                 backendDriverOut,
                                                                 backendDriverMapOut,
                                                                 statusLogPath,
                                                                 verifyExportLogPath,
                                                                 verifyExportParallelLogPath,
                                                                 planLogPath,
                                                                 referencePlanLogPath,
                                                                 compileLogPath,
                                                                 installLogPath,
                                                                 installedStatusLogPath,
                                                                 installedSelfhostProgressSmokeLogPath,
                                                                 ordinarySmokeReport,
                                                                 runtimeSmokeReport,
                                                                 migrationSmokeReport,
                                                                 freshNodeSmokeReport)
        if !chengpath.WriteTextFile(rootDir, reportPath, freshReport):
            CompilerPrintErr(" compiler: failed to write backend driver report: " + reportPath)
            return 2
        CompilerPrintLine(" compiler: backend driver fresh target=" + targetTriple + " out=" + backendDriverOut)
        return 0
    let compileArgs = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + compilerEntrySource,
        "--emit:exe",
        "--target:" + targetTriple,
        "--out:" + backendDriverCandidateOut,
        "--report-out:" + compileReportPath
    ]
    if chengpath.PathFileExists(backendDriverCandidateOut):
        let _ = os.RemoveFile(backendDriverCandidateOut)
    if chengpath.PathFileExists(backendDriverCandidateMapOut):
        let _ = os.RemoveFile(backendDriverCandidateMapOut)
    if chengpath.PathFileExists(compileReportPath):
        let _ = os.RemoveFile(compileReportPath)
    if !CompilerRunFileEnvLogged(rootDir,
                                   currentCompiler,
                                   compileArgs,
                                   noHandoffEnv,
                                   compileLogPath,
                                   "build-backend-driver compile"):
        return 2
    if !chengpath.PathFileExists(compileReportPath):
        CompilerPrintErr(" compiler: missing backend driver compile report: " + compileReportPath)
        return 2
    if !chengpath.PathFileExists(backendDriverCandidateOut):
        CompilerPrintErr(" compiler: missing backend driver candidate output: " + backendDriverCandidateOut)
        return 2
    if !chengpath.PathFileExists(backendDriverCandidateMapOut):
        CompilerPrintErr(" compiler: missing backend driver candidate map: " + backendDriverCandidateMapOut)
        return 2
    let compileLogText = CompilerBuildBackendDriverCompileLogText(targetTriple,
                                                                    currentCompiler,
                                                                    compilerEntrySource,
                                                                    backendDriverCandidateOut,
                                                                    backendDriverCandidateMapOut,
                                                                    compileReportPath)
    if !chengpath.WriteTextFile(rootDir, compileLogPath, compileLogText):
        CompilerPrintErr(" compiler: failed to write backend driver compile log: " + compileLogPath)
        return 2
    let statusArgs = CompilerBuildBackendDriverStatusArgs(rootDir,
                                                            packageRoot,
                                                            compilerEntrySource)
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverCandidateOut,
                                   statusArgs,
                                   noHandoffEnv,
                                   statusLogPath,
                                   "build-backend-driver status"):
        return 2
    if !CompilerBuildBackendDriverStatusLogOk(statusLogPath, packageRoot, compilerEntrySource):
        CompilerPrintErr(" compiler: backend driver candidate status did not exercise argv provider path")
        return 2
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverCandidateOut,
                                   ["verify-export-visibility"],
                                   noHandoffEnv,
                                   verifyExportLogPath,
                                   "build-backend-driver verify-export-visibility"):
        return 2
    let planArgs = ["print-build-plan", "--target:" + targetTriple]
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverCandidateOut,
                                   planArgs,
                                   noHandoffEnv,
                                   planLogPath,
                                   "build-backend-driver plan"):
        return 2
    let bootstrapSnapshot = contracts.BootstrapSnapshotDefault(rootDir)
    let backendDriverReference = CompilerBackendDriverPath(rootDir)
    var referenceCompiler = ""
    let bootstrapReference = CompilerBootstrapCompilerPath(rootDir, bootstrapSnapshot)
    if len(backendDriverReference) > 0 &&
       (CompilerBackendDriverFresh(rootDir, backendDriverReference) ||
        CompilerBackendDriverReadyOverride(rootDir, backendDriverReference)):
        referenceCompiler = backendDriverReference
    elif len(bootstrapReference) > 0:
        referenceCompiler = bootstrapReference
    let referencePlanArgs = ["print-build-plan", "--target:" + targetTriple]
    var referencePlanCheck = "missing_reference_compiler"
    if len(referenceCompiler) <= 0:
        CompilerPrintErr(" compiler: missing reference compiler for build-backend-driver plan")
        return 2
    else:
        if !CompilerRunFileEnvLogged(rootDir,
                                       referenceCompiler,
                                       referencePlanArgs,
                                       noHandoffEnv,
                                       referencePlanLogPath,
                                       "build-backend-driver reference-plan"):
            return 2
        let referencePlanText = chengpath.ReadTextFile("", referencePlanLogPath)
        if !CompilerTextContainsAll(referencePlanText, ["target=" + targetTriple]):
            if len(bootstrapReference) > 0 && bootstrapReference != currentCompiler:
                referenceCompiler = bootstrapReference
                if !CompilerRunFileEnvLogged(rootDir,
                                               referenceCompiler,
                                               referencePlanArgs,
                                               noHandoffEnv,
                                               referencePlanLogPath,
                                               "build-backend-driver reference-plan"):
                    return 2
        let resolvedReferencePlanText = chengpath.ReadTextFile("", referencePlanLogPath)
        if !CompilerTextContainsAll(resolvedReferencePlanText, ["target=" + targetTriple]):
            CompilerPrintErr(" compiler: reference build plan target mismatch")
            return 2
        let planCoreText = CompilerBuildPlanCoreText(chengpath.ReadTextFile("", planLogPath))
        let referencePlanCoreText = CompilerBuildPlanCoreText(chengpath.ReadTextFile("", referencePlanLogPath))
        let _planCoreWritten = chengpath.WriteTextFile(rootDir, planCorePath, strutil.Join([planCoreText, "\n"], ""))
        let _referencePlanCoreWritten = chengpath.WriteTextFile(rootDir, referencePlanCorePath, strutil.Join([referencePlanCoreText, "\n"], ""))
        if planCoreText != referencePlanCoreText:
            CompilerPrintErr(" compiler: backend driver build plan drift vs current compiler")
            return 2
        referencePlanCheck = "ok"
    if !CompilerRunBackendDriverSelftest(rootDir,
                                           packageRoot,
                                           backendDriverCandidateOut,
                                           targetTriple,
                                           smokeSource,
                                           "ordinary_zero_exit_fixture",
                                           "",
                                           smokeOut,
                                           smokeCompileReportPath,
                                           smokeCompileLogPath,
                                           smokeRunLogPath):
        return 2
    if !CompilerRunBackendDriverSelftest(rootDir,
                                           packageRoot,
                                           backendDriverCandidateOut,
                                           targetTriple,
                                           runtimeSmokeSource,
                                           "compiler_runtime_smoke",
                                           " compiler_runtime_smoke ok",
                                           runtimeSmokeOut,
                                           runtimeSmokeCompileReportPath,
                                           runtimeSmokeCompileLogPath,
                                           runtimeSmokeRunLogPath):
        return 2
    if !CompilerRunBackendDriverSelftest(rootDir,
                                           packageRoot,
                                           backendDriverCandidateOut,
                                           targetTriple,
                                           migrationSmokeSource,
                                           "compiler_migration_publish_smoke",
                                           " compiler_migration_publish_smoke ok",
                                           migrationSmokeOut,
                                           migrationSmokeCompileReportPath,
                                           migrationSmokeCompileLogPath,
                                           migrationSmokeRunLogPath):
        return 2
    if !CompilerRunBackendDriverSelftest(rootDir,
                                           packageRoot,
                                           backendDriverCandidateOut,
                                           targetTriple,
                                           freshNodeSmokeSource,
                                           "compiler_world_fresh_node_selfhost_smoke",
                                           " compiler_world_fresh_node_selfhost_smoke ok",
                                           freshNodeSmokeOut,
                                           freshNodeSmokeCompileReportPath,
                                           freshNodeSmokeCompileLogPath,
                                           freshNodeSmokeRunLogPath):
        return 2
    let candidateBinarySize = chengpath.PathFileSize(backendDriverCandidateOut)
    let candidateMapSize = chengpath.PathFileSize(backendDriverCandidateMapOut)
    let candidateMapText = chengpath.ReadTextFile("", backendDriverCandidateMapOut)
    if candidateBinarySize <= Int64(0) ||
       candidateMapSize <= Int64(0) ||
       len(candidateMapText) <= 0 ||
       !strutil.Contains(candidateMapText, "cheng_line_map_v1") ||
       !strutil.Contains(candidateMapText, compilerEntrySource):
        CompilerPrintErr(" compiler: backend driver candidate map is not from current candidate source")
        return 2
    var installReport = ""
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            backendDriverCandidateMapOut,
                                            backendDriverMapOut,
                                            installLogPath,
                                            "map",
                                            installReport):
        CompilerPrintErr(" compiler: failed to install backend driver map: " + backendDriverMapOut)
        return 2
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            backendDriverCandidateOut,
                                            backendDriverOut,
                                            installLogPath,
                                            "binary",
                                            installReport):
        CompilerPrintErr(" compiler: failed to install backend driver output: " + backendDriverOut)
        return 2
    if !CompilerBuildBackendDriverInstalledPairOk(backendDriverOut,
                                                   backendDriverMapOut,
                                                   candidateBinarySize,
                                                   candidateMapSize,
                                                   candidateMapText,
                                                   compilerEntrySource,
                                                   installReport):
        chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        CompilerPrintErr(" compiler: installed backend driver binary/map are not the same candidate batch")
        return 2
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverOut,
                                   statusArgs,
                                   noHandoffEnv,
                                   installedStatusLogPath,
                                   "build-backend-driver installed status"):
        installReport = installReport + "installed_status=failed\n"
        chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        return 2
    if !CompilerBuildBackendDriverStatusLogOk(installedStatusLogPath, packageRoot, compilerEntrySource):
        installReport = installReport + "installed_status=argv_provider_drift\n"
        chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        CompilerPrintErr(" compiler: installed backend driver status did not exercise argv provider path")
        return 2
    installReport = installReport + "installed_status=ok\n"
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverOut,
                                   ["verify-export-visibility-parallel"],
                                   noHandoffEnv,
                                   verifyExportParallelLogPath,
                                   "build-backend-driver installed verify-export-visibility-parallel"):
        installReport = installReport + "installed_verify_export_parallel=failed\n"
        chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        return 2
    installReport = installReport + "installed_verify_export_parallel=ok\n"
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverOut,
                                   ["run-host-smokes",
                                    "--label:build_backend_driver_installed_selfhost_progress",
                                    "backend_driver_selfhost_progress_smoke"],
                                   noHandoffEnv,
                                   installedSelfhostProgressSmokeLogPath,
                                   "build-backend-driver installed selfhost-progress smoke"):
        installReport = installReport + "installed_selfhost_progress_smoke=failed\n"
        chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        return 2
    installReport = installReport + "installed_selfhost_progress_smoke=ok\n"
    if !chengpath.WriteTextFile(rootDir, installLogPath, installReport):
        CompilerPrintErr(" compiler: failed to write backend driver install log: " + installLogPath)
        return 2
    let report = CompilerBuildBackendDriverReportText(targetTriple,
                                                        currentCompiler,
                                                        referenceCompiler,
                                                        referencePlanCheck,
                                                        plannedEntrySource,
                                                        compilerEntrySource,
                                                        compilerRuntimeSource,
                                                        compilerRequestSource,
                                                        backendDriverCandidateOut,
                                                        backendDriverCandidateMapOut,
                                                        backendDriverOut,
                                                        backendDriverMapOut,
                                                        statusLogPath,
                                                        verifyExportLogPath,
                                                        verifyExportParallelLogPath,
                                                        planLogPath,
                                                        referencePlanLogPath,
                                                        compileLogPath,
                                                        installLogPath,
                                                        installedStatusLogPath,
                                                        installedSelfhostProgressSmokeLogPath,
                                                        ordinarySmokeReport,
                                                        runtimeSmokeReport,
                                                        migrationSmokeReport,
                                                        freshNodeSmokeReport)
    if !chengpath.WriteTextFile(rootDir, reportPath, report):
        CompilerPrintErr(" compiler: failed to write backend driver report: " + reportPath)
        return 2
    CompilerPrintLine("backend driver ok: " + backendDriverOut)
    return 0


fn CompilerBootstrapTarget(rootDir: str): str =
    let ignoredRootDir = rootDir
    return CompilerRequestedTarget()

fn CompilerBootstrapLog(rootDir: str,
                          name: str): str =
    return chengpath.PathAbsolute(rootDir, strutil.Join(["artifacts/bootstrap/", name], ""))

fn CompilerPathNewerThan(rootDir: str,
                           leftPath: str,
                           rightPath: str): bool =
    if !chengpath.PathFileExists(leftPath):
        return false
    if !chengpath.PathFileExists(rightPath):
        return true
    let _rootDir = rootDir
    return os.FileMtime(leftPath) > os.FileMtime(rightPath)

fn CompilerBootstrapEnvText(rootDir: str,
                              snapshot: contracts.BootstrapSnapshot): str =
    var out = ""
    out = out + "CHENG_ROOT=" + rootDir + "\n"
    out = out + "CHENG_TARGET=" + CompilerBootstrapTarget(rootDir) + "\n"
    out = out + "CHENG_BOOTSTRAP_KIND=" + snapshot.bootstrapMode + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1_SOURCE=" + snapshot.stage1Source.path + "\n"
    out = out + "CHENG_COMPILER_ENTRY_SOURCE=" + contracts.BootstrapCompilerEntrySourcePath(rootDir) + "\n"
    out = out + "CHENG_COMPILER_RUNTIME_SOURCE=" + contracts.BootstrapCompilerRuntimeSourcePath(rootDir) + "\n"
    out = out + "CHENG_COMPILER_REQUEST_SOURCE=" + contracts.BootstrapCompilerRequestSourcePath(rootDir) + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "CHENG_BOOTSTRAP_ENV=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "CHENG_BOOTSTRAP_SNAPSHOT=" + contracts.BootstrapSnapshotPath(rootDir) + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE1_REPORT=" + CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt") + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE2_REPORT=" + CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt") + "\n"
    out = out + "CHENG_BOOTSTRAP_STAGE3_REPORT=" + CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt") + "\n"
    return out

fn CompilerBootstrapSnapshotText(rootDir: str,
                                   snapshot: contracts.BootstrapSnapshot): str =
    var out = ""
    var freshErr = ""
    let freshInputPaths = contracts.BootstrapFreshInputPathsCsv(rootDir, freshErr)
    out = out + "target=" + CompilerBootstrapTarget(rootDir) + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "fresh_input_paths=" + freshInputPaths + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + contracts.BootstrapCompilerEntrySourcePath(rootDir) + "\n"
    out = out + "compiler_runtime_source=" + contracts.BootstrapCompilerRuntimeSourcePath(rootDir) + "\n"
    out = out + "compiler_request_source=" + contracts.BootstrapCompilerRequestSourcePath(rootDir) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "stage1_report=" + CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt") + "\n"
    out = out + "stage2_report=" + CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt") + "\n"
    out = out + "stage3_report=" + CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt") + "\n"
    out = out + "stage0_build_log=" + CompilerBootstrapLog(rootDir, "cheng.stage0.build.log") + "\n"
    out = out + "stage0_self_check_log=" + CompilerBootstrapLog(rootDir, "cheng.stage0.self-check.log") + "\n"
    out = out + "stage1_build_log=" + CompilerBootstrapLog(rootDir, "cheng.stage1.compile.log") + "\n"
    out = out + "stage1_self_check_log=" + CompilerBootstrapLog(rootDir, "cheng.stage1.self-check.log") + "\n"
    out = out + "stage2_build_log=" + CompilerBootstrapLog(rootDir, "cheng.stage2.compile.log") + "\n"
    out = out + "stage2_self_check_log=" + CompilerBootstrapLog(rootDir, "cheng.stage2.self-check.log") + "\n"
    out = out + "stage3_build_log=" + CompilerBootstrapLog(rootDir, "cheng.stage3.compile.log") + "\n"
    out = out + "stage3_self_check_log=" + CompilerBootstrapLog(rootDir, "cheng.stage3.self-check.log") + "\n"
    out = out + "stage2_contract_log=" + CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt") + "\n"
    out = out + "stage3_contract_log=" + CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt") + "\n"
    out = out + "bootstrap_install_log=" + CompilerBootstrapLog(rootDir, "bootstrap_bridge.install.txt") + "\n"
    out = out + "fixed_point=stage2_stage3_contract_match\n"
    return out

fn CompilerBootstrapStageRun(rootDir: str,
                               label: str,
                               binPath: str,
                               args: str[],
                               logPath: str): bool =
    return CompilerRunFileLogged(rootDir,
                                   binPath,
                                   args,
                                   logPath,
                                   "bootstrap-bridge " + label)

fn CompilerBootstrapCompilerFresh(rootDir: str,
                                    compilerPath: str): bool =
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        return false
    let compilerMtime = os.FileMtime(compilerPath)
    if compilerMtime <= int64(0):
        return false
    return os.FileMtime(contracts.BootstrapSeedSourcePath(rootDir)) <= compilerMtime &&
           os.FileMtime(contracts.BootstrapStage1SourcePath(rootDir)) <= compilerMtime

fn CompilerBootstrapCompilerPath(rootDir: str,
                                   snapshot: contracts.BootstrapSnapshot): str =
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage3Compiler.path) &&
       CompilerBootstrapCompilerFresh(rootDir, snapshot.stage3Compiler.path):
        return snapshot.stage3Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path) &&
       CompilerBootstrapCompilerFresh(rootDir, snapshot.stage2Compiler.path):
        return snapshot.stage2Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage1Compiler.path) &&
       CompilerBootstrapCompilerFresh(rootDir, snapshot.stage1Compiler.path):
        return snapshot.stage1Compiler.path
    if chengpath.FileExistsNonEmpty(rootDir, snapshot.stage0Compiler.path) &&
       CompilerBootstrapCompilerFresh(rootDir, snapshot.stage0Compiler.path):
        return snapshot.stage0Compiler.path
    return ""

fn CompilerBootstrapBridgeFresh(rootDir: str,
                                  snapshot: contracts.BootstrapSnapshot): bool =
    if !chengpath.FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path):
        return false
    if !chengpath.FileExistsNonEmpty(rootDir, snapshot.stage3Compiler.path):
        return false
    if !chengpath.PathFileExists(snapshot.bootstrapEnv.path):
        return false
    if !CompilerBootstrapFreshInputsReady(rootDir, snapshot.stage2Compiler.path):
        return false
    if !CompilerBootstrapFreshInputsReady(rootDir, snapshot.stage3Compiler.path):
        return false
    return true

fn CompilerBootstrapMaterializeStage0Candidate(rootDir: str,
                                                 compilerPath: str,
                                                 finalPath: str,
                                                 candidatePath: str): bool =
    let logPath = CompilerBootstrapLog(rootDir, "cheng.stage0.materialize.log")
    let buildLogPath = CompilerBootstrapLog(rootDir, "cheng.stage0.build.log")
    let _ = os.RemoveFile(candidatePath)
    if compilerPath == finalPath:
        let copied = os.ReadFile(compilerPath)
        if len(copied) <= 0:
            return false
        if !chengpath.WriteTextFile(rootDir, candidatePath, copied):
            return false
        if !CompilerRunProgramLogged(rootDir,
                                       "chmod",
                                       ["755", candidatePath],
                                       logPath,
                                       "bootstrap-bridge stage0-chmod"):
            return false
        let buildText = CompilerConcat3("stage0_candidate_copied_from=", compilerPath, "\n")
        return chengpath.WriteTextFile(rootDir,
                                      buildLogPath,
                                      buildText)
    if chengpath.PathFileExists(candidatePath):
        os.RemoveFile(candidatePath)
    if !CompilerRunProgramLogged(rootDir,
                                   "ln",
                                   ["-s", compilerPath, candidatePath],
                                   logPath,
                                   "bootstrap-bridge stage0-symlink"):
        return false
    let buildText = CompilerConcat3("stage0_symlinked_from=", compilerPath, "\n")
    if !chengpath.WriteTextFile(rootDir,
                               buildLogPath,
                               buildText):
        return false
    return chengpath.PathFileExists(candidatePath)

fn CompilerBootstrapInstallCandidate(rootDir: str,
                                       candidatePath: str,
                                       finalPath: str,
                                       installLogPath: str,
                                       label: str,
                                       installReport: var str): bool =
    if !chengpath.PathFileExists(candidatePath):
        installReport = installReport + label + "_rename=missing_candidate\n"
        let ignoredWriteInstallLog = chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        return false
    if !os.RenameFile(candidatePath, finalPath):
        installReport = installReport + label + "_rename=failed\n"
        let ignoredWriteInstallLog = chengpath.WriteTextFile(rootDir, installLogPath, installReport)
        return false
    installReport = installReport + label + "_rename=ok\n"
    return chengpath.WriteTextFile(rootDir, installLogPath, installReport)

fn CompilerBootstrapBridge(rootDir: str): int32 =
    let snapshot = contracts.BootstrapSnapshotDefault(rootDir)
    let outDir = contracts.BootstrapOutDir(rootDir)
    if !chengpath.MkdirP(rootDir, outDir):
        CompilerPrintErr(" compiler: failed to create bootstrap dir")
        return 2
    if !chengpath.PathFileExists(snapshot.stage1Source.path):
        CompilerPrintErr(" compiler: missing stage1 source: " + snapshot.stage1Source.path)
        return 2
    if CompilerBootstrapBridgeFresh(rootDir, snapshot):
        if !chengpath.WriteTextFile(rootDir, snapshot.bootstrapEnv.path, CompilerBootstrapEnvText(rootDir, snapshot)):
            CompilerPrintErr(" compiler: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
            return 2
        if !chengpath.WriteTextFile(rootDir,
                                   contracts.BootstrapSnapshotPath(rootDir),
                                   CompilerBootstrapSnapshotText(rootDir, snapshot)):
            CompilerPrintErr(" compiler: failed to write bootstrap snapshot: " +
                               contracts.BootstrapSnapshotPath(rootDir))
            return 2
        CompilerPrintLine("bootstrap bridge ok: " + snapshot.stage2Compiler.path)
        return 0
    let bootstrapCompiler = CompilerBootstrapCompilerPath(rootDir, snapshot)
    if len(bootstrapCompiler) <= 0:
        CompilerPrintErr(" compiler: bootstrap inputs newer than live bootstrap compiler; rebuild stage0 and rerun bootstrap-bridge")
        return 2
    if !CompilerBootstrapCompilerFresh(rootDir, bootstrapCompiler):
        CompilerPrintErr(" compiler: bootstrap inputs newer than live bootstrap compiler; rebuild stage0 and rerun bootstrap-bridge")
        return 2
    let stage0Candidate = snapshot.stage0Compiler.path + ".next"
    let stage1Candidate = snapshot.stage1Compiler.path + ".next"
    let stage2Candidate = snapshot.stage2Compiler.path + ".next"
    let stage3Candidate = snapshot.stage3Compiler.path + ".next"
    let stage1ReportPath = CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt")
    let stage2ReportPath = CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt")
    let stage3ReportPath = CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt")
    let installLogPath = CompilerBootstrapLog(rootDir, "bootstrap_bridge.install.txt")
    if !CompilerBootstrapMaterializeStage0Candidate(rootDir,
                                                      bootstrapCompiler,
                                                      snapshot.stage0Compiler.path,
                                                      stage0Candidate):
        CompilerPrintErr(" compiler: failed to materialize stage0 candidate: " + stage0Candidate)
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage0_self_check",
                                    stage0Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage0.self-check.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage1_compile",
                                    stage0Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage1Candidate
                                    ],
                                    CompilerBootstrapLog(rootDir, "cheng.stage1.compile.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage1_self_check",
                                    stage1Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage1.self-check.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage2_compile",
                                    stage1Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage2Candidate
                                    ],
                                    CompilerBootstrapLog(rootDir, "cheng.stage2.compile.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage2_self_check",
                                    stage2Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage2.self-check.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage3_compile",
                                    stage2Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage3Candidate
                                    ],
                                    CompilerBootstrapLog(rootDir, "cheng.stage3.compile.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage3_self_check",
                                    stage3Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage3.self-check.log")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage2_contract",
                                    stage2Candidate,
                                    ["print-contract", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt")):
        return 2
    if !CompilerBootstrapStageRun(rootDir,
                                    "stage3_contract",
                                    stage3Candidate,
                                    ["print-contract", "--in:" + snapshot.stage1Source.path],
                                    CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt")):
        return 2
    let stage2Contract = chengpath.ReadTextFile("", CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt"))
    let stage3Contract = chengpath.ReadTextFile("", CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt"))
    if stage2Contract != stage3Contract:
        CompilerPrintErr(" compiler: fixed point mismatch stage2/stage3 contract drift")
        return 2
    var installReport = ""
    if bootstrapCompiler == snapshot.stage0Compiler.path:
        if chengpath.PathFileExists(stage0Candidate) && !os.RemoveFile(stage0Candidate):
            installReport = installReport + "stage0_reuse=cleanup_failed\n"
            let ignoredWriteInstallLog = chengpath.WriteTextFile(rootDir, installLogPath, installReport)
            CompilerPrintErr(" compiler: failed to discard bootstrap stage0 candidate: " + stage0Candidate)
            return 2
        installReport = installReport + "stage0_reuse=ok\n"
    else:
        if !CompilerBootstrapInstallCandidate(rootDir,
                                                stage0Candidate,
                                                snapshot.stage0Compiler.path,
                                                installLogPath,
                                                "stage0",
                                                installReport):
            CompilerPrintErr(" compiler: failed to install bootstrap stage0: " + snapshot.stage0Compiler.path)
            return 2
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            stage1Candidate,
                                            snapshot.stage1Compiler.path,
                                            installLogPath,
                                            "stage1",
                                            installReport):
        CompilerPrintErr(" compiler: failed to install bootstrap stage1: " + snapshot.stage1Compiler.path)
        return 2
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            stage2Candidate,
                                            snapshot.stage2Compiler.path,
                                            installLogPath,
                                            "stage2",
                                            installReport):
        CompilerPrintErr(" compiler: failed to install bootstrap stage2: " + snapshot.stage2Compiler.path)
        return 2
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            stage3Candidate,
                                            snapshot.stage3Compiler.path,
                                            installLogPath,
                                            "stage3",
                                            installReport):
        CompilerPrintErr(" compiler: failed to install bootstrap stage3: " + snapshot.stage3Compiler.path)
        return 2
    if !chengpath.WriteTextFile(rootDir, snapshot.bootstrapEnv.path, CompilerBootstrapEnvText(rootDir, snapshot)):
        CompilerPrintErr(" compiler: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
        return 2
    if !chengpath.WriteTextFile(rootDir,
                               contracts.BootstrapSnapshotPath(rootDir),
                               CompilerBootstrapSnapshotText(rootDir, snapshot)):
        CompilerPrintErr(" compiler: failed to write bootstrap snapshot: " +
                           contracts.BootstrapSnapshotPath(rootDir))
        return 2
    CompilerPrintLine("bootstrap bridge ok: " + snapshot.stage2Compiler.path)
    return 0

fn CompilerR2cReactFreshCleanGate(rootDir: str,
                                    args: str[]): int32 =
    let repoRaw = cmdline.ReadFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let repo = chengpath.PathAbsolute(rootDir, repoRaw)
    if !os.DirExists(repo):
        CompilerPrintErr(" compiler: missing React.js repo: " + repo)
        return 2
    let statusOut = "/tmp/r2c-status-fresh-clean-gate.json"
    let smokeNames: str[] = [
        "compiler_runtime_smoke",
        "host_process_pipe_spawn_bridge_smoke",
        "host_process_pipe_spawn_api_smoke",
        "host_process_exec_file_capture_smoke",
        "host_process_exec_file_direct_seq_smoke"
    ]
    let routeStates: str[] = ["home_default", "content_detail", "publish_selector"]
    let codegenSmokeOutDir = "/tmp/r2c-codegen-surface-fresh-clean-gate"
    let statusNeedles: str[] = r2cstatus.R2cReactExpectedStatusNeedles()
    let reportNeedles: str[] = [
        "\"ok\": true",
        "\"native_gui_host_ready\": true",
        "\"native_gui_renderer_ready\": true"
    ]
    if !CompilerRemovePathTree(statusOut):
        CompilerPrintErr(" compiler: failed to clear status report: " + statusOut)
        return 2
    for i in 0..<routeStates.len:
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeStates[i]
        if !CompilerRemovePathTree(bundleOutDir):
            CompilerPrintErr(" compiler: failed to clear bundle dir: " + bundleOutDir)
            return 2
    if !CompilerRemovePathTree(codegenSmokeOutDir):
        CompilerPrintErr(" compiler: failed to clear codegen smoke dir: " + codegenSmokeOutDir)
        return 2
    if !CompilerCleanHostrunArtifacts(rootDir, smokeNames):
        CompilerPrintErr(" compiler: failed to clear stale hostrun artifacts")
        return 2
    if !CompilerEnsureBackendDriver(rootDir, "r2c fresh gate"):
        return 2
    let backendDriverPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
    if !chengpath.FileExistsNonEmpty(rootDir, backendDriverPath):
        CompilerPrintErr(" compiler: missing backend driver for r2c fresh gate: " + backendDriverPath)
        return 2
    let bootstrapSnapshot = contracts.BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !chengpath.FileExistsNonEmpty(rootDir, stage3Path):
        CompilerPrintErr(" compiler: missing stage3 for r2c fresh gate: " + stage3Path)
        return 2
    if CompilerForwardToBridge(rootDir, stage3Path, "run-host-smokes", smokeNames) != 0:
        CompilerPrintErr(" compiler: run-host-smokes failed inside r2c fresh gate")
        return 2
    let auditText = hbagate.HostBridgeAuditGateText(rootDir)
    CompilerPrintLine(auditText)
    if !strutil.Contains(auditText, "pure_cheng_zero_c_ready=1") ||
       !strutil.Contains(auditText, "remaining_non_pure_cheng_boundary=none"):
        CompilerPrintErr(" compiler: host bridge audit not ready for r2c fresh gate")
        return 2
    if CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react",
                                 ["status", "--out", statusOut]) != 0:
        CompilerPrintErr(" compiler: r2c-react status failed inside fresh gate")
        return 2
    if !chengpath.PathFileExists(statusOut):
        CompilerPrintErr(" compiler: missing r2c status report: " + statusOut)
        return 2
    let statusText = chengpath.ReadTextFile("", statusOut)
    if !CompilerTextContainsAll(statusText, statusNeedles):
        CompilerPrintErr(" compiler: r2c status report drifted from expected helper contract")
        return 2
    if CompilerForwardToBridgeEnv(rootDir,
                                    backendDriverPath,
                                    "r2c-react-codegen-surface-smoke",
                                    [
                                        "--repo", repo,
                                        "--out-dir", codegenSmokeOutDir
                                    ],
                                    ["CHENG_BACKEND_DRIVER_READY=1"]) != 0:
        CompilerPrintErr(" compiler: r2c codegen surface smoke failed inside fresh gate")
        return 2
    for i in 0..<routeStates.len:
        let routeState = routeStates[i]
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        if CompilerForwardToBridge(rootDir,
                                     stage3Path,
                                     "r2c-react",
                                     [
                                         "native-gui-bundle",
                                         "--repo", repo,
                                         "--out-dir", bundleOutDir,
                                         "--route-state", routeState
                                     ]) != 0:
            CompilerPrintErr(" compiler: native-gui-bundle failed for route: " + routeState)
            return 2
        let bundleReport = os.JoinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
        let bundleSummary = os.JoinPath(bundleOutDir, "native_gui_bundle.summary.env")
        let bundleJson = os.JoinPath(bundleOutDir, "native_gui_bundle_v1.json")
        if !chengpath.PathFileExists(bundleReport) || !chengpath.PathFileExists(bundleSummary) || !chengpath.PathFileExists(bundleJson):
            CompilerPrintErr(" compiler: missing bundle artifacts for route: " + routeState)
            return 2
        let reportText = chengpath.ReadTextFile("", bundleReport)
        let summaryText = chengpath.ReadTextFile("", bundleSummary)
        if !CompilerTextContainsAll(reportText, reportNeedles):
            CompilerPrintErr(" compiler: bundle report drifted for route: " + routeState)
            return 2
        if !strutil.Contains(summaryText, "native_gui_runtime_mode=cheng_compiled_json_v1") ||
           !strutil.Contains(summaryText, "native_gui_route_state=" + routeState):
            CompilerPrintErr(" compiler: bundle runtime mode drifted for route: " + routeState)
            return 2
    CompilerPrintLine("r2c-react fresh clean gate: ok")
    CompilerPrintLine("status_report=" + statusOut)
    for i in 0..<routeStates.len:
        let routeState = routeStates[i]
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        let bundleReport = os.JoinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
        var bundleLine = "bundle_report_"
        bundleLine = bundleLine + routeState
        bundleLine = bundleLine + "="
        bundleLine = bundleLine + bundleReport
        CompilerPrintLine(bundleLine)
    return 0

fn CompilerLegacyMigrationBuild(rootDir: str,
                                  packageRoot: str,
                                  legacySourcePathRaw: str,
                                  packageIdHint: str,
                                  entryModulePath: str,
                                  out: var ccsg.CompilerLegacyMigration): Result[bool] =
    let legacySourcePath = chengpath.PathAbsolute(rootDir, legacySourcePathRaw)
    if len(legacySourcePath) <= 0:
        return Err[bool](" compiler migration: missing --legacy-in")
    let migrationRes = ccsg.BuildCompilerLegacyMigration(rootDir,
                                                           packageRoot,
                                                           legacySourcePath,
                                                           packageIdHint,
                                                           entryModulePath)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    out = ccsg.CompilerLegacyMigrationClone(Value(migrationRes))
    return Ok[bool](true)

fn CompilerMigrationReceipt(plan: sexec.SystemLinkExecPlan,
                              migration: ccsg.CompilerLegacyMigration): ccsg.CompileReceipt =
    let outputDigest = ccsg.CompileOutputDigest(plan.systemLinkPlan.outputPath,
                                                  plan.systemLinkPlan.targetTriple,
                                                  plan.systemLinkPlan.providerModules,
                                                  migration.compilerCsg.graphCid)
    let canonicalOutputDigest = ccsg.CompileOutputDigest(plan.systemLinkPlan.outputPath,
                                                           plan.systemLinkPlan.targetTriple,
                                                           plan.systemLinkPlan.providerModules,
                                                           migration.compilerCsg.canonicalGraphCid)
    return ccsg.CompileReceiptMake(plan.localUniverse.worldHead.headCid,
                                     migration.compilerCsg.graphCid,
                                     migration.compilerCsg.canonicalGraphCid,
                                     plan.systemLinkPlan.targetTriple,
                                     outputDigest,
                                     canonicalOutputDigest,
                                     plan.compileReceipt.bootstrapStage,
                                     plan.systemLinkPlan.providerModules)

fn CompilerMigrationProofFromArgs(rootDir: str,
                                    args: str[],
                                    req: creq.CompilerRequest,
                                    plan: sexec.SystemLinkExecPlan,
                                    outMigration: var ccsg.CompilerLegacyMigration,
                                    out: var ceq.CompilerEquivalenceProof): Result[bool] =
    let legacySourcePath = creq.CompilerLegacyInPathFromArgs(args)
    if len(legacySourcePath) <= 0:
        return Err[bool](" compiler migration: missing --legacy-in")
    let packageRoot = creq.CompilerRequestRootDir(req)
    let sourcePath = creq.CompilerRequestSourcePath(req)
    let entryModulePath = parser.ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                sourcePath)
    let migrationRes = CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      plan.systemLinkPlan.packageId,
                                                      entryModulePath,
                                                      outMigration)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    let baselineCsgText = ccsg.CompilerCsgReport(plan.compilerCsg)
    let migratedCsgText = ccsg.CompilerCsgReport(outMigration.compilerCsg)
    let baselineSurfaceText = ccsg.CompilerExportSurfaceReport(plan.exportSurface)
    let migratedSurfaceText = ccsg.CompilerExportSurfaceReport(outMigration.exportSurface)
    let migratedReceipt = CompilerMigrationReceipt(plan, outMigration)
    let baselineReceiptText = ccsg.CompileReceiptReport(plan.compileReceipt)
    let migratedReceiptText = ccsg.CompileReceiptReport(migratedReceipt)
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var graphEquivalent = 0
    let graphRes = ceq.CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn CompilerMigrationProofFromRuntimeFlags(rootDir: str,
                                            req: creq.CompilerRequest,
                                            plan: sexec.SystemLinkExecPlan,
                                            outMigration: var ccsg.CompilerLegacyMigration,
                                            out: var ceq.CompilerEquivalenceProof): Result[bool] =
    let legacySourcePath = cmdline.ReadFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        return Err[bool](" compiler migration: missing --legacy-in")
    let packageRoot = creq.CompilerRequestRootDir(req)
    let sourcePath = creq.CompilerRequestSourcePath(req)
    let entryModulePath = parser.ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                sourcePath)
    let migrationRes = CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      plan.systemLinkPlan.packageId,
                                                      entryModulePath,
                                                      outMigration)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    let baselineCsgText = ccsg.CompilerCsgReport(plan.compilerCsg)
    let migratedCsgText = ccsg.CompilerCsgReport(outMigration.compilerCsg)
    let baselineSurfaceText = ccsg.CompilerExportSurfaceReport(plan.exportSurface)
    let migratedSurfaceText = ccsg.CompilerExportSurfaceReport(outMigration.exportSurface)
    let migratedReceipt = CompilerMigrationReceipt(plan, outMigration)
    let baselineReceiptText = ccsg.CompileReceiptReport(plan.compileReceipt)
    let migratedReceiptText = ccsg.CompileReceiptReport(migratedReceipt)
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var graphEquivalent = 0
    let graphRes = ceq.CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn CompilerProofModeFromArgs(args: str[],
                               required: bool,
                               outMode: var str): Result[bool] =
    let equivalenceInputsRes = CompilerEquivalenceInputsReady(args, false)
    if IsErr(equivalenceInputsRes):
        return Err[bool](Error(equivalenceInputsRes))
    let equivalenceEnabled = Value(equivalenceInputsRes)
    let legacySourcePath = creq.CompilerLegacyInPathFromArgs(args)
    let legacySourcePathLen = len(legacySourcePath)
    var migrationEnabled = false
    if legacySourcePathLen > 0:
        migrationEnabled = true
    if equivalenceEnabled && migrationEnabled:
        return Err[bool](" compiler proof: choose either --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    if required && !equivalenceEnabled && !migrationEnabled:
        return Err[bool](" compiler proof: stable requires --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    outMode = ""
    if migrationEnabled:
        outMode = "migration"
    elif equivalenceEnabled:
        outMode = "equivalence"
    return Ok[bool](migrationEnabled || equivalenceEnabled)

fn CompilerProofModeFromRuntimeFlags(required: bool,
                                       outMode: var str): Result[bool] =
    let equivalenceInputsRes = CompilerEquivalenceInputsReadyFromRuntimeFlags(false)
    if IsErr(equivalenceInputsRes):
        return Err[bool](Error(equivalenceInputsRes))
    let equivalenceEnabled = Value(equivalenceInputsRes)
    let legacySourcePath = cmdline.ReadFlagOrDefault("--legacy-in", "")
    let legacySourcePathLen = len(legacySourcePath)
    var migrationEnabled = false
    if legacySourcePathLen > 0:
        migrationEnabled = true
    if equivalenceEnabled && migrationEnabled:
        return Err[bool](" compiler proof: choose either --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    if required && !equivalenceEnabled && !migrationEnabled:
        return Err[bool](" compiler proof: stable requires --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    outMode = ""
    if migrationEnabled:
        outMode = "migration"
    elif equivalenceEnabled:
        outMode = "equivalence"
    return Ok[bool](migrationEnabled || equivalenceEnabled)

fn CompilerLegacyArtifactsWrite(rootDir: str,
                                  prefix: str,
                                  migration: ccsg.CompilerLegacyMigration,
                                  receipt: ccsg.CompileReceipt): bool =
    if len(prefix) <= 0:
        return true
    if !chengpath.WriteTextFile(rootDir, prefix + ".migration.txt", ccsg.CompilerLegacyMigrationReport(migration) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, prefix + ".migration.csg.txt", ccsg.CompilerCsgReport(migration.compilerCsg) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, prefix + ".migration.surface.txt", ccsg.CompilerExportSurfaceReport(migration.exportSurface) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, prefix + ".migration.receipt.txt", ccsg.CompileReceiptReport(receipt) + "\n"):
        return false
    return true

fn CompilerManagedMirrorKey(text: str): str =
    return cworld.CompilerManagedMirrorKey(text)

fn CompilerManagedMirrorRelSourcePath(packageRoot: str,
                                        sourcePath: str): str =
    let packageRootTrimmed = chengpath.PathTrim(packageRoot)
    let sourcePathTrimmed = chengpath.PathTrim(sourcePath)
    let packagePrefix = packageRootTrimmed + "/"
    if len(packageRootTrimmed) > 0 && strutil.StartsWith(sourcePathTrimmed, packagePrefix):
        return strings.DropPrefix(sourcePathTrimmed, packagePrefix)
    return chengpath.PathBaseName(sourcePathTrimmed)

fn CompilerManagedMirrorPackageManifestText(packageIdRaw: str): str =
    let packageId = chengpath.PathTrim(packageIdRaw)
    var modulePrefix = chengpath.PathBaseName(packageId)
    if len(modulePrefix) <= 0:
        modulePrefix = "pkg"
    return "package_id = \"pkg://" + packageId + "\"\nmodule_prefix = \"" + modulePrefix + "\"\n"

fn CompilerManagedMigrationMirrorWrite(rootDir: str,
                                         packageRoot: str,
                                         channel: str,
                                         migration: ccsg.CompilerLegacyMigration,
                                         receipt: ccsg.CompileReceipt,
                                         proof: ceq.CompilerEquivalenceProof,
                                         lockText: str,
                                         outMirrorRoot: var str): bool =
    outMirrorRoot = ""
    let mirrorRel = cworld.CompilerManagedMirrorRel(channel, migration.packageId, proof.proofCid)
    let mirrorRoot = chengpath.PathAbsolute(rootDir, mirrorRel)
    if !chengpath.MkdirP(rootDir, mirrorRel):
        return false
    if !chengpath.WriteTextFile(rootDir,
                               chengpath.PathJoin(mirrorRel, "cheng-package.toml"),
                               CompilerManagedMirrorPackageManifestText(migration.packageId)):
        return false
    var sourcesReport = ""
    for i in 0..<migration.units.len:
        let unit = migration.units[i]
        let relSourcePath = CompilerManagedMirrorRelSourcePath(packageRoot, unit.sourcePath)
        let mirrorSourcePath = chengpath.PathJoin(mirrorRel, relSourcePath)
        if !chengpath.WriteTextFile(rootDir, mirrorSourcePath, unit.migratedText):
            return false
        if len(sourcesReport) > 0:
            sourcesReport = sourcesReport + "\n"
        sourcesReport = sourcesReport + relSourcePath
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "sources.list.txt"), sourcesReport + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "migration.txt"), ccsg.CompilerLegacyMigrationReport(migration) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "migration.csg.txt"), ccsg.CompilerCsgReport(migration.compilerCsg) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "migration.surface.txt"), ccsg.CompilerExportSurfaceReport(migration.exportSurface) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "migration.receipt.txt"), ccsg.CompileReceiptReport(receipt) + "\n"):
        return false
    if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "proof.txt"), ceq.CompilerEquivalenceProofReport(proof) + "\n"):
        return false
    if len(lockText) > 0:
        if !chengpath.WriteTextFile(rootDir, chengpath.PathJoin(mirrorRel, "cheng.lock.toml"), lockText):
            return false
    outMirrorRoot = mirrorRoot
    return true

fn CompilerPublishSummary(prefix: str,
                            channel: str,
                            plan: sexec.SystemLinkExecPlan,
                            proofMode: str,
                            equivalenceChecked: bool,
                            equivalencePassed: int32,
                            publishAllowed: int32,
                            proofCid: layout.FixedBytes32): str =
    var checked = "0"
    var passed = IntToStr(equivalencePassed)
    var proofModeText = "-"
    if equivalenceChecked:
        checked = "1"
    if len(proofMode) > 0:
        proofModeText = proofMode
    var out = ""
    out = out + "bundle_prefix=" + prefix + "\n"
    out = out + "channel=" + channel + "\n"
    out = out + "world_head_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    out = out + "manifest_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.manifest.manifestCid) + "\n"
    out = out + "manifest_entry_count=" + IntToStr(plan.localUniverse.manifest.entryCount) + "\n"
    out = out + "csg_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.csgRootCid) + "\n"
    out = out + "surface_cid=" + layout.FixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    out = out + "receipt_cid=" + layout.FixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    out = out + "proof_mode=" + proofModeText + "\n"
    out = out + "equivalence_checked=" + checked + "\n"
    out = out + "equivalence_passed=" + passed + "\n"
    out = out + "publish_allowed=" + IntToStr(publishAllowed) + "\n"
    out = out + "proof_cid=" + layout.FixedBytes32Hex(proofCid)
    return out

fn CompilerEmitCsg(rootDir: str,
                     args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err):
        CompilerPrintErr(err)
        return 2
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    if IsErr(sourceBundleRes):
        CompilerPrintErr(Error(sourceBundleRes))
        return 2
    let sourceBundleCid = Value(sourceBundleRes)
    var csg: ccsg.CompilerCsg
    var csgErr = ""
    if !ccsg.BuildCompilerCsgInto(linkPlan, sourceBundleCid, csg, csgErr):
        if len(csgErr) <= 0:
            csgErr = "compiler emit csg: compiler csg build failed"
        CompilerPrintErr(csgErr)
        return 2
    let report = ccsg.CompilerCsgReport(csg)
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerVerifyBackendEgraphCost(rootDir: str,
                                    args: str[]): int32 =
    args
    let report = ccsg.CompilerCsgEgraphActiveContractReport()
    let reportPath = cmdline.ReadFlagOrDefault("--report-out", "")
    if !CompilerWriteOptionalReport(rootDir, reportPath, report):
        CompilerPrintErr(strutil.Join([" compiler: failed to write report: ", reportPath], ""))
        return 2
    CompilerPrintErr(report)
    return ccsg.CompilerCsgUirEgraphUnavailableExitCode()

fn CompilerMigrateCsg(rootDir: str,
                        args: str[]): int32 =
    args
    let packageRoot = CompilerPackageRootFromRuntimeFlags(rootDir)
    let legacySourcePath = cmdline.ReadFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        CompilerPrintErr(" compiler migration: missing --legacy-in")
        return 2
    let currentSourcePath = cmdline.ReadFlagOrDefault("--in", "")
    var entryModulePath = ""
    if len(currentSourcePath) > 0:
        entryModulePath = parser.ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                chengpath.PathAbsolute(rootDir, currentSourcePath))
    var migration: ccsg.CompilerLegacyMigration
    let migrationRes = CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      parser.ParserPackageId(packageRoot),
                                                      entryModulePath,
                                                      migration)
    if IsErr(migrationRes):
        CompilerPrintErr(Error(migrationRes))
        return 2
    let prefix = cmdline.ReadFlagOrDefault("--out", "")
    var providers: str[]
    if entryModulePath == "cheng/core/tooling/compiler_main":
        crun.RuntimeProviderModulesForTrack(crun.CompilerTrackTooling, providers)
    else:
        crun.RuntimeProviderModulesForTrack(crun.CompilerTrackProgram, providers)
    let receipt = ccsg.CompileReceiptMake(layout.FixedBytes32(),
                                            migration.compilerCsg.graphCid,
                                            migration.compilerCsg.canonicalGraphCid,
                                            contracts.BootstrapDefaultTarget(),
                                            ccsg.CompileOutputDigest(prefix,
                                                                      contracts.BootstrapDefaultTarget(),
                                                                      providers,
                                                                      migration.compilerCsg.graphCid),
                                            ccsg.CompileOutputDigest(prefix,
                                                                      contracts.BootstrapDefaultTarget(),
                                                                      providers,
                                                                      migration.compilerCsg.canonicalGraphCid),
                                            "legacy_migration",
                                            providers)
    if !CompilerLegacyArtifactsWrite(rootDir, prefix, migration, receipt):
        CompilerPrintErr(" compiler migration: failed to write migration artifacts: " + prefix)
        return 2
    let report = ccsg.CompilerLegacyMigrationReport(migration)
    let reportPath = cmdline.ReadFlagOrDefault("--report-out", "")
    if !CompilerWriteOptionalReport(rootDir, reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerVerifyWorld(rootDir: str,
                         args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let stagedReqRes = CompilerStageRequestForWorldPlan(rootDir,
                                                          req,
                                                          "artifacts/backend_driver/verify_world_source")
    if IsErr(stagedReqRes):
        CompilerPrintErr(Error(stagedReqRes))
        return 2
    let stagedReq = Value(stagedReqRes)
    let planRes = CompilerBuildSystemPlanFromRuntimeFlags(rootDir, stagedReq)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(CompilerSystemLinkExecSummary(plan))
    return 0

fn CompilerWorldReceiptReport(plan: sexec.SystemLinkExecPlan): str =
    var report = ""
    report = report + "entry=" + plan.compilerEntrySource + "\n"
    report = report + "world_head_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    report = report + "manifest_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.manifest.manifestCid) + "\n"
    report = report + "compile_receipt_cid=" + layout.FixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    report = report + "compile_canonical_output_digest=" + layout.FixedBytes32Hex(plan.compileReceipt.canonicalOutputDigest) + "\n"
    report = report + "compile_output_digest=" + layout.FixedBytes32Hex(plan.compileReceipt.outputDigest) + "\n"
    report = report + "compile_bootstrap_stage=" + plan.compileReceipt.bootstrapStage
    return report

fn CompilerWorldReceipt(rootDir: str,
                          args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let stagedReqRes = CompilerStageRequestForWorldPlan(rootDir,
                                                          req,
                                                          "artifacts/backend_driver/world_receipt_source")
    if IsErr(stagedReqRes):
        CompilerPrintErr(Error(stagedReqRes))
        return 2
    let stagedReq = Value(stagedReqRes)
    let planRes = CompilerBuildSystemPlanFromRuntimeFlags(rootDir, stagedReq)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = CompilerWorldReceiptReport(plan)
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerWorldSyncWriteBundle(rootDir: str,
                                  prefix: str,
                                  plan: sexec.SystemLinkExecPlan,
                                  managedMirrorBundles: cwlp.CompilerManagedMirrorBundle[]): bool =
    let worldText = cworld.CompilerWorldHeadReport(plan.localUniverse.worldHead) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".world.txt", worldText):
        return false
    let manifestText = cworld.CompilerUniverseManifestReport(plan.localUniverse.manifest) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".manifest.txt", manifestText):
        return false
    let compilerSnapshotText = cworld.CompilerPackageSnapshotReport(plan.localUniverse.compilerSnapshot) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".compiler.snapshot.txt", compilerSnapshotText):
        return false
    let stdSnapshotText = cworld.CompilerPackageSnapshotReport(plan.localUniverse.stdSnapshot) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".std.snapshot.txt", stdSnapshotText):
        return false
    let runtimeSnapshotText = cworld.CompilerPackageSnapshotReport(plan.localUniverse.runtimeSnapshot) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".runtime.snapshot.txt", runtimeSnapshotText):
        return false
    let csgText = ccsg.CompilerCsgWireReport(plan.compilerCsg) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".csg.txt", csgText):
        return false
    let surfaceText = ccsg.CompilerExportSurfaceReport(plan.exportSurface) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".surface.txt", surfaceText):
        return false
    let receiptText = ccsg.CompileReceiptReport(plan.compileReceipt) + "\n"
    if !chengpath.WriteTextFile(rootDir, prefix + ".receipt.txt", receiptText):
        return false
    let lockText = cworld.CompilerLockText(plan.localUniverse)
    if !chengpath.WriteTextFile(rootDir, prefix + ".lock.toml", lockText):
        return false
    if !cwlp.CompilerWorldWriteManagedMirrorBundleFiles(rootDir,
                                                          prefix,
                                                          managedMirrorBundles):
        return false
    return true

fn compilerMainWorldSync(rootDir: str,
                           args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let stagedReqRes = CompilerStageRequestForWorldPlan(rootDir,
                                                          req,
                                                          "artifacts/backend_driver/world_sync_source")
    if IsErr(stagedReqRes):
        CompilerPrintErr(Error(stagedReqRes))
        return 2
    let stagedReq = Value(stagedReqRes)
    let planRes = CompilerBuildSystemPlanFromRuntimeFlags(rootDir, stagedReq)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let managedMirrorBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(managedMirrorBundlesRes):
        CompilerPrintErr(Error(managedMirrorBundlesRes))
        return 2
    let managedMirrorBundles = Value(managedMirrorBundlesRes)
    if !CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan, managedMirrorBundles):
        CompilerPrintErr(" compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    let sourceSnapshotRes = CompilerWorldBundleSourceSnapshotWrite(rootDir, stagedReq, req.outputPath)
    if IsErr(sourceSnapshotRes):
        CompilerPrintErr(Error(sourceSnapshotRes))
        return 2
    var report = "bundle_prefix=" + req.outputPath
    report = report + "\nworld_head_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid)
    report = report + "\nmanifest_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.manifest.manifestCid)
    report = report + "\nmanifest_entry_count=" + IntToStr(plan.localUniverse.manifest.entryCount)
    report = report + "\nmanaged_mirror_count=" + IntToStr(managedMirrorBundles.len)
    report = report + "\ncsg_root_cid=" + layout.FixedBytes32Hex(plan.localUniverse.worldHead.csgRootCid)
    report = report + "\nsurface_cid=" + layout.FixedBytes32Hex(plan.exportSurface.surfaceCid)
    report = report + "\nreceipt_cid=" + layout.FixedBytes32Hex(plan.compileReceipt.receiptCid)
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerMaterializeWorldMirrors(rootDir: str,
                                     args: str[]): int32 =
    args
    let bundlePrefix = cmdline.ReadFlagOrDefault("--in", "")
    if len(bundlePrefix) <= 0:
        CompilerPrintErr(" compiler: missing --in")
        return 2
    let materializeRes = cwlp.CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir, bundlePrefix)
    if IsErr(materializeRes):
        CompilerPrintErr(Error(materializeRes))
        return 2
    let report = cwlp.CompilerWorldManagedMirrorMaterializeReport(bundlePrefix, Value(materializeRes))
    let reportPath = cmdline.ReadFlagOrDefault("--report-out", "")
    if !CompilerWriteOptionalReport(rootDir, reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerProveEquivalence(rootDir: str,
                              args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let proofInputsRes = CompilerEquivalenceInputsReadyFromRuntimeFlags(true)
    if IsErr(proofInputsRes):
        CompilerPrintErr(Error(proofInputsRes))
        return 2
    let req = Value(reqRes)
    let planRes = CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    var proof: ceq.CompilerEquivalenceProof
    let proofRes = CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
    if IsErr(proofRes):
        CompilerPrintErr(Error(proofRes))
        return 2
    let report = ceq.CompilerEquivalenceProofReport(proof)
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerProveMigration(rootDir: str,
                            args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let legacySourcePath = cmdline.ReadFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        CompilerPrintErr(" compiler migration: missing --legacy-in")
        return 2
    let req = Value(reqRes)
    let planRes = CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    var migration: ccsg.CompilerLegacyMigration
    var proof: ceq.CompilerEquivalenceProof
    let proofRes = CompilerMigrationProofFromRuntimeFlags(rootDir, req, plan, migration, proof)
    if IsErr(proofRes):
        CompilerPrintErr(Error(proofRes))
        return 2
    let migrationReceipt = CompilerMigrationReceipt(plan, migration)
    let prefix = req.outputPath
    if !CompilerLegacyArtifactsWrite(rootDir, prefix, migration, migrationReceipt):
        CompilerPrintErr(" compiler migration: failed to write migration artifacts: " + prefix)
        return 2
    let proofReport = ceq.CompilerEquivalenceProofReport(proof)
    if len(prefix) > 0:
        if !chengpath.WriteTextFile(rootDir, prefix + ".proof.txt", proofReport + "\n"):
            CompilerPrintErr(" compiler: failed to write proof: " + prefix + ".proof.txt")
            return 2
    var managedMirrorRoot = ""
    if !CompilerManagedMigrationMirrorWrite(rootDir,
                                              creq.CompilerRequestRootDir(req),
                                              plan.localUniverse.worldHead.channel,
                                              migration,
                                              migrationReceipt,
                                              proof,
                                              cworld.CompilerLockText(plan.localUniverse),
                                              managedMirrorRoot):
        CompilerPrintErr(" compiler migration: failed to write managed mirror")
        return 2
    var report = ccsg.CompilerLegacyMigrationReport(migration) + "\n" + proofReport
    if len(managedMirrorRoot) > 0:
        report = report + "\nmanaged_mirror_root=" + managedMirrorRoot
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(report)
    return 0

fn CompilerPublishWorld(rootDir: str,
                          args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let stagedReqRes = CompilerStageRequestForWorldPlan(rootDir,
                                                          req,
                                                          "artifacts/backend_driver/publish_world_source")
    if IsErr(stagedReqRes):
        CompilerPrintErr(Error(stagedReqRes))
        return 2
    let stagedReq = Value(stagedReqRes)
    let planRes = CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, stagedReq)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let channel = plan.localUniverse.worldHead.channel
    var proofMode = ""
    let proofModeRes = CompilerProofModeFromRuntimeFlags(channel == "stable", proofMode)
    if IsErr(proofModeRes):
        CompilerPrintErr(Error(proofModeRes))
        return 2
    let proofEnabled = Value(proofModeRes)
    var equivalenceChecked = false
    var migration: ccsg.CompilerLegacyMigration
    var proof: ceq.CompilerEquivalenceProof
    var proofReport = ""
    var migrationReport = ""
    var migrationReceipt: ccsg.CompileReceipt
    if proofEnabled:
        if proofMode == "migration":
            let proofRes = CompilerMigrationProofFromRuntimeFlags(rootDir, stagedReq, plan, migration, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
            migrationReceipt = CompilerMigrationReceipt(plan, migration)
            migrationReport = ccsg.CompilerLegacyMigrationReport(migration)
            if !CompilerLegacyArtifactsWrite(rootDir, req.outputPath, migration, migrationReceipt):
                CompilerPrintErr(" compiler migration: failed to write migration artifacts: " + req.outputPath)
                return 2
        else:
            let proofRes = CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.FixedBytes32()
    var publishChannel = ""
    var stableGateRequired = 0
    var equivalenceCheckedFlag = 0
    var equivalencePassed = 0
    var publishAllowed = 0
    var proofCid = layout.FixedBytes32()
    let decisionRes = cpub.CompilerPublishDecisionEvaluate(channel,
                                                             plan.localUniverse.worldHead.headCid,
                                                             equivalenceChecked,
                                                             proof,
                                                             publishChannel,
                                                             stableGateRequired,
                                                             equivalenceCheckedFlag,
                                                             equivalencePassed,
                                                             publishAllowed,
                                                             proofCid)
    if IsErr(decisionRes):
        CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = cpub.CompilerPublishDecisionReport(publishChannel,
                                                              stableGateRequired,
                                                              equivalenceCheckedFlag,
                                                              equivalencePassed,
                                                              publishAllowed,
                                                              plan.localUniverse.worldHead.headCid,
                                                              proofCid)
    if publishAllowed == 0:
        if !CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
            return 2
        CompilerPrintErr(" compiler: publish blocked by canonical equivalence gate")
        CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                CompilerPrintErr(migrationReport)
            CompilerPrintErr(proofReport)
        return 2
    let managedMirrorBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(managedMirrorBundlesRes):
        CompilerPrintErr(Error(managedMirrorBundlesRes))
        return 2
    let managedMirrorBundles = Value(managedMirrorBundlesRes)
    if !CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan, managedMirrorBundles):
        CompilerPrintErr(" compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !chengpath.WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            CompilerPrintErr(" compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    var managedMirrorRoot = ""
    if proofMode == "migration":
        if !CompilerManagedMigrationMirrorWrite(rootDir,
                                                  creq.CompilerRequestRootDir(req),
                                                  channel,
                                                  migration,
                                                  migrationReceipt,
                                                  proof,
                                                  cworld.CompilerLockText(plan.localUniverse),
                                                  managedMirrorRoot):
            CompilerPrintErr(" compiler migration: failed to write managed mirror")
            return 2
    var freshReport = ""
    if channel == "stable":
        let freshRes = cwlp.CompilerWorldFreshNodeSelfhostReport(rootDir, stagedReq, plan)
        if IsErr(freshRes):
            CompilerPrintErr(" compiler: stable publish requires fresh-node selfhost")
            CompilerPrintErr(Error(freshRes))
            return 2
        freshReport = Value(freshRes)
        if !chengpath.WriteTextFile(rootDir, req.outputPath + ".fresh.txt", freshReport + "\n"):
            CompilerPrintErr(" compiler: failed to write fresh-node report: " + req.outputPath + ".fresh.txt")
            return 2
    if !chengpath.WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        CompilerPrintErr(" compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    var summary = CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           equivalencePassed,
                                           publishAllowed,
                                           proofCid)
    if len(managedMirrorRoot) > 0:
        summary = summary + "\nmanaged_mirror_root=" + managedMirrorRoot
    if len(freshReport) > 0:
        summary = summary + "\n" + freshReport
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(summary)
    return 0

fn CompilerFreshNodeSelfhost(rootDir: str,
                               args: str[]): int32 =
    args
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let stagedReqRes = CompilerStageRequestForWorldPlan(rootDir,
                                                          req,
                                                          "artifacts/backend_driver/fresh_node_source")
    if IsErr(stagedReqRes):
        CompilerPrintErr(Error(stagedReqRes))
        return 2
    let stagedReq = Value(stagedReqRes)
    let planRes = CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, stagedReq)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let channel = plan.localUniverse.worldHead.channel
    var proofMode = ""
    let proofModeRes = CompilerProofModeFromRuntimeFlags(channel == "stable", proofMode)
    if IsErr(proofModeRes):
        CompilerPrintErr(Error(proofModeRes))
        return 2
    let proofEnabled = Value(proofModeRes)
    var equivalenceChecked = false
    var migration: ccsg.CompilerLegacyMigration
    var proof: ceq.CompilerEquivalenceProof
    var proofReport = ""
    var migrationReport = ""
    var migrationReceipt: ccsg.CompileReceipt
    if proofEnabled:
        if proofMode == "migration":
            let proofRes = CompilerMigrationProofFromRuntimeFlags(rootDir, stagedReq, plan, migration, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
            migrationReceipt = CompilerMigrationReceipt(plan, migration)
            migrationReport = ccsg.CompilerLegacyMigrationReport(migration)
            if !CompilerLegacyArtifactsWrite(rootDir, req.outputPath, migration, migrationReceipt):
                CompilerPrintErr(" compiler migration: failed to write migration artifacts: " + req.outputPath)
                return 2
        else:
            let proofRes = CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.FixedBytes32()
    var publishChannel = ""
    var stableGateRequired = 0
    var equivalenceCheckedFlag = 0
    var equivalencePassed = 0
    var publishAllowed = 0
    var proofCid = layout.FixedBytes32()
    let decisionRes = cpub.CompilerPublishDecisionEvaluate(channel,
                                                             plan.localUniverse.worldHead.headCid,
                                                             equivalenceChecked,
                                                             proof,
                                                             publishChannel,
                                                             stableGateRequired,
                                                             equivalenceCheckedFlag,
                                                             equivalencePassed,
                                                             publishAllowed,
                                                             proofCid)
    if IsErr(decisionRes):
        CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = cpub.CompilerPublishDecisionReport(publishChannel,
                                                              stableGateRequired,
                                                              equivalenceCheckedFlag,
                                                              equivalencePassed,
                                                              publishAllowed,
                                                              plan.localUniverse.worldHead.headCid,
                                                              proofCid)
    if publishAllowed == 0:
        if !CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
            return 2
        CompilerPrintErr(" compiler: publish blocked by canonical equivalence gate")
        CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                CompilerPrintErr(migrationReport)
            CompilerPrintErr(proofReport)
        return 2
    let managedMirrorBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(managedMirrorBundlesRes):
        CompilerPrintErr(Error(managedMirrorBundlesRes))
        return 2
    let managedMirrorBundles = Value(managedMirrorBundlesRes)
    if !CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan, managedMirrorBundles):
        CompilerPrintErr(" compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !chengpath.WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            CompilerPrintErr(" compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    var managedMirrorRoot = ""
    if proofMode == "migration":
        if !CompilerManagedMigrationMirrorWrite(rootDir,
                                                  creq.CompilerRequestRootDir(req),
                                                  channel,
                                                  migration,
                                                  migrationReceipt,
                                                  proof,
                                                  cworld.CompilerLockText(plan.localUniverse),
                                                  managedMirrorRoot):
            CompilerPrintErr(" compiler migration: failed to write managed mirror")
            return 2
    if !chengpath.WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        CompilerPrintErr(" compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    let freshRes = cwlp.CompilerWorldFreshNodeSelfhostReport(rootDir, req, plan)
    if IsErr(freshRes):
        CompilerPrintErr(Error(freshRes))
        return 2
    let freshReport = Value(freshRes)
    if !chengpath.WriteTextFile(rootDir, req.outputPath + ".fresh.txt", freshReport + "\n"):
        CompilerPrintErr(" compiler: failed to write fresh-node report: " + req.outputPath + ".fresh.txt")
        return 2
    var summary = CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           equivalencePassed,
                                           publishAllowed,
                                           proofCid)
    if len(managedMirrorRoot) > 0:
        summary = summary + "\nmanaged_mirror_root=" + managedMirrorRoot
    summary = summary + "\n" + freshReport
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(summary)
    return 0

type
    CompilerFollowInstallResult =
        backendDriverPath: str
        targetReceiptCid: layout.FixedBytes32
        candidateReceiptCid: layout.FixedBytes32

fn CompilerFollowWorldStageSourceSnapshot(rootDir: str,
                                            packageRoot: str,
                                            compilerEntrySource: str,
                                            stageRootRel: str,
                                            outPackageRoot: var str,
                                            outCompilerEntrySource: var str): Result[bool] =
    let stageRoot = chengpath.PathAbsolute(rootDir, stageRootRel)
    if (chengpath.PathDirExists(stageRoot) || chengpath.PathFileExists(stageRoot)) &&
       !CompilerRemovePathTree(stageRoot):
        return Err[bool](" compiler: failed to reset follow-world source stage root: " + stageRoot)
    if !chengpath.MkdirP(rootDir, stageRoot):
        return Err[bool](" compiler: failed to prepare follow-world source stage root: " + stageRoot)
    let packageLeaf = os.ExtractFilename(packageRoot)
    if len(packageLeaf) <= 0:
        return Err[bool](" compiler: invalid follow-world package root: " + packageRoot)
    let stagedPackageRoot = os.JoinPath(stageRoot, packageLeaf)
    let entryRelRaw = os.RelativePath(compilerEntrySource, packageRoot)
    let entryRel = strutil.Strip(entryRelRaw)
    if len(entryRel) <= 0 ||
       entryRel == compilerEntrySource ||
       strutil.StartsWith(entryRel, ".."):
        return Err[bool](" compiler: follow-world entry is outside package root: " + compilerEntrySource)
    let copyLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.copy.log")
    let copyRun = hostops.RunProgramLogged(rootDir,
                                             "follow_world_stage_source",
                                             "cp",
                                             ["-R", packageRoot, stageRoot],
                                             [],
                                             rootDir,
                                             0,
                                             copyLogPath)
    if !hostops.LoggedRunOk(copyRun):
        return Err[bool](" compiler: failed to stage follow-world package root: " + copyRun.output)
    let stagedEntry = os.JoinPath(stagedPackageRoot, entryRel)
    if !chengpath.PathFileExists(stagedEntry):
        return Err[bool](" compiler: missing staged follow-world entry source: " + stagedEntry)
    let workspaceRoot = parser.ParserWorkspaceRoot(packageRoot)
    if workspaceRoot != "" && workspaceRoot != packageRoot:
        let workspaceSrc = os.JoinPath(workspaceRoot, "src")
        if !chengpath.PathDirExists(workspaceSrc):
            return Err[bool](" compiler: missing follow-world shared workspace src: " + workspaceSrc)
        let workspaceSrcCopyLogPath = chengpath.PathAbsolute(rootDir,
                                                            "artifacts/backend_driver/follow_world.workspace_src.copy.log")
        let workspaceSrcCopyRun = hostops.RunProgramLogged(rootDir,
                                                             "follow_world_stage_workspace_src",
                                                             "cp",
                                                             ["-R", workspaceSrc, stageRoot],
                                                             [],
                                                             rootDir,
                                                             0,
                                                             workspaceSrcCopyLogPath)
        if !hostops.LoggedRunOk(workspaceSrcCopyRun):
            return Err[bool](" compiler: failed to stage follow-world shared workspace src: " +
                             workspaceSrcCopyRun.output)
        let stagedWorkspaceSrc = os.JoinPath(stageRoot, "src")
        if !chengpath.PathDirExists(stagedWorkspaceSrc):
            return Err[bool](" compiler: missing staged follow-world shared workspace src: " + stagedWorkspaceSrc)
    outPackageRoot = stagedPackageRoot
    outCompilerEntrySource = stagedEntry
    return Ok[bool](true)

fn CompilerStageRequestForWorldPlan(rootDir: str,
                                      req: creq.CompilerRequest,
                                      stageRootRel: str): Result[creq.CompilerRequest] =
    var stagedPackageRoot = creq.CompilerRequestRootDir(req)
    var stagedSourcePath = creq.CompilerRequestSourcePath(req)
    let stageRes = CompilerFollowWorldStageSourceSnapshot(rootDir,
                                                            creq.CompilerRequestRootDir(req),
                                                            creq.CompilerRequestSourcePath(req),
                                                            stageRootRel,
                                                            stagedPackageRoot,
                                                            stagedSourcePath)
    if IsErr(stageRes):
        return Err[creq.CompilerRequest](Error(stageRes))
    let stagedReq0 = creq.CompilerRequestNew(stagedPackageRoot,
                                               stagedSourcePath,
                                               creq.CompilerRequestOutputPath(req),
                                               creq.CompilerRequestTargetTriple(req),
                                               creq.CompilerRequestEmitKind(req),
                                               req.reportPath)
    let stagedReq1 = creq.CompilerRequestWithSymbolVisibility(stagedReq0,
                                                                creq.CompilerRequestSymbolVisibility(req))
    let stagedReq = creq.CompilerRequestWithBrowserBridgeObject(stagedReq1,
                                                                  creq.CompilerRequestBrowserBridgeObjectPath(req))
    return Ok[creq.CompilerRequest](stagedReq)

fn CompilerWorldBundleSourceStageRoot(bundlePrefix: str): str =
    return bundlePrefix + ".source"

fn CompilerBridgeSurfaceStageRoot(): str =
    return "artifacts/backend_driver/bridge_surface_source"

fn CompilerBridgeIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn CompilerBridgeIsInlineSpace(ch: char): bool =
    return ch == ' ' || ch == '\t'

fn CompilerBridgeSkipInlineSpaces(text: str,
                                    startRaw: int32): int32 =
    var start = startRaw
    if start < 0:
        start = 0
    while start < text.len:
        if !CompilerBridgeIsInlineSpace(text[start]):
            break
        start = start + 1
    return start

fn CompilerBridgeQuoteIsEscaped(text: str,
                                  pos: int32): bool =
    if pos <= 0 || pos > text.len:
        return false
    var slashCount: int32
    let iStart = pos - 1
    if iStart >= 0:
        for iOffset in 0..iStart:
            let i = iStart - iOffset
            if int32(text[i]) != 92:
                break
            slashCount = slashCount + 1
    return (slashCount % 2) != 0

fn CompilerBridgeFindMatchingParen(text: str,
                                     openPos: int32): int32 =
    if openPos < 0 || openPos >= text.len || text[openPos] != '(':
        return -1
    var depth: int32 = 1
    var inString = false
    var inChar = false
    var i = openPos + 1
    for i in i..<text.len:
        let ch = text[i]
        if !inChar && ch == char(34) && !CompilerBridgeQuoteIsEscaped(text, i):
            inString = !inString
            continue
        if !inString && ch == char(39) && !CompilerBridgeQuoteIsEscaped(text, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            depth = depth + 1
        elif ch == ')':
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn CompilerBridgeAppendFmtPiece(out: var str,
                                  pieceCount: var int32,
                                  piece: str) =
    if pieceCount > 0:
        out = Fmt"{out}, "
    out = Fmt"{out}{piece}"
    pieceCount = pieceCount + 1

fn CompilerBridgeFmtQuotedPiece(raw: str): str =
    return Fmt"\"{raw}\""

fn CompilerBridgeRewriteSimplePrefixStringify(lineRaw: str,
                                                dollarPos: int32,
                                                rewrittenOut: var str,
                                                stopExclusiveOut: var int32): bool =
    rewrittenOut = ""
    stopExclusiveOut = dollarPos
    if dollarPos < 0 || dollarPos >= lineRaw.len || lineRaw[dollarPos] != '$':
        return false
    if dollarPos + 1 >= lineRaw.len:
        return false
    let first = lineRaw[dollarPos + 1]
    if first == '(' || !CompilerBridgeIsIdentChar(first):
        return false
    var stop = dollarPos + 1
    while stop < lineRaw.len:
        let ch = lineRaw[stop]
        if CompilerBridgeIsIdentChar(ch) || ch == '.':
            stop = stop + 1
            continue
        break
    let operand = strings.SliceBytes(lineRaw, dollarPos + 1, stop - dollarPos - 1)
    let operandTrimmed = strutil.Strip(operand)
    if len(operandTrimmed) <= 0:
        return false
    rewrittenOut = CompilerConcat3("$(", operand, ")")
    stopExclusiveOut = stop
    return true

fn CompilerBridgeRewriteParenStringify(lineRaw: str,
                                         dollarPos: int32,
                                         rewrittenOut: var str,
                                         stopExclusiveOut: var int32): bool =
    rewrittenOut = ""
    stopExclusiveOut = dollarPos
    if dollarPos < 0 || dollarPos + 1 >= lineRaw.len:
        return false
    if lineRaw[dollarPos] != '$' || lineRaw[dollarPos + 1] != '(':
        return false
    let closePos = CompilerBridgeFindMatchingParen(lineRaw, dollarPos + 1)
    if closePos <= dollarPos + 1:
        return false
    let inner = strings.SliceBytes(lineRaw, dollarPos + 2, closePos - dollarPos - 2)
    rewrittenOut = CompilerConcat3("$(", inner, ")")
    stopExclusiveOut = closePos + 1
    return true

fn CompilerBridgeRewriteFmtLiteral(lineRaw: str,
                                     fmtPos: int32,
                                     rewrittenOut: var str,
                                     stopExclusiveOut: var int32): bool =
    rewrittenOut = ""
    stopExclusiveOut = fmtPos
    if fmtPos < 0 || fmtPos + 3 > lineRaw.len:
        return false
    if strings.SliceBytes(lineRaw, fmtPos, 3) != "Fmt":
        return false
    if fmtPos > 0 && CompilerBridgeIsIdentChar(lineRaw[fmtPos - 1]):
        return false
    if fmtPos + 3 < lineRaw.len && CompilerBridgeIsIdentChar(lineRaw[fmtPos + 3]):
        return false
    let quotePos = CompilerBridgeSkipInlineSpaces(lineRaw, fmtPos + 3)
    if quotePos >= lineRaw.len || lineRaw[quotePos] != char(34):
        return false
    var closePos = quotePos + 1
    while closePos < lineRaw.len:
        if lineRaw[closePos] == char(34) && !CompilerBridgeQuoteIsEscaped(lineRaw, closePos):
            break
        closePos = closePos + 1
    if closePos >= lineRaw.len:
        return false
    let literalRaw = strings.SliceBytes(lineRaw, quotePos + 1, closePos - quotePos - 1)
    var fmtOut = "strutil.Join(["
    var pieceCount: int32
    var currentLiteral = ""
    var i: int32
    while i < literalRaw.len:
        let ch = literalRaw[i]
        if ch == '{':
            if i + 1 < literalRaw.len && literalRaw[i + 1] == '{':
                currentLiteral = Fmt"{currentLiteral}{{"
                i = i + 2
                continue
            if len(currentLiteral) > 0:
                CompilerBridgeAppendFmtPiece(fmtOut,
                                               pieceCount,
                                               CompilerBridgeFmtQuotedPiece(currentLiteral))
                currentLiteral = ""
            var exprStart = i + 1
            var exprEnd = -1
            var inExprString = false
            var inExprChar = false
            var parenDepth: int32
            var bracketDepth: int32
            var braceDepth: int32
            var cursor = exprStart
            for cursor in cursor..<literalRaw.len:
                let exprCh = literalRaw[cursor]
                if !inExprChar && exprCh == char(34) && !CompilerBridgeQuoteIsEscaped(literalRaw, cursor):
                    inExprString = !inExprString
                    continue
                if !inExprString && exprCh == char(39) && !CompilerBridgeQuoteIsEscaped(literalRaw, cursor):
                    inExprChar = !inExprChar
                    continue
                if inExprString || inExprChar:
                    continue
                if exprCh == '(':
                    parenDepth = parenDepth + 1
                    continue
                if exprCh == ')':
                    if parenDepth > 0:
                        parenDepth = parenDepth - 1
                    continue
                if exprCh == '[':
                    bracketDepth = bracketDepth + 1
                    continue
                if exprCh == ']':
                    if bracketDepth > 0:
                        bracketDepth = bracketDepth - 1
                    continue
                if exprCh == '{':
                    braceDepth = braceDepth + 1
                    continue
                if exprCh == '}':
                    if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                        exprEnd = cursor
                        break
                    braceDepth = braceDepth - 1
                    continue
            if exprEnd < exprStart:
                return false
            let exprText = strutil.Strip(strings.SliceBytes(literalRaw, exprStart, exprEnd - exprStart))
            if len(exprText) <= 0:
                return false
            CompilerBridgeAppendFmtPiece(fmtOut,
                                           pieceCount,
                                           CompilerConcat3("$(", exprText, ")"))
            i = exprEnd + 1
            continue
        if ch == '}':
            if i + 1 < literalRaw.len && literalRaw[i + 1] == '}':
                currentLiteral = Fmt"{currentLiteral}}}"
                i = i + 2
                continue
            return false
        currentLiteral = Fmt"{currentLiteral}{strings.CharToStr(ch)}"
        i = i + 1
    if len(currentLiteral) > 0 || pieceCount == 0:
        CompilerBridgeAppendFmtPiece(fmtOut,
                                       pieceCount,
                                       CompilerBridgeFmtQuotedPiece(currentLiteral))
    fmtOut = Fmt"{fmtOut}], \"\")"
    rewrittenOut = fmtOut
    stopExclusiveOut = closePos + 1
    return true

fn CompilerBridgeNextRewriteCandidate(lineRaw: str,
                                        startRaw: int32): int32 =
    var i = startRaw
    if i < 0:
        i = 0
    var inString = false
    var inChar = false
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inString && !inChar:
            if ch == char(35):
                return -1
            if int32(ch) == 96:
                var closePos = i + 1
                while closePos < lineRaw.len:
                    if int32(lineRaw[closePos]) == 96:
                        closePos = closePos + 1
                        break
                    closePos = closePos + 1
                i = closePos
                continue
            if ch == char(70) || ch == char(36):
                return i
            if ch == char(34):
                inString = true
                i = i + 1
                continue
            if int32(ch) == 39:
                inChar = true
                i = i + 1
                continue
            i = i + 1
            continue
        if inString && ch == char(34) && !CompilerBridgeQuoteIsEscaped(lineRaw, i):
            inString = false
        elif inChar && int32(ch) == 39 && !CompilerBridgeQuoteIsEscaped(lineRaw, i):
            inChar = false
        i = i + 1
    return -1

fn CompilerBridgeRewriteLine(lineRaw: str): str =
    var out = ""
    var cursor: int32
    while cursor < lineRaw.len:
        let candidate = CompilerBridgeNextRewriteCandidate(lineRaw, cursor)
        if candidate < 0:
            out = out + strings.SliceBytes(lineRaw, cursor, lineRaw.len - cursor)
            break
        if candidate > cursor:
            out = out + strings.SliceBytes(lineRaw, cursor, candidate - cursor)
        var rewritten = ""
        var stop = candidate
        var didRewrite = false
        if lineRaw[candidate] == char(70):
            didRewrite = CompilerBridgeRewriteFmtLiteral(lineRaw, candidate, rewritten, stop)
        elif lineRaw[candidate] == char(36):
            didRewrite = CompilerBridgeRewriteParenStringify(lineRaw, candidate, rewritten, stop)
            if !didRewrite:
                didRewrite = CompilerBridgeRewriteSimplePrefixStringify(lineRaw, candidate, rewritten, stop)
        if didRewrite:
            out = out + rewritten
            cursor = stop
            continue
        out = out + strings.CharToStr(lineRaw[candidate])
        cursor = candidate + 1
    return out

fn CompilerBridgeRewriteSourceTextChecked(text: str,
                                            rewrittenOut: var str,
                                            err: var str): bool =
    var normalizedText = ""
    if !parser.ParserRewriteMultilineStringSourceText(text, normalizedText, err):
        return false
    var out = ""
    var start: int32
    var i: int32
    for i in i..<= normalizedText.len:
        var atLineEnd = false
        if i == normalizedText.len:
            atLineEnd = true
        elif normalizedText[i] == '\n':
            atLineEnd = true
        if !atLineEnd:
            continue
        let lineRaw = strings.SliceBytes(normalizedText, start, i - start)
        out = out + CompilerBridgeRewriteLine(lineRaw)
        if i < normalizedText.len:
            out = out + "\n"
        start = i + 1
    rewrittenOut = out
    err = ""
    return true

fn CompilerBridgeRewriteSourceText(text: str): str =
    var out = ""
    var err = ""
    if !CompilerBridgeRewriteSourceTextChecked(text, out, err):
        return text
    return out

fn CompilerBridgeSourceNeedsRewrite(text: str): bool =
    if parser.ParserSourceHasMultilineString(text):
        return true
    var out = ""
    var err = ""
    if !CompilerBridgeRewriteSourceTextChecked(text, out, err):
        return true
    return out != text

fn CompilerBridgeCopyTextFile(srcPath: str,
                                destPath: str): bool =
    let parts = os.SplitFile(destPath)
    if len(parts.dir) > 0 && !chengpath.MkdirP(chengpath.PathCurrentDir(), parts.dir):
        return false
    if !chengpath.PathFileExists(srcPath):
        return false
    os.WriteFile(destPath, os.ReadFile(srcPath))
    return chengpath.PathFileExists(destPath)

fn CompilerBridgeCopyTextTree(srcDir: str,
                                destDir: str): bool =
    if !chengpath.MkdirP(chengpath.PathCurrentDir(), destDir):
        return false
    let entries = os.WalkDir(srcDir)
    for i in 0..<entries.len:
        let entry = os.WalkDirEntry(entries, i)
        let child = os.WalkDirEntryPath(entry)
        let kind = os.WalkDirEntryKind(entry)
        let destChild = os.JoinPath(destDir, os.ExtractFilename(child))
        if kind == os.PcDir || kind == os.PcLinkToDir:
            if !CompilerBridgeCopyTextTree(child, destChild):
                return false
        elif kind == os.PcFile || kind == os.PcLinkToFile:
            if !CompilerBridgeCopyTextFile(child, destChild):
                return false
    return true

fn CompilerBridgeStageCopyRequired(rootDir: str,
                                     srcPath: str,
                                     destDir: str,
                                     logRel: str,
                                     context: str): Result[bool] =
    let _logPath = chengpath.PathAbsolute(rootDir, logRel)
    let leaf = os.ExtractFilename(srcPath)
    let destPath = os.JoinPath(destDir, leaf)
    if os.DirExists(srcPath) && CompilerBridgeCopyTextTree(srcPath, destPath):
        return Ok[bool](true)
    if os.FileExists(srcPath) && CompilerBridgeCopyTextFile(srcPath, destPath):
        return Ok[bool](true)
    return Err[bool](strutil.Join([" compiler: ", context, " failed: ", srcPath], ""))

fn CompilerBridgeStageCopyOptional(rootDir: str,
                                     srcPath: str,
                                     destDir: str,
                                     logRel: str,
                                     context: str): Result[bool] =
    if !chengpath.PathFileExists(srcPath):
        return Ok[bool](true)
    return CompilerBridgeStageCopyRequired(rootDir, srcPath, destDir, logRel, context)

fn CompilerBridgeRewriteStagedTree(rootDir: str,
                                     stageRoot: str): Result[bool] =
    if !chengpath.PathDirExists(stageRoot):
        return Err[bool](" compiler: missing bridge surface stage root: " + stageRoot)
    let files = os.WalkDirRec(stageRoot)
    for i in 0..<files.len:
        let path = files[i]
        if !strings.HasSuffix(path, ".cheng"):
            continue
        let sourceText = chengpath.ReadTextFile("", path)
        if len(sourceText) <= 0:
            continue
        var rewritten = ""
        var rewriteErr = ""
        if !CompilerBridgeRewriteSourceTextChecked(sourceText, rewritten, rewriteErr):
            return Err[bool](CompilerConcat3(" compiler: ", rewriteErr, ""))
        if rewritten == sourceText:
            continue
        if !chengpath.WriteTextFile("", path, rewritten):
            return Err[bool](" compiler: failed to rewrite staged source: " + path)
    return Ok[bool](true)

fn CompilerBridgeRequestNeedsSurfaceRewrite(rootDir: str,
                                              req: creq.CompilerRequest): bool =
    var closure: str[]
    var err = ""
    if CompilerAppendOrdinaryClosure(creq.CompilerRequestRootDir(req),
                                       creq.CompilerRequestSourcePath(req),
                                       closure,
                                       err):
        for i in 0..<closure.len:
            let sourceText = chengpath.ReadTextFile("", closure[i])
            if CompilerBridgeSourceNeedsRewrite(sourceText):
                return true
        return false
    let entryText = chengpath.ReadTextFile("", creq.CompilerRequestSourcePath(req))
    return CompilerBridgeSourceNeedsRewrite(entryText)

fn CompilerArgsWithoutPathFlag(args: str[],
                                 flagName: str): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = strutil.Strip(args[i])
        if arg == flagName:
            i = i + 2
            continue
        if strutil.StartsWith(arg, flagName + ":") || strutil.StartsWith(arg, flagName + "="):
            i = i + 1
            continue
        add(out, args[i])
        i = i + 1
    return out

fn CompilerArgsWithBridgeStagedRequest(args: str[],
                                         stagedReq: creq.CompilerRequest): str[] =
    var out = CompilerArgsWithoutPathFlag(args, "--root")
    out = CompilerArgsWithoutPathFlag(out, "--in")
    add(out, "--root:" + creq.CompilerRequestRootDir(stagedReq))
    add(out, "--in:" + creq.CompilerRequestSourcePath(stagedReq))
    return out

fn CompilerBridgeSurfaceStageRequest(rootDir: str,
                                       req: creq.CompilerRequest): Result[creq.CompilerRequest] =
    let stageRoot = chengpath.PathAbsolute(rootDir, CompilerBridgeSurfaceStageRoot())
    if (chengpath.PathDirExists(stageRoot) || chengpath.PathFileExists(stageRoot)) &&
       !CompilerRemovePathTree(stageRoot):
        return Err[creq.CompilerRequest](" compiler: failed to reset bridge surface stage root: " + stageRoot)
    if !chengpath.MkdirP(rootDir, stageRoot):
        return Err[creq.CompilerRequest](" compiler: failed to prepare bridge surface stage root: " + stageRoot)
    let packageRoot = creq.CompilerRequestRootDir(req)
    let compilerEntrySource = creq.CompilerRequestSourcePath(req)
    let packageLeaf = os.ExtractFilename(packageRoot)
    if len(packageLeaf) <= 0:
        return Err[creq.CompilerRequest](" compiler: invalid bridge surface package root: " + packageRoot)
    let stagedPackageRoot = os.JoinPath(stageRoot, packageLeaf)
    let entryRelRaw = os.RelativePath(compilerEntrySource, packageRoot)
    let entryRel = strutil.Strip(entryRelRaw)
    if len(entryRel) <= 0 ||
       entryRel == compilerEntrySource ||
       strutil.StartsWith(entryRel, ".."):
        return Err[creq.CompilerRequest](" compiler: bridge surface entry is outside package root: " +
                                         compilerEntrySource)
    if !chengpath.MkdirP(rootDir, stagedPackageRoot):
        return Err[creq.CompilerRequest](" compiler: failed to prepare bridge surface package root: " +
                                         stagedPackageRoot)
    let manifestCopyRes = CompilerBridgeStageCopyRequired(rootDir,
                                                            os.JoinPath(packageRoot, "cheng-package.toml"),
                                                            stagedPackageRoot,
                                                            "artifacts/backend_driver/bridge_surface.manifest.copy.log",
                                                            "bridge_surface_stage_manifest")
    if IsErr(manifestCopyRes):
        return Err[creq.CompilerRequest](Error(manifestCopyRes))
    let lockCopyRes = CompilerBridgeStageCopyOptional(rootDir,
                                                        os.JoinPath(packageRoot, "cheng.lock.toml"),
                                                        stagedPackageRoot,
                                                        "artifacts/backend_driver/bridge_surface.lock.copy.log",
                                                        "bridge_surface_stage_lock")
    if IsErr(lockCopyRes):
        return Err[creq.CompilerRequest](Error(lockCopyRes))
    let srcCopyRes = CompilerBridgeStageCopyRequired(rootDir,
                                                       os.JoinPath(packageRoot, "src"),
                                                       stagedPackageRoot,
                                                       "artifacts/backend_driver/bridge_surface.src.copy.log",
                                                       "bridge_surface_stage_src")
    if IsErr(srcCopyRes):
        return Err[creq.CompilerRequest](Error(srcCopyRes))
    let workspaceRoot = parser.ParserWorkspaceRoot(packageRoot)
    if workspaceRoot != "" && workspaceRoot != packageRoot:
        let workspaceSrc = os.JoinPath(workspaceRoot, "src")
        if !chengpath.PathDirExists(workspaceSrc):
            return Err[creq.CompilerRequest](" compiler: missing bridge surface shared workspace src: " +
                                             workspaceSrc)
        let workspaceCopyRes = CompilerBridgeStageCopyRequired(rootDir,
                                                                 workspaceSrc,
                                                                 stageRoot,
                                                                 "artifacts/backend_driver/bridge_surface.workspace_src.copy.log",
                                                                 "bridge_surface_stage_workspace_src")
        if IsErr(workspaceCopyRes):
            return Err[creq.CompilerRequest](Error(workspaceCopyRes))
    let rewriteRes = CompilerBridgeRewriteStagedTree(rootDir, stageRoot)
    if IsErr(rewriteRes):
        return Err[creq.CompilerRequest](Error(rewriteRes))
    let stagedEntry = os.JoinPath(stagedPackageRoot, entryRel)
    if !chengpath.PathFileExists(stagedEntry):
        return Err[creq.CompilerRequest](" compiler: missing staged bridge surface entry source: " + stagedEntry)
    let stagedReq0 = creq.CompilerRequestNew(stagedPackageRoot,
                                               stagedEntry,
                                               creq.CompilerRequestOutputPath(req),
                                               creq.CompilerRequestTargetTriple(req),
                                               creq.CompilerRequestEmitKind(req),
                                               req.reportPath)
    let stagedReq1 = creq.CompilerRequestWithSymbolVisibility(stagedReq0,
                                                                creq.CompilerRequestSymbolVisibility(req))
    let stagedReq = creq.CompilerRequestWithBrowserBridgeObject(stagedReq1,
                                                                  creq.CompilerRequestBrowserBridgeObjectPath(req))
    return Ok[creq.CompilerRequest](stagedReq)

fn CompilerWorldBundleSourceSnapshotWrite(rootDir: str,
                                            stagedReq: creq.CompilerRequest,
                                            bundlePrefix: str): Result[bool] =
    var snapshotPackageRoot = ""
    var snapshotEntrySource = ""
    let stageRes = CompilerFollowWorldStageSourceSnapshot(rootDir,
                                                            creq.CompilerRequestRootDir(stagedReq),
                                                            creq.CompilerRequestSourcePath(stagedReq),
                                                            CompilerWorldBundleSourceStageRoot(bundlePrefix),
                                                            snapshotPackageRoot,
                                                            snapshotEntrySource)
    if IsErr(stageRes):
        return Err[bool](Error(stageRes))
    return Ok[bool](true)

fn CompilerWorldBundleSourceSnapshotPaths(rootDir: str,
                                            bundlePrefix: str,
                                            packageRoot: str,
                                            compilerEntrySource: str,
                                            outPackageRoot: var str,
                                            outCompilerEntrySource: var str): Result[bool] =
    let stageRoot = chengpath.PathAbsolute(rootDir, CompilerWorldBundleSourceStageRoot(bundlePrefix))
    if !chengpath.PathDirExists(stageRoot):
        return Err[bool](" compiler: follow-world bundle missing frozen source snapshot: " + stageRoot)
    let packageLeaf = os.ExtractFilename(packageRoot)
    if len(packageLeaf) <= 0:
        return Err[bool](" compiler: invalid follow-world package root: " + packageRoot)
    let entryRelRaw = os.RelativePath(compilerEntrySource, packageRoot)
    let entryRel = strutil.Strip(entryRelRaw)
    if len(entryRel) <= 0 ||
       entryRel == compilerEntrySource ||
       strutil.StartsWith(entryRel, ".."):
        return Err[bool](" compiler: follow-world entry is outside package root: " + compilerEntrySource)
    let snapshotPackageRoot = os.JoinPath(stageRoot, packageLeaf)
    let snapshotEntrySource = os.JoinPath(snapshotPackageRoot, entryRel)
    if !chengpath.PathDirExists(snapshotPackageRoot):
        return Err[bool](" compiler: follow-world bundle missing frozen package root: " + snapshotPackageRoot)
    if !chengpath.PathFileExists(snapshotEntrySource):
        return Err[bool](" compiler: follow-world bundle missing frozen entry source: " + snapshotEntrySource)
    let workspaceRoot = parser.ParserWorkspaceRoot(packageRoot)
    if workspaceRoot != "" && workspaceRoot != packageRoot:
        let snapshotWorkspaceSrc = os.JoinPath(stageRoot, "src")
        if !chengpath.PathDirExists(snapshotWorkspaceSrc):
            return Err[bool](" compiler: follow-world bundle missing frozen shared workspace src: " +
                             snapshotWorkspaceSrc)
    outPackageRoot = snapshotPackageRoot
    outCompilerEntrySource = snapshotEntrySource
    return Ok[bool](true)

fn CompilerFollowWorldInstallBackendDriver(rootDir: str,
                                             packageRoot: str,
                                             compilerEntrySource: str,
                                             targetTriple: str,
                                             requestedWorldHeadHex: str,
                                             lockPath: str,
                                             channel: str,
                                             expectedReceipt: ccsg.CompileReceipt,
                                             enforceExpectedReceipt: bool): Result[CompilerFollowInstallResult] =
    let backendDriverOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
    let backendDriverMapOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.map")
    let backendDriverCandidateOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.follow.next")
    let backendDriverCandidateMapOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng.follow.next.map")
    let backendDriverCandidateBuildOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng_follow_candidate")
    let backendDriverCandidateBuildMapOut = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng_follow_candidate.map")
    let compileReportPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.compile.report.txt")
    let compileLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.compile.log")
    let receiptLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.receipt.log")
    let statusLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.status.txt")
    let verifyLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.verify_world.txt")
    let installLogPath = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/follow_world.install.txt")
    let followMaxRssBytesText: str = CompilerFollowWorldMaxRssBytesText()
    os.SetEnv("CHENG_PROGRESS", "1")
    os.SetEnv("CHENG_PROCESS_MAX_RSS_BYTES", followMaxRssBytesText)
    let followGuardEnv: str[] = [
        "CHENG_NO_BACKEND_DRIVER_HANDOFF=1",
        "CHENG_PROGRESS=1",
        strutil.Join(["CHENG_PROCESS_MAX_RSS_BYTES=", followMaxRssBytesText], ""),
        "BACKEND_INCREMENTAL=0",
        "BACKEND_MULTI_MODULE_CACHE=0",
        "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1",
        "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0",
        "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0"
    ]
    var stagedPackageRoot = packageRoot
    var stagedCompilerEntrySource = compilerEntrySource
    let stageRes = CompilerFollowWorldStageSourceSnapshot(rootDir,
                                                            packageRoot,
                                                            compilerEntrySource,
                                                            "artifacts/backend_driver/follow_world_source",
                                                            stagedPackageRoot,
                                                            stagedCompilerEntrySource)
    if IsErr(stageRes):
        return Err[CompilerFollowInstallResult](Error(stageRes))
    let installReq = creq.CompilerRequestNew(stagedPackageRoot,
                                               stagedCompilerEntrySource,
                                               backendDriverCandidateBuildOut,
                                               targetTriple,
                                               creq.EmitExe,
                                               "")
    var targetReceiptCid = expectedReceipt.receiptCid
    if !enforceExpectedReceipt:
        let installPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                                installReq,
                                                                                requestedWorldHeadHex,
                                                                                lockPath,
                                                                                "",
                                                                                channel)
        if IsErr(installPlanRes):
            return Err[CompilerFollowInstallResult](" compiler: follow-world install plan failed: " + Error(installPlanRes))
        let installPlan = Value(installPlanRes)
        targetReceiptCid = installPlan.compileReceipt.receiptCid
    var currentCompiler = CompilerCurrentExecutablePath(rootDir)
    if len(currentCompiler) > 0 && !chengpath.FileExistsNonEmpty(rootDir, currentCompiler):
        currentCompiler = ""
    if len(currentCompiler) <= 0:
        currentCompiler = CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) <= 0:
        return Err[CompilerFollowInstallResult](" compiler: missing live Cheng bridge for follow-world")
    if chengpath.PathFileExists(backendDriverCandidateBuildOut):
        let _ = os.RemoveFile(backendDriverCandidateBuildOut)
    if chengpath.PathFileExists(backendDriverCandidateBuildMapOut):
        let _ = os.RemoveFile(backendDriverCandidateBuildMapOut)
    if chengpath.PathFileExists(backendDriverCandidateOut):
        let _ = os.RemoveFile(backendDriverCandidateOut)
    if chengpath.PathFileExists(backendDriverCandidateMapOut):
        let _ = os.RemoveFile(backendDriverCandidateMapOut)
    let compileArgs = [
        "system-link-exec",
        "--root:" + stagedPackageRoot,
        "--in:" + stagedCompilerEntrySource,
        "--emit:exe",
        "--target:" + targetTriple,
        "--out:" + backendDriverCandidateBuildOut,
        "--world-head:" + requestedWorldHeadHex,
        "--lock:" + lockPath,
        "--channel:" + channel
    ]
    if !CompilerRunFileEnvLogged(rootDir,
                                   currentCompiler,
                                   compileArgs,
                                   followGuardEnv,
                                   compileLogPath,
                                   "follow-world compile"):
        return Err[CompilerFollowInstallResult](" compiler: follow-world compile failed")
    if chengpath.PathFileExists(compileReportPath):
        let _ = os.RemoveFile(compileReportPath)
    let receiptArgs = [
        "world-receipt",
        "--root:" + stagedPackageRoot,
        "--in:" + stagedCompilerEntrySource,
        "--emit:exe",
        "--target:" + targetTriple,
        "--out:" + backendDriverCandidateBuildOut,
        "--report-out:" + compileReportPath,
        "--world-head:" + requestedWorldHeadHex,
        "--lock:" + lockPath,
        "--channel:" + channel
    ]
    if !CompilerRunFileEnvLogged(rootDir,
                                   currentCompiler,
                                   receiptArgs,
                                   followGuardEnv,
                                   receiptLogPath,
                                   "follow-world receipt"):
        return Err[CompilerFollowInstallResult](" compiler: follow-world receipt failed")
    if !chengpath.PathFileExists(backendDriverCandidateBuildOut):
        return Err[CompilerFollowInstallResult](" compiler: missing follow-world backend driver candidate: " + backendDriverCandidateBuildOut)
    if !chengpath.PathFileExists(backendDriverCandidateBuildMapOut):
        return Err[CompilerFollowInstallResult](" compiler: missing follow-world backend driver candidate map: " + backendDriverCandidateBuildMapOut)
    if !os.RenameFile(backendDriverCandidateBuildMapOut, backendDriverCandidateMapOut):
        return Err[CompilerFollowInstallResult](" compiler: failed to stage follow-world backend driver candidate map: " + backendDriverCandidateMapOut)
    if !os.RenameFile(backendDriverCandidateBuildOut, backendDriverCandidateOut):
        return Err[CompilerFollowInstallResult](" compiler: failed to stage follow-world backend driver candidate output: " + backendDriverCandidateOut)
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverCandidateOut,
                                   ["status"],
                                   followGuardEnv,
                                   statusLogPath,
                                   "follow-world status"):
        return Err[CompilerFollowInstallResult](" compiler: follow-world status failed")
    let verifyArgs = [
        "verify-world",
        "--root:" + stagedPackageRoot,
        "--in:" + stagedCompilerEntrySource,
        "--target:" + targetTriple,
        "--world-head:" + requestedWorldHeadHex,
        "--lock:" + lockPath,
        "--channel:" + channel
    ]
    if !CompilerRunFileEnvLogged(rootDir,
                                   backendDriverCandidateOut,
                                   verifyArgs,
                                   followGuardEnv,
                                   verifyLogPath,
                                   "follow-world verify-world"):
        return Err[CompilerFollowInstallResult](" compiler: follow-world verify-world failed")
    let compileReportText = chengpath.ReadTextFile("", compileReportPath)
    let candidateReceiptHex = cworld.CompilerWorldLineValue(compileReportText, "compile_receipt_cid")
    if len(candidateReceiptHex) <= 0:
        return Err[CompilerFollowInstallResult](" compiler: follow-world missing candidate compile receipt")
    let candidateReceiptRes = layout.FixedBytes32FromHex(candidateReceiptHex)
    if IsErr(candidateReceiptRes):
        return Err[CompilerFollowInstallResult](" compiler: follow-world invalid candidate compile receipt")
    if !layout.FixedBytes32Equal(Value(candidateReceiptRes), targetReceiptCid):
        return Err[CompilerFollowInstallResult](" compiler: follow-world backend driver receipt drift")
    var installReport = ""
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            backendDriverCandidateMapOut,
                                            backendDriverMapOut,
                                            installLogPath,
                                            "map",
                                            installReport):
        return Err[CompilerFollowInstallResult](" compiler: failed to install follow-world backend driver map: " + backendDriverMapOut)
    if !CompilerBootstrapInstallCandidate(rootDir,
                                            backendDriverCandidateOut,
                                            backendDriverOut,
                                            installLogPath,
                                            "binary",
                                            installReport):
        return Err[CompilerFollowInstallResult](" compiler: failed to install follow-world backend driver output: " + backendDriverOut)
    var out: CompilerFollowInstallResult
    out.backendDriverPath = backendDriverOut
    out.targetReceiptCid = targetReceiptCid
    out.candidateReceiptCid = Value(candidateReceiptRes)
    return Ok[CompilerFollowInstallResult](out)

fn CompilerFollowWorldOfflineLockPath(rootDir: str,
                                        bundle: cwbundle.CompilerWorldBundle,
                                        outLockPath: var str): Result[bool] =
    let lockPathRaw = strutil.Strip(cmdline.ReadFlagOrDefault("--lock", ""))
    if len(lockPathRaw) <= 0:
        outLockPath = bundle.bundlePrefix + ".lock.toml"
        return Ok[bool](true)
    let lockRes = cworld.CompilerLockSnapshotRead(rootDir, lockPathRaw)
    if IsErr(lockRes):
        return Err[bool](Error(lockRes))
    let verifyRes = cworld.CompilerWorldVerifyLock(cwbundle.CompilerWorldBundleUniverse(bundle),
                                                     Value(lockRes))
    if IsErr(verifyRes):
        return Err[bool](" compiler: follow-world provided lock mismatches bundle: " + Error(verifyRes))
    outLockPath = chengpath.PathAbsolute(rootDir, lockPathRaw)
    return Ok[bool](true)

fn CompilerFollowWorldOfflineSummary(bundle: cwbundle.CompilerWorldBundle,
                                       managedMirrorCount: int32,
                                       install: CompilerFollowInstallResult,
                                       targetTriple: str): str =
    var out = ""
    out = out + "follow_mode=offline_bundle\n"
    out = out + "bundle_prefix=" + bundle.bundlePrefix + "\n"
    out = out + "channel=" + bundle.worldHead.channel + "\n"
    out = out + "world_head_cid=" + layout.FixedBytes32Hex(bundle.worldHead.headCid) + "\n"
    out = out + "manifest_root_cid=" + layout.FixedBytes32Hex(bundle.manifest.manifestCid) + "\n"
    out = out + "manifest_entry_count=" + IntToStr(bundle.manifest.entryCount) + "\n"
    out = out + "managed_mirror_count=" + IntToStr(managedMirrorCount) + "\n"
    out = out + "receipt_cid=" + layout.FixedBytes32Hex(bundle.receipt.receiptCid) + "\n"
    out = out + "follow_target=" + targetTriple + "\n"
    out = out + "follow_backend_driver=" + install.backendDriverPath + "\n"
    out = out + "follow_target_receipt_cid=" + layout.FixedBytes32Hex(install.targetReceiptCid) + "\n"
    out = out + "follow_candidate_receipt_cid=" + layout.FixedBytes32Hex(install.candidateReceiptCid) + "\n"
    out = out + "follow_candidate_receipt_match=1\n"
    out = out + "follow_candidate_status=ok\n"
    out = out + "follow_candidate_verify_world=ok\n"
    out = out + "follow_install=ok"
    return out

fn CompilerFollowWorldOffline(rootDir: str): int32 =
    let bundlePrefix = strutil.Strip(cmdline.ReadFlagOrDefault("--bundle-prefix", ""))
    if len(bundlePrefix) <= 0:
        CompilerPrintErr(" compiler: missing --bundle-prefix")
        return 2
    var bundle: cwbundle.CompilerWorldBundle
    let bundleRes = cwbundle.CompilerWorldBundleReadAndVerify(rootDir, bundlePrefix, bundle)
    if IsErr(bundleRes):
        CompilerPrintErr(Error(bundleRes))
        return 2
    let requestedChannelRaw = strutil.Strip(cmdline.ReadFlagOrDefault("--channel", ""))
    if len(requestedChannelRaw) > 0:
        let requestedChannelRes = cworld.CompilerWorldNormalizeChannel(requestedChannelRaw)
        if IsErr(requestedChannelRes):
            CompilerPrintErr(Error(requestedChannelRes))
            return 2
        if Value(requestedChannelRes) != bundle.worldHead.channel:
            CompilerPrintErr(" compiler: follow-world bundle channel mismatch")
            return 2
    let worldHeadMatchRes = cworld.CompilerWorldHeadMatchesHex(bundle.worldHead,
                                                                 strutil.Strip(cmdline.ReadFlagOrDefault("--world-head", "")))
    if IsErr(worldHeadMatchRes):
        CompilerPrintErr(Error(worldHeadMatchRes))
        return 2
    var targetTriple = strutil.Strip(cmdline.ReadFlagOrDefault("--target", ""))
    if len(targetTriple) <= 0:
        targetTriple = bundle.receipt.targetTriple
    if len(targetTriple) <= 0:
        CompilerPrintErr(" compiler: follow-world bundle target missing")
        return 2
    if targetTriple != bundle.receipt.targetTriple:
        CompilerPrintErr(" compiler: follow-world bundle target mismatch")
        return 2
    var lockPath = ""
    let lockPathRes = CompilerFollowWorldOfflineLockPath(rootDir, bundle, lockPath)
    if IsErr(lockPathRes):
        CompilerPrintErr(Error(lockPathRes))
        return 2
    let materializeRes = cwlp.CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir,
                                                                                              bundle.bundlePrefix)
    if IsErr(materializeRes):
        CompilerPrintErr(Error(materializeRes))
        return 2
    let livePackageRoot = rootDir
    let liveCompilerEntrySource = buildplan.BackendBuildPlanBackendDriverEntryPath(rootDir)
    var packageRoot = livePackageRoot
    var compilerEntrySource = liveCompilerEntrySource
    let sourcePathsRes = CompilerWorldBundleSourceSnapshotPaths(rootDir,
                                                                  bundle.bundlePrefix,
                                                                  livePackageRoot,
                                                                  liveCompilerEntrySource,
                                                                  packageRoot,
                                                                  compilerEntrySource)
    if IsErr(sourcePathsRes):
        CompilerPrintErr(Error(sourcePathsRes))
        return 2
    let installRes = CompilerFollowWorldInstallBackendDriver(rootDir,
                                                               packageRoot,
                                                               compilerEntrySource,
                                                               targetTriple,
                                                               layout.FixedBytes32Hex(bundle.worldHead.headCid),
                                                               lockPath,
                                                               bundle.worldHead.channel,
                                                               bundle.receipt,
                                                               true)
    if IsErr(installRes):
        CompilerPrintErr(Error(installRes))
        return 2
    let summary = CompilerFollowWorldOfflineSummary(bundle,
                                                      Value(materializeRes),
                                                      Value(installRes),
                                                      targetTriple)
    let reportPath = cmdline.ReadFlagOrDefault("--report-out", "")
    if !CompilerWriteOptionalReport(rootDir, reportPath, summary):
        CompilerPrintErr(" compiler: failed to write report: " + reportPath)
        return 2
    CompilerPrintLine(summary)
    return 0

fn CompilerFollowWorld(rootDir: str,
                         args: str[]): int32 =
    args
    let bundlePrefix = strutil.Strip(cmdline.ReadFlagOrDefault("--bundle-prefix", ""))
    if len(bundlePrefix) > 0:
        return CompilerFollowWorldOffline(rootDir)
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let channel = plan.localUniverse.worldHead.channel
    var proofMode = ""
    let proofModeRes = CompilerProofModeFromRuntimeFlags(channel == "stable", proofMode)
    if IsErr(proofModeRes):
        CompilerPrintErr(Error(proofModeRes))
        return 2
    let proofEnabled = Value(proofModeRes)
    var equivalenceChecked = false
    var migration: ccsg.CompilerLegacyMigration
    var proof: ceq.CompilerEquivalenceProof
    var proofReport = ""
    var migrationReport = ""
    var migrationReceipt: ccsg.CompileReceipt
    if proofEnabled:
        if proofMode == "migration":
            let proofRes = CompilerMigrationProofFromRuntimeFlags(rootDir, req, plan, migration, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
            migrationReceipt = CompilerMigrationReceipt(plan, migration)
            migrationReport = ccsg.CompilerLegacyMigrationReport(migration)
            if !CompilerLegacyArtifactsWrite(rootDir, req.outputPath, migration, migrationReceipt):
                CompilerPrintErr(" compiler migration: failed to write migration artifacts: " + req.outputPath)
                return 2
        else:
            let proofRes = CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.FixedBytes32()
    var publishChannel = ""
    var stableGateRequired = 0
    var equivalenceCheckedFlag = 0
    var equivalencePassed = 0
    var publishAllowed = 0
    var proofCid = layout.FixedBytes32()
    let decisionRes = cpub.CompilerPublishDecisionEvaluate(channel,
                                                             plan.localUniverse.worldHead.headCid,
                                                             equivalenceChecked,
                                                             proof,
                                                             publishChannel,
                                                             stableGateRequired,
                                                             equivalenceCheckedFlag,
                                                             equivalencePassed,
                                                             publishAllowed,
                                                             proofCid)
    if IsErr(decisionRes):
        CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = cpub.CompilerPublishDecisionReport(publishChannel,
                                                              stableGateRequired,
                                                              equivalenceCheckedFlag,
                                                              equivalencePassed,
                                                              publishAllowed,
                                                              plan.localUniverse.worldHead.headCid,
                                                              proofCid)
    if publishAllowed == 0:
        if !CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
            return 2
        CompilerPrintErr(" compiler: publish blocked by canonical equivalence gate")
        CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                CompilerPrintErr(migrationReport)
            CompilerPrintErr(proofReport)
        return 2
    let managedMirrorBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(managedMirrorBundlesRes):
        CompilerPrintErr(Error(managedMirrorBundlesRes))
        return 2
    let managedMirrorBundles = Value(managedMirrorBundlesRes)
    if !CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan, managedMirrorBundles):
        CompilerPrintErr(" compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !chengpath.WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            CompilerPrintErr(" compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    var managedMirrorRoot = ""
    if proofMode == "migration":
        if !CompilerManagedMigrationMirrorWrite(rootDir,
                                                  creq.CompilerRequestRootDir(req),
                                                  channel,
                                                  migration,
                                                  migrationReceipt,
                                                  proof,
                                                  cworld.CompilerLockText(plan.localUniverse),
                                                  managedMirrorRoot):
            CompilerPrintErr(" compiler migration: failed to write managed mirror")
            return 2
    if !chengpath.WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        CompilerPrintErr(" compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    let freshRes = cwlp.CompilerWorldFreshNodeSelfhostReport(rootDir, req, plan)
    if IsErr(freshRes):
        CompilerPrintErr(Error(freshRes))
        return 2
    let freshReport = Value(freshRes)
    if !chengpath.WriteTextFile(rootDir, req.outputPath + ".fresh.txt", freshReport + "\n"):
        CompilerPrintErr(" compiler: failed to write fresh-node report: " + req.outputPath + ".fresh.txt")
        return 2
    let packageRoot = rootDir
    let compilerEntrySource = buildplan.BackendBuildPlanBackendDriverEntryPath(rootDir)
    let targetTriple = req.targetTriple
    let lockPath = req.outputPath + ".lock.toml"
    var emptyReceipt: ccsg.CompileReceipt
    let installRes = CompilerFollowWorldInstallBackendDriver(rootDir,
                                                               packageRoot,
                                                               compilerEntrySource,
                                                               targetTriple,
                                                               layout.FixedBytes32Hex(plan.localUniverse.worldHead.headCid),
                                                               lockPath,
                                                               channel,
                                                               emptyReceipt,
                                                               false)
    if IsErr(installRes):
        CompilerPrintErr(Error(installRes))
        return 2
    let install = Value(installRes)
    var summary = CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           equivalencePassed,
                                           publishAllowed,
                                           proofCid)
    if len(managedMirrorRoot) > 0:
        summary = summary + "\nmanaged_mirror_root=" + managedMirrorRoot
    summary = summary + "\n" + freshReport
    summary = summary + "\nfollow_bundle_prefix=" + req.outputPath
    summary = summary + "\nfollow_target=" + targetTriple
    summary = summary + "\nfollow_backend_driver=" + install.backendDriverPath
    summary = summary + "\nfollow_target_receipt_cid=" + layout.FixedBytes32Hex(install.targetReceiptCid)
    summary = summary + "\nfollow_candidate_receipt_cid=" + layout.FixedBytes32Hex(install.candidateReceiptCid)
    summary = summary + "\nfollow_candidate_receipt_match=1"
    summary = summary + "\nfollow_candidate_status=ok"
    summary = summary + "\nfollow_candidate_verify_world=ok"
    summary = summary + "\nfollow_install=ok"
    if !CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    CompilerPrintLine(summary)
    return 0

fn CompilerSelfhostBuild(rootDir: str,
                           args: str[]): int32 =
    let reqRes = CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let bridgeCompiler = CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return CompilerForwardToBridge(rootDir, bridgeCompiler, "selfhost-build", args)
    if CompilerPlanNeedsBootstrapBridge(plan):
        let bootstrapBridge = CompilerBootstrapBridgePath(rootDir, "selfhost-build")
        if len(bootstrapBridge) > 0:
            var bridgeReport = ""
            if len(req.reportPath) > 0:
                bridgeReport = CompilerSystemLinkExecBridgeMergeReport(plan)
            return CompilerForwardBootstrapBridge(rootDir,
                                                    bootstrapBridge,
                                                    "selfhost-build",
                                                    req,
                                                    args,
                                                    bridgeReport,
                                                    "")
    let summary = CompilerSystemLinkExecSummary(plan)
    if !CompilerWriteSystemLinkExecFullReport(rootDir, req.reportPath, plan):
        CompilerPrintErr(" compiler: failed to write report: " + req.reportPath)
        return 2
    if sexec.SystemLinkExecPlanReady(plan):
        CompilerPrintErr(" compiler: missing live Cheng bridge for selfhost-build")
        CompilerPrintErr(summary)
        return 2
    elif plan.primaryObjectPlan.missingReasons.len > 0:
        CompilerPrintErr(" compiler: selfhost primary object machine code not emitted")
    else:
        CompilerPrintErr(" compiler: selfhost build blocked")
    CompilerPrintErr(summary)
    return 2

fn CompilerTextEndsWith(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn CompilerOutputContains(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn CompilerRequireOutput(run: hostops.LoggedRun,
                           needle: str,
                           label: str): bool =
    if CompilerOutputContains(run.output, needle):
        return true
    CompilerPrintErr(label + ": missing output: " + needle)
    return false

fn CompilerLoggedRunFailed(run: hostops.LoggedRun): bool =
    if hostops.LoggedRunOk(run):
        return false
    CompilerPrintErr(hostops.LoggedRunSummary(run))
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        CompilerPrintErr(outputText)
    return true

fn CompilerEnsureFileParentDir(rootDir: str, path: str): bool =
    let parts = os.SplitFile(path)
    if len(parts.dir) <= 0:
        return true
    return chengpath.MkdirP(rootDir, parts.dir)

fn CompilerBackendDriverPath(rootDir: str): str =
    let snapshot = contracts.BootstrapSnapshotDefault(rootDir)
    return snapshot.backendDriverOut.path

fn CompilerEnsureBackendDriverPath(rootDir: str,
                                     context: str,
                                     outCompiler: var str): bool =
    outCompiler = CompilerBackendDriverPath(rootDir)
    if chengpath.FileExistsNonEmpty(rootDir, outCompiler):
        return true
    if !CompilerEnsureBackendDriver(rootDir, context):
        return false
    return chengpath.FileExistsNonEmpty(rootDir, outCompiler)

fn CompilerCompileTimeoutSec(): int32 =
    return 300

fn CompilerCommandText(filePath: str,
                         argv: str[],
                         envOverrides: str[]): str =
    var parts: str[]
    if envOverrides.len > 0:
        add(parts, "env")
        for i in 0..<envOverrides.len:
            let envText = envOverrides[i]
            if len(envText) > 0:
                add(parts, CompilerQuoteShell(envText))
    if len(filePath) > 0:
        add(parts, CompilerQuoteShell(filePath))
    for i in 0..<argv.len:
        add(parts, CompilerQuoteShell(argv[i]))
    return strutil.Join(parts, " ")

fn CompilerRunCommandCaptureLogged(rootDir: str,
                                     label: str,
                                     filePath: str,
                                     command: str,
                                     logPath: str): hostops.LoggedRun =
    let _ = CompilerEnsureFileParentDir(rootDir, logPath)
    let fullCommand = strutil.Join([command, " > ", CompilerQuoteShell(logPath), " 2>&1"], "")
    let exitCode = os.ExecShellCmdStatus(fullCommand, rootDir)
    let outputText = chengpath.ReadTextFile("", logPath)
    let _logged = chengpath.WriteTextFile(rootDir, logPath, outputText)
    return hostops.LoggedRunZero(label, filePath, logPath, exitCode, outputText)

fn CompilerRunFileLoggedEnv(rootDir: str,
                              label: str,
                              filePath: str,
                              argv: str[],
                              envOverrides: str[],
                              timeoutSec: int32,
                              logPath: str): hostops.LoggedRun =
    let _ = CompilerEnsureFileParentDir(rootDir, logPath)
    let filePathAbs = chengpath.PathAbsolute(rootDir, filePath)
    if !chengpath.FileExistsNonEmpty(rootDir, filePathAbs):
        let missingText = hostops.HostOpsMissingExecutableText(filePathAbs)
        let _logged = chengpath.WriteTextFile(rootDir, logPath, missingText)
        return hostops.LoggedRunZero(label, filePathAbs, logPath, 127, missingText)
    return hostops.RunFileLogged(rootDir,
                                   label,
                                   filePathAbs,
                                   argv,
                                   envOverrides,
                                   rootDir,
                                   timeoutSec,
                                   logPath)

fn CompilerCompileExeEnv(rootDir: str,
                           label: str,
                           compilerPath: str,
                           packageRoot: str,
                           sourcePath: str,
                           outPath: str,
                           target: str,
                           logPath: str,
                           envOverrides: str[]): hostops.LoggedRun =
    let compilerAbs = chengpath.PathAbsolute(rootDir, compilerPath)
    let _ = CompilerEnsureFileParentDir(rootDir, outPath)
    let _ = CompilerEnsureFileParentDir(rootDir, logPath)
    let run = CompilerRunFileLoggedEnv(rootDir,
                                         label,
                                         compilerAbs,
                                         [
                                             "system-link-exec",
                                             "--root", packageRoot,
                                             "--in", sourcePath,
                                             "--emit", "exe",
                                             "--target", target,
                                             "--out", outPath
                                         ],
                                         envOverrides,
                                         CompilerCompileTimeoutSec(),
                                         logPath)
    if hostops.LoggedRunOk(run) && !os.FileExists(outPath):
        let outputText = run.output + " compiler: compile missing output: " + outPath + "\n"
        let _logged = chengpath.WriteTextFile(rootDir, logPath, outputText)
        return hostops.LoggedRunZero(label, compilerAbs, logPath, 1, outputText)
    return run

fn CompilerCompileExe(rootDir: str,
                        label: str,
                        compilerPath: str,
                        packageRoot: str,
                        sourcePath: str,
                        outPath: str,
                        target: str,
                        logPath: str): hostops.LoggedRun =
    return CompilerCompileExeEnv(rootDir,
                                   label,
                                   compilerPath,
                                   packageRoot,
                                   sourcePath,
                                   outPath,
                                   target,
                                   logPath,
                                   [])

fn CompilerProviderSourcesAllPureCheng(paths: str[]): bool =
    if paths.len <= 0:
        return false
    for i in 0..<paths.len:
        if !CompilerTextEndsWith(paths[i], ".cheng"):
            return false
    return true

fn CompilerProviderSourcesContain(paths: str[], expected: str): bool =
    for i in 0..<paths.len:
        if paths[i] == expected:
            return true
    return false

fn CompilerVerifyPureChengProviderPlan(rootDir: str,
                                         packageRoot: str,
                                         sourcePath: str,
                                         outputPath: str,
                                         target: str,
                                         expectedSources: str[]): bool =
    let req = creq.CompilerRequestNew(packageRoot,
                                        sourcePath,
                                        outputPath,
                                        target,
                                        creq.EmitExe,
                                        "")
    let planRes = sexec.BuildSystemLinkExecPlan(rootDir, req)
    if IsErr(planRes):
        CompilerPrintErr(" pure provider plan: " + Error(planRes))
        return false
    let plan = Value(planRes)
    if !CompilerProviderSourcesAllPureCheng(plan.objectPlan.providerSourcePaths):
        CompilerPrintErr(" pure provider plan: non-Cheng provider source detected")
        return false
    for i in 0..<expectedSources.len:
        if !CompilerProviderSourcesContain(plan.objectPlan.providerSourcePaths, expectedSources[i]):
            CompilerPrintErr(" pure provider plan: missing provider source: " + expectedSources[i])
            return false
    return true

fn CompilerHostTarget(): str =
    let detected = contracts.BootstrapDetectHostTarget()
    if detected == "arm64-apple-darwin" ||
       detected == "x86_64-apple-darwin" ||
       detected == "x86_64-unknown-linux-gnu" ||
       detected == "aarch64-unknown-linux-gnu":
        return detected
    return ""

fn CompilerBuildPanicTrace(rootDir: str): int32 =
    var compiler = ""
    if !CompilerEnsureBackendDriverPath(rootDir, "verify-debug-runtime panic", compiler):
        return 1
    let outDir = chengpath.PathAbsolute(rootDir, "artifacts/panic_trace")
    let packageRoot = rootDir
    let src = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_panic_fixture.cheng")
    let outBin = os.JoinPath(outDir, "ordinary_panic_fixture")
    let reportPath = os.JoinPath(outDir, "ordinary_panic_fixture.report.txt")
    let compileRun = CompilerCompileExe(rootDir,
                                          "build_panic_trace",
                                          compiler,
                                          packageRoot,
                                          src,
                                          outBin,
                                          "arm64-apple-darwin",
                                          "artifacts/panic_trace/ordinary_panic_fixture.compile.log")
    if CompilerLoggedRunFailed(compileRun):
        return compileRun.exitCode
    let lineMap = outBin + ".map"
    if !os.FileExists(lineMap):
        CompilerPrintErr(" panic-trace: missing line-map sidecar")
        return 1
    let lineMapText = chengpath.ReadTextFile("", lineMap)
    if !CompilerOutputContains(lineMapText, "cheng_line_map_v1") ||
       !CompilerOutputContains(lineMapText, "ordinary_panic_fixture.cheng"):
        CompilerPrintErr(" panic-trace: invalid line-map")
        return 1
    let run = CompilerRunFileLoggedEnv(rootDir,
                                         "build_panic_trace_run",
                                         outBin,
                                         [],
                                         [],
                                         20,
                                         "artifacts/panic_trace/ordinary_panic_fixture.run.log")
    let runText = strutil.Strip(run.output)
    if len(runText) > 0:
        CompilerPrintLine(runText)
    if run.exitCode == 0:
        CompilerPrintErr(" panic-trace: expected non-zero exit")
        return 1
    let transformRun = CompilerRunFileLoggedEnv(rootDir,
                                                  "build_panic_trace_report",
                                                  compiler,
                                                  [
                                                      "crash-report",
                                                      "--in:" + run.logPath,
                                                      "--out:" + reportPath
                                                  ],
                                                  [],
                                                  20,
                                                  "artifacts/panic_trace/ordinary_panic_fixture.crash-report.log")
    if CompilerLoggedRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        CompilerPrintErr(" panic-trace: missing report")
        return 1
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !CompilerRequireOutput(run, " panic fixture", " panic-trace") ||
       !CompilerRequireOutput(run, "cheng_crash_raw_v1", " panic-trace") ||
       !CompilerRequireOutput(run, "reason=panic mode=backtrace", " panic-trace") ||
       !CompilerRequireOutput(run, "ordinary_panic_fixture.cheng:", " panic-trace") ||
       !CompilerOutputContains(reportText, "[cheng] cheng_crash_report_v1") ||
       !CompilerOutputContains(reportText, "[cheng] reason=panic mode=backtrace") ||
       !CompilerOutputContains(reportText, "ordinary_panic_fixture.cheng:"):
        return 1
    CompilerPrintLine(strutil.Strip(reportText))
    return 0

fn CompilerBuildBoundsTrace(rootDir: str): int32 =
    var compiler = ""
    if !CompilerEnsureBackendDriverPath(rootDir, "verify-debug-runtime bounds", compiler):
        return 1
    let outDir = chengpath.PathAbsolute(rootDir, "artifacts/bounds_trace")
    let packageRoot = rootDir
    let src = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_bounds_trace_fixture.cheng")
    let outBin = os.JoinPath(outDir, "ordinary_bounds_trace_fixture")
    let reportPath = os.JoinPath(outDir, "ordinary_bounds_trace_fixture.report.txt")
    let compileRun = CompilerCompileExe(rootDir,
                                          "build_bounds_trace",
                                          compiler,
                                          packageRoot,
                                          src,
                                          outBin,
                                          "arm64-apple-darwin",
                                          "artifacts/bounds_trace/ordinary_bounds_trace_fixture.compile.log")
    if CompilerLoggedRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin + ".map"):
        CompilerPrintErr(" bounds-trace: missing line-map sidecar")
        return 1
    let run = CompilerRunFileLoggedEnv(rootDir,
                                         "build_bounds_trace_run",
                                         outBin,
                                         [],
                                         [],
                                         20,
                                         "artifacts/bounds_trace/ordinary_bounds_trace_fixture.run.log")
    let runText = strutil.Strip(run.output)
    if len(runText) > 0:
        CompilerPrintLine(runText)
    if run.exitCode == 0:
        CompilerPrintErr(" bounds-trace: expected non-zero exit")
        return 1
    let transformRun = CompilerRunFileLoggedEnv(rootDir,
                                                  "build_bounds_trace_report",
                                                  compiler,
                                                  [
                                                      "crash-report",
                                                      "--in:" + run.logPath,
                                                      "--out:" + reportPath
                                                  ],
                                                  [],
                                                  20,
                                                  "artifacts/bounds_trace/ordinary_bounds_trace_fixture.crash-report.log")
    if CompilerLoggedRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        CompilerPrintErr(" bounds-trace: missing report")
        return 1
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !CompilerRequireOutput(run, "bounds check failed", " bounds-trace") ||
       !CompilerRequireOutput(run, "cheng_crash_raw_v1", " bounds-trace") ||
       !CompilerRequireOutput(run, "reason=bounds mode=backtrace", " bounds-trace") ||
       !CompilerRequireOutput(run, "ordinary_bounds_trace_fixture.cheng:", " bounds-trace") ||
       !CompilerOutputContains(reportText, "[cheng] cheng_crash_report_v1") ||
       !CompilerOutputContains(reportText, "[cheng] reason=bounds mode=backtrace") ||
       !CompilerOutputContains(reportText, "ordinary_bounds_trace_fixture.cheng:"):
        return 1
    CompilerPrintLine(strutil.Strip(reportText))
    return 0

fn CompilerBuildSignalTrace(rootDir: str): int32 =
    var compiler = ""
    if !CompilerEnsureBackendDriverPath(rootDir, "verify-debug-runtime signal", compiler):
        return 1
    let outDir = chengpath.PathAbsolute(rootDir, "artifacts/signal_trace")
    let packageRoot = rootDir
    let src = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_signal_trace_fixture.cheng")
    let outBin = os.JoinPath(outDir, "ordinary_signal_trace_fixture")
    let reportPath = os.JoinPath(outDir, "ordinary_signal_trace_fixture.report.txt")
    let compileRun = CompilerCompileExe(rootDir,
                                          "build_signal_trace",
                                          compiler,
                                          packageRoot,
                                          src,
                                          outBin,
                                          "arm64-apple-darwin",
                                          "artifacts/signal_trace/ordinary_signal_trace_fixture.compile.log")
    if CompilerLoggedRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin + ".map"):
        CompilerPrintErr(" signal-trace: missing line-map sidecar")
        return 1
    let run = CompilerRunFileLoggedEnv(rootDir,
                                         "build_signal_trace_run",
                                         outBin,
                                         [],
                                         [],
                                         20,
                                         "artifacts/signal_trace/ordinary_signal_trace_fixture.run.log")
    let runText = strutil.Strip(run.output)
    if len(runText) > 0:
        CompilerPrintLine(runText)
    if run.exitCode == 0:
        CompilerPrintErr(" signal-trace: expected non-zero exit")
        return 1
    let transformRun = CompilerRunFileLoggedEnv(rootDir,
                                                  "build_signal_trace_report",
                                                  compiler,
                                                  [
                                                      "crash-report",
                                                      "--in:" + run.logPath,
                                                      "--out:" + reportPath
                                                  ],
                                                  [],
                                                  20,
                                                  "artifacts/signal_trace/ordinary_signal_trace_fixture.crash-report.log")
    if CompilerLoggedRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        CompilerPrintErr(" signal-trace: missing report")
        return 1
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !CompilerRequireOutput(run, "cheng_crash_raw_v1", " signal-trace") ||
       !CompilerRequireOutput(run, "reason=signal mode=signal", " signal-trace") ||
       !CompilerRequireOutput(run, "ordinary_signal_trace_fixture.cheng:", " signal-trace") ||
       !CompilerOutputContains(reportText, "[cheng] cheng_crash_report_v1") ||
       !CompilerOutputContains(reportText, "[cheng] reason=signal mode=signal") ||
       !CompilerOutputContains(reportText, "ordinary_signal_trace_fixture.cheng:"):
        return 1
    CompilerPrintLine(strutil.Strip(reportText))
    return 0

fn CompilerVerifyDebugRuntime(rootDir: str): int32 =
    let hostTarget = CompilerHostTarget()
    if len(hostTarget) <= 0:
        CompilerPrintErr(" debug runtime: unsupported host target")
        return 1
    let packageRoot = rootDir
    let ordinarySource = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_panic_fixture.cheng")
    let toolingSource = chengpath.PathAbsolute(rootDir, "src/core/tooling/compiler_main.cheng")
    let ordinaryOutput = chengpath.PathAbsolute(rootDir, "artifacts/debug_runtime_verify/provider_plan_ordinary")
    let toolingOutput = chengpath.PathAbsolute(rootDir, "artifacts/debug_runtime_verify/provider_plan_tooling")
    var expectedCoreSource = ""
    if hostTarget == "arm64-apple-darwin" || hostTarget == "x86_64-apple-darwin":
        expectedCoreSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_darwin.cheng")
    else:
        expectedCoreSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/core_runtime_provider_linux.cheng")
    let expectedDebugSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/debug_runtime_stub.cheng")
    let expectedProgramSupportSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_backend.cheng")
    let expectedProgramSupportGetEnvSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_get_env_bridge.cheng")
    let expectedProgramSupportHostSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/program_support_host_runtime.cheng")
    let expectedProgramArgvSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_program_entry_provider.cheng")
    let expectedToolingArgvSource = chengpath.PathAbsolute(rootDir, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng")
    var ordinarySources: str[]
    add(ordinarySources, expectedProgramArgvSource)
    add(ordinarySources, expectedCoreSource)
    add(ordinarySources, expectedDebugSource)
    add(ordinarySources, expectedProgramSupportSource)
    add(ordinarySources, expectedProgramSupportGetEnvSource)
    add(ordinarySources, expectedProgramSupportHostSource)
    if !CompilerVerifyPureChengProviderPlan(rootDir,
                                              packageRoot,
                                              ordinarySource,
                                              ordinaryOutput,
                                              hostTarget,
                                              ordinarySources):
        return 1
    var toolingSources: str[]
    add(toolingSources, expectedToolingArgvSource)
    add(toolingSources, expectedCoreSource)
    add(toolingSources, expectedDebugSource)
    add(toolingSources, expectedProgramSupportSource)
    add(toolingSources, expectedProgramSupportGetEnvSource)
    add(toolingSources, expectedProgramSupportHostSource)
    if !CompilerVerifyPureChengProviderPlan(rootDir,
                                              packageRoot,
                                              toolingSource,
                                              toolingOutput,
                                              hostTarget,
                                              toolingSources):
        return 1
    if CompilerBuildPanicTrace(rootDir) != 0:
        return 1
    if CompilerBuildBoundsTrace(rootDir) != 0:
        return 1
    if CompilerBuildSignalTrace(rootDir) != 0:
        return 1
    CompilerPrintLine(" debug runtime: ok")
    return 0

