import cheng/core/tooling/path as chengpath
import cheng/core/runtime/provider_root as provroot
import cheng/core/runtime/handle_table as htable

type
    ProgramSupportContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str

fn ProgramSupportProviderSourcePath(rootDir: str): str =
    return provroot.RuntimeProviderPath(rootDir, "src/core/runtime/program_support_backend.cheng")

fn ProgramSupportGetEnvProviderSourcePath(rootDir: str): str =
    return provroot.RuntimeProviderPath(rootDir, "src/core/runtime/program_support_get_env_bridge.cheng")

fn ProgramSupportHostProviderSourcePath(rootDir: str): str =
    return provroot.RuntimeProviderPath(rootDir, "src/core/runtime/program_support_host_runtime.cheng")

fn ProgramSupportContract(rootDir: str): ProgramSupportContract =
    var out: ProgramSupportContract
    out.version = "cheng.runtime.program_support.v1"
    out.services = ["ffi.handle.i32"]
    out.providerNativeSources = [
        ProgramSupportProviderSourcePath(rootDir)
    ]
    out.executionModel = "pure_cheng_runtime_provider"
    out.traceSymbol = "cheng_ffi_handle_register_ptr"
    return out

fn ProgramSupportTargets(): str[] =
    return ["ffi.handle.i32"]

fn FfiHandleNewI32(value: int32): uint64 =
    return htable.handle_table_new_i32(value)

fn FfiHandleGetI32(handle: uint64): int32 =
    var out: int32
    let rc: int32 = htable.handle_table_get_i32(handle, out)
    if rc != 0:
        return rc
    return out

fn FfiHandleAddI32(handle: uint64, delta: int32): int32 =
    var out: int32
    let rc: int32 = htable.handle_table_add_i32(handle, delta, out)
    if rc != 0:
        return rc
    return out

fn FfiHandleReleaseI32(handle: uint64): int32 =
    return htable.handle_table_release_i32(handle)
