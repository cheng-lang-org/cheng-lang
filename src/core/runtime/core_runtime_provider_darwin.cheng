const
    chengStrFlagOwned: int32 = 1
    cheng_sc_nprocessors_onln: int32 = 58
    cheng_proc_pidtaskinfo: int32 = 4
    cheng_proc_all_pids: int32 = 1

type
    str =
        data: ptr
        len: int32
        store_id: int32
        flags: int32
    ChengDarwinStatfs =
        fBsize: uint32
        fIosize: int32
        fBlocks: uint64
        fBfree: uint64
        fBavail: uint64
        fFiles: uint64
        fFfree: uint64
        fFsid0: int32
        fFsid1: int32
        fOwner: uint32
        fType: uint32
        fFlags: uint32
        fFssubtype: uint32
        fFstypename: uint8[16]
        fMntonname: uint8[1024]
        fMntfromname: uint8[1024]
        fReserved: uint32[8]
    ChengDarwinProcTaskinfo =
        ptiVirtualSize: uint64
        ptiResidentSize: uint64
        ptiTotalUser: uint64
        ptiTotalSystem: uint64
        ptiThreadsUser: uint64
        ptiThreadsSystem: uint64
        ptiPolicy: int32
        ptiFaults: int32
        ptiPageins: int32
        ptiCowFaults: int32
        ptiMessagesSent: int32
        ptiMessagesReceived: int32
        ptiSyscallsMach: int32
        ptiSyscallsUnix: int32
        ptiCsw: int32
        ptiThreadnum: int32
        ptiNumrunning: int32
        ptiPriority: int32
    UInt8Ptr = uint8 *
    Int32Ptr = int32 *
    UInt64Ptr = uint64 *
    ChengDarwinThreadTask =
        fnPtr: ptr
        ctx: ptr
    ChengDarwinThreadTaskPtr = ChengDarwinThreadTask *

fn cheng_ptr_plus(base: ptr, off: int32): ptr =
    if base == nil:
        return nil
    return ptr(uint64(base) + uint64(off))

fn cheng_bytes_copy(dst: ptr, src: ptr, n0: int32) =
    if dst == nil || src == nil || n0 <= 0:
        return
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = *(UInt8Ptr(cheng_ptr_plus(src, i)))

fn cheng_bytes_set(dst: ptr, value: int32, n0: int32) =
    if dst == nil || n0 <= 0:
        return
    let v: uint8 = uint8(value & 255)
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = v

fn cheng_cstrlen_raw(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32
    while *(UInt8Ptr(cheng_ptr_plus(s, n))) != uint8(0):
        n = n + 1
    return n

fn cheng_string_copy(raw: ptr, n0: int32): ptr =
    var n: int32 = n0
    if n < 0:
        n = 0
    let out: ptr = cheng_runtime_malloc(n + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, n + 1)
    if raw != nil && n > 0:
        cheng_bytes_copy(out, raw, n)
    return out

fn cheng_str_empty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_str_view_owned(data: ptr, len0: int32): str =
    var out: str
    if data == nil || len0 <= 0:
        return out
    out.data = data
    out.len = len0
    out.store_id = 0
    out.flags = chengStrFlagOwned
    return out

fn cheng_str_copy(raw: ptr, n: int32): str =
    let outRaw: ptr = cheng_string_copy(raw, n)
    if outRaw == nil:
        return cheng_str_empty()
    return cheng_str_view_owned(outRaw, n)

fn cheng_str_copy_cstring(raw: ptr): str =
    return cheng_str_copy(raw, cheng_cstrlen_raw(raw))

fn cheng_sysctl_u64(name: ptr): int64 =
    var value: uint64 = uint64(0)
    var size: uint64 = uint64(sizeof(uint64))
    if libc_sysctlbyname(name, &value, &size, nil, uint64(0)) != 0:
        return 0
    if value > uint64(9223372036854775807):
        return 0
    return int64(value)

fn cheng_u64_mul_checked(left: uint64, right: uint64): int64 =
    if left == uint64(0) || right == uint64(0):
        return int64(0)
    let product: uint64 = left * right
    if product / right != left:
        return int64(0)
    if product > uint64(9223372036854775807):
        return int64(0)
    return int64(product)

fn cheng_u64_add_i64_checked(total: var uint64, value: int64): bool =
    if value <= 0:
        return true
    let addend: uint64 = uint64(value)
    if total > uint64(9223372036854775807) - addend:
        return false
    total = total + addend
    return true

fn cheng_darwin_process_rss_bytes(pid: int64): int64 =
    if pid <= 0 || pid > int64(2147483647):
        return 0
    var info: ChengDarwinProcTaskinfo
    let expectedSize: int32 = int32(sizeof(ChengDarwinProcTaskinfo))
    let rc: int32 = libc_proc_pidinfo(int32(pid),
                                      cheng_proc_pidtaskinfo,
                                      uint64(0),
                                      &info,
                                      expectedSize)
    if rc != expectedSize:
        return 0
    if info.ptiResidentSize > uint64(9223372036854775807):
        return 0
    return int64(info.ptiResidentSize)

fn cheng_root_path_cstr(): ptr =
    return cheng_string_copy("/", 1)

fn cheng_sysctl_hw_pagesize_value(): int64 =
    return cheng_sysctl_u64("hw.pagesize")

fn cheng_sysctl_vm_page_free_count_value(): int64 =
    return cheng_sysctl_u64("vm.page_free_count")

fn cheng_sysctl_vm_page_speculative_count_value(): int64 =
    return cheng_sysctl_u64("vm.page_speculative_count")

@exportc("core_runtime_stub_trace")
fn core_runtime_stub_trace_export(): int32 =
    let wrote: int32 = libc_write(2, " core runtime trace\n", 22)
    if wrote <= 0:
        return 0
    return wrote

