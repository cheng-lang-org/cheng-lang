@exportc("cheng_native_system_memory_available_bytes_value_bridge")
fn cheng_native_system_memory_available_bytes_value_bridge_export(): int64 =
    let pageSize: int64 = cheng_sysctl_hw_pagesize_value()
    let freePages: int64 = cheng_sysctl_vm_page_free_count_value()
    let speculativePages: int64 = cheng_sysctl_vm_page_speculative_count_value()
    if pageSize <= 0:
        return 0
    if freePages < 0 || speculativePages < 0:
        return 0
    return cheng_u64_mul_checked(uint64(freePages + speculativePages), uint64(pageSize))

@exportc("cheng_native_process_rss_bytes_value_bridge")
fn cheng_native_process_rss_bytes_value_bridge_export(pid: int64): int64 =
    return cheng_darwin_process_rss_bytes(pid)

@exportc("cheng_native_process_group_rss_bytes_value_bridge")
fn cheng_native_process_group_rss_bytes_value_bridge_export(pgid: int64): int64 =
    if pgid <= 0 || pgid > int64(2147483647):
        return 0
    var cap: int32 = libc_proc_listpids(cheng_proc_all_pids, uint32(0), nil, 0)
    if cap <= 0:
        return 0
    cap = cap + 4096
    var attempts: int32
    while attempts < 4 && cap > 0:
        let buf: ptr = cheng_runtime_malloc(cap)
        if buf == nil:
            return 0
        let got: int32 = libc_proc_listpids(cheng_proc_all_pids, uint32(0), buf, cap)
        if got > 0 && got < cap:
            var total: uint64
            var any = false
            let count: int32 = got / int32(sizeof(int32))
            for i in 0..<count:
                let pid: int32 = *(Int32Ptr(cheng_ptr_plus(buf, i * int32(sizeof(int32)))))
                if pid <= 0:
                    continue
                if libc_getpgid(pid) != int32(pgid):
                    continue
                let rss: int64 = cheng_darwin_process_rss_bytes(int64(pid))
                if rss > 0:
                    if !cheng_u64_add_i64_checked(total, rss):
                        cheng_runtime_free(buf)
                        return 0
                    any = true
            cheng_runtime_free(buf)
            if !any:
                return 0
            return int64(total)
        cheng_runtime_free(buf)
        if cap > 8388608:
            return 0
        cap = cap * 2
        attempts = attempts + 1
    return 0

@exportc("cheng_native_system_disk_total_bytes_value_bridge")
fn cheng_native_system_disk_total_bytes_value_bridge_export(): int64 =
    let rootPath: ptr = cheng_root_path_cstr()
    if rootPath == nil:
        return 0
    var fs: ChengDarwinStatfs
    let rc: int32 = libc_statfs(rootPath, &fs)
    cheng_runtime_free(rootPath)
    if rc != 0:
        return 0
    if fs.fBsize == uint32(0):
        return 0
    return cheng_u64_mul_checked(fs.fBlocks, uint64(fs.fBsize))

@exportc("cheng_native_system_disk_available_bytes_value_bridge")
fn cheng_native_system_disk_available_bytes_value_bridge_export(): int64 =
    let rootPath: ptr = cheng_root_path_cstr()
    if rootPath == nil:
        return 0
    var fs: ChengDarwinStatfs
    let rc: int32 = libc_statfs(rootPath, &fs)
    cheng_runtime_free(rootPath)
    if rc != 0:
        return 0
    if fs.fBsize == uint32(0):
        return 0
    return cheng_u64_mul_checked(fs.fBavail, uint64(fs.fBsize))

@exportc("cheng_mobile_biometric_fingerprint_authorize_bridge_native")
fn cheng_mobile_biometric_fingerprint_authorize_bridge_native_export(requestWire: str): str =
    let _ = requestWire
    return cheng_str_copy_cstring("ok=0\nfeature32_hex=\ndevice_binding_seed_hex=\ndevice_label_hex=\nsensor_id_hex=\nhardware_attestation_hex=\nerror_hex=76332062696f6d65747269633a206d6f62696c6520686f737420627269646765206d697373696e67\n")

fn cheng_darwin_thread_entry(raw: ptr): ptr =
    if raw == nil:
        return nil
    let task: ChengDarwinThreadTaskPtr = ChengDarwinThreadTaskPtr(raw)
    let fnPtr: ptr = task->fnPtr
    let ctx: ptr = task->ctx
    cheng_runtime_free(raw)
    if fnPtr != nil:
        cheng_darwin_call_indirect_void(fnPtr, ctx)
    return nil

@exportc("cheng_darwin_thread_spawn")
fn cheng_darwin_thread_spawn_export(fnPtr: ptr, ctx: ptr): int32 =
    if fnPtr == nil:
        return 0
    let mem: ptr = cheng_runtime_malloc(int32(sizeof(ChengDarwinThreadTask)))
    if mem == nil:
        return 0
    let task: ChengDarwinThreadTaskPtr = ChengDarwinThreadTaskPtr(mem)
    task->fnPtr = fnPtr
    task->ctx = ctx
    var thread: ptr
    let rc = cheng_darwin_pthread_create(ptr(&thread), nil, &cheng_darwin_thread_entry, mem)
    if rc != 0:
        cheng_runtime_free(mem)
        return 0
    if cheng_darwin_pthread_detach(thread) != 0:
        cheng_runtime_free(mem)
        return 0
    return 1
