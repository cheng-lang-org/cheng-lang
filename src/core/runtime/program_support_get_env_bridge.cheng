@importc("cheng_str_to_cstring_temp_bridge")
fn cheng_str_to_cstring_temp_bridge_runtime(text: str): cstring

@importc("cheng_host_getenv")
fn cheng_host_getenv_runtime(name: cstring): cstring

@importc("cheng_cstrlen")
fn cheng_cstrlen_runtime(text: cstring): int32

@importc("driver_c_str_from_utf8_copy_bridge")
fn driver_c_str_from_utf8_copy_bridge_runtime(raw: cstring, count: int32): str

@exportc("driver_c_get_env_bridge")
fn driver_c_get_env_bridge_export(key: str): str =
    let keyRaw: cstring = cheng_str_to_cstring_temp_bridge_runtime(key)
    let raw: cstring = cheng_host_getenv_runtime(keyRaw)
    let count: int32 = cheng_cstrlen_runtime(raw)
    return driver_c_str_from_utf8_copy_bridge_runtime(raw, count)
