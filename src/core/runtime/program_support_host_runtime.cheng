@exportc("cheng_host_list_dir")
fn cheng_host_list_dir_export(path: ptr): ptr =
    let emptyOut: ptr = raw_libc_malloc(1)
    if emptyOut != nil:
        *(UInt8Ptr(emptyOut)) = uint8(0)
    if path == nil || *UInt8Ptr(path) == uint8(0):
        return emptyOut
    let dir: ptr = raw_libc_opendir(path)
    if dir == nil:
        return emptyOut
    var cap: int32 = 256
    var lenOut: int32
    var out: ptr = raw_libc_malloc(cap)
    if out == nil:
        raw_libc_closedir(dir)
        return nil
    *(UInt8Ptr(out)) = uint8(0)
    if emptyOut != nil:
        raw_libc_free(emptyOut)
    while true:
        let entRaw: ptr = raw_libc_readdir(dir)
        if entRaw == nil:
            break
        let ent: DarwinDirentPtr = DarwinDirentPtr(entRaw)
        let nameLen: int32 = int32(ent->d_namlen)
        if nameLen <= 0:
            continue
        let namePtr: ptr = cheng_host_ptr_plus(entRaw, chengHostDirentNameOff)
        if nameLen == 1 && *UInt8Ptr(namePtr) == uint8(46):
            continue
        if nameLen == 2 &&
           *UInt8Ptr(namePtr) == uint8(46) &&
           *UInt8Ptr(cheng_host_ptr_plus(namePtr, 1)) == uint8(46):
            continue
        var need: int32 = lenOut + nameLen + 2
        if need > cap:
            var newCap: int32 = cap
            while newCap < need:
                newCap = newCap * 2
            let next: ptr = raw_libc_realloc(out, newCap)
            if next == nil:
                break
            out = next
            cap = newCap
        cheng_host_bytes_copy(cheng_host_ptr_plus(out, lenOut), namePtr, nameLen)
        lenOut = lenOut + nameLen
        *(UInt8Ptr(cheng_host_ptr_plus(out, lenOut))) = uint8(10)
        lenOut = lenOut + 1
        *(UInt8Ptr(cheng_host_ptr_plus(out, lenOut))) = uint8(0)
    raw_libc_closedir(dir)
    return out

