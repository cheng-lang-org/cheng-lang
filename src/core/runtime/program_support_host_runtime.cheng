const
    chengHostStdInFd: int32 = 0
    chengHostStdOutFd: int32 = 1
    chengHostStdErrFd: int32 = 2

type
    Int32Ptr = int32 *
    UInt8Ptr = uint8 *
    VoidPtrPtr = ptr *
    HostEnt =
        h_name: ptr
        h_aliases: ptr
        h_addrtype: int32
        h_length: int32
        h_addr_list: ptr
    HostEntPtr = HostEnt *
    DarwinDirent =
        d_ino: uint64
        d_seekoff: uint64
        d_reclen: uint16
        d_namlen: uint16
        d_type: uint8
    DarwinDirentPtr = DarwinDirent *

const
    chengHostDirentNameOff: int32 = 21
    chengHostSockaddrInLen: int32 = 16
    chengHostSockaddrIn6Len: int32 = 28
    chengHostSockStream: int32 = 1

fn cheng_host_ptr_plus(base: ptr, off: int32): ptr =
    if base == nil:
        return nil
    return ptr(uint64(int64(uint64(base)) + int64(off)))

fn cheng_host_bytes_copy(dst: ptr, src: ptr, n0: int32) =
    if dst == nil || src == nil || n0 <= 0:
        return
    for i in 0..<n0:
        *(UInt8Ptr(cheng_host_ptr_plus(dst, i))) = *(UInt8Ptr(cheng_host_ptr_plus(src, i)))

fn cheng_host_bytes_set(dst: ptr, value: int32, n0: int32) =
    if dst == nil || n0 <= 0:
        return
    let byteValue: uint8 = uint8(value & 255)
    for i in 0..<n0:
        *(UInt8Ptr(cheng_host_ptr_plus(dst, i))) = byteValue

fn cheng_host_fd_at(fds: ptr, idx: int32): int32 =
    if fds == nil:
        return -1
    return *(Int32Ptr(cheng_host_ptr_plus(fds, idx * int32(sizeof(int32)))))

fn cheng_host_close_fd_if_valid(fd: int32) =
    if fd >= 0:
        let ignoredClose = raw_libc_close(fd)

fn cheng_host_af_inet(): int32 =
    return raw_native_af_inet_bridge()

fn cheng_host_af_inet6(): int32 =
    return raw_native_af_inet6_bridge()

fn cheng_host_sockaddr_use_len_field(): bool =
    return raw_native_sockaddr_use_len_field_bridge() != 0

fn cheng_host_copy_cstring_from_str(text: str): ptr =
    let n: int32 = len(text)
    let out: ptr = raw_libc_malloc(int64(n + 1))
    if out == nil:
        return nil
    cheng_host_bytes_set(out, 0, n + 1)
    for i in 0..<n:
        *(UInt8Ptr(cheng_host_ptr_plus(out, i))) = uint8(int32(text[i]) & 255)
    return out

fn cheng_host_sockaddr_ipv4_from_raw(port: int32, rawAddr: ptr): ptr =
    let addr = raw_libc_malloc(chengHostSockaddrInLen)
    if addr == nil:
        return nil
    cheng_host_bytes_set(addr, 0, chengHostSockaddrInLen)
    let family = cheng_host_af_inet()
    if cheng_host_sockaddr_use_len_field():
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 0))) = uint8(chengHostSockaddrInLen)
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 1))) = uint8(family & 255)
    else:
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 0))) = uint8(family & 255)
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 1))) = uint8((family >> 8) & 255)
    *(UInt8Ptr(cheng_host_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_host_ptr_plus(addr, 3))) = uint8(port & 255)
    if rawAddr != nil:
        cheng_host_bytes_copy(cheng_host_ptr_plus(addr, 4), rawAddr, 4)
    return addr

fn cheng_host_sockaddr_ipv6_from_raw(port: int32, rawAddr: ptr): ptr =
    let addr = raw_libc_malloc(chengHostSockaddrIn6Len)
    if addr == nil:
        return nil
    cheng_host_bytes_set(addr, 0, chengHostSockaddrIn6Len)
    let family = cheng_host_af_inet6()
    if cheng_host_sockaddr_use_len_field():
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 0))) = uint8(chengHostSockaddrIn6Len)
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 1))) = uint8(family & 255)
    else:
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 0))) = uint8(family & 255)
        *(UInt8Ptr(cheng_host_ptr_plus(addr, 1))) = uint8((family >> 8) & 255)
    *(UInt8Ptr(cheng_host_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_host_ptr_plus(addr, 3))) = uint8(port & 255)
    if rawAddr != nil:
        cheng_host_bytes_copy(cheng_host_ptr_plus(addr, 8), rawAddr, 16)
    return addr

fn cheng_host_tcp_connect_first_resolved(entry: HostEntPtr, port: int32): int32 =
    if entry == nil || entry->h_addr_list == nil:
        return -1
    let family: int32 = entry->h_addrtype
    let rawLen: int32 = entry->h_length
    var idx: int32
    while true:
        let slot: ptr = cheng_host_ptr_plus(entry->h_addr_list, idx * int32(sizeof(ptr)))
        if slot == nil:
            return -1
        let rawAddr: ptr = *(VoidPtrPtr(slot))
        if rawAddr == nil:
            return -1
        var sockaddrLen: int32
        var sockaddrRaw: ptr = nil
        if family == cheng_host_af_inet() && rawLen >= 4:
            sockaddrRaw = cheng_host_sockaddr_ipv4_from_raw(port, rawAddr)
            sockaddrLen = chengHostSockaddrInLen
        elif family == cheng_host_af_inet6() && rawLen >= 16:
            sockaddrRaw = cheng_host_sockaddr_ipv6_from_raw(port, rawAddr)
            sockaddrLen = chengHostSockaddrIn6Len
        if sockaddrRaw != nil:
            let fd: int32 = raw_libc_socket(family, chengHostSockStream, 0)
            if fd >= 0:
                if raw_libc_connect(fd, sockaddrRaw, sockaddrLen) == 0:
                    raw_libc_free(sockaddrRaw)
                    return fd
                cheng_host_close_fd_if_valid(fd)
            raw_libc_free(sockaddrRaw)
        idx = idx + 1
    return -1

