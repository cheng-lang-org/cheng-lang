fn cheng_host_setsockopt_export(fd: int32, level: int32, optname: int32, optval: ptr, optlen: int32): int32 =
    return raw_libc_setsockopt(fd, level, optname, optval, optlen)

@exportc("cheng_host_inet_pton")
fn cheng_host_inet_pton_export(family: int32, src: ptr, dst: ptr): int32 =
    return raw_libc_inet_pton_native(family, src, dst)

@exportc("cheng_host_inet_ntop")
fn cheng_host_inet_ntop_export(family: int32, src: ptr, dst: ptr, size: int32): ptr =
    return raw_libc_inet_ntop_native(family, src, dst, size)

@exportc("cheng_host_close")
fn cheng_host_close_export(fd: int32): int32 =
    return raw_libc_close(fd)

@exportc("cheng_tcp_connect_host_port_bridge")
fn cheng_tcp_connect_host_port_bridge_export(host: str, port: int32): int32 =
    if port <= 0 || port > 65535:
        return -22
    let hostText: ptr = cheng_host_copy_cstring_from_str(host)
    if hostText == nil:
        return -12
    let v4Ent: HostEntPtr = HostEntPtr(raw_libc_gethostbyname2(hostText, cheng_host_af_inet()))
    if v4Ent != nil:
        let fd: int32 = cheng_host_tcp_connect_first_resolved(v4Ent, port)
        if fd >= 0:
            raw_libc_free(hostText)
            return fd
    let v6Ent: HostEntPtr = HostEntPtr(raw_libc_gethostbyname2(hostText, cheng_host_af_inet6()))
    if v6Ent != nil:
        let fd: int32 = cheng_host_tcp_connect_first_resolved(v6Ent, port)
        if fd >= 0:
            raw_libc_free(hostText)
            return fd
    raw_libc_free(hostText)
    return -1

@exportc("cheng_host_execvp")
fn cheng_host_execvp_export(file: ptr, argv: ptr): int32 =
    return raw_libc_execvp(file, argv)

@exportc("cheng_host_strerror")
fn cheng_host_strerror_export(err: int32): ptr =
    return raw_libc_strerror(err)
