    return cheng_u64_mul_checked(info.freeram, unit)

@exportc("cheng_native_process_rss_bytes_value_bridge")
fn cheng_native_process_rss_bytes_value_bridge_export(pid: int64): int64 =
    return cheng_linux_process_rss_bytes(pid)

@exportc("cheng_native_process_group_rss_bytes_value_bridge")
fn cheng_native_process_group_rss_bytes_value_bridge_export(pgid: int64): int64 =
    if pgid <= 0 || pgid > int64(2147483647):
        return 0
    let dir: ptr = libc_opendir("/proc")
    if dir == nil:
        return 0
    var total: uint64
    var any = false
    while true:
        let ent: ptr = libc_readdir(dir)
        if ent == nil:
            break
        let name: ptr = cheng_ptr_plus(ent, chengLinuxDirentNameOff)
        let pid: int32 = cheng_linux_parse_pid_cstring(name)
        if pid <= 0:
            continue
        if libc_getpgid(pid) != int32(pgid):
            continue
        let rss: int64 = cheng_linux_process_rss_bytes(int64(pid))
        if rss > 0:
            if !cheng_u64_add_i64_checked(total, rss):
                let _closeOverflow = libc_closedir(dir)
                return 0
            any = true
    let _close = libc_closedir(dir)
    if !any:
        return 0
    return int64(total)

@exportc("cheng_native_system_disk_total_bytes_value_bridge")
fn cheng_native_system_disk_total_bytes_value_bridge_export(): int64 =
    var fs: ChengLinuxStatfs
    if libc_statfs("/", &fs) != 0:
        return 0
    let blockSize: uint64 = fs.fFrsize > 0 ? uint64(fs.fFrsize) : uint64(fs.fBsize)
    if blockSize == uint64(0):
        return 0
    return cheng_u64_mul_checked(uint64(fs.fBlocks), blockSize)

@exportc("cheng_native_system_disk_available_bytes_value_bridge")
