const
    chengStrFlagOwned: int32 = 1
    chengLinuxORdonly: int32 = 0
    chengLinuxScPagesize: int32 = 30
    chengLinuxDirentNameOff: int32 = 19

type
    str =
        data: ptr
        len: int32
        store_id: int32
        flags: int32
    UInt8Ptr = uint8 *
    Int32Ptr = int32 *
    ChengLinuxSysinfo =
        uptime: int64
        load0: uint64
        load1: uint64
        load2: uint64
        totalram: uint64
        freeram: uint64
        sharedram: uint64
        bufferram: uint64
        totalswap: uint64
        freeswap: uint64
        procs: uint16
        pad: uint16
        totalhigh: uint64
        freehigh: uint64
        memUnit: uint32
    ChengLinuxStatfs =
        fType: int64
        fBsize: int64
        fBlocks: int64
        fBfree: int64
        fBavail: int64
        fFiles: int64
        fFfree: int64
        fFsid0: int32
        fFsid1: int32
        fNamelen: int64
        fFrsize: int64
        fFlags: int64
        fSpare0: int64
        fSpare1: int64
        fSpare2: int64
        fSpare3: int64

fn cheng_ptr_plus(base: ptr, off: int32): ptr =
    if base == nil:
        return nil
    return ptr(uint64(base) + uint64(off))

fn cheng_bytes_copy(dst: ptr, src: ptr, n0: int32) =
    if dst == nil || src == nil || n0 <= 0:
        return
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = *(UInt8Ptr(cheng_ptr_plus(src, i)))

fn cheng_bytes_set(dst: ptr, value: int32, n0: int32) =
    if dst == nil || n0 <= 0:
        return
    let v: uint8 = uint8(value & 255)
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = v

fn cheng_cstrlen_raw(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32
    while *(UInt8Ptr(cheng_ptr_plus(s, n))) != uint8(0):
        n = n + 1
    return n

fn cheng_string_copy(raw: ptr, n0: int32): ptr =
    var n: int32 = n0
    if n < 0:
        n = 0
    let out: ptr = cheng_runtime_malloc(n + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, n + 1)
    if raw != nil && n > 0:
        cheng_bytes_copy(out, raw, n)
    return out

fn cheng_str_empty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_str_view_owned(data: ptr, len0: int32): str =
    var out: str
    if data == nil || len0 <= 0:
        return out
    out.data = data
    out.len = len0
    out.store_id = 0
    out.flags = chengStrFlagOwned
    return out

fn cheng_str_copy(raw: ptr, n: int32): str =
    let outRaw: ptr = cheng_string_copy(raw, n)
    if outRaw == nil:
        return cheng_str_empty()
    return cheng_str_view_owned(outRaw, n)

fn cheng_str_copy_cstring(raw: ptr): str =
    return cheng_str_copy(raw, cheng_cstrlen_raw(raw))

fn cheng_u64_mul_checked(a: uint64, b: uint64): int64 =
    if a == uint64(0) || b == uint64(0):
        return 0
    if a > uint64(9223372036854775807) / b:
        return 0
    return int64(a * b)

fn cheng_u64_add_i64_checked(total: var uint64, value: int64): bool =
    if value <= 0:
        return true
    let addend: uint64 = uint64(value)
    if total > uint64(9223372036854775807) - addend:
        return false
    total = total + addend
    return true

fn cheng_linux_write_u64_decimal(value: uint64, out: ptr, offset0: int32, cap: int32): int32 =
    if value == uint64(0) || out == nil || offset0 < 0 || cap <= offset0 + 1:
        return -1
    var digits: uint8[20]
    var n: int32
    var v: uint64 = value
    while v > uint64(0) && n < 20:
        digits[n] = uint8(int32(v % uint64(10)) + int32('0'))
        n = n + 1
        v = v / uint64(10)
    if v != uint64(0) || n <= 0 || offset0 + n >= cap:
        return -1
    var offset: int32 = offset0
    for i in 0..<n:
        *(UInt8Ptr(cheng_ptr_plus(out, offset))) = digits[n - 1 - i]
        offset = offset + 1
    return offset

fn cheng_linux_build_proc_statm_path(pid: int64, out: ptr, cap: int32): bool =
    if pid <= 0 || out == nil || cap < 32:
        return false
    cheng_bytes_set(out, 0, cap)
    cheng_bytes_copy(out, "/proc/", 6)
    var offset: int32 = cheng_linux_write_u64_decimal(uint64(pid), out, 6, cap)
    if offset <= 0 || offset + 6 >= cap:
        return false
    cheng_bytes_copy(cheng_ptr_plus(out, offset), "/statm", 6)
    offset = offset + 6
    *(UInt8Ptr(cheng_ptr_plus(out, offset))) = uint8(0)
    return true

fn cheng_linux_ascii_is_space(value: uint8): bool =
    return value == uint8(' ') || value == uint8('\t') || value == uint8('\n') || value == uint8('\r')

fn cheng_linux_ascii_digit_value(value: uint8): int32 =
    if value < uint8('0') || value > uint8('9'):
        return -1
    return int32(value) - int32('0')

fn cheng_linux_parse_statm_rss_pages(buf: ptr, count: int32): uint64 =
    if buf == nil || count <= 0:
        return uint64(0)
    var index: int32
    while index < count:
        let b: uint8 = *(UInt8Ptr(cheng_ptr_plus(buf, index)))
        if cheng_linux_ascii_is_space(b):
            break
        index = index + 1
    while index < count:
        let b: uint8 = *(UInt8Ptr(cheng_ptr_plus(buf, index)))
        if !cheng_linux_ascii_is_space(b):
            break
        index = index + 1
    var value: uint64
    var sawDigit = false
    while index < count:
        let b: uint8 = *(UInt8Ptr(cheng_ptr_plus(buf, index)))
        let digit: int32 = cheng_linux_ascii_digit_value(b)
        if digit < 0:
            break
        let d: uint64 = uint64(digit)
        if value > (uint64(9223372036854775807) - d) / uint64(10):
            return uint64(0)
        value = value * uint64(10) + d
        sawDigit = true
        index = index + 1
    if !sawDigit:
        return uint64(0)
    return value

fn cheng_linux_parse_pid_cstring(raw: ptr): int32 =
    if raw == nil:
        return -1
    var value: int32
    var index: int32
    var sawDigit = false
    while index < 32:
        let b: uint8 = *(UInt8Ptr(cheng_ptr_plus(raw, index)))
        if b == uint8(0):
            break
        let digit: int32 = cheng_linux_ascii_digit_value(b)
        if digit < 0:
            return -1
        if value > (2147483647 - digit) / 10:
            return -1
        value = value * 10 + digit
        sawDigit = true
        index = index + 1
    if !sawDigit:
        return -1
    return value

fn cheng_linux_process_rss_bytes(pid: int64): int64 =
    if pid <= 0:
        return 0
    var path: uint8[64]
    if !cheng_linux_build_proc_statm_path(pid, &path[0], 64):
        return 0
    let fd: int32 = libc_open_runtime(&path[0], chengLinuxORdonly)
    if fd < 0:
        return 0
    var buf: uint8[128]
    let got: int64 = libc_read_runtime(fd, &buf[0], 127)
    let _ = libc_close(fd)
    if got <= 0 || got > int64(127):
        return 0
    buf[int32(got)] = uint8(0)
    let pages: uint64 = cheng_linux_parse_statm_rss_pages(&buf[0], int32(got))
    if pages == uint64(0):
        return 0
    let pageSize: int64 = libc_sysconf(chengLinuxScPagesize)
    if pageSize <= 0:
        return 0
    return cheng_u64_mul_checked(pages, uint64(pageSize))

