import cheng/core/runtime/provider_root as provroot

type
    CompilerRuntimeTrack = enum
        CompilerRuntimeTrackProgram
        CompilerRuntimeTrackTooling

    CompilerRuntimeContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str
        entryTrack: CompilerRuntimeTrack

fn CompilerRuntimeProviderPath(rootDir: str, rel: str): str =
    return provroot.RuntimeProviderPath(rootDir, rel)

fn CompilerRuntimeProviderSourcePath(rootDir: str, track: CompilerRuntimeTrack): str =
    if track == CompilerRuntimeTrackTooling:
        return CompilerRuntimeProviderPath(rootDir, "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng")
    return CompilerRuntimeProviderPath(rootDir, "src/core/runtime/compiler_runtime_program_entry_provider.cheng")

fn CompilerRuntimeProgramArgvTarget(): str =
    return "runtime/compiler.program_argv_entry"

fn CompilerRuntimeToolingArgvTarget(): str =
    return "runtime/compiler.tooling_argv_entry"

fn CompilerRuntimeProviderContract(rootDir: str, track: CompilerRuntimeTrack): CompilerRuntimeContract =
    var out: CompilerRuntimeContract
    out.version = "cheng.runtime.compiler.v1"
    if track == CompilerRuntimeTrackTooling:
        out.services = [CompilerRuntimeToolingArgvTarget()]
        out.providerNativeSources = [
            CompilerRuntimeProviderSourcePath(rootDir, CompilerRuntimeTrackTooling)
        ]
        out.executionModel = "pure_cheng_tooling_argv_bridge"
        out.traceSymbol = "cheng_tooling_argv_entry"
        out.entryTrack = CompilerRuntimeTrackTooling
        return out
    out.services = [CompilerRuntimeProgramArgvTarget()]
    out.providerNativeSources = [
        CompilerRuntimeProviderSourcePath(rootDir, CompilerRuntimeTrackProgram)
    ]
    out.executionModel = "pure_cheng_program_argv_bridge"
    out.traceSymbol = "cheng_program_argv_entry"
    out.entryTrack = CompilerRuntimeTrackProgram
    return out

fn CompilerRuntimeTargetsForTrack(rootDir: str, track: CompilerRuntimeTrack): str[] =
    var out: str[]
    if track == CompilerRuntimeTrackTooling:
        add(out, CompilerRuntimeToolingArgvTarget())
        return out
    add(out, CompilerRuntimeProgramArgvTarget())
    return out
