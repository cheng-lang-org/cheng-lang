import cheng/core/runtime/provider_root as provroot

type
    DebugRuntimeContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str

fn DebugRuntimePath(rootDir: str, rel: str): str =
    return provroot.RuntimeProviderPath(rootDir, rel)

fn DebugRuntimeProviderSourcePath(rootDir: str): str =
    return DebugRuntimePath(rootDir, "src/core/runtime/debug_runtime_stub.cheng")

fn DebugRuntimeContract(rootDir: str): DebugRuntimeContract =
    var out: DebugRuntimeContract
    out.version = "cheng.runtime.debug.v1"
    out.services = [
        "runtime/debug.register_line_map",
        "runtime/debug.dump_backtrace",
        "runtime/debug.profile"
    ]
    out.providerNativeSources = [
        DebugRuntimeProviderSourcePath(rootDir)
    ]
    out.executionModel = "pure_cheng_debug_runtime_provider"
    out.traceSymbol = "cheng_native_register_line_map_from_argv0"
    return out

fn DebugRuntimeTargets(): str[] =
    var out: str[]
    add(out, "runtime/debug.register_line_map")
    add(out, "runtime/debug.dump_backtrace")
    add(out, "runtime/debug.profile")
    return out
