import std/os
import std/strutils as strutil
import cheng/core/tooling/path as v3path
import cheng/core/tooling/root_discovery as rootdisco

fn v3RuntimeProviderRoot(rootDirRaw: str): str =
    let envRoot = strutil.Strip(os.GetEnv("CHENG_ROOT"))
    if len(envRoot) > 0:
        return envRoot
    let discoveredRoot = strutil.Strip(rootdisco.v3CompilerRootAuto())
    if len(discoveredRoot) > 0 &&
       v3path.V3PathFileExists(v3path.V3PathAbsolute(discoveredRoot, "bootstrap/cheng_seed.c")):
        return discoveredRoot
    return strutil.Strip(rootDirRaw)

fn v3RuntimeProviderPath(rootDirRaw: str, relRaw: str): str =
    let rel = strutil.Strip(relRaw)
    if len(rel) <= 0:
        return ""
    let rootDir = v3RuntimeProviderRoot(rootDirRaw)
    if len(rootDir) <= 0:
        return rel
    return v3path.V3PathAbsolute(rootDir, rel)
