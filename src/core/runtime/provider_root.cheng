import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/root_discovery as rootdisco

fn RuntimeProviderRoot(rootDirRaw: str): str =
    let envRoot = strutil.Strip(os.GetEnv("CHENG_ROOT"))
    if len(envRoot) > 0:
        return envRoot
    let discoveredRoot = strutil.Strip(rootdisco.CompilerRootAuto())
    if len(discoveredRoot) > 0 &&
       chengpath.PathFileExists(chengpath.PathAbsolute(discoveredRoot, "bootstrap/cheng_seed.c")):
        return discoveredRoot
    return strutil.Strip(rootDirRaw)

fn RuntimeProviderPath(rootDirRaw: str, relRaw: str): str =
    let rel = strutil.Strip(relRaw)
    if len(rel) <= 0:
        return ""
    let rootDir = RuntimeProviderRoot(rootDirRaw)
    if len(rootDir) <= 0:
        return rel
    return chengpath.PathAbsolute(rootDir, rel)
