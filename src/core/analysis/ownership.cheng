module ownership

type
    OwnershipKind = enum
        Owned
        Borrowed
        Shared

    OwnershipRecord =
        varId: int32
        kind: OwnershipKind
        ownerPath: int32
        sharedRefCount: int32

    OwnershipCtx =
        records: OwnershipRecord[]
        nextVarId: int32

    OwnershipError = enum
        Ok
        ErrDoubleMove
        ErrMoveAfterBorrow
        ErrInvalidOwnership

fn OwnershipCtxNew(): OwnershipCtx =
    var out: OwnershipCtx
    out.records = []
    out.nextVarId = 0
    return out

fn OwnershipCtxGetRecord(ctx: OwnershipCtx, varId: int32, outRecord: var OwnershipRecord): bool =
    for i in 0..<ctx.records.len
        if ctx.records[i].varId == varId
            outRecord = ctx.records[i]
            return true
    return false

fn OwnershipCtxSetRecord(ctx: var OwnershipCtx, record: OwnershipRecord) =
    for i in 0..<ctx.records.len
        if ctx.records[i].varId == record.varId
            ctx.records[i] = record
            return
    add(ctx.records, record)

fn OwnershipCtxTransfer(ctx: var OwnershipCtx, fromVarId: int32, toVarId: int32): OwnershipError =
    var fromRecord: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, fromVarId, fromRecord)
        fromRecord.varId = fromVarId
        fromRecord.kind = Owned
        fromRecord.sharedRefCount = 0
    if fromRecord.kind != Owned
        return ErrInvalidOwnership
    var toRecord: OwnershipRecord
    toRecord.varId = toVarId
    toRecord.kind = Owned
    toRecord.sharedRefCount = 0
    fromRecord.kind = Borrowed
    fromRecord.ownerPath = toVarId
    OwnershipCtxSetRecord(ctx, fromRecord)
    OwnershipCtxSetRecord(ctx, toRecord)
    return Ok

fn OwnershipCtxBorrowShared(ctx: var OwnershipCtx, fromVarId: int32, toVarId: int32): OwnershipError =
    var fromRecord: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, fromVarId, fromRecord)
        fromRecord.varId = fromVarId
        fromRecord.kind = Owned
        fromRecord.sharedRefCount = 0
    if fromRecord.kind != Owned && fromRecord.kind != Shared
        return ErrInvalidOwnership
    var toRecord: OwnershipRecord
    toRecord.varId = toVarId
    toRecord.kind = Shared
    toRecord.ownerPath = fromVarId
    toRecord.sharedRefCount = 0
    if fromRecord.kind == Owned
        fromRecord.kind = Shared
        fromRecord.sharedRefCount = 1
    else
        fromRecord.sharedRefCount = fromRecord.sharedRefCount + 1
    OwnershipCtxSetRecord(ctx, fromRecord)
    OwnershipCtxSetRecord(ctx, toRecord)
    return Ok

fn OwnershipCtxReleaseShared(ctx: var OwnershipCtx, varId: int32): OwnershipError =
    var record: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, varId, record)
        return Ok
    if record.kind == Shared
        var ownerRecord: OwnershipRecord
        if !OwnershipCtxGetRecord(ctx, record.ownerPath, ownerRecord)
            return Ok
        ownerRecord.sharedRefCount = ownerRecord.sharedRefCount - 1
        if ownerRecord.sharedRefCount <= 0
            ownerRecord.kind = Owned
        OwnershipCtxSetRecord(ctx, ownerRecord)
        for i in 0..<ctx.records.len
            if ctx.records[i].varId == varId
                remove(ctx.records, i)
                break
    return Ok

fn OwnershipCtxVerifyNoAlias(ctx: OwnershipCtx, varId: int32): bool =
    var record: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, varId, record)
        return true
    if record.kind == Shared
        return record.sharedRefCount <= 1
    if record.kind == Borrowed
        return true
    return true

fn OwnershipCtxOwnershipText(kind: OwnershipKind): str =
    if kind == Owned
        return "owned"
    if kind == Borrowed
        return "borrowed"
    if kind == Shared
        return "shared"
    return "unknown"

fn OwnershipErrorText(err: OwnershipError): str =
    if err == Ok
        return "ok"
    if err == ErrDoubleMove
        return "double move detected"
    if err == ErrMoveAfterBorrow
        return "cannot move while borrowed"
    if err == ErrInvalidOwnership
        return "invalid ownership state"
    return "unknown error"
