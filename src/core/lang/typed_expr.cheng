    var out = ""
    TypedExprReportAppendLine(out, "expr_surface_call_count", intToStr(TypedExprSurfaceCallCount(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_resolved_count", intToStr(TypedExprFactCountCallResolved(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_unresolved_count", intToStr(TypedExprFactCountCallUnresolved(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_local_kind_count", intToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallLocal)))
    TypedExprReportAppendLine(out, "expr_surface_call_external_kind_count", intToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallExternal)))
    TypedExprReportAppendLine(out, "expr_surface_call_importc_kind_count", intToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallImportc)))
    TypedExprReportAppendLine(out, "expr_surface_call_member_kind_count", intToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallMember)))
