    TypedExprReportAppendLine(out, "typed_ir_return_i32_sub_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpI32Sub)))
    TypedExprReportAppendLine(out, "typed_ir_return_i32_mul_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpI32Mul)))
    TypedExprReportAppendLine(out, "typed_ir_return_i32_asr_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpI32Asr)))
    TypedExprReportAppendLine(out, "typed_ir_return_i32_madd_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpI32Madd)))
    TypedExprReportAppendLine(out, "typed_ir_return_i32_if_arg0_le_zero_const_else_const_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpI32IfArg0LeZeroConstElseConst)))
    TypedExprReportAppendLine(out, "typed_ir_return_f64_mul_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpF64Mul)))
    TypedExprReportAppendLine(out, "typed_ir_return_str_len_fast_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpStrLenFast)))
    TypedExprReportAppendLine(out, "typed_ir_return_let_call_result_i32_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpLetCallResultI32)))
    TypedExprReportAppendLine(out, "typed_ir_return_let_call_i32_if_result_le_zero_return_zero_else_result_i32_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpLetCallI32IfResultLeZeroReturnZeroElseResultI32)))
    TypedExprReportAppendLine(out, "typed_ir_return_str_empty_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpStrEmptyReturn)))
    TypedExprReportAppendLine(out, "typed_ir_return_let_call_str_return_len_i32_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpLetCallStrReturnLenI32)))
    TypedExprReportAppendLine(out, "typed_ir_return_let_call_str_then_call_arg0_return_i32_const_0_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpLetCallStrThenCallArg0ReturnI32Const0)))
    TypedExprReportAppendLine(out, "typed_ir_return_str_i32_guard_arg0_return_0_count", intToStr(TypedExprIrReturnCountOpKind(ir, TypedExprIrOpStrI32GuardArg0Return0)))
    return out

fn TypedExprLoweringRulesReportText(rules: TypedExprLoweringRule[]): str =
    var out = ""
    TypedExprReportAppendLine(out, "lowering_rule_count", intToStr(rules.len))
    TypedExprReportAppendLine(out, "lowering_rule_unique_shape_count", intToStr(TypedExprLoweringRuleUniqueShapeCount(rules)))
    TypedExprReportAppendLine(out, "lowering_rule_unique_key_count", intToStr(TypedExprLoweringRuleUniqueKeyCount(rules)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_value_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassValue)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_address_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_call_result_address_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassCallResultAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_result_reg_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassReg)))
    TypedExprReportAppendLine(out, "lowering_rule_result_local_address_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassLocalAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_result_sret_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassSret)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_register_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeRegister)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_local_slot_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeLocalSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_call_result_local_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeCallResultLocal)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_dest_address_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeDestAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_copy_scalar_store_count", intToStr(TypedExprLoweringRuleCountCopyKind(rules, TypedExprCopyScalarStore)))
    TypedExprReportAppendLine(out, "lowering_rule_copy_region_copy_count", intToStr(TypedExprLoweringRuleCountCopyKind(rules, TypedExprCopyRegionCopy)))
    TypedExprReportAppendLine(out, "lowering_rule_import_import_buffer_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportImportBuffer)))
    TypedExprReportAppendLine(out, "lowering_rule_import_builtin_address_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportBuiltinAddressSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_import_i32_value_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportI32ValueSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_import_i32_address_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportI32AddressSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_none_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallNone)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_default_init_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallDefaultInit)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_constructor_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallConstructor)))
    TypedExprReportAppendLine(out, "lowering_rule_return_root_count", intToStr(TypedExprLoweringRuleReturnRootCount(rules)))
    for i in 0..<rules.len:
        TypedExprReportAppendLine(out, "lowering_rule_entry[" + intToStr(i) + "]", TypedExprLoweringRuleEntryText(rules[i]))
    return out

fn TypedExprReportText(facts: TypedExprFact[],
                         rules: TypedExprLoweringRule[]): str =
    let factsText = TypedExprFactsReportText(facts)
    let rulesText = TypedExprLoweringRulesReportText(rules)
    return factsText + rulesText

fn TypedExprLoweringRuleValidateTypeCallMaterialize(rule: TypedExprLoweringRule,
                                                      err: var str): bool =
    if rule.typeCallKind == TypedExprTypeCallNone:
        return true
    if !TypedExprTypeTextIsConcrete(rule.typeText):
        err = " typed expr: type-call rule missing concrete type"
        return false
    if rule.callKind != TypedExprCallNone:
        err = " typed expr: type-call rule leaked ordinary call kind"
        return false
    if rule.abiClass != TypedExprAbiComposite ||
       rule.valueKind != TypedExprValueComposite:
        err = " typed expr: type-call rule must materialize composite"
        return false
    if rule.placeKind == TypedExprPlaceCallResult:
        err = " typed expr: type-call rule cannot use call-result place"
        return false
    if rule.argPassKind != TypedExprArgPassAddress:
        err = " typed expr: type-call rule must pass address"
        return false
    if rule.copyKind != TypedExprCopyRegionCopy:
        err = " typed expr: type-call rule must copy region"
        return false
    if rule.loweringMode == TypedExprLowerLocalAddress:
        if rule.returnKind != TypedExprReturnCompositeLocal ||
           rule.resultPassKind != TypedExprResultPassLocalAddress ||
           rule.materializeKind != TypedExprMaterializeLocalSlot:
            err = " typed expr: type-call rule local-address lowering drift"
            return false
        err = ""
        return true
    if rule.loweringMode == TypedExprLowerSret:
        if rule.returnKind != TypedExprReturnSret ||
           rule.resultPassKind != TypedExprResultPassSret ||
           rule.materializeKind != TypedExprMaterializeDestAddress:
            err = " typed expr: type-call rule sret lowering drift"
            return false
        err = ""
        return true
    err = " typed expr: type-call rule missing address lowering"
    return false

fn TypedExprLoweringRulesValidate(rules: TypedExprLoweringRule[],
                                    err: var str): bool =
    for i in 0..<rules.len:
        let rule = rules[i]
        if rule.exprId == "" || rule.sourcePath == "":
            err = " typed expr: lowering rule missing owner"
            return false
        if rule.surfaceCallKind == TypedExprSurfaceCallNone:
            if rule.callResolved ||
               rule.callReason != TypedExprCallReasonNone ||
               rule.callQualifier != "" ||
               rule.callCallee != "" ||
               rule.callTarget != "" ||
               rule.callTargetSourcePath != "" ||
               rule.callTargetImportc:
                err = " typed expr: non-call rule leaked call resolution"
                return false
            if rule.typeCallKind != TypedExprTypeCallNone:
                if !TypedExprLoweringRuleValidateTypeCallMaterialize(rule, err):
                    return false
            elif rule.callPrefixStyle ||
                 rule.callArgCount != 0 ||
                 rule.callArgsText != "":
                err = " typed expr: non-call rule leaked call args"
                return false
        else:
            if rule.typeCallKind != TypedExprTypeCallNone:
                err = " typed expr: call rule leaked type-call kind"
                return false
            if rule.callQualifier == "" &&
               (rule.surfaceCallKind == TypedExprSurfaceCallExternal ||
                rule.surfaceCallKind == TypedExprSurfaceCallMember):
                if parser.ParserFindText(rule.callTarget, ".") >= 0:
                    err = " typed expr: qualified call rule missing qualifier: target=" +
                          rule.callTarget +
                          " callee=" +
                          rule.callCallee +
                          " source=" +
                          rule.sourcePath +
                          " expr=" +
                          rule.exprId
                    return false
            if rule.callCallee == "" || rule.callTarget == "":
                err = " typed expr: call rule missing callee or target"
                return false
            if rule.callResolved && rule.callReason != TypedExprCallReasonNone:
                err = " typed expr: resolved rule keeps call reason"
                return false
            if !rule.callResolved && rule.callReason == TypedExprCallReasonNone:
                err = " typed expr: unresolved rule missing call reason"
                return false
            if rule.callResolved && rule.callTargetSourcePath == "":
                err = " typed expr: resolved rule missing target source"
                return false
            if !rule.callResolved && rule.callTargetSourcePath != "":
                err = " typed expr: unresolved rule keeps target source"
                return false
            if !rule.callResolved && rule.callTargetImportc:
                err = " typed expr: unresolved rule keeps importc target"
                return false
        if rule.typeCallKind != TypedExprTypeCallNone &&
           rule.surfaceCallKind != TypedExprSurfaceCallNone:
            err = " typed expr: type-call rule leaked call surface"
            return false
        if (rule.abiClass == TypedExprAbiPolymorphic ||
            rule.loweringMode == TypedExprLowerDeferred) &&
           (rule.argPassKind != TypedExprArgPassDeferred ||
            rule.resultPassKind != TypedExprResultPassDeferred ||
            rule.materializeKind != TypedExprMaterializeDeferred ||
            rule.copyKind != TypedExprCopyDeferred ||
            rule.importKind != TypedExprImportDeferred):
            err = " typed expr: deferred rule leaked concrete lowering"
            return false
        if rule.importKind == TypedExprImportImportBuffer &&
           rule.loweringMode != TypedExprLowerImportBuffer &&
           rule.returnKind != TypedExprReturnImportBuffer:
            err = " typed expr: import buffer rule missing import buffer return"
            return false
        if rule.copyKind == TypedExprCopyRegionCopy &&
           rule.valueKind != TypedExprValueComposite:
            err = " typed expr: region copy rule must stay composite"
            return false
    err = ""
    return true

fn TypedExprBuildLoweringRules(facts: TypedExprFact[],
                                 rules: var TypedExprLoweringRule[],
                                 err: var str): bool =
    rules = TypedExprLoweringRulesFromFacts(facts)
    if !TypedExprLoweringRulesValidate(rules, err):
        return false
    err = ""
    return true

fn TypedExprConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn TypedExprConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn TypedExprNormalizeTypeText(typeRaw: str): str =
    let trimmed: str = chengpath.PathTrim(typeRaw)
    if trimmed == "":
        return ""
    var out = buffer.NewByteBuffer()
    for i in 0..<trimmed.len:
        let piece = chengpath.TextSlice(trimmed, i, 1)
        if piece == " ":
            continue
        if piece == "\t":
            continue
        if piece == "\n":
            continue
        if piece == "\r":
            continue
        buffer.AppendBytes(out, piece)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot: str,
                                                    packageRoot: str,
                                                    externalPackageRoots: parser.ParserExternalPackageRoot[],
                                                    sourcePath: str,
                                                    text: str): TypedExprSourceText =
    var out: TypedExprSourceText
    out.workspaceRoot = parser.ParserNormalizePath(workspaceRoot)
    out.packageRoot = parser.ParserNormalizePath(packageRoot)
    out.externalPackageRoots = parser.ParserExternalPackageRootsClone(externalPackageRoots)
    out.sourcePath = parser.ParserNormalizePath(sourcePath)
    out.text = text
    return out

fn TypedExprSourceTextNew(workspaceRoot: str,
                            packageRoot: str,
                            sourcePath: str,
                            text: str): TypedExprSourceText =
    var externalPackageRoots: parser.ParserExternalPackageRoot[]
    return TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot,
                                                            packageRoot,
                                                            externalPackageRoots,
                                                            sourcePath,
                                                            text)

fn TypedExprResultType(innerTypeRaw: str): str =
    let innerType = TypedExprNormalizeTypeText(innerTypeRaw)
    if innerType == "":
        return ""
    return TypedExprConcat3("Result[", innerType, "]")

fn TypedExprResultSuccessType(typeRaw: str): str =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if !parser.ParserStartsWith(typeText, "Result["):
        return ""
    if typeText.len <= 8:
        return ""
    if chengpath.TextSlice(typeText, typeText.len - 1, 1) != "]":
        return ""
    return chengpath.TextSlice(typeText, len("Result["), typeText.len - len("Result[") - 1)

fn TypedExprTypeIsScalar(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "void":
        return true
    if typeText == "bool" || typeText == "char":
        return true
    if typeText == "int" || typeText == "uint":
        return true
    if typeText == "int8" || typeText == "uint8" || typeText == "u8":
        return true
    if typeText == "int16" || typeText == "uint16" || typeText == "u16":
        return true
    if typeText == "int32" || typeText == "uint32" || typeText == "u32":
        return true
    if typeText == "int64" || typeText == "uint64" || typeText == "u64":
        return true
    if typeText == "float32" || typeText == "float64":
        return true
    return false

fn TypedExprTypeIsPointerLike(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "cstring":
        return true
    if typeText == "ptr":
        return true
    return parser.ParserStartsWith(typeText, "ptr[") || parser.ParserStartsWith(typeText, "Pointer[")

fn TypedExprTypeIsComposite(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "str" || typeText == "Bytes" || typeText == "bytes.Bytes":
        return true
    if typeText == "rawbytes" || typeText == "ErrorInfo" || typeText == "range":
        return true
    if parser.ParserStartsWith(typeText, "Result["):
        return true
    if parser.ParserStartsWith(typeText, "seq["):
        return true
    if parser.ParserStartsWith(typeText, "tuple["):
        return true
    if parser.ParserStartsWith(typeText, "array["):
        return true
    if parser.ParserStartsWith(typeText, "object["):
        return true
    if typeText.len >= 2 && chengpath.TextSlice(typeText, typeText.len - 2, 2) == "[]":
        return true
    return false

fn TypedExprAbiClassForType(typeRaw: str): TypedExprAbiClass =
    if TypedExprTypeIsScalar(typeRaw):
        return TypedExprAbiScalar
    if TypedExprTypeIsPointerLike(typeRaw):
        return TypedExprAbiPointerLike
    if TypedExprTypeIsComposite(typeRaw):
        return TypedExprAbiComposite
    return TypedExprAbiPolymorphic

fn TypedExprValueKindForAbiClass(abiClass: TypedExprAbiClass): TypedExprValueKind =
    if abiClass == TypedExprAbiScalar:
        return TypedExprValueScalar
    if abiClass == TypedExprAbiComposite:
        return TypedExprValueComposite
    if abiClass == TypedExprAbiPointerLike:
        return TypedExprValuePointerLike
    return TypedExprValuePolymorphic

fn TypedExprSkipInlineSpaces(lineRaw: str,
                               start: int32): int32 =
    var cursor = start
    for i in start..<lineRaw.len:
        if parser.ParserIsInlineSpace(lineRaw[i]):
            cursor = i + 1
        else:
            return i
    return cursor

fn TypedExprFindMatchingPair(lineRaw: str,
                               openPos: int32,
                               openText: str,
                               closeText: str): int32 =
    if openPos < 0:
        return -1
    if openPos >= lineRaw.len:
        return -1
    if chengpath.TextSlice(lineRaw, openPos, 1) != openText:
        return -1
    var depth: int32
    for i in openPos..<lineRaw.len:
        let piece = chengpath.TextSlice(lineRaw, i, 1)
        if piece == openText:
            depth = depth + 1
        elif piece == closeText:
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn TypedExprFindMatchingParen(lineRaw: str,
                                openPos: int32): int32 =
    return TypedExprFindMatchingPair(lineRaw, openPos, "(", ")")

fn TypedExprFindMatchingBracket(lineRaw: str,
                                  openPos: int32): int32 =
    return TypedExprFindMatchingPair(lineRaw, openPos, "[", "]")

fn TypedExprSliceTrim(textRaw: str,
                        start: int32,
                        count: int32): str =
    if start < 0 || count <= 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(textRaw, start, count))

fn TypedExprFindTopLevelToken(textRaw: str,
                                target: str): int32 =
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let piece = chengpath.TextSlice(textRaw, i, 1)
        if piece == "[":
            bracketDepth = bracketDepth + 1
        elif piece == "]":
            bracketDepth = bracketDepth - 1
        elif piece == "(":
            parenDepth = parenDepth + 1
        elif piece == ")":
            parenDepth = parenDepth - 1
        elif piece == "{":
            braceDepth = braceDepth + 1
        elif piece == "}":
            braceDepth = braceDepth - 1
        elif piece == target && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            return i
    return -1

fn TypedExprTextAt(textRaw: str,
                    start: int32,
                    target: str): bool =
    if start < 0 || len(target) <= 0:
        return false
    if start + len(target) > len(textRaw):
        return false
    for i in 0..<len(target):
        if textRaw[start + i] != target[i]:
            return false
    return true

fn TypedExprFindTopLevelTextToken(textRaw: str,
                                   target: str): int32 =
    if len(target) <= 0 || len(target) > len(textRaw):
        return -1
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let piece = chengpath.TextSlice(textRaw, i, 1)
        if piece == "[":
            bracketDepth = bracketDepth + 1
        elif piece == "]":
            bracketDepth = bracketDepth - 1
        elif piece == "(":
            parenDepth = parenDepth + 1
        elif piece == ")":
            parenDepth = parenDepth - 1
        elif piece == "{":
            braceDepth = braceDepth + 1
        elif piece == "}":
            braceDepth = braceDepth - 1
        elif bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            if TypedExprTextAt(textRaw, i, target):
                return i
    return -1

fn TypedExprParseFunctionReturnType(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return ""
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos < 0:
        return ""
    let cursor0 = TypedExprSkipInlineSpaces(line, closePos + 1)
    var cursor = cursor0
    if cursor >= line.len:
        return ""
    if chengpath.TextSlice(line, cursor, 1) != ":":
        return ""
    cursor = TypedExprSkipInlineSpaces(line, cursor + 1)
    let tail = chengpath.TextSlice(line, cursor, line.len - cursor)
    let eqPos = TypedExprFindTopLevelToken(tail, "=")
    if eqPos >= 0:
        return TypedExprNormalizeTypeText(chengpath.TextSlice(tail, 0, eqPos))
    return TypedExprNormalizeTypeText(tail)

fn TypedExprBodyTextAfterEquals(lineRaw: str): str =
    let eqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
    if eqPos < 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(lineRaw, eqPos + 1, lineRaw.len - eqPos - 1))

fn TypedExprFunctionBodyLine(ctx: TypedExprSourceContext,
                              scope: TypedExprFunctionScope,
                              bodyLineNumber: var int32): str =
    bodyLineNumber = 0
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return ""
    let declLine = ctx.lines[scope.startLine - 1]
    let inlineBody = TypedExprBodyTextAfterEquals(declLine)
    if inlineBody != "":
        bodyLineNumber = scope.startLine
        return inlineBody
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyLineNumber = i + 1
        return bodyTrim
    return ""

fn TypedExprFunctionParams(lineRaw: str): TypedExprParam[] =
    var out: TypedExprParam[]
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return out
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos <= openPos:
        return out
    let paramsText = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let params = TypedExprSplitTopLevelCsv(paramsText)
    for i in 0..<params.len:
        var item = params[i]
        if parser.ParserStartsWith(item, "var "):
            item = chengpath.TextSlice(item, 4, item.len - 4)
        let colonPos = TypedExprFindTopLevelTextToken(item, ":")
        if colonPos <= 0:
            continue
        var typeText = chengpath.TextSlice(item, colonPos + 1, item.len - colonPos - 1)
        let eqPos = TypedExprFindTopLevelTextToken(typeText, "=")
        if eqPos >= 0:
            typeText = chengpath.TextSlice(typeText, 0, eqPos)
        var param: TypedExprParam
        param.name = parser.ParserIdentPrefix(chengpath.PathTrim(chengpath.TextSlice(item, 0, colonPos)))
        param.typeText = TypedExprNormalizeTypeText(typeText)
        if param.name != "" && param.typeText != "":
            add(out, param)
    return out

fn TypedExprReturnExprFromBody(bodyText: str): str =
    let trimmed = chengpath.PathTrim(bodyText)
    if parser.ParserStartsWith(trimmed, "return "):
        return chengpath.PathTrim(chengpath.TextSlice(trimmed, 7, trimmed.len - 7))
    return trimmed

fn TypedExprReturnExprMatchesBinary(returnExpr: str,
                                     lhsName: str,
                                     opText: str,
                                     rhsName: str): bool =
    let opIndex = TypedExprFindTopLevelTextToken(returnExpr, opText)
    if opIndex < 0:
        return false
    let lhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, opIndex))
    let rhsStart = opIndex + len(opText)
    let rhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                         rhsStart,
                                                         returnExpr.len - rhsStart))
    return lhsText == lhsName && rhsText == rhsName

fn TypedExprReturnOpForBinary(lhs: TypedExprParam,
                               rhs: TypedExprParam,
                               returnType: str,
                               returnExpr: str): TypedExprReturnOpKind =
    if lhs.typeText == "int32" &&
       rhs.typeText == "int32" &&
       returnType == "int32":
        if TypedExprReturnExprMatchesBinary(returnExpr, lhs.name, "+", rhs.name):
            return TypedExprReturnOpI32AddArgs
        if TypedExprReturnExprMatchesBinary(returnExpr, lhs.name, "-", rhs.name):
            return TypedExprReturnOpI32SubArgs
        if TypedExprReturnExprMatchesBinary(returnExpr, lhs.name, "*", rhs.name):
            return TypedExprReturnOpI32MulArgs
        if TypedExprReturnExprMatchesBinary(returnExpr, lhs.name, ">>", rhs.name):
            return TypedExprReturnOpI32AsrArgs
    if lhs.typeText == "float64" &&
       rhs.typeText == "float64" &&
       returnType == "float64":
        if TypedExprReturnExprMatchesBinary(returnExpr, lhs.name, "*", rhs.name):
            return TypedExprReturnOpF64MulArgs
    return TypedExprReturnOpUnsupported

fn TypedExprReturnExprMatchesMadd(returnExpr: str,
                                   lhsName: str,
                                   rhsName: str,
                                   accName: str): bool =
    let opIndex = TypedExprFindTopLevelTextToken(returnExpr, "+")
    if opIndex < 0:
        return false
    let leftText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, opIndex))
    let rightStart = opIndex + 1
    let rightText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                          rightStart,
                                                          returnExpr.len - rightStart))
    if rightText == accName:
        if TypedExprReturnExprMatchesBinary(leftText, lhsName, "*", rhsName):
            return true
    if leftText == accName:
        if TypedExprReturnExprMatchesBinary(rightText, lhsName, "*", rhsName):
            return true
    return false

fn TypedExprReturnOpForMadd(lhs: TypedExprParam,
                             rhs: TypedExprParam,
                             acc: TypedExprParam,
                             returnType: str,
                             returnExpr: str): TypedExprReturnOpKind =
    if lhs.typeText == "int32" &&
       rhs.typeText == "int32" &&
       acc.typeText == "int32" &&
       returnType == "int32":
        if TypedExprReturnExprMatchesMadd(returnExpr, lhs.name, rhs.name, acc.name):
            return TypedExprReturnOpI32MaddArgs
    return TypedExprReturnOpUnsupported

fn TypedExprIrAddNode(ir: var TypedExprIr,
                       node: TypedExprIrNode): int32 =
    var out = node
    out.nodeIndex = ir.nodes.len
    add(ir.nodes, out)
    return out.nodeIndex

fn TypedExprIrAddParamNode(ir: var TypedExprIr,
                            sourcePath: str,
                            functionName: str,
                            lineNumber: int32,
                            param: TypedExprParam,
                            paramSlot: int32): int32 =
    var node: TypedExprIrNode
    node.sourcePath = sourcePath
    node.functionName = functionName
    node.lineNumber = lineNumber
    node.opKind = TypedExprIrOpParamRef
    node.resultType = param.typeText
    node.surfaceText = param.name
    node.paramSlot = paramSlot
    node.paramName = param.name
    node.operand0NodeIndex = -1
    node.operand1NodeIndex = -1
    node.operand2NodeIndex = -1
    return TypedExprIrAddNode(ir, node)

fn TypedExprIrAddParamNodes(ir: var TypedExprIr,
                             sourcePath: str,
                             functionName: str,
                             lineNumber: int32,
                             params: TypedExprParam[],
                             paramNodeIndices: var int32[]) =
    paramNodeIndices = []
    for i in 0..<params.len:
        let nodeIndex = TypedExprIrAddParamNode(ir,
                                                sourcePath,
                                                functionName,
                                                lineNumber,
                                                params[i],
                                                i)
        add(paramNodeIndices, nodeIndex)

fn TypedExprParamSlot(params: TypedExprParam[],
                       name: str): int32 =
    for i in 0..<params.len:
        if params[i].name == name:
            return i
    return -1

fn TypedExprIrParamNodeIndex(params: TypedExprParam[],
                              paramNodeIndices: int32[],
                              name: str): int32 =
    let slot = TypedExprParamSlot(params, name)
    if slot < 0 || slot >= paramNodeIndices.len:
        return -1
    return paramNodeIndices[slot]

fn TypedExprIrIsI32ConstLiteral(textRaw: str): bool =
    let text = chengpath.PathTrim(textRaw)
    if len(text) <= 0:
        return false
    var constValue: int32
    for i in 0..<text.len:
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
        let digit = int32(ch) - int32('0')
        if constValue > 6553 || (constValue == 6553 && digit > 5):
            return false
        constValue = constValue * 10 + digit
    return true

fn TypedExprIrAddI32ConstNode(ir: var TypedExprIr,
                               sourcePath: str,
                               functionName: str,
                               lineNumber: int32,
                               literalText: str): int32 =
    var node: TypedExprIrNode
    node.sourcePath = sourcePath
    node.functionName = functionName
    node.lineNumber = lineNumber
    node.opKind = TypedExprIrOpI32Const
    node.resultType = "int32"
    node.surfaceText = literalText
    node.paramSlot = -1
    node.operand0NodeIndex = -1
    node.operand1NodeIndex = -1
    node.operand2NodeIndex = -1
    node.literalText = literalText
    return TypedExprIrAddNode(ir, node)

fn TypedExprIrAddOpNode(ir: var TypedExprIr,
                         sourcePath: str,
                         functionName: str,
                         lineNumber: int32,
                         opKind: TypedExprIrOpKind,
                         resultType: str,
                         surfaceText: str,
                         operand0: int32,
                         operand1: int32,
                         operand2: int32): int32 =
    var node: TypedExprIrNode
    node.sourcePath = sourcePath
    node.functionName = functionName
    node.lineNumber = lineNumber
    node.opKind = opKind
    node.resultType = resultType
    node.surfaceText = surfaceText
    node.paramSlot = -1
    node.operand0NodeIndex = operand0
    node.operand1NodeIndex = operand1
    node.operand2NodeIndex = operand2
    return TypedExprIrAddNode(ir, node)

fn TypedExprIrBodyTextIsLetCall(bodyTextRaw: str): bool =
    let bodyText = chengpath.PathTrim(bodyTextRaw)
    var prefix = ""
    if parser.ParserStartsWith(bodyText, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(bodyText, "var "):
        prefix = "var "
    if prefix == "":
        return false
    let tail = chengpath.TextSlice(bodyText, len(prefix), bodyText.len - len(prefix))
    let eqPos = TypedExprFindTopLevelTextToken(tail, "=")
    if eqPos <= 0:
        return false
    let bindingText = chengpath.PathTrim(chengpath.TextSlice(tail, 0, eqPos))
    let bindingName = parser.ParserIdentPrefix(parser.ParserFirstToken(bindingText))
    if bindingName == "":
        return false
    let rhsStart = eqPos + 1
    let rhsText = chengpath.PathTrim(chengpath.TextSlice(tail, rhsStart, tail.len - rhsStart))
    let openPos = parser.ParserFindText(rhsText, "(")
    if openPos <= 0:
        return false
    let closePos = TypedExprFindMatchingParen(rhsText, openPos)
    return closePos == rhsText.len - 1

fn TypedExprIrBodyTextIsI32LetCall(bodyTextRaw: str): bool =
    let bodyText = chengpath.PathTrim(bodyTextRaw)
    if !TypedExprIrBodyTextIsLetCall(bodyText):
        return false
    var prefix = ""
    if parser.ParserStartsWith(bodyText, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(bodyText, "var "):
        prefix = "var "
    if prefix == "":
        return false
    let tail = chengpath.TextSlice(bodyText, len(prefix), bodyText.len - len(prefix))
    let colonPos = TypedExprFindTopLevelTextToken(tail, ":")
    let eqPos = TypedExprFindTopLevelTextToken(tail, "=")
    if colonPos < 0 && eqPos > 0:
        return true
    if colonPos < 0 || eqPos <= colonPos:
        return false
    let typeText = TypedExprNormalizeTypeText(chengpath.TextSlice(tail,
                                                                  colonPos + 1,
                                                                  eqPos - colonPos - 1))
    return typeText == "int32"

fn TypedExprIrBodyTextIsStrLetCall(bodyTextRaw: str): bool =
    let bodyText = chengpath.PathTrim(bodyTextRaw)
    if !TypedExprIrBodyTextIsLetCall(bodyText):
        return false
    var prefix = ""
    if parser.ParserStartsWith(bodyText, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(bodyText, "var "):
        prefix = "var "
    if prefix == "":
        return false
    let tail = chengpath.TextSlice(bodyText, len(prefix), bodyText.len - len(prefix))
    let colonPos = TypedExprFindTopLevelTextToken(tail, ":")
    let eqPos = TypedExprFindTopLevelTextToken(tail, "=")
    if colonPos < 0 && eqPos > 0:
        return true
    if colonPos < 0 || eqPos <= colonPos:
        return false
    let typeText = TypedExprNormalizeTypeText(chengpath.TextSlice(tail,
                                                                  colonPos + 1,
                                                                  eqPos - colonPos - 1))
    return typeText == "str"

fn TypedExprReturnStrLenFastBindingName(exprRaw: str): str =
    let exprText = chengpath.PathTrim(exprRaw)
    let prefix = "strLenFast("
    if len(exprText) <= len(prefix):
        return ""
    if !parser.ParserStartsWith(exprText, prefix):
        return ""
    if exprText[len(exprText) - 1] != ')':
        return ""
    let innerLen = len(exprText) - len(prefix) - 1
    if innerLen <= 0:
        return ""
    let innerText = chengpath.PathTrim(chengpath.TextSlice(exprText, len(prefix), innerLen))
    if parser.ParserIdentPrefix(parser.ParserFirstToken(innerText)) != innerText:
        return ""
    return innerText

fn TypedExprFunctionBodyIsStrEmptyReturn(ctx: TypedExprSourceContext,
                                          scope: TypedExprFunctionScope,
                                          params: TypedExprParam[],
                                          returnLineNumber: var int32): bool =
    returnLineNumber = 0
    if scope.returnType != "str" || params.len != 0:
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyCount: int32
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyCount = bodyCount + 1
        if bodyCount == 1:
            if bodyTrim != "var out: str":
                return false
            continue
        if bodyCount == 2:
            if bodyTrim != "return out":
                return false
            returnLineNumber = i + 1
            continue
        return false
    return bodyCount == 2 && returnLineNumber > 0

fn TypedExprFunctionBodyIsI32LetCallThenReturnConst(ctx: TypedExprSourceContext,
                                                     scope: TypedExprFunctionScope,
                                                     returnLineNumber: var int32,
                                                     returnExpr: var str): bool =
    returnLineNumber = 0
    returnExpr = ""
    if scope.returnType != "int32":
        return false
    var bodyCount: int32
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyCount = bodyCount + 1
        if bodyCount == 1:
            if !TypedExprIrBodyTextIsI32LetCall(bodyTrim):
                return false
            continue
        if bodyCount == 2:
            if !parser.ParserStartsWith(bodyTrim, "return "):
                return false
            let exprText = TypedExprReturnExprFromBody(bodyTrim)
            if !TypedExprIrIsI32ConstLiteral(exprText):
                return false
            returnLineNumber = i + 1
            returnExpr = exprText
            continue
        return false
    return bodyCount == 2 && returnLineNumber > 0

fn TypedExprLetCallBindingNameFromBody(bodyTextRaw: str): str =
    let bodyText = chengpath.PathTrim(bodyTextRaw)
    var prefix = ""
    if parser.ParserStartsWith(bodyText, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(bodyText, "var "):
        prefix = "var "
    if prefix == "":
        return ""
    let tail = chengpath.TextSlice(bodyText, len(prefix), bodyText.len - len(prefix))
    let eqPos = TypedExprFindTopLevelTextToken(tail, "=")
    if eqPos <= 0:
        return ""
    let bindingText = chengpath.PathTrim(chengpath.TextSlice(tail, 0, eqPos))
    return parser.ParserIdentPrefix(parser.ParserFirstToken(bindingText))

fn TypedExprFunctionBodyIsI32LetCallThenReturnBinding(ctx: TypedExprSourceContext,
                                                       scope: TypedExprFunctionScope,
                                                       returnLineNumber: var int32,
                                                       bindingName: var str): bool =
    returnLineNumber = 0
    bindingName = ""
    if scope.returnType != "int32":
        return false
    var bodyCount: int32
    var firstBinding = ""
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyCount = bodyCount + 1
        if bodyCount == 1:
            if !TypedExprIrBodyTextIsI32LetCall(bodyTrim):
                return false
            firstBinding = TypedExprLetCallBindingNameFromBody(bodyTrim)
            if firstBinding == "":
                return false
            continue
        if bodyCount == 2:
            if !parser.ParserStartsWith(bodyTrim, "return "):
                return false
            let exprText = TypedExprReturnExprFromBody(bodyTrim)
            if exprText != firstBinding:
                return false
            returnLineNumber = i + 1
            bindingName = firstBinding
            continue
        return false
    return bodyCount == 2 && returnLineNumber > 0 && bindingName != ""

fn TypedExprFunctionBodyIsI32LetCallThenIfResultLeZeroReturnZeroElseBinding(ctx: TypedExprSourceContext,
                                                                             scope: TypedExprFunctionScope,
                                                                             ifLineNumber: var int32,
                                                                             bindingName: var str): bool =
    ifLineNumber = 0
    bindingName = ""
    if scope.returnType != "int32":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    var bodyLineNumbers: int32[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
        add(bodyLineNumbers, i + 1)
    if bodyLines.len != 4:
        return false
    if !TypedExprIrBodyTextIsI32LetCall(bodyLines[0]):
        return false
    let firstBinding = TypedExprLetCallBindingNameFromBody(bodyLines[0])
    if firstBinding == "":
        return false
    if bodyLines[1] != Fmt(["if ", firstBinding, " <= 0:"]):
        return false
    if TypedExprReturnConstTextFromLine(bodyLines[2]) != "0":
        return false
    if TypedExprReturnExprFromBody(bodyLines[3]) != firstBinding:
        return false
    ifLineNumber = bodyLineNumbers[1]
    bindingName = firstBinding
    return true

fn TypedExprFunctionBodyIsStrLetCallThenReturnLen(ctx: TypedExprSourceContext,
                                                   scope: TypedExprFunctionScope,
                                                   returnLineNumber: var int32,
                                                   bindingName: var str): bool =
    returnLineNumber = 0
    bindingName = ""
    if scope.returnType != "int32":
        return false
    var bodyCount: int32
    var firstBinding = ""
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyCount = bodyCount + 1
        if bodyCount == 1:
            if !TypedExprIrBodyTextIsStrLetCall(bodyTrim):
                return false
            firstBinding = TypedExprLetCallBindingNameFromBody(bodyTrim)
            if firstBinding == "":
                return false
            continue
        if bodyCount == 2:
            if !parser.ParserStartsWith(bodyTrim, "return "):
                return false
            let exprText = TypedExprReturnExprFromBody(bodyTrim)
            if TypedExprReturnStrLenFastBindingName(exprText) != firstBinding:
                return false
            returnLineNumber = i + 1
            bindingName = firstBinding
            continue
        return false
    return bodyCount == 2 && returnLineNumber > 0 && bindingName != ""

fn TypedExprCallStatementUsesBindingArg0(bodyTextRaw: str,
                                          bindingName: str): bool =
    let bodyText = chengpath.PathTrim(bodyTextRaw)
    if bindingName == "" || bodyText == "":
        return false
    if parser.ParserStartsWith(bodyText, "return "):
        return false
    let openPos = parser.ParserFindText(bodyText, "(")
    if openPos <= 0:
        return false
    let closePos = TypedExprFindMatchingParen(bodyText, openPos)
    if closePos != bodyText.len - 1:
        return false
    let argLen = closePos - openPos - 1
    if argLen <= 0:
        return false
    let argText = chengpath.PathTrim(chengpath.TextSlice(bodyText, openPos + 1, argLen))
    return argText == bindingName

fn TypedExprFunctionBodyIsStrLetCallThenCallArg0ReturnZero(ctx: TypedExprSourceContext,
                                                            scope: TypedExprFunctionScope,
                                                            secondCallLineNumber: var int32,
                                                            returnLineNumber: var int32,
                                                            bindingName: var str): bool =
    secondCallLineNumber = 0
    returnLineNumber = 0
    bindingName = ""
    if scope.returnType != "int32":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    var bodyLineNumbers: int32[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
        add(bodyLineNumbers, i + 1)
    if bodyLines.len != 3:
        return false
    if !TypedExprIrBodyTextIsStrLetCall(bodyLines[0]):
        return false
    let firstBinding = TypedExprLetCallBindingNameFromBody(bodyLines[0])
    if firstBinding == "":
        return false
    if !TypedExprCallStatementUsesBindingArg0(bodyLines[1], firstBinding):
        return false
    if TypedExprReturnConstTextFromLine(bodyLines[2]) != "0":
        return false
    secondCallLineNumber = bodyLineNumbers[1]
    returnLineNumber = bodyLineNumbers[2]
    bindingName = firstBinding
    return true

fn TypedExprFunctionBodyIsStrI32GuardArg0ReturnZero(ctx: TypedExprSourceContext,
                                                     scope: TypedExprFunctionScope,
                                                     secondCallLineNumber: var int32,
                                                     countCallLineNumber: var int32,
                                                     guardCallLineNumber: var int32,
                                                     returnLineNumber: var int32,
                                                     bindingName: var str): bool =
    secondCallLineNumber = 0
    countCallLineNumber = 0
    guardCallLineNumber = 0
    returnLineNumber = 0
    bindingName = ""
    if scope.returnType != "int32":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    var bodyLineNumbers: int32[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if bodyTrim == "":
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
        add(bodyLineNumbers, i + 1)
    if bodyLines.len != 7:
        return false
    if !TypedExprIrBodyTextIsStrLetCall(bodyLines[0]):
        return false
    let firstBinding = TypedExprLetCallBindingNameFromBody(bodyLines[0])
    if firstBinding == "":
        return false
    if !TypedExprCallStatementUsesBindingArg0(bodyLines[1], firstBinding):
        return false
    if !TypedExprIrBodyTextIsI32LetCall(bodyLines[2]):
        return false
    let countBinding = TypedExprLetCallBindingNameFromBody(bodyLines[2])
    if countBinding == "":
        return false
    if bodyLines[3] != Fmt(["if ", countBinding, " <= 0:"]):
        return false
    if !TypedExprCallStatementUsesBindingArg0(bodyLines[4], firstBinding):
        return false
    if TypedExprReturnConstTextFromLine(bodyLines[5]) != "0":
        return false
    if TypedExprReturnConstTextFromLine(bodyLines[6]) != "0":
        return false
    secondCallLineNumber = bodyLineNumbers[1]
    countCallLineNumber = bodyLineNumbers[2]
    guardCallLineNumber = bodyLineNumbers[4]
    returnLineNumber = bodyLineNumbers[6]
    bindingName = firstBinding
    return true

fn TypedExprIrAddLetCallNode(ir: var TypedExprIr,
                              sourcePath: str,
                              functionName: str,
                              lineNumber: int32,
                              bodyText: str): int32 =
    return TypedExprIrAddOpNode(ir,
                                sourcePath,
                                functionName,
                                lineNumber,
                                TypedExprIrOpLetCall,
                                "",
                                bodyText,
                                -1,
                                -1,
                                -1)

