fn TypedExprIrAddLetCallStrThenCallArg0ReturnI32Const0Node(ir: var TypedExprIr,
                                                            sourcePath: str,
                                                            functionName: str,
                                                            returnLineNumber: int32,
                                                            secondCallLineNumber: int32,
                                                            bindingName: str): int32 =
