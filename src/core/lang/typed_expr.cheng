    return count

fn TypedExprFactCountCallResolved(facts: var TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind == TypedExprSurfaceCallNone:
            continue
        if facts[i].callResolved:
            count = count + 1
    return count

fn TypedExprFactCountCallUnresolved(facts: var TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind == TypedExprSurfaceCallNone:
            continue
        if !facts[i].callResolved:
            count = count + 1
    return count

fn TypedExprFactCountCallReason(facts: var TypedExprFact[],
                                  reason: TypedExprCallReason): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].callReason != reason:
            continue
        count = count + 1
    return count

fn TypedExprFactCountCallTargetImportc(facts: var TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].callTargetImportc:
            count = count + 1
