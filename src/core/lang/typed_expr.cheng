import std/buffer
import std/rawbytes
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser

type
    TypedExprAbiClass = enum
        TypedExprAbiScalar
        TypedExprAbiComposite
        TypedExprAbiPointerLike
        TypedExprAbiPolymorphic

    TypedExprValueKind = enum
        TypedExprValueScalar
        TypedExprValueComposite
        TypedExprValuePointerLike
        TypedExprValuePolymorphic

    TypedExprPlaceKind = enum
        TypedExprPlaceLocal
        TypedExprPlaceGlobal
        TypedExprPlaceField
        TypedExprPlaceTemporary
        TypedExprPlaceCallResult

    TypedExprLoweringMode = enum
        TypedExprLowerReg
        TypedExprLowerLocalAddress
        TypedExprLowerSret
        TypedExprLowerImportBuffer
        TypedExprLowerDeferred

    TypedExprCallKind = enum
        TypedExprCallNone
        TypedExprCallBuiltin
        TypedExprCallResultIntrinsic
        TypedExprCallProjection

    TypedExprTypeCallKind = enum
        TypedExprTypeCallNone
        TypedExprTypeCallDefaultInit
        TypedExprTypeCallConstructor

    TypedExprSurfaceCallKind = enum
        TypedExprSurfaceCallNone
        TypedExprSurfaceCallLocal
        TypedExprSurfaceCallExternal
        TypedExprSurfaceCallImportc
        TypedExprSurfaceCallMember

    TypedExprCallReason = enum
        TypedExprCallReasonNone
        TypedExprCallReasonUnknownQualifiedTarget
        TypedExprCallReasonShadowedQualifiedTarget
        TypedExprCallReasonAmbiguousExternalTarget
        TypedExprCallReasonAmbiguousQualifiedTarget
        TypedExprCallReasonUnknownExternalTarget
        TypedExprCallReasonUnknownCallTarget

    TypedExprReturnKind = enum
        TypedExprReturnReg
        TypedExprReturnCompositeLocal
        TypedExprReturnSret
        TypedExprReturnImportBuffer
        TypedExprReturnDeferred

    TypedExprArgPassKind = enum
        TypedExprArgPassValue
        TypedExprArgPassAddress
        TypedExprArgPassCallResultAddress
        TypedExprArgPassDeferred

    TypedExprResultPassKind = enum
        TypedExprResultPassReg
        TypedExprResultPassLocalAddress
        TypedExprResultPassSret
        TypedExprResultPassImportBuffer
        TypedExprResultPassDeferred

    TypedExprMaterializeKind = enum
        TypedExprMaterializeNone
        TypedExprMaterializeRegister
        TypedExprMaterializeLocalSlot
        TypedExprMaterializeCallResultLocal
        TypedExprMaterializeDestAddress
        TypedExprMaterializeImportBuffer
        TypedExprMaterializeDeferred

    TypedExprCopyKind = enum
        TypedExprCopyNone
        TypedExprCopyScalarStore
        TypedExprCopyRegionCopy
        TypedExprCopyDeferred

    TypedExprImportKind = enum
        TypedExprImportI32ValueSlot
        TypedExprImportI32AddressSlot
        TypedExprImportBuiltinValueSlot
        TypedExprImportBuiltinAddressSlot
        TypedExprImportImportBuffer
        TypedExprImportDeferred

    TypedExprFact =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: parser.NormalizedExprKind
        surfaceCallKind: TypedExprSurfaceCallKind
        callResolved: bool
        callReason: TypedExprCallReason
        callQualifier: str
        callCallee: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callPrefixStyle: bool
        callArgCount: int32
        callArgsText: str
        typeText: str
        abiClass: TypedExprAbiClass
        valueKind: TypedExprValueKind
        placeKind: TypedExprPlaceKind
        loweringMode: TypedExprLoweringMode
        callKind: TypedExprCallKind
        typeCallKind: TypedExprTypeCallKind
        returnKind: TypedExprReturnKind

    TypedExprLoweringRule =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        surfaceCallKind: TypedExprSurfaceCallKind
        callResolved: bool
        callReason: TypedExprCallReason
        callQualifier: str
        callCallee: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callPrefixStyle: bool
        callArgCount: int32
        callArgsText: str
        typeText: str
        abiClass: TypedExprAbiClass
        valueKind: TypedExprValueKind
        placeKind: TypedExprPlaceKind
        loweringMode: TypedExprLoweringMode
        callKind: TypedExprCallKind
        typeCallKind: TypedExprTypeCallKind
        returnKind: TypedExprReturnKind
        argPassKind: TypedExprArgPassKind
        resultPassKind: TypedExprResultPassKind
        materializeKind: TypedExprMaterializeKind
        copyKind: TypedExprCopyKind
        importKind: TypedExprImportKind

    TypedExprSourceText =
        workspaceRoot: str
        packageRoot: str
        externalPackageRoots: parser.ParserExternalPackageRoot[]
        sourcePath: str
        text: str

    TypedExprFunctionScope =
        sourcePath: str
        name: str
        startLine: int32
        endLine: int32
        returnType: str

    TypedExprBinding =
        sourcePath: str
        functionName: str
        globalFlag: bool
        lineNumber: int32
        name: str
        typeText: str

    TypedExprImportcFunction =
        sourcePath: str
        name: str
        returnType: str

    TypedExprImportedModule =
        qualifier: str
        targetSourcePath: str

    TypedExprLineExprColumns =
        columns: int32[]

    TypedExprSourceContext =
        sourcePath: str
        lines: str[]
        scopes: TypedExprFunctionScope[]
        bindings: TypedExprBinding[]
        importcFunctions: TypedExprImportcFunction[]
        importedModules: TypedExprImportedModule[]
        declaredTypes: str[]
        exprLineColumns: TypedExprLineExprColumns[]

    TypedExprSinkInfo =
        sinkType: str
        sinkPlaceKind: TypedExprPlaceKind
        hasSink: bool
        returnRoot: bool
        functionReturnType: str

fn TypedExprAbiClassText(abiClass: TypedExprAbiClass): str =
    if abiClass == TypedExprAbiScalar:
        return "scalar"
    if abiClass == TypedExprAbiComposite:
        return "composite"
    if abiClass == TypedExprAbiPointerLike:
        return "pointer_like"
    return "polymorphic"

fn TypedExprValueKindText(valueKind: TypedExprValueKind): str =
    if valueKind == TypedExprValueScalar:
        return "scalar"
    if valueKind == TypedExprValueComposite:
        return "composite"
    if valueKind == TypedExprValuePointerLike:
        return "pointer_like"
    return "polymorphic"

fn TypedExprPlaceKindText(placeKind: TypedExprPlaceKind): str =
    if placeKind == TypedExprPlaceLocal:
        return "local"
    if placeKind == TypedExprPlaceGlobal:
        return "global"
    if placeKind == TypedExprPlaceField:
        return "field"
    if placeKind == TypedExprPlaceCallResult:
        return "call_result"
    return "temporary"

fn TypedExprLoweringModeText(loweringMode: TypedExprLoweringMode): str =
    if loweringMode == TypedExprLowerReg:
        return "reg"
    if loweringMode == TypedExprLowerLocalAddress:
        return "local_address"
    if loweringMode == TypedExprLowerSret:
        return "sret"
    if loweringMode == TypedExprLowerImportBuffer:
        return "import_buffer"
    return "deferred"

fn TypedExprCallKindText(callKind: TypedExprCallKind): str =
    if callKind == TypedExprCallBuiltin:
        return "builtin"
    if callKind == TypedExprCallResultIntrinsic:
        return "result_intrinsic"
    if callKind == TypedExprCallProjection:
        return "projection"
    return "none"

fn TypedExprTypeCallKindText(typeCallKind: TypedExprTypeCallKind): str =
    if typeCallKind == TypedExprTypeCallDefaultInit:
        return "default_init"
    if typeCallKind == TypedExprTypeCallConstructor:
        return "constructor"
    return "none"

fn TypedExprSurfaceCallKindText(kind: TypedExprSurfaceCallKind): str =
    if kind == TypedExprSurfaceCallLocal:
        return "local_call"
    if kind == TypedExprSurfaceCallExternal:
        return "external_call"
    if kind == TypedExprSurfaceCallImportc:
        return "importc_call"
    if kind == TypedExprSurfaceCallMember:
        return "member_call"
    return "none"

fn TypedExprCallReasonText(reason: TypedExprCallReason): str =
    if reason == TypedExprCallReasonUnknownQualifiedTarget:
        return "unknown_qualified_target"
    if reason == TypedExprCallReasonShadowedQualifiedTarget:
        return "shadowed_qualified_target"
    if reason == TypedExprCallReasonAmbiguousExternalTarget:
        return "ambiguous_external_target"
    if reason == TypedExprCallReasonAmbiguousQualifiedTarget:
        return "ambiguous_qualified_target"
    if reason == TypedExprCallReasonUnknownExternalTarget:
        return "unknown_external_target"
    if reason == TypedExprCallReasonUnknownCallTarget:
        return "unknown_call_target"
    return ""

fn TypedExprSurfaceCallKindFromParser(kind: parser.NormalizedExprSurfaceCallKind): TypedExprSurfaceCallKind =
    if kind == parser.NormalizedExprSurfaceCallLocal:
        return TypedExprSurfaceCallLocal
    if kind == parser.NormalizedExprSurfaceCallExternal:
        return TypedExprSurfaceCallExternal
    if kind == parser.NormalizedExprSurfaceCallImportc:
        return TypedExprSurfaceCallImportc
    if kind == parser.NormalizedExprSurfaceCallMember:
        return TypedExprSurfaceCallMember
    return TypedExprSurfaceCallNone

fn TypedExprCallReasonFromParser(reason: parser.NormalizedExprCallReason): TypedExprCallReason =
    if reason == parser.NormalizedExprCallReasonUnknownQualifiedTarget:
        return TypedExprCallReasonUnknownQualifiedTarget
    if reason == parser.NormalizedExprCallReasonShadowedQualifiedTarget:
        return TypedExprCallReasonShadowedQualifiedTarget
    if reason == parser.NormalizedExprCallReasonAmbiguousExternalTarget:
        return TypedExprCallReasonAmbiguousExternalTarget
    if reason == parser.NormalizedExprCallReasonAmbiguousQualifiedTarget:
        return TypedExprCallReasonAmbiguousQualifiedTarget
    if reason == parser.NormalizedExprCallReasonUnknownExternalTarget:
        return TypedExprCallReasonUnknownExternalTarget
    if reason == parser.NormalizedExprCallReasonUnknownCallTarget:
        return TypedExprCallReasonUnknownCallTarget
    return TypedExprCallReasonNone

fn TypedExprReturnKindText(returnKind: TypedExprReturnKind): str =
    if returnKind == TypedExprReturnReg:
        return "reg"
    if returnKind == TypedExprReturnCompositeLocal:
        return "composite_local"
    if returnKind == TypedExprReturnSret:
        return "sret"
    if returnKind == TypedExprReturnImportBuffer:
        return "import_buffer"
    return "deferred"

fn TypedExprArgPassKindText(kind: TypedExprArgPassKind): str =
    if kind == TypedExprArgPassValue:
        return "value"
    if kind == TypedExprArgPassAddress:
        return "address"
    if kind == TypedExprArgPassCallResultAddress:
        return "call_result_address"
    return "deferred"

fn TypedExprArgPassKindForResolved(abiClass: TypedExprAbiClass,
                                     placeKind: TypedExprPlaceKind,
                                     loweringMode: TypedExprLoweringMode): TypedExprArgPassKind =
    if loweringMode == TypedExprLowerDeferred || abiClass == TypedExprAbiPolymorphic:
        return TypedExprArgPassDeferred
    if abiClass == TypedExprAbiComposite:
        if placeKind == TypedExprPlaceCallResult:
            return TypedExprArgPassCallResultAddress
        return TypedExprArgPassAddress
    return TypedExprArgPassValue

fn TypedExprResultPassKindText(kind: TypedExprResultPassKind): str =
    if kind == TypedExprResultPassReg:
        return "reg"
    if kind == TypedExprResultPassLocalAddress:
        return "local_address"
    if kind == TypedExprResultPassSret:
        return "sret"
    if kind == TypedExprResultPassImportBuffer:
        return "import_buffer"
    return "deferred"

fn TypedExprResultPassKindForResolved(returnKind: TypedExprReturnKind): TypedExprResultPassKind =
    if returnKind == TypedExprReturnReg:
        return TypedExprResultPassReg
    if returnKind == TypedExprReturnCompositeLocal:
        return TypedExprResultPassLocalAddress
    if returnKind == TypedExprReturnSret:
        return TypedExprResultPassSret
    if returnKind == TypedExprReturnImportBuffer:
        return TypedExprResultPassImportBuffer
    return TypedExprResultPassDeferred

fn TypedExprMaterializeKindText(kind: TypedExprMaterializeKind): str =
    if kind == TypedExprMaterializeDestAddress:
        return "dest_address"
    if kind == TypedExprMaterializeImportBuffer:
        return "import_buffer"
    if kind == TypedExprMaterializeCallResultLocal:
        return "call_result_local"
    if kind == TypedExprMaterializeLocalSlot:
        return "local_slot"
    if kind == TypedExprMaterializeRegister:
        return "register"
    if kind == TypedExprMaterializeDeferred:
        return "deferred"
    return "none"

fn TypedExprMaterializeKindForResolved(valueKind: TypedExprValueKind,
                                         placeKind: TypedExprPlaceKind,
                                         loweringMode: TypedExprLoweringMode): TypedExprMaterializeKind =
    if loweringMode == TypedExprLowerDeferred || valueKind == TypedExprValuePolymorphic:
        return TypedExprMaterializeDeferred
    if loweringMode == TypedExprLowerSret:
        return TypedExprMaterializeDestAddress
    if loweringMode == TypedExprLowerImportBuffer:
        return TypedExprMaterializeImportBuffer
    if valueKind == TypedExprValueComposite:
        if placeKind == TypedExprPlaceCallResult:
            return TypedExprMaterializeCallResultLocal
        return TypedExprMaterializeLocalSlot
    if loweringMode == TypedExprLowerReg:
        return TypedExprMaterializeRegister
    return TypedExprMaterializeNone

fn TypedExprCopyKindText(kind: TypedExprCopyKind): str =
    if kind == TypedExprCopyRegionCopy:
        return "region_copy"
    if kind == TypedExprCopyScalarStore:
        return "scalar_store"
    if kind == TypedExprCopyDeferred:
        return "deferred"
    return "none"

fn TypedExprCopyKindForResolved(valueKind: TypedExprValueKind,
                                  abiClass: TypedExprAbiClass): TypedExprCopyKind =
    if abiClass == TypedExprAbiPolymorphic || valueKind == TypedExprValuePolymorphic:
        return TypedExprCopyDeferred
    if valueKind == TypedExprValueComposite:
        return TypedExprCopyRegionCopy
    if valueKind == TypedExprValueScalar || valueKind == TypedExprValuePointerLike:
        return TypedExprCopyScalarStore
    return TypedExprCopyNone

fn TypedExprImportKindText(kind: TypedExprImportKind): str =
    if kind == TypedExprImportImportBuffer:
        return "import_buffer"
    if kind == TypedExprImportBuiltinAddressSlot:
        return "builtin_address_slot"
    if kind == TypedExprImportBuiltinValueSlot:
        return "builtin_value_slot"
    if kind == TypedExprImportI32AddressSlot:
        return "i32_address_slot"
    if kind == TypedExprImportI32ValueSlot:
        return "i32_value_slot"
    return "deferred"

fn TypedExprImportKindForResolved(callKind: TypedExprCallKind,
                                    abiClass: TypedExprAbiClass,
                                    loweringMode: TypedExprLoweringMode,
                                    returnKind: TypedExprReturnKind): TypedExprImportKind =
    if loweringMode == TypedExprLowerDeferred || abiClass == TypedExprAbiPolymorphic:
        return TypedExprImportDeferred
    if loweringMode == TypedExprLowerImportBuffer || returnKind == TypedExprReturnImportBuffer:
        return TypedExprImportImportBuffer
    if callKind == TypedExprCallBuiltin:
        if abiClass == TypedExprAbiComposite:
            return TypedExprImportBuiltinAddressSlot
        return TypedExprImportBuiltinValueSlot
    if abiClass == TypedExprAbiComposite:
        return TypedExprImportI32AddressSlot
    return TypedExprImportI32ValueSlot

fn TypedExprExprIsBuiltinStringifyCall(expr: parser.NormalizedExpr): bool =
    if expr.kind != parser.NormalizedExprCall:
        return false
    if expr.callCallee == "$" || expr.callTarget == "$":
        return true
    return false

fn TypedExprCallKindForExpr(expr: parser.NormalizedExpr): TypedExprCallKind =
    if expr.kind == parser.NormalizedExprStrFormat:
        return TypedExprCallBuiltin
    if TypedExprExprIsBuiltinStringifyCall(expr):
        return TypedExprCallBuiltin
    if expr.kind == parser.NormalizedExprResultIntrinsic:
        return TypedExprCallResultIntrinsic
    if expr.kind == parser.NormalizedExprTry:
        return TypedExprCallProjection
    return TypedExprCallNone

fn TypedExprTypeCallKindForExpr(expr: parser.NormalizedExpr): TypedExprTypeCallKind =
    if expr.kind == parser.NormalizedExprDefaultInit:
        return TypedExprTypeCallDefaultInit
    if expr.kind == parser.NormalizedExprConstructor:
        return TypedExprTypeCallConstructor
    return TypedExprTypeCallNone

fn TypedExprReturnKindForResolved(abiClass: TypedExprAbiClass,
                                    loweringMode: TypedExprLoweringMode): TypedExprReturnKind =
    if loweringMode == TypedExprLowerSret:
        return TypedExprReturnSret
    if loweringMode == TypedExprLowerImportBuffer:
        return TypedExprReturnImportBuffer
    if loweringMode == TypedExprLowerDeferred || abiClass == TypedExprAbiPolymorphic:
        return TypedExprReturnDeferred
    if abiClass == TypedExprAbiComposite:
        return TypedExprReturnCompositeLocal
    return TypedExprReturnReg

fn TypedExprFactClone(fact: TypedExprFact): TypedExprFact =
    var out: TypedExprFact
    out.exprId = fact.exprId
    out.sourcePath = fact.sourcePath
    out.lineNumber = fact.lineNumber
    out.columnNumber = fact.columnNumber
    out.endLineNumber = fact.endLineNumber
    out.endColumnNumber = fact.endColumnNumber
    out.kind = fact.kind
    out.surfaceCallKind = fact.surfaceCallKind
    out.callResolved = fact.callResolved
    out.callReason = fact.callReason
    out.callQualifier = fact.callQualifier
    out.callCallee = fact.callCallee
    out.callTarget = fact.callTarget
    out.callTargetSourcePath = fact.callTargetSourcePath
    out.callTargetImportc = fact.callTargetImportc
    out.callPrefixStyle = fact.callPrefixStyle
    out.callArgCount = fact.callArgCount
    out.callArgsText = fact.callArgsText
    out.typeText = fact.typeText
    out.abiClass = fact.abiClass
    out.valueKind = fact.valueKind
    out.placeKind = fact.placeKind
    out.loweringMode = fact.loweringMode
    out.callKind = fact.callKind
    out.typeCallKind = fact.typeCallKind
    out.returnKind = fact.returnKind
    return out

fn TypedExprFactsClone(facts: TypedExprFact[]): TypedExprFact[] =
    var out: TypedExprFact[]
    for i in 0..<facts.len:
        add(out, TypedExprFactClone(facts[i]))
    return out

fn TypedExprFactEqual(lhs: TypedExprFact,
                        rhs: TypedExprFact): bool =
    if lhs.exprId != rhs.exprId:
        return false
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.lineNumber != rhs.lineNumber:
        return false
    if lhs.columnNumber != rhs.columnNumber:
        return false
    if lhs.endLineNumber != rhs.endLineNumber:
        return false
    if lhs.endColumnNumber != rhs.endColumnNumber:
        return false
    if lhs.kind != rhs.kind:
        return false
    if lhs.surfaceCallKind != rhs.surfaceCallKind:
        return false
    if lhs.callResolved != rhs.callResolved:
        return false
    if lhs.callReason != rhs.callReason:
        return false
    if lhs.callQualifier != rhs.callQualifier:
        return false
    if lhs.callCallee != rhs.callCallee:
        return false
    if lhs.callTarget != rhs.callTarget:
        return false
    if lhs.callTargetSourcePath != rhs.callTargetSourcePath:
        return false
    if lhs.callTargetImportc != rhs.callTargetImportc:
        return false
    if lhs.callPrefixStyle != rhs.callPrefixStyle:
        return false
    if lhs.callArgCount != rhs.callArgCount:
        return false
    if lhs.callArgsText != rhs.callArgsText:
        return false
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    return lhs.returnKind == rhs.returnKind

fn TypedExprFactsEqual(lhs: TypedExprFact[],
                         rhs: TypedExprFact[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !TypedExprFactEqual(lhs[i], rhs[i]):
            return false
    return true

fn TypedExprFactCountAbiClass(facts: TypedExprFact[],
                                abiClass: TypedExprAbiClass): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].abiClass == abiClass:
            count = count + 1
    return count

fn TypedExprFactCountValueKind(facts: TypedExprFact[],
                                 valueKind: TypedExprValueKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].valueKind == valueKind:
            count = count + 1
    return count

fn TypedExprFactCountPlaceKind(facts: TypedExprFact[],
                                 placeKind: TypedExprPlaceKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].placeKind == placeKind:
            count = count + 1
    return count

fn TypedExprFactCountLoweringMode(facts: TypedExprFact[],
                                    loweringMode: TypedExprLoweringMode): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].loweringMode == loweringMode:
            count = count + 1
    return count

fn TypedExprFactCountCallKind(facts: TypedExprFact[],
                                callKind: TypedExprCallKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].callKind == callKind:
            count = count + 1
    return count

fn TypedExprFactCountTypeCallKind(facts: TypedExprFact[],
                                    typeCallKind: TypedExprTypeCallKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].typeCallKind == typeCallKind:
            count = count + 1
    return count

fn TypedExprFactCountReturnKind(facts: TypedExprFact[],
                                  returnKind: TypedExprReturnKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].returnKind == returnKind:
            count = count + 1
    return count

fn TypedExprFactCountSurfaceCallKind(facts: TypedExprFact[],
                                       kind: TypedExprSurfaceCallKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind == kind:
            count = count + 1
    return count

fn TypedExprFactCountCallResolved(facts: TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind == TypedExprSurfaceCallNone:
            continue
        if facts[i].callResolved:
            count = count + 1
    return count

fn TypedExprFactCountCallUnresolved(facts: TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind == TypedExprSurfaceCallNone:
            continue
        if !facts[i].callResolved:
            count = count + 1
    return count

fn TypedExprFactCountCallReason(facts: TypedExprFact[],
                                  reason: TypedExprCallReason): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].callReason != reason:
            continue
        count = count + 1
    return count

fn TypedExprFactCountCallTargetImportc(facts: TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].callTargetImportc:
            count = count + 1
    return count

fn TypedExprAbiScalarCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountAbiClass(facts, TypedExprAbiScalar)

fn TypedExprAbiCompositeCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountAbiClass(facts, TypedExprAbiComposite)

fn TypedExprAbiPointerLikeCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountAbiClass(facts, TypedExprAbiPointerLike)

fn TypedExprAbiPolymorphicCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountAbiClass(facts, TypedExprAbiPolymorphic)

fn TypedExprValueScalarCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountValueKind(facts, TypedExprValueScalar)

fn TypedExprValueCompositeCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountValueKind(facts, TypedExprValueComposite)

fn TypedExprValuePointerLikeCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountValueKind(facts, TypedExprValuePointerLike)

fn TypedExprValuePolymorphicCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountValueKind(facts, TypedExprValuePolymorphic)

fn TypedExprPlaceLocalCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountPlaceKind(facts, TypedExprPlaceLocal)

fn TypedExprPlaceGlobalCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountPlaceKind(facts, TypedExprPlaceGlobal)

fn TypedExprPlaceFieldCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountPlaceKind(facts, TypedExprPlaceField)

fn TypedExprPlaceTemporaryCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountPlaceKind(facts, TypedExprPlaceTemporary)

fn TypedExprPlaceCallResultCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountPlaceKind(facts, TypedExprPlaceCallResult)

fn TypedExprLowerRegCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountLoweringMode(facts, TypedExprLowerReg)

fn TypedExprLowerLocalAddressCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountLoweringMode(facts, TypedExprLowerLocalAddress)

fn TypedExprLowerSretCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountLoweringMode(facts, TypedExprLowerSret)

fn TypedExprLowerImportBufferCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountLoweringMode(facts, TypedExprLowerImportBuffer)

fn TypedExprLowerDeferredCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountLoweringMode(facts, TypedExprLowerDeferred)

fn TypedExprCallNoneCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountCallKind(facts, TypedExprCallNone)

fn TypedExprCallBuiltinCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountCallKind(facts, TypedExprCallBuiltin)

fn TypedExprCallResultIntrinsicCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountCallKind(facts, TypedExprCallResultIntrinsic)

fn TypedExprCallProjectionCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountCallKind(facts, TypedExprCallProjection)

fn TypedExprTypeCallNoneCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountTypeCallKind(facts, TypedExprTypeCallNone)

fn TypedExprTypeCallDefaultInitCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountTypeCallKind(facts, TypedExprTypeCallDefaultInit)

fn TypedExprTypeCallConstructorCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountTypeCallKind(facts, TypedExprTypeCallConstructor)

fn TypedExprReturnRegCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountReturnKind(facts, TypedExprReturnReg)

fn TypedExprReturnCompositeLocalCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountReturnKind(facts, TypedExprReturnCompositeLocal)

fn TypedExprReturnSretCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountReturnKind(facts, TypedExprReturnSret)

fn TypedExprReturnImportBufferCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountReturnKind(facts, TypedExprReturnImportBuffer)

fn TypedExprReturnDeferredCount(facts: TypedExprFact[]): int32 =
    return TypedExprFactCountReturnKind(facts, TypedExprReturnDeferred)

fn TypedExprFactCountSurfaceCallKindFromParser(facts: TypedExprFact[],
                                                 kind: parser.NormalizedExprSurfaceCallKind): int32 =
    return TypedExprFactCountSurfaceCallKind(facts, TypedExprSurfaceCallKindFromParser(kind))

fn TypedExprSurfaceCallCount(facts: TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind != TypedExprSurfaceCallNone:
            count = count + 1
    return count

fn TypedExprFactCountCallReasonFromParser(facts: TypedExprFact[],
                                            reason: parser.NormalizedExprCallReason): int32 =
    return TypedExprFactCountCallReason(facts, TypedExprCallReasonFromParser(reason))

fn TypedExprFactsForSource(facts: TypedExprFact[],
                             sourcePathRaw: str): TypedExprFact[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    var out: TypedExprFact[]
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        add(out, TypedExprFactClone(facts[i]))
    return out

fn TypedExprFactUsesImportBuffer(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerImportBuffer &&
           fact.returnKind == TypedExprReturnImportBuffer

fn TypedExprFactUsesLocalAddressCompositeLocal(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerLocalAddress &&
           fact.returnKind == TypedExprReturnCompositeLocal

fn TypedExprFactUsesRegReturnReg(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerReg &&
           fact.returnKind == TypedExprReturnReg

fn TypedExprFactUsesTypeCallMaterialize(fact: TypedExprFact): bool =
    return fact.typeCallKind == TypedExprTypeCallDefaultInit ||
           fact.typeCallKind == TypedExprTypeCallConstructor

fn TypedExprFactAbiIsPolymorphic(fact: TypedExprFact): bool =
    return fact.abiClass == TypedExprAbiPolymorphic

fn TypedExprTypeTextIsConcrete(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "unknown" ||
       typeText == "default_init_expr" ||
       typeText == "constructor_expr" ||
       typeText == "call_expr" ||
       typeText == "branch_join" ||
       typeText == "result_projection":
        return false
    return parser.ParserFindText(typeText, "unknown") < 0

fn TypedExprFactValidateTypeCallMaterialize(fact: TypedExprFact,
                                              err: var str): bool =
    if fact.typeCallKind == TypedExprTypeCallNone:
        return true
    if fact.kind != parser.NormalizedExprDefaultInit &&
       fact.kind != parser.NormalizedExprConstructor:
        err = " typed expr: type-call fact kind drift at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.callKind != TypedExprCallNone:
        err = " typed expr: type-call fact leaked ordinary call kind at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if !TypedExprTypeTextIsConcrete(fact.typeText):
        err = " typed expr: type-call fact missing concrete type at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.abiClass != TypedExprAbiComposite ||
       fact.valueKind != TypedExprValueComposite:
        err = " typed expr: type-call fact must materialize composite at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.placeKind == TypedExprPlaceCallResult:
        err = " typed expr: type-call fact cannot use call-result place at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.loweringMode != TypedExprLowerLocalAddress &&
       fact.loweringMode != TypedExprLowerSret:
        err = " typed expr: type-call fact missing address lowering at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.loweringMode == TypedExprLowerLocalAddress &&
       fact.returnKind != TypedExprReturnCompositeLocal:
        err = " typed expr: type-call fact local-address return drift at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    if fact.loweringMode == TypedExprLowerSret &&
       fact.returnKind != TypedExprReturnSret:
        err = " typed expr: type-call fact sret return drift at " + fact.sourcePath + ":" + intToStr(fact.lineNumber)
        return false
    err = ""
    return true

fn TypedExprFactsHasLineUsingImportBuffer(facts: TypedExprFact[],
                                            sourcePathRaw: str,
                                            lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesImportBuffer(facts[i]):
            return true
    return false

fn TypedExprFactsHasLineUsingLocalAddressCompositeLocal(facts: TypedExprFact[],
                                                          sourcePathRaw: str,
                                                          lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesLocalAddressCompositeLocal(facts[i]):
            return true
    return false

fn TypedExprFactsHasLineUsingRegReturnReg(facts: TypedExprFact[],
                                            sourcePathRaw: str,
                                            lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesRegReturnReg(facts[i]):
            return true
    return false

fn TypedExprTypeIsGenericPlaceholder(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText.len == 1 && typeText[0] >= 'A' && typeText[0] <= 'Z':
        return true
    if typeText.len != 4:
        return false
    if chengpath.TextSlice(typeText, 0, 3) != "ref":
        return false
    if typeText[3] < 'A' || typeText[3] > 'Z':
        return false
    return true

fn TypedExprFactsValidateCallResolution(exprLayer: parser.NormalizedExprLayer,
                                          facts: TypedExprFact[],
                                          err: var str): bool =
    if exprLayer.exprs.len != facts.len:
        err = " typed expr: call fact count mismatch"
        return false
    for i in 0..<facts.len:
        let expr = exprLayer.exprs[i]
        let fact = facts[i]
        let expectedTypeCallKind = TypedExprTypeCallKindForExpr(expr)
        if expr.exprId != fact.exprId:
            err = " typed expr: expr id mismatch"
            return false
        if expr.kind != fact.kind:
            err = " typed expr: expr kind mismatch"
            return false
        if expr.kind != parser.NormalizedExprCall:
            if fact.surfaceCallKind != TypedExprSurfaceCallNone ||
               fact.callResolved ||
               fact.callReason != TypedExprCallReasonNone ||
               fact.callQualifier != "" ||
               fact.callCallee != "" ||
               fact.callTarget != "" ||
               fact.callTargetSourcePath != "" ||
               fact.callTargetImportc:
                err = " typed expr: non-call fact leaked call resolution at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            if fact.typeCallKind != expectedTypeCallKind:
                err = " typed expr: non-call fact leaked type-call drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            if expectedTypeCallKind != TypedExprTypeCallNone:
                if fact.callPrefixStyle != expr.callPrefixStyle ||
                   fact.callArgCount != expr.callArgCount ||
                   fact.callArgsText != expr.callArgsText:
                    err = " typed expr: type-call fact args drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                    return false
                if !TypedExprFactValidateTypeCallMaterialize(fact, err):
                    return false
            elif fact.callPrefixStyle ||
                 fact.callArgCount != 0 ||
                 fact.callArgsText != "":
                err = " typed expr: non-call fact leaked call args at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            continue
        if fact.typeCallKind != TypedExprTypeCallNone:
            err = " typed expr: call fact leaked type-call kind at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        let surfaceKind = TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind)
        let resolved = expr.callResolved
        let reason = TypedExprCallReasonFromParser(expr.callReason)
        let qualifier = expr.callQualifier
        let callee = expr.callCallee
        let target = expr.callTarget
        let targetSourcePath = expr.callTargetSourcePath
        let targetImportc = expr.callTargetImportc
        if fact.surfaceCallKind != surfaceKind:
            err = " typed expr: call surface kind drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callResolved != resolved:
            err = " typed expr: call resolved drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callReason != reason:
            err = " typed expr: call reason drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callQualifier != qualifier:
            err = " typed expr: call qualifier drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callCallee != callee:
            err = " typed expr: call callee drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callTarget != target:
            err = " typed expr: call target drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callTargetSourcePath != targetSourcePath:
            err = " typed expr: call target source drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callTargetImportc != targetImportc:
            err = " typed expr: call importc drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callPrefixStyle != expr.callPrefixStyle:
            err = " typed expr: call prefix style drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callArgCount != expr.callArgCount:
            err = " typed expr: call arg count drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callArgsText != expr.callArgsText:
            err = " typed expr: call args text drift at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callResolved:
            if fact.callReason != TypedExprCallReasonNone:
                err = " typed expr: resolved call keeps unknown reason at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            if fact.callTargetSourcePath == "":
                err = " typed expr: resolved call missing target source at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            if fact.typeText == "" || fact.typeText == "unknown" || fact.typeText == "call_expr":
                err = " typed expr: resolved call missing concrete type at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            if !TypedExprTypeIsGenericPlaceholder(fact.typeText) &&
               (fact.abiClass == TypedExprAbiPolymorphic ||
                fact.loweringMode == TypedExprLowerDeferred ||
                fact.returnKind == TypedExprReturnDeferred):
                err = " typed expr: resolved call fell back to deferred at " +
                      expr.sourcePath + ":" + intToStr(expr.lineNumber) +
                      " target=" + fact.callTarget +
                      " type=" + fact.typeText +
                      " abi=" + TypedExprAbiClassText(fact.abiClass) +
                      " lower=" + TypedExprLoweringModeText(fact.loweringMode) +
                      " return=" + TypedExprReturnKindText(fact.returnKind) +
                      " target_source=" + fact.callTargetSourcePath
                return false
            if fact.callTargetImportc &&
               fact.abiClass == TypedExprAbiComposite &&
               (fact.loweringMode != TypedExprLowerImportBuffer ||
                fact.returnKind != TypedExprReturnImportBuffer):
                err = " typed expr: imported composite call missing import buffer at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
                return false
            continue
        if fact.callReason == TypedExprCallReasonNone:
            err = " typed expr: unresolved call missing reason at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callTargetSourcePath != "":
            err = " typed expr: unresolved call keeps target source at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
        if fact.callTargetImportc:
            err = " typed expr: unresolved call keeps importc target at " + expr.sourcePath + ":" + intToStr(expr.lineNumber)
            return false
    err = ""
    return true

fn TypedExprLoweringRuleFromFact(fact: TypedExprFact): TypedExprLoweringRule =
    var out: TypedExprLoweringRule
    let argPassKind = TypedExprArgPassKindForResolved(fact.abiClass, fact.placeKind, fact.loweringMode)
    let resultPassKind = TypedExprResultPassKindForResolved(fact.returnKind)
    let materializeKind = TypedExprMaterializeKindForResolved(fact.valueKind, fact.placeKind, fact.loweringMode)
    let copyKind = TypedExprCopyKindForResolved(fact.valueKind, fact.abiClass)
    let importKind = TypedExprImportKindForResolved(fact.callKind, fact.abiClass, fact.loweringMode, fact.returnKind)
    out.exprId = fact.exprId
    out.sourcePath = fact.sourcePath
    out.lineNumber = fact.lineNumber
    out.columnNumber = fact.columnNumber
    out.surfaceCallKind = fact.surfaceCallKind
    out.callResolved = fact.callResolved
    out.callReason = fact.callReason
    out.callQualifier = fact.callQualifier
    out.callCallee = fact.callCallee
    out.callTarget = fact.callTarget
    out.callTargetSourcePath = fact.callTargetSourcePath
    out.callTargetImportc = fact.callTargetImportc
    out.callPrefixStyle = fact.callPrefixStyle
    out.callArgCount = fact.callArgCount
    out.callArgsText = fact.callArgsText
    out.typeText = TypedExprNormalizeTypeText(fact.typeText)
    out.abiClass = fact.abiClass
    out.valueKind = fact.valueKind
    out.placeKind = fact.placeKind
    out.loweringMode = fact.loweringMode
    out.callKind = fact.callKind
    out.typeCallKind = fact.typeCallKind
    out.returnKind = fact.returnKind
    out.argPassKind = argPassKind
    out.resultPassKind = resultPassKind
    out.materializeKind = materializeKind
    out.copyKind = copyKind
    out.importKind = importKind
    return out

fn TypedExprLoweringRuleClone(rule: TypedExprLoweringRule): TypedExprLoweringRule =
    var out: TypedExprLoweringRule
    out.exprId = rule.exprId
    out.sourcePath = rule.sourcePath
    out.lineNumber = rule.lineNumber
    out.columnNumber = rule.columnNumber
    out.surfaceCallKind = rule.surfaceCallKind
    out.callResolved = rule.callResolved
    out.callReason = rule.callReason
    out.callQualifier = rule.callQualifier
    out.callCallee = rule.callCallee
    out.callTarget = rule.callTarget
    out.callTargetSourcePath = rule.callTargetSourcePath
    out.callTargetImportc = rule.callTargetImportc
    out.callPrefixStyle = rule.callPrefixStyle
    out.callArgCount = rule.callArgCount
    out.callArgsText = rule.callArgsText
    out.typeText = rule.typeText
    out.abiClass = rule.abiClass
    out.valueKind = rule.valueKind
    out.placeKind = rule.placeKind
    out.loweringMode = rule.loweringMode
    out.callKind = rule.callKind
    out.typeCallKind = rule.typeCallKind
    out.returnKind = rule.returnKind
    out.argPassKind = rule.argPassKind
    out.resultPassKind = rule.resultPassKind
    out.materializeKind = rule.materializeKind
    out.copyKind = rule.copyKind
    out.importKind = rule.importKind
    return out

fn TypedExprLoweringRulesClone(rules: TypedExprLoweringRule[]): TypedExprLoweringRule[] =
    var out: TypedExprLoweringRule[]
    for i in 0..<rules.len:
        add(out, TypedExprLoweringRuleClone(rules[i]))
    return out

fn TypedExprLoweringRuleEqual(lhs: TypedExprLoweringRule,
                                rhs: TypedExprLoweringRule): bool =
    if lhs.exprId != rhs.exprId:
        return false
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.lineNumber != rhs.lineNumber:
        return false
    if lhs.columnNumber != rhs.columnNumber:
        return false
    if lhs.surfaceCallKind != rhs.surfaceCallKind:
        return false
    if lhs.callResolved != rhs.callResolved:
        return false
    if lhs.callReason != rhs.callReason:
        return false
    if lhs.callQualifier != rhs.callQualifier:
        return false
    if lhs.callCallee != rhs.callCallee:
        return false
    if lhs.callTarget != rhs.callTarget:
        return false
    if lhs.callTargetSourcePath != rhs.callTargetSourcePath:
        return false
    if lhs.callTargetImportc != rhs.callTargetImportc:
        return false
    if lhs.callPrefixStyle != rhs.callPrefixStyle:
        return false
    if lhs.callArgCount != rhs.callArgCount:
        return false
    if lhs.callArgsText != rhs.callArgsText:
        return false
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    if lhs.returnKind != rhs.returnKind:
        return false
    if lhs.argPassKind != rhs.argPassKind:
        return false
    if lhs.resultPassKind != rhs.resultPassKind:
        return false
    if lhs.materializeKind != rhs.materializeKind:
        return false
    if lhs.copyKind != rhs.copyKind:
        return false
    if lhs.importKind != rhs.importKind:
        return false
    return true

fn TypedExprLoweringRuleShapeEqual(lhs: TypedExprLoweringRule,
                                     rhs: TypedExprLoweringRule): bool =
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    if lhs.returnKind != rhs.returnKind:
        return false
    if lhs.argPassKind != rhs.argPassKind:
        return false
    if lhs.resultPassKind != rhs.resultPassKind:
        return false
    if lhs.materializeKind != rhs.materializeKind:
        return false
    if lhs.copyKind != rhs.copyKind:
        return false
    return lhs.importKind == rhs.importKind

fn TypedExprLoweringRuleKey(rule: TypedExprLoweringRule): str =
    var out = ""
    out = out + "type=" + TypedExprNormalizeTypeText(rule.typeText)
    out = out + ";abi=" + TypedExprAbiClassText(rule.abiClass)
    out = out + ";value=" + TypedExprValueKindText(rule.valueKind)
    out = out + ";place=" + TypedExprPlaceKindText(rule.placeKind)
    out = out + ";lower=" + TypedExprLoweringModeText(rule.loweringMode)
    out = out + ";call=" + TypedExprCallKindText(rule.callKind)
    out = out + ";type_call=" + TypedExprTypeCallKindText(rule.typeCallKind)
    out = out + ";return=" + TypedExprReturnKindText(rule.returnKind)
    out = out + ";arg=" + TypedExprArgPassKindText(rule.argPassKind)
    out = out + ";result=" + TypedExprResultPassKindText(rule.resultPassKind)
    out = out + ";materialize=" + TypedExprMaterializeKindText(rule.materializeKind)
    out = out + ";copy=" + TypedExprCopyKindText(rule.copyKind)
    out = out + ";import=" + TypedExprImportKindText(rule.importKind)
    return out

fn TypedExprLoweringRuleEntryText(rule: TypedExprLoweringRule): str =
    var out = ""
    let callReasonText = TypedExprCallReasonText(rule.callReason)
    out = out + "source=" + rule.sourcePath
    out = out + ";line=" + intToStr(rule.lineNumber)
    out = out + ";column=" + intToStr(rule.columnNumber)
    out = out + ";expr=" + rule.exprId
    out = out + ";surface_call=" + TypedExprSurfaceCallKindText(rule.surfaceCallKind)
    out = out + ";type_call=" + TypedExprTypeCallKindText(rule.typeCallKind)
    out = out + ";resolved=" + (if rule.callResolved: "1" else: "0")
    if callReasonText != "":
        out = out + ";reason=" + callReasonText
    if rule.callQualifier != "":
        out = out + ";qualifier=" + rule.callQualifier
    if rule.callCallee != "":
        out = out + ";callee=" + rule.callCallee
    if rule.callTarget != "":
        out = out + ";target=" + rule.callTarget
    if rule.callTargetSourcePath != "":
        out = out + ";target_source=" + rule.callTargetSourcePath
    if rule.callTargetImportc:
        out = out + ";target_importc=1"
    if rule.callPrefixStyle:
        out = out + ";prefix_style=1"
    if rule.callArgCount > 0:
        out = out + ";arg_count=" + intToStr(rule.callArgCount)
    out = out + ";key=" + TypedExprLoweringRuleKey(rule)
    return out

fn TypedExprLoweringRulesEqual(lhs: TypedExprLoweringRule[],
                                 rhs: TypedExprLoweringRule[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !TypedExprLoweringRuleEqual(lhs[i], rhs[i]):
            return false
    return true

fn TypedExprLoweringRulesFromFacts(facts: TypedExprFact[]): TypedExprLoweringRule[] =
    var out: TypedExprLoweringRule[]
    for i in 0..<facts.len:
        add(out, TypedExprLoweringRuleFromFact(facts[i]))
    return out

fn TypedExprLoweringRuleUniqueShapeCount(rules: TypedExprLoweringRule[]): int32 =
    var count: int32
    var uniqueRules: TypedExprLoweringRule[]
    for i in 0..<rules.len:
        var seen = false
        for j in 0..<uniqueRules.len:
            if TypedExprLoweringRuleShapeEqual(uniqueRules[j], rules[i]):
                seen = true
                break
        if seen:
            continue
        add(uniqueRules, TypedExprLoweringRuleClone(rules[i]))
        count = count + 1
    return count

fn TypedExprLoweringRuleUniqueKeyCount(rules: TypedExprLoweringRule[]): int32 =
    var count: int32
    var keys: str[]
    for i in 0..<rules.len:
        let key = TypedExprLoweringRuleKey(rules[i])
        if parser.ParserStringSeqContainsExact(keys, key):
            continue
        add(keys, key)
        count = count + 1
    return count

fn TypedExprLoweringRuleCountArgPassKind(rules: TypedExprLoweringRule[],
                                           kind: TypedExprArgPassKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].argPassKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountResultPassKind(rules: TypedExprLoweringRule[],
                                              kind: TypedExprResultPassKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].resultPassKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountMaterializeKind(rules: TypedExprLoweringRule[],
                                               kind: TypedExprMaterializeKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].materializeKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountCopyKind(rules: TypedExprLoweringRule[],
                                        kind: TypedExprCopyKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].copyKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountImportKind(rules: TypedExprLoweringRule[],
                                          kind: TypedExprImportKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].importKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountTypeCallKind(rules: TypedExprLoweringRule[],
                                            typeCallKind: TypedExprTypeCallKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].typeCallKind == typeCallKind:
            count = count + 1
    return count

fn TypedExprReportAppendLine(out: var str,
                               key: str,
                               value: str) =
    out = out + key + "=" + value + "\n"

