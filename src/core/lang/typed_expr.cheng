fn TypedExprReturnConstTextFromLine(lineRaw: str): str =
    let exprText = TypedExprReturnExprFromBody(lineRaw)
    if TypedExprIrIsI32ConstLiteral(exprText):
        return exprText
    return ""

fn TypedExprFunctionBodyIsI32IfArg0LeZeroConstElseConst(ctx: var TypedExprSourceContext,
                                                         scope: TypedExprFunctionScope,
                                                         params: TypedExprParam[],
                                                         bodyLineNumber: var int32,
                                                         thenConstText: var str,
                                                         elseConstText: var str): bool =
    bodyLineNumber = 0
    thenConstText = ""
    elseConstText = ""
    if scope.returnType != "int32":
        return false
    if params.len != 1 || params[0].typeText != "int32":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    var bodyLineNumbers: int32[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if Len(bodyTrim) <= 0:
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
        add(bodyLineNumbers, i + 1)
    if bodyLines.len != 3:
        return false
    if bodyLines[0] != strutil.Join(["if ", params[0].name, " <= 0:"], ""):
        return false
    let thenText = TypedExprReturnConstTextFromLine(bodyLines[1])
    let elseText = TypedExprReturnConstTextFromLine(bodyLines[2])
    if Len(thenText) <= 0 || Len(elseText) <= 0:
        return false
    bodyLineNumber = bodyLineNumbers[0]
    thenConstText = thenText
    elseConstText = elseText
    return true

fn TypedExprIrAddI32IfArg0LeZeroConstElseConstNode(ir: var TypedExprIr,
                                                    sourcePath: str,
                                                    functionName: str,
                                                    lineNumber: int32,
                                                    paramNodeIndex: int32,
                                                    thenConstText: str,
                                                    elseConstText: str): int32 =
    var node: TypedExprIrNode
    node.sourcePath = sourcePath
    node.functionName = functionName
    node.lineNumber = lineNumber
    node.opKind = TypedExprIrOpI32IfArg0LeZeroConstElseConst
    node.resultType = "int32"
    node.surfaceText = "if_arg0_le_zero_const_else_const"
    node.paramSlot = -1
    node.operand0NodeIndex = paramNodeIndex
    node.operand1NodeIndex = -1
    node.operand2NodeIndex = -1
    node.literalText = strutil.Join([thenConstText, ",", elseConstText], "")
    return TypedExprIrAddNode(ir, node)

fn TypedExprIrAddBinaryIfMatches(ir: var TypedExprIr,
                                  sourcePath: str,
                                  functionName: str,
                                  lineNumber: int32,
                                  params: TypedExprParam[],
                                  paramNodeIndices: int32[],
                                  returnExpr: str,
                                  opText: str,
                                  opKind: TypedExprIrOpKind,
                                  resultType: str): int32 =
    let opIndex = TypedExprFindTopLevelTextToken(returnExpr, opText)
    if opIndex < 0:
        return -1
    let lhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, opIndex))
    let rhsStart = opIndex + Len(opText)
    let rhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                         rhsStart,
                                                         returnExpr.len - rhsStart))
    let lhsNodeIndex = TypedExprIrParamNodeIndex(params, paramNodeIndices, lhsText)
    let rhsNodeIndex = TypedExprIrParamNodeIndex(params, paramNodeIndices, rhsText)
    if lhsNodeIndex < 0 || rhsNodeIndex < 0:
        return -1
    return TypedExprIrAddOpNode(ir,
                                sourcePath,
                                functionName,
                                lineNumber,
                                opKind,
                                resultType,
                                returnExpr,
                                lhsNodeIndex,
                                rhsNodeIndex,
                                -1)

fn TypedExprIrBuildBinaryReturnNode(ir: var TypedExprIr,
                                     sourcePath: str,
                                     functionName: str,
                                     lineNumber: int32,
                                     params: TypedExprParam[],
                                     paramNodeIndices: int32[],
                                     returnType: str,
                                     returnExpr: str): int32 =
    if params.len != 2:
        return -1
    if params[0].typeText == "int32" &&
       params[1].typeText == "int32" &&
       returnType == "int32":
        let addIndex = TypedExprIrAddBinaryIfMatches(ir,
                                                     sourcePath,
                                                     functionName,
                                                     lineNumber,
                                                     params,
                                                     paramNodeIndices,
                                                     returnExpr,
                                                     "+",
                                                     TypedExprIrOpI32Add,
                                                     "int32")
        if addIndex >= 0:
            return addIndex
        let subIndex = TypedExprIrAddBinaryIfMatches(ir,
                                                     sourcePath,
                                                     functionName,
                                                     lineNumber,
                                                     params,
                                                     paramNodeIndices,
                                                     returnExpr,
                                                     "-",
                                                     TypedExprIrOpI32Sub,
                                                     "int32")
        if subIndex >= 0:
            return subIndex
        let mulIndex = TypedExprIrAddBinaryIfMatches(ir,
                                                     sourcePath,
                                                     functionName,
                                                     lineNumber,
                                                     params,
                                                     paramNodeIndices,
                                                     returnExpr,
                                                     "*",
                                                     TypedExprIrOpI32Mul,
                                                     "int32")
        if mulIndex >= 0:
            return mulIndex
        return TypedExprIrAddBinaryIfMatches(ir,
                                             sourcePath,
                                             functionName,
                                             lineNumber,
                                             params,
                                             paramNodeIndices,
                                             returnExpr,
                                             ">>",
                                             TypedExprIrOpI32Asr,
                                             "int32")
    if params[0].typeText == "float64" &&
       params[1].typeText == "float64" &&
       returnType == "float64":
        return TypedExprIrAddBinaryIfMatches(ir,
                                             sourcePath,
                                             functionName,
                                             lineNumber,
                                             params,
                                             paramNodeIndices,
                                             returnExpr,
                                             "*",
                                             TypedExprIrOpF64Mul,
                                             "float64")
    return -1

fn TypedExprIrBinaryParamsMatch(textRaw: str,
                                 lhsName: str,
                                 opText: str,
                                 rhsName: str): bool =
    let opIndex = TypedExprFindTopLevelTextToken(textRaw, opText)
    if opIndex < 0:
        return false
    let lhsText = chengpath.PathTrim(chengpath.TextSlice(textRaw, 0, opIndex))
    let rhsStart = opIndex + Len(opText)
    let rhsText = chengpath.PathTrim(chengpath.TextSlice(textRaw,
                                                         rhsStart,
                                                         textRaw.len - rhsStart))
    return lhsText == lhsName && rhsText == rhsName

fn TypedExprIrBuildMaddReturnNode(ir: var TypedExprIr,
                                   sourcePath: str,
                                   functionName: str,
                                   lineNumber: int32,
                                   params: TypedExprParam[],
                                   paramNodeIndices: int32[],
                                   returnType: str,
                                   returnExpr: str): int32 =
    if params.len != 3:
        return -1
    if params[0].typeText != "int32" ||
       params[1].typeText != "int32" ||
       params[2].typeText != "int32" ||
       returnType != "int32":
        return -1
    let opIndex = TypedExprFindTopLevelTextToken(returnExpr, "+")
    if opIndex < 0:
        return -1
    let leftText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, opIndex))
    let rightStart = opIndex + 1
    let rightText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                          rightStart,
                                                          returnExpr.len - rightStart))
    var matched = false
    if rightText == params[2].name:
        matched = TypedExprIrBinaryParamsMatch(leftText,
                                               params[0].name,
                                               "*",
                                               params[1].name)
    elif leftText == params[2].name:
        matched = TypedExprIrBinaryParamsMatch(rightText,
                                               params[0].name,
                                               "*",
                                               params[1].name)
    if !matched:
        return -1
    return TypedExprIrAddOpNode(ir,
                                sourcePath,
                                functionName,
                                lineNumber,
                                TypedExprIrOpI32Madd,
                                "int32",
                                returnExpr,
                                paramNodeIndices[0],
                                paramNodeIndices[1],
                                paramNodeIndices[2])

fn TypedExprFunctionBodyMatchesF64MulCheckExit(ctx: var TypedExprSourceContext,
                                                scope: TypedExprFunctionScope): bool =
    if scope.name != "main" || scope.returnType != "int32":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if Len(bodyTrim) <= 0:
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
    if bodyLines.len != 6:
        return false
    if bodyLines[0] != "let a = 1.5":
        return false
    if bodyLines[1] != "let b = 2.0":
        return false
    if bodyLines[2] != "let product = a * b":
        return false
    if bodyLines[3] != "if product == 3.0:":
        return false
    if bodyLines[4] != "return 0":
        return false
    return bodyLines[5] == "return 1"

fn TypedExprFunctionBodyMatchesStrLenFast(ctx: var TypedExprSourceContext,
                                           scope: TypedExprFunctionScope,
                                           params: TypedExprParam[]): bool =
    if scope.name != "strLenFast" || scope.returnType != "int32":
        return false
    if params.len != 1 || params[0].name != "s" || params[0].typeText != "str":
        return false
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        return false
    var bodyLines: str[]
    for i in scope.startLine..<ctx.lines.len:
        let bodyRaw = ctx.lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if Len(bodyTrim) <= 0:
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        add(bodyLines, bodyTrim)
    if bodyLines.len != 5:
        return false
    if bodyLines[0] != "if s.data == nil:":
        return false
    if bodyLines[1] != "return 0":
        return false
    if bodyLines[2] != "if s.len <= 0:":
        return false
    if bodyLines[3] != "return 0":
        return false
    return bodyLines[4] == "return s.len"

fn TypedExprIrBuildReturnNode(ir: var TypedExprIr,
                               ctx: var TypedExprSourceContext,
                               scope: TypedExprFunctionScope,
                               bodyLineNumber: int32,
                               returnExpr: str,
                               params: TypedExprParam[],
                               paramNodeIndices: int32[]): int32 =
    var ifLineNumber: int32
    var ifThenConst = ""
    var ifElseConst = ""
    if TypedExprFunctionBodyIsI32IfArg0LeZeroConstElseConst(ctx,
                                                            scope,
                                                            params,
                                                            ifLineNumber,
                                                            ifThenConst,
                                                            ifElseConst):
        return TypedExprIrAddI32IfArg0LeZeroConstElseConstNode(ir,
                                                               ctx.sourcePath,
                                                               scope.name,
                                                               ifLineNumber,
                                                               paramNodeIndices[0],
                                                               ifThenConst,
                                                               ifElseConst)
    if TypedExprFunctionBodyMatchesF64MulCheckExit(ctx, scope):
        return TypedExprIrAddOpNode(ir,
                                    ctx.sourcePath,
                                    scope.name,
                                    bodyLineNumber,
                                    TypedExprIrOpMainF64MulCheckExit,
                                    "int32",
                                    "main_f64_mul_check_exit",
                                    -1,
                                    -1,
                                    -1)
    if TypedExprFunctionBodyMatchesStrLenFast(ctx, scope, params):
        return TypedExprIrAddOpNode(ir,
                                    ctx.sourcePath,
                                    scope.name,
                                    bodyLineNumber,
                                    TypedExprIrOpStrLenFast,
                                    "int32",
                                    "str_len_fast",
                                    paramNodeIndices[0],
                                    -1,
                                    -1)
    if scope.returnType == "str" &&
       params.len == 1 &&
       params[0].typeText == "str" &&
       returnExpr == params[0].name:
        return TypedExprIrAddReturnStrArg0Node(ir,
                                               ctx.sourcePath,
                                               scope.name,
                                               bodyLineNumber,
                                               paramNodeIndices[0],
                                               params[0].name)
    if scope.returnType == "int32" &&
       params.len == 1 &&
       returnExpr == Fmt"{params[0].name}.len":
        let paramTypeText = TypedExprNormalizeTypeText(params[0].typeText)
        if paramTypeText == "Bytes" ||
           paramTypeText == "bytes.Bytes" ||
           paramTypeText == "rawbytes.Bytes":
            return TypedExprIrAddOpNode(ir,
                                        ctx.sourcePath,
                                        scope.name,
                                        bodyLineNumber,
                                        TypedExprIrOpReturnBytesLenArg0,
                                        "int32",
                                        returnExpr,
                                        paramNodeIndices[0],
                                        -1,
                                        -1)
        if (paramTypeText.len >= 2 && chengpath.TextSlice(paramTypeText, paramTypeText.len - 2, 2) == "[]") ||
           parser.ParserStartsWith(paramTypeText, "seq["):
            return TypedExprIrAddOpNode(ir,
                                        ctx.sourcePath,
                                        scope.name,
                                        bodyLineNumber,
                                        TypedExprIrOpReturnSeqLenArg0,
                                        "int32",
                                        returnExpr,
                                        paramNodeIndices[0],
                                        -1,
                                        -1)
    if scope.returnType == "char" &&
       params.len == 1:
        if (params[0].typeText == "char" && returnExpr == params[0].name) ||
           (params[0].typeText == "int32" && returnExpr == Fmt"char({params[0].name})"):
            return TypedExprIrAddOpNode(ir,
                                        ctx.sourcePath,
                                        scope.name,
                                        bodyLineNumber,
                                        TypedExprIrOpReturnCharArg0,
                                        "char",
                                        returnExpr,
                                        paramNodeIndices[0],
                                        -1,
                                        -1)
    if scope.returnType == "int64" &&
       params.len == 1 &&
       params[0].typeText == "int32" &&
       returnExpr == Fmt"int64({params[0].name})":
        return TypedExprIrAddOpNode(ir,
                                    ctx.sourcePath,
                                    scope.name,
                                    bodyLineNumber,
                                    TypedExprIrOpReturnI64FromI32Arg0,
                                    "int64",
                                    returnExpr,
                                    paramNodeIndices[0],
                                    -1,
                                    -1)
    if scope.returnType == "bool" &&
       params.len == 1 &&
       params[0].typeText == "int32" &&
       returnExpr == Fmt"{params[0].name} >= 0 && {params[0].name} <= 31":
        return TypedExprIrAddOpNode(ir,
                                    ctx.sourcePath,
                                    scope.name,
                                    bodyLineNumber,
                                    TypedExprIrOpReturnBoolI32Arg0Range0To31,
                                    "bool",
                                    returnExpr,
                                    paramNodeIndices[0],
                                    -1,
                                    -1)
    if params.len == 1 &&
       returnExpr == params[0].name &&
       TypedExprNormalizeTypeText(scope.returnType) == TypedExprNormalizeTypeText(params[0].typeText):
        let returnTypeText = TypedExprNormalizeTypeText(scope.returnType)
        if returnTypeText == "Bytes" ||
           returnTypeText == "bytes.Bytes" ||
           returnTypeText == "rawbytes.Bytes" ||
           (returnTypeText.len >= 2 && chengpath.TextSlice(returnTypeText, returnTypeText.len - 2, 2) == "[]") ||
           parser.ParserStartsWith(returnTypeText, "seq["):
            return TypedExprIrAddOpNode(ir,
                                        ctx.sourcePath,
                                        scope.name,
                                        bodyLineNumber,
                                        TypedExprIrOpReturnComposite16Arg0,
                                        returnTypeText,
                                        params[0].name,
                                        paramNodeIndices[0],
                                        -1,
                                        -1)
    if params.len == 1 &&
       returnExpr == Fmt"{params[0].name}.data":
        let returnTypeText = TypedExprNormalizeTypeText(scope.returnType)
        let paramTypeText = TypedExprNormalizeTypeText(params[0].typeText)
        if (returnTypeText == "Bytes" ||
            returnTypeText == "bytes.Bytes" ||
            returnTypeText == "rawbytes.Bytes") &&
           (paramTypeText == "ByteBuffer" ||
            paramTypeText == "buffer.ByteBuffer"):
            return TypedExprIrAddOpNode(ir,
                                        ctx.sourcePath,
                                        scope.name,
                                        bodyLineNumber,
                                        TypedExprIrOpReturnComposite16Field0Arg0,
                                        returnTypeText,
                                        returnExpr,
                                        paramNodeIndices[0],
                                        -1,
                                        -1)
    if scope.returnType == "int32":
        let returnParamIndex = TypedExprIrParamNodeIndex(params,
                                                         paramNodeIndices,
                                                         returnExpr)
        if returnParamIndex >= 0 && returnParamIndex < ir.nodes.len:
            if ir.nodes[returnParamIndex].resultType == "int32":
                return returnParamIndex
    if scope.returnType == "uint64" &&
       params.len == 1 &&
       params[0].typeText == "uint64":
        let orIndex = TypedExprFindTopLevelTextToken(returnExpr, "|")
        if orIndex > 0:
            let lhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, orIndex))
            let rhsStart = orIndex + 1
            let rhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                                 rhsStart,
                                                                 returnExpr.len - rhsStart))
            if lhsText == params[0].name && rhsText == "uint64(4)":
                return TypedExprIrAddOpNode(ir,
                                            ctx.sourcePath,
                                            scope.name,
                                            bodyLineNumber,
                                            TypedExprIrOpU64OrArg0Const4,
                                            "uint64",
                                            returnExpr,
                                            paramNodeIndices[0],
                                            -1,
                                            -1)
    if scope.returnType == "bool" &&
       params.len == 1 &&
       params[0].typeText == "uint64":
        let neIndex = TypedExprFindTopLevelTextToken(returnExpr, "!=")
        if neIndex > 0:
            let lhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr, 0, neIndex))
            let rhsStart = neIndex + 2
            let rhsText = chengpath.PathTrim(chengpath.TextSlice(returnExpr,
                                                                 rhsStart,
                                                                 returnExpr.len - rhsStart))
            let expectedLhsText = Fmt"({params[0].name} & uint64(4))"
            if lhsText == expectedLhsText && rhsText == "uint64(0)":
                return TypedExprIrAddOpNode(ir,
                                            ctx.sourcePath,
                                            scope.name,
                                            bodyLineNumber,
                                            TypedExprIrOpU64Arg0AndConst4NotZero,
                                            "bool",
                                            returnExpr,
                                            paramNodeIndices[0],
                                            -1,
                                            -1)
    var cstringCopyLineNumber: int32
    if TypedExprFunctionBodyIsCstringToStrCopy(ctx,
                                               scope,
                                               params,
                                               cstringCopyLineNumber):
        return TypedExprIrAddCstringToStrCopyNode(ir,
                                                  ctx.sourcePath,
                                                  scope.name,
                                                  cstringCopyLineNumber,
                                                  paramNodeIndices[0],
                                                  params[0].name)
    var strEmptyReturnLineNumber: int32
    if TypedExprFunctionBodyIsStrEmptyReturn(ctx,
                                             scope,
                                             params,
                                             strEmptyReturnLineNumber):
        return TypedExprIrAddStrEmptyReturnNode(ir,
                                                ctx.sourcePath,
                                                scope.name,
                                                strEmptyReturnLineNumber)
    var letCallResultLineNumber: int32
    var letCallResultBinding = ""
    if TypedExprFunctionBodyIsI32LetCallThenIfResultLeZeroReturnZeroElseBinding(ctx,
                                                                                scope,
                                                                                letCallResultLineNumber,
                                                                                letCallResultBinding):
        return TypedExprIrAddLetCallI32IfResultLeZeroReturnZeroElseResultI32Node(ir,
                                                                                 ctx.sourcePath,
                                                                                 scope.name,
                                                                                 letCallResultLineNumber,
                                                                                 letCallResultBinding)
    var guardReturnLineNumber: int32
    var guardBindingName = ""
    var guardFinalReturnExpr = ""
    if TypedExprFunctionBodyIsI32LetCallGuardLeZeroReturnZeroElseI32(ctx,
                                                                     scope,
                                                                     guardReturnLineNumber,
                                                                     guardBindingName,
                                                                     guardFinalReturnExpr):
        return TypedExprIrAddI32LetCallGuardLeZeroReturnZeroElseI32Node(ir,
                                                                        ctx.sourcePath,
                                                                        scope.name,
                                                                        guardReturnLineNumber,
                                                                        guardBindingName,
                                                                        guardFinalReturnExpr)
    if TypedExprFunctionBodyIsI32LetCallThenReturnBinding(ctx,
                                                          scope,
                                                          letCallResultLineNumber,
                                                          letCallResultBinding):
        return TypedExprIrAddLetCallResultI32Node(ir,
                                                  ctx.sourcePath,
                                                  scope.name,
                                                  letCallResultLineNumber,
                                                  letCallResultBinding)
    var letCallStrLenLineNumber: int32
    var letCallStrLenBinding = ""
    if TypedExprFunctionBodyIsStrLetCallThenReturnLen(ctx,
                                                      scope,
                                                      letCallStrLenLineNumber,
                                                      letCallStrLenBinding):
        return TypedExprIrAddLetCallStrReturnLenI32Node(ir,
                                                        ctx.sourcePath,
                                                        scope.name,
                                                        letCallStrLenLineNumber,
                                                        letCallStrLenBinding)
    var letCallStrSecondCallLineNumber: int32
    var letCallStrThenCallReturnLineNumber: int32
    var letCallStrThenCallBinding = ""
    if TypedExprFunctionBodyIsStrLetCallThenCallArg0ReturnZero(ctx,
                                                               scope,
                                                               letCallStrSecondCallLineNumber,
                                                               letCallStrThenCallReturnLineNumber,
                                                               letCallStrThenCallBinding):
        return TypedExprIrAddLetCallStrThenCallArg0ReturnI32Const0Node(ir,
                                                                       ctx.sourcePath,
                                                                       scope.name,
                                                                       letCallStrThenCallReturnLineNumber,
                                                                       letCallStrSecondCallLineNumber,
                                                                       letCallStrThenCallBinding)
    if scope.returnType == "int32" && TypedExprIrIsI32ConstLiteral(returnExpr):
        return TypedExprIrAddI32ConstNode(ir,
                                          ctx.sourcePath,
                                          scope.name,
                                          bodyLineNumber,
                                          returnExpr)
    let maddIndex = TypedExprIrBuildMaddReturnNode(ir,
                                                   ctx.sourcePath,
                                                   scope.name,
                                                   bodyLineNumber,
                                                   params,
                                                   paramNodeIndices,
                                                   scope.returnType,
                                                   returnExpr)
    if maddIndex >= 0:
        return maddIndex
    return TypedExprIrBuildBinaryReturnNode(ir,
                                            ctx.sourcePath,
                                            scope.name,
                                            bodyLineNumber,
                                            params,
                                            paramNodeIndices,
                                            scope.returnType,
                                            returnExpr)

fn TypedExprParseTypeDeclName(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    if line == "":
        return ""
    let eqPos = TypedExprFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return ""
    let headRaw = chengpath.PathTrim(chengpath.TextSlice(line, 0, eqPos))
    let genericPos = TypedExprFindTopLevelToken(headRaw, "[")
    var head = headRaw
    if genericPos > 0:
        head = chengpath.PathTrim(chengpath.TextSlice(headRaw, 0, genericPos))
    return parser.ParserIdentPrefix(parser.ParserFirstToken(head))

fn TypedExprSplitTopLevelCsv(itemsRaw: str): str[] =
    var out: str[]
    var start: int32
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<itemsRaw.len:
        let piece = chengpath.TextSlice(itemsRaw, i, 1)
        if piece == "[":
            bracketDepth = bracketDepth + 1
        elif piece == "]":
            bracketDepth = bracketDepth - 1
        elif piece == "(":
            parenDepth = parenDepth + 1
        elif piece == ")":
            parenDepth = parenDepth - 1
        elif piece == "{":
            braceDepth = braceDepth + 1
        elif piece == "}":
            braceDepth = braceDepth - 1
        elif piece == "," && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            add(out, TypedExprSliceTrim(itemsRaw, start, i - start))
            start = i + 1
    add(out, TypedExprSliceTrim(itemsRaw, start, itemsRaw.len - start))
    return out

fn TypedExprAlignBytes(value: int32, alignRaw: int32): int32 =
    var align = alignRaw
    if align <= 1:
        return value
    let rem = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn TypedExprStripVarType(typeRaw: str): str =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if parser.ParserStartsWith(typeText, "var") && typeText.len > 3:
        return chengpath.TextSlice(typeText, 3, typeText.len - 3)
    return typeText

fn TypedExprTypeLeafName(typeRaw: str): str =
    let typeText = TypedExprStripVarType(typeRaw)
    var start: int32
    for i in 0..<typeText.len:
        if typeText[i] == '.':
            start = i + 1
        elif i + 1 < typeText.len && typeText[i] == ':' && typeText[i + 1] == ':':
            start = i + 2
    if start > 0 && start < typeText.len:
        return chengpath.TextSlice(typeText, start, typeText.len - start)
    return typeText

fn TypedExprPointerPointeeType(currentCtx: var TypedExprSourceContext,
                                sourceContexts: var TypedExprSourceContext[],
                                typeRaw: str): str =
    let typeText = chengpath.PathTrim(TypedExprStripVarType(typeRaw))
    if typeText == "":
        return ""
    if typeText.len > 0 && typeText[typeText.len - 1] == '*':
        return chengpath.PathTrim(chengpath.TextSlice(typeText, 0, typeText.len - 1))
    let leaf = TypedExprTypeLeafName(typeText)
    if leaf.len > 3 &&
       chengpath.TextSlice(leaf, leaf.len - 3, 3) == "Ptr":
        let pointeeLeaf = chengpath.TextSlice(leaf, 0, leaf.len - 3)
        let ctxIndex = TypedExprFieldContextLookup(currentCtx, sourceContexts, pointeeLeaf)
        if ctxIndex >= 0 || ctxIndex == -2:
            return pointeeLeaf
    return typeText

fn TypedExprTypeFieldDeclMatches(field: TypedExprTypeFieldDecl,
                                  ownerTypeRaw: str,
                                  fieldNameRaw: str): bool =
    return field.ownerType == TypedExprTypeLeafName(ownerTypeRaw) &&
           field.fieldName == parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))

fn TypedExprContextHasTypeField(ctx: var TypedExprSourceContext,
                                 ownerTypeRaw: str): bool =
    let ownerType = TypedExprTypeLeafName(ownerTypeRaw)
    for i in 0..<ctx.typeFields.len:
        if ctx.typeFields[i].ownerType == ownerType:
            return true
    return false

fn TypedExprAddTypeFieldDecl(ctx: var TypedExprSourceContext,
                              ownerTypeRaw: str,
                              fieldNameRaw: str,
                              fieldTypeRaw: str) =
    let ownerType = TypedExprTypeLeafName(ownerTypeRaw)
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    let fieldType = TypedExprNormalizeTypeText(fieldTypeRaw)
    if ownerType == "" || fieldName == "" || fieldType == "":
        return
    var decl: TypedExprTypeFieldDecl
    decl.ownerType = ownerType
    decl.fieldName = fieldName
    decl.fieldType = fieldType
    add(ctx.typeFields, decl)

fn TypedExprParseTypeFieldLine(lineRaw: str,
                                fieldName: var str,
                                fieldType: var str): bool =
    fieldName = ""
    fieldType = ""
    let line = chengpath.PathTrim(parser.ParserStripLineComment(lineRaw))
    if line == "":
        return false
    let colonPos = TypedExprFindTopLevelToken(line, ":")
    if colonPos <= 0:
        return false
    let eqPos = TypedExprFindTopLevelToken(line, "=")
    fieldName = parser.ParserIdentPrefix(chengpath.TextSlice(line, 0, colonPos))
    var typeEnd = line.len
    if eqPos > colonPos:
        typeEnd = eqPos
    fieldType = TypedExprNormalizeTypeText(chengpath.TextSlice(line,
                                                               colonPos + 1,
                                                               typeEnd - colonPos - 1))
    return fieldName != "" && fieldType != ""

fn TypedExprFindTypeFieldDecl(ctx: var TypedExprSourceContext,
                               ownerTypeRaw: str,
                               fieldNameRaw: str,
                               out: var TypedExprTypeFieldDecl): bool =
    for i in 0..<ctx.typeFields.len:
        if TypedExprTypeFieldDeclMatches(ctx.typeFields[i], ownerTypeRaw, fieldNameRaw):
            out = ctx.typeFields[i]
            return true
    return false

fn TypedExprMaybeAddBinding(bindings: var TypedExprBinding[],
                              sourcePath: str,
                              functionName: str,
                              globalFlag: bool,
                              lineNumber: int32,
                              nameRaw: str,
                              typeRaw: str) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if name == "" || typeText == "":
        return
    var binding: TypedExprBinding
    binding.sourcePath = sourcePath
    binding.functionName = functionName
    binding.globalFlag = globalFlag
    binding.lineNumber = lineNumber
    binding.name = name
    binding.typeText = typeText
    add(bindings, binding)

fn TypedExprAppendParamBindings(bindings: var TypedExprBinding[],
                                  scope: TypedExprFunctionScope,
                                  lineRaw: str) =
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos <= openPos:
        return
    let paramsText = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let params = TypedExprSplitTopLevelCsv(paramsText)
    for i in 0..<params.len:
        var item = params[i]
        if parser.ParserStartsWith(item, "var "):
            item = chengpath.TextSlice(item, 4, item.len - 4)
        let colonPos = TypedExprFindTopLevelToken(item, ":")
        if colonPos <= 0:
            continue
        let nameText = chengpath.TextSlice(item, 0, colonPos)
        var typeText = chengpath.TextSlice(item, colonPos + 1, item.len - colonPos - 1)
        let eqPos = TypedExprFindTopLevelToken(typeText, "=")
        if eqPos >= 0:
            typeText = chengpath.TextSlice(typeText, 0, eqPos)
        TypedExprMaybeAddBinding(bindings,
                                   scope.sourcePath,
                                   scope.name,
                                   false,
                                   scope.startLine,
                                   nameText,
                                   typeText)

fn TypedExprTypeTextIsConcrete(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "unknown" ||
       typeText == "call_expr" ||
       typeText == "constructor_expr" ||
       typeText == "default_init_expr" ||
       typeText == "result_projection" ||
       typeText == "branch_join":
        return false
    if typeText.len == 1 &&
       typeText[0] >= 'A' &&
       typeText[0] <= 'Z':
        return false
    return true

fn TypedExprMaybeAddInferredCallBinding(ctx: var TypedExprSourceContext,
                                         sourceContexts: var TypedExprSourceContext[],
                                         fact: TypedExprFact) =
    if parser.ParserNormalizePath(fact.sourcePath) != parser.ParserNormalizePath(ctx.sourcePath):
        return
    if fact.kind != parser.NormalizedExprCall &&
       fact.kind != parser.NormalizedExprResultIntrinsic:
        return
    if !fact.hasSink:
        return
    if fact.sinkPlaceKind != TypedExprPlaceLocal &&
       fact.sinkPlaceKind != TypedExprPlaceGlobal:
        return
    let lineRaw = TypedExprSourceLine(ctx, fact.lineNumber)
    var bindingName = ""
    var explicitType = ""
    var rhsStartColumn: int32 = -1
    if !TypedExprParseBindingLine(lineRaw, bindingName, explicitType, rhsStartColumn):
        return
    if bindingName == "" || explicitType != "":
        return
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, fact.lineNumber)
    var typeText = ""
    if fact.kind == parser.NormalizedExprCall:
        typeText = TypedExprLookupCallTargetReturnTypeFromFact(ctx, sourceContexts, fact)
    if !TypedExprTypeTextIsConcrete(typeText):
        typeText = fact.typeText
    if !TypedExprTypeTextIsConcrete(typeText):
        return
    var functionName = ""
    var globalFlag = true
    if scopeIndex >= 0:
        functionName = ctx.scopes[scopeIndex].name
        globalFlag = false
    TypedExprMaybeAddBinding(ctx.bindings,
                             ctx.sourcePath,
                             functionName,
                             globalFlag,
                             fact.lineNumber,
                             bindingName,
                             typeText)

fn TypedExprAppendInferredCallBindings(ctx: var TypedExprSourceContext,
                                        sourceContexts: var TypedExprSourceContext[],
                                        facts: var TypedExprFact[],
                                        startIndex: int32,
                                        endIndexRaw: int32) =
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > facts.len:
        endIndex = facts.len
    for i in startIndex..<endIndex:
        TypedExprMaybeAddInferredCallBinding(ctx, sourceContexts, facts[i])

fn TypedExprBindingRhsCallHead(rhsRaw: str): str =
    let rhs = chengpath.PathTrim(rhsRaw)
    if rhs == "":
        return ""
    let openPos = TypedExprFindTopLevelToken(rhs, "(")
    if openPos <= 0:
        return ""
    if rhs[rhs.len - 1] != ')':
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(rhs, 0, openPos))

fn TypedExprBindingRhsCallReturnType(ctx: var TypedExprSourceContext,
                                      sourceContexts: var TypedExprSourceContext[],
                                      rhsRaw: str): str =
    let callHead = TypedExprBindingRhsCallHead(rhsRaw)
    if callHead == "":
        return ""
    let qualifier = TypedExprQualifiedCallQualifier(callHead)
    let callee = TypedExprQualifiedCallLeaf(callHead)
    if callee == "":
        return ""
    if qualifier != "":
        var targetSourcePath = ""
        var targetName = ""
        var targetImportc = false
        return TypedExprResolveQualifiedCallTargetReturnType(ctx,
                                                             sourceContexts,
                                                             qualifier,
                                                             callee,
                                                             callHead,
                                                             targetSourcePath,
                                                             targetName,
                                                             targetImportc)
    let importcReturnType = TypedExprLookupLocalImportcReturnTypeForCall(ctx,
                                                                         callee,
                                                                         callee)
    if importcReturnType != "":
        return importcReturnType
    let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, callee)
    if localReturnType != "":
        return localReturnType
    return TypedExprLookupExternalFunctionReturnTypeFromContexts(ctx,
                                                                 sourceContexts,
                                                                 "",
                                                                 callee)

fn TypedExprLookupEnumConstType(ctx: var TypedExprSourceContext,
                                 sourceContexts: var TypedExprSourceContext[],
                                 nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    var found = ""
    for i in 0..<ctx.enumValueNames.len:
        if i >= ctx.enumValueTypes.len:
            continue
        if ctx.enumValueNames[i] != name:
            continue
        if found != "" && found != ctx.enumValueTypes[i]:
            return ""
        found = ctx.enumValueTypes[i]
    for sourceIndex in 0..<sourceContexts.len:
        for i in 0..<sourceContexts[sourceIndex].enumValueNames.len:
            if i >= sourceContexts[sourceIndex].enumValueTypes.len:
                continue
            if sourceContexts[sourceIndex].enumValueNames[i] != name:
                continue
            if found != "" && found != sourceContexts[sourceIndex].enumValueTypes[i]:
                return ""
            found = sourceContexts[sourceIndex].enumValueTypes[i]
    return found

fn TypedExprBindingRhsCompareType(rhsRaw: str): str =
    let eqPos = TypedExprFindTopLevelTextToken(rhsRaw, "==")
    if eqPos >= 0:
        return "bool"
    let nePos = TypedExprFindTopLevelTextToken(rhsRaw, "!=")
    if nePos >= 0:
        return "bool"
    return ""

fn TypedExprBindingRhsTernaryType(ctx: var TypedExprSourceContext,
                                   sourceContexts: var TypedExprSourceContext[],
                                   rhsRaw: str): str =
    let qPos = TypedExprFindTopLevelTextToken(rhsRaw, "?")
    if qPos < 0:
        return ""
    let colonPos = TypedExprFindTopLevelTextToken(rhsRaw, ":")
    if colonPos <= qPos:
        return ""
    let trueText = chengpath.PathTrim(chengpath.TextSlice(rhsRaw,
                                                         qPos + 1,
                                                         colonPos - qPos - 1))
    let falseText = chengpath.PathTrim(chengpath.TextSlice(rhsRaw,
                                                          colonPos + 1,
                                                          rhsRaw.len - colonPos - 1))
    let trueType = TypedExprLookupEnumConstType(ctx, sourceContexts, trueText)
    if trueType == "":
        return ""
    let falseType = TypedExprLookupEnumConstType(ctx, sourceContexts, falseText)
    if falseType == trueType:
        return trueType
    return ""

fn TypedExprScopeIndexForLine(scopes: TypedExprFunctionScope[],
                                lineNumber: int32): int32 =
    for i in 0..<scopes.len:
        if lineNumber < scopes[i].startLine:
            continue
        if lineNumber > scopes[i].endLine:
            continue
        return i
    return -1

fn TypedExprParseBindingLine(lineRaw: str,
                               name: var str,
                               typeText: var str,
                               rhsStartColumn: var int32): bool =
    name = ""
    typeText = ""
    rhsStartColumn = -1
    let trimmed = chengpath.PathTrim(lineRaw)
    var prefix = ""
    if parser.ParserStartsWith(trimmed, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(trimmed, "var "):
        prefix = "var "
    elif parser.ParserStartsWith(trimmed, "const "):
        prefix = "const "
    if prefix == "":
        return false
    let tail = chengpath.TextSlice(trimmed, Len(prefix), trimmed.len - Len(prefix))
    let rawName = parser.ParserFirstToken(tail)
    let bindingName = parser.ParserIdentPrefix(rawName)
    if bindingName == "":
        return false
    var colonPos = TypedExprFindTopLevelToken(tail, ":")
    let eqPos = TypedExprFindTopLevelToken(tail, "=")
    if eqPos >= 0 && colonPos > eqPos:
        colonPos = -1
    if colonPos < 0:
        if eqPos < 0:
            return false
        name = bindingName
        typeText = ""
        let originalEqPosNoType = parser.ParserFindText(lineRaw, "=")
        if originalEqPosNoType < 0:
            return true
        rhsStartColumn = originalEqPosNoType + 2
        for column in rhsStartColumn..lineRaw.len:
            if parser.ParserIsInlineSpace(lineRaw[column - 1]):
                rhsStartColumn = column + 1
            else:
                rhsStartColumn = column
                break
        return true
    if eqPos >= 0 && eqPos <= colonPos:
        return false
    name = bindingName
    if eqPos < 0:
        typeText = TypedExprNormalizeTypeText(chengpath.TextSlice(tail,
                                                                  colonPos + 1,
                                                                  tail.len - colonPos - 1))
        return name != "" && typeText != ""
    typeText = TypedExprNormalizeTypeText(chengpath.TextSlice(tail, colonPos + 1, eqPos - colonPos - 1))
    let originalEqPos = parser.ParserFindText(lineRaw, "=")
    if originalEqPos < 0:
        return false
    rhsStartColumn = originalEqPos + 2
    for column in rhsStartColumn..lineRaw.len:
        if parser.ParserIsInlineSpace(lineRaw[column - 1]):
            rhsStartColumn = column + 1
        else:
            rhsStartColumn = column
            break
    return name != "" && typeText != ""

fn TypedExprLiteralBindingType(exprRaw: str): str =
    let expr = chengpath.PathTrim(exprRaw)
    if Len(expr) >= 2 && expr[0] == Char(34) && expr[Len(expr) - 1] == Char(34):
        return "str"
    if expr == "true" || expr == "false":
        return "bool"
    if TypedExprIrIsI32ConstLiteral(expr):
        return "int32"
    return ""

fn TypedExprConstructorBindingType(exprRaw: str): str =
    let expr = chengpath.PathTrim(exprRaw)
    let openPos = parser.ParserFindText(expr, "(")
    if openPos <= 0:
        return ""
    let closePos = TypedExprFindMatchingParen(expr, openPos)
    if closePos <= openPos || closePos + 1 != expr.len:
        return ""
    let typeText = parser.ParserIdentPrefix(chengpath.PathTrim(chengpath.TextSlice(expr,
                                                                                   0,
                                                                                   openPos)))
    if typeText == "":
        return ""
    return TypedExprNormalizeTypeText(typeText)

fn TypedExprBindingRhsText(lineRaw: str,
                            rhsStartColumn: int32): str =
    if rhsStartColumn <= 0 || rhsStartColumn > lineRaw.len:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(lineRaw,
                                                  rhsStartColumn - 1,
                                                  lineRaw.len - rhsStartColumn + 1))

fn TypedExprIrCallArgTypesText(ctx: var TypedExprSourceContext,
                                sourceContexts: var TypedExprSourceContext[],
                                scope: TypedExprFunctionScope,
                                lineNumber: int32,
                                argsTextRaw: str): str =
    let argsText = chengpath.PathTrim(argsTextRaw)
    if argsText == "":
        return ""
    let args = TypedExprSplitTopLevelCsv(argsText)
    var out = ""
    for i in 0..<args.len:
        let argText = chengpath.PathTrim(args[i])
        var argType = ""
        if argText != "":
            argType = TypedExprAssignStatementType(ctx,
                                                   sourceContexts,
                                                   scope,
                                                   lineNumber,
                                                   argText)
        if argType == "" && TypedExprIrIsI32ConstLiteral(argText):
            argType = "int32"
        if i > 0:
            out = strutil.Join([out, ","], "")
        out = strutil.Join([out, argType], "")
    return out

fn TypedExprIrPopulateAssignCallMeta(stmt: var TypedExprIrStatement,
                                      ctx: var TypedExprSourceContext,
                                      sourceContexts: var TypedExprSourceContext[],
                                      scope: TypedExprFunctionScope,
                                      lineNumber: int32,
                                      rhsRaw: str) =
    let rhsText = chengpath.PathTrim(rhsRaw)
    let callHead = TypedExprBindingRhsCallHead(rhsText)
    if callHead == "":
        return
    let openPos = TypedExprFindTopLevelToken(rhsText, "(")
    let closePos = TypedExprFindMatchingParen(rhsText, openPos)
    if openPos <= 0 || closePos <= openPos || closePos + 1 != rhsText.len:
        return
    let qualifier = TypedExprQualifiedCallQualifier(callHead)
    let callee = TypedExprQualifiedCallLeaf(callHead)
    if callee == "":
        return
    let argsText = chengpath.PathTrim(chengpath.TextSlice(rhsText,
                                                          openPos + 1,
                                                          closePos - openPos - 1))
    var resolvedSourcePath = ""
    var resolvedTargetName = ""
    var resolvedImportc = false
    var resolvedReturnType = ""
    if qualifier != "":
        resolvedReturnType = TypedExprResolveQualifiedCallTargetReturnType(ctx,
                                                                           sourceContexts,
                                                                           qualifier,
                                                                           callee,
                                                                           callHead,
                                                                           resolvedSourcePath,
                                                                           resolvedTargetName,
                                                                           resolvedImportc)
    else:
        let importcReturnType = TypedExprLookupLocalImportcReturnTypeForCall(ctx,
                                                                             callee,
                                                                             callee)
        if importcReturnType != "":
            resolvedReturnType = importcReturnType
            resolvedSourcePath = ctx.sourcePath
            resolvedTargetName = callee
            resolvedImportc = true
        else:
            let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, callee)
            if localReturnType != "":
                resolvedReturnType = localReturnType
                resolvedSourcePath = ctx.sourcePath
                resolvedTargetName = callee
                resolvedImportc = false
    if resolvedReturnType == "" || resolvedTargetName == "":
        return
    stmt.callKind = TypedExprCallNone
    stmt.callQualifier = qualifier
    stmt.callCallee = callee
    stmt.callTarget = resolvedTargetName
    stmt.callTargetSourcePath = resolvedSourcePath
    stmt.callTargetImportc = resolvedImportc
    stmt.resultType = resolvedReturnType
    stmt.callArgCount = parser.ParserCountTopLevelArgs(argsText)
    stmt.callArgsText = argsText
    stmt.callArgTypesText = TypedExprIrCallArgTypesText(ctx,
                                                        sourceContexts,
                                                        scope,
                                                        lineNumber,
                                                        argsText)

fn TypedExprIrBindAssignStatementCallFact(stmt: var TypedExprIrStatement,
                                           ctx: var TypedExprSourceContext,
                                           sourceContexts: var TypedExprSourceContext[],
                                           scope: TypedExprFunctionScope,
                                           fact: TypedExprFact) =
    if fact.kind != parser.NormalizedExprCall &&
       fact.kind != parser.NormalizedExprResultIntrinsic:
        return
    if fact.callCallee == "" && fact.callTarget == "":
        return
    stmt.callKind = TypedExprCallNone
    stmt.callQualifier = fact.callQualifier
    stmt.callCallee = fact.callCallee
    stmt.callTarget = fact.callTarget
    stmt.callTargetSourcePath = fact.callTargetSourcePath
    stmt.callTargetImportc = fact.callTargetImportc
    var resolvedCallReturnType = TypedExprLookupCallTargetReturnTypeFromFact(ctx,
                                                                             sourceContexts,
                                                                             fact)
    if fact.callQualifier != "" &&
       fact.surfaceCallKind != TypedExprSurfaceCallMember:
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        let qualifiedReturnType = TypedExprResolveQualifiedCallTargetReturnType(ctx,
                                                                                sourceContexts,
                                                                                fact.callQualifier,
                                                                                fact.callCallee,
                                                                                fact.callTarget,
                                                                                resolvedSourcePath,
                                                                                resolvedTargetName,
                                                                                resolvedImportc)
        if qualifiedReturnType != "":
            resolvedCallReturnType = qualifiedReturnType
            stmt.callTarget = resolvedTargetName
            stmt.callTargetSourcePath = resolvedSourcePath
            stmt.callTargetImportc = resolvedImportc
    if resolvedCallReturnType != "":
        stmt.resultType = resolvedCallReturnType
    stmt.callArgCount = fact.callArgCount
    stmt.callArgsText = fact.callArgsText
    stmt.callArgTypesText = TypedExprIrCallArgTypesText(ctx,
                                                        sourceContexts,
                                                        scope,
                                                        fact.lineNumber,
                                                        fact.callArgsText)

fn TypedExprIrAddLocalDeclStatement(ir: var TypedExprIr,
                                     scope: TypedExprFunctionScope,
                                     sourcePath: str,
                                     lineNumber: int32,
                                     lineIndent: int32,
                                     bindingName: str,
                                     bindingTypeRaw: str,
                                     rhsText: str) =
    let bindingType = TypedExprNormalizeTypeText(bindingTypeRaw)
    if Len(bindingName) <= 0 || Len(bindingType) <= 0:
        return
    var stmt: TypedExprIrStatement
    stmt.sourcePath = sourcePath
    stmt.functionName = scope.name
    stmt.statementIndex = ir.statements.len
    stmt.lineNumber = lineNumber
    stmt.columnNumber = 1
    stmt.lineIndent = lineIndent
    stmt.enclosingIfLineNumber = -1
    stmt.enclosingIfConditionText = ""
    stmt.exprId = ""
    stmt.kind = TypedExprIrStmtLocalDecl
    stmt.callKind = TypedExprCallNone
    stmt.detailKind = parser.NormalizedExprDetailNone
    stmt.surfaceText = rhsText
    stmt.bindingName = bindingName
    stmt.resultType = bindingType
    stmt.conditionKind = TypedExprIrCondNone
    stmt.conditionLhsText = ""
    stmt.conditionRhsText = ""
    stmt.conditionLiteralText = ""
    stmt.assignRootName = ""
    stmt.assignRootType = ""
    stmt.assignRootSourcePath = ""
    stmt.assignRootGlobalFlag = false
    stmt.assignPlaceKind = TypedExprPlaceTemporary
    stmt.assignFieldName = ""
    stmt.assignFieldType = ""
    stmt.assignFieldOffsetBytes = 0
    stmt.assignFieldSizeBytes = 0
    stmt.assignFieldAlignBytes = 0
    stmt.assignValueRootName = ""
    stmt.assignValueRootType = ""
    stmt.assignValueFieldName = ""
    stmt.assignValueFieldType = ""
    stmt.assignValueFieldOffsetBytes = 0
    stmt.assignValueFieldSizeBytes = 0
    stmt.assignValueFieldAlignBytes = 0
    stmt.assignValueOpKind = TypedExprIrOpUnsupported
    stmt.assignValueLhsText = ""
    stmt.assignValueRhsText = ""
    stmt.assignValueRhsConst = 0
    stmt.assignValueRhsHasConst = false
    var eqPos = TypedExprFindTopLevelTextToken(rhsText, "==")
    var cmpKind = TypedExprIrCondStrEqLocal
    if eqPos < 0:
        eqPos = TypedExprFindTopLevelTextToken(rhsText, "!=")
        cmpKind = TypedExprIrCondStrNeLocal
    if eqPos >= 0:
        stmt.conditionKind = cmpKind
        stmt.conditionLhsText = chengpath.PathTrim(chengpath.TextSlice(rhsText, 0, eqPos))
        stmt.conditionRhsText = chengpath.PathTrim(chengpath.TextSlice(rhsText,
                                                                       eqPos + 2,
                                                                       rhsText.len - eqPos - 2))
    let qPos = TypedExprFindTopLevelTextToken(rhsText, "?")
    let colonPos = TypedExprFindTopLevelTextToken(rhsText, ":")
    if qPos >= 0 && colonPos > qPos:
        stmt.assignValueOpKind = TypedExprIrOpLocalBoolEnumTernary
        stmt.assignValueLhsText = chengpath.PathTrim(chengpath.TextSlice(rhsText, 0, qPos))
        stmt.assignValueRhsText = chengpath.PathTrim(chengpath.TextSlice(rhsText,
                                                                         qPos + 1,
                                                                         colonPos - qPos - 1))
        stmt.conditionRhsText = chengpath.PathTrim(chengpath.TextSlice(rhsText,
                                                                       colonPos + 1,
                                                                       rhsText.len - colonPos - 1))
    stmt.callQualifier = ""
    stmt.callCallee = ""
    stmt.callTarget = ""
    stmt.callTargetSourcePath = ""
    stmt.callTargetImportc = false
    stmt.callArgCount = 0
    stmt.callArgsText = ""
    stmt.callArgTypesText = ""
    stmt.loweringMode = TypedExprLowerLocalAddress
    stmt.returnKind = TypedExprReturnDeferred
    stmt.returnRoot = false
    add(ir.statements, stmt)

fn TypedExprIrAppendLocalDeclStatementsForScope(ir: var TypedExprIr,
                                                 ctx: var TypedExprSourceContext,
                                                 sourceContexts: var TypedExprSourceContext[],
                                                 scope: TypedExprFunctionScope) =
    if scope.startLine + 1 > scope.endLine:
        return
    for lineNumber in (scope.startLine + 1)..scope.endLine:
        let lineRaw = TypedExprSourceLine(ctx, lineNumber)
        let trimmedLine = chengpath.PathTrim(lineRaw)
        if Len(trimmedLine) <= 0:
            continue
        if !parser.ParserStartsWith(trimmedLine, "let ") &&
           !parser.ParserStartsWith(trimmedLine, "var ") &&
           !parser.ParserStartsWith(trimmedLine, "const "):
            continue
        var bindingName = ""
        var bindingType = ""
        var rhsStartColumn: int32 = -1
        if !TypedExprParseBindingLine(lineRaw, bindingName, bindingType, rhsStartColumn):
            continue
        let rhsText = TypedExprBindingRhsText(lineRaw, rhsStartColumn)
        if Len(bindingType) <= 0:
            bindingType = TypedExprLiteralBindingType(rhsText)
        if Len(bindingType) <= 0:
            bindingType = TypedExprBindingRhsCompareType(rhsText)
        if Len(bindingType) <= 0:
            let callHead = TypedExprBindingRhsCallHead(rhsText)
            let callLeaf = TypedExprQualifiedCallLeaf(callHead)
            if callLeaf == "Value" ||
               callLeaf == "IsOk" ||
               callLeaf == "IsErr" ||
               callLeaf == "Error" ||
               callLeaf == "ErrorInfoOf":
                let openPos = TypedExprFindTopLevelToken(rhsText, "(")
                let closePos = TypedExprFindMatchingParen(rhsText, openPos)
                if openPos > 0 && closePos > openPos:
                    var argsText = chengpath.PathTrim(chengpath.TextSlice(rhsText,
                                                                          openPos + 1,
                                                                          closePos - openPos - 1))
                    let commaPos = TypedExprFindTopLevelToken(argsText, ",")
                    if commaPos >= 0:
                        argsText = chengpath.PathTrim(chengpath.TextSlice(argsText, 0, commaPos))
                    let resultArgName = parser.ParserIdentPrefix(argsText)
                    if resultArgName != "":
                        var resultArgType = TypedExprLookupBindingType(ctx,
                                                                       TypedExprScopeIndexForLine(ctx.scopes, lineNumber),
                                                                       lineNumber,
                                                                       resultArgName)
                        if resultArgType == "":
                            resultArgType = TypedExprIrPriorBindingType(ir,
                                                                        scope.name,
                                                                        lineNumber,
                                                                        resultArgName)
                        if callLeaf == "Value":
                            bindingType = TypedExprResultSuccessType(resultArgType)
                        elif callLeaf == "IsOk" || callLeaf == "IsErr":
                            bindingType = "bool"
                        elif callLeaf == "Error":
                            bindingType = "str"
                        elif callLeaf == "ErrorInfoOf":
                            bindingType = "ErrorInfo"
        if Len(bindingType) <= 0:
            let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
            bindingType = TypedExprLookupBindingType(ctx,
                                                     scopeIndex,
                                                     lineNumber,
                                                     bindingName)
        if Len(bindingType) <= 0:
            bindingType = TypedExprBindingRhsCallReturnType(ctx,
                                                            sourceContexts,
                                                            rhsText)
            if !TypedExprTypeTextIsConcrete(bindingType):
                bindingType = ""
        if Len(bindingType) <= 0:
            bindingType = TypedExprBindingRhsTernaryType(ctx,
                                                         sourceContexts,
                                                         rhsText)
        if Len(bindingType) <= 0:
            bindingType = TypedExprConstructorBindingType(rhsText)
        if Len(bindingType) <= 0:
            continue
        TypedExprIrAddLocalDeclStatement(ir,
                                         scope,
                                         ctx.sourcePath,
                                         lineNumber,
                                         TypedExprLineIndentWidth(lineRaw),
                                         bindingName,
                                         bindingType,
                                         rhsText)

fn TypedExprSourceContextIndexBucketCount(ctxCount: int32): int32 =
    var need = ctxCount * 2 + 8
    if need < 16:
        need = 16
    var out = 1
    while out < need:
        out = out * 2
    return out

fn TypedExprSourceContextIndexHash(sourcePath: str, bucketCount: int32): int32 =
    if bucketCount <= 0:
        return -1
    var h: int32
    for i in 0..<len(sourcePath):
        h = h * 31 + int32(sourcePath[i])
    if h < 0:
        h = -h
    return h & (bucketCount - 1)

fn TypedExprBuildSourceContextIndex(ir: var TypedExprIr,
                                      sourceContexts: var TypedExprSourceContext[]) =
    ir.sourceContextIndexSourcePaths = []
    ir.sourceContextIndexBucketHeads = []
    ir.sourceContextIndexEntryNext = []
    ir.sourceContextIndexEntryIndexes = []
    let bucketCount = TypedExprSourceContextIndexBucketCount(sourceContexts.len)
    var bucketTails: int32[]
    for bucketIndex in 0..<bucketCount:
        add(ir.sourceContextIndexBucketHeads, -1)
        add(bucketTails, -1)
    for ctxIndex in 0..<sourceContexts.len:
        let sourcePath = sourceContexts[ctxIndex].normalizedSourcePath
        if sourcePath == "":
            continue
        let bucket = TypedExprSourceContextIndexHash(sourcePath, bucketCount)
        let entryIndex = ir.sourceContextIndexEntryIndexes.len
        add(ir.sourceContextIndexEntryNext, -1)
        add(ir.sourceContextIndexEntryIndexes, ctxIndex)
        add(ir.sourceContextIndexSourcePaths, sourcePath)
        if ir.sourceContextIndexBucketHeads[bucket] < 0:
            ir.sourceContextIndexBucketHeads[bucket] = entryIndex
        else:
            ir.sourceContextIndexEntryNext[bucketTails[bucket]] = entryIndex
        bucketTails[bucket] = entryIndex

fn TypedExprSourceContextLookupWithIndex(ir: TypedExprIr,
                                           sourcePathRaw: str): int32 =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    if sourcePath == "" || ir.sourceContextIndexBucketHeads.len <= 0:
        return -1
    let bucket = TypedExprSourceContextIndexHash(sourcePath,
                                                  ir.sourceContextIndexBucketHeads.len)
    var entryIndex = ir.sourceContextIndexBucketHeads[bucket]
    while entryIndex >= 0:
        if entryIndex >= ir.sourceContextIndexEntryIndexes.len:
            return -1
        if ir.sourceContextIndexSourcePaths[entryIndex] == sourcePath:
            return ir.sourceContextIndexEntryIndexes[entryIndex]
        entryIndex = ir.sourceContextIndexEntryNext[entryIndex]
    return -1

fn TypedExprSourceContextLookup(sourceContexts: var TypedExprSourceContext[],
                                  sourcePathRaw: str): int32 =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<sourceContexts.len:
        if sourceContexts[i].normalizedSourcePath == sourcePath:
            return i
    return -1

fn TypedExprSourceContextLookupFast(ir: TypedExprIr,
                                      sourceContexts: var TypedExprSourceContext[],
                                      sourcePathRaw: str): int32 =
    if ir.sourceContextIndexBucketHeads.len > 0:
        let fastResult = TypedExprSourceContextLookupWithIndex(ir, sourcePathRaw)
        if fastResult >= 0:
            return fastResult
    return TypedExprSourceContextLookup(sourceContexts, sourcePathRaw)

fn TypedExprFieldContextLookup(currentCtx: var TypedExprSourceContext,
                                sourceContexts: var TypedExprSourceContext[],
                                ownerTypeRaw: str): int32 =
    let ownerType = TypedExprTypeLeafName(ownerTypeRaw)
    let typeText = TypedExprStripVarType(ownerTypeRaw)
    let dotPos = TypedExprQualifiedTypeDot(typeText)
    if dotPos > 0:
        let qualifier = chengpath.PathTrim(chengpath.TextSlice(typeText, 0, dotPos))
        let targetPath = TypedExprLookupQualifiedModuleSourcePath(currentCtx,
                                                                  sourceContexts,
                                                                  qualifier)
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetPath)
        if targetIndex >= 0 && TypedExprContextHasTypeField(sourceContexts[targetIndex], ownerType):
            return targetIndex
        return -1
    if TypedExprContextHasTypeField(currentCtx, ownerType):
        return -2
    var found: int32 = -1
    for i in 0..<sourceContexts.len:
        if !TypedExprContextHasTypeField(sourceContexts[i], ownerType):
            continue
        if found >= 0:
            return -1
        found = i
    return found

fn TypedExprDeclaredTypeContextLookup(currentCtx: var TypedExprSourceContext,
                                       sourceContexts: var TypedExprSourceContext[],
                                       typeRaw: str): int32 =
    let typeText = TypedExprStripVarType(typeRaw)
    let leaf = TypedExprTypeLeafName(typeText)
    if leaf == "":
        return -1
    let dotPos = TypedExprQualifiedTypeDot(typeText)
    if dotPos > 0:
        let qualifier = chengpath.PathTrim(chengpath.TextSlice(typeText, 0, dotPos))
        let targetPath = TypedExprLookupQualifiedModuleSourcePath(currentCtx,
                                                                  sourceContexts,
                                                                  qualifier)
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetPath)
        if targetIndex >= 0 && TypedExprSourceHasDeclaredType(sourceContexts[targetIndex], leaf):
            return targetIndex
        return -1
    if TypedExprSourceHasDeclaredType(currentCtx, leaf):
        return -2
    var found: int32 = -1
    for i in 0..<sourceContexts.len:
        if !TypedExprSourceHasDeclaredType(sourceContexts[i], leaf):
            continue
        if found >= 0:
            return -1
        found = i
    return found

fn TypedExprTypeLayoutImpl(currentCtx: var TypedExprSourceContext,
                            sourceContexts: var TypedExprSourceContext[],
                            typeRaw: str,
                            sizeBytes: var int32,
                            alignBytes: var int32,
                            depth: int32): bool =
    sizeBytes = 0
    alignBytes = 0
    if depth > 64:
        return false
    let typeText = TypedExprStripVarType(typeRaw)
    if typeText == "":
        return false
    if typeText == "bool" || typeText == "int8" || typeText == "uint8" || typeText == "u8":
        sizeBytes = 1
        alignBytes = 1
        return true
    if typeText == "int16" || typeText == "uint16" || typeText == "u16":
        sizeBytes = 2
        alignBytes = 2
        return true
    if typeText == "int32" || typeText == "int" ||
       typeText == "uint32" || typeText == "u32" ||
       typeText == "char":
        sizeBytes = 4
        alignBytes = 4
        return true
    if typeText == "int64" || typeText == "uint64" ||
       typeText == "u64" || typeText == "float32" ||
       typeText == "float64":
        sizeBytes = 8
        alignBytes = 8
        return true
    if typeText == "ptr" || typeText == "cstring" ||
       parser.ParserStartsWith(typeText, "ref"):
        sizeBytes = 8
        alignBytes = 8
        return true
    if typeText == "str":
        sizeBytes = 24
        alignBytes = 8
        return true
    if typeText == "Bytes" || typeText == "bytes.Bytes" || typeText == "rawbytes.Bytes":
        sizeBytes = 16
        alignBytes = 8
        return true
    if typeText == "FixedBytes32" || typeText == "layout.FixedBytes32" || typeText == "bytes_layout.FixedBytes32":
        sizeBytes = 32
        alignBytes = 1
        return true
    if typeText == "FixedBytes64" || typeText == "layout.FixedBytes64" || typeText == "bytes_layout.FixedBytes64":
        sizeBytes = 64
        alignBytes = 1
        return true
    if typeText == "FixedBytes65" || typeText == "layout.FixedBytes65" || typeText == "bytes_layout.FixedBytes65":
        sizeBytes = 65
        alignBytes = 1
        return true
    if typeText.len >= 2 && chengpath.TextSlice(typeText, typeText.len - 2, 2) == "[]":
        sizeBytes = 16
        alignBytes = 8
        return true
    if parser.ParserStartsWith(typeText, "seq[") ||
       parser.ParserStartsWith(typeText, "array["):
        sizeBytes = 16
        alignBytes = 8
        return true
    if parser.ParserStartsWith(typeText, "Result[") &&
       typeText.len > 8 &&
       chengpath.TextSlice(typeText, typeText.len - 1, 1) == "]":
        let inner = chengpath.TextSlice(typeText, 7, typeText.len - 8)
        var valueSize: int32
        var valueAlign: int32
        var errSize: int32
        var errAlign: int32
        if !TypedExprTypeLayoutImpl(currentCtx, sourceContexts, inner, valueSize, valueAlign, depth + 1):
            return false
        if !TypedExprTypeLayoutImpl(currentCtx, sourceContexts, "ErrorInfo", errSize, errAlign, depth + 1):
            return false
        let valueOffset = TypedExprAlignBytes(1, valueAlign)
        let errOffset = TypedExprAlignBytes(valueOffset + valueSize, errAlign)
        alignBytes = valueAlign
        if errAlign > alignBytes:
            alignBytes = errAlign
        if alignBytes <= 0:
            alignBytes = 1
        sizeBytes = TypedExprAlignBytes(errOffset + errSize, alignBytes)
        return true
    let declaredIndex = TypedExprDeclaredTypeContextLookup(currentCtx, sourceContexts, typeText)
    if declaredIndex == -2:
        if !TypedExprContextHasTypeField(currentCtx, typeText):
            sizeBytes = 4
            alignBytes = 4
            return true
    elif declaredIndex >= 0:
        if !TypedExprContextHasTypeField(sourceContexts[declaredIndex], typeText):
            sizeBytes = 4
            alignBytes = 4
            return true
    let ctxIndex = TypedExprFieldContextLookup(currentCtx, sourceContexts, typeText)
    var ownerCtx = currentCtx
    if ctxIndex >= 0:
        ownerCtx = sourceContexts[ctxIndex]
    elif ctxIndex != -2:
        if TypedExprSourceHasDeclaredType(currentCtx, TypedExprTypeLeafName(typeText)):
            sizeBytes = 4
            alignBytes = 4
            return true
        return false
    if !TypedExprContextHasTypeField(ownerCtx, typeText):
        if TypedExprSourceHasDeclaredType(ownerCtx, TypedExprTypeLeafName(typeText)):
            sizeBytes = 4
            alignBytes = 4
            return true
        return false
    var offset: int32
    var maxAlign: int32 = 1
    let ownerType = TypedExprTypeLeafName(typeText)
    for i in 0..<ownerCtx.typeFields.len:
        let field = ownerCtx.typeFields[i]
        if field.ownerType != ownerType:
            continue
        var fieldSize: int32
        var fieldAlign: int32
        if !TypedExprTypeLayoutImpl(ownerCtx, sourceContexts, field.fieldType, fieldSize, fieldAlign, depth + 1):
            return false
        if fieldAlign <= 0:
            fieldAlign = 1
        offset = TypedExprAlignBytes(offset, fieldAlign)
        offset = offset + fieldSize
        if fieldAlign > maxAlign:
            maxAlign = fieldAlign
    sizeBytes = TypedExprAlignBytes(offset, maxAlign)
    alignBytes = maxAlign
    return true

fn TypedExprTypeLayout(currentCtx: var TypedExprSourceContext,
                        sourceContexts: var TypedExprSourceContext[],
                        typeRaw: str,
                        sizeBytes: var int32,
                        alignBytes: var int32): bool =
    return TypedExprTypeLayoutImpl(currentCtx, sourceContexts, typeRaw, sizeBytes, alignBytes, 0)

fn TypedExprContextFieldCountForType(ctx: var TypedExprSourceContext,
                                      typeRaw: str): int32 =
    let ownerType = TypedExprTypeLeafName(typeRaw)
    var count: int32
    for i in 0..<ctx.typeFields.len:
        if ctx.typeFields[i].ownerType == ownerType:
            count = count + 1
    return count

fn TypedExprIrAppendTypeLayout(ir: var TypedExprIr,
                                sourcePathRaw: str,
                                typeNameRaw: str,
                                sizeBytes: int32,
                                alignBytes: int32,
                                fieldCount: int32) =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let typeName = TypedExprNormalizeTypeText(typeNameRaw)
    if sourcePath == "" || typeName == "" || sizeBytes <= 0 || alignBytes <= 0:
        return
    for i in 0..<ir.typeLayoutSourcePaths.len:
        if i >= ir.typeLayoutNames.len:
            continue
        if parser.ParserNormalizePath(ir.typeLayoutSourcePaths[i]) == sourcePath &&
           ir.typeLayoutNames[i] == typeName:
            return
    add(ir.typeLayoutSourcePaths, sourcePath)
    add(ir.typeLayoutNames, typeName)
    add(ir.typeLayoutSizeBytes, sizeBytes)
    add(ir.typeLayoutAlignBytes, alignBytes)
    add(ir.typeLayoutFieldCounts, fieldCount)

fn TypedExprIrAppendTypeFieldLayout(ir: var TypedExprIr,
                                     sourcePathRaw: str,
                                     ownerTypeRaw: str,
                                     fieldNameRaw: str,
                                     fieldTypeRaw: str,
                                     fieldOffsetBytes: int32,
                                     fieldSizeBytes: int32,
                                     fieldAlignBytes: int32) =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let ownerType = TypedExprNormalizeTypeText(ownerTypeRaw)
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    let fieldType = TypedExprNormalizeTypeText(fieldTypeRaw)
    if sourcePath == "" || ownerType == "" || fieldName == "" || fieldType == "":
        return
    if fieldOffsetBytes < 0 || fieldSizeBytes <= 0 || fieldAlignBytes <= 0:
        return
    for i in 0..<ir.typeFieldOwnerTypes.len:
        if i >= ir.typeFieldSourcePaths.len || i >= ir.typeFieldNames.len:
            continue
        if parser.ParserNormalizePath(ir.typeFieldSourcePaths[i]) == sourcePath &&
           ir.typeFieldOwnerTypes[i] == ownerType &&
           ir.typeFieldNames[i] == fieldName:
            return
    add(ir.typeFieldSourcePaths, sourcePath)
    add(ir.typeFieldOwnerTypes, ownerType)
    add(ir.typeFieldNames, fieldName)
    add(ir.typeFieldTypes, fieldType)
    add(ir.typeFieldOffsetBytes, fieldOffsetBytes)
    add(ir.typeFieldSizeBytes, fieldSizeBytes)
    add(ir.typeFieldAlignBytes, fieldAlignBytes)

fn TypedExprMaybeQualifyImportedFieldType(importedCtx: var TypedExprSourceContext,
                                           qualifier: str,
                                           fieldTypeRaw: str): str =
    let fieldType = TypedExprNormalizeTypeText(fieldTypeRaw)
    if qualifier == "" || fieldType == "":
        return fieldType
    if TypedExprQualifiedTypeDot(fieldType) > 0:
        return fieldType
    if TypedExprSourceHasDeclaredType(importedCtx, fieldType):
        return Fmt"{qualifier}.{fieldType}"
    return fieldType

fn TypedExprIrAppendTypeLayoutsFromContext(ir: var TypedExprIr,
                                            ctx: var TypedExprSourceContext,
                                            sourceContexts: var TypedExprSourceContext[]) =
    for i in 0..<ctx.declaredTypes.len:
        let typeName = ctx.declaredTypes[i]
        var sizeBytes: int32
        var alignBytes: int32
        if !TypedExprTypeLayout(ctx, sourceContexts, typeName, sizeBytes, alignBytes):
            continue
        let fieldCount = TypedExprContextFieldCountForType(ctx, typeName)
        TypedExprIrAppendTypeLayout(ir,
                                    ctx.sourcePath,
                                    typeName,
                                    sizeBytes,
                                    alignBytes,
                                    fieldCount)
        let ownerType = TypedExprTypeLeafName(typeName)
        for fieldIndex in 0..<ctx.typeFields.len:
            let field = ctx.typeFields[fieldIndex]
            if field.ownerType != ownerType:
                continue
            var fieldType = ""
            var fieldOffsetBytes: int32
            var fieldSizeBytes: int32
            var fieldAlignBytes: int32
            if !TypedExprResolveFieldPathMeta(ctx,
                                             sourceContexts,
                                             typeName,
                                             field.fieldName,
                                             fieldType,
                                             fieldOffsetBytes,
                                             fieldSizeBytes,
                                             fieldAlignBytes):
                continue
            TypedExprIrAppendTypeFieldLayout(ir,
                                             ctx.sourcePath,
                                             typeName,
                                             field.fieldName,
                                             fieldType,
                                             fieldOffsetBytes,
                                             fieldSizeBytes,
                                             fieldAlignBytes)
    for importIndex in 0..<ctx.importedModules.len:
        let qualifier = ctx.importedModules[importIndex].qualifier
        let targetSourcePath = ctx.importedModules[importIndex].targetSourcePath
        if qualifier == "" || targetSourcePath == "":
            continue
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
        if targetIndex < 0:
            continue
        for typeIndex in 0..<sourceContexts[targetIndex].declaredTypes.len:
            let importedTypeName = sourceContexts[targetIndex].declaredTypes[typeIndex]
            var importedSizeBytes: int32
            var importedAlignBytes: int32
            if !TypedExprTypeLayout(sourceContexts[targetIndex],
                                    sourceContexts,
                                    importedTypeName,
                                    importedSizeBytes,
                                    importedAlignBytes):
                continue
            let importedFieldCount = TypedExprContextFieldCountForType(sourceContexts[targetIndex],
                                                                       importedTypeName)
            TypedExprIrAppendTypeLayout(ir,
                                        ctx.sourcePath,
                                        Fmt"{qualifier}.{importedTypeName}",
                                        importedSizeBytes,
                                        importedAlignBytes,
                                        importedFieldCount)
            let importedOwnerType = TypedExprTypeLeafName(importedTypeName)
            for fieldIndex in 0..<sourceContexts[targetIndex].typeFields.len:
                let field = sourceContexts[targetIndex].typeFields[fieldIndex]
                if field.ownerType != importedOwnerType:
                    continue
                var fieldType = ""
                var fieldOffsetBytes: int32
                var fieldSizeBytes: int32
                var fieldAlignBytes: int32
                if !TypedExprResolveFieldPathMeta(sourceContexts[targetIndex],
                                                 sourceContexts,
                                                 importedTypeName,
                                                 field.fieldName,
                                                 fieldType,
                                                 fieldOffsetBytes,
                                                 fieldSizeBytes,
                                                 fieldAlignBytes):
                    continue
                TypedExprIrAppendTypeFieldLayout(ir,
                                                 ctx.sourcePath,
                                                 Fmt"{qualifier}.{importedTypeName}",
                                                 field.fieldName,
                                                 TypedExprMaybeQualifyImportedFieldType(sourceContexts[targetIndex],
                                                                                        qualifier,
                                                                                        fieldType),
                                                 fieldOffsetBytes,
                                                 fieldSizeBytes,
                                                 fieldAlignBytes)

fn TypedExprIrAppendEnumValuesFromContext(ir: var TypedExprIr,
                                           ctx: var TypedExprSourceContext) =
    for i in 0..<ctx.enumValueNames.len:
        if i >= ctx.enumValueTypes.len || i >= ctx.enumValueOrdinals.len:
            continue
        let name = ctx.enumValueNames[i]
        let typeName = ctx.enumValueTypes[i]
        if name == "" || typeName == "":
            continue
        var seen = false
        for j in 0..<ir.enumValueNames.len:
            if j >= ir.enumValueSourcePaths.len:
                continue
            if parser.ParserNormalizePath(ir.enumValueSourcePaths[j]) == parser.ParserNormalizePath(ctx.sourcePath) &&
               ir.enumValueNames[j] == name:
                seen = true
                break
        if seen:
            continue
        add(ir.enumValueSourcePaths, parser.ParserNormalizePath(ctx.sourcePath))
        add(ir.enumValueNames, name)
        add(ir.enumValueTypes, typeName)
        add(ir.enumValueOrdinals, ctx.enumValueOrdinals[i])

fn TypedExprIrLookupEnumConstValue(ir: TypedExprIr,
                                    sourcePathRaw: str,
                                    nameRaw: str,
                                    typeNameOut: var str,
                                    valueOut: var int32): bool =
    typeNameOut = ""
    valueOut = 0
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let nameText = chengpath.PathTrim(nameRaw)
    var nameStart: int32
    for ci in 0..<nameText.len:
        if nameText[ci] == '.':
            nameStart = ci + 1
    let name = parser.ParserIdentPrefix(chengpath.TextSlice(nameText,
                                                            nameStart,
                                                            nameText.len - nameStart))
    if name == "":
        return false
    var foundIndex: int32 = -1
    for i in 0..<ir.enumValueNames.len:
        if i >= ir.enumValueSourcePaths.len ||
           i >= ir.enumValueTypes.len ||
           i >= ir.enumValueOrdinals.len:
            continue
        if ir.enumValueNames[i] != name:
            continue
        if sourcePath != "" &&
           parser.ParserNormalizePath(ir.enumValueSourcePaths[i]) == sourcePath:
            foundIndex = i
            break
        if foundIndex < 0:
            foundIndex = i
        elif ir.enumValueTypes[foundIndex] != ir.enumValueTypes[i] ||
             ir.enumValueOrdinals[foundIndex] != ir.enumValueOrdinals[i]:
            return false
    if foundIndex < 0:
        return false
    typeNameOut = ir.enumValueTypes[foundIndex]
    valueOut = ir.enumValueOrdinals[foundIndex]
    return true

fn TypedExprIrTypeIsEnum(ir: TypedExprIr,
                          sourcePathRaw: str,
                          typeRaw: str): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let typeName = TypedExprStripVarType(typeRaw)
    let leafName = TypedExprTypeLeafName(typeName)
    if typeName == "" || leafName == "":
        return false
    var foundSourcePath = ""
    for i in 0..<ir.enumValueTypes.len:
        if i >= ir.enumValueSourcePaths.len:
            continue
        if ir.enumValueTypes[i] != typeName &&
           ir.enumValueTypes[i] != leafName:
            continue
        let enumSourcePath = parser.ParserNormalizePath(ir.enumValueSourcePaths[i])
        if sourcePath != "" && enumSourcePath == sourcePath:
            return true
        if foundSourcePath == "":
            foundSourcePath = enumSourcePath
        elif foundSourcePath != enumSourcePath:
            return false
    return foundSourcePath != ""

fn TypedExprIrBuiltinTypeLayout(typeRaw: str,
                                 sizeBytes: var int32,
                                 alignBytes: var int32,
                                 fieldCount: var int32): bool =
    sizeBytes = 0
    alignBytes = 0
    fieldCount = 0
    let typeText = TypedExprStripVarType(typeRaw)
    if typeText.len >= 2 && chengpath.TextSlice(typeText, typeText.len - 2, 2) == "[]":
        sizeBytes = 16
        alignBytes = 8
        fieldCount = 3
        return true
    if parser.ParserStartsWith(typeText, "seq[") ||
       parser.ParserStartsWith(typeText, "array["):
        sizeBytes = 16
        alignBytes = 8
        fieldCount = 3
        return true
    if typeText == "str":
        sizeBytes = 24
        alignBytes = 8
        fieldCount = 4
        return true
    if typeText == "Bytes" || typeText == "bytes.Bytes" || typeText == "rawbytes.Bytes":
        sizeBytes = 16
        alignBytes = 8
        fieldCount = 2
        return true
    if typeText == "FixedBytes32" || typeText == "layout.FixedBytes32" || typeText == "bytes_layout.FixedBytes32":
        sizeBytes = 32
        alignBytes = 1
        fieldCount = 1
        return true
    if typeText == "FixedBytes64" || typeText == "layout.FixedBytes64" || typeText == "bytes_layout.FixedBytes64":
        sizeBytes = 64
        alignBytes = 1
        fieldCount = 1
        return true
    if typeText == "FixedBytes65" || typeText == "layout.FixedBytes65" || typeText == "bytes_layout.FixedBytes65":
        sizeBytes = 65
        alignBytes = 1
        fieldCount = 1
        return true
    if typeText == "ErrorInfo":
        sizeBytes = 32
        alignBytes = 8
        fieldCount = 2
        return true
    return false

fn TypedExprIrLookupTypeLayout(ir: TypedExprIr,
                                sourcePathRaw: str,
                                typeRaw: str,
                                sizeBytes: var int32,
                                alignBytes: var int32,
                                fieldCount: var int32): bool =
    if TypedExprIrBuiltinTypeLayout(typeRaw, sizeBytes, alignBytes, fieldCount):
        return true
    let normalizedType = TypedExprStripVarType(typeRaw)
    if parser.ParserStartsWith(normalizedType, "Result[") &&
       normalizedType.len > 8 &&
       chengpath.TextSlice(normalizedType, normalizedType.len - 1, 1) == "]":
        let inner = chengpath.TextSlice(normalizedType, 7, normalizedType.len - 8)
        var valueSize: int32
        var valueAlign: int32
        var valueFieldCount: int32
        if !TypedExprIrLookupTypeLayout(ir,
                                        sourcePathRaw,
                                        inner,
                                        valueSize,
                                        valueAlign,
                                        valueFieldCount):
            return false
        var errSize: int32
        var errAlign: int32
        var errFieldCount: int32
        if !TypedExprIrLookupTypeLayout(ir,
                                        sourcePathRaw,
                                        "ErrorInfo",
                                        errSize,
                                        errAlign,
                                        errFieldCount):
            return false
        let valueOffset = TypedExprAlignBytes(1, valueAlign)
        let errOffset = TypedExprAlignBytes(valueOffset + valueSize, errAlign)
        alignBytes = valueAlign
        if errAlign > alignBytes:
            alignBytes = errAlign
        if alignBytes <= 0:
            alignBytes = 1
        sizeBytes = TypedExprAlignBytes(errOffset + errSize, alignBytes)
        fieldCount = 3
        return true
    sizeBytes = 0
    alignBytes = 0
    fieldCount = 0
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let fullTypeName = TypedExprStripVarType(typeRaw)
    var typeName = fullTypeName
    if typeName == "":
        return false
    var foundIndex: int32 = -1
    for i in 0..<ir.typeLayoutNames.len:
        if ir.typeLayoutNames[i] != typeName:
            continue
        if i < ir.typeLayoutSourcePaths.len &&
           parser.ParserNormalizePath(ir.typeLayoutSourcePaths[i]) == sourcePath:
            foundIndex = i
            break
        if foundIndex < 0:
            foundIndex = i
        elif i < ir.typeLayoutSourcePaths.len &&
             foundIndex < ir.typeLayoutSourcePaths.len &&
             parser.ParserNormalizePath(ir.typeLayoutSourcePaths[i]) != parser.ParserNormalizePath(ir.typeLayoutSourcePaths[foundIndex]):
            return false
    if foundIndex >= 0 &&
       foundIndex < ir.typeLayoutSizeBytes.len &&
       foundIndex < ir.typeLayoutAlignBytes.len &&
       foundIndex < ir.typeLayoutFieldCounts.len:
        sizeBytes = ir.typeLayoutSizeBytes[foundIndex]
        alignBytes = ir.typeLayoutAlignBytes[foundIndex]
        fieldCount = ir.typeLayoutFieldCounts[foundIndex]
        if sizeBytes > 0 && alignBytes > 0:
            return true
    typeName = TypedExprTypeLeafName(typeRaw)
    if typeName == "" || typeName == fullTypeName:
        return false
    foundIndex = -1
    for i in 0..<ir.typeLayoutNames.len:
        if ir.typeLayoutNames[i] != typeName:
            continue
        if i < ir.typeLayoutSourcePaths.len &&
           parser.ParserNormalizePath(ir.typeLayoutSourcePaths[i]) == sourcePath:
            foundIndex = i
            break
        if foundIndex < 0:
            foundIndex = i
        elif i < ir.typeLayoutSourcePaths.len &&
             foundIndex < ir.typeLayoutSourcePaths.len &&
             parser.ParserNormalizePath(ir.typeLayoutSourcePaths[i]) != parser.ParserNormalizePath(ir.typeLayoutSourcePaths[foundIndex]):
            return false
    if foundIndex < 0 ||
       foundIndex >= ir.typeLayoutSizeBytes.len ||
       foundIndex >= ir.typeLayoutAlignBytes.len ||
       foundIndex >= ir.typeLayoutFieldCounts.len:
        return false
    sizeBytes = ir.typeLayoutSizeBytes[foundIndex]
    alignBytes = ir.typeLayoutAlignBytes[foundIndex]
    fieldCount = ir.typeLayoutFieldCounts[foundIndex]
    return sizeBytes > 0 && alignBytes > 0

fn TypedExprIrLookupSingleFieldMeta(ir: TypedExprIr,
                                     sourcePathRaw: str,
                                     ownerTypeRaw: str,
                                     fieldNameRaw: str,
                                     fieldType: var str,
                                     fieldOffsetBytes: var int32,
                                     fieldSizeBytes: var int32,
                                     fieldAlignBytes: var int32): bool =
    fieldType = ""
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let ownerType = TypedExprStripVarType(ownerTypeRaw)
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    if sourcePath == "" || ownerType == "" || fieldName == "":
        return false
    for i in 0..<ir.typeFieldOwnerTypes.len:
        if i >= ir.typeFieldSourcePaths.len ||
           i >= ir.typeFieldNames.len ||
           i >= ir.typeFieldTypes.len ||
           i >= ir.typeFieldOffsetBytes.len ||
           i >= ir.typeFieldSizeBytes.len ||
           i >= ir.typeFieldAlignBytes.len:
            continue
        if parser.ParserNormalizePath(ir.typeFieldSourcePaths[i]) != sourcePath:
            continue
        if ir.typeFieldOwnerTypes[i] != ownerType:
            continue
        if ir.typeFieldNames[i] != fieldName:
            continue
        fieldType = ir.typeFieldTypes[i]
        fieldOffsetBytes = ir.typeFieldOffsetBytes[i]
        fieldSizeBytes = ir.typeFieldSizeBytes[i]
        fieldAlignBytes = ir.typeFieldAlignBytes[i]
        return fieldType != "" && fieldOffsetBytes >= 0 && fieldSizeBytes > 0 && fieldAlignBytes > 0
    if TypedExprQualifiedTypeDot(ownerType) > 0:
        var found = false
        var foundType = ""
        var foundOffset: int32
        var foundSize: int32
        var foundAlign: int32
        for i in 0..<ir.typeFieldOwnerTypes.len:
            if i >= ir.typeFieldSourcePaths.len ||
               i >= ir.typeFieldNames.len ||
               i >= ir.typeFieldTypes.len ||
               i >= ir.typeFieldOffsetBytes.len ||
               i >= ir.typeFieldSizeBytes.len ||
               i >= ir.typeFieldAlignBytes.len:
                continue
            if ir.typeFieldOwnerTypes[i] != ownerType:
                continue
            if ir.typeFieldNames[i] != fieldName:
                continue
            if !found:
                found = true
                foundType = ir.typeFieldTypes[i]
                foundOffset = ir.typeFieldOffsetBytes[i]
                foundSize = ir.typeFieldSizeBytes[i]
                foundAlign = ir.typeFieldAlignBytes[i]
                continue
            if foundType != ir.typeFieldTypes[i] ||
               foundOffset != ir.typeFieldOffsetBytes[i] ||
               foundSize != ir.typeFieldSizeBytes[i] ||
               foundAlign != ir.typeFieldAlignBytes[i]:
                return false
        if found:
            fieldType = foundType
            fieldOffsetBytes = foundOffset
            fieldSizeBytes = foundSize
            fieldAlignBytes = foundAlign
            return fieldType != "" && fieldOffsetBytes >= 0 && fieldSizeBytes > 0 && fieldAlignBytes > 0
    return false

fn TypedExprIrLookupFieldPathMeta(ir: TypedExprIr,
                                   sourcePathRaw: str,
                                   ownerTypeRaw: str,
                                   fieldPathRaw: str,
                                   fieldType: var str,
                                   fieldOffsetBytes: var int32,
                                   fieldSizeBytes: var int32,
                                   fieldAlignBytes: var int32): bool =
    fieldType = TypedExprStripVarType(ownerTypeRaw)
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let parts = parser.ParserSplitChar(chengpath.PathTrim(fieldPathRaw), '.')
    if fieldType == "" || parts.len <= 0:
        return false
    for i in 0..<parts.len:
        let part = parser.ParserIdentPrefix(parts[i])
        if part == "":
            return false
        var nextType = ""
        var nextOffset: int32
        var nextSize: int32
        var nextAlign: int32
        if !TypedExprIrLookupSingleFieldMeta(ir,
                                             sourcePathRaw,
                                             fieldType,
                                             part,
                                             nextType,
                                             nextOffset,
                                             nextSize,
                                             nextAlign):
            return false
        fieldOffsetBytes = fieldOffsetBytes + nextOffset
        fieldType = nextType
        fieldSizeBytes = nextSize
        fieldAlignBytes = nextAlign
    return true

fn TypedExprResolveFieldMeta(currentCtx: var TypedExprSourceContext,
                              sourceContexts: var TypedExprSourceContext[],
                              baseTypeRaw: str,
                              fieldNameRaw: str,
                              fieldType: var str,
                              fieldOffsetBytes: var int32,
                              fieldSizeBytes: var int32,
                              fieldAlignBytes: var int32): bool =
    fieldType = ""
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let baseType = TypedExprStripVarType(baseTypeRaw)
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    if fieldName == "":
        return false
    if baseType == "str":
        if fieldName == "data":
            fieldType = "ptr"
            fieldOffsetBytes = 0
        elif fieldName == "len":
            fieldType = "int32"
            fieldOffsetBytes = 8
        elif fieldName == "storeId" || fieldName == "store_id":
            fieldType = "int32"
            fieldOffsetBytes = 12
        elif fieldName == "flags":
            fieldType = "int32"
            fieldOffsetBytes = 16
        else:
            return false
        return TypedExprTypeLayout(currentCtx, sourceContexts, fieldType, fieldSizeBytes, fieldAlignBytes)
    if baseType == "Bytes" || baseType == "bytes.Bytes" || baseType == "rawbytes.Bytes":
        if fieldName == "data":
            fieldType = "ptr"
            fieldOffsetBytes = 0
        elif fieldName == "len":
            fieldType = "int32"
            fieldOffsetBytes = 8
        else:
            return false
        return TypedExprTypeLayout(currentCtx, sourceContexts, fieldType, fieldSizeBytes, fieldAlignBytes)
    if baseType.len >= 2 && chengpath.TextSlice(baseType, baseType.len - 2, 2) == "[]":
        if fieldName == "len":
            fieldType = "int32"
            fieldOffsetBytes = 0
        elif fieldName == "cap":
            fieldType = "int32"
            fieldOffsetBytes = 4
        elif fieldName == "buffer":
            fieldType = "ptr"
            fieldOffsetBytes = 8
        else:
            return false
        return TypedExprTypeLayout(currentCtx, sourceContexts, fieldType, fieldSizeBytes, fieldAlignBytes)
    if parser.ParserStartsWith(baseType, "Result[") &&
       baseType.len > 8 &&
       chengpath.TextSlice(baseType, baseType.len - 1, 1) == "]":
        let inner = chengpath.TextSlice(baseType, 7, baseType.len - 8)
        var valueSize: int32
        var valueAlign: int32
        if !TypedExprTypeLayout(currentCtx, sourceContexts, inner, valueSize, valueAlign):
            return false
        if fieldName == "ok":
            fieldType = "bool"
            fieldOffsetBytes = 0
        elif fieldName == "value":
            fieldType = inner
            fieldOffsetBytes = TypedExprAlignBytes(1, valueAlign)
        elif fieldName == "err" || fieldName == "error":
            var errSize: int32
            var errAlign: int32
            if !TypedExprTypeLayout(currentCtx, sourceContexts, "ErrorInfo", errSize, errAlign):
                return false
            fieldType = "ErrorInfo"
            fieldOffsetBytes = TypedExprAlignBytes(TypedExprAlignBytes(1, valueAlign) + valueSize, errAlign)
        else:
            return false
        return TypedExprTypeLayout(currentCtx, sourceContexts, fieldType, fieldSizeBytes, fieldAlignBytes)
    let ctxIndex = TypedExprFieldContextLookup(currentCtx, sourceContexts, baseType)
    var ownerCtx = currentCtx
    if ctxIndex >= 0:
        ownerCtx = sourceContexts[ctxIndex]
    elif ctxIndex != -2:
        return false
    let ownerType = TypedExprTypeLeafName(baseType)
    var offset: int32
    for i in 0..<ownerCtx.typeFields.len:
        let field = ownerCtx.typeFields[i]
        if field.ownerType != ownerType:
            continue
        var size: int32
        var align: int32
        if !TypedExprTypeLayout(ownerCtx, sourceContexts, field.fieldType, size, align):
            return false
        if align <= 0:
            align = 1
        offset = TypedExprAlignBytes(offset, align)
        if field.fieldName == fieldName:
            fieldType = field.fieldType
            fieldOffsetBytes = offset
            fieldSizeBytes = size
            fieldAlignBytes = align
            return true
        offset = offset + size
    return false

fn TypedExprResolveFieldPathMeta(currentCtx: var TypedExprSourceContext,
                                  sourceContexts: var TypedExprSourceContext[],
                                  rootTypeRaw: str,
                                  fieldPathRaw: str,
                                  fieldType: var str,
                                  fieldOffsetBytes: var int32,
                                  fieldSizeBytes: var int32,
                                  fieldAlignBytes: var int32): bool =
    fieldType = TypedExprStripVarType(rootTypeRaw)
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let parts = parser.ParserSplitChar(chengpath.PathTrim(fieldPathRaw), '.')
    if parts.len <= 0:
        return false
    for i in 0..<parts.len:
        let part = parser.ParserIdentPrefix(parts[i])
        if part == "":
            return false
        var nextType = ""
        var nextOffset: int32
        var nextSize: int32
        var nextAlign: int32
        if !TypedExprResolveFieldMeta(currentCtx,
                                      sourceContexts,
                                      fieldType,
                                      part,
                                      nextType,
                                      nextOffset,
                                      nextSize,
                                      nextAlign):
            return false
        fieldOffsetBytes = fieldOffsetBytes + nextOffset
        fieldType = nextType
        fieldSizeBytes = nextSize
        fieldAlignBytes = nextAlign
    return true

fn TypedExprSourceLine(ctx: var TypedExprSourceContext,
                         lineNumber: int32): str =
    if lineNumber <= 0 || lineNumber > ctx.lines.len:
        return ""
    return ctx.lines[lineNumber - 1]

fn TypedExprClearSourceContextHeavyFields(ctx: var TypedExprSourceContext) =
    ctx.lines = []
    ctx.bindings = []
    ctx.exprLineColumns = []

fn TypedExprAnnotationQuotedValue(lineRaw: str,
                                   annotationName: str): str =
    let trimmed = chengpath.PathTrim(lineRaw)
    let prefix = Fmt"@{annotationName}(\""
    if !parser.ParserStartsWith(trimmed, prefix):
        return ""
    let start = len(prefix)
    for i in start..<len(trimmed):
        if trimmed[i] == '"':
            return chengpath.TextSlice(trimmed, start, i - start)
    return ""

fn TypedExprImportcAnnotationNameForDecl(lines: str[],
                                          lineIndex: int32): str =
    if lineIndex <= 1 || lineIndex > lines.len:
        return ""
    var cursor = lineIndex - 1
    while cursor >= 1:
        let trimmed = chengpath.PathTrim(lines[cursor - 1])
        if trimmed == "":
            cursor = cursor - 1
            continue
        let importName = TypedExprAnnotationQuotedValue(trimmed, "importc")
        if importName != "":
            return importName
        if parser.ParserStartsWith(trimmed, "@"):
            cursor = cursor - 1
            continue
        return ""
    return ""

fn TypedExprLookupBindingType(ctx: var TypedExprSourceContext,
                                scopeIndex: int32,
                                lineNumber: int32,
                                nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    var bestLine: int32 = -1
    var bestType = ""
    var scopeName = ""
    if scopeIndex >= 0:
        scopeName = ctx.scopes[scopeIndex].name
    for i in 0..<ctx.bindings.len:
        let binding = ctx.bindings[i]
        if binding.name != name:
            continue
        if binding.lineNumber > lineNumber:
            continue
        if scopeName != "":
            if !binding.globalFlag && binding.functionName == scopeName && binding.lineNumber >= bestLine:
                bestLine = binding.lineNumber
                bestType = binding.typeText
                continue
            if binding.globalFlag && bestLine < 0:
                bestLine = binding.lineNumber
                bestType = binding.typeText
            continue
        if !binding.globalFlag:
            continue
        if binding.lineNumber >= bestLine:
            bestLine = binding.lineNumber
            bestType = binding.typeText
    return bestType

fn TypedExprLookupBindingMeta(ctx: var TypedExprSourceContext,
                               scopeIndex: int32,
                               lineNumber: int32,
                               nameRaw: str,
                               typeOut: var str,
                               sourcePathOut: var str,
                               globalFlagOut: var bool): bool =
    typeOut = ""
    sourcePathOut = ""
    globalFlagOut = false
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return false
    var bestLine: int32 = -1
    var scopeName = ""
    if scopeIndex >= 0:
        scopeName = ctx.scopes[scopeIndex].name
    for i in 0..<ctx.bindings.len:
        let binding = ctx.bindings[i]
        if binding.name != name:
            continue
        if binding.lineNumber > lineNumber:
            continue
        if scopeName != "":
            if !binding.globalFlag && binding.functionName == scopeName && binding.lineNumber >= bestLine:
                bestLine = binding.lineNumber
                typeOut = binding.typeText
                sourcePathOut = binding.sourcePath
                globalFlagOut = false
                continue
            if binding.globalFlag && bestLine < 0:
                bestLine = binding.lineNumber
                typeOut = binding.typeText
                sourcePathOut = binding.sourcePath
                globalFlagOut = true
            continue
        if !binding.globalFlag:
            continue
        if binding.lineNumber >= bestLine:
            bestLine = binding.lineNumber
            typeOut = binding.typeText
            sourcePathOut = binding.sourcePath
            globalFlagOut = true
    return typeOut != ""

fn TypedExprLookupImportcReturnType(ctx: var TypedExprSourceContext,
                                      nameRaw: str): str =
    let trimmedName = chengpath.PathTrim(nameRaw)
    let name = parser.ParserIdentPrefix(trimmedName)
    if name == "" && trimmedName == "":
        return ""
    for i in 0..<ctx.importcFunctions.len:
        if ctx.importcFunctions[i].name == name ||
           ctx.importcFunctions[i].importName == name ||
           ctx.importcFunctions[i].importName == trimmedName ||
           ctx.importcFunctions[i].name == trimmedName:
            if ctx.importcFunctions[i].returnType == "":
                return "void"
            return ctx.importcFunctions[i].returnType
    return ""

fn TypedExprLookupLocalImportcReturnTypeForCall(ctx: var TypedExprSourceContext,
                                                 calleeRaw: str,
                                                 targetRaw: str): str =
    let calleeFound = TypedExprLookupImportcReturnType(ctx, calleeRaw)
    if calleeFound != "":
        return calleeFound
    return TypedExprLookupImportcReturnType(ctx, targetRaw)

fn TypedExprIrAddImportcReturnType(ir: var TypedExprIr,
                                    sourcePathRaw: str,
                                    nameRaw: str,
                                    returnTypeRaw: str) =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    let returnType = TypedExprNormalizeTypeText(returnTypeRaw)
    if sourcePath == "" || name == "" || returnType == "":
        return
    for i in 0..<ir.importcNames.len:
        if i >= ir.importcSourcePaths.len:
            continue
        if parser.ParserNormalizePath(ir.importcSourcePaths[i]) == sourcePath &&
           ir.importcNames[i] == name:
            return
    add(ir.importcSourcePaths, sourcePath)
    add(ir.importcNames, name)
    add(ir.importcReturnTypes, returnType)

fn TypedExprIrAppendImportcFunctionsFromContext(ir: var TypedExprIr,
                                                 ctx: var TypedExprSourceContext) =
    for i in 0..<ctx.importcFunctions.len:
        let importcFn = ctx.importcFunctions[i]
        TypedExprIrAddImportcReturnType(ir,
                                        ctx.sourcePath,
                                        importcFn.name,
                                        importcFn.returnType)
        if importcFn.importName != "":
            TypedExprIrAddImportcReturnType(ir,
                                            ctx.sourcePath,
                                            importcFn.importName,
                                            importcFn.returnType)

fn TypedExprIrLookupImportcReturnType(ir: TypedExprIr,
                                       sourcePathRaw: str,
                                       nameRaw: str): str =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    let trimmedName = chengpath.PathTrim(nameRaw)
    let name = parser.ParserIdentPrefix(trimmedName)
    if name == "" && trimmedName == "":
        return ""
    var foundExact = ""
    var foundAny = ""
    for i in 0..<ir.importcNames.len:
        if i >= ir.importcSourcePaths.len || i >= ir.importcReturnTypes.len:
            continue
        if ir.importcNames[i] != name && ir.importcNames[i] != trimmedName:
            continue
        if foundAny != "" && foundAny != ir.importcReturnTypes[i]:
            return ""
        foundAny = ir.importcReturnTypes[i]
        if sourcePath != "" &&
           parser.ParserNormalizePath(ir.importcSourcePaths[i]) == sourcePath:
            if foundExact != "" && foundExact != ir.importcReturnTypes[i]:
                return ""
            foundExact = ir.importcReturnTypes[i]
    if foundExact != "":
        return foundExact
    return foundAny

fn TypedExprLookupImportcReturnTypeFromContexts(sourceContexts: var TypedExprSourceContext[],
                                                  nameRaw: str): str =
    let trimmedName = chengpath.PathTrim(nameRaw)
    let name = parser.ParserIdentPrefix(trimmedName)
    if name == "" && trimmedName == "":
        return ""
    for i in 0..<sourceContexts.len:
        let found = TypedExprLookupImportcReturnType(sourceContexts[i], trimmedName)
        if found != "":
            return found
    return ""

fn TypedExprQualifiedCallDot(nameRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    var dotPos: int32 = -1
    for i in 0..<name.len:
        if name[i] == '.':
            dotPos = i
    return dotPos

fn TypedExprQualifiedCallQualifier(nameRaw: str): str =
    let name = chengpath.PathTrim(nameRaw)
    let dotPos = TypedExprQualifiedCallDot(name)
    if dotPos <= 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(name, 0, dotPos))

fn TypedExprQualifiedCallLeaf(nameRaw: str): str =
    let name = chengpath.PathTrim(nameRaw)
    let dotPos = TypedExprQualifiedCallDot(name)
    if dotPos < 0:
        return parser.ParserIdentPrefix(name)
    if dotPos + 1 >= name.len:
        return ""
    return parser.ParserIdentPrefix(chengpath.TextSlice(name, dotPos + 1, name.len - dotPos - 1))

fn TypedExprQualifiedCallSurface(qualifierRaw: str,
                                  calleeRaw: str): str =
    let callee = chengpath.PathTrim(calleeRaw)
    if callee == "":
        return ""
    let qualifier = chengpath.PathTrim(qualifierRaw)
    if qualifier == "":
        return callee
    return Fmt"{qualifier}.{callee}"

fn TypedExprLookupLocalFunctionReturnType(ctx: var TypedExprSourceContext,
                                            nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<ctx.scopes.len:
        if ctx.scopes[i].name == name:
            if ctx.scopes[i].returnType == "":
                return "void"
            return ctx.scopes[i].returnType
    return ""

fn TypedExprLookupImportedModuleSourcePath(ctx: var TypedExprSourceContext,
                                             qualifierRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    if qualifier == "":
        return ""
    for i in 0..<ctx.importedModules.len:
        if ctx.importedModules[i].qualifier == qualifier:
            return ctx.importedModules[i].targetSourcePath
    return ""

fn TypedExprLookupQualifiedModuleSourcePath(currentCtx: var TypedExprSourceContext,
                                              sourceContexts: var TypedExprSourceContext[],
                                              qualifierChainRaw: str): str =
    let qualifierChain = chengpath.PathTrim(qualifierChainRaw)
    if qualifierChain == "":
        return ""
    let qualifierParts = parser.ParserSplitChar(qualifierChain, '.')
    var ctx = currentCtx
    var targetSourcePath = ""
    for i in 0..<qualifierParts.len:
        let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierParts[i]))
        if qualifier == "":
            return ""
        targetSourcePath = TypedExprLookupImportedModuleSourcePath(ctx, qualifier)
        if targetSourcePath == "":
            return ""
        if i + 1 >= qualifierParts.len:
            return targetSourcePath
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
        if targetIndex < 0:
            return ""
        ctx = sourceContexts[targetIndex]
    return targetSourcePath

fn TypedExprSourceHasDeclaredType(ctx: var TypedExprSourceContext,
                                    typeNameRaw: str): bool =
    let typeName = TypedExprNormalizeTypeText(typeNameRaw)
    if typeName == "":
        return false
    for i in 0..<ctx.declaredTypes.len:
        if ctx.declaredTypes[i] == typeName:
            return true
    return false

fn TypedExprQualifiedTypeDot(typeRaw: str): int32 =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    var dotPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '.':
            dotPos = i
    return dotPos

fn TypedExprTypeIsNamedCompositeInContext(currentCtx: var TypedExprSourceContext,
                                            sourceContexts: var TypedExprSourceContext[],
                                            typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    let dotPos = TypedExprQualifiedTypeDot(typeText)
    if dotPos > 0:
        let qualifier = chengpath.PathTrim(chengpath.TextSlice(typeText, 0, dotPos))
        let leaf = chengpath.PathTrim(chengpath.TextSlice(typeText, dotPos + 1, typeText.len - dotPos - 1))
        if qualifier == "" || leaf == "":
            return false
        let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(currentCtx, sourceContexts, qualifier)
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
        if targetIndex < 0:
            return false
        return TypedExprSourceHasDeclaredType(sourceContexts[targetIndex], leaf)
    if TypedExprSourceHasDeclaredType(currentCtx, typeText):
        return true
    var resolvedSourcePath = ""
    for i in 0..<currentCtx.importedModules.len:
        let importedSourcePath = parser.ParserNormalizePath(currentCtx.importedModules[i].targetSourcePath)
        let importedIndex = TypedExprSourceContextLookup(sourceContexts, importedSourcePath)
        if importedIndex < 0:
            continue
        if !TypedExprSourceHasDeclaredType(sourceContexts[importedIndex], typeText):
            continue
        if resolvedSourcePath == "":
            resolvedSourcePath = importedSourcePath
            continue
        if resolvedSourcePath != importedSourcePath:
            return false
    return resolvedSourcePath != ""

fn TypedExprAbiClassForTypeInContext(currentCtx: var TypedExprSourceContext,
                                       sourceContexts: var TypedExprSourceContext[],
                                       typeRaw: str): TypedExprAbiClass =
    let abiClass = TypedExprAbiClassForType(typeRaw)
    if abiClass != TypedExprAbiPolymorphic:
        return abiClass
    if TypedExprTypeIsNamedCompositeInContext(currentCtx, sourceContexts, typeRaw):
        return TypedExprAbiComposite
    return TypedExprAbiPolymorphic

fn TypedExprLookupQualifiedExternalReturnType(currentCtx: var TypedExprSourceContext,
                                                sourceContexts: var TypedExprSourceContext[],
                                                qualifierRaw: str,
                                                functionNameRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    let functionName = parser.ParserIdentPrefix(chengpath.PathTrim(functionNameRaw))
    if qualifier == "" || functionName == "":
        return ""
    let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(currentCtx, sourceContexts, qualifier)
    if targetSourcePath == "":
        return ""
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
    if targetIndex < 0:
        return ""
    let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], functionName)
    if localReturnType != "":
        return localReturnType
    return TypedExprLookupImportcReturnType(sourceContexts[targetIndex], functionName)

fn TypedExprLookupExternalFunctionReturnTypeFromContexts(currentCtx: var TypedExprSourceContext,
                                                           sourceContexts: var TypedExprSourceContext[],
                                                           qualifierRaw: str,
                                                           nameRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    let qualifiedReturnType = TypedExprLookupQualifiedExternalReturnType(currentCtx, sourceContexts, qualifier, nameRaw)
    if qualifiedReturnType != "":
        return qualifiedReturnType
    if qualifier != "":
        return ""
    let sourcePath = currentCtx.sourcePath
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<sourceContexts.len:
        if sourceContexts[i].sourcePath == sourcePath:
            continue
        let found = TypedExprLookupLocalFunctionReturnType(sourceContexts[i], name)
        if found != "":
            return found
        let importcFound = TypedExprLookupImportcReturnType(sourceContexts[i], name)
        if importcFound != "":
            return importcFound
    return ""

fn TypedExprLookupUnqualifiedImportedFunctionReturnType(currentCtx: var TypedExprSourceContext,
                                                          sourceContexts: var TypedExprSourceContext[],
                                                          nameRaw: str,
                                                          targetSourcePathOut: var str,
                                                          targetImportcOut: var bool): str =
    targetSourcePathOut = ""
    targetImportcOut = false
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    var foundReturnType = ""
    var foundSourcePath = ""
    var foundImportc = false
    for i in 0..<currentCtx.importedModules.len:
        let importedSourcePath = parser.ParserNormalizePath(currentCtx.importedModules[i].targetSourcePath)
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, importedSourcePath)
        if targetIndex < 0:
            continue
        let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], name)
        if localReturnType != "":
            if foundReturnType != "":
                return ""
            foundReturnType = localReturnType
            foundSourcePath = importedSourcePath
            foundImportc = false
            continue
        let importcReturnType = TypedExprLookupImportcReturnType(sourceContexts[targetIndex], name)
        if importcReturnType != "":
            if foundReturnType != "":
                return ""
            foundReturnType = importcReturnType
            foundSourcePath = importedSourcePath
            foundImportc = true
    if foundReturnType == "":
        return ""
    targetSourcePathOut = foundSourcePath
    targetImportcOut = foundImportc
    return foundReturnType

fn TypedExprResolveQualifiedCallTargetReturnType(currentCtx: var TypedExprSourceContext,
                                                  sourceContexts: var TypedExprSourceContext[],
                                                  qualifierRaw: str,
                                                  calleeRaw: str,
                                                  targetRaw: str,
                                                  targetSourcePathOut: var str,
                                                  targetNameOut: var str,
                                                  targetImportcOut: var bool): str =
    targetSourcePathOut = ""
    targetNameOut = ""
    targetImportcOut = false
    var qualifier = chengpath.PathTrim(qualifierRaw)
    let target = chengpath.PathTrim(targetRaw)
    if qualifier == "" && target != "":
        qualifier = TypedExprQualifiedCallQualifier(target)
    var callee = parser.ParserIdentPrefix(chengpath.PathTrim(calleeRaw))
    if (callee == "" || TypedExprQualifiedCallDot(callee) >= 0) && target != "":
        callee = TypedExprQualifiedCallLeaf(target)
    if qualifier == "" || callee == "":
        return ""
    let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(currentCtx,
                                                                    sourceContexts,
                                                                    qualifier)
    if targetSourcePath == "":
        return ""
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
    if targetIndex < 0:
        return ""
    let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex],
                                                                  callee)
    if localReturnType != "":
        targetSourcePathOut = targetSourcePath
        targetNameOut = callee
        targetImportcOut = false
        return localReturnType
    let importReturnType = TypedExprLookupImportcReturnType(sourceContexts[targetIndex],
                                                            callee)
    if importReturnType != "":
        targetSourcePathOut = targetSourcePath
        targetNameOut = callee
        targetImportcOut = true
        return importReturnType
    return ""

fn TypedExprLookupCallTargetReturnTypeFromFact(currentCtx: var TypedExprSourceContext,
                                                sourceContexts: var TypedExprSourceContext[],
                                                 fact: TypedExprFact): str =
    if fact.callQualifier != "" &&
       fact.surfaceCallKind != TypedExprSurfaceCallMember:
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        return TypedExprResolveQualifiedCallTargetReturnType(currentCtx,
                                                             sourceContexts,
                                                             fact.callQualifier,
                                                             fact.callCallee,
                                                             fact.callTarget,
                                                             resolvedSourcePath,
                                                             resolvedTargetName,
                                                             resolvedImportc)
    if fact.callTargetSourcePath == "":
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        let qualifiedReturnType = TypedExprResolveQualifiedCallTargetReturnType(currentCtx,
                                                                                sourceContexts,
                                                                                fact.callQualifier,
                                                                                fact.callCallee,
                                                                                fact.callTarget,
                                                                                resolvedSourcePath,
                                                                                resolvedTargetName,
                                                                                resolvedImportc)
        if qualifiedReturnType != "":
            return qualifiedReturnType
        if fact.callTargetImportc:
            return TypedExprLookupLocalImportcReturnTypeForCall(currentCtx,
                                                                fact.callCallee,
                                                                fact.callTarget)
        return TypedExprLookupLocalFunctionReturnType(currentCtx, fact.callTarget)
    let targetSourcePath = parser.ParserNormalizePath(fact.callTargetSourcePath)
    if targetSourcePath == "":
        return ""
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
    if targetIndex < 0:
        return ""
    if fact.callTargetImportc:
        return TypedExprLookupLocalImportcReturnTypeForCall(sourceContexts[targetIndex],
                                                            fact.callCallee,
                                                            fact.callTarget)
    return TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], fact.callCallee)

fn TypedExprCountFunctionParams(lineRaw: str): int32 =
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return 0
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos <= openPos:
        return 0
    let paramsText = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let trimmed = chengpath.PathTrim(paramsText)
    if trimmed == "":
        return 0
    let params = TypedExprSplitTopLevelCsv(trimmed)
    return params.len

fn TypedExprValidateFfiAnnotations(decl: parser.NormalizedFunctionDecl,
                                    paramCount: int32): str[] =
    var errors: str[]
    if decl.ffiMapPtrArg >= 0 || decl.ffiMapLenArg >= 0:
        if decl.ffiMapPtrArg < 0 || decl.ffiMapLenArg < 0:
            add(errors, Fmt"@{decl.name}: @ffi_map requires both ptr and len args")
        else:
            if decl.ffiMapPtrArg >= paramCount:
                add(errors, Fmt"@{decl.name}: @ffi_map ptr arg index {decl.ffiMapPtrArg} out of range (param count={paramCount})")
            if decl.ffiMapLenArg >= paramCount:
                add(errors, Fmt"@{decl.name}: @ffi_map len arg index {decl.ffiMapLenArg} out of range (param count={paramCount})")
    if decl.ffiOutPtrArgs != "":
        let parts = TypedExprSplitTopLevelCsv(decl.ffiOutPtrArgs)
        for i in 0..<parts.len:
            let part = chengpath.PathTrim(parts[i])
            if part == "":
                continue
            var idx: int32
            for j in 0..<part.len:
                let ch = part[j]
                if ch >= '0' && ch <= '9':
                    idx = idx * 10 + Int32(ch - '0')
            if idx < 0 || idx >= paramCount:
                add(errors, Fmt"@{decl.name}: @ffi_out_ptrs arg index {idx} out of range (param count={paramCount})")
    return errors

fn TypedExprFirstExprColumnAfter(ctx: var TypedExprSourceContext,
                                   lineNumber: int32,
                                   minColumn: int32): int32 =
    if lineNumber <= 0 || lineNumber > ctx.exprLineColumns.len:
        return -1
    let lineColumns = ctx.exprLineColumns[lineNumber - 1].columns
    var bestColumn: int32 = -1
    for i in 0..<lineColumns.len:
        let exprColumnNumber = lineColumns[i]
        if exprColumnNumber < minColumn:
            continue
        if bestColumn < 0 || exprColumnNumber < bestColumn:
            bestColumn = exprColumnNumber
    return bestColumn

fn TypedExprLineHasRootReturn(lineRaw: str,
                                ctx: var TypedExprSourceContext,
                                expr: parser.NormalizedExpr): bool =
    let firstToken = parser.ParserFirstToken(chengpath.PathTrim(lineRaw))
    if firstToken != "return":
        return false
    let returnPos = parser.ParserFindText(lineRaw, "return")
    if returnPos < 0:
        return false
    let exprStart = returnPos + Len("return") + 1
    let rootExprColumn = TypedExprFirstExprColumnAfter(ctx,
                                                         expr.lineNumber,
                                                         exprStart)
    return rootExprColumn == expr.columnNumber

fn TypedExprSourceContextForPathOrCurrent(currentCtx: var TypedExprSourceContext,
                                            sourceContexts: var TypedExprSourceContext[],
                                            sourcePathRaw: str): TypedExprSourceContext =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        return currentCtx
    let ctxIndex = TypedExprSourceContextLookup(sourceContexts, sourcePath)
    if ctxIndex < 0:
        return currentCtx
    return sourceContexts[ctxIndex]

fn TypedExprComprehensionFilterIf(lineRaw: str,
                                    expr: parser.NormalizedExpr): bool =
    if expr.kind != parser.NormalizedExprIf ||
       expr.detailKind != parser.NormalizedExprDetailIfKeyword:
        return false
    let exprPos = expr.columnNumber - 1
    for openPos in 0..<lineRaw.len:
        if lineRaw[openPos] != '[':
            continue
        var itemText = ""
        var bindingText = ""
        var sourceText = ""
        var filterText = ""
        var filterColumn = -1
        var endColumn = -1
        if !parser.ParserParseListComprehensionAt(lineRaw,
                                                    openPos,
                                                    itemText,
                                                    bindingText,
                                                    sourceText,
                                                    filterText,
                                                    filterColumn,
                                                    endColumn):
            continue
        if filterColumn == expr.columnNumber:
            return true
        if filterColumn > 0 && filterColumn - 1 == exprPos:
            return true
    return false

fn TypedExprExtractGenericArg(lineRaw: str,
                                columnNumber: int32,
                                callName: str): str =
    if columnNumber <= 0:
        return ""
    var start = columnNumber
    start = start - 1
    if start < 0 || start + Len(callName) > lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, start, Len(callName)) != callName:
        return ""
    let cursor0 = TypedExprSkipInlineSpaces(lineRaw, start + Len(callName))
    var cursor = cursor0
    if cursor >= lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, cursor, 1) != "[":
        return ""
    let closePos = TypedExprFindMatchingBracket(lineRaw, cursor)
    if closePos <= cursor:
        return ""
    return TypedExprNormalizeTypeText(chengpath.TextSlice(lineRaw, cursor + 1, closePos - cursor - 1))

fn TypedExprExtractTypeGenericArg(typeRaw: str): str =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    let openPos = TypedExprFindTopLevelToken(typeText, "[")
    if openPos < 0 || openPos + 1 >= typeText.len:
        return ""
    let closePos = TypedExprFindMatchingBracket(typeText, openPos)
    if closePos <= openPos || closePos + 1 != typeText.len:
        return ""
    return TypedExprNormalizeTypeText(chengpath.TextSlice(typeText, openPos + 1, closePos - openPos - 1))

fn TypedExprExtractArgsText(lineRaw: str,
                             columnNumber: int32,
                             callName: str): str =
    if columnNumber <= 0:
        return ""
    var start = columnNumber
    start = start - 1
    if start < 0 || start + Len(callName) > lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, start, Len(callName)) != callName:
        return ""
    var cursor = TypedExprSkipInlineSpaces(lineRaw, start + Len(callName))
    if cursor < lineRaw.len && chengpath.TextSlice(lineRaw, cursor, 1) == "[":
        let closeBracket = TypedExprFindMatchingBracket(lineRaw, cursor)
        if closeBracket < 0:
            return ""
        cursor = closeBracket + 1
    cursor = TypedExprSkipInlineSpaces(lineRaw, cursor)
    if cursor >= lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, cursor, 1) != "(":
        return ""
    let closeParen = TypedExprFindMatchingParen(lineRaw, cursor)
    if closeParen <= cursor:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(lineRaw, cursor + 1, closeParen - cursor - 1))

fn TypedExprExtractFirstArg(lineRaw: str,
                              columnNumber: int32,
                              callName: str): str =
    var argsText = TypedExprExtractArgsText(lineRaw, columnNumber, callName)
    if Len(argsText) <= 0:
        return ""
    let commaPos = TypedExprFindTopLevelToken(argsText, ",")
    if commaPos >= 0:
        argsText = chengpath.TextSlice(argsText, 0, commaPos)
    return chengpath.PathTrim(argsText)

fn TypedExprInferredResultInputType(ctx: var TypedExprSourceContext,
                                      scopeIndex: int32,
                                      expr: parser.NormalizedExpr): str =
    let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
    if lineRaw == "":
        return ""
    if expr.kind == parser.NormalizedExprTry:
        let token = parser.ParserPreviousToken(lineRaw, expr.columnNumber - 1)
        return TypedExprLookupBindingType(ctx, scopeIndex, expr.lineNumber, token)
    if expr.kind != parser.NormalizedExprResultIntrinsic:
        return ""
    let callName = expr.surfaceText
    let argText = TypedExprExtractFirstArg(lineRaw, expr.columnNumber, callName)
    let argName = parser.ParserIdentPrefix(argText)
    if argName == "":
        return ""
    return TypedExprLookupBindingType(ctx, scopeIndex, expr.lineNumber, argName)

fn TypedExprSinkForExpr(ctx: var TypedExprSourceContext,
                          expr: parser.NormalizedExpr): TypedExprSinkInfo =
    var sink: TypedExprSinkInfo
    sink.sinkType = ""
    sink.sinkPlaceKind = TypedExprPlaceTemporary
    sink.hasSink = false
    sink.returnRoot = false
    sink.functionReturnType = ""
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, expr.lineNumber)
    if scopeIndex >= 0:
        sink.functionReturnType = ctx.scopes[scopeIndex].returnType
    let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
    if lineRaw == "":
        return sink
    var bindingName = ""
    var bindingType = ""
    var rhsStartColumn: int32 = -1
    if TypedExprParseBindingLine(lineRaw, bindingName, bindingType, rhsStartColumn):
        let bindingRoot = TypedExprFirstExprColumnAfter(ctx,
                                                          expr.lineNumber,
                                                          rhsStartColumn)
        if bindingRoot == expr.columnNumber:
            sink.sinkType = bindingType
            sink.sinkPlaceKind = scopeIndex >= 0 ? TypedExprPlaceLocal : TypedExprPlaceGlobal
            sink.hasSink = true
    var returnRoot = TypedExprLineHasRootReturn(lineRaw, ctx, expr)
    if !returnRoot:
        if scopeIndex >= 0:
            if ctx.scopes[scopeIndex].startLine == expr.lineNumber:
                let eqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if eqPos >= 0:
                    let inlineRootColumn = TypedExprFirstExprColumnAfter(ctx,
                                                                         expr.lineNumber,
                                                                         eqPos + 2)
                    returnRoot = inlineRootColumn == expr.columnNumber
    if returnRoot:
        if sink.functionReturnType != "":
            sink.sinkType = sink.functionReturnType
            sink.sinkPlaceKind = TypedExprPlaceTemporary
            sink.hasSink = true
            sink.returnRoot = true
    return sink

fn TypedExprApplyResolvedType(fact: var TypedExprFact,
                                abiCtx: var TypedExprSourceContext,
                                sourceContexts: var TypedExprSourceContext[],
                                typeRaw: str,
                                sink: TypedExprSinkInfo,
                                forceCallResult: bool) =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return
    fact.typeText = typeText
    fact.abiClass = TypedExprAbiClassForTypeInContext(abiCtx, sourceContexts, typeText)
    fact.valueKind = TypedExprValueKindForAbiClass(fact.abiClass)
    if forceCallResult:
        fact.placeKind = TypedExprPlaceCallResult
    elif sink.hasSink:
        fact.placeKind = sink.sinkPlaceKind
    else:
        fact.placeKind = TypedExprPlaceTemporary
    if fact.abiClass == TypedExprAbiPolymorphic:
        fact.loweringMode = TypedExprLowerDeferred
        fact.returnKind = TypedExprReturnDeferred
        return
    if sink.returnRoot && sink.sinkType == typeText:
        fact.loweringMode = fact.abiClass == TypedExprAbiComposite ? TypedExprLowerSret : TypedExprLowerReg
        fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)
        return
    if fact.abiClass == TypedExprAbiComposite:
        fact.loweringMode = TypedExprLowerLocalAddress
        fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)
        return
    fact.loweringMode = TypedExprLowerReg
    fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)

fn TypedExprBuildFact(ctx: var TypedExprSourceContext,
                        sourceContexts: var TypedExprSourceContext[],
                        expr: parser.NormalizedExpr): TypedExprFact =
    var fact: TypedExprFact
    fact.exprId = expr.exprId
    fact.sourcePath = expr.sourcePath
    fact.lineNumber = expr.lineNumber
    fact.columnNumber = expr.columnNumber
    fact.endLineNumber = expr.endLineNumber
    fact.endColumnNumber = expr.endColumnNumber
    fact.kind = expr.kind
    fact.surfaceCallKind = TypedExprSurfaceCallNone
    fact.callResolved = false
    fact.callReason = TypedExprCallReasonNone
    fact.callQualifier = ""
    fact.callCallee = ""
    fact.callTarget = ""
    fact.callTargetSourcePath = ""
    fact.callTargetImportc = false
    fact.callPrefixStyle = false
    fact.callArgCount = 0
    fact.callArgsText = ""
    fact.typeText = "unknown"
    fact.abiClass = TypedExprAbiPolymorphic
    fact.valueKind = TypedExprValuePolymorphic
    fact.placeKind = TypedExprPlaceTemporary
    fact.loweringMode = TypedExprLowerDeferred
    fact.callKind = TypedExprCallKindForExpr(expr)
    fact.typeCallKind = TypedExprTypeCallKindForExpr(expr)
    fact.returnKind = TypedExprReturnDeferred
    let sink = TypedExprSinkForExpr(ctx, expr)
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, expr.lineNumber)
    let sourceResultType = TypedExprInferredResultInputType(ctx, scopeIndex, expr)
    fact.hasSink = sink.hasSink
    fact.sinkPlaceKind = sink.sinkPlaceKind
    fact.returnRoot = sink.returnRoot
    if expr.kind == parser.NormalizedExprRange:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "range", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprComprehension:
        let sinkType = sink.sinkType
        if parser.ParserStartsWith(sinkType, "seq[") || (sinkType.len >= 2 && chengpath.TextSlice(sinkType, sinkType.len - 2, 2) == "[]"):
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sinkType, sink, false)
            return fact
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "seq[unknown]", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprStrFormat:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "str", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprIf:
        if sink.hasSink && sink.sinkType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
            return fact
        let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
        let trimmed = chengpath.PathTrim(lineRaw)
        if parser.ParserStartsWith(trimmed, "if ") || TypedExprComprehensionFilterIf(lineRaw, expr):
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "bool", sink, false)
            return fact
        fact.typeText = "branch_join"
        return fact
    if expr.kind == parser.NormalizedExprTry:
        let innerType = TypedExprResultSuccessType(sourceResultType)
        if innerType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, innerType, sink, true)
            return fact
        let returnInnerType = TypedExprResultSuccessType(sink.functionReturnType)
        if returnInnerType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, returnInnerType, sink, true)
            return fact
        if sink.hasSink && sink.sinkType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, true)
            return fact
        fact.typeText = "result_projection"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    let isResultIntrinsic = expr.kind == parser.NormalizedExprResultIntrinsic
    var resultLineRaw = ""
    var resultArgsText = ""
    var resultGenericInner = ""
    var resultInnerType = ""
    if isResultIntrinsic:
        resultLineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
        resultArgsText = TypedExprExtractArgsText(resultLineRaw, expr.columnNumber, expr.surfaceText)
        resultGenericInner = TypedExprExtractGenericArg(resultLineRaw, expr.columnNumber, expr.surfaceText)
        resultInnerType = TypedExprResultSuccessType(sourceResultType)
        fact.callCallee = expr.surfaceText
        fact.callPrefixStyle = true
        fact.callArgsText = resultArgsText
        fact.callArgCount = parser.ParserCountTopLevelArgs(resultArgsText)
    var isResultCtorIntrinsic = false
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultOk:
        isResultCtorIntrinsic = true
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultErr:
        isResultCtorIntrinsic = true
    if isResultCtorIntrinsic && resultGenericInner != "":
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, TypedExprResultType(resultGenericInner), sink, false)
        return fact
    if isResultCtorIntrinsic && sink.hasSink && parser.ParserStartsWith(sink.sinkType, "Result["):
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
        return fact
    if isResultCtorIntrinsic && parser.ParserStartsWith(sink.functionReturnType, "Result["):
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.functionReturnType, sink, false)
        return fact
    if isResultCtorIntrinsic:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "Result[unknown]", sink, false)
        return fact
    var isResultBoolProjection = false
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultIsOk:
        isResultBoolProjection = true
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultIsErr:
        isResultBoolProjection = true
    if isResultBoolProjection:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "bool", sink, true)
        return fact
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultError:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "str", sink, true)
        return fact
    if isResultIntrinsic && expr.detailKind == parser.NormalizedExprDetailResultErrorInfoOf:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "ErrorInfo", sink, true)
        return fact
    if isResultIntrinsic && resultGenericInner != "":
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, resultGenericInner, sink, true)
        return fact
    if isResultIntrinsic && resultInnerType != "":
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, resultInnerType, sink, true)
        return fact
    if isResultIntrinsic && sink.hasSink && sink.sinkType != "":
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, true)
        return fact
    if isResultIntrinsic:
        fact.typeText = "result_projection"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    if expr.kind == parser.NormalizedExprDefaultInit:
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        let defaultInitType = parser.NormalizedExprDefaultInitType(expr)
        if defaultInitType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, defaultInitType, sink, false)
            return fact
        fact.typeText = "default_init_expr"
        return fact
    if expr.kind == parser.NormalizedExprConstructor:
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        let constructorType = parser.NormalizedExprConstructorType(expr)
        let constructorName = parser.ParserIdentPrefix(constructorType)
        if constructorName == "Ok" || constructorName == "Err":
            let genericInner = TypedExprExtractTypeGenericArg(constructorType)
            if genericInner != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, TypedExprResultType(genericInner), sink, false)
                return fact
            if sink.hasSink && parser.ParserStartsWith(sink.sinkType, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
                return fact
            if parser.ParserStartsWith(sink.functionReturnType, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.functionReturnType, sink, false)
                return fact
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "Result[unknown]", sink, false)
            return fact
        if constructorType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, constructorType, sink, false)
            return fact
        fact.typeText = "constructor_expr"
        return fact
    if expr.kind == parser.NormalizedExprCall:
        if expr.callArgCount <= 0 &&
           TypedExprSymbolExportedByCase(expr.callCallee):
            var typeName = ""
            if expr.callQualifier != "":
                let typeSourcePath = TypedExprLookupQualifiedModuleSourcePath(ctx,
                                                                              sourceContexts,
                                                                              expr.callQualifier)
                let typeSourceIndex = TypedExprSourceContextLookup(sourceContexts, typeSourcePath)
                if typeSourceIndex >= 0 &&
                   TypedExprSourceHasDeclaredType(sourceContexts[typeSourceIndex], expr.callCallee):
                    typeName = Fmt"{expr.callQualifier}.{expr.callCallee}"
            elif TypedExprSourceHasDeclaredType(ctx, expr.callCallee):
                typeName = expr.callCallee
            if typeName != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, typeName, sink, false)
                return fact
        fact.surfaceCallKind = TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind)
        fact.callResolved = expr.callResolved
        fact.callReason = TypedExprCallReasonFromParser(expr.callReason)
        fact.callQualifier = expr.callQualifier
        fact.callCallee = expr.callCallee
        fact.callTarget = expr.callTarget
        fact.callTargetSourcePath = expr.callTargetSourcePath
        fact.callTargetImportc = expr.callTargetImportc
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        if TypedExprExprIsBuiltinCall(expr):
            fact.callResolved = true
            fact.callReason = TypedExprCallReasonNone
            fact.callTarget = ""
            fact.callTargetSourcePath = ""
            fact.callTargetImportc = false
            var builtinTypeText = TypedExprBuiltinTypeCallResult(expr)
            if builtinTypeText == "":
                builtinTypeText = "str"
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, builtinTypeText, sink, true)
            return fact
        if !fact.callResolved:
            fact.typeText = "call_expr"
            fact.placeKind = TypedExprPlaceCallResult
            return fact
        let detailReturnType = TypedExprLookupCallTargetReturnTypeFromFact(ctx, sourceContexts, fact)
        if detailReturnType != "":
            if fact.callQualifier != "" &&
               fact.surfaceCallKind != TypedExprSurfaceCallMember:
                let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(ctx,
                                                                                sourceContexts,
                                                                                fact.callQualifier)
                if targetSourcePath != "":
                    fact.callTarget = fact.callCallee
                    fact.callTargetSourcePath = targetSourcePath
                    fact.callTargetImportc = false
                    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
                    if targetIndex >= 0:
                        let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex],
                                                                                      fact.callCallee)
                        if localReturnType == "":
                            let importReturnType = TypedExprLookupImportcReturnType(sourceContexts[targetIndex],
                                                                                    fact.callCallee)
                            fact.callTargetImportc = importReturnType != ""
            var targetCtx = TypedExprSourceContextForPathOrCurrent(ctx,
                                                                     sourceContexts,
                                                                     fact.callTargetSourcePath)
            TypedExprApplyResolvedType(fact, targetCtx, sourceContexts, detailReturnType, sink, true)
            if fact.callTargetImportc && fact.abiClass == TypedExprAbiComposite:
                fact.loweringMode = TypedExprLowerImportBuffer
                fact.returnKind = TypedExprReturnImportBuffer
            return fact
        if fact.surfaceCallKind == TypedExprSurfaceCallImportc:
            let importReturnType = TypedExprLookupImportcReturnTypeFromContexts(sourceContexts, fact.callTarget)
            if importReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, importReturnType, sink, true)
                if fact.abiClass == TypedExprAbiComposite:
                    fact.loweringMode = TypedExprLowerImportBuffer
                    fact.returnKind = TypedExprReturnImportBuffer
                return fact
        elif fact.surfaceCallKind == TypedExprSurfaceCallLocal:
            var localTarget = fact.callTarget
            if localTarget == "":
                localTarget = fact.callCallee
            let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, localTarget)
            if localReturnType != "":
                fact.callResolved = true
                fact.callReason = TypedExprCallReasonNone
                fact.callTarget = localTarget
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, localReturnType, sink, true)
                return fact
        elif fact.surfaceCallKind == TypedExprSurfaceCallExternal:
            var targetSourcePath = ""
            var targetImportc = false
            var externalReturnType = ""
            if fact.callQualifier == "":
                externalReturnType = TypedExprLookupUnqualifiedImportedFunctionReturnType(ctx,
                                                                                          sourceContexts,
                                                                                          fact.callCallee,
                                                                                          targetSourcePath,
                                                                                          targetImportc)
            else:
                externalReturnType = TypedExprLookupExternalFunctionReturnTypeFromContexts(ctx,
                                                                                           sourceContexts,
                                                                                           fact.callQualifier,
                                                                                           fact.callCallee)
                if externalReturnType != "":
                    targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(ctx,
                                                                                sourceContexts,
                                                                                fact.callQualifier)
                    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
                    if targetIndex >= 0:
                        let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex],
                                                                                      fact.callCallee)
                        if localReturnType == "":
                            let importReturnType = TypedExprLookupImportcReturnType(sourceContexts[targetIndex],
                                                                                    fact.callCallee)
                            targetImportc = importReturnType != ""
            if externalReturnType != "" && targetSourcePath != "":
                fact.callResolved = true
                fact.callReason = TypedExprCallReasonNone
                fact.callTarget = fact.callCallee
                fact.callTargetSourcePath = targetSourcePath
                fact.callTargetImportc = targetImportc
                var targetCtx = TypedExprSourceContextForPathOrCurrent(ctx,
                                                                         sourceContexts,
                                                                         targetSourcePath)
                TypedExprApplyResolvedType(fact, targetCtx, sourceContexts, externalReturnType, sink, true)
                return fact
        else:
            var localTarget = fact.callTarget
            if localTarget == "":
                localTarget = fact.callCallee
            let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, localTarget)
            if localReturnType != "":
                fact.callResolved = true
                fact.callReason = TypedExprCallReasonNone
                fact.callTarget = localTarget
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, localReturnType, sink, true)
                return fact
            let importReturnType = TypedExprLookupImportcReturnTypeFromContexts(sourceContexts, fact.callTarget)
            if importReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, importReturnType, sink, true)
                if fact.abiClass == TypedExprAbiComposite:
                    fact.loweringMode = TypedExprLowerImportBuffer
                    fact.returnKind = TypedExprReturnImportBuffer
                return fact
        fact.typeText = "call_expr"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    return fact

fn TypedExprFunctionScopeEndLine(lines: str[],
                                  startLine: int32,
                                  nextDeclLine: int32): int32 =
    if startLine <= 0 || startLine > lines.len:
        return startLine
    var upper = lines.len
    if nextDeclLine > startLine:
        upper = nextDeclLine - 1
    if upper < startLine:
        return startLine
    var endLine = startLine
    if startLine + 1 > upper:
        return endLine
    for lineNumber in (startLine + 1)..upper:
        let rawLine = lines[lineNumber - 1]
        let trimmed = chengpath.PathTrim(parser.ParserStripLineComment(rawLine))
        if trimmed == "":
            continue
        if !parser.ParserHasLeadingIndent(rawLine):
            return endLine
        endLine = lineNumber
    return endLine

fn TypedExprBuildSourceContext(source: TypedExprSourceText,
                                 ctx: var TypedExprSourceContext,
                                 err: var str): bool =
    ctx.sourcePath = source.sourcePath
    ctx.normalizedSourcePath = parser.ParserNormalizePath(source.sourcePath)
    var normalizedText = ""
    if !parser.ParserRewriteMultilineStringSourceText(source.text, normalizedText, err):
        return false
    ctx.lines = parser.ParserSplitChar(normalizedText, '\n')
    ctx.scopes = []
    ctx.bindings = []
    ctx.importcFunctions = []
    ctx.importedModules = []
    ctx.declaredTypes = []
    ctx.typeFields = []
    ctx.enumValueNames = []
    ctx.enumValueTypes = []
    ctx.enumValueOrdinals = []
    ctx.exprLineColumns = []
    var decls: parser.NormalizedFunctionDecl[]
    if !parser.ParserReadNormalizedFunctionDecls(normalizedText, decls, err):
        return false
    for i in 0..<decls.len:
        let decl = decls[i]
        if decl.importc:
            if decl.lineIndex > 0 && decl.lineIndex <= ctx.lines.len:
                let declHeader = TypedExprFunctionDeclHeaderText(ctx.lines, decl.lineIndex)
                var importcFn: TypedExprImportcFunction
                importcFn.sourcePath = source.sourcePath
                importcFn.name = decl.name
                importcFn.importName = TypedExprImportcAnnotationNameForDecl(ctx.lines, decl.lineIndex)
                importcFn.returnType = TypedExprParseFunctionReturnType(declHeader)
                importcFn.ffiMapPtrArg = decl.ffiMapPtrArg
                importcFn.ffiMapLenArg = decl.ffiMapLenArg
                importcFn.ffiOutPtrArgs = decl.ffiOutPtrArgs
                add(ctx.importcFunctions, importcFn)
                let paramCount = TypedExprCountFunctionParams(declHeader)
                let ffiErrors = TypedExprValidateFfiAnnotations(decl, paramCount)
                if ffiErrors.len > 0:
                    err = ffiErrors[0]
                    return false
            continue
        if decl.lineIndex <= 0 || decl.lineIndex > ctx.lines.len:
            continue
        var scope: TypedExprFunctionScope
        scope.sourcePath = source.sourcePath
        scope.name = decl.name
        scope.startLine = decl.lineIndex
        var nextDeclLine: int32
        if i + 1 < decls.len:
            nextDeclLine = decls[i + 1].lineIndex
        scope.endLine = TypedExprFunctionScopeEndLine(ctx.lines,
                                                      scope.startLine,
                                                      nextDeclLine)
        let declHeader = TypedExprFunctionDeclHeaderText(ctx.lines, decl.lineIndex)
        scope.returnType = TypedExprParseFunctionReturnType(declHeader)
        add(ctx.scopes, scope)
        TypedExprAppendParamBindings(ctx.bindings, scope, declHeader)
    var inGlobalVarBlock = false
    for i in 0..<ctx.lines.len:
        let rawLineForBinding = ctx.lines[i]
        let trimmedForBinding = chengpath.PathTrim(parser.ParserStripLineComment(rawLineForBinding))
        if !parser.ParserHasLeadingIndent(rawLineForBinding):
            if trimmedForBinding != "":
                inGlobalVarBlock = trimmedForBinding == "var"
        var bindingName = ""
        var bindingType = ""
        var rhsStartColumn: int32 = -1
        if !TypedExprParseBindingLine(rawLineForBinding, bindingName, bindingType, rhsStartColumn):
            if inGlobalVarBlock && parser.ParserHasLeadingIndent(rawLineForBinding):
                var globalName = ""
                var globalType = ""
                if TypedExprParseTypeFieldLine(rawLineForBinding, globalName, globalType):
                    TypedExprMaybeAddBinding(ctx.bindings,
                                               source.sourcePath,
                                               "",
                                               true,
                                               i + 1,
                                               globalName,
                                               globalType)
            continue
        let lineNumber = i + 1
        let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
        if scopeIndex >= 0:
            TypedExprMaybeAddBinding(ctx.bindings,
                                       source.sourcePath,
                                       ctx.scopes[scopeIndex].name,
                                       false,
                                       lineNumber,
                                       bindingName,
                                       bindingType)
        else:
            TypedExprMaybeAddBinding(ctx.bindings,
                                       source.sourcePath,
                                       "",
                                       true,
                                       lineNumber,
                                       bindingName,
                                       bindingType)
    var inTypeBlock = false
    var currentTypeName = ""
    var currentTypeIndent: int32
    var currentTypeIsEnum = false
    var currentEnumOrdinal: int32
    for i in 0..<ctx.lines.len:
        let rawLine = ctx.lines[i]
        let trimmed = chengpath.PathTrim(parser.ParserStripLineComment(rawLine))
        if !parser.ParserHasLeadingIndent(rawLine):
            if trimmed == "":
                continue
            inTypeBlock = trimmed == "type"
            currentTypeName = ""
            currentTypeIndent = 0
            currentTypeIsEnum = false
            currentEnumOrdinal = 0
            continue
        if !inTypeBlock:
            continue
        let lineIndent = TypedExprLineIndentWidth(rawLine)
        let declaredType = TypedExprParseTypeDeclName(trimmed)
        if declaredType != "":
            currentTypeName = declaredType
            currentTypeIndent = lineIndent
            currentTypeIsEnum = parser.ParserFindText(trimmed, "enum") >= 0
            currentEnumOrdinal = 0
            if parser.ParserStringSeqContainsExact(ctx.declaredTypes, declaredType):
                continue
            add(ctx.declaredTypes, declaredType)
            continue
        if currentTypeName == "" || lineIndent <= currentTypeIndent:
            continue
        if currentTypeIsEnum:
            let enumName = parser.ParserIdentPrefix(trimmed)
            if enumName != "":
                add(ctx.enumValueNames, enumName)
                add(ctx.enumValueTypes, currentTypeName)
                add(ctx.enumValueOrdinals, currentEnumOrdinal)
                currentEnumOrdinal = currentEnumOrdinal + 1
            continue
        var fieldName = ""
        var fieldType = ""
        if TypedExprParseTypeFieldLine(trimmed, fieldName, fieldType):
            TypedExprAddTypeFieldDecl(ctx, currentTypeName, fieldName, fieldType)
    if source.workspaceRoot != "" && source.packageRoot != "":
        let ownerModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(source.workspaceRoot,
                                                                                             source.packageRoot,
                                                                                             source.externalPackageRoots,
                                                                                             source.sourcePath)
        var importEdges: parser.ImportEdge[]
        if !parser.ParserReadImportEdgesLinesWithExternalPackageRoots(source.workspaceRoot,
                                                                        source.packageRoot,
                                                                        source.externalPackageRoots,
                                                                        ownerModulePath,
                                                                        ctx.lines,
                                                                        importEdges,
                                                                        err):
            return false
        for i in 0..<importEdges.len:
            if !importEdges[i].resolved:
                continue
            let qualifier = parser.ParserImportEdgeQualifier(importEdges[i])
            if qualifier == "":
                continue
            var importedModule: TypedExprImportedModule
            importedModule.qualifier = qualifier
            importedModule.targetSourcePath = parser.ParserNormalizePath(importEdges[i].targetSourcePath)
            add(ctx.importedModules, importedModule)
    err = ""
    return true

fn TypedExprLineIndentWidth(lineRaw: str): int32 =
    var width: int32
    for i in 0..<lineRaw.len:
        if lineRaw[i] == ' ':
            width = width + 1
        elif lineRaw[i] == '\t':
            width = width + 4
        else:
            return width
    return width

fn TypedExprIfConditionTextFromLine(lineRaw: str): str =
    let trimmed = chengpath.PathTrim(parser.ParserStripLineComment(lineRaw))
    if !parser.ParserStartsWith(trimmed, "if "):
        return ""
    if trimmed.len <= 4:
        return ""
    if trimmed[trimmed.len - 1] != ':':
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(trimmed, 3, trimmed.len - 4))

fn TypedExprIrConditionTextFromSurface(textRaw: str): str =
    var text = chengpath.PathTrim(textRaw)
    if parser.ParserStartsWith(text, "if "):
        text = chengpath.PathTrim(chengpath.TextSlice(text, 3, text.len - 3))
    elif parser.ParserStartsWith(text, "elif "):
        text = chengpath.PathTrim(chengpath.TextSlice(text, 5, text.len - 5))
    if text.len > 0 && text[text.len - 1] == ':':
        text = chengpath.PathTrim(chengpath.TextSlice(text, 0, text.len - 1))
    return text

fn TypedExprIrSimpleBindingName(textRaw: str): str =
    let text = chengpath.PathTrim(textRaw)
    let name = parser.ParserIdentPrefix(text)
    if name == "" || name.len != text.len:
        return ""
    return name

fn TypedExprIrShortStringLiteralPayload(textRaw: str,
                                         payload: var str): bool =
    payload = ""
    let text = chengpath.PathTrim(textRaw)
    if text.len < 2 || text[0] != '"' || text[text.len - 1] != '"':
        return false
    for i in 1..<(text.len - 1):
        if text[i] == '\\':
            return false
    payload = chengpath.TextSlice(text, 1, text.len - 2)
    return true

fn TypedExprIrPriorBindingType(ir: TypedExprIr,
                                functionName: str,
                                lineNumber: int32,
                                bindingName: str): str =
    var foundType = ""
    for i in 0..<ir.statements.len:
        let prev = ir.statements[i]
        if prev.functionName != functionName:
            continue
        if prev.lineNumber >= lineNumber:
            continue
        if prev.bindingName != bindingName:
            continue
        if prev.resultType != "" && prev.resultType != "unknown" && prev.resultType != "call_expr":
            foundType = prev.resultType
            continue
        var sourcePath = prev.callTargetSourcePath
        if sourcePath == "":
            sourcePath = prev.sourcePath
        let importcReturnType = TypedExprIrLookupImportcReturnType(ir, sourcePath, prev.callTarget)
        if importcReturnType != "":
            foundType = importcReturnType
    return foundType

fn TypedExprIrPopulateConditionMeta(stmt: var TypedExprIrStatement,
                                     ir: TypedExprIr,
                                     ctx: var TypedExprSourceContext,
                                     sourceContexts: var TypedExprSourceContext[],
                                     lineNumber: int32) =
    let _ = sourceContexts
    stmt.conditionKind = TypedExprIrCondNone
    stmt.conditionLhsText = ""
    stmt.conditionRhsText = ""
    stmt.conditionLiteralText = ""
    if stmt.kind != TypedExprIrStmtIf && stmt.kind != TypedExprIrStmtElif:
        return
    let conditionText = TypedExprIrConditionTextFromSurface(stmt.surfaceText)
    if conditionText == "":
        return
    var opPos = TypedExprFindTopLevelTextToken(conditionText, "==")
    var conditionKind = TypedExprIrCondStrEqLiteral
    if opPos < 0:
        opPos = TypedExprFindTopLevelTextToken(conditionText, "!=")
        conditionKind = TypedExprIrCondStrNeLiteral
    if opPos < 0:
        return
    let lhsText = chengpath.PathTrim(chengpath.TextSlice(conditionText, 0, opPos))
    let rhsText = chengpath.PathTrim(chengpath.TextSlice(conditionText,
                                                         opPos + 2,
                                                         conditionText.len - opPos - 2))
    var literalPayload = ""
    var valueName = TypedExprIrSimpleBindingName(lhsText)
    var literalSide = rhsText
    if valueName == "" || !TypedExprIrShortStringLiteralPayload(literalSide, literalPayload):
        valueName = TypedExprIrSimpleBindingName(rhsText)
        literalSide = lhsText
        if valueName == "" || !TypedExprIrShortStringLiteralPayload(literalSide, literalPayload):
            return
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
    var valueType = TypedExprNormalizeTypeText(TypedExprLookupBindingType(ctx,
                                                                          scopeIndex,
                                                                          lineNumber,
                                                                          valueName))
    if valueType != "str":
        let priorType = TypedExprNormalizeTypeText(TypedExprIrPriorBindingType(ir,
                                                                               stmt.functionName,
                                                                               lineNumber,
                                                                               valueName))
        if priorType != "":
            valueType = priorType
    if valueType != "str":
        return
    stmt.conditionKind = conditionKind
    stmt.conditionLhsText = valueName
    stmt.conditionRhsText = literalSide
    stmt.conditionLiteralText = literalPayload

fn TypedExprNearestEnclosingIf(ctx: var TypedExprSourceContext,
                                scope: TypedExprFunctionScope,
                                lineNumber: int32,
                                lineIndent: int32,
                                outLineNumber: var int32,
                                outConditionText: var str) =
    outLineNumber = 0
    outConditionText = ""
    if lineNumber <= scope.startLine:
        return
    var bestIndent: int32 = -1
    for sourceLineNumber in scope.startLine..<lineNumber:
        if sourceLineNumber <= 0 || sourceLineNumber > ctx.lines.len:
            continue
        let rawLine = ctx.lines[sourceLineNumber - 1]
        let trimmed = chengpath.PathTrim(parser.ParserStripLineComment(rawLine))
        if trimmed == "":
            continue
        if !parser.ParserHasLeadingIndent(rawLine):
            continue
        let indent = TypedExprLineIndentWidth(rawLine)
        if indent >= lineIndent:
            continue
        let conditionText = TypedExprIfConditionTextFromLine(rawLine)
        if conditionText == "":
            continue
        if indent >= bestIndent:
            bestIndent = indent
            outLineNumber = sourceLineNumber
            outConditionText = conditionText

fn TypedExprIrAddCallStatement(ir: var TypedExprIr,
                                scope: TypedExprFunctionScope,
                                fact: TypedExprFact,
                                kind: TypedExprIrStatementKind,
                                bindingName: str,
                                resultType: str,
                                lineIndent: int32,
                                enclosingIfLineNumber: int32,
                                enclosingIfConditionText: str): int32 =
    var stmt: TypedExprIrStatement
    stmt.sourcePath = fact.sourcePath
    stmt.functionName = scope.name
    stmt.statementIndex = ir.statements.len
    stmt.lineNumber = fact.lineNumber
    stmt.columnNumber = fact.columnNumber
    stmt.lineIndent = lineIndent
    stmt.enclosingIfLineNumber = enclosingIfLineNumber
    stmt.enclosingIfConditionText = enclosingIfConditionText
    stmt.exprId = fact.exprId
    stmt.kind = kind
    stmt.callKind = fact.callKind
    stmt.detailKind = parser.NormalizedExprDetailNone
    stmt.surfaceText = TypedExprQualifiedCallSurface(fact.callQualifier, fact.callCallee)
    if fact.callKind == TypedExprCallResultIntrinsic:
        stmt.detailKind = parser.ParserResultIntrinsicDetailKind(fact.callCallee)
    stmt.bindingName = bindingName
    stmt.resultType = resultType
    stmt.conditionKind = TypedExprIrCondNone
    stmt.conditionLhsText = ""
    stmt.conditionRhsText = ""
    stmt.conditionLiteralText = ""
    stmt.assignRootName = ""
    stmt.assignRootType = ""
    stmt.assignRootSourcePath = ""
    stmt.assignRootGlobalFlag = false
    stmt.assignPlaceKind = TypedExprPlaceTemporary
    stmt.assignFieldName = ""
    stmt.assignFieldType = ""
    stmt.assignFieldOffsetBytes = 0
    stmt.assignFieldSizeBytes = 0
    stmt.assignFieldAlignBytes = 0
    stmt.assignValueRootName = ""
    stmt.assignValueRootType = ""
    stmt.assignValueFieldName = ""
    stmt.assignValueFieldType = ""
    stmt.assignValueFieldOffsetBytes = 0
    stmt.assignValueFieldSizeBytes = 0
    stmt.assignValueFieldAlignBytes = 0
    stmt.assignValueOpKind = TypedExprIrOpUnsupported
    stmt.assignValueLhsText = ""
    stmt.assignValueRhsText = ""
    stmt.assignValueRhsConst = 0
    stmt.assignValueRhsHasConst = false
    stmt.callQualifier = fact.callQualifier
    stmt.callCallee = fact.callCallee
    stmt.callTarget = fact.callTarget
    stmt.callTargetSourcePath = fact.callTargetSourcePath
    stmt.callTargetImportc = fact.callTargetImportc
    stmt.callArgCount = fact.callArgCount
    stmt.callArgsText = fact.callArgsText
    stmt.callArgTypesText = ""
    stmt.callArgNodeStart = -1
    stmt.callArgNodeCount = 0
    if fact.callArgCount == 1 && TypedExprTextIsI32Zero(fact.callArgsText):
        let nodeIndex = TypedExprIrAddI32ConstNode(ir,
                                                   stmt.sourcePath,
                                                   stmt.functionName,
                                                   stmt.lineNumber,
                                                   "0")
        stmt.callArgNodeStart = nodeIndex
        stmt.callArgNodeCount = 1
    stmt.loweringMode = fact.loweringMode
    stmt.returnKind = fact.returnKind
    stmt.returnRoot = fact.returnRoot
    add(ir.statements, stmt)
    return stmt.statementIndex

fn TypedExprIrAppendStatementsForScope(ir: var TypedExprIr,
                                        ctx: var TypedExprSourceContext,
                                        scope: TypedExprFunctionScope,
                                        facts: var TypedExprFact[],
                                        startIndex: int32,
                                        endIndexRaw: int32) =
    var cursor = startIndex
    if cursor < 0:
        cursor = 0
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > facts.len:
        endIndex = facts.len
    if cursor >= endIndex:
        return
    var currentLineNumber: int32 = -1
    var currentLineHasIf = false
    var currentLineBindingName = ""
    var currentLineBindingType = ""
    var currentLineBindingRootColumn: int32 = -1
    var currentLineBindingRhsStartColumn: int32 = -1
    var currentLineIndent: int32
    var currentLineEnclosingIfLineNumber: int32
    var currentLineEnclosingIfConditionText = ""
    for i in cursor..<endIndex:
        if facts[i].lineNumber <= scope.startLine || facts[i].lineNumber > scope.endLine:
            if facts[i].lineNumber > scope.endLine:
                break
            continue
        if facts[i].lineNumber != currentLineNumber:
            currentLineNumber = facts[i].lineNumber
            currentLineHasIf = false
            currentLineBindingName = ""
            currentLineBindingType = ""
            currentLineBindingRootColumn = -1
            currentLineBindingRhsStartColumn = -1
            let lineRaw = TypedExprSourceLine(ctx, currentLineNumber)
            currentLineIndent = TypedExprLineIndentWidth(lineRaw)
            TypedExprNearestEnclosingIf(ctx,
                                        scope,
                                        currentLineNumber,
                                        currentLineIndent,
                                        currentLineEnclosingIfLineNumber,
                                        currentLineEnclosingIfConditionText)
            let trimmedLine = chengpath.PathTrim(lineRaw)
            var isBindingLine = false
            if parser.ParserStartsWith(trimmedLine, "let "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "var "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "const "):
                isBindingLine = true
            if isBindingLine:
                currentLineBindingName = TypedExprLetCallBindingNameFromBody(trimmedLine)
                var bindingName = ""
                var bindingType = ""
                var bindingRhsColumn: int32 = -1
                if TypedExprParseBindingLine(lineRaw, bindingName, bindingType, bindingRhsColumn):
                    currentLineBindingName = bindingName
                    currentLineBindingType = bindingType
                let eqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if eqPos >= 0:
                    var rhsStartColumn = eqPos + 2
                    for column in rhsStartColumn..lineRaw.len:
                        if parser.ParserIsInlineSpace(lineRaw[column - 1]):
                            rhsStartColumn = column + 1
                        else:
                            rhsStartColumn = column
                            break
                    currentLineBindingRhsStartColumn = rhsStartColumn
            for j in i..<endIndex:
                if facts[j].lineNumber != currentLineNumber:
                    if facts[j].lineNumber > currentLineNumber:
                        break
                    continue
                if facts[j].kind == parser.NormalizedExprIf:
                    currentLineHasIf = true
                    break
                if currentLineBindingRhsStartColumn > 0 &&
                   (facts[j].kind == parser.NormalizedExprCall ||
                    facts[j].kind == parser.NormalizedExprResultIntrinsic) &&
                   facts[j].columnNumber >= currentLineBindingRhsStartColumn:
                    if currentLineBindingRootColumn < 0 ||
                       facts[j].columnNumber < currentLineBindingRootColumn:
                        currentLineBindingRootColumn = facts[j].columnNumber
        let isResultIntrinsic = facts[i].kind == parser.NormalizedExprResultIntrinsic
        let isNormalCall = facts[i].kind == parser.NormalizedExprCall
        if !isNormalCall && !isResultIntrinsic:
            continue
        if isNormalCall && facts[i].callKind == TypedExprCallBuiltin:
            continue
        if isNormalCall && (!facts[i].callResolved || facts[i].callTarget == ""):
            continue
        var statementKind = TypedExprIrStmtCall
        if isResultIntrinsic:
            statementKind = TypedExprIrStmtResultIntrinsic
        else:
            if facts[i].hasSink &&
               (facts[i].sinkPlaceKind == TypedExprPlaceLocal ||
                facts[i].sinkPlaceKind == TypedExprPlaceGlobal):
                statementKind = TypedExprIrStmtLetCall
            elif currentLineBindingRootColumn == facts[i].columnNumber:
                statementKind = TypedExprIrStmtLetCall
            elif currentLineHasIf:
                statementKind = TypedExprIrStmtIfCall
        var statementBindingName = ""
        if statementKind == TypedExprIrStmtLetCall ||
           (statementKind == TypedExprIrStmtResultIntrinsic &&
            (facts[i].hasSink || currentLineBindingRootColumn == facts[i].columnNumber)):
            statementBindingName = currentLineBindingName
        var statementFact = facts[i]
        var statementLocalImportcReturnType = ""
        if statementFact.kind == parser.NormalizedExprCall &&
           statementFact.callQualifier == "":
            statementLocalImportcReturnType = TypedExprLookupLocalImportcReturnTypeForCall(ctx,
                                                                                           statementFact.callCallee,
                                                                                           statementFact.callTarget)
            if statementLocalImportcReturnType == "":
                var importcSourcePath = statementFact.callTargetSourcePath
                if importcSourcePath == "":
                    importcSourcePath = ctx.sourcePath
                statementLocalImportcReturnType = TypedExprIrLookupImportcReturnType(ir,
                                                                                     importcSourcePath,
                                                                                     statementFact.callTarget)
            if statementLocalImportcReturnType != "" && !statementFact.callTargetImportc:
                if statementFact.callTargetSourcePath == "" ||
                   parser.ParserNormalizePath(statementFact.callTargetSourcePath) == parser.ParserNormalizePath(ctx.sourcePath):
                    if statementFact.callCallee != "":
                        statementFact.callTarget = statementFact.callCallee
                    statementFact.callTargetSourcePath = ctx.sourcePath
                    statementFact.callTargetImportc = true
        var statementResultType = statementFact.typeText
        if statementLocalImportcReturnType != "":
            statementResultType = statementLocalImportcReturnType
        if (statementKind == TypedExprIrStmtLetCall ||
            statementKind == TypedExprIrStmtResultIntrinsic) &&
           Len(currentLineBindingType) > 0:
            statementResultType = currentLineBindingType
        if Len(statementResultType) <= 0 &&
           statementFact.callQualifier == "":
            statementResultType = TypedExprLookupLocalFunctionReturnType(ctx, statementFact.callTarget)
        let _ = TypedExprIrAddCallStatement(ir,
                                            scope,
                                            statementFact,
                                            statementKind,
                                            statementBindingName,
                                            statementResultType,
                                            currentLineIndent,
                                            currentLineEnclosingIfLineNumber,
                                            currentLineEnclosingIfConditionText)

fn TypedExprFactIsIrCallStatementCandidate(fact: TypedExprFact): bool =
    let isResultIntrinsic = fact.kind == parser.NormalizedExprResultIntrinsic
    let isNormalCall = fact.kind == parser.NormalizedExprCall
    if !isNormalCall && !isResultIntrinsic:
        return false
    if isNormalCall && fact.callKind == TypedExprCallBuiltin:
        return false
    if isNormalCall && (!fact.callResolved || fact.callTarget == ""):
        return false
    return true

fn TypedExprProcessedFactContains(processedFactIndexes: int32[],
                                    factIndex: int32): bool =
    for i in 0..<processedFactIndexes.len:
        if processedFactIndexes[i] == factIndex:
            return true
    return false

fn TypedExprFactFullCallText(fact: TypedExprFact): str =
    let surface = TypedExprQualifiedCallSurface(fact.callQualifier, fact.callCallee)
    if fact.callArgCount > 0:
        return Fmt"{surface}({fact.callArgsText})"
    return Fmt"{surface}()"

fn TypedExprFactCallArgsContainFact(rootFact: TypedExprFact,
                                      dependencyFact: TypedExprFact): bool =
    if rootFact.lineNumber != dependencyFact.lineNumber:
        return false
    if dependencyFact.columnNumber <= rootFact.columnNumber:
        return false
    let dependencyText = TypedExprFactFullCallText(dependencyFact)
    if dependencyText == "" || rootFact.callArgsText == "":
        return false
    return strutil.Contains(rootFact.callArgsText, dependencyText)

fn TypedExprIrAppendFactStatementForScope(ir: var TypedExprIr,
                                           ctx: var TypedExprSourceContext,
                                           sourceContexts: var TypedExprSourceContext[],
                                           scope: TypedExprFunctionScope,
                                           fact: TypedExprFact,
                                           currentLineHasIf: bool,
                                           currentLineBindingName: str,
                                           currentLineBindingType: str,
                                           currentLineBindingRootColumn: int32,
                                           currentLineIndent: int32,
                                           currentLineEnclosingIfLineNumber: int32,
                                           currentLineEnclosingIfConditionText: str): int32 =
    var statementFact = fact
    var localImportcReturnType = ""
    if statementFact.kind == parser.NormalizedExprCall &&
       statementFact.callQualifier == "":
        localImportcReturnType = TypedExprLookupLocalImportcReturnTypeForCall(ctx,
                                                                              statementFact.callCallee,
                                                                              statementFact.callTarget)
        if localImportcReturnType == "":
            var importcSourcePath = statementFact.callTargetSourcePath
            if importcSourcePath == "":
                importcSourcePath = ctx.sourcePath
            localImportcReturnType = TypedExprIrLookupImportcReturnType(ir,
                                                                        importcSourcePath,
                                                                        statementFact.callTarget)
        if localImportcReturnType != "" && !statementFact.callTargetImportc:
            if statementFact.callTargetSourcePath == "" ||
               parser.ParserNormalizePath(statementFact.callTargetSourcePath) == parser.ParserNormalizePath(ctx.sourcePath):
                if statementFact.callCallee != "":
                    statementFact.callTarget = statementFact.callCallee
                statementFact.callTargetSourcePath = ctx.sourcePath
                statementFact.callTargetImportc = true
    if statementFact.kind == parser.NormalizedExprCall &&
       (statementFact.callTargetSourcePath == "" ||
        (statementFact.callQualifier != "" &&
         statementFact.surfaceCallKind != TypedExprSurfaceCallMember)):
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        let resolvedReturnType = TypedExprResolveQualifiedCallTargetReturnType(ctx,
                                                                               sourceContexts,
                                                                               statementFact.callQualifier,
                                                                               statementFact.callCallee,
                                                                               statementFact.callTarget,
                                                                               resolvedSourcePath,
                                                                               resolvedTargetName,
                                                                               resolvedImportc)
        if resolvedReturnType != "":
            statementFact.callTarget = resolvedTargetName
            statementFact.callTargetSourcePath = resolvedSourcePath
            statementFact.callTargetImportc = resolvedImportc
        elif statementFact.callQualifier != "" &&
             statementFact.surfaceCallKind != TypedExprSurfaceCallMember:
            return -1
    var statementKind = TypedExprIrStmtCall
    if statementFact.kind == parser.NormalizedExprResultIntrinsic:
        statementKind = TypedExprIrStmtResultIntrinsic
    else:
        if statementFact.hasSink &&
           (statementFact.sinkPlaceKind == TypedExprPlaceLocal ||
            statementFact.sinkPlaceKind == TypedExprPlaceGlobal):
            statementKind = TypedExprIrStmtLetCall
        elif currentLineBindingRootColumn == fact.columnNumber:
            statementKind = TypedExprIrStmtLetCall
        elif currentLineHasIf:
            statementKind = TypedExprIrStmtIfCall
    var statementBindingName = ""
    if statementKind == TypedExprIrStmtLetCall ||
       (statementKind == TypedExprIrStmtResultIntrinsic &&
        (statementFact.hasSink || currentLineBindingRootColumn == statementFact.columnNumber)):
        statementBindingName = currentLineBindingName
    var statementResultType = statementFact.typeText
    if localImportcReturnType != "":
        statementResultType = localImportcReturnType
    if (statementKind == TypedExprIrStmtLetCall ||
        statementKind == TypedExprIrStmtResultIntrinsic) &&
       Len(currentLineBindingType) > 0:
        statementResultType = currentLineBindingType
    var resultCallName = ""
    if statementFact.kind == parser.NormalizedExprResultIntrinsic:
        resultCallName = statementFact.callCallee
    elif statementFact.kind == parser.NormalizedExprCall:
        resultCallName = TypedExprQualifiedCallLeaf(statementFact.callCallee)
        if resultCallName == "":
            resultCallName = TypedExprQualifiedCallLeaf(statementFact.callTarget)
    if resultCallName != "":
        if resultCallName == "Value" ||
           resultCallName == "IsOk" ||
           resultCallName == "IsErr" ||
           resultCallName == "Error" ||
           resultCallName == "ErrorInfoOf":
            var argsText = chengpath.PathTrim(statementFact.callArgsText)
            let commaPos = TypedExprFindTopLevelToken(argsText, ",")
            if commaPos >= 0:
                argsText = chengpath.PathTrim(chengpath.TextSlice(argsText, 0, commaPos))
            let resultArgName = parser.ParserIdentPrefix(argsText)
            if resultArgName != "":
                let resultScopeIndex = TypedExprScopeIndexForLine(ctx.scopes, statementFact.lineNumber)
                var resultArgType = TypedExprLookupBindingType(ctx,
                                                               resultScopeIndex,
                                                               statementFact.lineNumber,
                                                               resultArgName)
                if resultArgType == "":
                    resultArgType = TypedExprIrPriorBindingType(ir,
                                                                scope.name,
                                                                statementFact.lineNumber,
                                                                resultArgName)
                if resultCallName == "Value":
                    let resultInnerType = TypedExprResultSuccessType(resultArgType)
                    if resultInnerType != "":
                        statementResultType = resultInnerType
                elif resultCallName == "IsOk" || resultCallName == "IsErr":
                    statementResultType = "bool"
                elif resultCallName == "Error":
                    statementResultType = "str"
                elif resultCallName == "ErrorInfoOf":
                    statementResultType = "ErrorInfo"
    if statementFact.kind == parser.NormalizedExprCall &&
       localImportcReturnType == "" &&
       !TypedExprTypeTextIsConcrete(statementResultType):
        let resolvedReturnType = TypedExprLookupCallTargetReturnTypeFromFact(ctx, sourceContexts, statementFact)
        if resolvedReturnType != "":
            statementResultType = resolvedReturnType
    if Len(statementResultType) <= 0 ||
       statementResultType == "call_expr" ||
       statementResultType == "unknown":
        let resolvedReturnType = TypedExprLookupCallTargetReturnTypeFromFact(ctx, sourceContexts, statementFact)
        if resolvedReturnType != "":
            statementResultType = resolvedReturnType
    if (Len(statementResultType) <= 0 ||
        statementResultType == "call_expr" ||
        statementResultType == "unknown") &&
       statementFact.callQualifier == "":
        statementResultType = TypedExprLookupLocalFunctionReturnType(ctx, statementFact.callTarget)
    return TypedExprIrAddCallStatement(ir,
                                       scope,
                                       statementFact,
                                       statementKind,
                                       statementBindingName,
                                       statementResultType,
                                       currentLineIndent,
                                       currentLineEnclosingIfLineNumber,
                                       currentLineEnclosingIfConditionText)

fn TypedExprIrAppendFactDependenciesForScope(ir: var TypedExprIr,
                                              ctx: var TypedExprSourceContext,
                                              sourceContexts: var TypedExprSourceContext[],
                                              scope: TypedExprFunctionScope,
                                              facts: var TypedExprFact[],
                                              rootFactIndex: int32,
                                              factStartIndex: int32,
                                              factEndIndex: int32,
                                              processedFactIndexes: var int32[],
                                              currentLineHasIf: bool,
                                              currentLineBindingName: str,
                                              currentLineBindingType: str,
                                              currentLineBindingRootColumn: int32,
                                              currentLineIndent: int32,
                                              currentLineEnclosingIfLineNumber: int32,
                                              currentLineEnclosingIfConditionText: str) =
    if rootFactIndex < 0 || rootFactIndex >= facts.len:
        return
    let rootFact = facts[rootFactIndex]
    for depIndex in factStartIndex..<factEndIndex:
        if depIndex == rootFactIndex:
            continue
        if TypedExprProcessedFactContains(processedFactIndexes, depIndex):
            continue
        let dependencyFact = facts[depIndex]
        if dependencyFact.lineNumber < rootFact.lineNumber:
            continue
        if dependencyFact.lineNumber > rootFact.lineNumber:
            break
        if !TypedExprFactIsIrCallStatementCandidate(dependencyFact):
            continue
        if !TypedExprFactCallArgsContainFact(rootFact, dependencyFact):
            continue
        TypedExprIrAppendFactDependenciesForScope(ir,
                                                  ctx,
                                                  sourceContexts,
                                                  scope,
                                                  facts,
                                                  depIndex,
                                                  factStartIndex,
                                                  factEndIndex,
                                                  processedFactIndexes,
                                                  currentLineHasIf,
                                                  currentLineBindingName,
                                                  currentLineBindingType,
                                                  currentLineBindingRootColumn,
                                                  currentLineIndent,
                                                  currentLineEnclosingIfLineNumber,
                                                  currentLineEnclosingIfConditionText)
        let _ = TypedExprIrAppendFactStatementForScope(ir,
                                                       ctx,
                                                       sourceContexts,
                                                       scope,
                                                       dependencyFact,
                                                       currentLineHasIf,
                                                       currentLineBindingName,
                                                       currentLineBindingType,
                                                       currentLineBindingRootColumn,
                                                       currentLineIndent,
                                                       currentLineEnclosingIfLineNumber,
                                                       currentLineEnclosingIfConditionText)
        add(processedFactIndexes, depIndex)

fn TypedExprExprIsStructuredStatement(expr: parser.NormalizedExpr): bool =
    if expr.kind == parser.NormalizedExprReturn:
        return true
    if expr.kind == parser.NormalizedExprAssign:
        return true
    if expr.kind == parser.NormalizedExprIfStmt ||
       expr.kind == parser.NormalizedExprElifStmt ||
       expr.kind == parser.NormalizedExprElseStmt ||
       expr.kind == parser.NormalizedExprForStmt:
        return true
    return false

fn TypedExprScopeHasDirectLeafControlBody(ctx: var TypedExprSourceContext,
                                           scope: TypedExprFunctionScope,
                                           params: TypedExprParam[]): bool =
    var bodyLineNumber: int32
    var thenConst = ""
    var elseConst = ""
    if TypedExprFunctionBodyIsI32IfArg0LeZeroConstElseConst(ctx,
                                                            scope,
                                                            params,
                                                            bodyLineNumber,
                                                            thenConst,
                                                            elseConst):
        return true
    if TypedExprFunctionBodyMatchesF64MulCheckExit(ctx, scope):
        return true
    if TypedExprFunctionBodyMatchesStrLenFast(ctx, scope, params):
        return true
    return false

fn TypedExprTextIsI32Zero(textRaw: str): bool =
    let text = chengpath.PathTrim(textRaw)
    return text == "0" || text == "int32(0)"

fn TypedExprScopeNeedsStructuredStatements(ctx: var TypedExprSourceContext,
                                            scope: TypedExprFunctionScope,
                                            params: TypedExprParam[],
                                            returnExpr: str,
                                            facts: var TypedExprFact[],
                                            factStartIndex: int32,
                                            factEndIndexRaw: int32,
                                            exprLayer: var parser.NormalizedExprLayer,
                                            exprStartIndex: int32,
                                            exprEndIndexRaw: int32): bool =
    var exprEndIndex = exprEndIndexRaw
    if exprEndIndex < 0 || exprEndIndex > exprLayer.exprs.len:
        exprEndIndex = exprLayer.exprs.len
    var hasControlStatement = false
    var hasAssignStatement = false
    var hasForStatement = false
    for i in exprStartIndex..<exprEndIndex:
        let expr = exprLayer.exprs[i]
        if expr.lineNumber <= scope.startLine || expr.lineNumber > scope.endLine:
            if expr.lineNumber > scope.endLine:
                break
            continue
        if expr.kind == parser.NormalizedExprAssign:
            hasAssignStatement = true
        elif expr.kind == parser.NormalizedExprForStmt:
            hasForStatement = true
            hasControlStatement = true
        elif expr.kind == parser.NormalizedExprIfStmt ||
             expr.kind == parser.NormalizedExprElifStmt ||
             expr.kind == parser.NormalizedExprElseStmt:
            hasControlStatement = true
    if hasAssignStatement || hasForStatement:
        return true
    if hasControlStatement:
        if scope.returnType == "" || scope.returnType == "void":
            return true
        if !TypedExprScopeHasDirectLeafControlBody(ctx, scope, params):
            return true
    var factEndIndex = factEndIndexRaw
    if factEndIndex < 0 || factEndIndex > facts.len:
        factEndIndex = facts.len
    var callCount: int32
    var onlyCallIndex: int32 = -1
    for i in factStartIndex..<factEndIndex:
        let fact = facts[i]
        if fact.lineNumber <= scope.startLine || fact.lineNumber > scope.endLine:
            if fact.lineNumber > scope.endLine:
                break
            continue
        if !TypedExprFactIsIrCallStatementCandidate(fact):
            continue
        callCount = callCount + 1
        onlyCallIndex = i
        if callCount > 1:
            return true
    if callCount <= 0:
        return false
    let onlyFact = facts[onlyCallIndex]
    if onlyFact.returnRoot && !onlyFact.hasSink:
        return false
    if onlyFact.kind == parser.NormalizedExprCall &&
       !onlyFact.returnRoot &&
       !onlyFact.hasSink &&
       onlyFact.callArgCount == 1 &&
       TypedExprTextIsI32Zero(onlyFact.callArgsText) &&
       TypedExprTextIsI32Zero(returnExpr):
        return false
    return true

fn TypedExprNextStructuredStatementExprIndex(exprLayer: var parser.NormalizedExprLayer,
                                              cursorRaw: int32,
                                              endIndexRaw: int32,
                                              scope: TypedExprFunctionScope): int32 =
    var cursor = cursorRaw
    if cursor < 0:
        cursor = 0
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > exprLayer.exprs.len:
        endIndex = exprLayer.exprs.len
    for i in cursor..<endIndex:
        let expr = exprLayer.exprs[i]
        if expr.lineNumber <= scope.startLine:
            continue
        if expr.lineNumber > scope.endLine:
            return -1
        if TypedExprExprIsStructuredStatement(expr):
            return i
    return -1

fn TypedExprNextCallStatementFactIndex(facts: var TypedExprFact[],
                                        cursorRaw: int32,
                                        endIndexRaw: int32,
                                        scope: TypedExprFunctionScope,
                                        processedFactIndexes: int32[]): int32 =
    var cursor = cursorRaw
    if cursor < 0:
        cursor = 0
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > facts.len:
        endIndex = facts.len
    for i in cursor..<endIndex:
        let fact = facts[i]
        if fact.lineNumber <= scope.startLine:
            continue
        if fact.lineNumber > scope.endLine:
            return -1
        if TypedExprProcessedFactContains(processedFactIndexes, i):
            continue
        if TypedExprFactIsIrCallStatementCandidate(fact):
            return i
    return -1

fn TypedExprStructuredExprComesBeforeFact(expr: parser.NormalizedExpr,
                                           fact: TypedExprFact): bool =
    if expr.lineNumber < fact.lineNumber:
        return true
    if expr.lineNumber > fact.lineNumber:
        return false
    return expr.columnNumber <= fact.columnNumber

fn TypedExprIrAppendStatementsForScopeWithFactsAndExprLayer(ir: var TypedExprIr,
                                                             ctx: var TypedExprSourceContext,
                                                             sourceContexts: var TypedExprSourceContext[],
                                                             scope: TypedExprFunctionScope,
                                                             facts: var TypedExprFact[],
                                                             factStartIndex: int32,
                                                             factEndIndexRaw: int32,
                                                             exprLayer: var parser.NormalizedExprLayer,
                                                             exprStartIndex: int32,
                                                             exprEndIndexRaw: int32,
                                                             includeStructuredStatements: bool) =
    var factCursor = factStartIndex
    if factCursor < 0:
        factCursor = 0
    var factEndIndex = factEndIndexRaw
    if factEndIndex < 0 || factEndIndex > facts.len:
        factEndIndex = facts.len
    var exprCursor = exprStartIndex
    if exprCursor < 0:
        exprCursor = 0
    var exprEndIndex = exprEndIndexRaw
    if exprEndIndex < 0 || exprEndIndex > exprLayer.exprs.len:
        exprEndIndex = exprLayer.exprs.len
    var currentLineNumber: int32 = -1
    var currentLineHasIf = false
    var currentLineBindingName = ""
    var currentLineBindingType = ""
    var currentLineBindingRootColumn: int32 = -1
    var currentLineBindingRhsStartColumn: int32 = -1
    var currentLineReturnRootColumn: int32 = -1
    var currentLineReturnExprStartColumn: int32 = -1
    var currentLineIndent: int32
    var currentLineEnclosingIfLineNumber: int32
    var currentLineEnclosingIfConditionText = ""
    var processedFactIndexes: int32[]
    while true:
        var exprIndex: int32 = -1
        if includeStructuredStatements:
            exprIndex = TypedExprNextStructuredStatementExprIndex(exprLayer,
                                                                  exprCursor,
                                                                  exprEndIndex,
                                                                  scope)
        let factIndex = TypedExprNextCallStatementFactIndex(facts,
                                                            factCursor,
                                                            factEndIndex,
                                                            scope,
                                                            processedFactIndexes)
        if exprIndex < 0 && factIndex < 0:
            break
        var useExpr = false
        if exprIndex >= 0:
            if factIndex < 0:
                useExpr = true
            else:
                useExpr = TypedExprStructuredExprComesBeforeFact(exprLayer.exprs[exprIndex],
                                                                 facts[factIndex])
        var lineNumber: int32
        if useExpr:
            lineNumber = exprLayer.exprs[exprIndex].lineNumber
        else:
            lineNumber = facts[factIndex].lineNumber
        if lineNumber != currentLineNumber:
            currentLineNumber = lineNumber
            currentLineHasIf = false
            currentLineBindingName = ""
            currentLineBindingType = ""
            currentLineBindingRootColumn = -1
            currentLineBindingRhsStartColumn = -1
            currentLineReturnRootColumn = -1
            currentLineReturnExprStartColumn = -1
            let lineRaw = TypedExprSourceLine(ctx, currentLineNumber)
            currentLineIndent = TypedExprLineIndentWidth(lineRaw)
            TypedExprNearestEnclosingIf(ctx,
                                        scope,
                                        currentLineNumber,
                                        currentLineIndent,
                                        currentLineEnclosingIfLineNumber,
                                        currentLineEnclosingIfConditionText)
            let trimmedLine = chengpath.PathTrim(lineRaw)
            var isBindingLine = false
            if parser.ParserStartsWith(trimmedLine, "let "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "var "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "const "):
                isBindingLine = true
            if isBindingLine:
                currentLineBindingName = TypedExprLetCallBindingNameFromBody(trimmedLine)
                var bindingName = ""
                var bindingType = ""
                var bindingRhsColumn: int32 = -1
                if TypedExprParseBindingLine(lineRaw, bindingName, bindingType, bindingRhsColumn):
                    currentLineBindingName = bindingName
                    currentLineBindingType = bindingType
                let eqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if eqPos >= 0:
                    var rhsStartColumn = eqPos + 2
                    for column in rhsStartColumn..lineRaw.len:
                        if parser.ParserIsInlineSpace(lineRaw[column - 1]):
                            rhsStartColumn = column + 1
                        else:
                            rhsStartColumn = column
                            break
                    currentLineBindingRhsStartColumn = rhsStartColumn
            let firstToken = parser.ParserFirstToken(chengpath.PathTrim(lineRaw))
            if firstToken == "return":
                let returnPos = parser.ParserFindText(lineRaw, "return")
                currentLineReturnExprStartColumn = returnPos + 7
            elif scope.startLine == currentLineNumber:
                let inlineEqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if inlineEqPos >= 0:
                    currentLineReturnExprStartColumn = inlineEqPos + 2
                else:
                    currentLineReturnExprStartColumn = -1
            for j in exprStartIndex..<exprEndIndex:
                let lineExpr = exprLayer.exprs[j]
                if lineExpr.lineNumber != currentLineNumber:
                    if lineExpr.lineNumber > currentLineNumber:
                        break
                    continue
                if lineExpr.kind == parser.NormalizedExprIf:
                    currentLineHasIf = true
                    break
            for j in factStartIndex..<factEndIndex:
                let lineFact = facts[j]
                if lineFact.lineNumber != currentLineNumber:
                    if lineFact.lineNumber > currentLineNumber:
                        break
                    continue
                if currentLineBindingRhsStartColumn > 0 &&
                   (lineFact.kind == parser.NormalizedExprCall ||
                    lineFact.kind == parser.NormalizedExprResultIntrinsic) &&
                   lineFact.columnNumber >= currentLineBindingRhsStartColumn:
                    if currentLineBindingRootColumn < 0 ||
                       lineFact.columnNumber < currentLineBindingRootColumn:
                        currentLineBindingRootColumn = lineFact.columnNumber
                if currentLineReturnExprStartColumn > 0 &&
                   (lineFact.kind == parser.NormalizedExprCall ||
                    lineFact.kind == parser.NormalizedExprResultIntrinsic) &&
                   lineFact.columnNumber >= currentLineReturnExprStartColumn:
                    if currentLineReturnRootColumn < 0 ||
                       lineFact.columnNumber < currentLineReturnRootColumn:
                        currentLineReturnRootColumn = lineFact.columnNumber
        if useExpr:
            let expr = exprLayer.exprs[exprIndex]
            if expr.kind == parser.NormalizedExprReturn:
                let _ = TypedExprIrAddCallStatementFromExpr(ir,
                                                            ctx,
                                                            sourceContexts,
                                                            scope,
                                                            expr,
                                                            TypedExprIrStmtReturn,
                                                            "",
                                                            scope.returnType,
                                                            currentLineIndent,
                                                            currentLineEnclosingIfLineNumber,
                                                            currentLineEnclosingIfConditionText,
                                                            true)
            elif expr.kind == parser.NormalizedExprAssign:
                let assignStmtIndex = TypedExprIrAddAssignStatementFromExpr(ir,
                                                                            ctx,
                                                                            sourceContexts,
                                                                            scope,
                                                                            expr,
                                                                            currentLineIndent,
                                                                            currentLineEnclosingIfLineNumber,
                                                                            currentLineEnclosingIfConditionText)
                if assignStmtIndex >= 0 &&
                   assignStmtIndex < ir.statements.len &&
                   factIndex >= 0 &&
                   factIndex < facts.len &&
                   facts[factIndex].lineNumber == expr.lineNumber &&
                   facts[factIndex].columnNumber > expr.columnNumber:
                    var assignStmt = ir.statements[assignStmtIndex]
                    TypedExprIrBindAssignStatementCallFact(assignStmt,
                                                           ctx,
                                                           sourceContexts,
                                                           scope,
                                                           facts[factIndex])
                    ir.statements[assignStmtIndex] = assignStmt
            else:
                let _ = TypedExprIrAddControlStatementFromExpr(ir,
                                                               ctx,
                                                               sourceContexts,
                                                               scope,
                                                               expr,
                                                               currentLineIndent,
                                                               currentLineEnclosingIfLineNumber,
                                                               currentLineEnclosingIfConditionText)
            exprCursor = exprIndex + 1
            continue
        let fact = facts[factIndex]
        TypedExprIrAppendFactDependenciesForScope(ir,
                                                  ctx,
                                                  sourceContexts,
                                                  scope,
                                                  facts,
                                                  factIndex,
                                                  factStartIndex,
                                                  factEndIndex,
                                                  processedFactIndexes,
                                                  currentLineHasIf,
                                                  currentLineBindingName,
                                                  currentLineBindingType,
                                                  currentLineBindingRootColumn,
                                                  currentLineIndent,
                                                  currentLineEnclosingIfLineNumber,
                                                  currentLineEnclosingIfConditionText)
        if !TypedExprProcessedFactContains(processedFactIndexes, factIndex):
            let _ = TypedExprIrAppendFactStatementForScope(ir,
                                                           ctx,
                                                           sourceContexts,
                                                           scope,
                                                           fact,
                                                           currentLineHasIf,
                                                           currentLineBindingName,
                                                           currentLineBindingType,
                                                           currentLineBindingRootColumn,
                                                           currentLineIndent,
                                                           currentLineEnclosingIfLineNumber,
                                                           currentLineEnclosingIfConditionText)
            add(processedFactIndexes, factIndex)
        factCursor = factIndex + 1

fn TypedExprLookupCallTargetReturnTypeFromExpr(currentCtx: var TypedExprSourceContext,
                                                sourceContexts: var TypedExprSourceContext[],
                                                expr: parser.NormalizedExpr): str =
    if expr.callQualifier != "" &&
       TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind) != TypedExprSurfaceCallMember:
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        return TypedExprResolveQualifiedCallTargetReturnType(currentCtx,
                                                             sourceContexts,
                                                             expr.callQualifier,
                                                             expr.callCallee,
                                                             expr.callTarget,
                                                             resolvedSourcePath,
                                                             resolvedTargetName,
                                                             resolvedImportc)
    let sourcePath = parser.ParserNormalizePath(expr.callTargetSourcePath)
    if sourcePath == "":
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        let qualifiedReturnType = TypedExprResolveQualifiedCallTargetReturnType(currentCtx,
                                                                                sourceContexts,
                                                                                expr.callQualifier,
                                                                                expr.callCallee,
                                                                                expr.callTarget,
                                                                                resolvedSourcePath,
                                                                                resolvedTargetName,
                                                                                resolvedImportc)
        if qualifiedReturnType != "":
            return qualifiedReturnType
        if expr.callTargetImportc:
            return TypedExprLookupLocalImportcReturnTypeForCall(currentCtx,
                                                                expr.callCallee,
                                                                expr.callTarget)
        return TypedExprLookupLocalFunctionReturnType(currentCtx, expr.callTarget)
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, sourcePath)
    if targetIndex < 0:
        return ""
    if expr.callTargetImportc:
        return TypedExprLookupLocalImportcReturnTypeForCall(sourceContexts[targetIndex],
                                                            expr.callCallee,
                                                            expr.callTarget)
    return TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], expr.callCallee)

fn TypedExprResultIntrinsicTypeFromExpr(ctx: var TypedExprSourceContext,
                                         expr: parser.NormalizedExpr,
                                         sink: TypedExprSinkInfo): str =
    if expr.detailKind == parser.NormalizedExprDetailResultIsOk ||
       expr.detailKind == parser.NormalizedExprDetailResultIsErr:
        return "bool"
    if expr.detailKind == parser.NormalizedExprDetailResultError:
        return "str"
    if expr.detailKind == parser.NormalizedExprDetailResultErrorInfoOf:
        return "ErrorInfo"
    if sink.hasSink && sink.sinkType != "":
        return sink.sinkType
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, expr.lineNumber)
    let sourceResultType = TypedExprInferredResultInputType(ctx, scopeIndex, expr)
    let innerType = TypedExprResultSuccessType(sourceResultType)
    if innerType != "":
        return innerType
    return "result_projection"

fn TypedExprAssignLhsRootName(lhsRaw: str): str =
    let lhs = chengpath.PathTrim(lhsRaw)
    if lhs == "":
        return ""
    var dotPos = parser.ParserFindText(lhs, "->")
    if dotPos < 0:
        dotPos = parser.ParserFindText(lhs, ".")
    if dotPos > 0:
        return parser.ParserIdentPrefix(chengpath.TextSlice(lhs, 0, dotPos))
    return parser.ParserIdentPrefix(lhs)

fn TypedExprAssignFieldName(lhsRaw: str): str =
    let lhs = chengpath.PathTrim(lhsRaw)
    var sepLen = 1
    var dotPos = parser.ParserFindText(lhs, "->")
    if dotPos >= 0:
        sepLen = 2
    else:
        dotPos = parser.ParserFindText(lhs, ".")
    if dotPos < 0 || dotPos + 1 >= lhs.len:
        return ""
    return parser.ParserIdentPrefix(chengpath.TextSlice(lhs,
                                                       dotPos + sepLen,
                                                       lhs.len - dotPos - sepLen))

fn TypedExprAssignFieldPath(lhsRaw: str): str =
    let lhs = chengpath.PathTrim(lhsRaw)
    var sepLen = 1
    var dotPos = parser.ParserFindText(lhs, "->")
    if dotPos >= 0:
        sepLen = 2
    else:
        dotPos = parser.ParserFindText(lhs, ".")
    if dotPos < 0 || dotPos + 1 >= lhs.len:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(lhs,
                                                  dotPos + sepLen,
                                                  lhs.len - dotPos - sepLen))

fn TypedExprTextIsSimpleFieldPath(textRaw: str): bool =
    let text = chengpath.PathTrim(textRaw)
    if text == "":
        return false
    let arrowPos = parser.ParserFindText(text, "->")
    let dotPos = parser.ParserFindText(text, ".")
    if arrowPos <= 0 && dotPos <= 0:
        return false
    if parser.ParserFindText(text, "(") >= 0 ||
       parser.ParserFindText(text, ")") >= 0 ||
       parser.ParserFindText(text, "[") >= 0 ||
       parser.ParserFindText(text, "]") >= 0 ||
       parser.ParserFindText(text, "{") >= 0 ||
       parser.ParserFindText(text, "}") >= 0 ||
       parser.ParserFindText(text, " ") >= 0 ||
       parser.ParserFindText(text, "+") >= 0 ||
       (parser.ParserFindText(text, "-") >= 0 && arrowPos < 0) ||
       parser.ParserFindText(text, "*") >= 0 ||
       parser.ParserFindText(text, "/") >= 0 ||
       parser.ParserFindText(text, "?") >= 0 ||
       parser.ParserFindText(text, ":") >= 0 ||
       parser.ParserFindText(text, ",") >= 0:
        return false
    return true

fn TypedExprAssignFieldType(rootTypeRaw: str,
                             fieldNameRaw: str): str =
    let rootType = TypedExprNormalizeTypeText(rootTypeRaw)
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    if fieldName == "":
        return ""
    if fieldName == "len":
        return "int32"
    if rootType == "Bytes" || rootType == "rawbytes.Bytes":
        if fieldName == "data":
            return "ptr"
        if fieldName == "len":
            return "int32"
    if parser.ParserStartsWith(rootType, "Result["):
        if fieldName == "ok":
            return "bool"
        if fieldName == "value":
            return TypedExprResultSuccessType(rootType)
        if fieldName == "error":
            return "str"
    return ""

fn TypedExprAssignStatementType(ctx: var TypedExprSourceContext,
                                 sourceContexts: var TypedExprSourceContext[],
                                 scope: TypedExprFunctionScope,
                                 lineNumber: int32,
                                 lhsRaw: str): str =
    let rootName = TypedExprAssignLhsRootName(lhsRaw)
    if rootName == "":
        return ""
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
    let rootType = TypedExprLookupBindingType(ctx, scopeIndex, lineNumber, rootName)
    let fieldName = TypedExprAssignFieldName(lhsRaw)
    if fieldName == "":
        return rootType
    let fieldPath = TypedExprAssignFieldPath(lhsRaw)
    var resolvedFieldType = ""
    var resolvedOffset: int32
    var resolvedSize: int32
    var resolvedAlign: int32
    if TypedExprResolveFieldPathMeta(ctx,
                                     sourceContexts,
                                     rootType,
                                     fieldPath,
                                     resolvedFieldType,
                                     resolvedOffset,
                                     resolvedSize,
                                     resolvedAlign):
        return resolvedFieldType
    let fieldType = TypedExprAssignFieldType(rootType, fieldName)
    if fieldType != "":
       return fieldType
    return ""

fn TypedExprIrPopulateAssignLhsMeta(stmt: var TypedExprIrStatement,
                                     ctx: var TypedExprSourceContext,
                                     sourceContexts: var TypedExprSourceContext[],
                                     scope: TypedExprFunctionScope,
                                     lineNumber: int32,
                                     lhsRaw: str): str =
    let rootName = TypedExprAssignLhsRootName(lhsRaw)
    stmt.assignRootName = rootName
    stmt.assignRootType = ""
    stmt.assignRootSourcePath = ""
    stmt.assignRootGlobalFlag = false
    stmt.assignPlaceKind = TypedExprPlaceTemporary
    stmt.assignFieldName = ""
    stmt.assignFieldType = ""
    stmt.assignFieldOffsetBytes = 0
    stmt.assignFieldSizeBytes = 0
    stmt.assignFieldAlignBytes = 0
    if rootName == "":
        return ""
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
    var rootType = ""
    var rootSourcePath = ""
    var rootGlobalFlag = false
    let hasRootMeta = TypedExprLookupBindingMeta(ctx,
                                                scopeIndex,
                                                lineNumber,
                                                rootName,
                                                rootType,
                                                rootSourcePath,
                                                rootGlobalFlag)
    if !hasRootMeta:
        rootType = TypedExprLookupBindingType(ctx, scopeIndex, lineNumber, rootName)
    stmt.assignRootType = rootType
    stmt.assignRootSourcePath = rootSourcePath
    stmt.assignRootGlobalFlag = rootGlobalFlag
    if hasRootMeta:
        if rootGlobalFlag:
            stmt.assignPlaceKind = TypedExprPlaceGlobal
        else:
            stmt.assignPlaceKind = TypedExprPlaceLocal
    let fieldPath = TypedExprAssignFieldPath(lhsRaw)
    if fieldPath == "":
        return rootType
    stmt.assignFieldName = fieldPath
    stmt.assignPlaceKind = TypedExprPlaceField
    var fieldRootType = rootType
    if parser.ParserFindText(lhsRaw, "->") > 0:
        fieldRootType = TypedExprPointerPointeeType(ctx, sourceContexts, rootType)
    var fieldType = ""
    var fieldOffset: int32
    var fieldSize: int32
    var fieldAlign: int32
    if TypedExprResolveFieldPathMeta(ctx,
                                     sourceContexts,
                                     fieldRootType,
                                     fieldPath,
                                     fieldType,
                                     fieldOffset,
                                     fieldSize,
                                     fieldAlign):
        stmt.assignFieldType = fieldType
        stmt.assignFieldOffsetBytes = fieldOffset
        stmt.assignFieldSizeBytes = fieldSize
        stmt.assignFieldAlignBytes = fieldAlign
        return fieldType
    fieldType = TypedExprAssignFieldType(fieldRootType, TypedExprAssignFieldName(lhsRaw))
    if fieldType != "":
        stmt.assignFieldType = fieldType
        var sizeBytes: int32
        var alignBytes: int32
        if TypedExprTypeLayout(ctx, sourceContexts, fieldType, sizeBytes, alignBytes):
            stmt.assignFieldSizeBytes = sizeBytes
            stmt.assignFieldAlignBytes = alignBytes
        return fieldType
    return ""

fn TypedExprIrPopulateAssignValueMeta(stmt: var TypedExprIrStatement,
                                       ctx: var TypedExprSourceContext,
                                       sourceContexts: var TypedExprSourceContext[],
                                       scope: TypedExprFunctionScope,
                                       lineNumber: int32,
                                       valueRaw: str) =
    stmt.assignValueRootName = ""
    stmt.assignValueRootType = ""
    stmt.assignValueFieldName = ""
    stmt.assignValueFieldType = ""
    stmt.assignValueFieldOffsetBytes = 0
    stmt.assignValueFieldSizeBytes = 0
    stmt.assignValueFieldAlignBytes = 0
    stmt.assignValueOpKind = TypedExprIrOpUnsupported
    stmt.assignValueLhsText = ""
    stmt.assignValueRhsText = ""
    stmt.assignValueRhsConst = 0
    stmt.assignValueRhsHasConst = false
    let addPos = TypedExprFindTopLevelTextToken(valueRaw, "+")
    if addPos >= 0:
        let lhsText = chengpath.PathTrim(chengpath.TextSlice(valueRaw, 0, addPos))
        let rhsText = chengpath.PathTrim(chengpath.TextSlice(valueRaw,
                                                             addPos + 1,
                                                             valueRaw.len - addPos - 1))
        if lhsText != "" && rhsText != "":
            stmt.assignValueOpKind = TypedExprIrOpI32Add
            stmt.assignValueLhsText = lhsText
            stmt.assignValueRhsText = rhsText
            if TypedExprIrIsI32ConstLiteral(rhsText):
                stmt.assignValueRhsConst = TypedExprIrParseI32Const(rhsText)
                stmt.assignValueRhsHasConst = true
    let subPos = TypedExprFindTopLevelTextToken(valueRaw, "-")
    if stmt.assignValueOpKind == TypedExprIrOpUnsupported && subPos >= 0:
        let lhsText = chengpath.PathTrim(chengpath.TextSlice(valueRaw, 0, subPos))
        let rhsText = chengpath.PathTrim(chengpath.TextSlice(valueRaw,
                                                             subPos + 1,
                                                             valueRaw.len - subPos - 1))
        if lhsText != "" && rhsText != "":
            stmt.assignValueOpKind = TypedExprIrOpI32Sub
            stmt.assignValueLhsText = lhsText
            stmt.assignValueRhsText = rhsText
            if TypedExprIrIsI32ConstLiteral(rhsText):
                stmt.assignValueRhsConst = TypedExprIrParseI32Const(rhsText)
                stmt.assignValueRhsHasConst = true
    if !TypedExprTextIsSimpleFieldPath(valueRaw):
        return
    let rootName = TypedExprAssignLhsRootName(valueRaw)
    let fieldPath = TypedExprAssignFieldPath(valueRaw)
    if rootName == "" || fieldPath == "":
        return
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
    let rootType = TypedExprLookupBindingType(ctx, scopeIndex, lineNumber, rootName)
    if rootType == "":
        return
    var fieldRootType = rootType
    if parser.ParserFindText(valueRaw, "->") > 0:
        fieldRootType = TypedExprPointerPointeeType(ctx, sourceContexts, rootType)
    var fieldType = ""
    var fieldOffset: int32
    var fieldSize: int32
    var fieldAlign: int32
    if !TypedExprResolveFieldPathMeta(ctx,
                                      sourceContexts,
                                      fieldRootType,
                                      fieldPath,
                                      fieldType,
                                      fieldOffset,
                                      fieldSize,
                                      fieldAlign):
        return
    stmt.assignValueRootName = rootName
    stmt.assignValueRootType = rootType
    stmt.assignValueFieldName = fieldPath
    stmt.assignValueFieldType = fieldType
    stmt.assignValueFieldOffsetBytes = fieldOffset
    stmt.assignValueFieldSizeBytes = fieldSize
    stmt.assignValueFieldAlignBytes = fieldAlign

fn TypedExprControlStatementKindFromExpr(expr: parser.NormalizedExpr): TypedExprIrStatementKind =
    if expr.kind == parser.NormalizedExprIfStmt:
        return TypedExprIrStmtIf
    if expr.kind == parser.NormalizedExprElifStmt:
        return TypedExprIrStmtElif
    if expr.kind == parser.NormalizedExprElseStmt:
        return TypedExprIrStmtElse
    if expr.kind == parser.NormalizedExprForStmt:
        return TypedExprIrStmtFor
    return TypedExprIrStmtUnsupported

fn TypedExprForBindingNameFromHeader(headerRaw: str): str =
    let header = chengpath.PathTrim(headerRaw)
    let inPos = parser.ParserFindText(header, " in ")
    if inPos <= 0:
        return ""
    return parser.ParserIdentPrefix(chengpath.PathTrim(chengpath.TextSlice(header,
                                                                           0,
                                                                           inPos)))

fn TypedExprIrAddControlStatementFromExpr(ir: var TypedExprIr,
                                           ctx: var TypedExprSourceContext,
                                           sourceContexts: var TypedExprSourceContext[],
                                           scope: TypedExprFunctionScope,
                                           expr: parser.NormalizedExpr,
                                           lineIndent: int32,
                                           enclosingIfLineNumber: int32,
                                           enclosingIfConditionText: str): int32 =
    let statementKind = TypedExprControlStatementKindFromExpr(expr)
    if statementKind == TypedExprIrStmtUnsupported:
        return -1
    var stmt: TypedExprIrStatement
    stmt.sourcePath = expr.sourcePath
    stmt.functionName = scope.name
    stmt.statementIndex = ir.statements.len
    stmt.lineNumber = expr.lineNumber
    stmt.columnNumber = expr.columnNumber
    stmt.lineIndent = lineIndent
    stmt.enclosingIfLineNumber = enclosingIfLineNumber
    stmt.enclosingIfConditionText = enclosingIfConditionText
    stmt.exprId = expr.exprId
    stmt.kind = statementKind
    stmt.callKind = TypedExprCallNone
    stmt.detailKind = expr.detailKind
    stmt.surfaceText = chengpath.PathTrim(expr.surfaceText)
    stmt.bindingName = ""
    if statementKind == TypedExprIrStmtFor:
        stmt.bindingName = TypedExprForBindingNameFromHeader(stmt.surfaceText)
    stmt.resultType = ""
    if statementKind == TypedExprIrStmtIf ||
       statementKind == TypedExprIrStmtElif:
        stmt.resultType = "bool"
    elif statementKind == TypedExprIrStmtFor:
        stmt.resultType = "range"
    stmt.assignRootName = ""
    stmt.assignRootType = ""
    stmt.assignRootSourcePath = ""
    stmt.assignRootGlobalFlag = false
    stmt.assignPlaceKind = TypedExprPlaceTemporary
    stmt.assignFieldName = ""
    stmt.assignFieldType = ""
    stmt.assignFieldOffsetBytes = 0
    stmt.assignFieldSizeBytes = 0
    stmt.assignFieldAlignBytes = 0
    stmt.assignValueRootName = ""
    stmt.assignValueRootType = ""
    stmt.assignValueFieldName = ""
    stmt.assignValueFieldType = ""
    stmt.assignValueFieldOffsetBytes = 0
    stmt.assignValueFieldSizeBytes = 0
    stmt.assignValueFieldAlignBytes = 0
    stmt.assignValueOpKind = TypedExprIrOpUnsupported
    stmt.assignValueLhsText = ""
    stmt.assignValueRhsText = ""
    stmt.assignValueRhsConst = 0
    stmt.assignValueRhsHasConst = false
    stmt.callQualifier = ""
    stmt.callCallee = ""
    stmt.callTarget = ""
    stmt.callTargetSourcePath = ""
    stmt.callTargetImportc = false
    stmt.callArgCount = 0
    stmt.callArgsText = ""
    stmt.callArgTypesText = ""
    stmt.callArgNodeStart = -1
    stmt.callArgNodeCount = 0
    stmt.loweringMode = TypedExprLowerDeferred
    stmt.returnKind = TypedExprReturnDeferred
    stmt.returnRoot = false
    TypedExprIrPopulateConditionMeta(stmt, ir, ctx, sourceContexts, expr.lineNumber)
    add(ir.statements, stmt)
    return stmt.statementIndex

fn TypedExprIrAddAssignStatementFromExpr(ir: var TypedExprIr,
                                          ctx: var TypedExprSourceContext,
                                          sourceContexts: var TypedExprSourceContext[],
                                          scope: TypedExprFunctionScope,
                                          expr: parser.NormalizedExpr,
                                          lineIndent: int32,
                                          enclosingIfLineNumber: int32,
                                          enclosingIfConditionText: str): int32 =
    let lhsText = chengpath.PathTrim(expr.surfaceText)
    let rhsText = chengpath.PathTrim(expr.callArgsText)
    if lhsText == "" || rhsText == "":
        return -1
    var stmt: TypedExprIrStatement
    stmt.sourcePath = expr.sourcePath
    stmt.functionName = scope.name
    stmt.statementIndex = ir.statements.len
    stmt.lineNumber = expr.lineNumber
    stmt.columnNumber = expr.columnNumber
    stmt.lineIndent = lineIndent
    stmt.enclosingIfLineNumber = enclosingIfLineNumber
    stmt.enclosingIfConditionText = enclosingIfConditionText
    stmt.exprId = expr.exprId
    stmt.kind = TypedExprIrStmtAssign
    stmt.callKind = TypedExprCallNone
    stmt.detailKind = expr.detailKind
    stmt.surfaceText = rhsText
    stmt.bindingName = lhsText
    stmt.conditionKind = TypedExprIrCondNone
    stmt.conditionLhsText = ""
    stmt.conditionRhsText = ""
    stmt.conditionLiteralText = ""
    stmt.resultType = TypedExprIrPopulateAssignLhsMeta(stmt,
                                                       ctx,
                                                       sourceContexts,
                                                       scope,
                                                       expr.lineNumber,
                                                       lhsText)
    TypedExprIrPopulateAssignValueMeta(stmt,
                                       ctx,
                                       sourceContexts,
                                       scope,
                                       expr.lineNumber,
                                       rhsText)
    if stmt.resultType == "":
        stmt.resultType = "unknown"
    stmt.callQualifier = ""
    stmt.callCallee = ""
    stmt.callTarget = ""
    stmt.callTargetSourcePath = ""
    stmt.callTargetImportc = false
    stmt.callArgCount = 0
    stmt.callArgsText = ""
    stmt.callArgTypesText = ""
    stmt.callArgNodeStart = -1
    stmt.callArgNodeCount = 0
    TypedExprIrPopulateAssignCallMeta(stmt,
                                      ctx,
                                      sourceContexts,
                                      scope,
                                      expr.lineNumber,
                                      rhsText)
    stmt.loweringMode = TypedExprLowerLocalAddress
    stmt.returnKind = TypedExprReturnDeferred
    stmt.returnRoot = false
    add(ir.statements, stmt)
    return stmt.statementIndex

fn TypedExprIrAddCallStatementFromExpr(ir: var TypedExprIr,
                                        ctx: var TypedExprSourceContext,
                                        sourceContexts: var TypedExprSourceContext[],
                                        scope: TypedExprFunctionScope,
                                        expr: parser.NormalizedExpr,
                                        kind: TypedExprIrStatementKind,
                                        bindingName: str,
                                        resultTypeRaw: str,
                                        lineIndent: int32,
                                        enclosingIfLineNumber: int32,
                                        enclosingIfConditionText: str,
                                        returnRoot: bool): int32 =
    var stmt: TypedExprIrStatement
    stmt.sourcePath = expr.sourcePath
    stmt.functionName = scope.name
    stmt.statementIndex = ir.statements.len
    stmt.lineNumber = expr.lineNumber
    stmt.columnNumber = expr.columnNumber
    stmt.lineIndent = lineIndent
    stmt.enclosingIfLineNumber = enclosingIfLineNumber
    stmt.enclosingIfConditionText = enclosingIfConditionText
    stmt.exprId = expr.exprId
    stmt.kind = kind
    stmt.callKind = TypedExprCallKindForExpr(expr)
    stmt.detailKind = expr.detailKind
    stmt.surfaceText = expr.surfaceText
    if expr.kind == parser.NormalizedExprCall:
        stmt.surfaceText = TypedExprQualifiedCallSurface(expr.callQualifier, expr.callCallee)
    stmt.bindingName = bindingName
    stmt.resultType = resultTypeRaw
    if stmt.resultType == "":
        stmt.resultType = "unknown"
    stmt.conditionKind = TypedExprIrCondNone
    stmt.conditionLhsText = ""
    stmt.conditionRhsText = ""
    stmt.conditionLiteralText = ""
    stmt.assignRootName = ""
    stmt.assignRootType = ""
    stmt.assignRootSourcePath = ""
    stmt.assignRootGlobalFlag = false
    stmt.assignPlaceKind = TypedExprPlaceTemporary
    stmt.assignFieldName = ""
    stmt.assignFieldType = ""
    stmt.assignFieldOffsetBytes = 0
    stmt.assignFieldSizeBytes = 0
    stmt.assignFieldAlignBytes = 0
    stmt.assignValueRootName = ""
    stmt.assignValueRootType = ""
    stmt.assignValueFieldName = ""
    stmt.assignValueFieldType = ""
    stmt.assignValueFieldOffsetBytes = 0
    stmt.assignValueFieldSizeBytes = 0
    stmt.assignValueFieldAlignBytes = 0
    stmt.assignValueOpKind = TypedExprIrOpUnsupported
    stmt.assignValueLhsText = ""
    stmt.assignValueRhsText = ""
    stmt.assignValueRhsConst = 0
    stmt.assignValueRhsHasConst = false
    stmt.callQualifier = expr.callQualifier
    stmt.callCallee = expr.callCallee
    stmt.callTarget = expr.callTarget
    stmt.callTargetSourcePath = expr.callTargetSourcePath
    stmt.callTargetImportc = expr.callTargetImportc
    var resolvedCallReturnType = ""
    var localImportcReturnType = ""
    if expr.kind == parser.NormalizedExprCall &&
       expr.callQualifier == "":
        localImportcReturnType = TypedExprLookupLocalImportcReturnTypeForCall(ctx,
                                                                              expr.callCallee,
                                                                              expr.callTarget)
        if localImportcReturnType == "":
            var importcSourcePath = expr.callTargetSourcePath
            if importcSourcePath == "":
                importcSourcePath = ctx.sourcePath
            localImportcReturnType = TypedExprIrLookupImportcReturnType(ir,
                                                                        importcSourcePath,
                                                                        expr.callTarget)
        if localImportcReturnType != "" && !stmt.callTargetImportc:
            if stmt.callTargetSourcePath == "" ||
               parser.ParserNormalizePath(stmt.callTargetSourcePath) == parser.ParserNormalizePath(ctx.sourcePath):
                resolvedCallReturnType = localImportcReturnType
                if expr.callCallee != "":
                    stmt.callTarget = expr.callCallee
                stmt.callTargetSourcePath = ctx.sourcePath
                stmt.callTargetImportc = true
    if expr.kind == parser.NormalizedExprCall &&
       (stmt.callTargetSourcePath == "" ||
        (expr.callQualifier != "" &&
         TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind) != TypedExprSurfaceCallMember)):
        var resolvedSourcePath = ""
        var resolvedTargetName = ""
        var resolvedImportc = false
        resolvedCallReturnType = TypedExprResolveQualifiedCallTargetReturnType(ctx,
                                                                               sourceContexts,
                                                                               expr.callQualifier,
                                                                               expr.callCallee,
                                                                               expr.callTarget,
                                                                               resolvedSourcePath,
                                                                               resolvedTargetName,
                                                                               resolvedImportc)
        if resolvedCallReturnType != "":
            stmt.callTarget = resolvedTargetName
            stmt.callTargetSourcePath = resolvedSourcePath
            stmt.callTargetImportc = resolvedImportc
        else:
            if expr.callQualifier != "" &&
               TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind) != TypedExprSurfaceCallMember:
                stmt.callTarget = ""
                stmt.callTargetSourcePath = ""
                stmt.callTargetImportc = false
            elif localImportcReturnType != "":
                resolvedCallReturnType = localImportcReturnType
                if expr.callCallee != "":
                    stmt.callTarget = expr.callCallee
                stmt.callTargetSourcePath = ctx.sourcePath
                stmt.callTargetImportc = true
    stmt.callArgCount = expr.callArgCount
    stmt.callArgsText = expr.callArgsText
    stmt.callArgTypesText = TypedExprIrCallArgTypesText(ctx,
                                                        sourceContexts,
                                                        scope,
                                                        expr.lineNumber,
                                                        expr.callArgsText)
    stmt.callArgNodeStart = -1
    stmt.callArgNodeCount = 0
    if expr.callArgCount == 1 && TypedExprTextIsI32Zero(expr.callArgsText):
        let nodeIndex = TypedExprIrAddI32ConstNode(ir,
                                                   stmt.sourcePath,
                                                   stmt.functionName,
                                                   stmt.lineNumber,
                                                   "0")
        stmt.callArgNodeStart = nodeIndex
        stmt.callArgNodeCount = 1
    if expr.kind == parser.NormalizedExprCall:
        var callReturnType = resolvedCallReturnType
        if callReturnType == "":
            callReturnType = TypedExprLookupCallTargetReturnTypeFromExpr(ctx, sourceContexts, expr)
        if callReturnType != "":
            stmt.resultType = callReturnType
    stmt.loweringMode = TypedExprLowerDeferred
    stmt.returnKind = TypedExprReturnDeferred
    stmt.returnRoot = returnRoot
    add(ir.statements, stmt)
    return stmt.statementIndex

fn TypedExprIrAppendStatementsForScopeFromExprLayer(ir: var TypedExprIr,
                                                     ctx: var TypedExprSourceContext,
                                                     sourceContexts: var TypedExprSourceContext[],
                                                     scope: TypedExprFunctionScope,
                                                     exprLayer: var parser.NormalizedExprLayer,
                                                     startIndex: int32,
                                                     endIndexRaw: int32) =
    var cursor = startIndex
    if cursor < 0:
        cursor = 0
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > exprLayer.exprs.len:
        endIndex = exprLayer.exprs.len
    if cursor >= endIndex:
        return
    var currentLineNumber: int32 = -1
    var currentLineHasIf = false
    var currentLineBindingName = ""
    var currentLineBindingType = ""
    var currentLineBindingRootColumn: int32 = -1
    var currentLineBindingRhsStartColumn: int32 = -1
    var currentLineReturnRootColumn: int32 = -1
    var currentLineReturnExprStartColumn: int32 = -1
    var currentLineIndent: int32
    var currentLineEnclosingIfLineNumber: int32
    var currentLineEnclosingIfConditionText = ""
    for i in cursor..<endIndex:
        let expr = exprLayer.exprs[i]
        if expr.lineNumber <= scope.startLine || expr.lineNumber > scope.endLine:
            if expr.lineNumber > scope.endLine:
                break
            continue
        if expr.lineNumber != currentLineNumber:
            currentLineNumber = expr.lineNumber
            currentLineHasIf = false
            currentLineBindingName = ""
            currentLineBindingType = ""
            currentLineBindingRootColumn = -1
            currentLineBindingRhsStartColumn = -1
            currentLineReturnRootColumn = -1
            currentLineReturnExprStartColumn = -1
            let lineRaw = TypedExprSourceLine(ctx, currentLineNumber)
            currentLineIndent = TypedExprLineIndentWidth(lineRaw)
            TypedExprNearestEnclosingIf(ctx,
                                        scope,
                                        currentLineNumber,
                                        currentLineIndent,
                                        currentLineEnclosingIfLineNumber,
                                        currentLineEnclosingIfConditionText)
            let trimmedLine = chengpath.PathTrim(lineRaw)
            var isBindingLine = false
            if parser.ParserStartsWith(trimmedLine, "let "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "var "):
                isBindingLine = true
            elif parser.ParserStartsWith(trimmedLine, "const "):
                isBindingLine = true
            if isBindingLine:
                currentLineBindingName = TypedExprLetCallBindingNameFromBody(trimmedLine)
                var bindingName = ""
                var bindingType = ""
                var bindingRhsColumn: int32 = -1
                if TypedExprParseBindingLine(lineRaw, bindingName, bindingType, bindingRhsColumn):
                    currentLineBindingName = bindingName
                    currentLineBindingType = bindingType
                let eqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if eqPos >= 0:
                    var rhsStartColumn = eqPos + 2
                    for column in rhsStartColumn..lineRaw.len:
                        if parser.ParserIsInlineSpace(lineRaw[column - 1]):
                            rhsStartColumn = column + 1
                        else:
                            rhsStartColumn = column
                            break
                    currentLineBindingRhsStartColumn = rhsStartColumn
            let firstToken = parser.ParserFirstToken(chengpath.PathTrim(lineRaw))
            if firstToken == "return":
                let returnPos = parser.ParserFindText(lineRaw, "return")
                currentLineReturnExprStartColumn = returnPos + 7
            elif scope.startLine == currentLineNumber:
                let inlineEqPos = TypedExprFindTopLevelTextToken(lineRaw, "=")
                if inlineEqPos >= 0:
                    currentLineReturnExprStartColumn = inlineEqPos + 2
                else:
                    currentLineReturnExprStartColumn = -1
            for j in i..<endIndex:
                let lineExpr = exprLayer.exprs[j]
                if lineExpr.lineNumber != currentLineNumber:
                    if lineExpr.lineNumber > currentLineNumber:
                        break
                    continue
                if lineExpr.kind == parser.NormalizedExprIf:
                    currentLineHasIf = true
                    break
                if currentLineBindingRhsStartColumn > 0 &&
                   (lineExpr.kind == parser.NormalizedExprCall ||
                    lineExpr.kind == parser.NormalizedExprResultIntrinsic) &&
                   lineExpr.columnNumber >= currentLineBindingRhsStartColumn:
                    if currentLineBindingRootColumn < 0 ||
                       lineExpr.columnNumber < currentLineBindingRootColumn:
                        currentLineBindingRootColumn = lineExpr.columnNumber
                if currentLineReturnExprStartColumn > 0 &&
                   (lineExpr.kind == parser.NormalizedExprCall ||
                    lineExpr.kind == parser.NormalizedExprResultIntrinsic) &&
                   lineExpr.columnNumber >= currentLineReturnExprStartColumn:
                    if currentLineReturnRootColumn < 0 ||
                       lineExpr.columnNumber < currentLineReturnRootColumn:
                        currentLineReturnRootColumn = lineExpr.columnNumber
        let isResultIntrinsic = expr.kind == parser.NormalizedExprResultIntrinsic
        let isNormalCall = expr.kind == parser.NormalizedExprCall
        if expr.kind == parser.NormalizedExprReturn:
            let _ = TypedExprIrAddCallStatementFromExpr(ir,
                                                        ctx,
                                                        sourceContexts,
                                                        scope,
                                                        expr,
                                                        TypedExprIrStmtReturn,
                                                        "",
                                                        scope.returnType,
                                                        currentLineIndent,
                                                        currentLineEnclosingIfLineNumber,
                                                        currentLineEnclosingIfConditionText,
                                                        true)
            continue
        if expr.kind == parser.NormalizedExprAssign:
            let _ = TypedExprIrAddAssignStatementFromExpr(ir,
                                                          ctx,
                                                          sourceContexts,
                                                          scope,
                                                          expr,
                                                          currentLineIndent,
                                                          currentLineEnclosingIfLineNumber,
                                                          currentLineEnclosingIfConditionText)
            continue
        if expr.kind == parser.NormalizedExprIfStmt ||
           expr.kind == parser.NormalizedExprElifStmt ||
           expr.kind == parser.NormalizedExprElseStmt ||
           expr.kind == parser.NormalizedExprForStmt:
            let _ = TypedExprIrAddControlStatementFromExpr(ir,
                                                           ctx,
                                                           sourceContexts,
                                                           scope,
                                                           expr,
                                                           currentLineIndent,
                                                           currentLineEnclosingIfLineNumber,
                                                           currentLineEnclosingIfConditionText)
            continue
        if !isNormalCall && !isResultIntrinsic:
            continue
        if isNormalCall && TypedExprExprIsBuiltinStringifyCall(expr):
            continue
        if isNormalCall && (!expr.callResolved || expr.callTarget == ""):
            continue
        var sink: TypedExprSinkInfo
        sink.sinkType = ""
        sink.sinkPlaceKind = TypedExprPlaceTemporary
        sink.hasSink = false
        sink.returnRoot = false
        sink.functionReturnType = scope.returnType
        if currentLineBindingRootColumn == expr.columnNumber:
            sink.sinkType = currentLineBindingType
            sink.sinkPlaceKind = TypedExprPlaceLocal
            sink.hasSink = true
        if currentLineReturnRootColumn == expr.columnNumber && scope.returnType != "":
            sink.sinkType = scope.returnType
            sink.sinkPlaceKind = TypedExprPlaceTemporary
            sink.hasSink = true
            sink.returnRoot = true
        var statementKind = TypedExprIrStmtCall
        if isResultIntrinsic:
            statementKind = TypedExprIrStmtResultIntrinsic
        else:
            if sink.hasSink &&
               (sink.sinkPlaceKind == TypedExprPlaceLocal ||
                sink.sinkPlaceKind == TypedExprPlaceGlobal):
                statementKind = TypedExprIrStmtLetCall
            elif currentLineBindingRootColumn == expr.columnNumber:
                statementKind = TypedExprIrStmtLetCall
            elif currentLineHasIf:
                statementKind = TypedExprIrStmtIfCall
        var statementBindingName = ""
        if statementKind == TypedExprIrStmtLetCall ||
           (statementKind == TypedExprIrStmtResultIntrinsic &&
            (sink.hasSink || currentLineBindingRootColumn == expr.columnNumber)):
            statementBindingName = currentLineBindingName
        var statementResultType = "unknown"
        if isResultIntrinsic:
            statementResultType = TypedExprResultIntrinsicTypeFromExpr(ctx, expr, sink)
        elif isNormalCall:
            statementResultType = TypedExprLookupCallTargetReturnTypeFromExpr(ctx, sourceContexts, expr)
        if (statementKind == TypedExprIrStmtLetCall ||
            statementKind == TypedExprIrStmtResultIntrinsic) &&
           Len(currentLineBindingType) > 0:
            statementResultType = currentLineBindingType
        let _ = TypedExprIrAddCallStatementFromExpr(ir,
                                                    ctx,
                                                    sourceContexts,
                                                    scope,
                                                    expr,
                                                    statementKind,
                                                    statementBindingName,
                                                    statementResultType,
                                                    currentLineIndent,
                                                    currentLineEnclosingIfLineNumber,
                                                    currentLineEnclosingIfConditionText,
                                                    sink.returnRoot)

fn TypedExprIrFirstBindingCallFactIndex(facts: var TypedExprFact[],
                                         lineNumber: int32,
                                         startIndex: int32,
                                         endIndexRaw: int32): int32 =
    if lineNumber <= 0:
        return -1
    var cursor = startIndex
    if cursor < 0:
        cursor = 0
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > facts.len:
        endIndex = facts.len
    if cursor >= endIndex:
        return -1
    for i in cursor..<endIndex:
        if facts[i].lineNumber != lineNumber:
            if facts[i].lineNumber > lineNumber:
                break
            continue
        if facts[i].kind != parser.NormalizedExprCall:
            continue
        if facts[i].callKind == TypedExprCallBuiltin:
            continue
        if !facts[i].callResolved || facts[i].callTarget == "":
            continue
        if !facts[i].hasSink:
            continue
        if facts[i].sinkPlaceKind != TypedExprPlaceLocal &&
           facts[i].sinkPlaceKind != TypedExprPlaceGlobal:
            continue
        return i
    return -1

fn TypedExprBuildIrForScope(ctx: var TypedExprSourceContext,
                             scope: TypedExprFunctionScope,
                             facts: var TypedExprFact[],
                             factStartIndex: int32,
                             factEndIndex: int32,
                             ir: var TypedExprIr) =
    let nodeStart = ir.nodes.len
    let statementStart = ir.statements.len
    var fnIr: TypedExprIrFunction
    fnIr.sourcePath = ctx.sourcePath
    fnIr.functionName = scope.name
    fnIr.signatureLineNumber = scope.startLine
    fnIr.endLineNumber = scope.endLine
    fnIr.returnType = scope.returnType
    fnIr.nodeStart = nodeStart
    fnIr.statementStart = statementStart
    fnIr.returnNodeIndex = -1
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        add(ir.functions, fnIr)
        return
    var bodyLineNumber: int32
    let bodyText = TypedExprFunctionBodyLine(ctx, scope, bodyLineNumber)
    var returnExpr = TypedExprReturnExprFromBody(bodyText)
    var returnLineNumber = bodyLineNumber
    let bodyTrim = chengpath.PathTrim(bodyText)
    if !parser.ParserStartsWith(bodyTrim, "return ") &&
       !parser.ParserStartsWith(bodyTrim, "if "):
        let topLevelReturnExpr = TypedExprFunctionTopLevelReturnExpr(ctx,
                                                                    scope,
                                                                    returnLineNumber)
        if topLevelReturnExpr != "":
            returnExpr = topLevelReturnExpr
        else:
            let singleExpr = TypedExprFunctionSingleExpressionBodyExpr(ctx,
                                                                       scope,
                                                                       returnLineNumber)
            returnExpr = singleExpr
    let params = TypedExprFunctionParams(TypedExprFunctionDeclHeaderText(ctx.lines, scope.startLine))
    var paramNodeIndices: int32[]
    TypedExprIrAddParamNodes(ir,
                             ctx.sourcePath,
                             scope.name,
                             scope.startLine,
                             params,
                             paramNodeIndices)
    var emptySourceContexts: TypedExprSourceContext[]
    TypedExprIrAppendLocalDeclStatementsForScope(ir, ctx, emptySourceContexts, scope)
    TypedExprIrAppendStatementsForScope(ir, ctx, scope, facts, factStartIndex, factEndIndex)
    let firstBindingCallFactIndex: int32 = TypedExprIrFirstBindingCallFactIndex(facts,
                                                                                bodyLineNumber,
                                                                                factStartIndex,
                                                                                factEndIndex)
    if firstBindingCallFactIndex >= 0:
        let _ = TypedExprIrAddLetCallNode(ir,
                                          ctx.sourcePath,
                                          scope.name,
                                          bodyLineNumber,
                                          facts[firstBindingCallFactIndex].exprId)
        var letCallReturnLineNumber: int32
        var letCallReturnExpr = ""
        if TypedExprFunctionBodyIsI32LetCallThenReturnConst(ctx,
                                                            scope,
                                                            letCallReturnLineNumber,
                                                            letCallReturnExpr):
            returnLineNumber = letCallReturnLineNumber
            returnExpr = letCallReturnExpr
    let returnNodeIndex = TypedExprIrBuildReturnNode(ir,
                                                     ctx,
                                                     scope,
                                                     returnLineNumber,
                                                     returnExpr,
                                                     params,
                                                     paramNodeIndices)
    fnIr.bodyLineNumber = bodyLineNumber
    fnIr.returnExpr = returnExpr
    fnIr.returnNodeIndex = returnNodeIndex
    fnIr.statementCount = ir.statements.len - statementStart
    fnIr.nodeCount = ir.nodes.len - nodeStart
    add(ir.functions, fnIr)

fn TypedExprBuildIrForScopeWithFactsAndExprLayer(ctx: var TypedExprSourceContext,
                                                  sourceContexts: var TypedExprSourceContext[],
                                                  scope: TypedExprFunctionScope,
                                                  facts: var TypedExprFact[],
                                                  factStartIndex: int32,
                                                  factEndIndex: int32,
                                                  exprLayer: var parser.NormalizedExprLayer,
                                                  exprStartIndex: int32,
                                                  exprEndIndex: int32,
                                                  ir: var TypedExprIr) =
    let nodeStart = ir.nodes.len
    let statementStart = ir.statements.len
    var fnIr: TypedExprIrFunction
    fnIr.sourcePath = ctx.sourcePath
    fnIr.functionName = scope.name
    fnIr.signatureLineNumber = scope.startLine
    fnIr.endLineNumber = scope.endLine
    fnIr.returnType = scope.returnType
    fnIr.nodeStart = nodeStart
    fnIr.statementStart = statementStart
    fnIr.returnNodeIndex = -1
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        add(ir.functions, fnIr)
        return
    var bodyLineNumber: int32
    let bodyText = TypedExprFunctionBodyLine(ctx, scope, bodyLineNumber)
    var returnExpr = TypedExprReturnExprFromBody(bodyText)
    var returnLineNumber = bodyLineNumber
    let bodyTrim = chengpath.PathTrim(bodyText)
    if !parser.ParserStartsWith(bodyTrim, "return ") &&
       !parser.ParserStartsWith(bodyTrim, "if "):
        let topLevelReturnExpr = TypedExprFunctionTopLevelReturnExpr(ctx,
                                                                    scope,
                                                                    returnLineNumber)
        if topLevelReturnExpr != "":
            returnExpr = topLevelReturnExpr
        else:
            let singleExpr = TypedExprFunctionSingleExpressionBodyExpr(ctx,
                                                                       scope,
                                                                       returnLineNumber)
            returnExpr = singleExpr
    let params = TypedExprFunctionParams(TypedExprFunctionDeclHeaderText(ctx.lines, scope.startLine))
    var paramNodeIndices: int32[]
    TypedExprIrAddParamNodes(ir,
                             ctx.sourcePath,
                             scope.name,
                             scope.startLine,
                             params,
                             paramNodeIndices)
    TypedExprIrAppendLocalDeclStatementsForScope(ir, ctx, sourceContexts, scope)
    let includeStructuredStatements = TypedExprScopeNeedsStructuredStatements(ctx,
                                                                             scope,
                                                                             params,
                                                                             returnExpr,
                                                                             facts,
                                                                             factStartIndex,
                                                                             factEndIndex,
                                                                             exprLayer,
                                                                             exprStartIndex,
                                                                             exprEndIndex)
    TypedExprIrAppendStatementsForScopeWithFactsAndExprLayer(ir,
                                                             ctx,
                                                             sourceContexts,
                                                             scope,
                                                             facts,
                                                             factStartIndex,
                                                             factEndIndex,
                                                             exprLayer,
                                                             exprStartIndex,
                                                             exprEndIndex,
                                                             includeStructuredStatements)
    let firstBindingCallFactIndex: int32 = TypedExprIrFirstBindingCallFactIndex(facts,
                                                                                bodyLineNumber,
                                                                                factStartIndex,
                                                                                factEndIndex)
    if firstBindingCallFactIndex >= 0:
        let _ = TypedExprIrAddLetCallNode(ir,
                                          ctx.sourcePath,
                                          scope.name,
                                          bodyLineNumber,
                                          facts[firstBindingCallFactIndex].exprId)
        var letCallReturnLineNumber: int32
        var letCallReturnExpr = ""
        if TypedExprFunctionBodyIsI32LetCallThenReturnConst(ctx,
                                                            scope,
                                                            letCallReturnLineNumber,
                                                            letCallReturnExpr):
            returnLineNumber = letCallReturnLineNumber
            returnExpr = letCallReturnExpr
    let returnNodeIndex = TypedExprIrBuildReturnNode(ir,
                                                     ctx,
                                                     scope,
                                                     returnLineNumber,
                                                     returnExpr,
                                                     params,
                                                     paramNodeIndices)
    fnIr.bodyLineNumber = bodyLineNumber
    fnIr.returnExpr = returnExpr
    fnIr.returnNodeIndex = returnNodeIndex
    fnIr.statementCount = ir.statements.len - statementStart
    fnIr.nodeCount = ir.nodes.len - nodeStart
    add(ir.functions, fnIr)

fn TypedExprBuildIrForScopeFromExprLayer(ctx: var TypedExprSourceContext,
                                          sourceContexts: var TypedExprSourceContext[],
                                          scope: TypedExprFunctionScope,
                                          exprLayer: var parser.NormalizedExprLayer,
                                          exprStartIndex: int32,
                                          exprEndIndex: int32,
                                          ir: var TypedExprIr) =
    let nodeStart = ir.nodes.len
    let statementStart = ir.statements.len
    var fnIr: TypedExprIrFunction
    fnIr.sourcePath = ctx.sourcePath
    fnIr.functionName = scope.name
    fnIr.signatureLineNumber = scope.startLine
    fnIr.endLineNumber = scope.endLine
    fnIr.returnType = scope.returnType
    fnIr.nodeStart = nodeStart
    fnIr.statementStart = statementStart
    fnIr.returnNodeIndex = -1
    if scope.startLine <= 0 || scope.startLine > ctx.lines.len:
        add(ir.functions, fnIr)
        return
    var bodyLineNumber: int32
    let bodyText = TypedExprFunctionBodyLine(ctx, scope, bodyLineNumber)
    var returnExpr = TypedExprReturnExprFromBody(bodyText)
    var returnLineNumber = bodyLineNumber
    let bodyTrim = chengpath.PathTrim(bodyText)
    if !parser.ParserStartsWith(bodyTrim, "return ") &&
       !parser.ParserStartsWith(bodyTrim, "if "):
        let topLevelReturnExpr = TypedExprFunctionTopLevelReturnExpr(ctx,
                                                                    scope,
                                                                    returnLineNumber)
        if topLevelReturnExpr != "":
            returnExpr = topLevelReturnExpr
        else:
            let singleExpr = TypedExprFunctionSingleExpressionBodyExpr(ctx,
                                                                       scope,
                                                                       returnLineNumber)
            returnExpr = singleExpr
    let params = TypedExprFunctionParams(TypedExprFunctionDeclHeaderText(ctx.lines, scope.startLine))
    var paramNodeIndices: int32[]
    TypedExprIrAddParamNodes(ir,
                             ctx.sourcePath,
                             scope.name,
                             scope.startLine,
                             params,
                             paramNodeIndices)
    TypedExprIrAppendLocalDeclStatementsForScope(ir, ctx, sourceContexts, scope)
    TypedExprIrAppendStatementsForScopeFromExprLayer(ir,
                                                     ctx,
                                                     sourceContexts,
                                                     scope,
                                                     exprLayer,
                                                     exprStartIndex,
                                                     exprEndIndex)
    let returnNodeIndex = TypedExprIrBuildReturnNode(ir,
                                                     ctx,
                                                     scope,
                                                     returnLineNumber,
                                                     returnExpr,
                                                     params,
                                                     paramNodeIndices)
    fnIr.bodyLineNumber = bodyLineNumber
    fnIr.returnExpr = returnExpr
    fnIr.returnNodeIndex = returnNodeIndex
    fnIr.statementCount = ir.statements.len - statementStart
    fnIr.nodeCount = ir.nodes.len - nodeStart
    add(ir.functions, fnIr)

fn TypedExprExprLayerEndIndexForSource(exprLayer: var parser.NormalizedExprLayer,
                                        sourcePathRaw: str,
                                        startIndex: int32): int32 =
    if startIndex < 0:
        return 0
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in startIndex..<exprLayer.exprs.len:
        if parser.ParserNormalizePath(exprLayer.exprs[i].sourcePath) != sourcePath:
            return i
    return exprLayer.exprs.len

fn TypedExprSourceRangeIndexBuildFromExprLayer(exprLayer: var parser.NormalizedExprLayer): TypedExprSourceRangeIndex =
    var index: TypedExprSourceRangeIndex
    index.sourcePaths = []
    index.starts = []
    index.ends = []
    var cursor: int32
    while cursor < exprLayer.exprs.len:
        let sourcePath = parser.ParserNormalizePath(exprLayer.exprs[cursor].sourcePath)
        var endIndex = cursor + 1
        while endIndex < exprLayer.exprs.len:
            if parser.ParserNormalizePath(exprLayer.exprs[endIndex].sourcePath) != sourcePath:
                break
            endIndex = endIndex + 1
        TypedExprSourceRangeIndexAdd(index, sourcePath, cursor, endIndex)
        cursor = endIndex
    return index

fn TypedExprReadNormalizedExprLayerForSourceTexts(sourceTexts: var TypedExprSourceText[],
                                                   exprLayer: var parser.NormalizedExprLayer,
                                                   err: var str): bool =
    exprLayer = parser.NormalizedExprLayer()
    for i in 0..<sourceTexts.len:
        os.ProcessResourceGuardCheck()
        var sourceText = sourceTexts[i].text
        if sourceText == "" && sourceTexts[i].sourcePath != "":
            sourceText = chengpath.ReadTextFile("", sourceTexts[i].sourcePath)
        var sourceExprLayer: parser.NormalizedExprLayer
        if !parser.ParserReadNormalizedExprLayerFromText(sourceTexts[i].sourcePath,
                                                         sourceText,
                                                         sourceExprLayer,
                                                         err):
            return false
        parser.NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
    err = ""
    return true

fn TypedExprBuildIrWithFactsAndExprLayer(sourceTexts: var TypedExprSourceText[],
                                          facts: var TypedExprFact[],
                                          exprLayer: var parser.NormalizedExprLayer,
                                          ir: var TypedExprIr,
                                          err: var str): bool =
    ir = TypedExprIr()
    var contexts: TypedExprSourceContext[]
    if facts.len > 0:
        for i in 0..<sourceTexts.len:
            os.ProcessResourceGuardCheck()
            var sourceForContext = sourceTexts[i]
            if sourceForContext.text == "" && sourceForContext.sourcePath != "":
                sourceForContext.text = chengpath.ReadTextFile("", sourceForContext.sourcePath)
            var context: TypedExprSourceContext
            if !TypedExprBuildSourceContext(sourceForContext, context, err):
                err = " typed expr: build typed ir source context failed"
                return false
            sourceTexts[i].text = ""
            add(contexts, context)
    var factSourceRanges: TypedExprSourceRangeIndex
    var exprSourceRanges: TypedExprSourceRangeIndex
    if facts.len > 0:
        factSourceRanges = TypedExprSourceRangeIndexBuildFromFacts(facts)
        exprSourceRanges = TypedExprSourceRangeIndexBuildFromExprLayer(exprLayer)
        TypedExprBuildSourceContextIndex(ir, contexts)
    for i in 0..<sourceTexts.len:
        os.ProcessResourceGuardCheck()
        var ctx: TypedExprSourceContext
        if facts.len > 0 && i < contexts.len:
            ctx = contexts[i]
        else:
            var sourceForIr = sourceTexts[i]
            if sourceForIr.text == "" && sourceForIr.sourcePath != "":
                sourceForIr.text = chengpath.ReadTextFile("", sourceForIr.sourcePath)
            if !TypedExprBuildSourceContext(sourceForIr, ctx, err):
                err = " typed expr: build typed ir source context failed"
                return false
        TypedExprIrAppendImportcFunctionsFromContext(ir, ctx)
        TypedExprIrAppendEnumValuesFromContext(ir, ctx)
        if contexts.len > 0:
            TypedExprIrAppendTypeLayoutsFromContext(ir, ctx, contexts)
        let sourceFactRange = TypedExprSourceRangeIndexFind(factSourceRanges, ctx.sourcePath)
        var sourceFactStart: int32
        var sourceFactEnd: int32
        var factCursor: int32
        if sourceFactRange >= 0:
            sourceFactStart = factSourceRanges.starts[sourceFactRange]
            sourceFactEnd = factSourceRanges.ends[sourceFactRange]
            factCursor = sourceFactStart
            TypedExprAppendInferredCallBindings(ctx,
                                                contexts,
                                                facts,
                                                sourceFactStart,
                                                sourceFactEnd)
        else:
            sourceFactEnd = 0
            factCursor = 0
        for bindingIndex in 0..<ctx.bindings.len:
            let binding = ctx.bindings[bindingIndex]
            if !binding.globalFlag:
                continue
            var seenGlobal = false
            for globalIndex in 0..<ir.globalNames.len:
                if globalIndex >= ir.globalSourcePaths.len:
                    continue
                if ir.globalSourcePaths[globalIndex] == binding.sourcePath &&
                   ir.globalNames[globalIndex] == binding.name:
                    seenGlobal = true
                    break
            if seenGlobal:
                continue
            add(ir.globalSourcePaths, binding.sourcePath)
            add(ir.globalNames, binding.name)
            add(ir.globalTypes, binding.typeText)
        let sourceExprRange = TypedExprSourceRangeIndexFind(exprSourceRanges, ctx.sourcePath)
        var sourceExprStart: int32
        var sourceExprEnd: int32
        var exprCursor: int32
        if facts.len > 0 && sourceExprRange >= 0:
            sourceExprStart = exprSourceRanges.starts[sourceExprRange]
            sourceExprEnd = exprSourceRanges.ends[sourceExprRange]
            exprCursor = sourceExprStart
        else:
            sourceExprEnd = 0
            exprCursor = 0
        for j in 0..<ctx.scopes.len:
            if j % 128 == 0:
                os.ProcessResourceGuardCheck()
            if factCursor < sourceFactEnd:
                for factIndex in factCursor..<sourceFactEnd:
                    if facts[factIndex].lineNumber > ctx.scopes[j].startLine:
                        break
                    factCursor = factIndex + 1
            if exprCursor < sourceExprEnd:
                for exprIndex in exprCursor..<sourceExprEnd:
                    if exprLayer.exprs[exprIndex].lineNumber > ctx.scopes[j].startLine:
                        break
                    exprCursor = exprIndex + 1
            if facts.len > 0:
                TypedExprBuildIrForScopeWithFactsAndExprLayer(ctx,
                                                              contexts,
                                                              ctx.scopes[j],
                                                              facts,
                                                              factCursor,
                                                              sourceFactEnd,
                                                              exprLayer,
                                                              exprCursor,
                                                              sourceExprEnd,
                                                              ir)
            else:
                TypedExprBuildIrForScope(ctx, ctx.scopes[j], facts, factCursor, sourceFactEnd, ir)
        if facts.len > 0 && i < contexts.len:
            TypedExprClearSourceContextHeavyFields(contexts[i])
        sourceTexts[i].text = ""
    err = ""
    return true

fn TypedExprBuildIrWithFacts(sourceTexts: var TypedExprSourceText[],
                              facts: var TypedExprFact[],
                              ir: var TypedExprIr,
                              err: var str): bool =
    var exprLayer: parser.NormalizedExprLayer
    if facts.len > 0:
        if !TypedExprReadNormalizedExprLayerForSourceTexts(sourceTexts, exprLayer, err):
            err = Fmt" typed expr: build typed ir normalized expr layer failed: {err}"
            return false
    return TypedExprBuildIrWithFactsAndExprLayer(sourceTexts,
                                                 facts,
                                                 exprLayer,
                                                 ir,
                                                 err)

fn TypedExprBuildIrFromExprLayer(sourceTexts: var TypedExprSourceText[],
                                  exprLayer: var parser.NormalizedExprLayer,
                                  ir: var TypedExprIr,
                                  err: var str): bool =
    ir = TypedExprIr()
    var contexts: TypedExprSourceContext[]
    var exprSourceRanges = TypedExprSourceRangeIndexBuildFromExprLayer(exprLayer)
    for i in 0..<sourceTexts.len:
        os.ProcessResourceGuardCheck()
        var sourceForContext = sourceTexts[i]
        if sourceForContext.text == "" && sourceForContext.sourcePath != "":
            sourceForContext.text = chengpath.ReadTextFile("", sourceForContext.sourcePath)
        var ctx: TypedExprSourceContext
        if !TypedExprBuildSourceContext(sourceForContext, ctx, err):
            err = " typed expr: build typed ir source context failed"
            return false
        sourceTexts[i].text = ""
        add(contexts, ctx)
    for i in 0..<sourceTexts.len:
        os.ProcessResourceGuardCheck()
        var ctxForIr = contexts[i]
        TypedExprIrAppendImportcFunctionsFromContext(ir, ctxForIr)
        TypedExprIrAppendEnumValuesFromContext(ir, ctxForIr)
        TypedExprIrAppendTypeLayoutsFromContext(ir, ctxForIr, contexts)
        for bindingIndex in 0..<ctxForIr.bindings.len:
            let binding = ctxForIr.bindings[bindingIndex]
            if !binding.globalFlag:
                continue
            var seenGlobal = false
            for globalIndex in 0..<ir.globalNames.len:
                if globalIndex >= ir.globalSourcePaths.len:
                    continue
                if ir.globalSourcePaths[globalIndex] == binding.sourcePath &&
                   ir.globalNames[globalIndex] == binding.name:
                    seenGlobal = true
                    break
            if seenGlobal:
                continue
            add(ir.globalSourcePaths, binding.sourcePath)
            add(ir.globalNames, binding.name)
            add(ir.globalTypes, binding.typeText)
        let sourceExprRange = TypedExprSourceRangeIndexFind(exprSourceRanges, ctxForIr.sourcePath)
        var sourceExprStart: int32
        var sourceExprEnd: int32
        var exprCursor: int32
        if sourceExprRange >= 0:
            sourceExprStart = exprSourceRanges.starts[sourceExprRange]
            sourceExprEnd = exprSourceRanges.ends[sourceExprRange]
            exprCursor = sourceExprStart
        else:
            sourceExprEnd = 0
            exprCursor = 0
        let scopeCount = ctxForIr.scopes.len
        for j in 0..<scopeCount:
            if j % 128 == 0:
                os.ProcessResourceGuardCheck()
            let scope = ctxForIr.scopes[j]
            if exprCursor < sourceExprEnd:
                for exprIndex in exprCursor..<sourceExprEnd:
                    if exprLayer.exprs[exprIndex].lineNumber > scope.startLine:
                        break
                    exprCursor = exprIndex + 1
            TypedExprBuildIrForScopeFromExprLayer(ctxForIr,
                                                  contexts,
                                                  scope,
                                                  exprLayer,
                                                  exprCursor,
                                                  sourceExprEnd,
                                                  ir)
        TypedExprClearSourceContextHeavyFields(contexts[i])
        sourceTexts[i].text = ""
        os.ProcessResourceGuardCheck()
    err = ""
    return true

fn TypedExprBuildIr(sourceTexts: var TypedExprSourceText[],
                     ir: var TypedExprIr,
                     err: var str): bool =
    var emptyFacts: TypedExprFact[]
    return TypedExprBuildIrWithFacts(sourceTexts, emptyFacts, ir, err)

fn TypedExprReturnOpFactFromIrFunction(ir: var TypedExprIr,
                                        fnIr: TypedExprIrFunction): TypedExprReturnOpFact =
    var fact: TypedExprReturnOpFact
    fact.sourcePath = fnIr.sourcePath
    fact.functionName = fnIr.functionName
    fact.signatureLineNumber = fnIr.signatureLineNumber
    fact.bodyLineNumber = fnIr.bodyLineNumber
    fact.returnType = fnIr.returnType
    fact.returnExpr = fnIr.returnExpr
    fact.opKind = TypedExprReturnOpUnsupported
    if fnIr.returnNodeIndex < 0 || fnIr.returnNodeIndex >= ir.nodes.len:
        return fact
    let node = ir.nodes[fnIr.returnNodeIndex]
    fact.opKind = TypedExprReturnOpKindFromIrOp(node.opKind)
    if fact.opKind == TypedExprReturnOpUnsupported:
        return fact
    if node.operand0NodeIndex >= 0 && node.operand0NodeIndex < ir.nodes.len:
        let lhsNode = ir.nodes[node.operand0NodeIndex]
        fact.lhsName = lhsNode.paramName
        fact.lhsType = lhsNode.resultType
    if node.operand1NodeIndex >= 0 && node.operand1NodeIndex < ir.nodes.len:
        let rhsNode = ir.nodes[node.operand1NodeIndex]
        fact.rhsName = rhsNode.paramName
        fact.rhsType = rhsNode.resultType
    if node.operand2NodeIndex >= 0 && node.operand2NodeIndex < ir.nodes.len:
        let accNode = ir.nodes[node.operand2NodeIndex]
        fact.accName = accNode.paramName
        fact.accType = accNode.resultType
    return fact

fn TypedExprReturnOpFactsFromIr(ir: var TypedExprIr): TypedExprReturnOpFact[] =
    var facts: TypedExprReturnOpFact[]
    for i in 0..<ir.functions.len:
        let fact = TypedExprReturnOpFactFromIrFunction(ir, ir.functions[i])
        if fact.opKind == TypedExprReturnOpUnsupported:
            continue
        add(facts, fact)
    return facts

fn TypedExprBuildReturnOpFacts(sourceTexts: var TypedExprSourceText[],
                                facts: var TypedExprReturnOpFact[],
                                err: var str): bool =
    var ir: TypedExprIr
    if !TypedExprBuildIr(sourceTexts, ir, err):
        return false
    facts = TypedExprReturnOpFactsFromIr(ir)
    err = ""
    return true

fn TypedExprPopulateSourceExprLineColumns(contexts: var TypedExprSourceContext[],
                                            exprLayer: var parser.NormalizedExprLayer,
                                            err: var str): bool =
    for i in 0..<exprLayer.exprs.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let expr = exprLayer.exprs[i]
        let ctxIndex = TypedExprSourceContextLookup(contexts, expr.sourcePath)
        if ctxIndex < 0:
            err = " typed expr: missing source context"
            return false
        if expr.lineNumber <= 0 || expr.lineNumber > contexts[ctxIndex].exprLineColumns.len:
            err = " typed expr: expr line out of range"
            return false
        let lineIndex = expr.lineNumber - 1
        var lineExprColumns = contexts[ctxIndex].exprLineColumns[lineIndex]
        var shouldAppend = true
        if lineExprColumns.columns.len > 0:
            shouldAppend = lineExprColumns.columns[lineExprColumns.columns.len - 1] != expr.columnNumber
        if shouldAppend:
            add(lineExprColumns.columns, expr.columnNumber)
            contexts[ctxIndex].exprLineColumns[lineIndex] = lineExprColumns
    err = ""
    return true

fn TypedExprPopulateSourceExprLineColumnsForRange(ctx: var TypedExprSourceContext,
                                                   exprLayer: var parser.NormalizedExprLayer,
                                                   startIndex: int32,
                                                   endIndexRaw: int32,
                                                   err: var str): bool =
    var endIndex = endIndexRaw
    if endIndex < 0 || endIndex > exprLayer.exprs.len:
        endIndex = exprLayer.exprs.len
    for i in startIndex..<endIndex:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let expr = exprLayer.exprs[i]
        if expr.lineNumber <= 0 || expr.lineNumber > ctx.exprLineColumns.len:
            err = " typed expr: expr line out of range"
            return false
        let lineIndex = expr.lineNumber - 1
        var lineExprColumns = ctx.exprLineColumns[lineIndex]
        var shouldAppend = true
        if lineExprColumns.columns.len > 0:
            shouldAppend = lineExprColumns.columns[lineExprColumns.columns.len - 1] != expr.columnNumber
        if shouldAppend:
            add(lineExprColumns.columns, expr.columnNumber)
            ctx.exprLineColumns[lineIndex] = lineExprColumns
    err = ""
    return true

fn TypedExprBuildFacts(sourceTexts: var TypedExprSourceText[],
                         exprLayer: var parser.NormalizedExprLayer,
                         facts: var TypedExprFact[],
                         err: var str): bool =
    var emptyFacts: TypedExprFact[]
    facts = emptyFacts
    var contexts: TypedExprSourceContext[]
    for i in 0..<sourceTexts.len:
        os.ProcessResourceGuardCheck()
        var ctx: TypedExprSourceContext
        if !TypedExprBuildSourceContext(sourceTexts[i], ctx, err):
            err = " typed expr: build source context failed"
            return false
        add(contexts, ctx)
    var exprIndex: int32
    while exprIndex < exprLayer.exprs.len:
        if exprIndex % 256 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = exprLayer.exprs[exprIndex].sourcePath
        let ctxIndex = TypedExprSourceContextLookup(contexts, sourcePath)
        if ctxIndex < 0:
            err = " typed expr: missing source context"
            return false
        var exprEnd = TypedExprExprLayerEndIndexForSource(exprLayer, sourcePath, exprIndex)
        if exprEnd <= exprIndex:
            exprEnd = exprIndex + 1
        var ctxForFact = contexts[ctxIndex]
        ctxForFact.exprLineColumns = []
        for lineIndex in 0..<ctxForFact.lines.len:
            var lineExprColumns: TypedExprLineExprColumns
            lineExprColumns.columns = []
            add(ctxForFact.exprLineColumns, lineExprColumns)
        if !TypedExprPopulateSourceExprLineColumnsForRange(ctxForFact,
                                                           exprLayer,
                                                           exprIndex,
                                                           exprEnd,
                                                           err):
            return false
        for factIndex in exprIndex..<exprEnd:
            if factIndex % 256 == 0:
                os.ProcessResourceGuardCheck()
            add(facts, TypedExprBuildFact(ctxForFact, contexts, exprLayer.exprs[factIndex]))
        TypedExprClearSourceContextHeavyFields(ctxForFact)
        sourceTexts[ctxIndex].text = ""
        exprIndex = exprEnd
    var validateErr = ""
    if !TypedExprFactsValidateCallResolution(exprLayer, contexts, facts, validateErr):
        err = validateErr
        return false
    err = ""
    return true

fn TypedExprCheckNoPointerSurface(line: str, lineNumber: int32, sourcePath: str): str =
    let trimmed = chengpath.PathTrim(line)
    if Len(trimmed) <= 0:
        return ""
    var i: int32
    for i in 0..<trimmed.len:
        if trimmed[i] == '*':
            if i + 1 < trimmed.len:
                let next = trimmed[i + 1]
                if (next >= 'a' && next <= 'z') || (next >= 'A' && next <= 'Z') || next == '_':
                    if i <= 0:
                        return Fmt"ZRPC no-pointer violation at {sourcePath}:{lineNumber}: raw pointer type not allowed in Cheng surface. Use @ffi_map, @ffi_out_ptrs, handles, or borrows instead."
                    let prev = trimmed[i - 1]
                    if !((prev >= 'a' && prev <= 'z') || (prev >= 'A' && prev <= 'Z') || (prev >= '0' && prev <= '9') || prev == '_' || prev == ')'):
                        return Fmt"ZRPC no-pointer violation at {sourcePath}:{lineNumber}: raw pointer type not allowed in Cheng surface. Use @ffi_map, @ffi_out_ptrs, handles, or borrows instead."
        if i + 4 < trimmed.len:
            let slice = chengpath.TextSlice(trimmed, i, 4)
            if slice == "void":
                if trimmed[i + 4] == '*':
                    return Fmt"ZRPC no-pointer violation at {sourcePath}:{lineNumber}: raw pointer type not allowed in Cheng surface. Use @ffi_map, @ffi_out_ptrs, handles, or borrows instead."
    var searchStart: int32
    while searchStart < trimmed.len:
        let ptrPos = parser.ParserFindText(chengpath.TextSlice(trimmed, searchStart, trimmed.len - searchStart), "ptr")
        if ptrPos < 0:
            break
        let absPtrPos = searchStart + ptrPos
        let beforeIsAlpha = absPtrPos > 0 &&
            ((trimmed[absPtrPos - 1] >= 'a' && trimmed[absPtrPos - 1] <= 'z') ||
             (trimmed[absPtrPos - 1] >= 'A' && trimmed[absPtrPos - 1] <= 'Z') ||
             (trimmed[absPtrPos - 1] >= '0' && trimmed[absPtrPos - 1] <= '9') ||
             trimmed[absPtrPos - 1] == '_')
        let afterPtrPos = absPtrPos + 3
        let afterIsAlpha = afterPtrPos < trimmed.len &&
            ((trimmed[afterPtrPos] >= 'a' && trimmed[afterPtrPos] <= 'z') ||
             (trimmed[afterPtrPos] >= 'A' && trimmed[afterPtrPos] <= 'Z') ||
             (trimmed[afterPtrPos] >= '0' && trimmed[afterPtrPos] <= '9') ||
             trimmed[afterPtrPos] == '_')
        if !beforeIsAlpha && !afterIsAlpha:
            var searchPos = absPtrPos - 1
            while searchPos >= 0:
                if trimmed[searchPos] == ':':
                    return Fmt"ZRPC no-pointer violation at {sourcePath}:{lineNumber}: raw pointer type not allowed in Cheng surface. Use @ffi_map, @ffi_out_ptrs, handles, or borrows instead."
                if trimmed[searchPos] == ',' || trimmed[searchPos] == '(':
                    break
                searchPos = searchPos - 1
        searchStart = absPtrPos + 3
    return ""

fn TypedExprEnforceNoPointerPolicy(sourceText: TypedExprSourceText): str[] =
    var violations: str[]
    let normalizedPath = parser.ParserNormalizePath(sourceText.sourcePath)
    if chengpath.TextContains(normalizedPath, "src/core/"):
        return violations
    if chengpath.TextContains(normalizedPath, "src/tooling/"):
        return violations
    var normalizedText = ""
    var rewriteErr = ""
    if !parser.ParserRewriteMultilineStringSourceText(sourceText.text, normalizedText, rewriteErr):
        return violations
    var decls: parser.NormalizedFunctionDecl[]
    if !parser.ParserReadNormalizedFunctionDecls(normalizedText, decls, rewriteErr):
        return violations
    var importcStartLines: int32[]
    var importcEndLines: int32[]
    let lines = parser.ParserSplitChar(normalizedText, '\n')
    let totalLines = lines.len
    for i in 0..<decls.len:
        if decls[i].importc:
            let startLine = decls[i].lineIndex
            var endLine: int32
            if i + 1 < decls.len:
                endLine = decls[i + 1].lineIndex - 1
            else:
                endLine = totalLines
            add(importcStartLines, startLine)
            add(importcEndLines, endLine)
    for i in 0..<lines.len:
        let lineNumber = i + 1
        var inImportc = false
        for j in 0..<importcStartLines.len:
            if lineNumber >= importcStartLines[j] && lineNumber <= importcEndLines[j]:
                inImportc = true
                break
        if inImportc:
            continue
        let violation = TypedExprCheckNoPointerSurface(lines[i], lineNumber, sourceText.sourcePath)
        if violation != "":
            add(violations, violation)
    return violations
