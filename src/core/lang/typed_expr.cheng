    TypedExprReportAppendLine(out, "expr_surface_call_reason_shadowed_qualified_target_count", intToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonShadowedQualifiedTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_ambiguous_external_target_count", intToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousExternalTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_ambiguous_qualified_target_count", intToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_unknown_external_target_count", intToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownExternalTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_unknown_call_target_count", intToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownCallTarget)))
    TypedExprReportAppendLine(out, "typed_expr_fact_count", intToStr(facts.len))
