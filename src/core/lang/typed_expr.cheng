    TypedExprReportAppendLine(out, "typed_expr_abi_composite_count", intToStr(TypedExprAbiCompositeCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_abi_pointer_like_count", intToStr(TypedExprAbiPointerLikeCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_abi_polymorphic_count", intToStr(TypedExprAbiPolymorphicCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_value_scalar_count", intToStr(TypedExprValueScalarCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_value_composite_count", intToStr(TypedExprValueCompositeCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_value_pointer_like_count", intToStr(TypedExprValuePointerLikeCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_value_polymorphic_count", intToStr(TypedExprValuePolymorphicCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_place_local_count", intToStr(TypedExprPlaceLocalCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_place_global_count", intToStr(TypedExprPlaceGlobalCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_place_field_count", intToStr(TypedExprPlaceFieldCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_place_temporary_count", intToStr(TypedExprPlaceTemporaryCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_place_call_result_count", intToStr(TypedExprPlaceCallResultCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_lower_reg_count", intToStr(TypedExprLowerRegCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_lower_local_address_count", intToStr(TypedExprLowerLocalAddressCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_lower_sret_count", intToStr(TypedExprLowerSretCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_lower_import_buffer_count", intToStr(TypedExprLowerImportBufferCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_lower_deferred_count", intToStr(TypedExprLowerDeferredCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_call_none_count", intToStr(TypedExprCallNoneCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_call_builtin_count", intToStr(TypedExprCallBuiltinCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_call_result_intrinsic_count", intToStr(TypedExprCallResultIntrinsicCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_call_projection_count", intToStr(TypedExprCallProjectionCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_type_call_none_count", intToStr(TypedExprTypeCallNoneCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_type_call_default_init_count", intToStr(TypedExprTypeCallDefaultInitCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_type_call_constructor_count", intToStr(TypedExprTypeCallConstructorCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_return_reg_count", intToStr(TypedExprReturnRegCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_return_composite_local_count", intToStr(TypedExprReturnCompositeLocalCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_return_sret_count", intToStr(TypedExprReturnSretCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_return_import_buffer_count", intToStr(TypedExprReturnImportBufferCount(facts)))
    TypedExprReportAppendLine(out, "typed_expr_return_deferred_count", intToStr(TypedExprReturnDeferredCount(facts)))
    return out

fn TypedExprLoweringRulesReportText(rules: TypedExprLoweringRule[]): str =
    var out = ""
    TypedExprReportAppendLine(out, "lowering_rule_count", intToStr(rules.len))
    TypedExprReportAppendLine(out, "lowering_rule_unique_shape_count", intToStr(TypedExprLoweringRuleUniqueShapeCount(rules)))
    TypedExprReportAppendLine(out, "lowering_rule_unique_key_count", intToStr(TypedExprLoweringRuleUniqueKeyCount(rules)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_value_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassValue)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_address_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_arg_call_result_address_count", intToStr(TypedExprLoweringRuleCountArgPassKind(rules, TypedExprArgPassCallResultAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_result_reg_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassReg)))
    TypedExprReportAppendLine(out, "lowering_rule_result_local_address_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassLocalAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_result_sret_count", intToStr(TypedExprLoweringRuleCountResultPassKind(rules, TypedExprResultPassSret)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_register_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeRegister)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_local_slot_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeLocalSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_call_result_local_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeCallResultLocal)))
    TypedExprReportAppendLine(out, "lowering_rule_materialize_dest_address_count", intToStr(TypedExprLoweringRuleCountMaterializeKind(rules, TypedExprMaterializeDestAddress)))
    TypedExprReportAppendLine(out, "lowering_rule_copy_scalar_store_count", intToStr(TypedExprLoweringRuleCountCopyKind(rules, TypedExprCopyScalarStore)))
    TypedExprReportAppendLine(out, "lowering_rule_copy_region_copy_count", intToStr(TypedExprLoweringRuleCountCopyKind(rules, TypedExprCopyRegionCopy)))
    TypedExprReportAppendLine(out, "lowering_rule_import_import_buffer_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportImportBuffer)))
    TypedExprReportAppendLine(out, "lowering_rule_import_builtin_address_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportBuiltinAddressSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_import_i32_value_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportI32ValueSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_import_i32_address_slot_count", intToStr(TypedExprLoweringRuleCountImportKind(rules, TypedExprImportI32AddressSlot)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_none_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallNone)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_default_init_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallDefaultInit)))
    TypedExprReportAppendLine(out, "lowering_rule_type_call_constructor_count", intToStr(TypedExprLoweringRuleCountTypeCallKind(rules, TypedExprTypeCallConstructor)))
    for i in 0..<rules.len:
        TypedExprReportAppendLine(out, "lowering_rule_entry[" + intToStr(i) + "]", TypedExprLoweringRuleEntryText(rules[i]))
    return out

fn TypedExprReportText(facts: TypedExprFact[],
                         rules: TypedExprLoweringRule[]): str =
    let factsText = TypedExprFactsReportText(facts)
    let rulesText = TypedExprLoweringRulesReportText(rules)
    return factsText + rulesText

fn TypedExprLoweringRuleValidateTypeCallMaterialize(rule: TypedExprLoweringRule,
                                                      err: var str): bool =
    if rule.typeCallKind == TypedExprTypeCallNone:
        return true
    if !TypedExprTypeTextIsConcrete(rule.typeText):
        err = " typed expr: type-call rule missing concrete type"
        return false
    if rule.callKind != TypedExprCallNone:
        err = " typed expr: type-call rule leaked ordinary call kind"
        return false
    if rule.abiClass != TypedExprAbiComposite ||
       rule.valueKind != TypedExprValueComposite:
        err = " typed expr: type-call rule must materialize composite"
        return false
    if rule.placeKind == TypedExprPlaceCallResult:
        err = " typed expr: type-call rule cannot use call-result place"
        return false
    if rule.argPassKind != TypedExprArgPassAddress:
        err = " typed expr: type-call rule must pass address"
        return false
    if rule.copyKind != TypedExprCopyRegionCopy:
        err = " typed expr: type-call rule must copy region"
        return false
    if rule.loweringMode == TypedExprLowerLocalAddress:
        if rule.returnKind != TypedExprReturnCompositeLocal ||
           rule.resultPassKind != TypedExprResultPassLocalAddress ||
           rule.materializeKind != TypedExprMaterializeLocalSlot:
            err = " typed expr: type-call rule local-address lowering drift"
            return false
        err = ""
        return true
    if rule.loweringMode == TypedExprLowerSret:
        if rule.returnKind != TypedExprReturnSret ||
           rule.resultPassKind != TypedExprResultPassSret ||
           rule.materializeKind != TypedExprMaterializeDestAddress:
            err = " typed expr: type-call rule sret lowering drift"
            return false
        err = ""
        return true
    err = " typed expr: type-call rule missing address lowering"
    return false

fn TypedExprLoweringRulesValidate(rules: TypedExprLoweringRule[],
                                    err: var str): bool =
    for i in 0..<rules.len:
        let rule = rules[i]
        if rule.exprId == "" || rule.sourcePath == "":
            err = " typed expr: lowering rule missing owner"
            return false
        if rule.surfaceCallKind == TypedExprSurfaceCallNone:
            if rule.callResolved ||
               rule.callReason != TypedExprCallReasonNone ||
               rule.callQualifier != "" ||
               rule.callCallee != "" ||
               rule.callTarget != "" ||
               rule.callTargetSourcePath != "" ||
               rule.callTargetImportc:
                err = " typed expr: non-call rule leaked call resolution"
                return false
            if rule.typeCallKind != TypedExprTypeCallNone:
                if !TypedExprLoweringRuleValidateTypeCallMaterialize(rule, err):
                    return false
            elif rule.callPrefixStyle ||
                 rule.callArgCount != 0 ||
                 rule.callArgsText != "":
                err = " typed expr: non-call rule leaked call args"
                return false
        else:
            if rule.typeCallKind != TypedExprTypeCallNone:
                err = " typed expr: call rule leaked type-call kind"
                return false
            if rule.callQualifier == "" &&
               (rule.surfaceCallKind == TypedExprSurfaceCallExternal ||
                rule.surfaceCallKind == TypedExprSurfaceCallMember):
                if parser.ParserFindText(rule.callTarget, ".") >= 0:
                    err = " typed expr: qualified call rule missing qualifier: target=" +
                          rule.callTarget +
                          " callee=" +
                          rule.callCallee +
                          " source=" +
                          rule.sourcePath +
                          " expr=" +
                          rule.exprId
                    return false
            if rule.callCallee == "" || rule.callTarget == "":
                err = " typed expr: call rule missing callee or target"
                return false
            if rule.callResolved && rule.callReason != TypedExprCallReasonNone:
                err = " typed expr: resolved rule keeps call reason"
                return false
            if !rule.callResolved && rule.callReason == TypedExprCallReasonNone:
                err = " typed expr: unresolved rule missing call reason"
                return false
            if rule.callResolved && rule.callTargetSourcePath == "":
                err = " typed expr: resolved rule missing target source"
                return false
            if !rule.callResolved && rule.callTargetSourcePath != "":
                err = " typed expr: unresolved rule keeps target source"
                return false
            if !rule.callResolved && rule.callTargetImportc:
                err = " typed expr: unresolved rule keeps importc target"
                return false
        if rule.typeCallKind != TypedExprTypeCallNone &&
           rule.surfaceCallKind != TypedExprSurfaceCallNone:
            err = " typed expr: type-call rule leaked call surface"
            return false
        if (rule.abiClass == TypedExprAbiPolymorphic ||
            rule.loweringMode == TypedExprLowerDeferred) &&
           (rule.argPassKind != TypedExprArgPassDeferred ||
            rule.resultPassKind != TypedExprResultPassDeferred ||
            rule.materializeKind != TypedExprMaterializeDeferred ||
            rule.copyKind != TypedExprCopyDeferred ||
            rule.importKind != TypedExprImportDeferred):
            err = " typed expr: deferred rule leaked concrete lowering"
            return false
        if rule.importKind == TypedExprImportImportBuffer &&
           rule.loweringMode != TypedExprLowerImportBuffer &&
           rule.returnKind != TypedExprReturnImportBuffer:
            err = " typed expr: import buffer rule missing import buffer return"
            return false
        if rule.copyKind == TypedExprCopyRegionCopy &&
           rule.valueKind != TypedExprValueComposite:
            err = " typed expr: region copy rule must stay composite"
            return false
    err = ""
    return true

fn TypedExprBuildLoweringRules(facts: TypedExprFact[],
                                 rules: var TypedExprLoweringRule[],
                                 err: var str): bool =
    rules = TypedExprLoweringRulesFromFacts(facts)
    if !TypedExprLoweringRulesValidate(rules, err):
        return false
    err = ""
    return true

fn TypedExprConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn TypedExprConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn TypedExprNormalizeTypeText(typeRaw: str): str =
    let trimmed: str = chengpath.PathTrim(typeRaw)
    if trimmed == "":
        return ""
    var out = buffer.NewByteBuffer()
    for i in 0..<trimmed.len:
        let piece = chengpath.TextSlice(trimmed, i, 1)
        if piece == " ":
            continue
        if piece == "\t":
            continue
        if piece == "\n":
            continue
        if piece == "\r":
            continue
        buffer.AppendBytes(out, piece)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot: str,
                                                    packageRoot: str,
                                                    externalPackageRoots: parser.ParserExternalPackageRoot[],
                                                    sourcePath: str,
                                                    text: str): TypedExprSourceText =
    var out: TypedExprSourceText
    out.workspaceRoot = parser.ParserNormalizePath(workspaceRoot)
    out.packageRoot = parser.ParserNormalizePath(packageRoot)
    out.externalPackageRoots = parser.ParserExternalPackageRootsClone(externalPackageRoots)
    out.sourcePath = parser.ParserNormalizePath(sourcePath)
    out.text = text
    return out

fn TypedExprSourceTextNew(workspaceRoot: str,
                            packageRoot: str,
                            sourcePath: str,
                            text: str): TypedExprSourceText =
    var externalPackageRoots: parser.ParserExternalPackageRoot[]
    return TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot,
                                                            packageRoot,
                                                            externalPackageRoots,
                                                            sourcePath,
                                                            text)

fn TypedExprResultType(innerTypeRaw: str): str =
    let innerType = TypedExprNormalizeTypeText(innerTypeRaw)
    if innerType == "":
        return ""
    return TypedExprConcat3("Result[", innerType, "]")

fn TypedExprResultSuccessType(typeRaw: str): str =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if !parser.ParserStartsWith(typeText, "Result["):
        return ""
    if typeText.len <= 8:
        return ""
    if chengpath.TextSlice(typeText, typeText.len - 1, 1) != "]":
        return ""
    return chengpath.TextSlice(typeText, len("Result["), typeText.len - len("Result[") - 1)

fn TypedExprTypeIsScalar(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "void":
        return true
    if typeText == "bool" || typeText == "char":
        return true
    if typeText == "int" || typeText == "uint":
        return true
    if typeText == "int8" || typeText == "uint8" || typeText == "u8":
        return true
    if typeText == "int16" || typeText == "uint16" || typeText == "u16":
        return true
    if typeText == "int32" || typeText == "uint32" || typeText == "u32":
        return true
    if typeText == "int64" || typeText == "uint64" || typeText == "u64":
        return true
    if typeText == "float32" || typeText == "float64":
        return true
    return false

fn TypedExprTypeIsPointerLike(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "cstring":
        return true
    if typeText == "ptr":
        return true
    return parser.ParserStartsWith(typeText, "ptr[") || parser.ParserStartsWith(typeText, "Pointer[")

fn TypedExprTypeIsComposite(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "str" || typeText == "Bytes" || typeText == "bytes.Bytes":
        return true
    if typeText == "rawbytes" || typeText == "ErrorInfo" || typeText == "range":
        return true
    if parser.ParserStartsWith(typeText, "Result["):
        return true
    if parser.ParserStartsWith(typeText, "seq["):
        return true
    if parser.ParserStartsWith(typeText, "tuple["):
        return true
    if parser.ParserStartsWith(typeText, "array["):
        return true
    if parser.ParserStartsWith(typeText, "object["):
        return true
    if typeText.len >= 2 && chengpath.TextSlice(typeText, typeText.len - 2, 2) == "[]":
        return true
    return false

fn TypedExprAbiClassForType(typeRaw: str): TypedExprAbiClass =
    if TypedExprTypeIsScalar(typeRaw):
        return TypedExprAbiScalar
    if TypedExprTypeIsPointerLike(typeRaw):
        return TypedExprAbiPointerLike
    if TypedExprTypeIsComposite(typeRaw):
        return TypedExprAbiComposite
    return TypedExprAbiPolymorphic

fn TypedExprValueKindForAbiClass(abiClass: TypedExprAbiClass): TypedExprValueKind =
    if abiClass == TypedExprAbiScalar:
        return TypedExprValueScalar
    if abiClass == TypedExprAbiComposite:
        return TypedExprValueComposite
    if abiClass == TypedExprAbiPointerLike:
        return TypedExprValuePointerLike
    return TypedExprValuePolymorphic

fn TypedExprSkipInlineSpaces(lineRaw: str,
                               start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if parser.ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn TypedExprFindMatchingPair(lineRaw: str,
                               openPos: int32,
                               openText: str,
                               closeText: str): int32 =
    if openPos < 0:
        return -1
    if openPos >= lineRaw.len:
        return -1
    if chengpath.TextSlice(lineRaw, openPos, 1) != openText:
        return -1
    var depth: int32
    for i in openPos..<lineRaw.len:
        let piece = chengpath.TextSlice(lineRaw, i, 1)
        if piece == openText:
            depth = depth + 1
        elif piece == closeText:
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn TypedExprFindMatchingParen(lineRaw: str,
                                openPos: int32): int32 =
    return TypedExprFindMatchingPair(lineRaw, openPos, "(", ")")

fn TypedExprFindMatchingBracket(lineRaw: str,
                                  openPos: int32): int32 =
    return TypedExprFindMatchingPair(lineRaw, openPos, "[", "]")

fn TypedExprSliceTrim(textRaw: str,
                        start: int32,
                        count: int32): str =
    if start < 0 || count <= 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(textRaw, start, count))

fn TypedExprFindTopLevelToken(textRaw: str,
                                target: str): int32 =
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let piece = chengpath.TextSlice(textRaw, i, 1)
        if piece == "[":
            bracketDepth = bracketDepth + 1
        elif piece == "]":
            bracketDepth = bracketDepth - 1
        elif piece == "(":
            parenDepth = parenDepth + 1
        elif piece == ")":
            parenDepth = parenDepth - 1
        elif piece == "{":
            braceDepth = braceDepth + 1
        elif piece == "}":
            braceDepth = braceDepth - 1
        elif piece == target && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            return i
    return -1

fn TypedExprParseFunctionReturnType(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return ""
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos < 0:
        return ""
    let cursor0 = TypedExprSkipInlineSpaces(line, closePos + 1)
    var cursor = cursor0
    if cursor >= line.len:
        return ""
    if chengpath.TextSlice(line, cursor, 1) != ":":
        return ""
    cursor = TypedExprSkipInlineSpaces(line, cursor + 1)
    let tail = chengpath.TextSlice(line, cursor, line.len - cursor)
    let eqPos = TypedExprFindTopLevelToken(tail, "=")
    if eqPos >= 0:
        return TypedExprNormalizeTypeText(chengpath.TextSlice(tail, 0, eqPos))
    return TypedExprNormalizeTypeText(tail)

fn TypedExprParseTypeDeclName(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    if line == "":
        return ""
    let eqPos = TypedExprFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return ""
    let headRaw = chengpath.PathTrim(chengpath.TextSlice(line, 0, eqPos))
    let genericPos = TypedExprFindTopLevelToken(headRaw, "[")
    var head = headRaw
    if genericPos > 0:
        head = chengpath.PathTrim(chengpath.TextSlice(headRaw, 0, genericPos))
    return parser.ParserIdentPrefix(parser.ParserFirstToken(head))

fn TypedExprSplitTopLevelCsv(itemsRaw: str): str[] =
    var out: str[]
    var start: int32
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<itemsRaw.len:
        let piece = chengpath.TextSlice(itemsRaw, i, 1)
        if piece == "[":
            bracketDepth = bracketDepth + 1
        elif piece == "]":
            bracketDepth = bracketDepth - 1
        elif piece == "(":
            parenDepth = parenDepth + 1
        elif piece == ")":
            parenDepth = parenDepth - 1
        elif piece == "{":
            braceDepth = braceDepth + 1
        elif piece == "}":
            braceDepth = braceDepth - 1
        elif piece == "," && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            add(out, TypedExprSliceTrim(itemsRaw, start, i - start))
            start = i + 1
    add(out, TypedExprSliceTrim(itemsRaw, start, itemsRaw.len - start))
    return out

fn TypedExprMaybeAddBinding(bindings: var TypedExprBinding[],
                              sourcePath: str,
                              functionName: str,
                              globalFlag: bool,
                              lineNumber: int32,
                              nameRaw: str,
                              typeRaw: str) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if name == "" || typeText == "":
        return
    var binding: TypedExprBinding
    binding.sourcePath = sourcePath
    binding.functionName = functionName
    binding.globalFlag = globalFlag
    binding.lineNumber = lineNumber
    binding.name = name
    binding.typeText = typeText
    add(bindings, binding)

fn TypedExprAppendParamBindings(bindings: var TypedExprBinding[],
                                  scope: TypedExprFunctionScope,
                                  lineRaw: str) =
    let line = chengpath.PathTrim(lineRaw)
    let openPos = parser.ParserFindText(line, "(")
    if openPos < 0:
        return
    let closePos = TypedExprFindMatchingParen(line, openPos)
    if closePos <= openPos:
        return
    let paramsText = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let params = TypedExprSplitTopLevelCsv(paramsText)
    for i in 0..<params.len:
        var item = params[i]
        if parser.ParserStartsWith(item, "var "):
            item = chengpath.TextSlice(item, 4, item.len - 4)
        let colonPos = TypedExprFindTopLevelToken(item, ":")
        if colonPos <= 0:
            continue
        let nameText = chengpath.TextSlice(item, 0, colonPos)
        var typeText = chengpath.TextSlice(item, colonPos + 1, item.len - colonPos - 1)
        let eqPos = TypedExprFindTopLevelToken(typeText, "=")
        if eqPos >= 0:
            typeText = chengpath.TextSlice(typeText, 0, eqPos)
        TypedExprMaybeAddBinding(bindings,
                                   scope.sourcePath,
                                   scope.name,
                                   false,
                                   scope.startLine,
                                   nameText,
                                   typeText)

fn TypedExprScopeIndexForLine(scopes: TypedExprFunctionScope[],
                                lineNumber: int32): int32 =
    for i in 0..<scopes.len:
        if lineNumber < scopes[i].startLine:
            continue
        if lineNumber > scopes[i].endLine:
            continue
        return i
    return -1

fn TypedExprParseBindingLine(lineRaw: str,
                               name: var str,
                               typeText: var str,
                               rhsStartColumn: var int32): bool =
    name = ""
    typeText = ""
    rhsStartColumn = -1
    let trimmed = chengpath.PathTrim(lineRaw)
    var prefix = ""
    if parser.ParserStartsWith(trimmed, "let "):
        prefix = "let "
    elif parser.ParserStartsWith(trimmed, "var "):
        prefix = "var "
    elif parser.ParserStartsWith(trimmed, "const "):
        prefix = "const "
    if prefix == "":
        return false
    let tail = chengpath.TextSlice(trimmed, len(prefix), trimmed.len - len(prefix))
    let rawName = parser.ParserFirstToken(tail)
    let bindingName = parser.ParserIdentPrefix(rawName)
    if bindingName == "":
        return false
    let colonPos = TypedExprFindTopLevelToken(tail, ":")
    let eqPos = TypedExprFindTopLevelToken(tail, "=")
    if colonPos < 0 || eqPos < 0 || eqPos <= colonPos:
        return false
    name = bindingName
    typeText = TypedExprNormalizeTypeText(chengpath.TextSlice(tail, colonPos + 1, eqPos - colonPos - 1))
    let originalEqPos = parser.ParserFindText(lineRaw, "=")
    if originalEqPos < 0:
        return false
    rhsStartColumn = originalEqPos + 2
    var scanning = true
    while rhsStartColumn <= lineRaw.len && scanning:
        if parser.ParserIsInlineSpace(lineRaw[rhsStartColumn - 1]):
            rhsStartColumn = rhsStartColumn + 1
        else:
            scanning = false
    return name != "" && typeText != ""

fn TypedExprSourceContextLookup(sourceContexts: TypedExprSourceContext[],
                                  sourcePathRaw: str): int32 =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<sourceContexts.len:
        if sourceContexts[i].sourcePath == sourcePath:
            return i
    return -1

fn TypedExprSourceLine(ctx: TypedExprSourceContext,
                         lineNumber: int32): str =
    if lineNumber <= 0 || lineNumber > ctx.lines.len:
        return ""
    return ctx.lines[lineNumber - 1]

fn TypedExprLookupBindingType(ctx: TypedExprSourceContext,
                                scopeIndex: int32,
                                lineNumber: int32,
                                nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    var bestLine: int32 = -1
    var bestType = ""
    var scopeName = ""
    if scopeIndex >= 0:
        scopeName = ctx.scopes[scopeIndex].name
    for i in 0..<ctx.bindings.len:
        let binding = ctx.bindings[i]
        if binding.name != name:
            continue
        if binding.lineNumber > lineNumber:
            continue
        if scopeName != "":
            if !binding.globalFlag && binding.functionName == scopeName && binding.lineNumber >= bestLine:
                bestLine = binding.lineNumber
                bestType = binding.typeText
                continue
            if binding.globalFlag && bestLine < 0:
                bestLine = binding.lineNumber
                bestType = binding.typeText
            continue
        if !binding.globalFlag:
            continue
        if binding.lineNumber >= bestLine:
            bestLine = binding.lineNumber
            bestType = binding.typeText
    return bestType

fn TypedExprLookupImportcReturnType(ctx: TypedExprSourceContext,
                                      nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<ctx.importcFunctions.len:
        if ctx.importcFunctions[i].name == name:
            if ctx.importcFunctions[i].returnType == "":
                return "void"
            return ctx.importcFunctions[i].returnType
    return ""

fn TypedExprLookupImportcReturnTypeFromContexts(sourceContexts: TypedExprSourceContext[],
                                                  nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<sourceContexts.len:
        let found = TypedExprLookupImportcReturnType(sourceContexts[i], name)
        if found != "":
            return found
    return ""

fn TypedExprQualifiedCallDot(nameRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    var dotPos: int32 = -1
    for i in 0..<name.len:
        if name[i] == '.':
            dotPos = i
    return dotPos

fn TypedExprQualifiedCallQualifier(nameRaw: str): str =
    let name = chengpath.PathTrim(nameRaw)
    let dotPos = TypedExprQualifiedCallDot(name)
    if dotPos <= 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(name, 0, dotPos))

fn TypedExprQualifiedCallLeaf(nameRaw: str): str =
    let name = chengpath.PathTrim(nameRaw)
    let dotPos = TypedExprQualifiedCallDot(name)
    if dotPos < 0:
        return parser.ParserIdentPrefix(name)
    if dotPos + 1 >= name.len:
        return ""
    return parser.ParserIdentPrefix(chengpath.TextSlice(name, dotPos + 1, name.len - dotPos - 1))

fn TypedExprLookupLocalFunctionReturnType(ctx: TypedExprSourceContext,
                                            nameRaw: str): str =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<ctx.scopes.len:
        if ctx.scopes[i].name == name:
            if ctx.scopes[i].returnType == "":
                return "void"
            return ctx.scopes[i].returnType
    return ""

fn TypedExprLookupImportedModuleSourcePath(ctx: TypedExprSourceContext,
                                             qualifierRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    if qualifier == "":
        return ""
    for i in 0..<ctx.importedModules.len:
        if ctx.importedModules[i].qualifier == qualifier:
            return ctx.importedModules[i].targetSourcePath
    return ""

fn TypedExprLookupQualifiedModuleSourcePath(currentCtx: TypedExprSourceContext,
                                              sourceContexts: TypedExprSourceContext[],
                                              qualifierChainRaw: str): str =
    let qualifierChain = chengpath.PathTrim(qualifierChainRaw)
    if qualifierChain == "":
        return ""
    let qualifierParts = parser.ParserSplitChar(qualifierChain, '.')
    var ctx = currentCtx
    var targetSourcePath = ""
    for i in 0..<qualifierParts.len:
        let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierParts[i]))
        if qualifier == "":
            return ""
        targetSourcePath = TypedExprLookupImportedModuleSourcePath(ctx, qualifier)
        if targetSourcePath == "":
            return ""
        if i + 1 >= qualifierParts.len:
            return targetSourcePath
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
        if targetIndex < 0:
            return ""
        ctx = sourceContexts[targetIndex]
    return targetSourcePath

fn TypedExprSourceHasDeclaredType(ctx: TypedExprSourceContext,
                                    typeNameRaw: str): bool =
    let typeName = TypedExprNormalizeTypeText(typeNameRaw)
    if typeName == "":
        return false
    for i in 0..<ctx.declaredTypes.len:
        if ctx.declaredTypes[i] == typeName:
            return true
    return false

fn TypedExprQualifiedTypeDot(typeRaw: str): int32 =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    var dotPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '.':
            dotPos = i
    return dotPos

fn TypedExprTypeIsNamedCompositeInContext(currentCtx: TypedExprSourceContext,
                                            sourceContexts: TypedExprSourceContext[],
                                            typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    let dotPos = TypedExprQualifiedTypeDot(typeText)
    if dotPos > 0:
        let qualifier = chengpath.PathTrim(chengpath.TextSlice(typeText, 0, dotPos))
        let leaf = chengpath.PathTrim(chengpath.TextSlice(typeText, dotPos + 1, typeText.len - dotPos - 1))
        if qualifier == "" || leaf == "":
            return false
        let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(currentCtx, sourceContexts, qualifier)
        let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
        if targetIndex < 0:
            return false
        return TypedExprSourceHasDeclaredType(sourceContexts[targetIndex], leaf)
    if TypedExprSourceHasDeclaredType(currentCtx, typeText):
        return true
    var resolvedSourcePath = ""
    for i in 0..<currentCtx.importedModules.len:
        let importedSourcePath = parser.ParserNormalizePath(currentCtx.importedModules[i].targetSourcePath)
        let importedIndex = TypedExprSourceContextLookup(sourceContexts, importedSourcePath)
        if importedIndex < 0:
            continue
        if !TypedExprSourceHasDeclaredType(sourceContexts[importedIndex], typeText):
            continue
        if resolvedSourcePath == "":
            resolvedSourcePath = importedSourcePath
            continue
        if resolvedSourcePath != importedSourcePath:
            return false
    return resolvedSourcePath != ""

fn TypedExprAbiClassForTypeInContext(currentCtx: TypedExprSourceContext,
                                       sourceContexts: TypedExprSourceContext[],
                                       typeRaw: str): TypedExprAbiClass =
    let abiClass = TypedExprAbiClassForType(typeRaw)
    if abiClass != TypedExprAbiPolymorphic:
        return abiClass
    if TypedExprTypeIsNamedCompositeInContext(currentCtx, sourceContexts, typeRaw):
        return TypedExprAbiComposite
    return TypedExprAbiPolymorphic

fn TypedExprLookupQualifiedExternalReturnType(currentCtx: TypedExprSourceContext,
                                                sourceContexts: TypedExprSourceContext[],
                                                qualifierRaw: str,
                                                functionNameRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    let functionName = parser.ParserIdentPrefix(chengpath.PathTrim(functionNameRaw))
    if qualifier == "" || functionName == "":
        return ""
    let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(currentCtx, sourceContexts, qualifier)
    if targetSourcePath == "":
        return ""
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, targetSourcePath)
    if targetIndex < 0:
        return ""
    let localReturnType = TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], functionName)
    if localReturnType != "":
        return localReturnType
    return TypedExprLookupImportcReturnType(sourceContexts[targetIndex], functionName)

fn TypedExprLookupExternalFunctionReturnTypeFromContexts(currentCtx: TypedExprSourceContext,
                                                           sourceContexts: TypedExprSourceContext[],
                                                           qualifierRaw: str,
                                                           nameRaw: str): str =
    let qualifier = parser.ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    let qualifiedReturnType = TypedExprLookupQualifiedExternalReturnType(currentCtx, sourceContexts, qualifier, nameRaw)
    if qualifiedReturnType != "":
        return qualifiedReturnType
    if qualifier != "":
        return ""
    let sourcePath = currentCtx.sourcePath
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return ""
    for i in 0..<sourceContexts.len:
        if sourceContexts[i].sourcePath == sourcePath:
            continue
        let found = TypedExprLookupLocalFunctionReturnType(sourceContexts[i], name)
        if found != "":
            return found
        let importcFound = TypedExprLookupImportcReturnType(sourceContexts[i], name)
        if importcFound != "":
            return importcFound
    return ""

fn TypedExprLookupCallTargetReturnTypeFromFact(sourceContexts: TypedExprSourceContext[],
                                                 fact: TypedExprFact): str =
    if fact.callTargetSourcePath == "":
        return ""
    let targetIndex = TypedExprSourceContextLookup(sourceContexts, fact.callTargetSourcePath)
    if targetIndex < 0:
        return ""
    if fact.callTargetImportc:
        return TypedExprLookupImportcReturnType(sourceContexts[targetIndex], fact.callCallee)
    return TypedExprLookupLocalFunctionReturnType(sourceContexts[targetIndex], fact.callCallee)

fn TypedExprFirstExprColumnAfter(ctx: TypedExprSourceContext,
                                   lineNumber: int32,
                                   minColumn: int32): int32 =
    if lineNumber <= 0 || lineNumber > ctx.exprLineColumns.len:
        return -1
    let lineColumns = ctx.exprLineColumns[lineNumber - 1].columns
    for i in 0..<lineColumns.len:
        let exprColumnNumber = lineColumns[i]
        if exprColumnNumber >= minColumn:
            return exprColumnNumber
    return -1

fn TypedExprLineHasRootReturn(lineRaw: str,
                                ctx: TypedExprSourceContext,
                                expr: parser.NormalizedExpr): bool =
    let firstToken = parser.ParserFirstToken(chengpath.PathTrim(lineRaw))
    if firstToken != "return":
        return false
    let returnPos = parser.ParserFindText(lineRaw, "return")
    if returnPos < 0:
        return false
    let exprStart = returnPos + len("return") + 1
    let rootExprColumn = TypedExprFirstExprColumnAfter(ctx,
                                                         expr.lineNumber,
                                                         exprStart)
    return rootExprColumn == expr.columnNumber

fn TypedExprSourceContextForPathOrCurrent(currentCtx: TypedExprSourceContext,
                                            sourceContexts: TypedExprSourceContext[],
                                            sourcePathRaw: str): TypedExprSourceContext =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        return currentCtx
    let ctxIndex = TypedExprSourceContextLookup(sourceContexts, sourcePath)
    if ctxIndex < 0:
        return currentCtx
    return sourceContexts[ctxIndex]

fn TypedExprComprehensionFilterIf(lineRaw: str,
                                    expr: parser.NormalizedExpr): bool =
    if expr.kind != parser.NormalizedExprIf ||
       expr.detailKind != parser.NormalizedExprDetailIfKeyword:
        return false
    let exprPos = expr.columnNumber - 1
    for openPos in 0..<lineRaw.len:
        if lineRaw[openPos] != '[':
            continue
        var itemText = ""
        var bindingText = ""
        var sourceText = ""
        var filterText = ""
        var filterColumn = -1
        var endColumn = -1
        if !parser.ParserParseListComprehensionAt(lineRaw,
                                                    openPos,
                                                    itemText,
                                                    bindingText,
                                                    sourceText,
                                                    filterText,
                                                    filterColumn,
                                                    endColumn):
            continue
        if filterColumn == expr.columnNumber:
            return true
        if filterColumn > 0 && filterColumn - 1 == exprPos:
            return true
    return false

fn TypedExprExtractGenericArg(lineRaw: str,
                                columnNumber: int32,
                                callName: str): str =
    if columnNumber <= 0:
        return ""
    var start = columnNumber
    start = start - 1
    if start < 0 || start + len(callName) > lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, start, len(callName)) != callName:
        return ""
    let cursor0 = TypedExprSkipInlineSpaces(lineRaw, start + len(callName))
    var cursor = cursor0
    if cursor >= lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, cursor, 1) != "[":
        return ""
    let closePos = TypedExprFindMatchingBracket(lineRaw, cursor)
    if closePos <= cursor:
        return ""
    return TypedExprNormalizeTypeText(chengpath.TextSlice(lineRaw, cursor + 1, closePos - cursor - 1))

fn TypedExprExtractTypeGenericArg(typeRaw: str): str =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    let openPos = TypedExprFindTopLevelToken(typeText, "[")
    if openPos < 0 || openPos + 1 >= typeText.len:
        return ""
    let closePos = TypedExprFindMatchingBracket(typeText, openPos)
    if closePos <= openPos || closePos + 1 != typeText.len:
        return ""
    return TypedExprNormalizeTypeText(chengpath.TextSlice(typeText, openPos + 1, closePos - openPos - 1))

fn TypedExprExtractFirstArg(lineRaw: str,
                              columnNumber: int32,
                              callName: str): str =
    if columnNumber <= 0:
        return ""
    var start = columnNumber
    start = start - 1
    if start < 0 || start + len(callName) > lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, start, len(callName)) != callName:
        return ""
    var cursor = TypedExprSkipInlineSpaces(lineRaw, start + len(callName))
    if cursor < lineRaw.len && chengpath.TextSlice(lineRaw, cursor, 1) == "[":
        let closeBracket = TypedExprFindMatchingBracket(lineRaw, cursor)
        if closeBracket < 0:
            return ""
        cursor = closeBracket + 1
    cursor = TypedExprSkipInlineSpaces(lineRaw, cursor)
    if cursor >= lineRaw.len:
        return ""
    if chengpath.TextSlice(lineRaw, cursor, 1) != "(":
        return ""
    let closeParen = TypedExprFindMatchingParen(lineRaw, cursor)
    if closeParen <= cursor:
        return ""
    var argsText = chengpath.TextSlice(lineRaw, cursor + 1, closeParen - cursor - 1)
    let commaPos = TypedExprFindTopLevelToken(argsText, ",")
    if commaPos >= 0:
        argsText = chengpath.TextSlice(argsText, 0, commaPos)
    return chengpath.PathTrim(argsText)

fn TypedExprInferredResultInputType(ctx: TypedExprSourceContext,
                                      scopeIndex: int32,
                                      expr: parser.NormalizedExpr): str =
    let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
    if lineRaw == "":
        return ""
    if expr.kind == parser.NormalizedExprTry:
        let token = parser.ParserPreviousToken(lineRaw, expr.columnNumber - 1)
        return TypedExprLookupBindingType(ctx, scopeIndex, expr.lineNumber, token)
    if expr.kind != parser.NormalizedExprResultIntrinsic:
        return ""
    let callName = expr.surfaceText
    let argText = TypedExprExtractFirstArg(lineRaw, expr.columnNumber, callName)
    let argName = parser.ParserIdentPrefix(argText)
    if argName == "":
        return ""
    return TypedExprLookupBindingType(ctx, scopeIndex, expr.lineNumber, argName)

fn TypedExprSinkForExpr(ctx: TypedExprSourceContext,
                          expr: parser.NormalizedExpr): TypedExprSinkInfo =
    var sink: TypedExprSinkInfo
    sink.sinkType = ""
    sink.sinkPlaceKind = TypedExprPlaceTemporary
    sink.hasSink = false
    sink.returnRoot = false
    sink.functionReturnType = ""
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, expr.lineNumber)
    if scopeIndex >= 0:
        sink.functionReturnType = ctx.scopes[scopeIndex].returnType
    let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
    if lineRaw == "":
        return sink
    var bindingName = ""
    var bindingType = ""
    var rhsStartColumn: int32 = -1
    if TypedExprParseBindingLine(lineRaw, bindingName, bindingType, rhsStartColumn):
        let bindingRoot = TypedExprFirstExprColumnAfter(ctx,
                                                          expr.lineNumber,
                                                          rhsStartColumn)
        if bindingRoot == expr.columnNumber:
            sink.sinkType = bindingType
            sink.sinkPlaceKind = scopeIndex >= 0 ? TypedExprPlaceLocal : TypedExprPlaceGlobal
            sink.hasSink = true
    if TypedExprLineHasRootReturn(lineRaw, ctx, expr) && sink.functionReturnType != "":
        sink.sinkType = sink.functionReturnType
        sink.sinkPlaceKind = TypedExprPlaceTemporary
        sink.hasSink = true
        sink.returnRoot = true
    return sink

fn TypedExprApplyResolvedType(fact: var TypedExprFact,
                                abiCtx: TypedExprSourceContext,
                                sourceContexts: TypedExprSourceContext[],
                                typeRaw: str,
                                sink: TypedExprSinkInfo,
                                forceCallResult: bool) =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return
    fact.typeText = typeText
    fact.abiClass = TypedExprAbiClassForTypeInContext(abiCtx, sourceContexts, typeText)
    fact.valueKind = TypedExprValueKindForAbiClass(fact.abiClass)
    if forceCallResult:
        fact.placeKind = TypedExprPlaceCallResult
    elif sink.hasSink:
        fact.placeKind = sink.sinkPlaceKind
    else:
        fact.placeKind = TypedExprPlaceTemporary
    if fact.abiClass == TypedExprAbiPolymorphic:
        fact.loweringMode = TypedExprLowerDeferred
        fact.returnKind = TypedExprReturnDeferred
        return
    if sink.returnRoot && sink.sinkType == typeText:
        fact.loweringMode = fact.abiClass == TypedExprAbiComposite ? TypedExprLowerSret : TypedExprLowerReg
        fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)
        return
    if fact.abiClass == TypedExprAbiComposite:
        fact.loweringMode = TypedExprLowerLocalAddress
        fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)
        return
    fact.loweringMode = TypedExprLowerReg
    fact.returnKind = TypedExprReturnKindForResolved(fact.abiClass, fact.loweringMode)

fn TypedExprBuildFact(ctx: TypedExprSourceContext,
                        sourceContexts: TypedExprSourceContext[],
                        expr: parser.NormalizedExpr): TypedExprFact =
    var fact: TypedExprFact
    fact.exprId = expr.exprId
    fact.sourcePath = expr.sourcePath
    fact.lineNumber = expr.lineNumber
    fact.columnNumber = expr.columnNumber
    fact.endLineNumber = expr.endLineNumber
    fact.endColumnNumber = expr.endColumnNumber
    fact.kind = expr.kind
    fact.surfaceCallKind = TypedExprSurfaceCallNone
    fact.callResolved = false
    fact.callReason = TypedExprCallReasonNone
    fact.callQualifier = ""
    fact.callCallee = ""
    fact.callTarget = ""
    fact.callTargetSourcePath = ""
    fact.callTargetImportc = false
    fact.callPrefixStyle = false
    fact.callArgCount = 0
    fact.callArgsText = ""
    fact.typeText = "unknown"
    fact.abiClass = TypedExprAbiPolymorphic
    fact.valueKind = TypedExprValuePolymorphic
    fact.placeKind = TypedExprPlaceTemporary
    fact.loweringMode = TypedExprLowerDeferred
    fact.callKind = TypedExprCallKindForExpr(expr)
    fact.typeCallKind = TypedExprTypeCallKindForExpr(expr)
    fact.returnKind = TypedExprReturnDeferred
    let sink = TypedExprSinkForExpr(ctx, expr)
    let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, expr.lineNumber)
    let sourceResultType = TypedExprInferredResultInputType(ctx, scopeIndex, expr)
    if expr.kind == parser.NormalizedExprRange:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "range", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprComprehension:
        let sinkType = sink.sinkType
        if parser.ParserStartsWith(sinkType, "seq[") || (sinkType.len >= 2 && chengpath.TextSlice(sinkType, sinkType.len - 2, 2) == "[]"):
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sinkType, sink, false)
            return fact
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "seq[unknown]", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprStrFormat:
        TypedExprApplyResolvedType(fact, ctx, sourceContexts, "str", sink, false)
        return fact
    if expr.kind == parser.NormalizedExprIf:
        if sink.hasSink && sink.sinkType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
            return fact
        let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
        let trimmed = chengpath.PathTrim(lineRaw)
        if parser.ParserStartsWith(trimmed, "if ") || TypedExprComprehensionFilterIf(lineRaw, expr):
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "bool", sink, false)
            return fact
        fact.typeText = "branch_join"
        return fact
    if expr.kind == parser.NormalizedExprTry:
        let innerType = TypedExprResultSuccessType(sourceResultType)
        if innerType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, innerType, sink, true)
            return fact
        let returnInnerType = TypedExprResultSuccessType(sink.functionReturnType)
        if returnInnerType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, returnInnerType, sink, true)
            return fact
        if sink.hasSink && sink.sinkType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, true)
            return fact
        fact.typeText = "result_projection"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    if expr.kind == parser.NormalizedExprResultIntrinsic:
        let lineRaw = TypedExprSourceLine(ctx, expr.lineNumber)
        if expr.detailKind == parser.NormalizedExprDetailResultOk ||
           expr.detailKind == parser.NormalizedExprDetailResultErr:
            let genericInner = TypedExprExtractGenericArg(lineRaw, expr.columnNumber, expr.surfaceText)
            if genericInner != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, TypedExprResultType(genericInner), sink, false)
                return fact
            if sink.hasSink && parser.ParserStartsWith(sink.sinkType, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
                return fact
            let returnResult = sink.functionReturnType
            if parser.ParserStartsWith(returnResult, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, returnResult, sink, false)
                return fact
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "Result[unknown]", sink, false)
            return fact
        if expr.detailKind == parser.NormalizedExprDetailResultIsOk ||
           expr.detailKind == parser.NormalizedExprDetailResultIsErr:
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "bool", sink, true)
            return fact
        if expr.detailKind == parser.NormalizedExprDetailResultError:
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "str", sink, true)
            return fact
        if expr.detailKind == parser.NormalizedExprDetailResultErrorInfoOf:
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "ErrorInfo", sink, true)
            return fact
        let genericInner = TypedExprExtractGenericArg(lineRaw, expr.columnNumber, expr.surfaceText)
        if genericInner != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, genericInner, sink, true)
            return fact
        let innerType = TypedExprResultSuccessType(sourceResultType)
        if innerType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, innerType, sink, true)
            return fact
        if sink.hasSink && sink.sinkType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, true)
            return fact
        fact.typeText = "result_projection"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    if expr.kind == parser.NormalizedExprDefaultInit:
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        let defaultInitType = parser.NormalizedExprDefaultInitType(expr)
        if defaultInitType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, defaultInitType, sink, false)
            return fact
        fact.typeText = "default_init_expr"
        return fact
    if expr.kind == parser.NormalizedExprConstructor:
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        let constructorType = parser.NormalizedExprConstructorType(expr)
        let constructorName = parser.ParserIdentPrefix(constructorType)
        if constructorName == "Ok" || constructorName == "Err":
            let genericInner = TypedExprExtractTypeGenericArg(constructorType)
            if genericInner != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, TypedExprResultType(genericInner), sink, false)
                return fact
            if sink.hasSink && parser.ParserStartsWith(sink.sinkType, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.sinkType, sink, false)
                return fact
            if parser.ParserStartsWith(sink.functionReturnType, "Result["):
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, sink.functionReturnType, sink, false)
                return fact
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "Result[unknown]", sink, false)
            return fact
        if constructorType != "":
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, constructorType, sink, false)
            return fact
        fact.typeText = "constructor_expr"
        return fact
    if expr.kind == parser.NormalizedExprCall:
        fact.surfaceCallKind = TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind)
        fact.callResolved = expr.callResolved
        fact.callReason = TypedExprCallReasonFromParser(expr.callReason)
        fact.callQualifier = expr.callQualifier
        fact.callCallee = expr.callCallee
        fact.callTarget = expr.callTarget
        fact.callTargetSourcePath = expr.callTargetSourcePath
        fact.callTargetImportc = expr.callTargetImportc
        fact.callPrefixStyle = expr.callPrefixStyle
        fact.callArgCount = expr.callArgCount
        fact.callArgsText = expr.callArgsText
        if TypedExprExprIsBuiltinStringifyCall(expr):
            fact.callResolved = true
            fact.callReason = TypedExprCallReasonNone
            TypedExprApplyResolvedType(fact, ctx, sourceContexts, "str", sink, true)
            return fact
        let detailReturnType = TypedExprLookupCallTargetReturnTypeFromFact(sourceContexts, fact)
        if detailReturnType != "":
            let targetCtx = TypedExprSourceContextForPathOrCurrent(ctx,
                                                                     sourceContexts,
                                                                     fact.callTargetSourcePath)
            TypedExprApplyResolvedType(fact, targetCtx, sourceContexts, detailReturnType, sink, true)
            if fact.callTargetImportc && fact.abiClass == TypedExprAbiComposite:
                fact.loweringMode = TypedExprLowerImportBuffer
                fact.returnKind = TypedExprReturnImportBuffer
            return fact
        if fact.surfaceCallKind == TypedExprSurfaceCallImportc:
            let importReturnType = TypedExprLookupImportcReturnTypeFromContexts(sourceContexts, fact.callTarget)
            if importReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, importReturnType, sink, true)
                if fact.abiClass == TypedExprAbiComposite:
                    fact.loweringMode = TypedExprLowerImportBuffer
                    fact.returnKind = TypedExprReturnImportBuffer
                return fact
        elif fact.surfaceCallKind == TypedExprSurfaceCallLocal:
            let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, fact.callTarget)
            if localReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, localReturnType, sink, true)
                return fact
        elif fact.surfaceCallKind == TypedExprSurfaceCallExternal:
            let externalReturnType = TypedExprLookupExternalFunctionReturnTypeFromContexts(ctx,
                                                                                             sourceContexts,
                                                                                             fact.callQualifier,
                                                                                             fact.callCallee)
            if externalReturnType != "":
                let targetSourcePath = TypedExprLookupQualifiedModuleSourcePath(ctx,
                                                                                  sourceContexts,
                                                                                  fact.callQualifier)
                let targetCtx = TypedExprSourceContextForPathOrCurrent(ctx,
                                                                         sourceContexts,
                                                                         targetSourcePath)
                TypedExprApplyResolvedType(fact, targetCtx, sourceContexts, externalReturnType, sink, true)
                return fact
        else:
            let localReturnType = TypedExprLookupLocalFunctionReturnType(ctx, fact.callTarget)
            if localReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, localReturnType, sink, true)
                return fact
            let importReturnType = TypedExprLookupImportcReturnTypeFromContexts(sourceContexts, fact.callTarget)
            if importReturnType != "":
                TypedExprApplyResolvedType(fact, ctx, sourceContexts, importReturnType, sink, true)
                if fact.abiClass == TypedExprAbiComposite:
                    fact.loweringMode = TypedExprLowerImportBuffer
                    fact.returnKind = TypedExprReturnImportBuffer
                return fact
        fact.typeText = "call_expr"
        fact.placeKind = TypedExprPlaceCallResult
        return fact
    return fact

fn TypedExprBuildSourceContext(source: TypedExprSourceText,
                                 ctx: var TypedExprSourceContext,
                                 err: var str): bool =
    ctx.sourcePath = source.sourcePath
    ctx.lines = parser.ParserSplitChar(source.text, '\n')
    ctx.scopes = []
    ctx.bindings = []
    ctx.importcFunctions = []
    ctx.importedModules = []
    ctx.declaredTypes = []
    ctx.exprLineColumns = []
    for i in 0..<ctx.lines.len:
        var lineExprColumns: TypedExprLineExprColumns
        lineExprColumns.columns = []
        add(ctx.exprLineColumns, lineExprColumns)
    var decls: parser.NormalizedFunctionDecl[]
    if !parser.ParserReadNormalizedFunctionDecls(source.text, decls, err):
        return false
    for i in 0..<decls.len:
        let decl = decls[i]
        if decl.importc:
            if decl.lineIndex > 0 && decl.lineIndex <= ctx.lines.len:
                var importcFn: TypedExprImportcFunction
                importcFn.sourcePath = source.sourcePath
                importcFn.name = decl.name
                importcFn.returnType = TypedExprParseFunctionReturnType(ctx.lines[decl.lineIndex - 1])
                add(ctx.importcFunctions, importcFn)
            continue
        if decl.lineIndex <= 0 || decl.lineIndex > ctx.lines.len:
            continue
        var scope: TypedExprFunctionScope
        scope.sourcePath = source.sourcePath
        scope.name = decl.name
        scope.startLine = decl.lineIndex
        if i + 1 < decls.len:
            scope.endLine = decls[i + 1].lineIndex - 1
        else:
            scope.endLine = ctx.lines.len
        scope.returnType = TypedExprParseFunctionReturnType(ctx.lines[decl.lineIndex - 1])
        add(ctx.scopes, scope)
        TypedExprAppendParamBindings(ctx.bindings, scope, ctx.lines[decl.lineIndex - 1])
    for i in 0..<ctx.lines.len:
        var bindingName = ""
        var bindingType = ""
        var rhsStartColumn: int32 = -1
        if !TypedExprParseBindingLine(ctx.lines[i], bindingName, bindingType, rhsStartColumn):
            continue
        let lineNumber = i + 1
        let scopeIndex = TypedExprScopeIndexForLine(ctx.scopes, lineNumber)
        if scopeIndex >= 0:
            TypedExprMaybeAddBinding(ctx.bindings,
                                       source.sourcePath,
                                       ctx.scopes[scopeIndex].name,
                                       false,
                                       lineNumber,
                                       bindingName,
                                       bindingType)
        else:
            TypedExprMaybeAddBinding(ctx.bindings,
                                       source.sourcePath,
                                       "",
                                       true,
                                       lineNumber,
                                       bindingName,
                                       bindingType)
    var inTypeBlock = false
    for i in 0..<ctx.lines.len:
        let rawLine = ctx.lines[i]
        let trimmed = chengpath.PathTrim(parser.ParserStripLineComment(rawLine))
        if !parser.ParserHasLeadingIndent(rawLine):
            if trimmed == "":
                continue
            inTypeBlock = trimmed == "type"
            continue
        if !inTypeBlock:
            continue
        let declaredType = TypedExprParseTypeDeclName(trimmed)
        if declaredType == "":
            continue
        if parser.ParserStringSeqContainsExact(ctx.declaredTypes, declaredType):
            continue
        add(ctx.declaredTypes, declaredType)
    if source.workspaceRoot != "" && source.packageRoot != "":
        let ownerModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(source.workspaceRoot,
                                                                                             source.packageRoot,
                                                                                             source.externalPackageRoots,
                                                                                             source.sourcePath)
        var importEdges: parser.ImportEdge[]
        if !parser.ParserReadImportEdgesWithExternalPackageRoots(source.workspaceRoot,
                                                                   source.packageRoot,
                                                                   source.externalPackageRoots,
                                                                   ownerModulePath,
                                                                   source.text,
                                                                   importEdges,
                                                                   err):
            return false
        for i in 0..<importEdges.len:
            if !importEdges[i].resolved:
                continue
            let qualifier = parser.ParserImportEdgeQualifier(importEdges[i])
            if qualifier == "":
                continue
            var importedModule: TypedExprImportedModule
            importedModule.qualifier = qualifier
            importedModule.targetSourcePath = parser.ParserNormalizePath(importEdges[i].targetSourcePath)
            add(ctx.importedModules, importedModule)
    err = ""
    return true

fn TypedExprPopulateSourceExprLineColumns(contexts: var TypedExprSourceContext[],
                                            exprLayer: parser.NormalizedExprLayer,
                                            err: var str): bool =
    for i in 0..<exprLayer.exprs.len:
        let expr = exprLayer.exprs[i]
        let ctxIndex = TypedExprSourceContextLookup(contexts, expr.sourcePath)
        if ctxIndex < 0:
            err = " typed expr: missing source context"
            return false
        if expr.lineNumber <= 0 || expr.lineNumber > contexts[ctxIndex].exprLineColumns.len:
            err = " typed expr: expr line out of range"
            return false
        let lineIndex = expr.lineNumber - 1
        var lineExprColumns = contexts[ctxIndex].exprLineColumns[lineIndex]
        var shouldAppend = true
        if lineExprColumns.columns.len > 0:
            shouldAppend = lineExprColumns.columns[lineExprColumns.columns.len - 1] != expr.columnNumber
        if shouldAppend:
            add(lineExprColumns.columns, expr.columnNumber)
            contexts[ctxIndex].exprLineColumns[lineIndex] = lineExprColumns
    err = ""
    return true

fn TypedExprBuildFacts(sourceTexts: TypedExprSourceText[],
                         exprLayer: parser.NormalizedExprLayer,
                         facts: var TypedExprFact[],
                         err: var str): bool =
    var emptyFacts: TypedExprFact[]
    facts = emptyFacts
    var contexts: TypedExprSourceContext[]
    for i in 0..<sourceTexts.len:
        var ctx: TypedExprSourceContext
        if !TypedExprBuildSourceContext(sourceTexts[i], ctx, err):
            err = " typed expr: build source context failed"
            return false
        add(contexts, ctx)
    if !TypedExprPopulateSourceExprLineColumns(contexts, exprLayer, err):
        return false
    for i in 0..<exprLayer.exprs.len:
        let expr = exprLayer.exprs[i]
        let ctxIndex = TypedExprSourceContextLookup(contexts, expr.sourcePath)
        if ctxIndex < 0:
            err = " typed expr: missing source context"
            return false
        add(facts, TypedExprBuildFact(contexts[ctxIndex], contexts, expr))
    var validateErr = ""
    if !TypedExprFactsValidateCallResolution(exprLayer, facts, validateErr):
        err = validateErr
        return false
    err = ""
    return true
