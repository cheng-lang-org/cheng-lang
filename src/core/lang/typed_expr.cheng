fn TypedExprIrReportText(ir: var TypedExprIr): str =
    var out = ""
    TypedExprReportAppendLine(out, "typed_ir_function_count", IntToStr(ir.functions.len))
    TypedExprReportAppendLine(out, "typed_ir_statement_count", IntToStr(ir.statements.len))
    TypedExprReportAppendLine(out, "typed_ir_global_count", IntToStr(ir.globalNames.len))
