    TypedExprReportAppendLine(out, "typed_expr_return_root_count", IntToStr(TypedExprReturnRootCount(facts)))
    return out

fn TypedExprReturnOpFactsReportText(facts: TypedExprReturnOpFact[]): str =
    var out = ""
    TypedExprReportAppendLine(out, "typed_return_op_count", IntToStr(facts.len))
    TypedExprReportAppendLine(out, "typed_return_op_kinds", TypedExprReturnOpFactsKindListText(facts))
    TypedExprReportAppendLine(out, "typed_return_op_i32_add_count", IntToStr(TypedExprReturnOpFactsCountKind(facts, TypedExprReturnOpI32AddArgs)))
    TypedExprReportAppendLine(out, "typed_return_op_i32_sub_count", IntToStr(TypedExprReturnOpFactsCountKind(facts, TypedExprReturnOpI32SubArgs)))
    TypedExprReportAppendLine(out, "typed_return_op_i32_mul_count", IntToStr(TypedExprReturnOpFactsCountKind(facts, TypedExprReturnOpI32MulArgs)))
    TypedExprReportAppendLine(out, "typed_return_op_i32_asr_count", IntToStr(TypedExprReturnOpFactsCountKind(facts, TypedExprReturnOpI32AsrArgs)))
    TypedExprReportAppendLine(out, "typed_return_op_i32_madd_count", IntToStr(TypedExprReturnOpFactsCountKind(facts, TypedExprReturnOpI32MaddArgs)))
