    out.surfaceText = node.surfaceText
    out.paramSlot = node.paramSlot
    out.paramName = node.paramName
    out.operand0NodeIndex = node.operand0NodeIndex
    out.operand1NodeIndex = node.operand1NodeIndex
    out.operand2NodeIndex = node.operand2NodeIndex
    out.literalText = node.literalText
    return out

fn TypedExprIrStatementClone(stmt: TypedExprIrStatement): TypedExprIrStatement =
    var out: TypedExprIrStatement
    out.sourcePath = stmt.sourcePath
    out.functionName = stmt.functionName
    out.statementIndex = stmt.statementIndex
    out.lineNumber = stmt.lineNumber
    out.columnNumber = stmt.columnNumber
    out.lineIndent = stmt.lineIndent
    out.enclosingIfLineNumber = stmt.enclosingIfLineNumber
    out.enclosingIfConditionText = stmt.enclosingIfConditionText
    out.exprId = stmt.exprId
    out.kind = stmt.kind
    out.callKind = stmt.callKind
    out.detailKind = stmt.detailKind
    out.surfaceText = stmt.surfaceText
    out.bindingName = stmt.bindingName
    out.resultType = stmt.resultType
    out.conditionKind = stmt.conditionKind
    out.conditionLhsText = stmt.conditionLhsText
    out.conditionRhsText = stmt.conditionRhsText
    out.conditionLiteralText = stmt.conditionLiteralText
    out.assignRootName = stmt.assignRootName
    out.assignRootType = stmt.assignRootType
    out.assignRootSourcePath = stmt.assignRootSourcePath
    out.assignRootGlobalFlag = stmt.assignRootGlobalFlag
    out.assignPlaceKind = stmt.assignPlaceKind
    out.assignFieldName = stmt.assignFieldName
    out.assignFieldType = stmt.assignFieldType
    out.assignFieldOffsetBytes = stmt.assignFieldOffsetBytes
    out.assignFieldSizeBytes = stmt.assignFieldSizeBytes
    out.assignFieldAlignBytes = stmt.assignFieldAlignBytes
    out.assignValueRootName = stmt.assignValueRootName
    out.assignValueRootType = stmt.assignValueRootType
    out.assignValueFieldName = stmt.assignValueFieldName
    out.assignValueFieldType = stmt.assignValueFieldType
    out.assignValueFieldOffsetBytes = stmt.assignValueFieldOffsetBytes
    out.assignValueFieldSizeBytes = stmt.assignValueFieldSizeBytes
    out.assignValueFieldAlignBytes = stmt.assignValueFieldAlignBytes
    out.assignValueOpKind = stmt.assignValueOpKind
    out.assignValueLhsText = stmt.assignValueLhsText
    out.assignValueRhsText = stmt.assignValueRhsText
    out.assignValueRhsConst = stmt.assignValueRhsConst
    out.assignValueRhsHasConst = stmt.assignValueRhsHasConst
    out.callQualifier = stmt.callQualifier
    out.callCallee = stmt.callCallee
    out.callTarget = stmt.callTarget
    out.callTargetSourcePath = stmt.callTargetSourcePath
    out.callTargetImportc = stmt.callTargetImportc
    out.callArgCount = stmt.callArgCount
    out.callArgsText = stmt.callArgsText
    out.callArgTypesText = stmt.callArgTypesText
    out.callArgNodeStart = stmt.callArgNodeStart
    out.callArgNodeCount = stmt.callArgNodeCount
    out.loweringMode = stmt.loweringMode
    out.returnKind = stmt.returnKind
    out.returnRoot = stmt.returnRoot
