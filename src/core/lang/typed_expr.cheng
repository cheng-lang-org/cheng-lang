        TypedExprIrOpReturnStrArg0
        TypedExprIrOpI32Const
        TypedExprIrOpI32Add
        TypedExprIrOpI32Sub
        TypedExprIrOpI32Mul
        TypedExprIrOpI32Asr
        TypedExprIrOpI32Madd
