fn TypedExprIrFunctionClone(fnIr: TypedExprIrFunction): TypedExprIrFunction =
    var out: TypedExprIrFunction
    out.sourcePath = fnIr.sourcePath
    out.functionName = fnIr.functionName
    out.signatureLineNumber = fnIr.signatureLineNumber
    out.endLineNumber = fnIr.endLineNumber
    out.bodyLineNumber = fnIr.bodyLineNumber
    out.returnType = fnIr.returnType
    out.returnExpr = fnIr.returnExpr
    out.statementStart = fnIr.statementStart
    out.statementCount = fnIr.statementCount
    out.nodeStart = fnIr.nodeStart
    out.nodeCount = fnIr.nodeCount
    out.returnNodeIndex = fnIr.returnNodeIndex
    return out

fn TypedExprIrClone(ir: var TypedExprIr): TypedExprIr =
    var out: TypedExprIr
    for i in 0..<ir.functions.len:
        add(out.functions, TypedExprIrFunctionClone(ir.functions[i]))
    for i in 0..<ir.statements.len:
        add(out.statements, TypedExprIrStatementClone(ir.statements[i]))
    for i in 0..<ir.nodes.len:
        add(out.nodes, TypedExprIrNodeClone(ir.nodes[i]))
    for i in 0..<ir.globalSourcePaths.len:
        add(out.globalSourcePaths, ir.globalSourcePaths[i])
    for i in 0..<ir.globalNames.len:
        add(out.globalNames, ir.globalNames[i])
    for i in 0..<ir.globalTypes.len:
        add(out.globalTypes, ir.globalTypes[i])
    for i in 0..<ir.importcSourcePaths.len:
        add(out.importcSourcePaths, ir.importcSourcePaths[i])
    for i in 0..<ir.importcNames.len:
        add(out.importcNames, ir.importcNames[i])
    for i in 0..<ir.importcReturnTypes.len:
        add(out.importcReturnTypes, ir.importcReturnTypes[i])
    for i in 0..<ir.typeLayoutSourcePaths.len:
        add(out.typeLayoutSourcePaths, ir.typeLayoutSourcePaths[i])
    for i in 0..<ir.typeLayoutNames.len:
        add(out.typeLayoutNames, ir.typeLayoutNames[i])
    for i in 0..<ir.typeLayoutSizeBytes.len:
        add(out.typeLayoutSizeBytes, ir.typeLayoutSizeBytes[i])
    for i in 0..<ir.typeLayoutAlignBytes.len:
        add(out.typeLayoutAlignBytes, ir.typeLayoutAlignBytes[i])
    for i in 0..<ir.typeLayoutFieldCounts.len:
        add(out.typeLayoutFieldCounts, ir.typeLayoutFieldCounts[i])
    for i in 0..<ir.typeFieldSourcePaths.len:
        add(out.typeFieldSourcePaths, ir.typeFieldSourcePaths[i])
    for i in 0..<ir.typeFieldOwnerTypes.len:
        add(out.typeFieldOwnerTypes, ir.typeFieldOwnerTypes[i])
    for i in 0..<ir.typeFieldNames.len:
        add(out.typeFieldNames, ir.typeFieldNames[i])
    for i in 0..<ir.typeFieldTypes.len:
        add(out.typeFieldTypes, ir.typeFieldTypes[i])
    for i in 0..<ir.typeFieldOffsetBytes.len:
        add(out.typeFieldOffsetBytes, ir.typeFieldOffsetBytes[i])
    for i in 0..<ir.typeFieldSizeBytes.len:
        add(out.typeFieldSizeBytes, ir.typeFieldSizeBytes[i])
    for i in 0..<ir.typeFieldAlignBytes.len:
        add(out.typeFieldAlignBytes, ir.typeFieldAlignBytes[i])
    for i in 0..<ir.enumValueSourcePaths.len:
        add(out.enumValueSourcePaths, ir.enumValueSourcePaths[i])
    for i in 0..<ir.enumValueNames.len:
        add(out.enumValueNames, ir.enumValueNames[i])
    for i in 0..<ir.enumValueTypes.len:
        add(out.enumValueTypes, ir.enumValueTypes[i])
    for i in 0..<ir.enumValueOrdinals.len:
        add(out.enumValueOrdinals, ir.enumValueOrdinals[i])
    return out

fn TypedExprReturnOpFactClone(fact: TypedExprReturnOpFact): TypedExprReturnOpFact =
    var out: TypedExprReturnOpFact
    out.sourcePath = fact.sourcePath
    out.functionName = fact.functionName
    out.signatureLineNumber = fact.signatureLineNumber
    out.bodyLineNumber = fact.bodyLineNumber
    out.opKind = fact.opKind
    out.returnType = fact.returnType
    out.lhsName = fact.lhsName
    out.lhsType = fact.lhsType
    out.rhsName = fact.rhsName
    out.rhsType = fact.rhsType
    out.accName = fact.accName
    out.accType = fact.accType
    out.returnExpr = fact.returnExpr
    return out

fn TypedExprReturnOpFactsClone(facts: TypedExprReturnOpFact[]): TypedExprReturnOpFact[] =
    var out: TypedExprReturnOpFact[]
    for i in 0..<facts.len:
        add(out, TypedExprReturnOpFactClone(facts[i]))
    return out

fn TypedExprReturnOpFactsCountKind(facts: TypedExprReturnOpFact[],
                                    kind: TypedExprReturnOpKind): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].opKind == kind:
            count = count + 1
    return count

fn TypedExprReturnOpFactsKindListText(facts: TypedExprReturnOpFact[]): str =
    if facts.len <= 0:
        return "-"
    var out = ""
    for i in 0..<facts.len:
        if i > 0:
            out = strutil.Join([out, ","], "")
        out = strutil.Join([out, TypedExprReturnOpKindText(facts[i].opKind)], "")
    return out

fn TypedExprIrCountOpKind(ir: var TypedExprIr,
                           kind: TypedExprIrOpKind): int32 =
    var count: int32
    for i in 0..<ir.nodes.len:
        if ir.nodes[i].opKind == kind:
            count = count + 1
    return count

fn TypedExprIrCountStatementKind(ir: var TypedExprIr,
                                  kind: TypedExprIrStatementKind): int32 =
    var count: int32
    for i in 0..<ir.statements.len:
        if ir.statements[i].kind == kind:
            count = count + 1
    return count

fn TypedExprIrReturnCountOpKind(ir: var TypedExprIr,
                                 kind: TypedExprIrOpKind): int32 =
    var count: int32
    for i in 0..<ir.functions.len:
        let returnIndex = ir.functions[i].returnNodeIndex
        if returnIndex < 0 || returnIndex >= ir.nodes.len:
            continue
        if ir.nodes[returnIndex].opKind == kind:
            count = count + 1
    return count

fn TypedExprIrReturnKindListText(ir: var TypedExprIr): str =
    var out = ""
    for i in 0..<ir.functions.len:
        let returnIndex = ir.functions[i].returnNodeIndex
        if returnIndex < 0 || returnIndex >= ir.nodes.len:
            continue
        let kind = ir.nodes[returnIndex].opKind
        if kind == TypedExprIrOpUnsupported || kind == TypedExprIrOpParamRef:
            continue
        if Len(out) > 0:
            out = strutil.Join([out, ","], "")
        out = strutil.Join([out, TypedExprIrOpKindText(kind)], "")
    if Len(out) <= 0:
        return "-"
    return out

fn TypedExprImportKindForResolved(callKind: TypedExprCallKind,
                                    abiClass: TypedExprAbiClass,
                                    loweringMode: TypedExprLoweringMode,
                                    returnKind: TypedExprReturnKind): TypedExprImportKind =
    if loweringMode == TypedExprLowerDeferred || abiClass == TypedExprAbiPolymorphic:
        return TypedExprImportDeferred
    if loweringMode == TypedExprLowerImportBuffer || returnKind == TypedExprReturnImportBuffer:
        return TypedExprImportImportBuffer
    if callKind == TypedExprCallBuiltin:
        if abiClass == TypedExprAbiComposite:
            return TypedExprImportBuiltinAddressSlot
        return TypedExprImportBuiltinValueSlot
    if abiClass == TypedExprAbiComposite:
        return TypedExprImportI32AddressSlot
    return TypedExprImportI32ValueSlot

fn TypedExprExprIsBuiltinStringifyCall(expr: parser.NormalizedExpr): bool =
    if expr.kind != parser.NormalizedExprCall:
        return false
    if expr.callCallee == "$" || expr.callTarget == "$":
        return true
    return false

fn TypedExprBuiltinTypeCallResult(expr: parser.NormalizedExpr): str =
    if expr.kind != parser.NormalizedExprCall:
        return ""
    if chengpath.PathTrim(expr.callQualifier) != "":
        return ""
    let callee = chengpath.PathTrim(expr.callCallee)
    if callee == "len" || callee == "Len":
        return "int32"
    if callee == "bool" ||
       callee == "char" ||
       callee == "int8" ||
       callee == "int16" ||
       callee == "int32" ||
       callee == "int64" ||
       callee == "uint8" ||
       callee == "uint16" ||
       callee == "uint32" ||
       callee == "uint64" ||
       callee == "float32" ||
       callee == "float64" ||
       callee == "str" ||
       callee == "cstring":
        return callee
    if callee == "new" && expr.callArgCount == 1:
        let typeText = TypedExprNormalizeTypeText(expr.callArgsText)
        if typeText != "":
            return Fmt"ref{typeText}"
    return ""

fn TypedExprExprIsBuiltinCall(expr: parser.NormalizedExpr): bool =
    if TypedExprExprIsBuiltinStringifyCall(expr):
        return true
    return TypedExprBuiltinTypeCallResult(expr) != ""

fn TypedExprCallKindForExpr(expr: parser.NormalizedExpr): TypedExprCallKind =
    if expr.kind == parser.NormalizedExprStrFormat:
        return TypedExprCallBuiltin
    if TypedExprExprIsBuiltinCall(expr):
        return TypedExprCallBuiltin
    if expr.kind == parser.NormalizedExprResultIntrinsic:
        return TypedExprCallResultIntrinsic
    if expr.kind == parser.NormalizedExprTry:
        return TypedExprCallProjection
    return TypedExprCallNone

fn TypedExprTypeCallKindForExpr(expr: parser.NormalizedExpr): TypedExprTypeCallKind =
    if expr.kind == parser.NormalizedExprDefaultInit:
        return TypedExprTypeCallDefaultInit
    if expr.kind == parser.NormalizedExprConstructor:
        return TypedExprTypeCallConstructor
    return TypedExprTypeCallNone

fn TypedExprReturnKindForResolved(abiClass: TypedExprAbiClass,
                                    loweringMode: TypedExprLoweringMode): TypedExprReturnKind =
    if loweringMode == TypedExprLowerSret:
        return TypedExprReturnSret
    if loweringMode == TypedExprLowerImportBuffer:
        return TypedExprReturnImportBuffer
    if loweringMode == TypedExprLowerDeferred || abiClass == TypedExprAbiPolymorphic:
        return TypedExprReturnDeferred
    if abiClass == TypedExprAbiComposite:
        return TypedExprReturnCompositeLocal
    return TypedExprReturnReg

fn TypedExprFactClone(fact: TypedExprFact): TypedExprFact =
    var out: TypedExprFact
    out.exprId = fact.exprId
    out.sourcePath = fact.sourcePath
    out.lineNumber = fact.lineNumber
    out.columnNumber = fact.columnNumber
    out.endLineNumber = fact.endLineNumber
    out.endColumnNumber = fact.endColumnNumber
    out.kind = fact.kind
    out.surfaceCallKind = fact.surfaceCallKind
    out.callResolved = fact.callResolved
    out.callReason = fact.callReason
    out.callQualifier = fact.callQualifier
    out.callCallee = fact.callCallee
    out.callTarget = fact.callTarget
    out.callTargetSourcePath = fact.callTargetSourcePath
    out.callTargetImportc = fact.callTargetImportc
    out.callPrefixStyle = fact.callPrefixStyle
    out.callArgCount = fact.callArgCount
    out.callArgsText = fact.callArgsText
    out.typeText = fact.typeText
    out.abiClass = fact.abiClass
    out.valueKind = fact.valueKind
    out.placeKind = fact.placeKind
    out.hasSink = fact.hasSink
    out.sinkPlaceKind = fact.sinkPlaceKind
    out.loweringMode = fact.loweringMode
    out.callKind = fact.callKind
    out.typeCallKind = fact.typeCallKind
    out.returnKind = fact.returnKind
    out.returnRoot = fact.returnRoot
    return out

fn TypedExprFactsClone(facts: var TypedExprFact[]): TypedExprFact[] =
    var out: TypedExprFact[]
    for i in 0..<facts.len:
        add(out, TypedExprFactClone(facts[i]))
    return out

fn TypedExprFactEqual(lhs: TypedExprFact,
                        rhs: TypedExprFact): bool =
    if lhs.exprId != rhs.exprId:
        return false
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.lineNumber != rhs.lineNumber:
        return false
    if lhs.columnNumber != rhs.columnNumber:
        return false
    if lhs.endLineNumber != rhs.endLineNumber:
        return false
    if lhs.endColumnNumber != rhs.endColumnNumber:
        return false
    if lhs.kind != rhs.kind:
        return false
    if lhs.surfaceCallKind != rhs.surfaceCallKind:
        return false
    if lhs.callResolved != rhs.callResolved:
        return false
    if lhs.callReason != rhs.callReason:
        return false
    if lhs.callQualifier != rhs.callQualifier:
        return false
    if lhs.callCallee != rhs.callCallee:
        return false
    if lhs.callTarget != rhs.callTarget:
        return false
    if lhs.callTargetSourcePath != rhs.callTargetSourcePath:
        return false
    if lhs.callTargetImportc != rhs.callTargetImportc:
        return false
    if lhs.callPrefixStyle != rhs.callPrefixStyle:
        return false
    if lhs.callArgCount != rhs.callArgCount:
        return false
    if lhs.callArgsText != rhs.callArgsText:
        return false
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.hasSink != rhs.hasSink:
        return false
    if lhs.sinkPlaceKind != rhs.sinkPlaceKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    if lhs.returnKind != rhs.returnKind:
        return false
    return lhs.returnRoot == rhs.returnRoot

fn TypedExprFactsEqual(lhs: TypedExprFact[],
                         rhs: TypedExprFact[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !TypedExprFactEqual(lhs[i], rhs[i]):
            return false
    return true

fn TypedExprFactCountAbiClass(facts: var TypedExprFact[],
                                abiClass: TypedExprAbiClass): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].abiClass == abiClass:
            count = count + 1
    return count

