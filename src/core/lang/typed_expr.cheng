fn TypedExprSurfaceCallCount(facts: var TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind != TypedExprSurfaceCallNone:
            count = count + 1
    return count

fn TypedExprFactCountCallReasonFromParser(facts: var TypedExprFact[],
                                            reason: parser.NormalizedExprCallReason): int32 =
    return TypedExprFactCountCallReason(facts, TypedExprCallReasonFromParser(reason))

fn TypedExprFactsForSource(facts: var TypedExprFact[],
                             sourcePathRaw: str): TypedExprFact[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    var out: TypedExprFact[]
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        add(out, TypedExprFactClone(facts[i]))
    return out

fn TypedExprSourceRangeIndexAdd(index: var TypedExprSourceRangeIndex,
                                 sourcePathRaw: str,
                                 startIndex: int32,
                                 endIndex: int32) =
    add(index.sourcePaths, parser.ParserNormalizePath(sourcePathRaw))
    add(index.starts, startIndex)
    add(index.ends, endIndex)

fn TypedExprSourceRangeIndexFind(index: var TypedExprSourceRangeIndex,
                                  sourcePathRaw: str): int32 =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<index.sourcePaths.len:
        if index.sourcePaths[i] == sourcePath:
            return i
    return -1

fn TypedExprSourceRangeIndexBuildFromFacts(facts: var TypedExprFact[]): TypedExprSourceRangeIndex =
    var index: TypedExprSourceRangeIndex
    index.sourcePaths = []
    index.starts = []
    index.ends = []
    var cursor: int32
    while cursor < facts.len:
        let sourcePath = parser.ParserNormalizePath(facts[cursor].sourcePath)
        var endIndex = cursor + 1
        while endIndex < facts.len:
            if parser.ParserNormalizePath(facts[endIndex].sourcePath) != sourcePath:
                break
            endIndex = endIndex + 1
        TypedExprSourceRangeIndexAdd(index, sourcePath, cursor, endIndex)
        cursor = endIndex
    return index

fn TypedExprFactUsesImportBuffer(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerImportBuffer &&
           fact.returnKind == TypedExprReturnImportBuffer

fn TypedExprFactUsesLocalAddressCompositeLocal(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerLocalAddress &&
           fact.returnKind == TypedExprReturnCompositeLocal

fn TypedExprFactUsesRegReturnReg(fact: TypedExprFact): bool =
    return fact.loweringMode == TypedExprLowerReg &&
           fact.returnKind == TypedExprReturnReg

fn TypedExprFactUsesTypeCallMaterialize(fact: TypedExprFact): bool =
    return fact.typeCallKind == TypedExprTypeCallDefaultInit ||
           fact.typeCallKind == TypedExprTypeCallConstructor

fn TypedExprFactAbiIsPolymorphic(fact: TypedExprFact): bool =
    return fact.abiClass == TypedExprAbiPolymorphic

fn TypedExprTypeTextIsConcrete(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText == "":
        return false
    if typeText == "unknown" ||
       typeText == "default_init_expr" ||
       typeText == "constructor_expr" ||
       typeText == "call_expr" ||
       typeText == "branch_join" ||
       typeText == "result_projection":
        return false
    return parser.ParserFindText(typeText, "unknown") < 0

fn TypedExprFactValidateTypeCallMaterialize(fact: TypedExprFact,
                                              err: var str): bool =
    if fact.typeCallKind == TypedExprTypeCallNone:
        return true
    if fact.kind != parser.NormalizedExprDefaultInit &&
       fact.kind != parser.NormalizedExprConstructor:
        err = Fmt" typed expr: type-call fact kind drift at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.callKind != TypedExprCallNone:
        err = Fmt" typed expr: type-call fact leaked ordinary call kind at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if !TypedExprTypeTextIsConcrete(fact.typeText):
        err = Fmt" typed expr: type-call fact missing concrete type at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.abiClass != TypedExprAbiComposite ||
       fact.valueKind != TypedExprValueComposite:
        err = Fmt" typed expr: type-call fact must materialize composite at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.placeKind == TypedExprPlaceCallResult:
        err = Fmt" typed expr: type-call fact cannot use call-result place at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.loweringMode != TypedExprLowerLocalAddress &&
       fact.loweringMode != TypedExprLowerSret:
        err = Fmt" typed expr: type-call fact missing address lowering at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.loweringMode == TypedExprLowerLocalAddress &&
       fact.returnKind != TypedExprReturnCompositeLocal:
        err = Fmt" typed expr: type-call fact local-address return drift at {fact.sourcePath}:{fact.lineNumber}"
        return false
    if fact.loweringMode == TypedExprLowerSret &&
       fact.returnKind != TypedExprReturnSret:
        err = Fmt" typed expr: type-call fact sret return drift at {fact.sourcePath}:{fact.lineNumber}"
        return false
    err = ""
    return true

fn TypedExprFactsHasLineUsingImportBuffer(facts: var TypedExprFact[],
                                            sourcePathRaw: str,
                                            lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesImportBuffer(facts[i]):
            return true
    return false

fn TypedExprFactsHasLineUsingLocalAddressCompositeLocal(facts: var TypedExprFact[],
                                                          sourcePathRaw: str,
                                                          lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesLocalAddressCompositeLocal(facts[i]):
            return true
    return false

fn TypedExprFactsHasLineUsingRegReturnReg(facts: var TypedExprFact[],
                                            sourcePathRaw: str,
                                            lineNumber: int32): bool =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath || facts[i].lineNumber != lineNumber:
            continue
        if TypedExprFactUsesRegReturnReg(facts[i]):
            return true
    return false

fn TypedExprTypeIsGenericPlaceholder(typeRaw: str): bool =
    let typeText = TypedExprNormalizeTypeText(typeRaw)
    if typeText.len == 1 && typeText[0] >= 'A' && typeText[0] <= 'Z':
        return true
    if typeText.len != 4:
        return false
    if chengpath.TextSlice(typeText, 0, 3) != "ref":
        return false
    if typeText[3] < 'A' || typeText[3] > 'Z':
        return false
    return true

fn TypedExprSymbolExportedByCase(name: str): bool =
    if Len(name) <= 0:
        return false
    let ch = name[0]
    return ch >= 'A' && ch <= 'Z'

fn TypedExprSourcePackageRoot(sourcePath: str): str =
    var current = chengpath.PathParentDir(sourcePath)
    for _ in 0..<64:
        if current == "":
            return ""
        let manifestPath = chengpath.PathJoin(current, "cheng-package.toml")
        if chengpath.PathFileExists(manifestPath):
            return current
        let parent = chengpath.PathParentDir(current)
        if parent == "" || parent == current:
            return ""
        current = parent
    return ""

fn TypedExprSourcesSharePackage(leftSourcePath: str,
                                 rightSourcePath: str): bool =
    let leftRoot = TypedExprSourcePackageRoot(leftSourcePath)
    if leftRoot == "":
        return false
    let rightRoot = TypedExprSourcePackageRoot(rightSourcePath)
    if rightRoot == "":
        return false
    let cwd = os.GetCurrentDir()
    let leftAbs = chengpath.PathAbsolute(cwd, leftRoot)
    let rightAbs = chengpath.PathAbsolute(cwd, rightRoot)
    if leftAbs == rightAbs && leftAbs == parser.ParserSharedPackageRoot(leftAbs):
        return true
    let leftPackageId = parser.ParserPackageId(leftRoot)
    let rightPackageId = parser.ParserPackageId(rightRoot)
    if leftPackageId == "" || rightPackageId == "":
        return false
    if leftPackageId != rightPackageId:
        return false
    if leftPackageId != "cheng":
        return true
    let leftSrcPrefix = strutil.Join([chengpath.PathJoin(leftRoot, "src"), "/"], "")
    let rightSrcPrefix = strutil.Join([chengpath.PathJoin(rightRoot, "src"), "/"], "")
    if !chengpath.TextStartsWith(leftSourcePath, leftSrcPrefix):
        return false
    if !chengpath.TextStartsWith(rightSourcePath, rightSrcPrefix):
        return false
    let leftRel = chengpath.TextSlice(leftSourcePath,
                                      Len(leftSrcPrefix),
                                      Len(leftSourcePath) - Len(leftSrcPrefix))
    let rightRel = chengpath.TextSlice(rightSourcePath,
                                       Len(rightSrcPrefix),
                                       Len(rightSourcePath) - Len(rightSrcPrefix))
    var leftSlash: int32 = -1
    var rightSlash: int32 = -1
    for i in 0..<leftRel.len:
        if leftRel[i] == '/' || leftRel[i] == '\\':
            leftSlash = i
            break
    for i in 0..<rightRel.len:
        if rightRel[i] == '/' || rightRel[i] == '\\':
            rightSlash = i
            break
    if leftSlash <= 0 || rightSlash <= 0:
        return leftRel == rightRel
    let leftHead = chengpath.TextSlice(leftRel, 0, leftSlash)
    let rightHead = chengpath.TextSlice(rightRel, 0, rightSlash)
    return leftHead == rightHead

fn TypedExprFactsValidateCallResolution(exprLayer: var parser.NormalizedExprLayer,
                                          sourceContexts: var TypedExprSourceContext[],
                                          facts: var TypedExprFact[],
                                          err: var str): bool =
    if exprLayer.exprs.len != facts.len:
        err = " typed expr: call fact count mismatch"
        return false
    for i in 0..<facts.len:
        let expr = exprLayer.exprs[i]
        let fact = facts[i]
        let expectedTypeCallKind = TypedExprTypeCallKindForExpr(expr)
        if expr.exprId != fact.exprId:
            err = " typed expr: expr id mismatch"
            return false
        if expr.kind != fact.kind:
            err = " typed expr: expr kind mismatch"
            return false
        if expr.kind == parser.NormalizedExprResultIntrinsic:
            if fact.callKind != TypedExprCallResultIntrinsic:
                err = Fmt" typed expr: result intrinsic fact lost call kind at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callCallee != expr.surfaceText:
                err = Fmt" typed expr: result intrinsic callee drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callResolved ||
               fact.callTarget != "" ||
               fact.callTargetSourcePath != "" ||
               fact.callTargetImportc:
                err = Fmt" typed expr: result intrinsic leaked resolved target at {expr.sourcePath}:{expr.lineNumber}"
                return false
            continue
        if expr.kind != parser.NormalizedExprCall:
            if fact.surfaceCallKind != TypedExprSurfaceCallNone ||
               fact.callResolved ||
               fact.callReason != TypedExprCallReasonNone ||
               fact.callQualifier != "" ||
               fact.callCallee != "" ||
               fact.callTarget != "" ||
               fact.callTargetSourcePath != "" ||
               fact.callTargetImportc:
                err = Fmt" typed expr: non-call fact leaked call resolution at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.typeCallKind != expectedTypeCallKind:
                err = Fmt" typed expr: non-call fact leaked type-call drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if expectedTypeCallKind != TypedExprTypeCallNone:
                if fact.callPrefixStyle != expr.callPrefixStyle ||
                   fact.callArgCount != expr.callArgCount ||
                   fact.callArgsText != expr.callArgsText:
                    err = Fmt" typed expr: type-call fact args drift at {expr.sourcePath}:{expr.lineNumber}"
                    return false
                if !TypedExprFactValidateTypeCallMaterialize(fact, err):
                    return false
            elif fact.callPrefixStyle ||
                 fact.callArgCount != 0 ||
                 fact.callArgsText != "":
                err = Fmt" typed expr: non-call fact leaked call args at {expr.sourcePath}:{expr.lineNumber}"
                return false
            continue
        if fact.typeCallKind != TypedExprTypeCallNone:
            err = Fmt" typed expr: call fact leaked type-call kind at {expr.sourcePath}:{expr.lineNumber}"
            return false
        let surfaceKind = TypedExprSurfaceCallKindFromParser(expr.callSurfaceKind)
        var resolved = expr.callResolved
        var reason = TypedExprCallReasonFromParser(expr.callReason)
        let qualifier = expr.callQualifier
        let callee = expr.callCallee
        var target = expr.callTarget
        var targetSourcePath = expr.callTargetSourcePath
        var targetImportc = expr.callTargetImportc
        if surfaceKind == TypedExprSurfaceCallExternal &&
           qualifier != "" &&
           expr.callArgCount <= 0 &&
           expr.callReason == parser.NormalizedExprCallReasonUnknownQualifiedTarget &&
           TypedExprSymbolExportedByCase(callee):
            let sourceContextIndex = TypedExprSourceContextLookup(sourceContexts, expr.sourcePath)
            if sourceContextIndex < 0:
                err = Fmt" typed expr: missing source context for qualified type constructor at {expr.sourcePath}:{expr.lineNumber}"
                return false
            let typeSourcePath = TypedExprLookupQualifiedModuleSourcePath(sourceContexts[sourceContextIndex],
                                                                          sourceContexts,
                                                                          qualifier)
            let typeSourceIndex = TypedExprSourceContextLookup(sourceContexts, typeSourcePath)
            if typeSourceIndex >= 0 &&
               TypedExprSourceHasDeclaredType(sourceContexts[typeSourceIndex], callee):
                let qualifiedType = TypedExprNormalizeTypeText(Fmt"{qualifier}.{callee}")
                if fact.surfaceCallKind != TypedExprSurfaceCallNone ||
                   fact.callResolved ||
                   fact.callReason != TypedExprCallReasonNone ||
                   fact.callQualifier != "" ||
                   fact.callCallee != "" ||
                   fact.callTarget != "" ||
                   fact.callTargetSourcePath != "" ||
                   fact.callTargetImportc ||
                   fact.callKind != TypedExprCallNone ||
                   fact.typeText != qualifiedType ||
                   fact.abiClass == TypedExprAbiPolymorphic ||
                   fact.loweringMode == TypedExprLowerDeferred ||
                   fact.returnKind == TypedExprReturnDeferred:
                    err = Fmt" typed expr: qualified type constructor drift at {expr.sourcePath}:{expr.lineNumber}"
                    return false
                continue
        if qualifier != "" &&
           surfaceKind != TypedExprSurfaceCallMember:
            let sourceContextIndex = TypedExprSourceContextLookup(sourceContexts, expr.sourcePath)
            if sourceContextIndex < 0:
                err = Fmt" typed expr: missing source context for qualified call at {expr.sourcePath}:{expr.lineNumber}"
                return false
            var resolvedSourcePath = ""
            var resolvedTargetName = ""
            var resolvedImportc = false
            let qualifiedReturnType = TypedExprResolveQualifiedCallTargetReturnType(sourceContexts[sourceContextIndex],
                                                                                    sourceContexts,
                                                                                    qualifier,
                                                                                    callee,
                                                                                    expr.callTarget,
                                                                                    resolvedSourcePath,
                                                                                    resolvedTargetName,
                                                                                    resolvedImportc)
            if qualifiedReturnType == "":
                err = Fmt" typed expr: unknown_qualified_target:{qualifier}:{callee}"
                return false
            resolved = true
            reason = TypedExprCallReasonNone
            target = resolvedTargetName
            targetSourcePath = resolvedSourcePath
            targetImportc = resolvedImportc
        if TypedExprExprIsBuiltinCall(expr):
            if fact.surfaceCallKind != surfaceKind:
                err = Fmt" typed expr: builtin call surface kind drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if !fact.callResolved || fact.callReason != TypedExprCallReasonNone:
                err = Fmt" typed expr: builtin call resolution drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callQualifier != qualifier || fact.callCallee != callee:
                err = Fmt" typed expr: builtin call callee drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callTarget != "" ||
               fact.callTargetSourcePath != "" ||
               fact.callTargetImportc:
                err = Fmt" typed expr: builtin call leaked runtime target at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callPrefixStyle != expr.callPrefixStyle ||
               fact.callArgCount != expr.callArgCount ||
               fact.callArgsText != expr.callArgsText:
                err = Fmt" typed expr: builtin call args drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            let builtinTypeText = TypedExprBuiltinTypeCallResult(expr)
            var expectedTypeText = "str"
            if builtinTypeText != "":
                expectedTypeText = builtinTypeText
            if fact.callKind != TypedExprCallBuiltin ||
               fact.typeText != expectedTypeText ||
               fact.abiClass == TypedExprAbiPolymorphic ||
               fact.loweringMode == TypedExprLowerDeferred ||
               fact.returnKind == TypedExprReturnDeferred:
                err = Fmt" typed expr: builtin call type drift at {expr.sourcePath}:{expr.lineNumber}"
                return false
            continue
        if fact.surfaceCallKind != surfaceKind:
            err = Fmt" typed expr: call surface kind drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callResolved != resolved:
            err = Fmt" typed expr: call resolved drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callReason != reason:
            err = Fmt" typed expr: call reason drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callQualifier != qualifier:
            err = Fmt" typed expr: call qualifier drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callCallee != callee:
            err = Fmt" typed expr: call callee drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callTarget != target:
            err = Fmt" typed expr: call target drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callTargetSourcePath != targetSourcePath:
            err = Fmt" typed expr: call target source drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callTargetImportc != targetImportc:
            err = Fmt" typed expr: call importc drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callPrefixStyle != expr.callPrefixStyle:
            err = Fmt" typed expr: call prefix style drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callArgCount != expr.callArgCount:
            err = Fmt" typed expr: call arg count drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callArgsText != expr.callArgsText:
            err = Fmt" typed expr: call args text drift at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callResolved:
            if fact.callReason != TypedExprCallReasonNone:
                err = Fmt" typed expr: resolved call keeps unknown reason at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.callTargetSourcePath == "":
                err = Fmt" typed expr: resolved call missing target source at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if fact.surfaceCallKind == TypedExprSurfaceCallExternal:
                let symbolExported = TypedExprSymbolExportedByCase(fact.callCallee)
                if !symbolExported:
                    let samePackage = TypedExprSourcesSharePackage(expr.sourcePath,
                                                                    fact.callTargetSourcePath)
                    if !samePackage:
                        err = Fmt" typed expr: imported private symbol '{fact.callCallee}' is not exported at {expr.sourcePath}:{expr.lineNumber} target_source={fact.callTargetSourcePath}"
                        return false
            if fact.typeText == "" || fact.typeText == "unknown" || fact.typeText == "call_expr":
                err = Fmt" typed expr: resolved call missing concrete type at {expr.sourcePath}:{expr.lineNumber}"
                return false
            if !TypedExprTypeIsGenericPlaceholder(fact.typeText) &&
               (fact.abiClass == TypedExprAbiPolymorphic ||
                fact.loweringMode == TypedExprLowerDeferred ||
                fact.returnKind == TypedExprReturnDeferred):
                err = Fmt" typed expr: resolved call fell back to deferred at {expr.sourcePath}:{expr.lineNumber} target={fact.callTarget} type={fact.typeText} abi={TypedExprAbiClassText(fact.abiClass)} lower={TypedExprLoweringModeText(fact.loweringMode)} return={TypedExprReturnKindText(fact.returnKind)} target_source={fact.callTargetSourcePath}"
                return false
            if fact.callTargetImportc &&
               fact.abiClass == TypedExprAbiComposite &&
               (fact.loweringMode != TypedExprLowerImportBuffer ||
                fact.returnKind != TypedExprReturnImportBuffer):
                err = Fmt" typed expr: imported composite call missing import buffer at {expr.sourcePath}:{expr.lineNumber}"
                return false
            continue
        if fact.callReason == TypedExprCallReasonNone:
            err = Fmt" typed expr: unresolved call missing reason at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callTargetSourcePath != "":
            err = Fmt" typed expr: unresolved call keeps target source at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.callTargetImportc:
            err = Fmt" typed expr: unresolved call keeps importc target at {expr.sourcePath}:{expr.lineNumber}"
            return false
        if fact.surfaceCallKind == TypedExprSurfaceCallExternal &&
           fact.callQualifier != "" &&
           !TypedExprSymbolExportedByCase(fact.callCallee):
            err = Fmt" typed expr: unknown_qualified_target:{fact.callQualifier}:{fact.callCallee}"
            return false
    err = ""
    return true

fn TypedExprLoweringRuleFillFromFact(fact: var TypedExprFact,
                                      out: var TypedExprLoweringRule) =
    let argPassKind = TypedExprArgPassKindForResolved(fact.abiClass, fact.placeKind, fact.loweringMode)
    let resultPassKind = TypedExprResultPassKindForResolved(fact.returnKind)
    let materializeKind = TypedExprMaterializeKindForResolved(fact.valueKind, fact.placeKind, fact.loweringMode)
    let copyKind = TypedExprCopyKindForResolved(fact.valueKind, fact.abiClass)
    let importKind = TypedExprImportKindForResolved(fact.callKind, fact.abiClass, fact.loweringMode, fact.returnKind)
    out.exprId = fact.exprId
    out.sourcePath = fact.sourcePath
    out.lineNumber = fact.lineNumber
    out.columnNumber = fact.columnNumber
    out.surfaceCallKind = fact.surfaceCallKind
    out.callResolved = fact.callResolved
    out.callReason = fact.callReason
    out.callQualifier = fact.callQualifier
    out.callCallee = fact.callCallee
    out.callTarget = fact.callTarget
    out.callTargetSourcePath = fact.callTargetSourcePath
    out.callTargetImportc = fact.callTargetImportc
    out.callPrefixStyle = fact.callPrefixStyle
    out.callArgCount = fact.callArgCount
    out.callArgsText = fact.callArgsText
    out.typeText = TypedExprNormalizeTypeText(fact.typeText)
    out.abiClass = fact.abiClass
    out.valueKind = fact.valueKind
    out.placeKind = fact.placeKind
    out.loweringMode = fact.loweringMode
    out.callKind = fact.callKind
    out.typeCallKind = fact.typeCallKind
    out.returnKind = fact.returnKind
    out.returnRoot = fact.returnRoot
    out.argPassKind = argPassKind
    out.resultPassKind = resultPassKind
    out.materializeKind = materializeKind
    out.copyKind = copyKind
    out.importKind = importKind

fn TypedExprLoweringRuleClone(rule: TypedExprLoweringRule): TypedExprLoweringRule =
    var out: TypedExprLoweringRule
    out.exprId = rule.exprId
    out.sourcePath = rule.sourcePath
    out.lineNumber = rule.lineNumber
    out.columnNumber = rule.columnNumber
    out.surfaceCallKind = rule.surfaceCallKind
    out.callResolved = rule.callResolved
    out.callReason = rule.callReason
    out.callQualifier = rule.callQualifier
    out.callCallee = rule.callCallee
    out.callTarget = rule.callTarget
    out.callTargetSourcePath = rule.callTargetSourcePath
    out.callTargetImportc = rule.callTargetImportc
    out.callPrefixStyle = rule.callPrefixStyle
    out.callArgCount = rule.callArgCount
    out.callArgsText = rule.callArgsText
    out.typeText = rule.typeText
    out.abiClass = rule.abiClass
    out.valueKind = rule.valueKind
    out.placeKind = rule.placeKind
    out.loweringMode = rule.loweringMode
    out.callKind = rule.callKind
    out.typeCallKind = rule.typeCallKind
    out.returnKind = rule.returnKind
    out.returnRoot = rule.returnRoot
    out.argPassKind = rule.argPassKind
    out.resultPassKind = rule.resultPassKind
    out.materializeKind = rule.materializeKind
    out.copyKind = rule.copyKind
    out.importKind = rule.importKind
    return out

fn TypedExprLoweringRulesClone(rules: TypedExprLoweringRule[]): TypedExprLoweringRule[] =
    var out: TypedExprLoweringRule[]
    for i in 0..<rules.len:
        add(out, TypedExprLoweringRuleClone(rules[i]))
    return out

fn TypedExprLoweringRuleEqual(lhs: TypedExprLoweringRule,
                                rhs: TypedExprLoweringRule): bool =
    if lhs.exprId != rhs.exprId:
        return false
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.lineNumber != rhs.lineNumber:
        return false
    if lhs.columnNumber != rhs.columnNumber:
        return false
    if lhs.surfaceCallKind != rhs.surfaceCallKind:
        return false
    if lhs.callResolved != rhs.callResolved:
        return false
    if lhs.callReason != rhs.callReason:
        return false
    if lhs.callQualifier != rhs.callQualifier:
        return false
    if lhs.callCallee != rhs.callCallee:
        return false
    if lhs.callTarget != rhs.callTarget:
        return false
    if lhs.callTargetSourcePath != rhs.callTargetSourcePath:
        return false
    if lhs.callTargetImportc != rhs.callTargetImportc:
        return false
    if lhs.callPrefixStyle != rhs.callPrefixStyle:
        return false
    if lhs.callArgCount != rhs.callArgCount:
        return false
    if lhs.callArgsText != rhs.callArgsText:
        return false
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.callKind == TypedExprCallResultIntrinsic &&
       lhs.callCallee != rhs.callCallee:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    if lhs.returnKind != rhs.returnKind:
        return false
    if lhs.returnRoot != rhs.returnRoot:
        return false
    if lhs.argPassKind != rhs.argPassKind:
        return false
    if lhs.resultPassKind != rhs.resultPassKind:
        return false
    if lhs.materializeKind != rhs.materializeKind:
        return false
    if lhs.copyKind != rhs.copyKind:
        return false
    if lhs.importKind != rhs.importKind:
        return false
    return true

fn TypedExprLoweringRuleShapeEqual(lhs: TypedExprLoweringRule,
                                     rhs: TypedExprLoweringRule): bool =
    if lhs.typeText != rhs.typeText:
        return false
    if lhs.abiClass != rhs.abiClass:
        return false
    if lhs.valueKind != rhs.valueKind:
        return false
    if lhs.placeKind != rhs.placeKind:
        return false
    if lhs.loweringMode != rhs.loweringMode:
        return false
    if lhs.callKind != rhs.callKind:
        return false
    if lhs.typeCallKind != rhs.typeCallKind:
        return false
    if lhs.returnKind != rhs.returnKind:
        return false
    if lhs.returnRoot != rhs.returnRoot:
        return false
    if lhs.argPassKind != rhs.argPassKind:
        return false
    if lhs.resultPassKind != rhs.resultPassKind:
        return false
    if lhs.materializeKind != rhs.materializeKind:
        return false
    if lhs.copyKind != rhs.copyKind:
        return false
    return lhs.importKind == rhs.importKind

fn TypedExprLoweringRuleKey(rule: TypedExprLoweringRule): str =
    var out = ""
    out = strutil.Join([out, "type=", TypedExprNormalizeTypeText(rule.typeText)], "")
    out = strutil.Join([out, ";abi=", TypedExprAbiClassText(rule.abiClass)], "")
    out = strutil.Join([out, ";value=", TypedExprValueKindText(rule.valueKind)], "")
    out = strutil.Join([out, ";place=", TypedExprPlaceKindText(rule.placeKind)], "")
    out = strutil.Join([out, ";lower=", TypedExprLoweringModeText(rule.loweringMode)], "")
    out = strutil.Join([out, ";call=", TypedExprCallKindText(rule.callKind)], "")
    if rule.callKind == TypedExprCallResultIntrinsic:
        out = strutil.Join([out, ";result_intrinsic=", rule.callCallee], "")
        out = strutil.Join([out, ";result_detail=", IntToStr(parser.NormalizedExprDetailKindCode(parser.ParserResultIntrinsicDetailKind(rule.callCallee)))], "")
    out = strutil.Join([out, ";type_call=", TypedExprTypeCallKindText(rule.typeCallKind)], "")
    out = strutil.Join([out, ";return=", TypedExprReturnKindText(rule.returnKind)], "")
    out = strutil.Join([out, ";return_root=", rule.returnRoot ? "1" : "0"], "")
    out = strutil.Join([out, ";arg=", TypedExprArgPassKindText(rule.argPassKind)], "")
    out = strutil.Join([out, ";result=", TypedExprResultPassKindText(rule.resultPassKind)], "")
    out = strutil.Join([out, ";materialize=", TypedExprMaterializeKindText(rule.materializeKind)], "")
    out = strutil.Join([out, ";copy=", TypedExprCopyKindText(rule.copyKind)], "")
    out = strutil.Join([out, ";import=", TypedExprImportKindText(rule.importKind)], "")
    return out

fn TypedExprLoweringRuleEntryText(rule: TypedExprLoweringRule): str =
    var out = ""
    let callReasonText = TypedExprCallReasonText(rule.callReason)
    out = strutil.Join([out, "source=", rule.sourcePath], "")
    out = strutil.Join([out, ";line=", IntToStr(rule.lineNumber)], "")
    out = strutil.Join([out, ";column=", IntToStr(rule.columnNumber)], "")
    out = strutil.Join([out, ";expr=", rule.exprId], "")
    out = strutil.Join([out, ";surface_call=", TypedExprSurfaceCallKindText(rule.surfaceCallKind)], "")
    out = strutil.Join([out, ";type_call=", TypedExprTypeCallKindText(rule.typeCallKind)], "")
    out = strutil.Join([out, ";resolved=", (if rule.callResolved: "1" else: "0")], "")
    if callReasonText != "":
        out = strutil.Join([out, ";reason=", callReasonText], "")
    if rule.callQualifier != "":
        out = strutil.Join([out, ";qualifier=", rule.callQualifier], "")
    if rule.callCallee != "":
        out = strutil.Join([out, ";callee=", rule.callCallee], "")
    if rule.callTarget != "":
        out = strutil.Join([out, ";target=", rule.callTarget], "")
    if rule.callTargetSourcePath != "":
        out = strutil.Join([out, ";target_source=", rule.callTargetSourcePath], "")
    if rule.callTargetImportc:
        out = strutil.Join([out, ";target_importc=1"], "")
    if rule.callPrefixStyle:
        out = strutil.Join([out, ";prefix_style=1"], "")
    if rule.callArgCount > 0:
        out = strutil.Join([out, ";arg_count=", IntToStr(rule.callArgCount)], "")
    if rule.returnRoot:
        out = strutil.Join([out, ";return_root=1"], "")
    out = strutil.Join([out, ";key=", TypedExprLoweringRuleKey(rule)], "")
    return out

fn TypedExprLoweringRulesEqual(lhs: TypedExprLoweringRule[],
                                 rhs: TypedExprLoweringRule[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !TypedExprLoweringRuleEqual(lhs[i], rhs[i]):
            return false
    return true

fn TypedExprLoweringRulesFromFacts(facts: var TypedExprFact[]): TypedExprLoweringRule[] =
    var out: TypedExprLoweringRule[]
    for i in 0..<facts.len:
        var empty: TypedExprLoweringRule
        add(out, empty)
        let ruleIndex = out.len - 1
        TypedExprLoweringRuleFillFromFact(facts[i], out[ruleIndex])
    return out

fn TypedExprLoweringRuleUniqueShapeCount(rules: TypedExprLoweringRule[]): int32 =
    var count: int32
    var uniqueRules: TypedExprLoweringRule[]
    for i in 0..<rules.len:
        var seen = false
        for j in 0..<uniqueRules.len:
            if TypedExprLoweringRuleShapeEqual(uniqueRules[j], rules[i]):
                seen = true
                break
        if seen:
            continue
        add(uniqueRules, TypedExprLoweringRuleClone(rules[i]))
        count = count + 1
    return count

fn TypedExprLoweringRuleUniqueKeyCount(rules: TypedExprLoweringRule[]): int32 =
    var count: int32
    var keys: str[]
    for i in 0..<rules.len:
        let key = TypedExprLoweringRuleKey(rules[i])
        if parser.ParserStringSeqContainsExact(keys, key):
            continue
        add(keys, key)
        count = count + 1
    return count

fn TypedExprLoweringRuleCountArgPassKind(rules: TypedExprLoweringRule[],
                                           kind: TypedExprArgPassKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].argPassKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountResultPassKind(rules: TypedExprLoweringRule[],
                                              kind: TypedExprResultPassKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].resultPassKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountMaterializeKind(rules: TypedExprLoweringRule[],
                                               kind: TypedExprMaterializeKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].materializeKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountCopyKind(rules: TypedExprLoweringRule[],
                                        kind: TypedExprCopyKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].copyKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountImportKind(rules: TypedExprLoweringRule[],
                                          kind: TypedExprImportKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].importKind == kind:
            count = count + 1
    return count

fn TypedExprLoweringRuleCountTypeCallKind(rules: TypedExprLoweringRule[],
                                            typeCallKind: TypedExprTypeCallKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].typeCallKind == typeCallKind:
            count = count + 1
    return count

fn TypedExprLoweringRuleReturnRootCount(rules: TypedExprLoweringRule[]): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].returnRoot:
            count = count + 1
    return count

fn TypedExprReportAppendLine(out: var str,
                              key: str,
                              value: str) =
    out = strutil.Join([out, key, "=", value, "\n"], "")

fn TypedExprFactsReportText(facts: var TypedExprFact[]): str =
    var out = ""
    TypedExprReportAppendLine(out, "expr_surface_call_count", IntToStr(TypedExprSurfaceCallCount(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_resolved_count", IntToStr(TypedExprFactCountCallResolved(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_unresolved_count", IntToStr(TypedExprFactCountCallUnresolved(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_local_kind_count", IntToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallLocal)))
    TypedExprReportAppendLine(out, "expr_surface_call_external_kind_count", IntToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallExternal)))
    TypedExprReportAppendLine(out, "expr_surface_call_importc_kind_count", IntToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallImportc)))
    TypedExprReportAppendLine(out, "expr_surface_call_member_kind_count", IntToStr(TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallMember)))
    TypedExprReportAppendLine(out, "expr_surface_call_target_importc_count", IntToStr(TypedExprFactCountCallTargetImportc(facts)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_unknown_qualified_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownQualifiedTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_shadowed_qualified_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonShadowedQualifiedTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_ambiguous_external_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousExternalTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_ambiguous_qualified_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_unknown_external_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownExternalTarget)))
    TypedExprReportAppendLine(out, "expr_surface_call_reason_unknown_call_target_count", IntToStr(TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownCallTarget)))
    TypedExprReportAppendLine(out, "typed_expr_fact_count", IntToStr(facts.len))
    TypedExprReportAppendLine(out, "typed_expr_abi_scalar_count", IntToStr(TypedExprAbiScalarCount(facts)))
