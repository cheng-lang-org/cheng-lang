fn TypedExprIrAddStrI32GuardArg0Return0Node(ir: var TypedExprIr,
                                             sourcePath: str,
                                             functionName: str,
                                             returnLineNumber: int32,
                                             secondCallLineNumber: int32,
                                             countCallLineNumber: int32,
