    TypedExprIrStatement =
        sourcePath: str
        functionName: str
        statementIndex: int32
        lineNumber: int32
        columnNumber: int32
        lineIndent: int32
        enclosingIfLineNumber: int32
        enclosingIfConditionText: str
        exprId: str
        kind: TypedExprIrStatementKind
        callKind: TypedExprCallKind
        detailKind: parser.NormalizedExprDetailKind
        surfaceText: str
        bindingName: str
        resultType: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callArgCount: int32
        callArgsText: str
        loweringMode: TypedExprLoweringMode
        returnKind: TypedExprReturnKind
        returnRoot: bool

    TypedExprIrFunction =
        sourcePath: str
        functionName: str
        signatureLineNumber: int32
        endLineNumber: int32
        bodyLineNumber: int32
        returnType: str
        returnExpr: str
        statementStart: int32
        statementCount: int32
        nodeStart: int32
        nodeCount: int32
        returnNodeIndex: int32

    TypedExprIr =
        functions: TypedExprIrFunction[]
        statements: TypedExprIrStatement[]
        nodes: TypedExprIrNode[]

    TypedExprFunctionScope =
        sourcePath: str
        name: str
        startLine: int32
        endLine: int32
