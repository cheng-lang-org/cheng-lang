fn TypedExprSurfaceCallCount(facts: var TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if facts[i].surfaceCallKind != TypedExprSurfaceCallNone:
            count = count + 1
    return count

