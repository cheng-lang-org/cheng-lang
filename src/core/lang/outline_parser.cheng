import std/seqs
import std/strings
import std/os
import std/strformat

# ---------------------------------------------------------------------------
# Types
# ---------------------------------------------------------------------------

type
    OutlineDeclKind = enum
        OutlineModule
        OutlineImport
        OutlineFn
        OutlineType
        OutlineVar
        OutlineConst
        OutlineMacro
        OutlineTemplate
        OutlineConcept
        OutlineTrait
        OutlineEnum
        OutlineSet
        OutlineAnnotation

    OutlineImport =
        modulePath: str
        alias: str
        sourceStart: int32
        sourceEnd: int32

    OutlineDecl =
        kind: OutlineDeclKind
        name: str
        sourceStart: int32
        sourceEnd: int32
        bodyStart: int32
        signatureText: str
        annotations: str[]
        modulePath: str
        isPublic: bool
        isAsync: bool
        genericParams: str[]
        returnTypeHint: str

    OutlineParser =
        source: str
        pos: int32
        declarations: OutlineDecl[]
        imports: OutlineImport[]
        errors: str[]
        currentModulePath: str

    OutlineSymbolTable =
        names: str[]
        kinds: int32[]
        sourceStarts: int32[]
        sourceEnds: int32[]
        modulePaths: str[]
        isPublicFlags: bool[]
        genericCounts: int32[]

# ---------------------------------------------------------------------------
# Helpers: character classification
# ---------------------------------------------------------------------------

fn OutlineIsIdentStart(ch: uint8): bool =
    return (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95

fn OutlineIsIdentCont(ch: uint8): bool =
    return OutlineIsIdentStart(ch) || (ch >= 48 && ch <= 57)

fn OutlineIsSpace(ch: uint8): bool =
    return ch == 32 || ch == 9 || ch == 10 || ch == 13

# ---------------------------------------------------------------------------
# Helpers: skip strings, comments, identifiers
# ---------------------------------------------------------------------------

fn OutlineSkipString(p: var OutlineParser) =
    let start = p.pos
    if start + 2 < len(p.source) && p.source[start + 1] == '"' && p.source[start + 2] == '"':
        p.pos = p.pos + 3
        while p.pos + 2 < len(p.source):
            if p.source[p.pos] == '"' && p.source[p.pos + 1] == '"' && p.source[p.pos + 2] == '"':
                p.pos = p.pos + 3
                return
            p.pos = p.pos + 1
    else:
        p.pos = p.pos + 1
        while p.pos < len(p.source):
            if p.source[p.pos] == '\\':
                p.pos = p.pos + 2
            elif p.source[p.pos] == '"':
                p.pos = p.pos + 1
                return
            elif p.source[p.pos] == '\n':
                return
            else:
                p.pos = p.pos + 1

fn OutlineSkipCharLiteral(p: var OutlineParser) =
    p.pos = p.pos + 1
    while p.pos < len(p.source):
        if p.source[p.pos] == '\\':
            p.pos = p.pos + 2
        elif p.source[p.pos] == '\'':
            p.pos = p.pos + 1
            return
        elif p.source[p.pos] == '\n':
            return
        else:
            p.pos = p.pos + 1

fn OutlineSkipLineComment(p: var OutlineParser) =
    while p.pos < len(p.source) && p.source[p.pos] != '\n':
        p.pos = p.pos + 1

fn OutlineSkipBlockComment(p: var OutlineParser) =
    p.pos = p.pos + 2
    while p.pos + 1 < len(p.source):
        if p.source[p.pos] == '*' && p.source[p.pos + 1] == '/':
            p.pos = p.pos + 2
            return
        p.pos = p.pos + 1

fn OutlineSkipWhitespaceAndComments(p: var OutlineParser) =
    while p.pos < len(p.source):
        let ch = p.source[p.pos]
        if ch == ' ' || ch == '\t' || ch == '\r' || ch == '\n':
            p.pos = p.pos + 1
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*':
                OutlineSkipBlockComment(p)
            else:
                break
        else:
            break

fn OutlineReadIdentifier(p: var OutlineParser): str =
    let start = p.pos
    while p.pos < len(p.source) && OutlineIsIdentCont(p.source[p.pos]):
        p.pos = p.pos + 1
    if p.pos > start:
        return strings.SliceBytes(p.source, start, p.pos - start)
    return ""

fn OutlineReadAnnotation(p: var OutlineParser): str =
    let start = p.pos
    p.pos = p.pos + 1
    while p.pos < len(p.source) && OutlineIsIdentCont(p.source[p.pos]):
        p.pos = p.pos + 1
    if p.pos < len(p.source) && p.source[p.pos] == 40:
        var depth: int32 = 1
        p.pos = p.pos + 1
        while p.pos < len(p.source) && depth > 0:
            let ac = p.source[p.pos]
            if ac == 40: depth = depth + 1
            elif ac == 41: depth = depth - 1
            elif ac == 34: OutlineSkipString(p); continue
            elif ac == 39: OutlineSkipCharLiteral(p); continue
            p.pos = p.pos + 1
    return strings.SliceBytes(p.source, start, p.pos - start)

# ---------------------------------------------------------------------------
# Helpers: indentation, general skipping
# ---------------------------------------------------------------------------

fn OutlineComputeLineIndent(source: str, pos: int32): int32 =
    var i = pos
    while i > 0:
        i = i - 1
        if source[i] == '\n':
            i = i + 1
            break
    var indent: int32
    while i < len(source):
        let ch = source[i]
        if ch == ' ': indent = indent + 1
        elif ch == '\t': indent = indent + 4
        else: break
        i = i + 1
    return indent

fn OutlineCollectAnnotations(p: var OutlineParser): str[] =
    var result: str[]
    while p.pos < len(p.source):
        OutlineSkipWhitespaceAndComments(p)
        if p.pos < len(p.source) && p.source[p.pos] == '@':
            seqs.Add(result, OutlineReadAnnotation(p))
        else:
            break
    return result

fn OutlineSkipToNextLine(p: var OutlineParser) =
    while p.pos < len(p.source):
        let ch = p.source[p.pos]
        if ch == '\n':
            p.pos = p.pos + 1
            return
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
                return
            elif p.source[p.pos + 1] == '*':
                OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == '{':
            p.pos = p.pos + 1
            if !OutlineSkipToMatchingBrace(p): return
        else: p.pos = p.pos + 1

# ---------------------------------------------------------------------------
# Core: skip to matching '}' (string/comment aware)
# ---------------------------------------------------------------------------

fn OutlineSkipToMatchingBrace(p: var OutlineParser): bool =
    var depth: int32 = 1
    while p.pos < len(p.source) && depth > 0:
        let ch = p.source[p.pos]
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*':
                OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == '{': depth = depth + 1; p.pos = p.pos + 1
        elif ch == '}':
            depth = depth - 1
            if depth == 0: p.pos = p.pos + 1; return true
            p.pos = p.pos + 1
        else: p.pos = p.pos + 1
    seqs.Add(p.errors, "unmatched '{'")
    return false

# ---------------------------------------------------------------------------
# Core: skip body after '='
#   brace-block  { ... }
#   indented     NEWLINE INDENT ... DEDENT
#   inline       expression on same line
# ---------------------------------------------------------------------------

fn OutlineSkipBody(p: var OutlineParser): bool =
    if p.pos < len(p.source) && p.source[p.pos] == '=':
        p.pos = p.pos + 1
    OutlineSkipWhitespaceAndComments(p)
    if p.pos >= len(p.source): return true

    if p.source[p.pos] == '{':
        p.pos = p.pos + 1
        return OutlineSkipToMatchingBrace(p)

    if p.source[p.pos] == '\n':
        let declIndent = OutlineComputeLineIndent(p.source, p.pos)
        p.pos = p.pos + 1
        var braceDepth: int32
        var atLineStart: bool = true
        var curIndent: int32
        var bodyStarted: bool

        while p.pos < len(p.source):
            let ch = p.source[p.pos]
            if atLineStart:
                if ch == ' ' || ch == '\t':
                    if ch == '\t':
                        curIndent = curIndent + 4
                    else:
                        curIndent = curIndent + 1
                    p.pos = p.pos + 1
                elif ch == '\n' || ch == '\r':
                    p.pos = p.pos + 1; curIndent = 0
                elif ch == '/' && p.pos + 1 < len(p.source):
                    if p.source[p.pos + 1] == '/':
                        OutlineSkipLineComment(p); curIndent = 0
                    elif p.source[p.pos + 1] == '*':
                        OutlineSkipBlockComment(p); curIndent = 0
                    else: atLineStart = false; p.pos = p.pos + 1
                else:
                    if !bodyStarted && curIndent > declIndent:
                        bodyStarted = true
                    if braceDepth == 0 && curIndent <= declIndent:
                        return true
                    atLineStart = false
            else:
                if ch == '"': OutlineSkipString(p)
                elif ch == '\'': OutlineSkipCharLiteral(p)
                elif ch == '/' && p.pos + 1 < len(p.source):
                    if p.source[p.pos + 1] == '/':
                        OutlineSkipLineComment(p); atLineStart = true; curIndent = 0
                    elif p.source[p.pos + 1] == '*':
                        OutlineSkipBlockComment(p)
                    else: p.pos = p.pos + 1
                elif ch == '{': braceDepth = braceDepth + 1; p.pos = p.pos + 1
                elif ch == '}':
                    if braceDepth > 0: braceDepth = braceDepth - 1
                    p.pos = p.pos + 1
                elif ch == '\n': atLineStart = true; curIndent = 0; p.pos = p.pos + 1
                else: p.pos = p.pos + 1
        return true

    # inline body
    while p.pos < len(p.source):
        let ch = p.source[p.pos]
        if ch == '\n': return true
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/': return true
            elif p.source[p.pos + 1] == '*': OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == '{':
            p.pos = p.pos + 1
            if !OutlineSkipToMatchingBrace(p): return false
        else: p.pos = p.pos + 1
    return true

# ---------------------------------------------------------------------------
# Core: parse generic param names from a [...] list
# ---------------------------------------------------------------------------

fn OutlineParseGenericParams(p: var OutlineParser): str[] =
    var result: str[]
    if p.pos < len(p.source) && p.source[p.pos] == '[':
        let gpStart = p.pos
        if OutlineSkipBalanced(p, '[', ']'):
            let gpText = strings.SliceBytes(p.source, gpStart + 1, p.pos - gpStart - 2)
            var j: int32
            var current: str
            while j < len(gpText):
                if gpText[j] == ',' || gpText[j] == ';':
                    if len(current) > 0: seqs.Add(result, current); current = ""
                elif gpText[j] != ' ':
                    current = Fmt"{current}{gpText[j]}"
                j = j + 1
            if len(current) > 0: seqs.Add(result, current)
    return result

# ---------------------------------------------------------------------------
# Core: skip balanced brackets/parens (string/comment aware)
# ---------------------------------------------------------------------------

fn OutlineSkipBalanced(p: var OutlineParser, openCh: uint8, closeCh: uint8): bool =
    if p.pos >= len(p.source) || p.source[p.pos] != openCh: return false
    var depth: int32 = 1
    p.pos = p.pos + 1
    while p.pos < len(p.source) && depth > 0:
        let ch = p.source[p.pos]
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/': OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*': OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == openCh: depth = depth + 1; p.pos = p.pos + 1
        elif ch == closeCh:
            depth = depth - 1
            if depth > 0: p.pos = p.pos + 1
            else: p.pos = p.pos + 1; return true
        else: p.pos = p.pos + 1
    seqs.Add(p.errors, "unbalanced bracket/paren")
    return false

# ---------------------------------------------------------------------------
# Core: scan forward to '=' at depth 0 (skip return type, where clause)
# ---------------------------------------------------------------------------

fn OutlineSkipToEquals(p: var OutlineParser): bool =
    var depth: int32
    while p.pos < len(p.source):
        let ch = p.source[p.pos]
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/': OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*': OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == '(' || ch == '[' || ch == '{': depth = depth + 1; p.pos = p.pos + 1
        elif ch == ')' || ch == ']' || ch == '}':
            if depth > 0: depth = depth - 1
            p.pos = p.pos + 1
        elif ch == '=' && depth == 0: return true
        else: p.pos = p.pos + 1
    return false

# ---------------------------------------------------------------------------
# Helper: extract return type hint from source region
# ---------------------------------------------------------------------------

fn OutlineExtractReturnTypeHint(source: str, sigEnd: int32, bodyStart: int32): str =
    var lastColon: int32 = -1
    var i = sigEnd
    while i < bodyStart:
        if source[i] == ':': lastColon = i
        i = i + 1
    if lastColon < 0: return ""
    let retText = strings.SliceBytes(source, lastColon + 1, bodyStart - lastColon - 1)
    var trimStart: int32
    var trimEnd: int32 = len(retText) - 1
    while trimStart < len(retText) && OutlineIsSpace(retText[trimStart]):
        trimStart = trimStart + 1
    while trimEnd >= 0 && OutlineIsSpace(retText[trimEnd]):
        trimEnd = trimEnd - 1
    if trimStart > trimEnd: return ""
    return strings.SliceBytes(retText, trimStart, trimEnd - trimStart + 1)

# ---------------------------------------------------------------------------
# Helper: find the ':' that separates keyword from body (for concept/trait)
# ---------------------------------------------------------------------------

fn OutlineSkipToColonOrEquals(p: var OutlineParser): bool =
    while p.pos < len(p.source):
        let ch = p.source[p.pos]
        if ch == '"': OutlineSkipString(p)
        elif ch == '\'': OutlineSkipCharLiteral(p)
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/': OutlineSkipLineComment(p); return true
            elif p.source[p.pos + 1] == '*': OutlineSkipBlockComment(p)
            else: p.pos = p.pos + 1
        elif ch == '(':
            if !OutlineSkipBalanced(p, '(', ')'): return false
        elif ch == '[':
            if !OutlineSkipBalanced(p, '[', ']'): return false
        elif ch == '{':
            p.pos = p.pos + 1
            if !OutlineSkipToMatchingBrace(p): return false
        elif ch == ':' || ch == '=': return true
        elif ch == '\n': return true
        else: p.pos = p.pos + 1
    return false

# ---------------------------------------------------------------------------
# Module-level parsing
# ---------------------------------------------------------------------------

fn OutlineRecordDecl(p: var OutlineParser, kind: OutlineDeclKind, name: str,
                     sourceStart: int32, signatureText: str,
                     annotations: str[], bodyStart: int32) =
    var decl: OutlineDecl
    decl.kind = kind
    decl.name = name
    decl.sourceStart = sourceStart
    decl.sourceEnd = 0
    decl.bodyStart = bodyStart
    decl.signatureText = signatureText
    decl.annotations = annotations
    let modCopy = p.currentModulePath
    decl.modulePath = modCopy
    decl.isPublic = true
    decl.isAsync = false
    seqs.Add(p.declarations, decl)

fn OutlineUpdateLastDeclEnd(p: var OutlineParser) =
    if len(p.declarations) > 0:
        p.declarations[len(p.declarations) - 1].sourceEnd = p.pos

fn OutlineParseModule(p: var OutlineParser): bool =
    while p.pos < len(p.source):
        OutlineSkipWhitespaceAndComments(p)
        if p.pos >= len(p.source): break

        let lineIndent = OutlineComputeLineIndent(p.source, p.pos)
        if lineIndent > 0:
            OutlineSkipToNextLine(p)
            continue

        let annotations = OutlineCollectAnnotations(p)
        OutlineSkipWhitespaceAndComments(p)
        if p.pos >= len(p.source): break

        if !OutlineIsIdentStart(p.source[p.pos]):
            if p.source[p.pos] == '#': OutlineSkipToNextLine(p); continue
            p.pos = p.pos + 1
            continue

        let kwStart = p.pos
        let keyword = OutlineReadIdentifier(p)

        if keyword == "module":
            OutlineSkipWhitespaceAndComments(p)
            let modName = OutlineReadIdentifier(p)
            if len(modName) > 0:
                p.currentModulePath = modName
                OutlineRecordDecl(p, OutlineModule, modName, kwStart,
                    strings.SliceBytes(p.source, kwStart, p.pos - kwStart), annotations, 0)
            else:
                seqs.Add(p.errors, "module name expected")
            OutlineSkipToNextLine(p)
            OutlineUpdateLastDeclEnd(p)

        elif keyword == "import":
            OutlineSkipWhitespaceAndComments(p)
            var path = OutlineReadIdentifier(p)
            while p.pos < len(p.source) && p.source[p.pos] == '/':
                p.pos = p.pos + 1
                let part = OutlineReadIdentifier(p)
                if len(part) > 0: path = Fmt"{path}/{part}"
                else: break
            var alias: str
            OutlineSkipWhitespaceAndComments(p)
            if p.pos + 1 < len(p.source) && p.source[p.pos] == 'a' && p.source[p.pos + 1] == 's':
                p.pos = p.pos + 2
                OutlineSkipWhitespaceAndComments(p)
                alias = OutlineReadIdentifier(p)
            var imp: OutlineImport
            imp.modulePath = path
            imp.alias = alias
            imp.sourceStart = kwStart
            imp.sourceEnd = p.pos
            seqs.Add(p.imports, imp)
            OutlineRecordDecl(p, OutlineImport, path, kwStart,
                Fmt"import {path}", annotations, 0)
            OutlineSkipToNextLine(p)
            OutlineUpdateLastDeclEnd(p)

        elif keyword == "fn":
            OutlineSkipWhitespaceAndComments(p)
            let fnName = OutlineReadIdentifier(p)
            if len(fnName) == 0:
                seqs.Add(p.errors, "function name expected")
                OutlineSkipToNextLine(p); continue

            let gp = OutlineParseGenericParams(p)
            OutlineSkipWhitespaceAndComments(p)
            if p.pos < len(p.source) && p.source[p.pos] == '(':
                if !OutlineSkipBalanced(p, '(', ')'):
                    seqs.Add(p.errors, Fmt"unbalanced parens in fn {fnName}")
                    OutlineSkipToNextLine(p); continue

            let sigEnd = p.pos
            if !OutlineSkipToEquals(p):
                seqs.Add(p.errors, Fmt"expected '=' in fn {fnName}")
                continue

            let equalsPos = p.pos
            var bodyStart = equalsPos
            let sigText = strings.SliceBytes(p.source, kwStart, equalsPos - kwStart)
            let returnHint = OutlineExtractReturnTypeHint(p.source, sigEnd, equalsPos)

            OutlineRecordDecl(p, OutlineFn, fnName, kwStart, sigText, annotations, bodyStart)
            let idx = len(p.declarations) - 1
            p.declarations[idx].genericParams = gp
            p.declarations[idx].returnTypeHint = returnHint

            if !OutlineSkipBody(p):
                seqs.Add(p.errors, Fmt"could not skip body of fn {fnName}")
            OutlineUpdateLastDeclEnd(p)

        elif keyword == "type":
            OutlineSkipWhitespaceAndComments(p)
            if p.pos < len(p.source) && p.source[p.pos] == '\n':
                OutlineRecordDecl(p, OutlineType, "", kwStart, "type", annotations, 0)
                if !OutlineSkipBody(p):
                    seqs.Add(p.errors, "could not skip multi-entry type")
                OutlineUpdateLastDeclEnd(p)
            else:
                let typeName = OutlineReadIdentifier(p)
                if len(typeName) == 0:
                    seqs.Add(p.errors, "type name expected")
                    OutlineSkipToNextLine(p); continue
                var sigText = strings.SliceBytes(p.source, kwStart, p.pos - kwStart)
                OutlineSkipWhitespaceAndComments(p)
                if p.pos < len(p.source) && p.source[p.pos] == '[':
                    if !OutlineSkipBalanced(p, '[', ']'):
                        seqs.Add(p.errors, Fmt"unbalanced brackets in type {typeName}")
                    sigText = strings.SliceBytes(p.source, kwStart, p.pos - kwStart)
                OutlineRecordDecl(p, OutlineType, typeName, kwStart, sigText, annotations, 0)
                OutlineSkipWhitespaceAndComments(p)
                if p.pos < len(p.source) && p.source[p.pos] == '=':
                    if !OutlineSkipBody(p):
                        seqs.Add(p.errors, Fmt"could not skip body of type {typeName}")
                else:
                    OutlineSkipToNextLine(p)
                OutlineUpdateLastDeclEnd(p)

        elif keyword == "var" || keyword == "const" || keyword == "let":
            let declKind: OutlineDeclKind =
                if keyword == "const": OutlineConst
                else: OutlineVar
            OutlineSkipWhitespaceAndComments(p)
            let name = OutlineReadIdentifier(p)
            if len(name) == 0:
                seqs.Add(p.errors, Fmt"name expected after {keyword}")
                OutlineSkipToNextLine(p); continue
            OutlineRecordDecl(p, declKind, name, kwStart,
                strings.SliceBytes(p.source, kwStart, p.pos - kwStart), annotations, 0)
            while p.pos < len(p.source):
                let ch = p.source[p.pos]
                if ch == '\n': p.pos = p.pos + 1; break
                if ch == '"': OutlineSkipString(p)
                elif ch == '\'': OutlineSkipCharLiteral(p)
                elif ch == '/' && p.pos + 1 < len(p.source):
                    if p.source[p.pos + 1] == '/':
                        OutlineSkipLineComment(p); p.pos = p.pos + 1; break
                    elif p.source[p.pos + 1] == '*': OutlineSkipBlockComment(p)
                    else: p.pos = p.pos + 1
                elif ch == '{':
                    p.pos = p.pos + 1
                    if !OutlineSkipToMatchingBrace(p): break
                elif ch == '=':
                    if !OutlineSkipBody(p):
                        seqs.Add(p.errors, Fmt"could not skip body of {keyword} {name}")
                    break
                else: p.pos = p.pos + 1
            OutlineUpdateLastDeclEnd(p)

        elif keyword == "macro" || keyword == "template" || keyword == "concept" || keyword == "trait":
            let declKind: OutlineDeclKind =
                if keyword == "macro": OutlineMacro
                elif keyword == "template": OutlineTemplate
                elif keyword == "concept": OutlineConcept
                else: OutlineTrait
            OutlineSkipWhitespaceAndComments(p)
            let name = OutlineReadIdentifier(p)
            OutlineRecordDecl(p, declKind, name, kwStart,
                Fmt"{keyword} {name}", annotations, 0)
            if !OutlineSkipToColonOrEquals(p): OutlineSkipToNextLine(p); continue
            let sep = p.source[p.pos]
            p.pos = p.pos + 1
            if sep == ':' || sep == '=':
                if !OutlineSkipBody(p):
                    seqs.Add(p.errors, Fmt"could not skip body of {keyword} {name}")
            else:
                OutlineSkipToNextLine(p)
            OutlineUpdateLastDeclEnd(p)

        elif keyword == "enum":
            OutlineSkipWhitespaceAndComments(p)
            let name = OutlineReadIdentifier(p)
            OutlineRecordDecl(p, OutlineEnum, name, kwStart,
                Fmt"enum {name}", annotations, 0)
            OutlineSkipWhitespaceAndComments(p)
            if p.pos < len(p.source) && p.source[p.pos] == ':':
                p.pos = p.pos + 1
            OutlineSkipWhitespaceAndComments(p)
            if p.pos < len(p.source) && (p.source[p.pos] == '\n' || p.source[p.pos] == '='):
                if !OutlineSkipBody(p):
                    seqs.Add(p.errors, Fmt"could not skip body of enum {name}")
                OutlineUpdateLastDeclEnd(p)

        elif keyword == "set":
            OutlineSkipWhitespaceAndComments(p)
            let name = OutlineReadIdentifier(p)
            OutlineRecordDecl(p, OutlineSet, name, kwStart,
                Fmt"set {name}", annotations, 0)
            OutlineSkipWhitespaceAndComments(p)
            if p.pos < len(p.source) && p.source[p.pos] == '=':
                if !OutlineSkipBody(p):
                    seqs.Add(p.errors, Fmt"could not skip body of set {name}")
            else:
                OutlineSkipToNextLine(p)
            OutlineUpdateLastDeclEnd(p)

        else:
            OutlineSkipToNextLine(p)

    return true

# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

fn OutlineParseFile(filePath: str): OutlineParser =
    let source = os.ReadFile(filePath)
    var parser: OutlineParser
    parser.source = source
    parser.pos = 0
    parser.currentModulePath = ""
    OutlineParseModule(parser)
    return parser

fn OutlineParseSource(source: str, modulePath: str): OutlineParser =
    var parser: OutlineParser
    parser.source = source
    parser.pos = 0
    parser.currentModulePath = modulePath
    OutlineParseModule(parser)
    return parser

fn OutlineParserFunctionCount(p: OutlineParser): int32 =
    var count: int32
    var i: int32
    while i < len(p.declarations):
        if p.declarations[i].kind == OutlineFn: count = count + 1
        i = i + 1
    return count

fn OutlineParserDeclarationNames(p: OutlineParser): str[] =
    var names: str[]
    var i: int32
    while i < len(p.declarations):
        if len(p.declarations[i].name) > 0: seqs.Add(names, p.declarations[i].name)
        i = i + 1
    return names

fn OutlineParserBuildSymbolTable(p: OutlineParser): OutlineSymbolTable =
    var table: OutlineSymbolTable
    var i: int32
    while i < len(p.declarations):
        let decl = p.declarations[i]
        if len(decl.name) > 0:
            seqs.Add(table.names, decl.name)
            seqs.Add(table.kinds, decl.kind)
            seqs.Add(table.sourceStarts, decl.sourceStart)
            seqs.Add(table.sourceEnds, decl.sourceEnd)
            seqs.Add(table.modulePaths, decl.modulePath)
            seqs.Add(table.isPublicFlags, decl.isPublic)
            seqs.Add(table.genericCounts, len(decl.genericParams))
        i = i + 1
    return table

fn OutlineParserHasErrors(p: OutlineParser): bool =
    return len(p.errors) > 0

fn OutlineParserDiagnostics(p: OutlineParser): str =
    if len(p.errors) == 0: return "no errors"
    var result: str
    var i: int32
    while i < len(p.errors):
        if len(result) > 0: result = Fmt"{result}\n"
        result = Fmt"{result}{p.errors[i]}"
        i = i + 1
    return result
