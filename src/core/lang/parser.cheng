import std/result
import std/buffer
import std/os as os
import std/rawbytes
import std/rawmem_support
import std/system
import cheng/core/tooling/path as v3path
import cheng/core/tooling/root_discovery as rootdisco

type
    V3ParsedSourceKind = enum
        v3ParsedOrdinarySource

    V3ParserExternalPackageRoot =
        packageId: str
        packageRoot: str

    V3ImportEdge =
        ownerModulePath: str
        targetModulePath: str
        targetSourcePath: str
        targetSourcePathLen: int32
        targetSourcePathFirstCode: int32
        targetSourcePathLastCode: int32
        targetSourcePathDotCount: int32
        targetSourcePathHash: int32
        targetProfileIndex: int32
        importAlias: str
        qualifier: str
        allowsUnqualifiedCall: bool
        resolved: bool

    V3NormalizedExprKind = enum
        v3NormalizedExprIf
        v3NormalizedExprRange
        v3NormalizedExprComprehension
        v3NormalizedExprStrFormat
        v3NormalizedExprResultIntrinsic
        v3NormalizedExprCall
        v3NormalizedExprTry
        v3NormalizedExprDefaultInit
        v3NormalizedExprConstructor

    V3NormalizedExprDetailKind = enum
        v3NormalizedExprDetailNone
        v3NormalizedExprDetailIfKeyword
        v3NormalizedExprDetailIfTernary
        v3NormalizedExprDetailTryPostfixQuestion
        v3NormalizedExprDetailRangeInclusive
        v3NormalizedExprDetailRangeExclusive
        v3NormalizedExprDetailComprehensionList
        v3NormalizedExprDetailStrFormatLiteral
        v3NormalizedExprDetailStrFormatCall
        v3NormalizedExprDetailResultOk
        v3NormalizedExprDetailResultErr
        v3NormalizedExprDetailResultValue
        v3NormalizedExprDetailResultError
        v3NormalizedExprDetailResultIsOk
        v3NormalizedExprDetailResultIsErr
        v3NormalizedExprDetailResultErrorInfoOf

    V3NormalizedExprSurfaceCallKind = enum
        v3NormalizedExprSurfaceCallNone
        v3NormalizedExprSurfaceCallLocal
        v3NormalizedExprSurfaceCallExternal
        v3NormalizedExprSurfaceCallImportc
        v3NormalizedExprSurfaceCallMember

    V3NormalizedExprCallReason = enum
        v3NormalizedExprCallReasonNone
        v3NormalizedExprCallReasonUnknownQualifiedTarget
        v3NormalizedExprCallReasonShadowedQualifiedTarget
        v3NormalizedExprCallReasonAmbiguousExternalTarget
        v3NormalizedExprCallReasonAmbiguousQualifiedTarget
        v3NormalizedExprCallReasonUnknownExternalTarget
        v3NormalizedExprCallReasonUnknownCallTarget

    V3NormalizedExpr =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: V3NormalizedExprKind
        detailKind: V3NormalizedExprDetailKind
        surfaceText: str
        callSurfaceKind: V3NormalizedExprSurfaceCallKind
        callResolved: bool
        callReason: V3NormalizedExprCallReason
        callQualifier: str
        callCallee: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callPrefixStyle: bool
        callArgCount: int32
        callArgsText: str

    V3NormalizedExprLookupBucket =
        sourcePathLen: int32
        sourcePathFirstCode: int32
        sourcePathLastCode: int32
        lineNumber: int32
        columnNumber: int32
        kindCode: int32
        detailCode: int32
        surfaceLen: int32
        surfaceFirstCode: int32
        surfaceLastCode: int32
        items: int32[]

    V3NormalizedExprLookupKey =
        sourcePathLen: int32
        sourcePathFirstCode: int32
        sourcePathLastCode: int32
        lineNumber: int32
        columnNumber: int32
        kindCode: int32
        detailCode: int32
        surfaceLen: int32
        surfaceFirstCode: int32
        surfaceLastCode: int32

    V3NormalizedExprLookup =
        slots: int32[]
        buckets: V3NormalizedExprLookupBucket[]

    V3NormalizedExprLayer =
        sourceCount: int32
        exprs: V3NormalizedExpr[]
        questionResidualCount: int32
        exprLookup: V3NormalizedExprLookup

    V3ParsedSourceStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entrySourcePath: str
        sourcePath: str
        moduleStem: str
        syntaxTag: str
        sourceKind: V3ParsedSourceKind
        ownerModulePaths: str[]
        importEdges: V3ImportEdge[]
        orderedClosureSourcePaths: str[]
        normalizedExprLayer: V3NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        unresolvedImportCount: int32

    V3NormalizedFunctionDecl =
        name: str
        lineIndex: int32
        importc: bool
        explicitExportName: str
        surfaceKeyword: str

    V3NormalizedTypeDecl =
        name: str
        refObject: bool

    V3NormalizedExprCallProfile =
        sourcePath: str
        ownerModulePath: str
        text: str
        lines: str[]
        decls: V3NormalizedFunctionDecl[]
        typeDecls: V3NormalizedTypeDecl[]
        importcCallNames: str[]
        localCallNames: str[]
        importEdges: V3ImportEdge[]
        maxQualifiedCallDepth: int32

    V3NormalizedExprResolvedCallTarget =
        sourcePath: str
        importc: bool
        reason: V3NormalizedExprCallReason

    V3ParserImportedTargetLookup =
        targetProfileIndex: int32
        reason: V3NormalizedExprCallReason

    V3ParserTextSeqCacheEntry =
        profileIndex: int32
        items: str[]

    V3ParserQualifiedTextSeqCacheEntry =
        profileIndex: int32
        prefix: str
        items: str[]

    V3ParserTextLookupKey =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32

    V3ParserTextLookupBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32
        items: str[]

    V3ParserTextLookup =
        slots: int32[]
        buckets: V3ParserTextLookupBucket[]
        totalCount: int32

    V3ParserSourcePathIndexEntry =
        sourcePath: str
        profileIndex: int32

    V3ParserSourcePathIndexBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        sourcePathHash: int32
        items: V3ParserSourcePathIndexEntry[]

    V3ParserSourcePathIndexLookup =
        slots: int32[]
        buckets: V3ParserSourcePathIndexBucket[]

type
    V3ParserProfileCallLookupCacheEntry =
        localLookup: V3ParserTextLookup
        importcLookup: V3ParserTextLookup

fn v3ParsedSourceKindText(kind: V3ParsedSourceKind): str =
    if kind == v3ParsedOrdinarySource:
        return "ordinary_cheng_source"
    return "unknown"

fn v3ParsedSourceWorkspaceRoot(parsed: V3ParsedSourceStub): str =
    return parsed.workspaceRoot

fn v3NormalizedExprKindText(kind: V3NormalizedExprKind): str =
    if kind == v3NormalizedExprIf:
        return "IfExpr"
    if kind == v3NormalizedExprRange:
        return "RangeExpr"
    if kind == v3NormalizedExprComprehension:
        return "ComprehensionExpr"
    if kind == v3NormalizedExprStrFormat:
        return "StrFormatExpr"
    if kind == v3NormalizedExprResultIntrinsic:
        return "ResultIntrinsic"
    if kind == v3NormalizedExprCall:
        return "CallExpr"
    if kind == v3NormalizedExprTry:
        return "TryExpr"
    if kind == v3NormalizedExprDefaultInit:
        return "DefaultInitExpr"
    if kind == v3NormalizedExprConstructor:
        return "ConstructorExpr"
    return "UnknownExpr"

fn v3NormalizedExprDetailKindCode(detailKind: V3NormalizedExprDetailKind): int32 =
    if detailKind == v3NormalizedExprDetailIfKeyword:
        return 1
    if detailKind == v3NormalizedExprDetailIfTernary:
        return 2
    if detailKind == v3NormalizedExprDetailTryPostfixQuestion:
        return 3
    if detailKind == v3NormalizedExprDetailRangeInclusive:
        return 4
    if detailKind == v3NormalizedExprDetailRangeExclusive:
        return 5
    if detailKind == v3NormalizedExprDetailComprehensionList:
        return 6
    if detailKind == v3NormalizedExprDetailStrFormatLiteral:
        return 7
    if detailKind == v3NormalizedExprDetailStrFormatCall:
        return 8
    if detailKind == v3NormalizedExprDetailResultOk:
        return 9
    if detailKind == v3NormalizedExprDetailResultErr:
        return 10
    if detailKind == v3NormalizedExprDetailResultValue:
        return 11
    if detailKind == v3NormalizedExprDetailResultError:
        return 12
    if detailKind == v3NormalizedExprDetailResultIsOk:
        return 13
    if detailKind == v3NormalizedExprDetailResultIsErr:
        return 14
    if detailKind == v3NormalizedExprDetailResultErrorInfoOf:
        return 15
    return 0

fn v3ParserCallSurfaceKindText(kind: V3NormalizedExprSurfaceCallKind): str =
    if kind == v3NormalizedExprSurfaceCallLocal:
        return "local_call"
    if kind == v3NormalizedExprSurfaceCallExternal:
        return "external_call"
    if kind == v3NormalizedExprSurfaceCallImportc:
        return "importc_call"
    if kind == v3NormalizedExprSurfaceCallMember:
        return "member_call"
    return ""

fn v3ParserCallReasonText(reason: V3NormalizedExprCallReason): str =
    if reason == v3NormalizedExprCallReasonUnknownQualifiedTarget:
        return "unknown_qualified_target"
    if reason == v3NormalizedExprCallReasonShadowedQualifiedTarget:
        return "shadowed_qualified_target"
    if reason == v3NormalizedExprCallReasonAmbiguousExternalTarget:
        return "ambiguous_external_target"
    if reason == v3NormalizedExprCallReasonAmbiguousQualifiedTarget:
        return "ambiguous_qualified_target"
    if reason == v3NormalizedExprCallReasonUnknownExternalTarget:
        return "unknown_external_target"
    if reason == v3NormalizedExprCallReasonUnknownCallTarget:
        return "unknown_call_target"
    return ""

fn v3NormalizedExprClone(expr: V3NormalizedExpr): V3NormalizedExpr =
    var out: V3NormalizedExpr
    out.exprId = expr.exprId
    out.sourcePath = expr.sourcePath
    out.lineNumber = expr.lineNumber
    out.columnNumber = expr.columnNumber
    out.endLineNumber = expr.endLineNumber
    out.endColumnNumber = expr.endColumnNumber
    out.kind = expr.kind
    out.detailKind = expr.detailKind
    out.surfaceText = expr.surfaceText
    out.callSurfaceKind = expr.callSurfaceKind
    out.callResolved = expr.callResolved
    out.callReason = expr.callReason
    out.callQualifier = expr.callQualifier
    out.callCallee = expr.callCallee
    out.callTarget = expr.callTarget
    out.callTargetSourcePath = expr.callTargetSourcePath
    out.callTargetImportc = expr.callTargetImportc
    out.callPrefixStyle = expr.callPrefixStyle
    out.callArgCount = expr.callArgCount
    out.callArgsText = expr.callArgsText
    return out

fn v3NormalizedExprEndColumn(columnNumber: int32,
                             surfaceText: str): int32 =
    if len(surfaceText) <= 0:
        return columnNumber
    return columnNumber + len(surfaceText) - 1

fn v3NormalizedExprKindCode(kind: V3NormalizedExprKind): int32 =
    if kind == v3NormalizedExprIf:
        return 1
    if kind == v3NormalizedExprRange:
        return 2
    if kind == v3NormalizedExprComprehension:
        return 3
    if kind == v3NormalizedExprStrFormat:
        return 4
    if kind == v3NormalizedExprResultIntrinsic:
        return 5
    if kind == v3NormalizedExprCall:
        return 6
    if kind == v3NormalizedExprTry:
        return 7
    if kind == v3NormalizedExprDefaultInit:
        return 8
    if kind == v3NormalizedExprConstructor:
        return 9
    return 0

fn v3NormalizedExprLookupTextFirstCode(text: str): int32 =
    if text == "":
        return 0
    return int32(text[0])

fn v3NormalizedExprLookupTextLastCode(text: str): int32 =
    if text == "":
        return 0
    return int32(text[text.len - 1])

fn v3NormalizedExprLookupInit(minCap: int32): V3NormalizedExprLookup =
    var lookup: V3NormalizedExprLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    var i: int32
    while i < cap:
        add(lookup.slots, 0)
        i = i + 1
    return lookup

fn v3NormalizedExprLookupDetailKind(kind: V3NormalizedExprKind,
                                    detailKind: V3NormalizedExprDetailKind): V3NormalizedExprDetailKind =
    if kind == v3NormalizedExprCall:
        return v3NormalizedExprDetailNone
    return detailKind

fn v3NormalizedExprLookupKeyExact(sourcePath: str,
                                  lineNumber: int32,
                                  columnNumber: int32,
                                  kind: V3NormalizedExprKind,
                                  detailKind: V3NormalizedExprDetailKind,
                                  surfaceText: str): V3NormalizedExprLookupKey =
    var key: V3NormalizedExprLookupKey
    key.sourcePathLen = sourcePath.len
    key.sourcePathFirstCode = v3NormalizedExprLookupTextFirstCode(sourcePath)
    key.sourcePathLastCode = v3NormalizedExprLookupTextLastCode(sourcePath)
    key.lineNumber = lineNumber
    key.columnNumber = columnNumber
    key.kindCode = v3NormalizedExprKindCode(kind)
    key.detailCode = v3NormalizedExprDetailKindCode(v3NormalizedExprLookupDetailKind(kind, detailKind))
    key.surfaceLen = surfaceText.len
    key.surfaceFirstCode = v3NormalizedExprLookupTextFirstCode(surfaceText)
    key.surfaceLastCode = v3NormalizedExprLookupTextLastCode(surfaceText)
    return key

fn v3NormalizedExprLookupKeyFromExpr(expr: V3NormalizedExpr): V3NormalizedExprLookupKey =
    return v3NormalizedExprLookupKeyExact(expr.sourcePath,
                                          expr.lineNumber,
                                          expr.columnNumber,
                                          expr.kind,
                                          expr.detailKind,
                                          expr.surfaceText)

fn v3NormalizedExprLookupHash(key: V3NormalizedExprLookupKey): int64 =
    var h: int64 = int64(key.sourcePathLen)
    h = h * 131 + int64(key.sourcePathFirstCode)
    h = h * 131 + int64(key.sourcePathLastCode)
    h = h * 131 + int64(key.lineNumber)
    h = h * 131 + int64(key.columnNumber)
    h = h * 131 + int64(key.kindCode)
    h = h * 131 + int64(key.detailCode)
    h = h * 131 + int64(key.surfaceLen)
    h = h * 131 + int64(key.surfaceFirstCode)
    h = h * 131 + int64(key.surfaceLastCode)
    if h < 0:
        h = -h
    return h

fn v3NormalizedExprLookupKeyMatchesBucket(key: V3NormalizedExprLookupKey,
                                          bucket: V3NormalizedExprLookupBucket): bool =
    return bucket.sourcePathLen == key.sourcePathLen &&
           bucket.sourcePathFirstCode == key.sourcePathFirstCode &&
           bucket.sourcePathLastCode == key.sourcePathLastCode &&
           bucket.lineNumber == key.lineNumber &&
           bucket.columnNumber == key.columnNumber &&
           bucket.kindCode == key.kindCode &&
           bucket.detailCode == key.detailCode &&
           bucket.surfaceLen == key.surfaceLen &&
           bucket.surfaceFirstCode == key.surfaceFirstCode &&
           bucket.surfaceLastCode == key.surfaceLastCode

fn v3NormalizedExprLookupSlotForKey(lookup: V3NormalizedExprLookup,
                                    key: V3NormalizedExprLookupKey): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = int32(v3NormalizedExprLookupHash(key) & int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucket = lookup.buckets[bucketIndexPlus1 - 1]
        if v3NormalizedExprLookupKeyMatchesBucket(key, bucket):
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3NormalizedExprLookupRehash(lookup: var V3NormalizedExprLookup,
                                newCap: int32) =
    var slots: int32[]
    var i: int32
    while i < newCap:
        add(slots, 0)
        i = i + 1
    lookup.slots = slots
    var bucketIndex: int32
    while bucketIndex < lookup.buckets.len:
        let bucket = lookup.buckets[bucketIndex]
        var key: V3NormalizedExprLookupKey
        key.sourcePathLen = bucket.sourcePathLen
        key.sourcePathFirstCode = bucket.sourcePathFirstCode
        key.sourcePathLastCode = bucket.sourcePathLastCode
        key.lineNumber = bucket.lineNumber
        key.columnNumber = bucket.columnNumber
        key.kindCode = bucket.kindCode
        key.detailCode = bucket.detailCode
        key.surfaceLen = bucket.surfaceLen
        key.surfaceFirstCode = bucket.surfaceFirstCode
        key.surfaceLastCode = bucket.surfaceLastCode
        let slot = v3NormalizedExprLookupSlotForKey(lookup, key)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1
        bucketIndex = bucketIndex + 1

fn v3NormalizedExprLookupGrow(lookup: var V3NormalizedExprLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    v3NormalizedExprLookupRehash(lookup, nextCap)

fn v3NormalizedExprLookupEnsureBucket(lookup: var V3NormalizedExprLookup,
                                      sourcePath: str,
                                      lineNumber: int32,
                                      columnNumber: int32,
                                      kind: V3NormalizedExprKind,
                                      detailKind: V3NormalizedExprDetailKind,
                                      surfaceText: str): int32 =
    if lookup.slots.len <= 0:
        lookup = v3NormalizedExprLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        v3NormalizedExprLookupGrow(lookup)
    let key = v3NormalizedExprLookupKeyExact(sourcePath,
                                             lineNumber,
                                             columnNumber,
                                             kind,
                                             detailKind,
                                             surfaceText)
    let slot = v3NormalizedExprLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: V3NormalizedExprLookupBucket
    bucket.sourcePathLen = key.sourcePathLen
    bucket.sourcePathFirstCode = key.sourcePathFirstCode
    bucket.sourcePathLastCode = key.sourcePathLastCode
    bucket.lineNumber = key.lineNumber
    bucket.columnNumber = key.columnNumber
    bucket.kindCode = key.kindCode
    bucket.detailCode = key.detailCode
    bucket.surfaceLen = key.surfaceLen
    bucket.surfaceFirstCode = key.surfaceFirstCode
    bucket.surfaceLastCode = key.surfaceLastCode
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn v3NormalizedExprLookupBucketIndexExact(lookup: V3NormalizedExprLookup,
                                          sourcePath: str,
                                          lineNumber: int32,
                                          columnNumber: int32,
                                          kind: V3NormalizedExprKind,
                                          detailKind: V3NormalizedExprDetailKind,
                                          surfaceText: str): int32 =
    if sourcePath == "":
        return -1
    let key = v3NormalizedExprLookupKeyExact(sourcePath,
                                             lineNumber,
                                             columnNumber,
                                             kind,
                                             detailKind,
                                             surfaceText)
    let slot = v3NormalizedExprLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3NormalizedExprMatchesExact(expr: V3NormalizedExpr,
                                expected: V3NormalizedExpr): bool =
    if expr.sourcePath != expected.sourcePath:
        return false
    if expr.lineNumber != expected.lineNumber:
        return false
    if expr.columnNumber != expected.columnNumber:
        return false
    if expr.kind != expected.kind:
        return false
    if expr.detailKind != expected.detailKind:
        return false
    if expr.surfaceText != expected.surfaceText:
        return false
    if expr.callSurfaceKind != expected.callSurfaceKind:
        return false
    if expr.callResolved != expected.callResolved:
        return false
    if expr.callReason != expected.callReason:
        return false
    if expr.callQualifier != expected.callQualifier:
        return false
    if expr.callCallee != expected.callCallee:
        return false
    if expr.callTarget != expected.callTarget:
        return false
    if expr.callTargetSourcePath != expected.callTargetSourcePath:
        return false
    if expr.callTargetImportc != expected.callTargetImportc:
        return false
    if expr.callPrefixStyle != expected.callPrefixStyle:
        return false
    if expr.callArgCount != expected.callArgCount:
        return false
    if expr.callArgsText != expected.callArgsText:
        return false
    return true

fn v3NormalizedExprLayerContainsExpr(layer: V3NormalizedExprLayer,
                                     expr: V3NormalizedExpr): bool =
    let bucketIndex = v3NormalizedExprLookupBucketIndexExact(layer.exprLookup,
                                                             expr.sourcePath,
                                                             expr.lineNumber,
                                                             expr.columnNumber,
                                                             expr.kind,
                                                             expr.detailKind,
                                                             expr.surfaceText)
    if bucketIndex < 0 || bucketIndex >= layer.exprLookup.buckets.len:
        return false
    let bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        let exprIndex = bucket.items[i]
        if exprIndex < 0 || exprIndex >= layer.exprs.len:
            continue
        if v3NormalizedExprMatchesExact(layer.exprs[exprIndex], expr):
            return true
    return false

fn v3NormalizedExprLayerRememberExpr(layer: var V3NormalizedExprLayer,
                                     exprIndex: int32) =
    if exprIndex < 0 || exprIndex >= layer.exprs.len:
        return
    let expr = layer.exprs[exprIndex]
    let bucketIndex = v3NormalizedExprLookupEnsureBucket(layer.exprLookup,
                                                         expr.sourcePath,
                                                         expr.lineNumber,
                                                         expr.columnNumber,
                                                         expr.kind,
                                                         expr.detailKind,
                                                         expr.surfaceText)
    if bucketIndex < 0:
        return
    var bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        if bucket.items[i] == exprIndex:
            layer.exprLookup.buckets[bucketIndex] = bucket
            return
    add(bucket.items, exprIndex)
    layer.exprLookup.buckets[bucketIndex] = bucket

fn v3NormalizedExprLayerAppendExisting(layer: var V3NormalizedExprLayer,
                                       expr: V3NormalizedExpr) =
    if v3NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3ParserConcat2(a: str, b: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserOwnedText(text: str): str =
    return newStringCopy(strDataPtr(text), strLenFast(text))

fn v3ParserWriteTextFast(outPtr: ptr,
                         writePos: var int32,
                         text: str) =
    let textLen = strLenFast(text)
    if textLen <= 0:
        return
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, writePos),
                              rawmemAsVoid(text),
                              textLen)
    writePos = writePos + textLen

fn v3ParserWriteByteFast(out: var str,
                         writePos: var int32,
                         value: int32) =
    out[writePos] = char(value)
    writePos = writePos + 1

fn v3NormalizedExprMakeId(sourcePath: str,
                          lineNumber: int32,
                          columnNumber: int32,
                          kind: V3NormalizedExprKind,
                          detailKind: V3NormalizedExprDetailKind): str =
    let lineText: str = intToStr(lineNumber)
    let columnText: str = intToStr(columnNumber)
    let kindText: str = intToStr(v3NormalizedExprKindCode(kind))
    let detailCodeText: str = intToStr(v3NormalizedExprDetailKindCode(detailKind))
    let totalLen = sourcePath.len + lineText.len + columnText.len + kindText.len + detailCodeText.len + 4
    if totalLen <= 0:
        return ""
    let out = newStringAlloc(totalLen)
    let outPtr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    v3ParserWriteTextFast(outPtr, writePos, sourcePath)
    v3ParserWriteByteFast(out, writePos, 35)
    v3ParserWriteTextFast(outPtr, writePos, lineText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, columnText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, kindText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, detailCodeText)
    return out

fn v3NormalizedExprMakeCallLikeId(sourcePath: str,
                                  lineNumber: int32,
                                  columnNumber: int32,
                                  kind: V3NormalizedExprKind,
                                  callSurfaceKind: V3NormalizedExprSurfaceCallKind,
                                  callResolved: bool,
                                  callReason: V3NormalizedExprCallReason,
                                  callQualifier: str,
                                  callCallee: str,
                                  callTarget: str,
                                  callTargetSourcePath: str,
                                  callTargetImportc: bool,
                                  callPrefixStyle: bool,
                                  callArgCount: int32,
                                  callArgsText: str): str =
    let callSurfaceKindText = v3ParserCallSurfaceKindText(callSurfaceKind)
    let callReasonText = v3ParserCallReasonText(callReason)
    let lineText: str = intToStr(lineNumber)
    let columnText: str = intToStr(columnNumber)
    let kindText: str = intToStr(v3NormalizedExprKindCode(kind))
    let resolvedText = if callResolved: "1" else: "0"
    let targetImportcText = if callTargetImportc: "1" else: "0"
    let prefixStyleText = if callPrefixStyle: "1" else: "0"
    let argCountText: str = intToStr(callArgCount)
    let normalizedTargetSourcePath = v3ParserNormalizePath(callTargetSourcePath)
    let totalLen = sourcePath.len +
                   lineText.len +
                   columnText.len +
                   kindText.len +
                   callSurfaceKindText.len +
                   resolvedText.len +
                   callReasonText.len +
                   callQualifier.len +
                   callCallee.len +
                   callTarget.len +
                   normalizedTargetSourcePath.len +
                   targetImportcText.len +
                   prefixStyleText.len +
                   argCountText.len +
                   callArgsText.len +
                   14
    if totalLen <= 0:
        return ""
    let out = newStringAlloc(totalLen)
    let outPtr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    v3ParserWriteTextFast(outPtr, writePos, sourcePath)
    v3ParserWriteByteFast(out, writePos, 35)
    v3ParserWriteTextFast(outPtr, writePos, lineText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, columnText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, kindText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callSurfaceKindText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, resolvedText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callReasonText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callQualifier)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callCallee)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callTarget)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, normalizedTargetSourcePath)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, targetImportcText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, prefixStyleText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, argCountText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, callArgsText)
    return out

fn v3NormalizedExprLayerClone(layer: V3NormalizedExprLayer): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = layer.questionResidualCount
    out.exprLookup = v3NormalizedExprLookupInit(layer.exprs.len * 2 + 8)
    out.sourceCount = layer.sourceCount
    for i in 0..<layer.exprs.len:
        v3NormalizedExprLayerAppendExisting(out, v3NormalizedExprClone(layer.exprs[i]))
    return out

fn v3NormalizedExprLayerAppend(layer: var V3NormalizedExprLayer,
                               sourcePath: str,
                               lineNumber: int32,
                               columnNumber: int32,
                               kind: V3NormalizedExprKind,
                               detailKind: V3NormalizedExprDetailKind,
                               surfaceText: str) =
    v3NormalizedExprLayerAppendSpan(layer,
                                    sourcePath,
                                    lineNumber,
                                    columnNumber,
                                    kind,
                                    detailKind,
                                    surfaceText,
                                    v3NormalizedExprEndColumn(columnNumber, surfaceText))

fn v3NormalizedExprLayerAppendSpan(layer: var V3NormalizedExprLayer,
                                   sourcePath: str,
                                   lineNumber: int32,
                                   columnNumber: int32,
                                   kind: V3NormalizedExprKind,
                                   detailKind: V3NormalizedExprDetailKind,
                                   surfaceText: str,
                                   endColumnNumberRaw: int32) =
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeId(sourcePath, lineNumber, columnNumber, kind, detailKind)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = kind
    expr.detailKind = detailKind
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = v3NormalizedExprSurfaceCallNone
    expr.callResolved = false
    expr.callReason = v3NormalizedExprCallReasonNone
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = false
    expr.callArgCount = 0
    expr.callArgsText = ""
    if v3NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3NormalizedExprLayerAppendCall(layer: var V3NormalizedExprLayer,
                                   sourcePath: str,
                                   lineNumber: int32,
                                   columnNumber: int32,
                                   surfaceText: str,
                                   callSurfaceKind: V3NormalizedExprSurfaceCallKind,
                                   callResolved: bool,
                                   callReason: V3NormalizedExprCallReason,
                                   callQualifier: str,
                                   callCallee: str,
                                   callTarget: str,
                                   callTargetSourcePath: str,
                                   callTargetImportc: bool,
                                   callArgsText: str,
                                   callArgCount: int32,
                                   callPrefixStyle: bool,
                                   endColumnNumberRaw: int32) =
    let normalizedTargetSourcePath = v3ParserNormalizePath(callTargetSourcePath)
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeCallLikeId(sourcePath,
                                                 lineNumber,
                                                 columnNumber,
                                                 v3NormalizedExprCall,
                                                 callSurfaceKind,
                                                 callResolved,
                                                 callReason,
                                                 callQualifier,
                                                 callCallee,
                                                 callTarget,
                                                 normalizedTargetSourcePath,
                                                 callTargetImportc,
                                                 callPrefixStyle,
                                                 callArgCount,
                                                 callArgsText)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = v3NormalizedExprCall
    expr.detailKind = v3NormalizedExprDetailNone
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = callSurfaceKind
    expr.callResolved = callResolved
    expr.callReason = callReason
    expr.callQualifier = callQualifier
    expr.callCallee = callCallee
    expr.callTarget = callTarget
    expr.callTargetSourcePath = normalizedTargetSourcePath
    expr.callTargetImportc = callTargetImportc
    expr.callPrefixStyle = callPrefixStyle
    expr.callArgCount = callArgCount
    expr.callArgsText = callArgsText
    if v3NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3NormalizedExprLayerAppendConstructor(layer: var V3NormalizedExprLayer,
                                          sourcePath: str,
                                          lineNumber: int32,
                                          columnNumber: int32,
                                          typeText: str,
                                          callArgsText: str,
                                          callArgCount: int32,
                                          callPrefixStyle: bool,
                                          endColumnNumberRaw: int32) =
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeCallLikeId(sourcePath,
                                                 lineNumber,
                                                 columnNumber,
                                                 v3NormalizedExprConstructor,
                                                 v3NormalizedExprSurfaceCallNone,
                                                 false,
                                                 v3NormalizedExprCallReasonNone,
                                                 "",
                                                 "",
                                                 "",
                                                 "",
                                                 false,
                                                 callPrefixStyle,
                                                 callArgCount,
                                                 callArgsText)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, typeText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = v3NormalizedExprConstructor
    expr.detailKind = v3NormalizedExprDetailNone
    expr.surfaceText = typeText
    expr.callSurfaceKind = v3NormalizedExprSurfaceCallNone
    expr.callResolved = false
    expr.callReason = v3NormalizedExprCallReasonNone
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = callPrefixStyle
    expr.callArgCount = callArgCount
    expr.callArgsText = callArgsText
    if v3NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3NormalizedExprLayerAdd(total: var V3NormalizedExprLayer,
                            delta: V3NormalizedExprLayer) =
    total.sourceCount = total.sourceCount + delta.sourceCount
    total.questionResidualCount = total.questionResidualCount + delta.questionResidualCount
    for i in 0..<delta.exprs.len:
        v3NormalizedExprLayerAppendExisting(total, v3NormalizedExprClone(delta.exprs[i]))

fn v3NormalizedExprLayerExprCount(layer: V3NormalizedExprLayer): int32 =
    return layer.exprs.len

fn v3NormalizedExprLayerCountKind(layer: V3NormalizedExprLayer,
                                  kind: V3NormalizedExprKind): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind == kind:
            count = count + 1
    return count

fn v3NormalizedExprLayerIfCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprIf)

fn v3NormalizedExprLayerRangeCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprRange)

fn v3NormalizedExprLayerComprehensionCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprComprehension)

fn v3NormalizedExprLayerStrFormatCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprStrFormat)

fn v3NormalizedExprLayerResultIntrinsicCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprResultIntrinsic)

fn v3NormalizedExprLayerTryCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprTry)

fn v3NormalizedExprLayerDefaultInitCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprDefaultInit)

fn v3NormalizedExprLayerConstructorCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprConstructor)

fn v3NormalizedExprLayerCallCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprCall)

fn v3NormalizedExprDefaultInitType(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprDefaultInit:
        return ""
    return expr.surfaceText

fn v3NormalizedExprConstructorType(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprConstructor:
        return ""
    return expr.surfaceText

fn v3NormalizedExprCallSurfaceKind(expr: V3NormalizedExpr): V3NormalizedExprSurfaceCallKind =
    if expr.kind != v3NormalizedExprCall:
        return v3NormalizedExprSurfaceCallNone
    return expr.callSurfaceKind

fn v3NormalizedExprCallResolved(expr: V3NormalizedExpr): bool =
    if expr.kind != v3NormalizedExprCall:
        return false
    return expr.callResolved

fn v3NormalizedExprCallReasonKind(expr: V3NormalizedExpr): V3NormalizedExprCallReason =
    if expr.kind != v3NormalizedExprCall:
        return v3NormalizedExprCallReasonNone
    return expr.callReason

fn v3NormalizedExprCallQualifier(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callQualifier

fn v3NormalizedExprCallCallee(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callCallee

fn v3NormalizedExprCallTarget(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callTarget

fn v3NormalizedExprCallTargetSourcePath(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callTargetSourcePath

fn v3NormalizedExprCallTargetImportc(expr: V3NormalizedExpr): bool =
    if expr.kind != v3NormalizedExprCall:
        return false
    return expr.callTargetImportc

fn v3NormalizedExprLayerCallResolvedCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callResolved:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallUnresolvedCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if !expr.callResolved:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallKindCountExact(layer: V3NormalizedExprLayer,
                                           callKind: V3NormalizedExprSurfaceCallKind): int32 =
    if callKind == v3NormalizedExprSurfaceCallNone:
        return 0
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callSurfaceKind == callKind:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallReasonCountExact(layer: V3NormalizedExprLayer,
                                             callReason: V3NormalizedExprCallReason): int32 =
    if callReason == v3NormalizedExprCallReasonNone:
        return 0
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callReason == callReason:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallTargetImportcCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callTargetImportc:
            count = count + 1
    return count

fn v3NormalizedExprLayerHasExprExact(layer: V3NormalizedExprLayer,
                                     kind: V3NormalizedExprKind,
                                     detailKind: V3NormalizedExprDetailKind,
                                     lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != kind:
            continue
        if expr.detailKind != detailKind:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3NormalizedExprLayerHasCallExpr(layer: V3NormalizedExprLayer,
                                    callKind: V3NormalizedExprSurfaceCallKind,
                                    lineNumber: int32): bool =
    if callKind == v3NormalizedExprSurfaceCallNone:
        return false
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callSurfaceKind != callKind:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3NormalizedExprLayerHasConstructorExpr(layer: V3NormalizedExprLayer,
                                           lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprConstructor:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3ParserNormalizePath(pathRaw: str): str =
    var path = v3path.V3PathTrim(pathRaw)
    while path.len > 1:
        let last = path[path.len - 1]
        if last != '/' && last != '\\':
            break
        path = v3path.V3TextSlice(path, 0, path.len - 1)
    return path

fn v3ParserBaseName(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    return v3path.V3PathBaseName(path)

fn v3ParserFileStem(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    var start: int32
    if lastSep >= 0:
        start = lastSep + 1
    var lastDot: int32 = -1
    for i in start..<path.len:
        if path[i] == '.':
            lastDot = i
    if lastDot <= start:
        return v3path.V3TextSlice(path, start, path.len - start)
    return v3path.V3TextSlice(path, start, lastDot - start)

fn v3ParserLastPathPiece(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    if lastSep + 1 >= path.len:
        return ""
    return v3path.V3TextSlice(path, lastSep + 1, path.len - lastSep - 1)

fn v3ParserDirPart(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return v3path.V3TextSlice(path, 0, lastSep)

fn v3ParserPackageManifestExists(dirRaw: str): bool =
    let dir = v3ParserNormalizePath(dirRaw)
    if dir == "":
        return false
    let manifestPath = v3path.V3PathJoin(dir, "cheng-package.toml")
    return v3path.V3PathFileExists(manifestPath)

fn v3ParserPackageManifestText(packageRootRaw: str): str =
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    let manifestPath = v3path.V3PathJoin(packageRoot, "cheng-package.toml")
    if !v3path.V3PathFileExists(manifestPath):
        return ""
    return v3ParserOwnedText(v3path.V3ReadTextFile("", manifestPath))

fn v3ParserManifestValue(manifestTextRaw: str,
                         keyRaw: str): str =
    let manifestText = v3ParserOwnedText(manifestTextRaw)
    let key = v3path.V3PathTrim(keyRaw)
    if manifestText == "" || key == "":
        return ""
    let prefix = key + " = "
    let lines = v3ParserSplitChar(manifestText, '\n')
    for i in 0..<lines.len:
        let line = v3ParserTrimmedLineWithoutComment(lines[i])
        if !v3ParserStartsWithExact(line, prefix):
            continue
        let valueStart = prefix.len
        if valueStart >= line.len || line[valueStart] != '"':
            continue
        var valueStop = valueStart + 1
        while valueStop < line.len:
            if line[valueStop] == '"':
                return v3ParserTextSliceFast(line, valueStart + 1, valueStop - valueStart - 1)
            valueStop = valueStop + 1
    return ""

fn v3ParserSharedV3Root(packageRootRaw: str): str =
    var cursor = v3ParserNormalizePath(packageRootRaw)
    while cursor != "":
        let manifestText = v3ParserPackageManifestText(cursor)
        let packageId = v3ParserManifestValue(manifestText, "package_id")
        if packageId == "pkg://cheng":
            return cursor
        let parent = v3path.V3PathParentDir(cursor)
        if parent == "" || parent == cursor:
            break
        cursor = parent
    return ""

fn v3ParserWorkspaceRoot(packageRootRaw: str): str =
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sharedV3Root = v3ParserSharedV3PackageRoot(packageRoot)
    if sharedV3Root != "":
        return sharedV3Root
    return packageRoot

fn v3ParserPackageId(packageRootRaw: str): str =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    let manifestText = v3ParserPackageManifestText(packageRoot)
    let manifestPackageId = v3ParserManifestValue(manifestText, "package_id")
    if v3ParserStartsWithExact(manifestPackageId, "pkg://"):
        return v3ParserTextSliceFast(manifestPackageId, 6, manifestPackageId.len - 6)
    if manifestPackageId != "":
        return manifestPackageId
    var lastSep: int32 = -1
    for i in 0..<packageRoot.len:
        if packageRoot[i] == '/' || packageRoot[i] == '\\':
            lastSep = i
    var name: str = packageRoot
    if lastSep >= 0:
        name = v3path.V3TextSlice(packageRoot, lastSep + 1, packageRoot.len - lastSep - 1)
    if name == "cheng-lang":
        return "cheng"
    if name == "":
        return ""
    return v3ParserConcat2("cheng/", name)

fn v3ParserExternalPackageRootNew(packageIdRaw: str,
                                  packageRootRaw: str): V3ParserExternalPackageRoot =
    var out: V3ParserExternalPackageRoot
    out.packageId = v3path.V3PathTrim(packageIdRaw)
    out.packageRoot = v3ParserNormalizePath(packageRootRaw)
    return out

fn v3ParserExternalPackageRootsClone(items: V3ParserExternalPackageRoot[]): V3ParserExternalPackageRoot[] =
    var out: V3ParserExternalPackageRoot[]
    for i in 0..<items.len:
        add(out, v3ParserExternalPackageRootNew(items[i].packageId, items[i].packageRoot))
    return out

fn v3ParserExternalPackageRootByModulePath(modulePathRaw: str,
                                           externalPackageRoots: V3ParserExternalPackageRoot[],
                                           outPackageRoot: var str,
                                           outPackageId: var str,
                                           outPackagePrefix: var str): bool =
    let modulePath = v3path.V3PathTrim(modulePathRaw)
    outPackageRoot = ""
    outPackageId = ""
    outPackagePrefix = ""
    var bestLen: int32
    for i in 0..<externalPackageRoots.len:
        let packageId = v3path.V3PathTrim(externalPackageRoots[i].packageId)
        let packageRoot = v3ParserNormalizePath(externalPackageRoots[i].packageRoot)
        if packageId == "" || packageRoot == "":
            continue
        let packagePrefix = v3ParserConcat2(packageId, "/")
        if modulePath.len <= packageId.len || !v3ParserStartsWithExact(modulePath, packagePrefix):
            continue
        if packageId.len <= bestLen:
            continue
        bestLen = packageId.len
        outPackageRoot = packageRoot
        outPackageId = packageId
        outPackagePrefix = packagePrefix
    return bestLen > 0

fn v3ParserExternalPackageRootBySourcePath(sourcePathRaw: str,
                                           externalPackageRoots: V3ParserExternalPackageRoot[],
                                           outPackageRoot: var str,
                                           outPackageId: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    outPackageRoot = ""
    outPackageId = ""
    var bestLen: int32
    for i in 0..<externalPackageRoots.len:
        let packageId = v3path.V3PathTrim(externalPackageRoots[i].packageId)
        let packageRoot = v3ParserNormalizePath(externalPackageRoots[i].packageRoot)
        if packageId == "" || packageRoot == "":
            continue
        let sourcePrefix = v3ParserConcat2(packageRoot, "/src/")
        if !v3ParserStartsWithExact(sourcePath, sourcePrefix):
            continue
        if packageRoot.len <= bestLen:
            continue
        bestLen = packageRoot.len
        outPackageRoot = packageRoot
        outPackageId = packageId
    return bestLen > 0

fn v3ParserSourceExists(path: str): bool =
    if path == "":
        return false
    return v3path.V3PathFileSize(path) > int64(0)

fn v3ParserExprIsResultIntrinsicName(name: str): bool =
    if name == "Ok" || name == "Err":
        return true
    if name == "Value" || name == "Error":
        return true
    if name == "IsOk" || name == "IsErr":
        return true
    if name == "ErrorInfoOf":
        return true
    return false

fn v3ParserResultIntrinsicDetailKind(name: str): V3NormalizedExprDetailKind =
    if name == "Ok":
        return v3NormalizedExprDetailResultOk
    if name == "Err":
        return v3NormalizedExprDetailResultErr
    if name == "Value":
        return v3NormalizedExprDetailResultValue
    if name == "Error":
        return v3NormalizedExprDetailResultError
    if name == "IsOk":
        return v3NormalizedExprDetailResultIsOk
    if name == "IsErr":
        return v3NormalizedExprDetailResultIsErr
    if name == "ErrorInfoOf":
        return v3NormalizedExprDetailResultErrorInfoOf
    return v3NormalizedExprDetailNone

fn v3ParserFmtExprDetailKind(modeRaw: str): V3NormalizedExprDetailKind =
    if modeRaw == "fmt_literal":
        return v3NormalizedExprDetailStrFormatLiteral
    if modeRaw == "fmt_call":
        return v3NormalizedExprDetailStrFormatCall
    return v3NormalizedExprDetailNone

fn v3ParserIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn v3ParserPreviousToken(lineRaw: str,
                         stopExclusive: int32): str =
    if stopExclusive <= 0:
        return ""
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !v3ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return ""
    let end = cursor - 1
    if end < 0:
        return ""
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !v3ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return ""
    return v3ParserTextSliceFast(lineRaw, start, end - start + 1)

fn v3ParserPreviousTokenIsDeclKeyword(lineRaw: str,
                                      stopExclusive: int32): bool =
    if stopExclusive <= 0:
        return false
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !v3ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return false
    let end = cursor - 1
    if end < 0:
        return false
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !v3ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return false
    let tokenLen = end - start + 1
    if tokenLen == 2 && v3ParserTextEqualsAt(lineRaw, start, "fn"):
        return true
    if tokenLen == 4 &&
       (v3ParserTextEqualsAt(lineRaw, start, "func") ||
        v3ParserTextEqualsAt(lineRaw, start, "proc")):
        return true
    if tokenLen == 6 && v3ParserTextEqualsAt(lineRaw, start, "method"):
        return true
    if tokenLen == 7 && v3ParserTextEqualsAt(lineRaw, start, "importc"):
        return true
    if tokenLen == 9 && v3ParserTextEqualsAt(lineRaw, start, "converter"):
        return true
    return false

fn v3ParserDottedQualifierDepth(lineRaw: str,
                                identStart: int32): int32 =
    if identStart <= 1:
        return 0
    let qualifierStop = identStart - 1
    if lineRaw[qualifierStop] != '.':
        return 0
    var depth: int32
    var segmentStart: int32 = identStart
    var scanning = true
    while scanning && segmentStart > 1:
        let dotPos = segmentStart - 1
        if lineRaw[dotPos] != '.':
            break
        var identPos = dotPos
        while identPos > 0:
            let prevPos = identPos - 1
            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                break
            identPos = prevPos
        if identPos >= dotPos:
            break
        depth = depth + 1
        segmentStart = identPos
        if segmentStart <= 1:
            break
        if lineRaw[segmentStart - 1] != '.':
            scanning = false
    return depth

fn v3ParserNextNonSpaceChar(lineRaw: str,
                            start: int32): char =
    var cursor = start
    while cursor < lineRaw.len:
        if !v3ParserIsInlineSpace(lineRaw[cursor]):
            return lineRaw[cursor]
        cursor = cursor + 1
    return char(0)

fn v3ParserSkipInlineSpaces(lineRaw: str,
                            start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if v3ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn v3ParserParseRangeExpr(textRaw: str,
                          startExprOut: var str,
                          endExprOut: var str,
                          endInclusiveOut: var bool): bool =
    startExprOut = ""
    endExprOut = ""
    endInclusiveOut = false
    let trimmed = v3path.V3PathTrim(textRaw)
    if trimmed == "":
        return false
    var opPos = v3ParserFindTopLevelToken(trimmed, "..<")
    var opLen: int32 = 3
    if opPos < 0:
        opPos = v3ParserFindTopLevelToken(trimmed, "..")
        opLen = 2
        endInclusiveOut = true
    if opPos <= 0 || opPos + opLen >= trimmed.len:
        return false
    startExprOut = v3path.V3PathTrim(v3ParserTextSliceFast(trimmed, 0, opPos))
    endExprOut = v3path.V3PathTrim(v3ParserTextSliceFast(trimmed,
                                                         opPos + opLen,
                                                         trimmed.len - opPos - opLen))
    return startExprOut != "" && endExprOut != ""

fn v3ParserParseRangeExprAt(lineRaw: str,
                            opPos: int32,
                            startExprOut: var str,
                            endExprOut: var str,
                            endInclusiveOut: var bool): bool =
    startExprOut = ""
    endExprOut = ""
    endInclusiveOut = false
    if opPos < 0 || opPos + 1 >= lineRaw.len:
        return false
    if lineRaw[opPos] != '.' || lineRaw[opPos + 1] != '.':
        return false
    var opLen: int32 = 2
    var hasExclusiveMarker = false
    if opPos + 2 < lineRaw.len:
        hasExclusiveMarker = lineRaw[opPos + 2] == '<'
    if hasExclusiveMarker:
        opLen = 3
    else:
        endInclusiveOut = true
    var segmentStart: int32
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var i: int32
    while i < opPos:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            i = i + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            i = i + 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            segmentStart = i + 1
            i = i + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            i = i + 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            segmentStart = i + 1
            i = i + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            i = i + 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           (ch == '=' || ch == ',' || ch == ':'):
            segmentStart = i + 1
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           v3ParserTextEqualsAt(lineRaw, i, "in"):
            var leftOk = true
            if i > 0:
                leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
            var rightOk = true
            if i + 2 < lineRaw.len:
                rightOk = !v3ParserIsIdentChar(lineRaw[i + 2])
            if leftOk && rightOk:
                segmentStart = i + 2
                i = i + 2
                continue
        i = i + 1
    var segmentStop = lineRaw.len
    inString = false
    inChar = false
    parenDepth = 0
    bracketDepth = 0
    braceDepth = 0
    i = opPos + opLen
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            i = i + 1
            continue
        if ch == ')':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            parenDepth = parenDepth - 1
            i = i + 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            i = i + 1
            continue
        if ch == ']':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            bracketDepth = bracketDepth - 1
            i = i + 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            i = i + 1
            continue
        if ch == '}':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            braceDepth = braceDepth - 1
            i = i + 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           (ch == ',' || ch == ':'):
            segmentStop = i
            break
        i = i + 1
    let rangeText = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, segmentStart, segmentStop - segmentStart))
    return v3ParserParseRangeExpr(rangeText, startExprOut, endExprOut, endInclusiveOut)

fn v3ParserParseFmtExprAt(lineRaw: str,
                          fmtPos: int32,
                          modeOut: var str,
                          literalOut: var str,
                          argTextOut: var str,
                          endColumnOut: var int32): bool =
    modeOut = ""
    literalOut = ""
    argTextOut = ""
    endColumnOut = -1
    if fmtPos < 0 || fmtPos + 3 > lineRaw.len:
        return false
    if !v3ParserTextEqualsAt(lineRaw, fmtPos, "Fmt"):
        return false
    if fmtPos > 0:
        if v3ParserIsIdentChar(lineRaw[fmtPos - 1]):
            return false
    if fmtPos + 3 < lineRaw.len:
        if v3ParserIsIdentChar(lineRaw[fmtPos + 3]):
            return false
    if v3ParserPreviousTokenIsDeclKeyword(lineRaw, fmtPos):
        return false
    let cursor = v3ParserSkipInlineSpaces(lineRaw, fmtPos + 3)
    if cursor >= lineRaw.len:
        return false
    let nextChar = lineRaw[cursor]
    if nextChar == '"':
        var closePos = cursor + 1
        while closePos < lineRaw.len:
            if lineRaw[closePos] == '"' && !v3ParserQuoteIsEscaped(lineRaw, closePos):
                modeOut = "fmt_literal"
                literalOut = v3ParserTextSliceFast(lineRaw, cursor + 1, closePos - cursor - 1)
                argTextOut = v3ParserTextSliceFast(lineRaw, cursor, closePos - cursor + 1)
                endColumnOut = closePos + 1
                return true
            closePos = closePos + 1
        return false
    if nextChar == '(':
        let closePos = v3ParserFindMatchingParen(lineRaw, cursor)
        if closePos <= cursor:
            return false
        modeOut = "fmt_call"
        argTextOut = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, cursor + 1, closePos - cursor - 1))
        endColumnOut = closePos + 1
        return true
    return false

fn v3ParserParseListComprehensionAt(lineRaw: str,
                                    openPos: int32,
                                    itemTextOut: var str,
                                    bindingTextOut: var str,
                                    sourceTextOut: var str,
                                    filterTextOut: var str,
                                    filterColumnOut: var int32,
                                    endColumnOut: var int32): bool =
    itemTextOut = ""
    bindingTextOut = ""
    sourceTextOut = ""
    filterTextOut = ""
    filterColumnOut = -1
    endColumnOut = -1
    if openPos < 0 || openPos >= lineRaw.len || lineRaw[openPos] != '[':
        return false
    let closePos = v3ParserFindMatchingBracket(lineRaw, openPos)
    if closePos <= openPos:
        return false
    let inner = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, openPos + 1, closePos - openPos - 1))
    if inner == "":
        return false
    let forPos = v3ParserFindTopLevelKeyword(inner, "for")
    if forPos <= 0:
        return false
    let inPos = v3ParserFindTopLevelKeyword(inner, "in")
    if inPos <= forPos + len("for"):
        return false
    let ifPos = v3ParserFindTopLevelKeyword(inner, "if")
    itemTextOut = v3path.V3PathTrim(v3ParserTextSliceFast(inner, 0, forPos))
    bindingTextOut = v3path.V3PathTrim(v3ParserTextSliceFast(inner,
                                                             forPos + len("for"),
                                                             inPos - forPos - len("for")))
    let sourceStop = ifPos >= 0 ? ifPos : inner.len
    sourceTextOut = v3path.V3PathTrim(v3ParserTextSliceFast(inner,
                                                            inPos + len("in"),
                                                            sourceStop - inPos - len("in")))
    if ifPos >= 0:
        filterTextOut = v3path.V3PathTrim(v3ParserTextSliceFast(inner,
                                                                ifPos + len("if"),
                                                                inner.len - ifPos - len("if")))
        filterColumnOut = openPos + ifPos + 2
    endColumnOut = closePos + 1
    return itemTextOut != "" && bindingTextOut != "" && sourceTextOut != ""

fn v3ParserIsTrimChar(ch: char): bool =
    if v3ParserIsInlineSpace(ch):
        return true
    let code = int32(ch)
    return code == 10 || code == 13

fn v3ParserTrimmedSliceRange(text: str,
                             startRaw: int32,
                             stopRaw: int32): str =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if stop <= start:
        return ""
    while start < stop:
        if !v3ParserIsTrimChar(text[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(text[stop - 1]):
            break
        stop = stop - 1
    if stop <= start:
        return ""
    return v3ParserTextSliceFast(text, start, stop - start)

fn v3ParserTrimmedLineWithoutComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return v3ParserTrimmedSliceRange(lineRaw, 0, lineRaw.len)
    return v3ParserTrimmedSliceRange(lineRaw, 0, hashPos)

fn v3ParserTrimmedLineRange(lineRaw: str,
                            startOut: var int32,
                            stopOut: var int32): bool =
    var start: int32
    var stop = lineRaw.len
    while start < stop:
        if !v3ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn v3ParserTrimmedCommentRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    var stop = lineRaw.len
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos >= 0:
        stop = hashPos
    var start: int32
    while start < stop:
        if !v3ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn v3ParserImportLineTailRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    startOut = -1
    stopOut = -1
    var lineStart: int32
    var lineStop: int32
    if !v3ParserTrimmedCommentRange(lineRaw, lineStart, lineStop):
        return false
    let importPrefix = "import "
    if lineStart + importPrefix.len > lineStop:
        return false
    if !v3ParserTextRangeEquals(lineRaw, lineStart, importPrefix.len, importPrefix):
        return false
    startOut = lineStart + importPrefix.len
    stopOut = lineStop
    return true

fn v3ParserHasNonTrimChar(lineRaw: str): bool =
    for i in 0..<lineRaw.len:
        if !v3ParserIsTrimChar(lineRaw[i]):
            return true
    return false

fn v3ParserStripLineComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return lineRaw
    return v3ParserTextSliceFast(lineRaw, 0, hashPos)

fn v3ParserAppendSimpleSurfaceExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        appendIfExprs: bool,
                                        appendQuestionExprs: bool,
                                        appendResultIntrinsics: bool,
                                        layer: var V3NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if appendQuestionExprs && ch == '?':
            let nextChar = v3ParserNextNonSpaceChar(lineRaw, i + 1)
            if nextChar == char(0) || nextChar == ',' || nextChar == ';' ||
               nextChar == ':' || nextChar == ')' || nextChar == ']' || nextChar == '}':
                v3NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            v3NormalizedExprTry,
                                            v3NormalizedExprDetailTryPostfixQuestion,
                                            "?")
            else:
                v3NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            v3NormalizedExprIf,
                                            v3NormalizedExprDetailIfTernary,
                                            "?")
            i = i + 1
            continue
        if !v3ParserIsIdentChar(ch):
            i = i + 1
            continue
        if i > 0:
            if v3ParserIsIdentChar(lineRaw[i - 1]):
                i = i + 1
                continue
        var stop = i + 1
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let ident = v3ParserTextSliceFast(lineRaw, i, stop - i)
        if appendIfExprs && ident == "if":
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprIf,
                                        v3NormalizedExprDetailIfKeyword,
                                        "if")
        elif appendResultIntrinsics && v3ParserExprIsResultIntrinsicName(ident):
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprResultIntrinsic,
                                        v3ParserResultIntrinsicDetailKind(ident),
                                        ident)
        i = stop

fn v3ParserAppendFmtExprsLine(sourcePath: str,
                              lineNumber: int32,
                              lineRaw: str,
                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        var mode = ""
        var literalText = ""
        var argText = ""
        var endColumn = -1
        if !v3ParserParseFmtExprAt(lineRaw, i, mode, literalText, argText, endColumn):
            continue
        v3NormalizedExprLayerAppendSpan(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprStrFormat,
                                        v3ParserFmtExprDetailKind(mode),
                                        "Fmt",
                                        endColumn)
    return

fn v3ParserAppendRangeExprsLine(sourcePath: str,
                                lineNumber: int32,
                                lineRaw: str,
                                layer: var V3NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i + 1 < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch != '.' || lineRaw[i + 1] != '.':
            i = i + 1
            continue
        var detailKind = v3NormalizedExprDetailRangeInclusive
        var surfaceText = ".."
        var step: int32 = 2
        var hasExclusiveMarker = false
        if i + 2 < lineRaw.len:
            hasExclusiveMarker = lineRaw[i + 2] == '<'
        if hasExclusiveMarker:
            detailKind = v3NormalizedExprDetailRangeExclusive
            surfaceText = "..<"
            step = 3
        v3NormalizedExprLayerAppend(layer,
                                    sourcePath,
                                    lineNumber,
                                    i + 1,
                                    v3NormalizedExprRange,
                                    detailKind,
                                    surfaceText)
        i = i + step
        continue

fn v3ParserCallExprUsesDedicatedNormalization(callNameRaw: str): bool =
    let callName = callNameRaw
    if v3ParserTextEqualsExact(callName, "Fmt"):
        return true
    if v3ParserTextEqualsExact(callName, "Ok"):
        return true
    if v3ParserTextEqualsExact(callName, "Err"):
        return true
    if v3ParserTextEqualsExact(callName, "Value"):
        return true
    if v3ParserTextEqualsExact(callName, "Error"):
        return true
    if v3ParserTextEqualsExact(callName, "IsOk"):
        return true
    if v3ParserTextEqualsExact(callName, "IsErr"):
        return true
    if v3ParserTextEqualsExact(callName, "ErrorInfoOf"):
        return true
    return false

fn v3ParserTypeExprIsScalarDefaultForbidden(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    return typeText == "bool" ||
           typeText == "int8" ||
           typeText == "uint8" ||
           typeText == "int16" ||
           typeText == "uint16" ||
           typeText == "int32" ||
           typeText == "int" ||
           typeText == "uint32" ||
           typeText == "int64" ||
           typeText == "uint64" ||
           typeText == "float" ||
           typeText == "float32" ||
           typeText == "float64" ||
           typeText == "char" ||
           typeText == "str" ||
           typeText == "cstring" ||
           typeText == "ptr" ||
           v3ParserStartsWithExact(typeText, "ptr[") ||
           v3ParserStartsWithExact(typeText, "Pointer[")

fn v3ParserTypeExprIsTuple(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    if !v3ParserStartsWithExact(typeText, "tuple["):
        return false
    if typeText.len <= len("tuple["):
        return false
    return typeText[typeText.len - 1] == ']'

fn v3ParserTypeExprIsSeq(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    return typeText.len >= 2 &&
           v3path.V3TextSlice(typeText, typeText.len - 2, 2) == "[]"

fn v3ParserTypeExprIsFixedArray(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    if typeText.len < 4:
        return false
    if v3ParserTypeExprIsSeq(typeText):
        return false
    if typeText[typeText.len - 1] != ']':
        return false
    var depth: int32
    var openPos: int32 = -1
    var closePos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '[':
            if depth == 0:
                openPos = i
            depth = depth + 1
            continue
        if typeText[i] == ']':
            depth = depth - 1
            if depth < 0:
                return false
            if depth == 0:
                closePos = i
    if depth != 0 || openPos <= 0 || closePos != typeText.len - 1:
        return false
    let sizeText = v3path.V3PathTrim(v3path.V3TextSlice(typeText, openPos + 1, closePos - openPos - 1))
    if sizeText == "":
        return false
    for i in 0..<sizeText.len:
        let ch = sizeText[i]
        if v3ParserIsInlineSpace(ch):
            continue
        if ch < '0' || ch > '9':
            return false
    return true

fn v3ParserTypeExprDot(typeRaw: str): int32 =
    let typeText = v3path.V3PathTrim(typeRaw)
    var dotPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '.':
            dotPos = i
    return dotPos

fn v3ParserTypeExprQualifier(typeRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    let dotPos = v3ParserTypeExprDot(typeText)
    if dotPos <= 0:
        return ""
    return v3path.V3PathTrim(v3path.V3TextSlice(typeText, 0, dotPos))

fn v3ParserTypeExprLeaf(typeRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    let dotPos = v3ParserTypeExprDot(typeText)
    if dotPos < 0:
        return v3ParserIdentPrefix(typeText)
    if dotPos + 1 >= typeText.len:
        return ""
    return v3ParserIdentPrefix(v3path.V3TextSlice(typeText, dotPos + 1, typeText.len - dotPos - 1))

fn v3ParserTypeDeclNameFromTrimmedLine(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if line == "":
        return ""
    let eqPos = v3ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return ""
    let headRaw = v3path.V3PathTrim(v3path.V3TextSlice(line, 0, eqPos))
    let genericPos = v3ParserFindTopLevelToken(headRaw, "[")
    var head = headRaw
    if genericPos > 0:
        head = v3path.V3PathTrim(v3path.V3TextSlice(headRaw, 0, genericPos))
    return v3ParserIdentPrefix(v3ParserFirstToken(head))

fn v3ParserTypeDeclIsRefObjectFromTrimmedLine(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    let eqPos = v3ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return false
    let tail = v3path.V3PathTrim(v3path.V3TextSlice(line, eqPos + 1, line.len - eqPos - 1))
    return v3ParserStartsWithExact(tail, "ref object")

fn v3ParserAddUniqueTypeDecl(out: var V3NormalizedTypeDecl[],
                             nameRaw: str,
                             refObject: bool) =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return
    for i in 0..<out.len:
        if out[i].name != name:
            continue
        if refObject:
            out[i].refObject = true
        return
    var decl: V3NormalizedTypeDecl
    decl.name = name
    decl.refObject = refObject
    add(out, decl)

fn v3ParserReadNormalizedTypeDeclsLines(lines: str[],
                                        decls: var V3NormalizedTypeDecl[]) =
    decls = []
    var inTypeBlock = false
    for i in 0..<lines.len:
        let rawLine = lines[i]
        let trimmed = v3path.V3PathTrim(v3ParserStripLineComment(rawLine))
        if !v3ParserHasLeadingIndent(rawLine):
            if trimmed == "":
                continue
            inTypeBlock = trimmed == "type"
            continue
        if !inTypeBlock:
            continue
        let declName = v3ParserTypeDeclNameFromTrimmedLine(trimmed)
        if declName == "":
            continue
        v3ParserAddUniqueTypeDecl(decls, declName, v3ParserTypeDeclIsRefObjectFromTrimmedLine(trimmed))

fn v3ParserProfileHasDeclaredType(profile: V3NormalizedExprCallProfile,
                                  nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    for i in 0..<profile.typeDecls.len:
        if profile.typeDecls[i].name == name:
            return true
    return false

fn v3ParserProfileHasRefObjectType(profile: V3NormalizedExprCallProfile,
                                   nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    for i in 0..<profile.typeDecls.len:
        if profile.typeDecls[i].name == name:
            return profile.typeDecls[i].refObject
    return false

fn v3ParserProfileImportTargetIndexForQualifier(profile: V3NormalizedExprCallProfile,
                                                qualifierRaw: str): int32 =
    let qualifier = v3ParserIdentPrefix(v3path.V3PathTrim(qualifierRaw))
    if qualifier == "":
        return -1
    var targetIndex = -1
    for i in 0..<profile.importEdges.len:
        let edge = profile.importEdges[i]
        if !edge.resolved || edge.targetProfileIndex < 0 || edge.qualifier != qualifier:
            continue
        if targetIndex < 0:
            targetIndex = edge.targetProfileIndex
            continue
        if targetIndex != edge.targetProfileIndex:
            return -1
    return targetIndex

fn v3ParserResolveQualifiedTypeProfileIndex(currentProfile: V3NormalizedExprCallProfile,
                                            profiles: V3NormalizedExprCallProfile[],
                                            qualifierChainRaw: str): int32 =
    let qualifierChain = v3path.V3PathTrim(qualifierChainRaw)
    if qualifierChain == "":
        return -1
    let parts = v3ParserSplitChar(qualifierChain, '.')
    var profile = currentProfile
    var targetIndex = -1
    for i in 0..<parts.len:
        targetIndex = v3ParserProfileImportTargetIndexForQualifier(profile, parts[i])
        if targetIndex < 0 || targetIndex >= profiles.len:
            return -1
        profile = profiles[targetIndex]
    return targetIndex

fn v3ParserResolveUnqualifiedTypeProfileIndex(currentProfile: V3NormalizedExprCallProfile,
                                              profiles: V3NormalizedExprCallProfile[],
                                              typeNameRaw: str): int32 =
    let typeName = v3ParserIdentPrefix(v3path.V3PathTrim(typeNameRaw))
    if typeName == "":
        return -1
    if v3ParserProfileHasDeclaredType(currentProfile, typeName):
        return -2
    var targetIndex = -1
    for i in 0..<currentProfile.importEdges.len:
        let edge = currentProfile.importEdges[i]
        if !edge.resolved || edge.targetProfileIndex < 0 || edge.targetProfileIndex >= profiles.len:
            continue
        if !v3ParserProfileHasDeclaredType(profiles[edge.targetProfileIndex], typeName):
            continue
        if targetIndex < 0:
            targetIndex = edge.targetProfileIndex
            continue
        if targetIndex != edge.targetProfileIndex:
            return -1
    return targetIndex

fn v3ParserDefaultInitRemovedDefaultError(exprRaw: str): str =
    let expr = v3path.V3PathTrim(exprRaw)
    return "[cheng_seed] default[T] removed expr=" + expr + "; use T() for object/tuple, typed implicit init or literals for T[]/T[N], and new(T) for ref object"

fn v3ParserDefaultInitScalarError(typeRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    return "[cheng_seed] simple type T() unsupported expr=" + typeText + "(); simple types use typed implicit init"

fn v3ParserDefaultInitSeqOrFixedError(typeRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    return "[cheng_seed] seq/fixed-array T() unsupported expr=" + typeText + "(); use typed implicit init or literals"

fn v3ParserDefaultInitRefObjectError(typeRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    return "[cheng_seed] ref object T() unsupported expr=" + typeText + "(); use new(T)"

fn v3ParserRedundantExplicitDefaultError(typeRaw: str,
                                         exprRaw: str): str =
    let typeText = v3path.V3PathTrim(typeRaw)
    let exprText = v3path.V3PathTrim(exprRaw)
    return "[cheng_seed] redundant explicit default init; omit initializer type=" + typeText + " expr=" + exprText

fn v3ParserCompactText(textRaw: str): str =
    var out = ""
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if v3ParserIsInlineSpace(ch):
            continue
        out = out + v3path.V3TextSlice(textRaw, i, 1)
    return out

fn v3ParserFindTopLevelAssignmentEq(textRaw: str): int32 =
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           ch == '=':
            var prev: char
            var next: char
            if i > 0:
                prev = textRaw[i - 1]
            if i + 1 < textRaw.len:
                next = textRaw[i + 1]
            if prev == '=' || prev == '!' || prev == '<' || prev == '>' || next == '=':
                continue
            return i
    return -1

fn v3ParserLineIndent(lineRaw: str): int32 =
    var indent: int32
    while indent < lineRaw.len:
        let ch = lineRaw[indent]
        if ch != ' ' && ch != '\t':
            break
        indent = indent + 1
    return indent

fn v3ParserTypeExprIsIntDefaultType(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    return typeText == "int8" ||
           typeText == "uint8" ||
           typeText == "int16" ||
           typeText == "uint16" ||
           typeText == "int32" ||
           typeText == "int" ||
           typeText == "uint32" ||
           typeText == "uint" ||
           typeText == "int64" ||
           typeText == "uint64"

fn v3ParserTypeExprIsFloatDefaultType(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    return typeText == "float" || typeText == "float32" || typeText == "float64"

fn v3ParserTypeExprIsStringDefaultType(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    return typeText == "str" || typeText == "cstring"

fn v3ParserTypeExprLooksLikeLowerGenericFunction(typeRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    if typeText == "" ||
       typeText == "Bytes" ||
       v3ParserTypeExprIsTuple(typeText) ||
       v3ParserTypeExprIsSeq(typeText) ||
       v3ParserTypeExprIsFixedArray(typeText) ||
       v3ParserStartsWithExact(typeText, "Result["):
        return false
    var bracketPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '[':
            bracketPos = i
            break
    if bracketPos <= 0 || bracketPos + 1 >= typeText.len:
        return false
    let base = v3ParserTypeExprLeaf(typeText)
    if base == "":
        return false
    return base[0] >= 'a' && base[0] <= 'z'

fn v3ParserDefaultInitTypeStatus(currentProfile: V3NormalizedExprCallProfile,
                                 profiles: V3NormalizedExprCallProfile[],
                                 typeRaw: str,
                                 err: var str): int32 =
    err = ""
    let typeText = v3path.V3PathTrim(typeRaw)
    if typeText == "":
        return 0
    if v3ParserTypeExprIsScalarDefaultForbidden(typeText):
        err = v3ParserDefaultInitScalarError(typeText)
        return -1
    if v3ParserTypeExprIsSeq(typeText) || v3ParserTypeExprIsFixedArray(typeText):
        err = v3ParserDefaultInitSeqOrFixedError(typeText)
        return -1
    if typeText == "Bytes" || v3ParserTypeExprIsTuple(typeText):
        return 1
    let qualifier = v3ParserTypeExprQualifier(typeText)
    let leaf = v3ParserTypeExprLeaf(typeText)
    if leaf == "":
        return 0
    if qualifier != "":
        let targetIndex = v3ParserResolveQualifiedTypeProfileIndex(currentProfile, profiles, qualifier)
        if targetIndex < 0:
            return 0
        if !v3ParserProfileHasDeclaredType(profiles[targetIndex], leaf):
            return 0
        if v3ParserProfileHasRefObjectType(profiles[targetIndex], leaf):
            err = v3ParserDefaultInitRefObjectError(typeText)
            return -1
        return 1
    let localType = v3ParserResolveUnqualifiedTypeProfileIndex(currentProfile, profiles, leaf)
    if localType == -2:
        if v3ParserProfileHasRefObjectType(currentProfile, leaf):
            err = v3ParserDefaultInitRefObjectError(typeText)
            return -1
        return 1
    if localType < 0:
        return 0
    if v3ParserProfileHasRefObjectType(profiles[localType], leaf):
        err = v3ParserDefaultInitRefObjectError(typeText)
        return -1
    return 1

fn v3ParserConstructorTypeStatus(currentProfile: V3NormalizedExprCallProfile,
                                 profiles: V3NormalizedExprCallProfile[],
                                 typeRaw: str): int32 =
    let typeText = v3path.V3PathTrim(typeRaw)
    if typeText == "":
        return 0
    if v3ParserTypeExprIsScalarDefaultForbidden(typeText):
        return 0
    if typeText == "Bytes" || v3ParserTypeExprIsTuple(typeText) ||
       v3ParserTypeExprIsSeq(typeText) || v3ParserTypeExprIsFixedArray(typeText):
        return 1
    let qualifier = v3ParserTypeExprQualifier(typeText)
    let leaf = v3ParserTypeExprLeaf(typeText)
    if leaf == "":
        return 0
    if qualifier != "":
        let targetIndex = v3ParserResolveQualifiedTypeProfileIndex(currentProfile, profiles, qualifier)
        if targetIndex < 0:
            return 0
        if !v3ParserProfileHasDeclaredType(profiles[targetIndex], leaf):
            return 0
        if v3ParserProfileHasRefObjectType(profiles[targetIndex], leaf):
            return 0
        return 1
    let localType = v3ParserResolveUnqualifiedTypeProfileIndex(currentProfile, profiles, leaf)
    if localType == -2:
        if v3ParserProfileHasRefObjectType(currentProfile, leaf):
            return 0
        return 1
    if localType < 0:
        return 0
    if v3ParserProfileHasRefObjectType(profiles[localType], leaf):
        return 0
    return 1

fn v3ParserExprMatchesImplicitDefault(currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      typeRaw: str,
                                      exprRaw: str): bool =
    let typeText = v3path.V3PathTrim(typeRaw)
    let exprText = v3path.V3PathTrim(exprRaw)
    if typeText == "" || exprText == "":
        return false
    if typeText == "bool" && exprText == "false":
        return true
    if v3ParserTypeExprIsIntDefaultType(typeText) && exprText == "0":
        return true
    if v3ParserTypeExprIsFloatDefaultType(typeText) && (exprText == "0" || exprText == "0.0"):
        return true
    if v3ParserTypeExprIsStringDefaultType(typeText) && exprText == "\"\"":
        return true
    if typeText == "char" && exprText == "'\\0'":
        return true
    if (v3ParserTypeExprIsSeq(typeText) || v3ParserTypeExprIsFixedArray(typeText)) && exprText == "[]":
        return true
    let compactType = v3ParserCompactText(typeText)
    let compactExpr = v3ParserCompactText(exprText)
    if compactType != "" && compactExpr == compactType + "()":
        var typeErr = ""
        return v3ParserDefaultInitTypeStatus(currentProfile, profiles, typeText, typeErr) > 0
    return false

fn v3ParserParseTypedInitializerLine(lineRaw: str,
                                     prefixRaw: str,
                                     typeOut: var str,
                                     exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let line = v3path.V3PathTrim(lineRaw)
    if prefixRaw != "" && !v3ParserStartsWithExact(line, prefixRaw):
        return false
    var tail = line
    if prefixRaw != "":
        tail = v3path.V3TextSlice(line, prefixRaw.len, line.len - prefixRaw.len)
    let eqPos = v3ParserFindTopLevelAssignmentEq(tail)
    if eqPos <= 0:
        return false
    let left = v3path.V3PathTrim(v3path.V3TextSlice(tail, 0, eqPos))
    let colonPos = v3ParserFindTopLevelToken(left, ":")
    if colonPos <= 0:
        return false
    typeOut = v3path.V3PathTrim(v3path.V3TextSlice(left, colonPos + 1, left.len - colonPos - 1))
    exprOut = v3path.V3PathTrim(v3path.V3TextSlice(tail, eqPos + 1, tail.len - eqPos - 1))
    return typeOut != "" && exprOut != ""

fn v3ParserParseTupleElemDefaultText(elemRaw: str,
                                     typeOut: var str,
                                     exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let elem = v3path.V3PathTrim(elemRaw)
    if elem == "":
        return false
    let eqPos = v3ParserFindTopLevelAssignmentEq(elem)
    if eqPos <= 0:
        return false
    let head = v3path.V3PathTrim(v3path.V3TextSlice(elem, 0, eqPos))
    if head == "":
        return false
    let colonPos = v3ParserFindTopLevelToken(head, ":")
    if colonPos > 0:
        typeOut = v3path.V3PathTrim(v3path.V3TextSlice(head, colonPos + 1, head.len - colonPos - 1))
    else:
        typeOut = head
    exprOut = v3path.V3PathTrim(v3path.V3TextSlice(elem, eqPos + 1, elem.len - eqPos - 1))
    return typeOut != "" && exprOut != ""

fn v3ParserFindTupleTypeRedundantDefaultLine(lineRaw: str,
                                             currentProfile: V3NormalizedExprCallProfile,
                                             profiles: V3NormalizedExprCallProfile[],
                                             typeOut: var str,
                                             exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let line = v3path.V3PathTrim(v3ParserStripLineComment(lineRaw))
    if line == "":
        return false
    let eqPos = v3ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return false
    let tupleType = v3path.V3PathTrim(v3path.V3TextSlice(line, eqPos + 1, line.len - eqPos - 1))
    if !v3ParserTypeExprIsTuple(tupleType):
        return false
    let body = v3path.V3TextSlice(tupleType, len("tuple["), tupleType.len - len("tuple[") - 1)
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var itemStart: int32
    var i: int32
    while i <= body.len:
        let atEnd = i >= body.len
        if !atEnd:
            let ch = body[i]
            if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(body, i):
                inString = !inString
                i = i + 1
                continue
            if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(body, i):
                inChar = !inChar
                i = i + 1
                continue
            if inString || inChar:
                i = i + 1
                continue
            if ch == '(':
                parenDepth = parenDepth + 1
                i = i + 1
                continue
            if ch == ')':
                parenDepth = parenDepth - 1
                i = i + 1
                continue
            if ch == '[':
                bracketDepth = bracketDepth + 1
                i = i + 1
                continue
            if ch == ']':
                bracketDepth = bracketDepth - 1
                i = i + 1
                continue
            if ch == '{':
                braceDepth = braceDepth + 1
                i = i + 1
                continue
            if ch == '}':
                braceDepth = braceDepth - 1
                i = i + 1
                continue
        var splitHere = atEnd
        if !splitHere:
            splitHere = body[i] == ',' &&
                        !inString &&
                        !inChar &&
                        parenDepth == 0 &&
                        bracketDepth == 0 &&
                        braceDepth == 0
        if splitHere:
            let item = v3path.V3PathTrim(v3path.V3TextSlice(body, itemStart, i - itemStart))
            var elemType = ""
            var elemExpr = ""
            if v3ParserParseTupleElemDefaultText(item, elemType, elemExpr) &&
               v3ParserExprMatchesImplicitDefault(currentProfile, profiles, elemType, elemExpr):
                typeOut = elemType
                exprOut = elemExpr
                return true
            itemStart = i + 1
        i = i + 1
    return false

fn v3ParserFindRedundantExplicitDefaultLine(lineRaw: str,
                                            inTypeBlock: bool,
                                            currentProfile: V3NormalizedExprCallProfile,
                                            profiles: V3NormalizedExprCallProfile[],
                                            typeOut: var str,
                                            exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    if v3ParserParseTypedInitializerLine(lineRaw, "let ", typeOut, exprOut) ||
       v3ParserParseTypedInitializerLine(lineRaw, "var ", typeOut, exprOut):
        return v3ParserExprMatchesImplicitDefault(currentProfile, profiles, typeOut, exprOut)
    if inTypeBlock:
        if v3ParserParseTypedInitializerLine(lineRaw, "", typeOut, exprOut):
            return v3ParserExprMatchesImplicitDefault(currentProfile, profiles, typeOut, exprOut)
        if v3ParserFindTupleTypeRedundantDefaultLine(lineRaw, currentProfile, profiles, typeOut, exprOut):
            return true
    return false

fn v3ParserIsTypeExprChar(ch: char): bool =
    return v3ParserIsIdentChar(ch) || ch == '.' || ch == '[' || ch == ']'

fn v3ParserFindRemovedDefaultExprLine(lineRaw: str,
                                      exprTextOut: var str,
                                      columnNumberOut: var int32): bool =
    exprTextOut = ""
    columnNumberOut = -1
    var inString = false
    var inChar = false
    var i: int32
    while i + len("default[") <= lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if i > 0:
            if v3ParserIsIdentChar(lineRaw[i - 1]):
                i = i + 1
                continue
        if !v3ParserTextEqualsAt(lineRaw, i, "default["):
            i = i + 1
            continue
        let closePos = v3ParserFindMatchingBracket(lineRaw, i + len("default"))
        if closePos < 0:
            return false
        exprTextOut = v3ParserTextSliceFast(lineRaw, i, closePos - i + 1)
        columnNumberOut = i + 1
        return true
    return false

fn v3ParserAppendDefaultInitExprsLine(sourcePath: str,
                                      lineNumber: int32,
                                      lineRaw: str,
                                      currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      layer: var V3NormalizedExprLayer,
                                      err: var str): bool =
    err = ""
    var removedExpr = ""
    var removedColumn = -1
    if v3ParserFindRemovedDefaultExprLine(lineRaw, removedExpr, removedColumn):
        let _ = removedColumn
        err = v3ParserDefaultInitRemovedDefaultError(removedExpr)
        return false
    var inString = false
    var inChar = false
    var i: int32
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar || ch != '(':
            i = i + 1
            continue
        let closePos = v3ParserFindMatchingParen(lineRaw, i)
        if closePos < 0:
            i = i + 1
            continue
        let argText = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, i + 1, closePos - i - 1))
        if argText != "":
            i = closePos + 1
            continue
        var calleeStop = i - 1
        while calleeStop >= 0:
            if !v3ParserIsInlineSpace(lineRaw[calleeStop]):
                break
            calleeStop = calleeStop - 1
        if calleeStop < 0:
            i = closePos + 1
            continue
        var calleeStart = calleeStop
        while calleeStart >= 0:
            if !v3ParserIsTypeExprChar(lineRaw[calleeStart]):
                break
            calleeStart = calleeStart - 1
        calleeStart = calleeStart + 1
        if calleeStart > calleeStop || v3ParserPreviousTokenIsDeclKeyword(lineRaw, calleeStart):
            i = closePos + 1
            continue
        let typeText = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, calleeStart, calleeStop - calleeStart + 1))
        var typeErr = ""
        let status = v3ParserDefaultInitTypeStatus(currentProfile, profiles, typeText, typeErr)
        if status < 0:
            err = typeErr
            return false
        if status > 0:
            v3NormalizedExprLayerAppendSpan(layer,
                                            sourcePath,
                                            lineNumber,
                                            calleeStart + 1,
                                            v3NormalizedExprDefaultInit,
                                            v3NormalizedExprDetailNone,
                                            typeText,
                                            closePos + 1)
        i = closePos + 1
    return true

fn v3ParserAppendConstructorExprsLine(sourcePath: str,
                                      lineNumber: int32,
                                      lineRaw: str,
                                      currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      layer: var V3NormalizedExprLayer) =
    var inString = false
    var inChar = false
    var i: int32
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar || ch != '(':
            i = i + 1
            continue
        let closePos = v3ParserFindMatchingParen(lineRaw, i)
        if closePos < 0:
            i = i + 1
            continue
        let argsText = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, i + 1, closePos - i - 1))
        if argsText == "":
            i = closePos + 1
            continue
        var calleeStop = i - 1
        while calleeStop >= 0:
            if !v3ParserIsInlineSpace(lineRaw[calleeStop]):
                break
            calleeStop = calleeStop - 1
        if calleeStop < 0:
            i = closePos + 1
            continue
        var calleeStart = calleeStop
        while calleeStart >= 0:
            if !v3ParserIsTypeExprChar(lineRaw[calleeStart]):
                break
            calleeStart = calleeStart - 1
        calleeStart = calleeStart + 1
        if calleeStart > calleeStop || v3ParserPreviousTokenIsDeclKeyword(lineRaw, calleeStart):
            i = closePos + 1
            continue
        let typeText = v3path.V3PathTrim(v3ParserTextSliceFast(lineRaw, calleeStart, calleeStop - calleeStart + 1))
        if v3ParserConstructorTypeStatus(currentProfile, profiles, typeText) > 0:
            v3NormalizedExprLayerAppendConstructor(layer,
                                                   sourcePath,
                                                   lineNumber,
                                                   calleeStart + 1,
                                                   typeText,
                                                   argsText,
                                                   v3ParserCountTopLevelArgs(argsText),
                                                   false,
                                                   closePos + 1)
        i = closePos + 1

fn v3ParserCallExprFirstDotExact(text: str): int32 =
    for i in 0..<text.len:
        if text[i] == '.':
            return i
    return -1

fn v3ParserCallExprLastDotExact(text: str): int32 =
    var dotPos: int32 = -1
    for i in 0..<text.len:
        if text[i] == '.':
            dotPos = i
    return dotPos

fn v3ParserCallExprLastDot(textRaw: str): int32 =
    return v3ParserCallExprLastDotExact(v3path.V3PathTrim(textRaw))

fn v3ParserFindMatchingParen(textRaw: str,
                             openPos: int32): int32 =
    let openCh: char = '('
    let closeCh: char = ')'
    return v3ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn v3ParserFindMatchingBracket(textRaw: str,
                               openPos: int32): int32 =
    let openCh: char = '['
    let closeCh: char = ']'
    return v3ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn v3ParserFindMatchingBrace(textRaw: str,
                             openPos: int32): int32 =
    let openCh: char = '{'
    let closeCh: char = '}'
    return v3ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn v3ParserFindMatchingPair(textRaw: str,
                            openPos: int32,
                            openCh: char,
                            closeCh: char): int32 =
    if openPos < 0 || openPos >= textRaw.len:
        return -1
    if textRaw[openPos] != openCh:
        return -1
    var depth: int32
    var inString = false
    var inChar = false
    for i in openPos..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == openCh:
            depth = depth + 1
        elif ch == closeCh:
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn v3ParserFindTopLevelToken(textRaw: str,
                             target: str): int32 =
    if target == "" || target.len > textRaw.len:
        return -1
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           v3ParserTextEqualsAt(textRaw, i, target):
            return i
    return -1

fn v3ParserFindTopLevelKeyword(textRaw: str,
                               keyword: str): int32 =
    if keyword == "" || keyword.len > textRaw.len:
        return -1
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !v3ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth != 0 || bracketDepth != 0 || braceDepth != 0:
            continue
        if !v3ParserTextEqualsAt(textRaw, i, keyword):
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(textRaw[i - 1])
        let rightPos = i + keyword.len
        var rightOk = true
        if rightPos < textRaw.len:
            rightOk = !v3ParserIsIdentChar(textRaw[rightPos])
        if leftOk && rightOk:
            return i
    return -1

fn v3ParserSplitTopLevelCsv(textRaw: str): str[] =
    var out: str[]
    var start: int32
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let piece = textRaw[i]
        if piece == '[':
            bracketDepth = bracketDepth + 1
        elif piece == ']':
            bracketDepth = bracketDepth - 1
        elif piece == '(':
            parenDepth = parenDepth + 1
        elif piece == ')':
            parenDepth = parenDepth - 1
        elif piece == '{':
            braceDepth = braceDepth + 1
        elif piece == '}':
            braceDepth = braceDepth - 1
        elif piece == ',' && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            add(out, v3path.V3PathTrim(v3path.V3TextSlice(textRaw, start, i - start)))
            start = i + 1
    add(out, v3path.V3PathTrim(v3path.V3TextSlice(textRaw, start, textRaw.len - start)))
    return out

fn v3ParserQuoteIsEscaped(textRaw: str,
                          indexRaw: int32): bool =
    var index = indexRaw - 1
    var slashCount: int32
    while index >= 0:
        if textRaw[index] != '\\':
            break
        slashCount = slashCount + 1
        index = index - 1
    return slashCount % 2 == 1

fn v3ParserCountTopLevelArgs(textRaw: str): int32 =
    var trimmedWhole = v3path.V3PathTrim(textRaw)
    if trimmedWhole == "":
        return 0
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var itemCount: int32
    var itemStart: int32
    var i: int32
    while i <= textRaw.len:
        let atEnd = i >= textRaw.len
        var splitHere = atEnd
        if !atEnd:
            let ch = textRaw[i]
            if !inChar && ch == '"' && !v3ParserQuoteIsEscaped(textRaw, i):
                inString = !inString
            elif !inString && ch == '\'' && !v3ParserQuoteIsEscaped(textRaw, i):
                inChar = !inChar
            elif !inString && !inChar && ch == '(':
                parenDepth = parenDepth + 1
            elif !inString && !inChar && ch == ')':
                parenDepth = parenDepth - 1
            elif !inString && !inChar && ch == '[':
                bracketDepth = bracketDepth + 1
            elif !inString && !inChar && ch == ']':
                bracketDepth = bracketDepth - 1
            elif !inString && !inChar && ch == '{':
                braceDepth = braceDepth + 1
            elif !inString && !inChar && ch == '}':
                braceDepth = braceDepth - 1
            elif !inString && !inChar &&
                 parenDepth == 0 &&
                 bracketDepth == 0 &&
                 braceDepth == 0 &&
                 ch == ',':
                splitHere = true
        if splitHere:
            let piece = v3path.V3PathTrim(v3ParserTextSliceFast(textRaw, itemStart, i - itemStart))
            itemCount = itemCount + 1
            itemStart = i + 1
            if atEnd:
                break
        i = i + 1
    return itemCount

fn v3ParserCallSurfaceFromOpenParen(lineRaw: str,
                                    openPos: int32,
                                    callArgsTextOut: var str,
                                    callArgCountOut: var int32,
                                    endColumnOut: var int32): bool =
    callArgsTextOut = ""
    callArgCountOut = 0
    endColumnOut = -1
    if openPos < 0 || openPos >= lineRaw.len:
        return false
    if lineRaw[openPos] != '(':
        return false
    let closePos = v3ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    callArgsTextOut = v3ParserTextSliceFast(lineRaw, openPos + 1, closePos - openPos - 1)
    callArgCountOut = v3ParserCountTopLevelArgs(callArgsTextOut)
    endColumnOut = closePos + 1
    return true

fn v3ParserFunctionScopeDeclIndex(profile: V3NormalizedExprCallProfile,
                                  lineNumber: int32): int32 =
    var scopeIndex: int32 = -1
    for i in 0..<profile.decls.len:
        if profile.decls[i].importc:
            continue
        if profile.decls[i].lineIndex > lineNumber:
            break
        scopeIndex = i
    if scopeIndex < 0:
        return -1
    var endLine: int32 = 2147483647
    if scopeIndex + 1 < profile.decls.len:
        endLine = profile.decls[scopeIndex + 1].lineIndex - 1
    if lineNumber > endLine:
        return -1
    return scopeIndex

fn v3ParserTextEqualsAt(text: str,
                        startRaw: int32,
                        expected: str): bool =
    let start = startRaw
    if start < 0:
        return false
    if expected.len <= 0:
        return false
    if start + expected.len > text.len:
        return false
    for i in 0..<expected.len:
        if text[start + i] != expected[i]:
            return false
    return true

fn v3ParserTextRangeEquals(text: str,
                           startRaw: int32,
                           countRaw: int32,
                           expected: str): bool =
    let start = startRaw
    let count = countRaw
    if start < 0:
        return false
    if count != expected.len:
        return false
    if count <= 0:
        return false
    if start + count > text.len:
        return false
    if text[start] != expected[0]:
        return false
    if count == 1:
        return true
    if text[start + count - 1] != expected[count - 1]:
        return false
    for i in 1..<(count - 1):
        if text[start + i] != expected[i]:
            return false
    return true

fn v3ParserTextEqualsExact(left: str,
                           right: str): bool =
    if left.len != right.len:
        return false
    if left.len <= 0:
        return true
    if left[0] != right[0]:
        return false
    if left.len == 1:
        return true
    if left[left.len - 1] != right[right.len - 1]:
        return false
    for i in 1..<(left.len - 1):
        if left[i] != right[i]:
            return false
    return true

fn v3ParserIdentPrefixCountInRange(text: str,
                                   startRaw: int32,
                                   stopRaw: int32): int32 =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if start >= stop:
        return 0
    var cursor = start
    while cursor < stop:
        if !v3ParserIsIdentChar(text[cursor]):
            break
        cursor = cursor + 1
    return cursor - start

fn v3ParserBindingNameRange(lineRaw: str,
                            nameStartOut: var int32,
                            nameLenOut: var int32): bool =
    nameStartOut = -1
    nameLenOut = 0
    var cursor: int32
    cursor = v3ParserSkipInlineSpaces(lineRaw, cursor)
    var keywordLen: int32
    if v3ParserTextEqualsAt(lineRaw, cursor, "let"):
        keywordLen = 3
    elif v3ParserTextEqualsAt(lineRaw, cursor, "var"):
        keywordLen = 3
    elif v3ParserTextEqualsAt(lineRaw, cursor, "const"):
        keywordLen = 5
    if keywordLen <= 0:
        return false
    let afterKeyword = cursor + keywordLen
    if afterKeyword >= lineRaw.len || !v3ParserIsInlineSpace(lineRaw[afterKeyword]):
        return false
    cursor = v3ParserSkipInlineSpaces(lineRaw, afterKeyword)
    let nameStart = cursor
    while cursor < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[cursor]):
            break
        cursor = cursor + 1
    if cursor <= nameStart:
        return false
    nameStartOut = nameStart
    nameLenOut = cursor - nameStart
    return true

fn v3ParserLineBindingMatches(lineRaw: str,
                              expectedRaw: str): bool =
    let expected = v3ParserIdentPrefix(v3path.V3PathTrim(expectedRaw))
    return v3ParserLineBindingMatchesExact(lineRaw, expected)

fn v3ParserLineBindingMatchesExact(lineRaw: str,
                                   expected: str): bool =
    if expected == "":
        return false
    var nameStart: int32 = -1
    var nameLen: int32
    if !v3ParserBindingNameRange(lineRaw, nameStart, nameLen):
        return false
    if nameLen != expected.len:
        return false
    for i in 0..<nameLen:
        if lineRaw[nameStart + i] != expected[i]:
            return false
    return true

fn v3ParserLineBindingMatchesTextRange(lineRaw: str,
                                       expectedText: str,
                                       expectedStart: int32,
                                       expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if expectedStart < 0:
        return false
    if expectedStart + expectedLen > expectedText.len:
        return false
    var nameStart: int32 = -1
    var nameLen: int32
    if !v3ParserBindingNameRange(lineRaw, nameStart, nameLen):
        return false
    if nameLen != expectedLen:
        return false
    for i in 0..<nameLen:
        if lineRaw[nameStart + i] != expectedText[expectedStart + i]:
            return false
    return true

fn v3ParserFunctionParamsContainBinding(lineRaw: str,
                                        expectedRaw: str): bool =
    let expected = v3ParserIdentPrefix(v3path.V3PathTrim(expectedRaw))
    return v3ParserFunctionParamsContainBindingExact(lineRaw, expected)

fn v3ParserFunctionParamsContainBindingExact(lineRaw: str,
                                             expected: str): bool =
    if expected == "":
        return false
    var openPos: int32 = -1
    openPos = v3ParserFindText(lineRaw, "(")
    if openPos < 0:
        return false
    var closePos: int32 = -1
    closePos = v3ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    var itemStart = openPos + 1
    var depthParen: int32
    var depthBracket: int32
    var depthBrace: int32
    var i = itemStart
    while i <= closePos:
        var itemStop = i
        var endItem = false
        if i >= closePos:
            itemStop = closePos
            endItem = true
        elif lineRaw[i] == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            itemStop = i
            endItem = true
        elif lineRaw[i] == '(':
            depthParen = depthParen + 1
        elif lineRaw[i] == ')':
            if depthParen > 0:
                depthParen = depthParen - 1
        elif lineRaw[i] == '[':
            depthBracket = depthBracket + 1
        elif lineRaw[i] == ']':
            if depthBracket > 0:
                depthBracket = depthBracket - 1
        elif lineRaw[i] == '{':
            depthBrace = depthBrace + 1
        elif lineRaw[i] == '}':
            if depthBrace > 0:
                depthBrace = depthBrace - 1
        if endItem:
            var cursor = v3ParserSkipInlineSpaces(lineRaw, itemStart)
            if v3ParserTextEqualsAt(lineRaw, cursor, "var"):
                let afterVar = cursor + 3
                if afterVar < itemStop && v3ParserIsInlineSpace(lineRaw[afterVar]):
                    cursor = v3ParserSkipInlineSpaces(lineRaw, afterVar)
            let nameStart = cursor
            while cursor < itemStop:
                if !v3ParserIsIdentChar(lineRaw[cursor]):
                    break
                cursor = cursor + 1
            let nameLen = cursor - nameStart
            if nameLen == expected.len && nameLen > 0:
                var matched = true
                for partIndex in 0..<nameLen:
                    if lineRaw[nameStart + partIndex] != expected[partIndex]:
                        matched = false
                        break
                if matched:
                    return true
            itemStart = i + 1
        i = i + 1
    return false

fn v3ParserFunctionParamsContainBindingTextRange(lineRaw: str,
                                                 expectedText: str,
                                                 expectedStart: int32,
                                                 expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if expectedStart < 0:
        return false
    if expectedStart + expectedLen > expectedText.len:
        return false
    var openPos: int32 = -1
    openPos = v3ParserFindText(lineRaw, "(")
    if openPos < 0:
        return false
    var closePos: int32 = -1
    closePos = v3ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    var itemStart = openPos + 1
    var depthParen: int32
    var depthBracket: int32
    var depthBrace: int32
    var i = itemStart
    while i <= closePos:
        var itemStop = i
        var endItem = false
        if i >= closePos:
            itemStop = closePos
            endItem = true
        elif lineRaw[i] == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            itemStop = i
            endItem = true
        elif lineRaw[i] == '(':
            depthParen = depthParen + 1
        elif lineRaw[i] == ')':
            if depthParen > 0:
                depthParen = depthParen - 1
        elif lineRaw[i] == '[':
            depthBracket = depthBracket + 1
        elif lineRaw[i] == ']':
            if depthBracket > 0:
                depthBracket = depthBracket - 1
        elif lineRaw[i] == '{':
            depthBrace = depthBrace + 1
        elif lineRaw[i] == '}':
            if depthBrace > 0:
                depthBrace = depthBrace - 1
        if endItem:
            var cursor = v3ParserSkipInlineSpaces(lineRaw, itemStart)
            if v3ParserTextEqualsAt(lineRaw, cursor, "var"):
                let afterVar = cursor + 3
                if afterVar < itemStop && v3ParserIsInlineSpace(lineRaw[afterVar]):
                    cursor = v3ParserSkipInlineSpaces(lineRaw, afterVar)
            let nameStart = cursor
            while cursor < itemStop:
                if !v3ParserIsIdentChar(lineRaw[cursor]):
                    break
                cursor = cursor + 1
            let nameLen = cursor - nameStart
            if nameLen == expectedLen && nameLen > 0:
                var matched = true
                for partIndex in 0..<nameLen:
                    if lineRaw[nameStart + partIndex] != expectedText[expectedStart + partIndex]:
                        matched = false
                        break
                if matched:
                    return true
            itemStart = i + 1
        i = i + 1
    return false

fn v3ParserScopeHasVisibleBinding(profile: V3NormalizedExprCallProfile,
                                  scopeIndex: int32,
                                  lineNumber: int32,
                                  expectedRaw: str): bool =
    let expected = v3ParserIdentPrefix(v3path.V3PathTrim(expectedRaw))
    return v3ParserScopeHasVisibleBindingExact(profile, scopeIndex, lineNumber, expected)

fn v3ParserScopeHasVisibleBindingExact(profile: V3NormalizedExprCallProfile,
                                       scopeIndex: int32,
                                       lineNumber: int32,
                                       expected: str): bool =
    if expected == "":
        return false
    if scopeIndex < 0 || scopeIndex >= profile.decls.len:
        return false
    let declLineIndex = profile.decls[scopeIndex].lineIndex
    if declLineIndex > 0 && declLineIndex <= profile.lines.len:
        if v3ParserFunctionParamsContainBindingExact(profile.lines[declLineIndex - 1], expected):
            return true
    var scanLine = declLineIndex + 1
    while scanLine < lineNumber && scanLine <= profile.lines.len:
        if v3ParserLineBindingMatchesExact(profile.lines[scanLine - 1], expected):
            return true
        scanLine = scanLine + 1
    return false

fn v3ParserScopeHasVisibleBindingTextRange(profile: V3NormalizedExprCallProfile,
                                           scopeIndex: int32,
                                           lineNumber: int32,
                                           expectedText: str,
                                           expectedStart: int32,
                                           expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if scopeIndex < 0 || scopeIndex >= profile.decls.len:
        return false
    let declLineIndex = profile.decls[scopeIndex].lineIndex
    if declLineIndex > 0 && declLineIndex <= profile.lines.len:
        if v3ParserFunctionParamsContainBindingTextRange(profile.lines[declLineIndex - 1],
                                                         expectedText,
                                                         expectedStart,
                                                         expectedLen):
            return true
    var scanLine = declLineIndex + 1
    while scanLine < lineNumber && scanLine <= profile.lines.len:
        if v3ParserLineBindingMatchesTextRange(profile.lines[scanLine - 1],
                                               expectedText,
                                               expectedStart,
                                               expectedLen):
            return true
        scanLine = scanLine + 1
    return false

fn v3ParserQualifiedTargetRootQualifierExact(target: str): str =
    if target == "":
        return ""
    let dotPos = v3ParserCallExprFirstDotExact(target)
    if dotPos <= 0:
        return ""
    return v3ParserTextSliceFast(target, 0, dotPos)

fn v3ParserQualifiedTargetRootQualifier(targetRaw: str): str =
    return v3ParserQualifiedTargetRootQualifierExact(v3path.V3PathTrim(targetRaw))

fn v3ParserQualifiedTargetQualifierChainExact(target: str): str =
    if target == "":
        return ""
    let dotPos = v3ParserCallExprLastDotExact(target)
    if dotPos <= 0:
        return ""
    return v3ParserTextSliceFast(target, 0, dotPos)

fn v3ParserQualifiedTargetQualifierChain(targetRaw: str): str =
    return v3ParserQualifiedTargetQualifierChainExact(v3path.V3PathTrim(targetRaw))

fn v3ParserQualifiedTargetShadowReasonExact(currentProfile: V3NormalizedExprCallProfile,
                                            lineNumber: int32,
                                            target: str): V3NormalizedExprCallReason =
    let dotPos = v3ParserCallExprFirstDotExact(target)
    if dotPos <= 0:
        return v3NormalizedExprCallReasonNone
    let scopeIndex = v3ParserFunctionScopeDeclIndex(currentProfile, lineNumber)
    if v3ParserScopeHasVisibleBindingTextRange(currentProfile,
                                               scopeIndex,
                                               lineNumber,
                                               target,
                                               0,
                                               dotPos):
        return v3NormalizedExprCallReasonShadowedQualifiedTarget
    return v3NormalizedExprCallReasonNone

fn v3ParserCallExprDetailExact(kind: str,
                               callee: str,
                               qualifier: str,
                               target: str,
                               resolved: bool,
                               reason: V3NormalizedExprCallReason,
                               targetSourcePath: str,
                               targetImportc: bool): str =
    let reasonText = v3ParserCallReasonText(reason)
    var pairCount: int32 = 3
    var totalLen: int32 = 5 + kind.len +
                          7 + callee.len +
                          7 + target.len
    if qualifier != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 10 + qualifier.len
    if resolved:
        pairCount = pairCount + 1
        totalLen = totalLen + 10
    if reasonText != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 7 + reasonText.len
    if targetSourcePath != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 19 + targetSourcePath.len
    if targetImportc:
        pairCount = pairCount + 1
        totalLen = totalLen + 16
    totalLen = totalLen + (pairCount - 1)
    if totalLen <= 0:
        return ""
    let out = newStringAlloc(totalLen)
    let outPtr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    var hasPairs: bool
    v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "kind", kind)
    v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "callee", callee)
    if qualifier != "":
        v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "qualifier", qualifier)
    v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target", target)
    if resolved:
        v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "resolved", "1")
    if reasonText != "":
        v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "reason", reasonText)
    if targetSourcePath != "":
        v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target_source_path", targetSourcePath)
    if targetImportc:
        v3ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target_importc", "1")
    return out

fn v3ParserAppendCallExprDetailPair(out: var str,
                                    outPtr: ptr,
                                    writePos: var int32,
                                    hasPairs: var bool,
                                    key: str,
                                    value: str) =
    if hasPairs:
        v3ParserWriteByteFast(out, writePos, 59)
    else:
        hasPairs = true
    v3ParserWriteTextFast(outPtr, writePos, key)
    v3ParserWriteByteFast(out, writePos, 61)
    v3ParserWriteTextFast(outPtr, writePos, value)

fn v3ParserAppendCallExprsLine(sourcePath: str,
                               lineNumber: int32,
                               lineRaw: str,
                               callLookup: V3ParserTextLookup*,
                               detailKind: V3NormalizedExprSurfaceCallKind,
                               currentProfile: V3NormalizedExprCallProfile,
                               profiles: V3NormalizedExprCallProfile[],
                               profileIndexLookup: V3ParserSourcePathIndexLookup,
                               profileCallLookupCache: var V3ParserProfileCallLookupCacheEntry[],
                               layer: var V3NormalizedExprLayer) =
    if callLookup == nil:
        return
    if callLookup->totalCount <= 0:
        return
    var i: int32
    while i < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        var middleOfIdent = false
        if i > 0:
            middleOfIdent = v3ParserIsIdentChar(lineRaw[i - 1])
        if middleOfIdent:
            i = i + 1
            continue
        var stop = i
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        if v3ParserPreviousTokenIsDeclKeyword(lineRaw, i):
            i = stop
            continue
        let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        if !hasCallParen:
            i = stop
            continue
        let callName = v3ParserTextSliceFast(lineRaw, i, stop - i)
        if v3ParserCallExprUsesDedicatedNormalization(callName):
            i = stop
            continue
        var qualifierStart: int32 = -1
        var qualifierStop: int32 = -1
        var dottedStart: int32 = i
        if i > 1:
            let prevDotPos: int32 = i - 1
            if lineRaw[prevDotPos] == '.':
                qualifierStop = prevDotPos
                qualifierStart = prevDotPos
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !v3ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                dottedStart = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
        let callNameKey = v3ParserTextLookupKeyExact(callName)
        var qualifiedCallName = callName
        var qualifiedCallNameKey = callNameKey
        var dottedCallName = callName
        var dottedCallNameKey = callNameKey
        var qualifierText = ""
        if qualifierStart >= 0 && qualifierStop > qualifierStart:
            qualifierText = v3ParserTextSliceFast(lineRaw, qualifierStart, qualifierStop - qualifierStart)
            qualifiedCallName = v3ParserConcat3(qualifierText, ".", callName)
            qualifiedCallNameKey = v3ParserTextLookupKeyExact(qualifiedCallName)
        if dottedStart < i:
            dottedCallName = v3ParserTextSliceFast(lineRaw, dottedStart, stop - dottedStart)
            dottedCallNameKey = v3ParserTextLookupKeyExact(dottedCallName)
        var matchedSurfaceText = v3ParserMatchKnownCallSurfaceTextKeysPtr(callLookup,
                                                                       callName,
                                                                       callNameKey,
                                                                       qualifiedCallName,
                                                                       qualifiedCallNameKey,
                                                                       dottedCallName,
                                                                       dottedCallNameKey)
        if detailKind == v3NormalizedExprSurfaceCallExternal && matchedSurfaceText != "":
            let shadowReason = v3ParserQualifiedTargetShadowReasonExact(currentProfile,
                                                                        lineNumber,
                                                                        matchedSurfaceText)
            if shadowReason != v3NormalizedExprCallReasonNone:
                matchedSurfaceText = ""
        if matchedSurfaceText != "":
            var callArgsText = ""
            var callArgCount: int32
            var endColumnNumber: int32 = -1
            let callSurfaceOk = v3ParserCallSurfaceFromOpenParen(lineRaw,
                                                                 nextPos,
                                                                 callArgsText,
                                                                 callArgCount,
                                                                 endColumnNumber)
            let _ = callSurfaceOk
            let resolvedTarget = v3ParserResolveCallTarget(currentProfile,
                                                           profiles,
                                                           profileIndexLookup,
                                                           profileCallLookupCache,
                                                           detailKind,
                                                           matchedSurfaceText,
                                                           callName)
            let resolved = resolvedTarget.sourcePath != ""
            v3NormalizedExprLayerAppendCall(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            matchedSurfaceText,
                                            detailKind,
                                            resolved,
                                            resolvedTarget.reason,
                                            qualifierText,
                                            callName,
                                            matchedSurfaceText,
                                            resolvedTarget.sourcePath,
                                            resolvedTarget.importc,
                                            callArgsText,
                                            callArgCount,
                                            false,
                                            endColumnNumber)
        i = stop
    return

fn v3ParserAppendMemberCallExprsLine(sourcePath: str,
                                     lineNumber: int32,
                                     lineRaw: str,
                                     knownCallLookup: V3ParserTextLookup,
                                     currentProfile: V3NormalizedExprCallProfile,
                                     layer: var V3NormalizedExprLayer) =
    if knownCallLookup.totalCount <= 0:
        return
    var i: int32
    while i < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        let start = i
        var stop = i
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        if v3ParserPreviousTokenIsDeclKeyword(lineRaw, start):
            i = stop
            continue
        let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        if !hasCallParen:
            i = stop
            continue
        let callName = v3ParserTextSliceFast(lineRaw, start, stop - start)
        if v3ParserCallExprUsesDedicatedNormalization(callName):
            i = stop
            continue
        var qualifierStart: int32 = -1
        var qualifierStop: int32 = -1
        var dottedStart: int32 = start
        if start > 1:
            let prevDotPos: int32 = start - 1
            if lineRaw[prevDotPos] == '.':
                qualifierStop = prevDotPos
                qualifierStart = prevDotPos
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !v3ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                dottedStart = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
        let callNameKey = v3ParserTextLookupKeyExact(callName)
        var dottedCallName = callName
        var dottedCallNameKey = callNameKey
        var qualifiedCallName = callName
        var qualifiedCallNameKey = callNameKey
        var qualifierText = ""
        if qualifierStart >= 0 && qualifierStop > qualifierStart:
            qualifierText = v3ParserTextSliceFast(lineRaw, qualifierStart, qualifierStop - qualifierStart)
            qualifiedCallName = v3ParserConcat3(qualifierText, ".", callName)
            qualifiedCallNameKey = v3ParserTextLookupKeyExact(qualifiedCallName)
        if dottedStart < start:
            dottedCallName = v3ParserTextSliceFast(lineRaw, dottedStart, stop - dottedStart)
            dottedCallNameKey = v3ParserTextLookupKeyExact(dottedCallName)
        if dottedCallName != callName:
            let shadowReason = v3ParserQualifiedTargetShadowReasonExact(currentProfile,
                                                                        lineNumber,
                                                                        dottedCallName)
            let knownCall = v3ParserMatchKnownCallSurfaceTextKeys(knownCallLookup,
                                                                  callName,
                                                                  callNameKey,
                                                                  qualifiedCallName,
                                                                  qualifiedCallNameKey,
                                                                  dottedCallName,
                                                                  dottedCallNameKey) != ""
            if shadowReason != v3NormalizedExprCallReasonNone || !knownCall:
                var reasonText = v3NormalizedExprCallReasonUnknownQualifiedTarget
                if shadowReason != v3NormalizedExprCallReasonNone:
                    reasonText = shadowReason
                var callArgsText = ""
                var callArgCount: int32
                var endColumnNumber: int32 = -1
                let callSurfaceOk = v3ParserCallSurfaceFromOpenParen(lineRaw,
                                                                     nextPos,
                                                                     callArgsText,
                                                                     callArgCount,
                                                                     endColumnNumber)
                let _ = callSurfaceOk
                v3NormalizedExprLayerAppendCall(layer,
                                                sourcePath,
                                                lineNumber,
                                                start + 1,
                                                dottedCallName,
                                                v3NormalizedExprSurfaceCallMember,
                                                false,
                                                reasonText,
                                                qualifierText,
                                                callName,
                                                dottedCallName,
                                                "",
                                                false,
                                                callArgsText,
                                                callArgCount,
                                                false,
                                                endColumnNumber)
        i = stop
    return

fn v3ParserMaxQualifiedCallDepthLines(lines: str[]): int32 =
    var maxDepth: int32
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        if !v3ParserHasNonTrimChar(lineRaw):
            continue
        var pos: int32
        while pos < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[pos]):
                pos = pos + 1
                continue
            let start = pos
            var stop = pos
            while stop < lineRaw.len:
                if !v3ParserIsIdentChar(lineRaw[stop]):
                    break
                stop = stop + 1
            let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
            var hasCallParen = false
            if nextPos < lineRaw.len:
                hasCallParen = lineRaw[nextPos] == '('
            if hasCallParen && !v3ParserPreviousTokenIsDeclKeyword(lineRaw, start):
                let depth = v3ParserDottedQualifierDepth(lineRaw, start)
                if depth > maxDepth:
                    maxDepth = depth
            pos = stop
    return maxDepth

fn v3ParserMaxQualifiedCallDepth(text: str): int32 =
    let lines = v3ParserPrepareCodeLines(v3ParserSplitChar(text, '\n'))
    return v3ParserMaxQualifiedCallDepthLines(lines)

fn v3ParserAppendComprehensionExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        layer: var V3NormalizedExprLayer) =
    for openPos in 0..<lineRaw.len:
        if lineRaw[openPos] != '[':
            continue
        var itemText = ""
        var bindingText = ""
        var sourceText = ""
        var filterText = ""
        var filterColumn = -1
        var endColumn = -1
        if !v3ParserParseListComprehensionAt(lineRaw,
                                             openPos,
                                             itemText,
                                             bindingText,
                                             sourceText,
                                             filterText,
                                             filterColumn,
                                             endColumn):
            continue
        v3NormalizedExprLayerAppendSpan(layer,
                                        sourcePath,
                                        lineNumber,
                                        openPos + 1,
                                        v3NormalizedExprComprehension,
                                        v3NormalizedExprDetailComprehensionList,
                                        "[for in]",
                                        endColumn)

fn v3ParserImportcCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                     names: var str[]) =
    var out: str[]
    for i in 0..<decls.len:
        if !decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserLocalCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                   names: var str[]) =
    var out: str[]
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRootRaw: str,
                                                        packageRootRaw: str,
                                                        externalPackageRoots: V3ParserExternalPackageRoot[],
                                                        sourcePathRaw: str,
                                                        text: str,
                                                        profile: var V3NormalizedExprCallProfile,
                                                        err: var str): bool =
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    profile.sourcePath = sourcePath
    profile.ownerModulePath = v3ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                     packageRoot,
                                                                                     externalPackageRoots,
                                                                                     sourcePath)
    profile.text = text
    profile.lines = []
    profile.decls = []
    profile.typeDecls = []
    profile.importcCallNames = []
    profile.localCallNames = []
    profile.importEdges = []
    profile.maxQualifiedCallDepth = 0
    let lines = v3ParserSplitChar(text, '\n')
    profile.lines = lines
    let codeLines = v3ParserPrepareCodeLines(lines)
    if !v3ParserReadNormalizedFunctionDeclsLines(lines, profile.decls, err):
        return false
    v3ParserReadNormalizedTypeDeclsLines(lines, profile.typeDecls)
    if workspaceRoot != "" && packageRoot != "":
        if !v3ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 profile.ownerModulePath,
                                                                 lines,
                                                                 profile.importEdges,
                                                                 err):
            return false
    v3ParserImportcCallNamesFromDecls(profile.decls, profile.importcCallNames)
    v3ParserLocalCallNamesFromDecls(profile.decls, profile.localCallNames)
    profile.maxQualifiedCallDepth = v3ParserMaxQualifiedCallDepthLines(codeLines)
    err = ""
    return true

fn v3ParserBuildExprCallProfile(workspaceRootRaw: str,
                                packageRootRaw: str,
                                sourcePathRaw: str,
                                text: str,
                                profile: var V3NormalizedExprCallProfile,
                                err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRootRaw,
                                                                packageRootRaw,
                                                                externalPackageRoots,
                                                                sourcePathRaw,
                                                                text,
                                                                profile,
                                                                err)

fn v3ParserImportEdgeQualifier(edge: V3ImportEdge): str =
    return edge.qualifier

fn v3ParserImportEdgeAllowsUnqualifiedCall(edge: V3ImportEdge): bool =
    return edge.allowsUnqualifiedCall

fn v3ParserQualifiedCallPrefixExact(prefix: str,
                                    qualifier: str): str =
    if prefix == "":
        return qualifier
    if qualifier == "":
        return prefix
    return v3ParserConcat3(prefix, ".", qualifier)

fn v3ParserQualifiedCallPrefix(prefixRaw: str,
                               qualifierRaw: str): str =
    let prefix = v3path.V3PathTrim(prefixRaw)
    let qualifier = v3path.V3PathTrim(qualifierRaw)
    return v3ParserQualifiedCallPrefixExact(prefix, qualifier)

fn v3ParserResolvedCallTargetNew(sourcePathRaw: str,
                                 importc: bool,
                                 reasonRaw: V3NormalizedExprCallReason): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNewExact(v3ParserNormalizePath(sourcePathRaw),
                                              importc,
                                              reasonRaw)

fn v3ParserResolvedCallTargetNewExact(sourcePath: str,
                                      importc: bool,
                                      reason: V3NormalizedExprCallReason): V3NormalizedExprResolvedCallTarget =
    var out: V3NormalizedExprResolvedCallTarget
    out.sourcePath = sourcePath
    out.importc = importc
    out.reason = reason
    return out

fn v3ParserResolvedCallTargetResolved(sourcePathRaw: str,
                                      importc: bool): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNewExact(sourcePathRaw, importc, v3NormalizedExprCallReasonNone)

fn v3ParserResolvedCallTargetUnknown(reasonRaw: V3NormalizedExprCallReason): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNewExact("", false, reasonRaw)

fn v3ParserResolvedCallTargetEmpty(): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNewExact("", false, v3NormalizedExprCallReasonNone)

fn v3ParserResolvedCallTargetSame(lhs: V3NormalizedExprResolvedCallTarget,
                                  rhs: V3NormalizedExprResolvedCallTarget): bool =
    return lhs.sourcePath == rhs.sourcePath &&
           lhs.importc == rhs.importc &&
           lhs.reason == rhs.reason

fn v3ParserAppendUniqueResolvedCallTarget(out: var V3NormalizedExprResolvedCallTarget[],
                                          target: V3NormalizedExprResolvedCallTarget) =
    if target.sourcePath == "" || target.reason != v3NormalizedExprCallReasonNone:
        return
    for i in 0..<out.len:
        if v3ParserResolvedCallTargetSame(out[i], target):
            return
    add(out, target)

fn v3ParserImportedTargetLookupResolved(targetProfileIndex: int32): V3ParserImportedTargetLookup =
    var out: V3ParserImportedTargetLookup
    out.targetProfileIndex = targetProfileIndex
    out.reason = v3NormalizedExprCallReasonNone
    return out

fn v3ParserImportedTargetLookupUnknown(reasonRaw: V3NormalizedExprCallReason): V3ParserImportedTargetLookup =
    return v3ParserImportedTargetLookupUnknownExact(reasonRaw)

fn v3ParserImportedTargetLookupUnknownExact(reason: V3NormalizedExprCallReason): V3ParserImportedTargetLookup =
    var out: V3ParserImportedTargetLookup
    out.targetProfileIndex = -1
    out.reason = reason
    return out

fn v3ParserCallProfileHasImportcCall(profile: V3NormalizedExprCallProfile,
                                     nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    return v3ParserStringSeqContainsExact(profile.importcCallNames, name)

fn v3ParserCallProfileHasLocalCall(profile: V3NormalizedExprCallProfile,
                                   nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    return v3ParserStringSeqContainsExact(profile.localCallNames, name)

fn v3ParserCallProfileHasImportcCallExact(profiles: V3NormalizedExprCallProfile[],
                                          profileIndex: int32,
                                          cache: var V3ParserProfileCallLookupCacheEntry[],
                                          name: str): bool =
    if name == "":
        return false
    let cacheIndex = v3ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    return v3ParserTextLookupContainsKey(cache[cacheIndex].importcLookup,
                                         name,
                                         v3ParserTextLookupKeyExact(name))

fn v3ParserCallProfileHasLocalCallExact(profiles: V3NormalizedExprCallProfile[],
                                        profileIndex: int32,
                                        cache: var V3ParserProfileCallLookupCacheEntry[],
                                        name: str): bool =
    if name == "":
        return false
    let cacheIndex = v3ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    return v3ParserTextLookupContainsKey(cache[cacheIndex].localLookup,
                                         name,
                                         v3ParserTextLookupKeyExact(name))

fn v3ParserProfileCallLookupFlagsCached(cache: V3ParserProfileCallLookupCacheEntry[],
                                        profileIndex: int32,
                                        name: str,
                                        nameKey: V3ParserTextLookupKey,
                                        hasImportc: var bool,
                                        hasLocal: var bool): bool =
    hasImportc = false
    hasLocal = false
    if name == "" || nameKey.keyLen <= 0:
        return false
    if profileIndex < 0 || profileIndex >= cache.len:
        return false
    hasImportc = v3ParserTextLookupContainsKey(cache[profileIndex].importcLookup, name, nameKey)
    hasLocal = v3ParserTextLookupContainsKey(cache[profileIndex].localLookup, name, nameKey)
    return true

fn v3ParserProfileCallLookupFlags(profiles: V3NormalizedExprCallProfile[],
                                  profileIndex: int32,
                                  cache: var V3ParserProfileCallLookupCacheEntry[],
                                  name: str,
                                  nameKey: V3ParserTextLookupKey,
                                  hasImportc: var bool,
                                  hasLocal: var bool): bool =
    hasImportc = false
    hasLocal = false
    if name == "" || nameKey.keyLen <= 0:
        return false
    let cacheIndex = v3ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    hasImportc = v3ParserTextLookupContainsKey(cache[cacheIndex].importcLookup, name, nameKey)
    hasLocal = v3ParserTextLookupContainsKey(cache[cacheIndex].localLookup, name, nameKey)
    return true

fn v3ParserImportedTargetProfileIndex(currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      qualifierChainRaw: str): V3ParserImportedTargetLookup =
    let qualifierChain = qualifierChainRaw
    if qualifierChain == "":
        return v3ParserImportedTargetLookupUnknownExact(v3NormalizedExprCallReasonUnknownQualifiedTarget)
    var ctx = currentProfile
    var targetProfileIndex: int32 = -1
    var partStart: int32
    while partStart <= qualifierChain.len:
        var partStop = partStart
        while partStop < qualifierChain.len:
            if qualifierChain[partStop] == '.':
                break
            partStop = partStop + 1
        let qualifierLen = v3ParserIdentPrefixCountInRange(qualifierChain, partStart, partStop)
        if qualifierLen <= 0:
            return v3ParserImportedTargetLookupUnknownExact(v3NormalizedExprCallReasonUnknownQualifiedTarget)
        targetProfileIndex = -1
        for edgeIndex in 0..<ctx.importEdges.len:
            if !ctx.importEdges[edgeIndex].resolved:
                continue
            let edgeQualifier = ctx.importEdges[edgeIndex].qualifier
            if !v3ParserTextRangeEquals(qualifierChain, partStart, qualifierLen, edgeQualifier):
                continue
            let candidateIndex = ctx.importEdges[edgeIndex].targetProfileIndex
            if candidateIndex < 0:
                continue
            if targetProfileIndex < 0:
                targetProfileIndex = candidateIndex
                continue
            if targetProfileIndex != candidateIndex:
                return v3ParserImportedTargetLookupUnknownExact(v3NormalizedExprCallReasonAmbiguousQualifiedTarget)
        if targetProfileIndex < 0:
            return v3ParserImportedTargetLookupUnknownExact(v3NormalizedExprCallReasonUnknownQualifiedTarget)
        if partStop >= qualifierChain.len:
            return v3ParserImportedTargetLookupResolved(targetProfileIndex)
        ctx = profiles[targetProfileIndex]
        partStart = partStop + 1
    return v3ParserImportedTargetLookupResolved(targetProfileIndex)

fn v3ParserResolveQualifiedCallTarget(currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      profileIndexLookup: V3ParserSourcePathIndexLookup,
                                      profileCallLookupCache: var V3ParserProfileCallLookupCacheEntry[],
                                      targetRaw: str,
                                      calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    let qualifier = v3ParserQualifiedTargetQualifierChainExact(targetRaw)
    let callee = v3ParserIdentPrefix(calleeRaw)
    if qualifier == "" || callee == "":
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownQualifiedTarget)
    let calleeKey = v3ParserTextLookupKeyExact(callee)
    let targetLookup = v3ParserImportedTargetProfileIndex(currentProfile,
                                                          profiles,
                                                          qualifier)
    if targetLookup.targetProfileIndex < 0:
        return v3ParserResolvedCallTargetUnknown(targetLookup.reason)
    let targetProfile = profiles[targetLookup.targetProfileIndex]
    var hasImportc = false
    var hasLocal = false
    let foundTarget = v3ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                           targetLookup.targetProfileIndex,
                                                           callee,
                                                           calleeKey,
                                                           hasImportc,
                                                           hasLocal)
    if foundTarget && hasImportc:
        return v3ParserResolvedCallTargetResolved(targetProfile.sourcePath, true)
    if foundTarget && hasLocal:
        return v3ParserResolvedCallTargetResolved(targetProfile.sourcePath, false)
    let visibleTarget = v3ParserResolveUnqualifiedExternalCallTarget(targetProfile,
                                                                    profiles,
                                                                    profileIndexLookup,
                                                                    profileCallLookupCache,
                                                                    callee)
    if visibleTarget.sourcePath != "":
        return visibleTarget
    if visibleTarget.reason == v3NormalizedExprCallReasonAmbiguousExternalTarget:
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonAmbiguousQualifiedTarget)
    return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownQualifiedTarget)

fn v3ParserResolveUnqualifiedExternalCallTarget(currentProfile: V3NormalizedExprCallProfile,
                                                profiles: V3NormalizedExprCallProfile[],
                                                profileIndexLookup: V3ParserSourcePathIndexLookup,
                                                profileCallLookupCache: var V3ParserProfileCallLookupCacheEntry[],
                                                calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    let callee = v3ParserIdentPrefix(calleeRaw)
    if callee == "":
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownExternalTarget)
    let calleeKey = v3ParserTextLookupKeyExact(callee)
    let currentProfileIndex = v3ParserProfileIndexLookupForNormalizedSourcePathExact(profileIndexLookup,
                                                                                     currentProfile.sourcePath)
    if currentProfileIndex < 0:
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownExternalTarget)
    var visited: bool[] = v3ParserBoolSeqInit(profiles.len, false)
    visited[currentProfileIndex] = true
    var pending: int32[]
    add(pending, currentProfileIndex)
    var pendingIndex: int32
    var found: V3NormalizedExprResolvedCallTarget[]
    while pendingIndex < pending.len:
        let workingProfileIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let workingProfile = profiles[workingProfileIndex]
        for edgeIndex in 0..<workingProfile.importEdges.len:
            if !workingProfile.importEdges[edgeIndex].resolved:
                continue
            if !workingProfile.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = workingProfile.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            var hasImportc = false
            var hasLocal = false
            let foundTarget = v3ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                                   targetProfileIndex,
                                                                   callee,
                                                                   calleeKey,
                                                                   hasImportc,
                                                                   hasLocal)
            if !foundTarget:
                continue
            if hasImportc || hasLocal:
                v3ParserAppendUniqueResolvedCallTarget(found,
                                                       v3ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)
    if found.len <= 0:
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownExternalTarget)
    if found.len > 1:
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonAmbiguousExternalTarget)
    return found[0]

fn v3ParserResolveCallTarget(currentProfile: V3NormalizedExprCallProfile,
                             profiles: V3NormalizedExprCallProfile[],
                             profileIndexLookup: V3ParserSourcePathIndexLookup,
                             profileCallLookupCache: var V3ParserProfileCallLookupCacheEntry[],
                             detailKind: V3NormalizedExprSurfaceCallKind,
                             targetRaw: str,
                             calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    if detailKind == v3NormalizedExprSurfaceCallLocal:
        return v3ParserResolvedCallTargetResolved(currentProfile.sourcePath, false)
    if detailKind == v3NormalizedExprSurfaceCallImportc:
        return v3ParserResolvedCallTargetResolved(currentProfile.sourcePath, true)
    if detailKind != v3NormalizedExprSurfaceCallExternal:
        return v3ParserResolvedCallTargetUnknown(v3NormalizedExprCallReasonUnknownCallTarget)
    let target = targetRaw
    if v3ParserCallExprLastDotExact(target) >= 0:
        return v3ParserResolveQualifiedCallTarget(currentProfile,
                                                  profiles,
                                                  profileIndexLookup,
                                                  profileCallLookupCache,
                                                  target,
                                                  calleeRaw)
    return v3ParserResolveUnqualifiedExternalCallTarget(currentProfile,
                                                        profiles,
                                                        profileIndexLookup,
                                                        profileCallLookupCache,
                                                        calleeRaw)

fn v3ParserQualifiedCallDepth(prefixRaw: str): int32 =
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix == "":
        return 0
    var depth: int32 = 1
    for i in 0..<prefix.len:
        if prefix[i] == '.':
            depth = depth + 1
    return depth

fn v3ParserAppendQualifiedCallNames(out: var str[],
                                    seen: var V3ParserTextLookup,
                                    prefixRaw: str,
                                    callNames: str[]) =
    let prefix = v3path.V3PathTrim(prefixRaw)
    v3ParserAppendQualifiedCallNamesExact(out, seen, prefix, callNames)

fn v3ParserAppendQualifiedCallNamesExact(out: var str[],
                                         seen: var V3ParserTextLookup,
                                         prefix: str,
                                         callNames: str[]) =
    if prefix == "":
        return
    let prefixWithDot = v3ParserConcat2(prefix, ".")
    for i in 0..<callNames.len:
        let callName = callNames[i]
        if callName == "":
            continue
        let qualifiedName = v3ParserConcat2(prefixWithDot, callName)
        v3ParserAppendUniqueLookupTextKey(out,
                                          seen,
                                          qualifiedName,
                                          v3ParserTextLookupKeyExact(qualifiedName))

fn v3ParserAppendDirectExternalCallNames(out: var str[],
                                         seen: var V3ParserTextLookup,
                                         callNames: str[]) =
    for i in 0..<callNames.len:
        let callName = callNames[i]
        if callName == "":
            continue
        v3ParserAppendUniqueLookupTextKey(out, seen, callName, v3ParserTextLookupKeyExact(callName))

fn v3ParserAppendVisibleDirectExternalCallNames(out: var str[],
                                                seen: var V3ParserTextLookup,
                                                callNames: str[],
                                                localLookup: V3ParserTextLookup,
                                                importcLookup: V3ParserTextLookup) =
    for i in 0..<callNames.len:
        let callName = callNames[i]
        if callName == "":
            continue
        let callNameKey = v3ParserTextLookupKeyExact(callName)
        if v3ParserTextLookupContainsKey(localLookup, callName, callNameKey):
            continue
        if v3ParserTextLookupContainsKey(importcLookup, callName, callNameKey):
            continue
        v3ParserAppendUniqueLookupTextKey(out, seen, callName, callNameKey)

fn v3ParserCloneTextSeq(items: str[]): str[] =
    var out: str[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn v3ParserPrepareCodeLines(lines: str[]): str[] =
    var out: str[]
    for i in 0..<lines.len:
        add(out, v3ParserStripLineComment(lines[i]))
    return out

fn v3ParserBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    var i: int32
    while i < count:
        add(out, value)
        i = i + 1
    return out

fn v3ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(profiles: V3NormalizedExprCallProfile[],
                                                               profileIndexLookup: V3ParserSourcePathIndexLookup,
                                                               profileIndex: int32,
                                                               rootLocalLookup: V3ParserTextLookup,
                                                               rootImportcLookup: V3ParserTextLookup,
                                                               seen: var V3ParserTextLookup,
                                                               out: var str[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    var visited: bool[] = v3ParserBoolSeqInit(profiles.len, false)
    visited[profileIndex] = true
    var pending: int32[]
    add(pending, profileIndex)
    var pendingIndex: int32
    while pendingIndex < pending.len:
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            if !current.importEdges[edgeIndex].resolved:
                continue
            if !current.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = current.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            v3ParserAppendVisibleDirectExternalCallNames(out,
                                                         seen,
                                                         targetProfile.localCallNames,
                                                         rootLocalLookup,
                                                         rootImportcLookup)
            v3ParserAppendVisibleDirectExternalCallNames(out,
                                                         seen,
                                                         targetProfile.importcCallNames,
                                                         rootLocalLookup,
                                                         rootImportcLookup)
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)

fn v3ParserCollectResolvedUnqualifiedExternalTargetsRecursive(profiles: V3NormalizedExprCallProfile[],
                                                              profileIndexLookup: V3ParserSourcePathIndexLookup,
                                                              profileIndex: int32,
                                                              calleeRaw: str,
                                                              out: var V3NormalizedExprResolvedCallTarget[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    let callee = v3ParserIdentPrefix(v3path.V3PathTrim(calleeRaw))
    if callee == "":
        return
    let calleeKey = v3ParserTextLookupKeyExact(callee)
    var visited: bool[] = v3ParserBoolSeqInit(profiles.len, false)
    visited[profileIndex] = true
    var pending: int32[]
    add(pending, profileIndex)
    var pendingIndex: int32
    var profileCallLookupCache = v3ParserBuildProfileCallLookupCache(profiles)
    while pendingIndex < pending.len:
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            if !current.importEdges[edgeIndex].resolved:
                continue
            if !current.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = current.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            var hasImportc = false
            var hasLocal = false
            let foundTarget = v3ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                                   targetProfileIndex,
                                                                   callee,
                                                                   calleeKey,
                                                                   hasImportc,
                                                                   hasLocal)
            if !foundTarget:
                continue
            if hasImportc || hasLocal:
                v3ParserAppendUniqueResolvedCallTarget(out,
                                                       v3ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)

fn v3ParserCachedVisibleUnqualifiedExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                                     profileIndexLookup: V3ParserSourcePathIndexLookup,
                                                     profileIndex: int32,
                                                     cache: var V3ParserTextSeqCacheEntry[]): str[] =
    var i: int32
    while i < cache.len:
        if cache[i].profileIndex == profileIndex:
            return cache[i].items
        i = i + 1
    var out: str[]
    if profileIndex < 0 || profileIndex >= profiles.len:
        return out
    let rootProfile = profiles[profileIndex]
    let rootLocalLookup = v3ParserTextLookupBuildExact(rootProfile.localCallNames)
    let rootImportcLookup = v3ParserTextLookupBuildExact(rootProfile.importcCallNames)
    var seen: V3ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    v3ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(profiles,
                                                                profileIndexLookup,
                                                                profileIndex,
                                                                rootLocalLookup,
                                                                rootImportcLookup,
                                                                seen,
                                                                out)
    var entry: V3ParserTextSeqCacheEntry
    entry.profileIndex = profileIndex
    entry.items = out
    add(cache, entry)
    return out

fn v3ParserCachedQualifiedExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                            profileIndexLookup: V3ParserSourcePathIndexLookup,
                                            profileIndex: int32,
                                            prefix: str,
                                            visibleNameCache: var V3ParserTextSeqCacheEntry[],
                                            cache: var V3ParserQualifiedTextSeqCacheEntry[]): str[] =
    var i: int32
    while i < cache.len:
        if cache[i].profileIndex == profileIndex && cache[i].prefix == prefix:
            return cache[i].items
        i = i + 1
    var out: str[]
    if profileIndex < 0 || profileIndex >= profiles.len:
        return out
    if prefix == "":
        return out
    let targetProfile = profiles[profileIndex]
    let visibleNames = v3ParserCachedVisibleUnqualifiedExternalCallNames(profiles,
                                                                         profileIndexLookup,
                                                                         profileIndex,
                                                                         visibleNameCache)
    var seen = v3ParserTextLookupInit(targetProfile.localCallNames.len +
                                      targetProfile.importcCallNames.len +
                                      visibleNames.len + 8)
    v3ParserAppendQualifiedCallNamesExact(out, seen, prefix, targetProfile.localCallNames)
    v3ParserAppendQualifiedCallNamesExact(out, seen, prefix, targetProfile.importcCallNames)
    v3ParserAppendQualifiedCallNamesExact(out, seen, prefix, visibleNames)
    var entry: V3ParserQualifiedTextSeqCacheEntry
    entry.profileIndex = profileIndex
    entry.prefix = prefix
    entry.items = out
    add(cache, entry)
    return out

fn v3ParserCollectExternalCallNamesRecursive(profiles: V3NormalizedExprCallProfile[],
                                             profileIndexLookup: V3ParserSourcePathIndexLookup,
                                             profileIndex: int32,
                                             prefix: str,
                                             prefixDepth: int32,
                                             maxQualifiedCallDepth: int32,
                                             activeProfileFlags: var bool[],
                                             visibleNameCache: var V3ParserTextSeqCacheEntry[],
                                             qualifiedNameCache: var V3ParserQualifiedTextSeqCacheEntry[],
                                             seen: var V3ParserTextLookup,
                                             out: var str[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    let current = profiles[profileIndex]
    for edgeIndex in 0..<current.importEdges.len:
        if !current.importEdges[edgeIndex].resolved:
            continue
        let targetProfileIndex = current.importEdges[edgeIndex].targetProfileIndex
        if targetProfileIndex < 0:
            continue
        let qualifier = current.importEdges[edgeIndex].qualifier
        if qualifier == "":
            continue
        let nextPrefix = v3ParserQualifiedCallPrefixExact(prefix, qualifier)
        let nextDepth = prefixDepth + 1
        if nextDepth > maxQualifiedCallDepth:
            continue
        let qualifiedNames = v3ParserCachedQualifiedExternalCallNames(profiles,
                                                                      profileIndexLookup,
                                                                      targetProfileIndex,
                                                                      nextPrefix,
                                                                      visibleNameCache,
                                                                      qualifiedNameCache)
        v3ParserAppendDirectExternalCallNames(out, seen, qualifiedNames)
        if nextDepth >= maxQualifiedCallDepth:
            continue
        if activeProfileFlags[targetProfileIndex]:
            continue
        activeProfileFlags[targetProfileIndex] = true
        v3ParserCollectExternalCallNamesRecursive(profiles,
                                                  profileIndexLookup,
                                                  targetProfileIndex,
                                                  nextPrefix,
                                                  nextDepth,
                                                  maxQualifiedCallDepth,
                                                  activeProfileFlags,
                                                  visibleNameCache,
                                                  qualifiedNameCache,
                                                  seen,
                                                  out)
        activeProfileFlags[targetProfileIndex] = false

fn v3ParserCollectExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                    profileIndexLookup: V3ParserSourcePathIndexLookup,
                                    profileIndex: int32,
                                    names: var str[]) =
    var out: str[]
    if profileIndex < 0 || profileIndex >= profiles.len:
        names = out
        return
    var seen: V3ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    var visibleNameCache: V3ParserTextSeqCacheEntry[]
    let visibleNames = v3ParserCachedVisibleUnqualifiedExternalCallNames(profiles,
                                                                         profileIndexLookup,
                                                                         profileIndex,
                                                                         visibleNameCache)
    v3ParserAppendDirectExternalCallNames(out, seen, visibleNames)
    var qualifiedNameCache: V3ParserQualifiedTextSeqCacheEntry[]
    var activeProfileFlags: bool[] = v3ParserBoolSeqInit(profiles.len, false)
    activeProfileFlags[profileIndex] = true
    v3ParserCollectExternalCallNamesRecursive(profiles,
                                              profileIndexLookup,
                                              profileIndex,
                                              "",
                                              0,
                                              profiles[profileIndex].maxQualifiedCallDepth,
                                              activeProfileFlags,
                                              visibleNameCache,
                                              qualifiedNameCache,
                                              seen,
                                              out)
    names = out

fn v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw: str,
                                                                    text: str,
                                                                    importcCallNames: str[],
                                                                    localCallNames: str[],
                                                                    externalCallNames: str[],
                                                                    currentProfile: V3NormalizedExprCallProfile,
                                                                    profiles: V3NormalizedExprCallProfile[],
                                                                    profileIndexLookup: V3ParserSourcePathIndexLookup,
                                                                    layer: var V3NormalizedExprLayer,
                                                                    err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    layer = V3NormalizedExprLayer()
    layer.sourceCount = 1
    var localCallLookup = v3ParserTextLookupBuildExact(localCallNames)
    var externalCallLookup = v3ParserTextLookupBuildExact(externalCallNames)
    var importcCallLookup = v3ParserTextLookupBuildExact(importcCallNames)
    var knownCallLookup = v3ParserTextLookupInit(localCallNames.len +
                                                 externalCallNames.len +
                                                 importcCallNames.len + 8)
    v3ParserTextLookupAddAllExact(knownCallLookup, localCallNames)
    v3ParserTextLookupAddAllExact(knownCallLookup, externalCallNames)
    v3ParserTextLookupAddAllExact(knownCallLookup, importcCallNames)
    var profileCallLookupCache = v3ParserBuildProfileCallLookupCache(profiles)
    let codeLines = v3ParserPrepareCodeLines(v3ParserSplitChar(text, '\n'))
    var inTypeBlock = false
    var typeBlockIndent: int32 = -1
    for i in 0..<codeLines.len:
        let line = codeLines[i]
        if !v3ParserHasNonTrimChar(line):
            continue
        let lineNumber = i + 1
        let trimmedLine = v3path.V3PathTrim(line)
        let lineIndent: int32 = v3ParserLineIndent(line)
        if inTypeBlock && lineIndent <= typeBlockIndent:
            inTypeBlock = false
        if !v3ParserHasLeadingIndent(line):
            inTypeBlock = trimmedLine == "type"
            if inTypeBlock:
                typeBlockIndent = lineIndent
        var redundantType = ""
        var redundantExpr = ""
        if v3ParserFindRedundantExplicitDefaultLine(line,
                                                    inTypeBlock,
                                                    currentProfile,
                                                    profiles,
                                                    redundantType,
                                                    redundantExpr):
            err = v3ParserRedundantExplicitDefaultError(redundantType, redundantExpr)
            return false
        v3ParserAppendSimpleSurfaceExprsLine(sourcePath,
                                             lineNumber,
                                             line,
                                             true,
                                             true,
                                             true,
                                             layer)
        v3ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        if !v3ParserAppendDefaultInitExprsLine(sourcePath,
                                               lineNumber,
                                               line,
                                               currentProfile,
                                               profiles,
                                               layer,
                                               err):
            return false
        v3ParserAppendConstructorExprsLine(sourcePath,
                                           lineNumber,
                                           line,
                                           currentProfile,
                                           profiles,
                                           layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &localCallLookup,
                                    v3NormalizedExprSurfaceCallLocal,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &externalCallLookup,
                                    v3NormalizedExprSurfaceCallExternal,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &importcCallLookup,
                                    v3NormalizedExprSurfaceCallImportc,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        v3ParserAppendMemberCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          knownCallLookup,
                                          currentProfile,
                                          layer)
    layer.questionResidualCount = 0
    err = ""
    return true

fn v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePathRaw: str,
                                                         text: str,
                                                         importcCallNames: str[],
                                                         localCallNames: str[],
                                                         externalCallNames: str[],
                                                         layer: var V3NormalizedExprLayer,
                                                         err: var str): bool =
    var currentProfile: V3NormalizedExprCallProfile
    currentProfile.sourcePath = v3ParserNormalizePath(sourcePathRaw)
    currentProfile.ownerModulePath = ""
    currentProfile.text = text
    currentProfile.lines = v3ParserSplitChar(text, '\n')
    currentProfile.decls = []
    currentProfile.typeDecls = []
    currentProfile.importcCallNames = v3ParserCloneTextSeq(importcCallNames)
    currentProfile.localCallNames = v3ParserCloneTextSeq(localCallNames)
    currentProfile.importEdges = []
    currentProfile.maxQualifiedCallDepth = v3ParserMaxQualifiedCallDepthLines(
        v3ParserPrepareCodeLines(currentProfile.lines))
    v3ParserReadNormalizedTypeDeclsLines(currentProfile.lines, currentProfile.typeDecls)
    var profiles: V3NormalizedExprCallProfile[]
    let profileIndexLookup = v3ParserSourcePathIndexLookupBuild(profiles)
    return v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw,
                                                                            text,
                                                                            importcCallNames,
                                                                            localCallNames,
                                                                            externalCallNames,
                                                                            currentProfile,
                                                                            profiles,
                                                                            profileIndexLookup,
                                                                            layer,
                                                                            err)

fn v3ParserReadNormalizedExprLayerFromText(sourcePathRaw: str,
                                           text: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    var decls: V3NormalizedFunctionDecl[]
    var declErr = ""
    if !v3ParserReadNormalizedFunctionDecls(text, decls, declErr):
        err = declErr
        return false
    var importcCallNames: str[]
    var localCallNames: str[]
    v3ParserImportcCallNamesFromDecls(decls, importcCallNames)
    v3ParserLocalCallNamesFromDecls(decls, localCallNames)
    return v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePath,
                                                                 text,
                                                                 importcCallNames,
                                                                 localCallNames,
                                                                 [],
                                                                 layer,
                                                                 err)

fn v3ParserReadNormalizedExprLayerFromPath(sourcePathRaw: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if !v3ParserSourceExists(sourcePath):
        err = "source file missing"
        return false
    let text: str = v3path.V3ReadTextFile("", sourcePath)
    if text == "":
        err = "failed to read source"
        return false
    return v3ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err)

fn v3ParserStringSeqContains(items: str[], targetRaw: str): bool =
    let target = v3path.V3PathTrim(targetRaw)
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i], target):
            return true
    return false

fn v3ParserTextLookupDotCount(text: str): int32 =
    var count: int32
    var i: int32
    while i < text.len:
        if text[i] == '.':
            count = count + 1
        i = i + 1
    return count

fn v3ParserTextLookupContentHash(text: str): int32 =
    var h: int32
    var i: int32
    while i < text.len:
        h = h * 131 + int32(text[i])
        i = i + 1
    if h < 0:
        h = -h
    return h

fn v3ParserTextLookupKeyExact(text: str): V3ParserTextLookupKey =
    var key: V3ParserTextLookupKey
    key.keyLen = text.len
    if text == "":
        key.firstCode = 0
        key.lastCode = 0
        key.dotCount = 0
        key.textHash = 0
        return key
    key.firstCode = int32(text[0])
    key.lastCode = int32(text[text.len - 1])
    var dotCount: int32
    var h: int32
    var i: int32
    while i < text.len:
        let ch = text[i]
        if ch == '.':
            dotCount = dotCount + 1
        h = h * 131 + int32(ch)
        i = i + 1
    if h < 0:
        h = -h
    key.dotCount = dotCount
    key.textHash = h
    return key

fn v3ParserTextLookupInit(minCap: int32): V3ParserTextLookup =
    var lookup: V3ParserTextLookup
    lookup.slots = []
    lookup.buckets = []
    lookup.totalCount = 0
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    var i: int32
    while i < cap:
        add(lookup.slots, 0)
        i = i + 1
    return lookup

fn v3ParserTextLookupHash(keyLen: int32,
                          firstCode: int32,
                          lastCode: int32,
                          dotCount: int32,
                          textHash: int32): int64 =
    var h: int64 = int64(textHash)
    h = h * 131 + int64(firstCode)
    h = h * 131 + int64(lastCode)
    h = h * 131 + int64(dotCount)
    h = h * 131 + int64(keyLen)
    if h < 0:
        h = -h
    return h

fn v3ParserTextLookupSlotForParts(lookup: V3ParserTextLookup,
                                  keyLen: int32,
                                  firstCode: int32,
                                  lastCode: int32,
                                  dotCount: int32,
                                  textHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = int32(v3ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    textHash) & int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        if lookup.buckets[bucketIndexPlus1 - 1].keyLen == keyLen &&
           lookup.buckets[bucketIndexPlus1 - 1].firstCode == firstCode &&
           lookup.buckets[bucketIndexPlus1 - 1].lastCode == lastCode &&
           lookup.buckets[bucketIndexPlus1 - 1].dotCount == dotCount &&
           lookup.buckets[bucketIndexPlus1 - 1].textHash == textHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3ParserTextLookupSlotForKey(lookup: V3ParserTextLookup,
                                key: V3ParserTextLookupKey): int32 =
    return v3ParserTextLookupSlotForParts(lookup,
                                          key.keyLen,
                                          key.firstCode,
                                          key.lastCode,
                                          key.dotCount,
                                          key.textHash)

fn v3ParserTextLookupRehash(lookup: var V3ParserTextLookup,
                            newCap: int32) =
    var slots: int32[]
    var i: int32
    while i < newCap:
        add(slots, 0)
        i = i + 1
    lookup.slots = slots
    var bucketIndex: int32
    while bucketIndex < lookup.buckets.len:
        let slot = v3ParserTextLookupSlotForParts(lookup,
                                                  lookup.buckets[bucketIndex].keyLen,
                                                  lookup.buckets[bucketIndex].firstCode,
                                                  lookup.buckets[bucketIndex].lastCode,
                                                  lookup.buckets[bucketIndex].dotCount,
                                                  lookup.buckets[bucketIndex].textHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1
        bucketIndex = bucketIndex + 1

fn v3ParserTextLookupGrow(lookup: var V3ParserTextLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    v3ParserTextLookupRehash(lookup, nextCap)

fn v3ParserTextLookupBucketIndexExact(lookup: V3ParserTextLookup,
                                      text: str): int32 =
    if text == "":
        return -1
    return v3ParserTextLookupBucketIndexKey(lookup, v3ParserTextLookupKeyExact(text))

fn v3ParserTextLookupBucketIndexKey(lookup: V3ParserTextLookup,
                                    key: V3ParserTextLookupKey): int32 =
    if key.keyLen <= 0:
        return -1
    let slot = v3ParserTextLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3ParserTextLookupEnsureBucket(lookup: var V3ParserTextLookup,
                                  text: str): int32 =
    if text == "":
        return -1
    return v3ParserTextLookupEnsureBucketKey(lookup, v3ParserTextLookupKeyExact(text))

fn v3ParserTextLookupEnsureBucketKey(lookup: var V3ParserTextLookup,
                                     key: V3ParserTextLookupKey): int32 =
    if lookup.slots.len <= 0:
        lookup = v3ParserTextLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        v3ParserTextLookupGrow(lookup)
    let slot = v3ParserTextLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: V3ParserTextLookupBucket
    bucket.keyLen = key.keyLen
    bucket.firstCode = key.firstCode
    bucket.lastCode = key.lastCode
    bucket.dotCount = key.dotCount
    bucket.textHash = key.textHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn v3ParserTextLookupInsertExact(lookup: var V3ParserTextLookup,
                                 value: str): bool =
    if value == "":
        return false
    return v3ParserTextLookupInsertKey(lookup, value, v3ParserTextLookupKeyExact(value))

fn v3ParserTextLookupInsertKey(lookup: var V3ParserTextLookup,
                               value: str,
                               key: V3ParserTextLookupKey): bool =
    if value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = v3ParserTextLookupEnsureBucketKey(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        if v3ParserTextEqualsExact(lookup.buckets[bucketIndex].items[i], value):
            return false
    add(lookup.buckets[bucketIndex].items, value)
    lookup.totalCount = lookup.totalCount + 1
    return true

fn v3ParserTextLookupAddExact(lookup: var V3ParserTextLookup,
                              value: str) =
    let _ = v3ParserTextLookupInsertExact(lookup, value)

fn v3ParserTextLookupAdd(lookup: var V3ParserTextLookup,
                         text: str) =
    let value = v3path.V3PathTrim(text)
    v3ParserTextLookupAddExact(lookup, value)

fn v3ParserTextLookupAddAll(lookup: var V3ParserTextLookup,
                            items: str[]) =
    for i in 0..<items.len:
        v3ParserTextLookupAdd(lookup, items[i])

fn v3ParserTextLookupAddAllExact(lookup: var V3ParserTextLookup,
                                 items: str[]) =
    for i in 0..<items.len:
        let value = items[i]
        if value == "":
            continue
        let _ = v3ParserTextLookupInsertKey(lookup, value, v3ParserTextLookupKeyExact(value))

fn v3ParserTextLookupBuild(items: str[]): V3ParserTextLookup =
    var lookup = v3ParserTextLookupInit(items.len * 2 + 8)
    v3ParserTextLookupAddAll(lookup, items)
    return lookup

fn v3ParserTextLookupBuildExact(items: str[]): V3ParserTextLookup =
    var lookup = v3ParserTextLookupInit(items.len * 2 + 8)
    v3ParserTextLookupAddAllExact(lookup, items)
    return lookup

fn v3ParserTextLookupContainsExact(lookup: V3ParserTextLookup,
                                   target: str): bool =
    if target == "":
        return false
    return v3ParserTextLookupContainsKey(lookup, target, v3ParserTextLookupKeyExact(target))

fn v3ParserTextLookupContainsKey(lookup: V3ParserTextLookup,
                                 value: str,
                                 key: V3ParserTextLookupKey): bool =
    if value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = v3ParserTextLookupBucketIndexKey(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        if v3ParserTextEqualsExact(lookup.buckets[bucketIndex].items[i], value):
            return true
    return false

fn v3ParserTextLookupSlotForPartsPtr(lookup: V3ParserTextLookup*,
                                     keyLen: int32,
                                     firstCode: int32,
                                     lastCode: int32,
                                     dotCount: int32,
                                     textHash: int32): int32 =
    if lookup == nil || lookup->slots.len <= 0:
        return -1
    let mask = lookup->slots.len - 1
    var probe: int32 = int32(v3ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    textHash) & int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup->slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucketIndex = bucketIndexPlus1 - 1
        if lookup->buckets[bucketIndex].keyLen == keyLen &&
           lookup->buckets[bucketIndex].firstCode == firstCode &&
           lookup->buckets[bucketIndex].lastCode == lastCode &&
           lookup->buckets[bucketIndex].dotCount == dotCount &&
           lookup->buckets[bucketIndex].textHash == textHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3ParserTextLookupSlotForKeyPtr(lookup: V3ParserTextLookup*,
                                   key: V3ParserTextLookupKey): int32 =
    return v3ParserTextLookupSlotForPartsPtr(lookup,
                                             key.keyLen,
                                             key.firstCode,
                                             key.lastCode,
                                             key.dotCount,
                                             key.textHash)

fn v3ParserTextLookupBucketIndexKeyPtr(lookup: V3ParserTextLookup*,
                                       key: V3ParserTextLookupKey): int32 =
    if lookup == nil || key.keyLen <= 0:
        return -1
    let slot = v3ParserTextLookupSlotForKeyPtr(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup->slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3ParserTextLookupContainsKeyPtr(lookup: V3ParserTextLookup*,
                                    value: str,
                                    key: V3ParserTextLookupKey): bool =
    if lookup == nil || value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = v3ParserTextLookupBucketIndexKeyPtr(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup->buckets[bucketIndex].items.len:
        if v3ParserTextEqualsExact(lookup->buckets[bucketIndex].items[i], value):
            return true
    return false

fn v3ParserMatchKnownCallSurfaceTextKeysPtr(callLookup: V3ParserTextLookup*,
                                            callName: str,
                                            callNameKey: V3ParserTextLookupKey,
                                            qualifiedCallName: str,
                                            qualifiedCallNameKey: V3ParserTextLookupKey,
                                            dottedCallName: str,
                                            dottedCallNameKey: V3ParserTextLookupKey): str =
    if dottedCallName != callName &&
       v3ParserTextLookupContainsKeyPtr(callLookup,
                                        dottedCallName,
                                        dottedCallNameKey):
        return dottedCallName
    if qualifiedCallName != callName &&
       v3ParserTextLookupContainsKeyPtr(callLookup,
                                        qualifiedCallName,
                                        qualifiedCallNameKey):
        return qualifiedCallName
    if v3ParserTextLookupContainsKeyPtr(callLookup, callName, callNameKey):
        return callName
    return ""

fn v3ParserSourcePathIndexLookupInit(minCap: int32): V3ParserSourcePathIndexLookup =
    var lookup: V3ParserSourcePathIndexLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    var i: int32
    while i < cap:
        add(lookup.slots, 0)
        i = i + 1
    return lookup

fn v3ParserSourcePathIndexLookupSlotForParts(lookup: V3ParserSourcePathIndexLookup,
                                             keyLen: int32,
                                             firstCode: int32,
                                             lastCode: int32,
                                             dotCount: int32,
                                             sourcePathHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = int32(v3ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    sourcePathHash) & int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        if lookup.buckets[bucketIndexPlus1 - 1].keyLen == keyLen &&
           lookup.buckets[bucketIndexPlus1 - 1].firstCode == firstCode &&
           lookup.buckets[bucketIndexPlus1 - 1].lastCode == lastCode &&
           lookup.buckets[bucketIndexPlus1 - 1].dotCount == dotCount &&
           lookup.buckets[bucketIndexPlus1 - 1].sourcePathHash == sourcePathHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3ParserSourcePathIndexLookupRehash(lookup: var V3ParserSourcePathIndexLookup,
                                       newCap: int32) =
    var slots: int32[]
    var i: int32
    while i < newCap:
        add(slots, 0)
        i = i + 1
    lookup.slots = slots
    var bucketIndex: int32
    while bucketIndex < lookup.buckets.len:
        let slot = v3ParserSourcePathIndexLookupSlotForParts(lookup,
                                                             lookup.buckets[bucketIndex].keyLen,
                                                             lookup.buckets[bucketIndex].firstCode,
                                                             lookup.buckets[bucketIndex].lastCode,
                                                             lookup.buckets[bucketIndex].dotCount,
                                                             lookup.buckets[bucketIndex].sourcePathHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1
        bucketIndex = bucketIndex + 1

fn v3ParserSourcePathIndexLookupGrow(lookup: var V3ParserSourcePathIndexLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    v3ParserSourcePathIndexLookupRehash(lookup, nextCap)

fn v3ParserSourcePathIndexBucketIndexExact(lookup: V3ParserSourcePathIndexLookup,
                                           sourcePath: str): int32 =
    if sourcePath == "":
        return -1
    let keyLen = sourcePath.len
    let firstCode = int32(sourcePath[0])
    let lastCode = int32(sourcePath[keyLen - 1])
    let dotCount = v3ParserTextLookupDotCount(sourcePath)
    let sourcePathHash = v3ParserTextLookupContentHash(sourcePath)
    let slot = v3ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         keyLen,
                                                         firstCode,
                                                         lastCode,
                                                         dotCount,
                                                         sourcePathHash)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3ParserSourcePathIndexEnsureBucket(lookup: var V3ParserSourcePathIndexLookup,
                                       sourcePath: str): int32 =
    if lookup.slots.len <= 0:
        lookup = v3ParserSourcePathIndexLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        v3ParserSourcePathIndexLookupGrow(lookup)
    let keyLen = sourcePath.len
    let firstCode = int32(sourcePath[0])
    let lastCode = int32(sourcePath[keyLen - 1])
    let dotCount = v3ParserTextLookupDotCount(sourcePath)
    let sourcePathHash = v3ParserTextLookupContentHash(sourcePath)
    let slot = v3ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         keyLen,
                                                         firstCode,
                                                         lastCode,
                                                         dotCount,
                                                         sourcePathHash)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: V3ParserSourcePathIndexBucket
    bucket.keyLen = keyLen
    bucket.firstCode = firstCode
    bucket.lastCode = lastCode
    bucket.dotCount = dotCount
    bucket.sourcePathHash = sourcePathHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn v3ParserSourcePathIndexLookupInsertExact(lookup: var V3ParserSourcePathIndexLookup,
                                            sourcePath: str,
                                            profileIndex: int32) =
    if sourcePath == "" || profileIndex < 0:
        return
    let bucketIndex = v3ParserSourcePathIndexEnsureBucket(lookup, sourcePath)
    if bucketIndex < 0:
        return
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i].sourcePath, sourcePath):
            return
    var entry: V3ParserSourcePathIndexEntry
    entry.sourcePath = sourcePath
    entry.profileIndex = profileIndex
    add(lookup.buckets[bucketIndex].items, entry)

fn v3ParserSourcePathIndexLookupBuild(profiles: V3NormalizedExprCallProfile[]): V3ParserSourcePathIndexLookup =
    var lookup = v3ParserSourcePathIndexLookupInit(profiles.len * 2 + 8)
    for i in 0..<profiles.len:
        v3ParserSourcePathIndexLookupInsertExact(lookup,
                                                 v3ParserNormalizePath(profiles[i].sourcePath),
                                                 i)
    return lookup

fn v3ParserProfileIndexLookupForNormalizedSourcePathExact(lookup: V3ParserSourcePathIndexLookup,
                                                          sourcePath: str): int32 =
    if sourcePath == "":
        return -1
    let bucketIndex = v3ParserSourcePathIndexBucketIndexExact(lookup, sourcePath)
    if bucketIndex < 0:
        return -1
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i].sourcePath, sourcePath):
            return items[i].profileIndex
    return -1

fn v3ParserSourcePathIndexBucketIndexForImportEdgeTargetSourcePath(lookup: V3ParserSourcePathIndexLookup,
                                                                   edge: V3ImportEdge): int32 =
    if edge.targetSourcePath == "":
        return -1
    let slot = v3ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         edge.targetSourcePathLen,
                                                         edge.targetSourcePathFirstCode,
                                                         edge.targetSourcePathLastCode,
                                                         edge.targetSourcePathDotCount,
                                                         edge.targetSourcePathHash)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3ParserProfileIndexLookupForImportEdgeTargetSourcePath(lookup: V3ParserSourcePathIndexLookup,
                                                           edge: V3ImportEdge): int32 =
    let bucketIndex = v3ParserSourcePathIndexBucketIndexForImportEdgeTargetSourcePath(lookup, edge)
    if bucketIndex < 0:
        return -1
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i].sourcePath, edge.targetSourcePath):
            return items[i].profileIndex
    return -1

fn v3ParserImportEdgeTargetProfileIndex(edge: V3ImportEdge,
                                        profileIndexLookup: V3ParserSourcePathIndexLookup): int32 =
    if edge.targetProfileIndex >= 0:
        return edge.targetProfileIndex
    return v3ParserProfileIndexLookupForImportEdgeTargetSourcePath(profileIndexLookup, edge)

fn v3ParserBindImportEdgeTargetProfileIndices(profiles: var V3NormalizedExprCallProfile[],
                                              profileIndexLookup: V3ParserSourcePathIndexLookup) =
    var profileIndex: int32
    while profileIndex < profiles.len:
        var profile = profiles[profileIndex]
        var edgeIndex: int32
        while edgeIndex < profile.importEdges.len:
            var edge = profile.importEdges[edgeIndex]
            edge.targetProfileIndex = -1
            if edge.resolved:
                edge.targetProfileIndex = v3ParserProfileIndexLookupForImportEdgeTargetSourcePath(profileIndexLookup,
                                                                                                  edge)
            profile.importEdges[edgeIndex] = edge
            edgeIndex = edgeIndex + 1
        profiles[profileIndex] = profile
        profileIndex = profileIndex + 1

fn v3ParserProfileIndexLookupForSourcePath(lookup: V3ParserSourcePathIndexLookup,
                                           sourcePathRaw: str): int32 =
    return v3ParserProfileIndexLookupForNormalizedSourcePathExact(lookup,
                                                                  v3ParserNormalizePath(sourcePathRaw))

fn v3ParserBuildProfileCallLookups(profile: V3NormalizedExprCallProfile): V3ParserProfileCallLookupCacheEntry =
    var entry: V3ParserProfileCallLookupCacheEntry
    entry.localLookup = v3ParserTextLookupBuildExact(profile.localCallNames)
    entry.importcLookup = v3ParserTextLookupBuildExact(profile.importcCallNames)
    return entry

fn v3ParserBuildProfileCallLookupCache(profiles: V3NormalizedExprCallProfile[]): V3ParserProfileCallLookupCacheEntry[] =
    var out: V3ParserProfileCallLookupCacheEntry[]
    for i in 0..<profiles.len:
        add(out, v3ParserBuildProfileCallLookups(profiles[i]))
    return out

fn v3ParserProfileCallLookupCacheEnsureIndex(profiles: V3NormalizedExprCallProfile[],
                                             profileIndex: int32,
                                             cache: var V3ParserProfileCallLookupCacheEntry[]): int32 =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return -1
    while cache.len <= profileIndex:
        var empty: V3ParserProfileCallLookupCacheEntry
        empty.localLookup.slots = []
        empty.localLookup.buckets = []
        empty.localLookup.totalCount = 0
        empty.importcLookup.slots = []
        empty.importcLookup.buckets = []
        empty.importcLookup.totalCount = 0
        add(cache, empty)
    if cache[profileIndex].localLookup.slots.len <= 0 &&
       cache[profileIndex].importcLookup.slots.len <= 0:
        cache[profileIndex] = v3ParserBuildProfileCallLookups(profiles[profileIndex])
    return profileIndex

fn v3ParserAppendUniqueLookupTextExact(out: var str[],
                                       seen: var V3ParserTextLookup,
                                       value: str) =
    if value == "":
        return
    v3ParserAppendUniqueLookupTextKey(out, seen, value, v3ParserTextLookupKeyExact(value))

fn v3ParserAppendUniqueLookupTextKey(out: var str[],
                                     seen: var V3ParserTextLookup,
                                     value: str,
                                     valueKey: V3ParserTextLookupKey) =
    if value == "" || valueKey.keyLen <= 0:
        return
    if v3ParserTextLookupInsertKey(seen, value, valueKey):
        add(out, value)

fn v3ParserAppendUniqueLookupText(out: var str[],
                                  seen: var V3ParserTextLookup,
                                  text: str) =
    let value = v3path.V3PathTrim(text)
    v3ParserAppendUniqueLookupTextExact(out, seen, value)

fn v3ParserMatchKnownCallSurfaceText(callLookup: V3ParserTextLookup,
                                     callName: str,
                                     qualifiedCallName: str,
                                     dottedCallName: str): str =
    let callNameKey = v3ParserTextLookupKeyExact(callName)
    let qualifiedCallNameKey = v3ParserTextLookupKeyExact(qualifiedCallName)
    let dottedCallNameKey = v3ParserTextLookupKeyExact(dottedCallName)
    return v3ParserMatchKnownCallSurfaceTextKeys(callLookup,
                                                 callName,
                                                 callNameKey,
                                                 qualifiedCallName,
                                                 qualifiedCallNameKey,
                                                 dottedCallName,
                                                 dottedCallNameKey)

fn v3ParserMatchKnownCallSurfaceTextKeys(callLookup: V3ParserTextLookup,
                                         callName: str,
                                         callNameKey: V3ParserTextLookupKey,
                                         qualifiedCallName: str,
                                         qualifiedCallNameKey: V3ParserTextLookupKey,
                                         dottedCallName: str,
                                         dottedCallNameKey: V3ParserTextLookupKey): str =
    if dottedCallName != callName &&
       v3ParserTextLookupContainsKey(callLookup,
                                     dottedCallName,
                                     dottedCallNameKey):
        return dottedCallName
    if qualifiedCallName != callName &&
       v3ParserTextLookupContainsKey(callLookup,
                                     qualifiedCallName,
                                     qualifiedCallNameKey):
        return qualifiedCallName
    if v3ParserTextLookupContainsKey(callLookup, callName, callNameKey):
        return callName
    return ""

fn v3ParserStringSeqContainsExact(items: str[], target: str): bool =
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i], target):
            return true
    return false

fn v3ParserIsInlineSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    return false

fn v3ParserFirstToken(textRaw: str): str =
    let text = v3path.V3PathTrim(textRaw)
    if text == "":
        return ""
    var start: int32
    while start < text.len:
        if !v3ParserIsInlineSpace(text[start]):
            break
        start = start + 1
    var stop: int32 = start
    while stop < text.len:
        if v3ParserIsInlineSpace(text[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return v3ParserTextSliceFast(text, start, stop - start)

fn v3ParserIdentPrefix(text: str): str =
    var stop: int32
    for i in 0..<text.len:
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            stop = i + 1
        else:
            break
    if stop <= 0:
        return ""
    return v3ParserTextSliceFast(text, 0, stop)

fn v3ParserTextSliceFast(text: str,
                         startRaw: int32,
                         countRaw: int32): str =
    if countRaw <= 0:
        return ""
    let textLen = text.len
    if textLen <= 0:
        return ""
    var start = startRaw
    if start < 0:
        start = 0
    if start >= textLen:
        return ""
    var count = countRaw
    if start + count > textLen:
        count = textLen - start
    if count <= 0:
        return ""
    let data = strDataPtr(text)
    if data == nil:
        return ""
    return strViewWithFlags(system_ptr_add(data, start), count, text.store_id, 0)

fn v3ParserSplitChar(textRaw: str, sep: char): str[] =
    let text = textRaw
    var out: str[]
    var start: int32
    for i in 0..<text.len:
        if text[i] == sep:
            add(out, v3ParserTextSliceFast(text, start, i - start))
            start = i + 1
    if start <= text.len:
        add(out, v3ParserTextSliceFast(text, start, text.len - start))
    return out

fn v3ParserJoinSlash(items: str[]): str =
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    for i in 0..<items.len:
        if items[i] == "":
            continue
        if wrote:
            buffer.AppendBytes(out, slash)
        buffer.AppendBytes(out, items[i])
        wrote = true
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3ParserStartsWith(textRaw: str, prefixRaw: str): bool =
    let text = v3path.V3PathTrim(textRaw)
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3ParserStartsWithExact(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3ParserLineStartsWith(lineRaw: str, prefix: str): bool =
    return v3ParserStartsWith(lineRaw, prefix)

fn v3ParserFindText(text: str, needle: str): int32 =
    if needle.len <= 0:
        return 0
    if needle.len == 1:
        let target = needle[0]
        for i in 0..<text.len:
            if text[i] == target:
                return i
        return -1
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn v3ParserCompilerTopLevelExportName(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWithExact(line, "@compiler_top_level("):
        return ""
    let exportPos = v3ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = v3ParserFindText(v3path.V3TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = v3path.V3TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, valueStart, quoteEnd)

fn v3ParserCompilerTopLevelExportNameExact(line: str): str =
    if !v3ParserStartsWithExact(line, "@compiler_top_level("):
        return ""
    let exportPos = v3ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = v3ParserFindText(v3path.V3TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = v3path.V3TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, valueStart, quoteEnd)

fn v3ParserExportcNameFromAnnotation(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWithExact(line, "@exportc("):
        return ""
    let quoteStart = v3ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = v3path.V3TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, quoteStart + 1, quoteEnd)

fn v3ParserExportcNameFromAnnotationExact(line: str): str =
    if !v3ParserStartsWithExact(line, "@exportc("):
        return ""
    let quoteStart = v3ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = v3path.V3TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, quoteStart + 1, quoteEnd)

fn v3ParserIsImportcAnnotation(lineRaw: str): bool =
    return v3ParserStartsWith(lineRaw, "@importc(")

fn v3ParserIsImportcAnnotationExact(line: str): bool =
    return v3ParserStartsWithExact(line, "@importc(")

fn v3ParserHasLeadingIndent(lineRaw: str): bool =
    if len(lineRaw) <= 0:
        return false
    let head = int32(lineRaw[0])
    return head == 32 || head == 9

fn v3ParserTopLevelFunctionPrefixLenKeywordExact(line: str,
                                                 keyword: var str): int32 =
    if v3ParserStartsWithExact(line, "importc fn "):
        keyword = "fn"
        return len("importc fn ")
    if v3ParserStartsWithExact(line, "fn "):
        keyword = "fn"
        return len("fn ")
    if v3ParserStartsWithExact(line, "func "):
        keyword = "func"
        return len("func ")
    if v3ParserStartsWithExact(line, "proc "):
        keyword = "proc"
        return len("proc ")
    if v3ParserStartsWithExact(line, "method "):
        keyword = "method"
        return len("method ")
    if v3ParserStartsWithExact(line, "converter "):
        keyword = "converter"
        return len("converter ")
    keyword = ""
    return 0

fn v3ParserTopLevelFunctionPrefixLenKeywordRange(lineRaw: str,
                                                 lineStart: int32,
                                                 lineStop: int32,
                                                 keyword: var str): int32 =
    if lineStart + len("importc fn ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("importc fn "), "importc fn "):
        keyword = "fn"
        return len("importc fn ")
    if lineStart + len("fn ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("fn "), "fn "):
        keyword = "fn"
        return len("fn ")
    if lineStart + len("func ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("func "), "func "):
        keyword = "func"
        return len("func ")
    if lineStart + len("proc ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("proc "), "proc "):
        keyword = "proc"
        return len("proc ")
    if lineStart + len("method ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("method "), "method "):
        keyword = "method"
        return len("method ")
    if lineStart + len("converter ") <= lineStop &&
       v3ParserTextRangeEquals(lineRaw, lineStart, len("converter "), "converter "):
        keyword = "converter"
        return len("converter ")
    keyword = ""
    return 0

fn v3ParserTopLevelFunctionKeywordExact(line: str): str =
    var keyword: str
    let prefixLen = v3ParserTopLevelFunctionPrefixLenKeywordExact(line, keyword)
    if prefixLen < 0:
        return ""
    return keyword

fn v3ParserTopLevelFunctionKeyword(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    return v3ParserTopLevelFunctionKeywordExact(line)

fn v3ParserFunctionNameFromTrimmedLineWithPrefix(line: str,
                                                 prefixLen: int32): str =
    if prefixLen <= 0:
        return ""
    if prefixLen >= line.len:
        return ""
    var start = prefixLen
    while start < line.len:
        if !v3ParserIsInlineSpace(line[start]):
            break
        start = start + 1
    if start >= line.len:
        return ""
    var stop = start
    while stop < line.len:
        if !v3ParserIsIdentChar(line[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return v3ParserTextSliceFast(line, start, stop - start)

fn v3ParserFunctionNameFromTrimmedRangeWithPrefix(lineRaw: str,
                                                  lineStart: int32,
                                                  lineStop: int32,
                                                  prefixLen: int32): str =
    if prefixLen <= 0:
        return ""
    let startBase = lineStart + prefixLen
    if startBase >= lineStop:
        return ""
    var start = startBase
    while start < lineStop:
        if !v3ParserIsInlineSpace(lineRaw[start]):
            break
        start = start + 1
    if start >= lineStop:
        return ""
    var stop = start
    while stop < lineStop:
        if !v3ParserIsIdentChar(lineRaw[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return v3ParserTextSliceFast(lineRaw, start, stop - start)

fn v3ParserFunctionNameFromTrimmedLine(line: str): str =
    var keyword: str
    let prefixLen = v3ParserTopLevelFunctionPrefixLenKeywordExact(line, keyword)
    return v3ParserFunctionNameFromTrimmedLineWithPrefix(line, prefixLen)

fn v3ParserFunctionNameFromLine(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    return v3ParserFunctionNameFromTrimmedLine(line)

fn v3ParserReadNormalizedFunctionDeclsLines(lines: str[],
                                            decls: var V3NormalizedFunctionDecl[],
                                            err: var str): bool =
    var emptyDecls: V3NormalizedFunctionDecl[]
    decls = emptyDecls
    var pendingImportc = false
    var pendingExplicitExportName: str
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        var lineStart: int32
        var lineStop: int32
        if !v3ParserTrimmedLineRange(lineRaw, lineStart, lineStop):
            continue
        if v3ParserHasLeadingIndent(lineRaw):
            continue
        if lineRaw[lineStart] == '@':
            let trimmed = v3ParserTextSliceFast(lineRaw, lineStart, lineStop - lineStart)
            let compilerExportName = v3ParserCompilerTopLevelExportNameExact(trimmed)
            if compilerExportName != "":
                pendingExplicitExportName = compilerExportName
                continue
            let exportcName = v3ParserExportcNameFromAnnotationExact(trimmed)
            if exportcName != "":
                pendingExplicitExportName = exportcName
                continue
            if v3ParserIsImportcAnnotationExact(trimmed):
                pendingImportc = true
                pendingExplicitExportName = ""
                continue
            continue
        var keyword: str
        let prefixLen = v3ParserTopLevelFunctionPrefixLenKeywordRange(lineRaw,
                                                                      lineStart,
                                                                      lineStop,
                                                                      keyword)
        if keyword == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        if keyword != "fn":
            err = v3ParserConcat3("unsupported top-level function alias '", keyword, "'")
            return false
        let functionName = v3ParserFunctionNameFromTrimmedRangeWithPrefix(lineRaw,
                                                                          lineStart,
                                                                          lineStop,
                                                                          prefixLen)
        if functionName == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        let inlineImportc = prefixLen == len("importc fn ")
        var decl: V3NormalizedFunctionDecl
        decl.name = functionName
        decl.lineIndex = i + 1
        decl.importc = pendingImportc || inlineImportc
        decl.explicitExportName = decl.importc ? "" : pendingExplicitExportName
        decl.surfaceKeyword = inlineImportc ? "importc fn" : "fn"
        add(decls, decl)
        pendingImportc = false
        pendingExplicitExportName = ""
    err = ""
    return true

fn v3ParserReadNormalizedFunctionDecls(textRaw: str,
                                       decls: var V3NormalizedFunctionDecl[],
                                       err: var str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    return v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err)

fn v3ParserContainsCompilerPrefix(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    if v3ParserStartsWithExact(line, "import "):
        return true
    if v3ParserStartsWithExact(line, "type"):
        return true
    if v3ParserTopLevelFunctionKeywordExact(line) != "":
        return true
    if v3ParserStartsWithExact(line, "iterator "):
        return true
    if v3ParserStartsWithExact(line, "const "):
        return true
    if v3ParserStartsWithExact(line, "let "):
        return true
    if v3ParserStartsWithExact(line, "var "):
        return true
    return false

fn v3ParserModulePathTail(modulePath: str, skipCount: int32): str =
    let modulePathTrim = v3path.V3PathTrim(modulePath)
    let parts = v3ParserSplitChar(modulePathTrim, '/')
    var out: str[]
    for i in skipCount..<parts.len:
        let rawPiece = parts[i]
        let piece = v3path.V3PathTrim(rawPiece)
        if piece != "":
            add(out, piece)
    return v3ParserJoinSlash(out)

fn v3ParserModulePathTailExact(modulePath: str, skipCount: int32): str =
    if modulePath == "":
        return ""
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    var pieceIndex: int32
    var start: int32
    var cursor: int32
    while cursor <= modulePath.len:
        let atEnd = cursor >= modulePath.len
        var stop = false
        if atEnd:
            stop = true
        elif modulePath[cursor] == '/':
            stop = true
        if !stop:
            cursor = cursor + 1
            continue
        if pieceIndex >= skipCount && cursor > start:
            if wrote:
                buffer.AppendBytes(out, slash)
            buffer.AppendBytes(out, v3ParserTextSliceFast(modulePath, start, cursor - start))
            wrote = true
        pieceIndex = pieceIndex + 1
        start = cursor + 1
        cursor = cursor + 1
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3ParserPathSlash(pathRaw: str): str =
    return v3ParserJoinSlash(v3ParserSplitChar(pathRaw, '\\'))

fn v3ParserRelWithoutExt(pathRaw: str): str =
    let path = v3ParserPathSlash(v3ParserNormalizePath(pathRaw))
    if path.len >= 6 && v3path.V3TextSlice(path, path.len - 6, 6) == ".cheng":
        return v3path.V3TextSlice(path, 0, path.len - 6)
    return path

fn v3ParserSharedV3PackageRoot(workspaceRootRaw: str): str =
    let envRoot = v3ParserNormalizePath(os.GetEnv("CHENG_ROOT"))
    if envRoot != "":
        if v3ParserPackageId(envRoot) == "cheng":
            return envRoot
    let discoveredRoot = v3ParserNormalizePath(rootdisco.v3CompilerRootAuto())
    if discoveredRoot != "" && v3ParserPackageId(discoveredRoot) == "cheng":
        return discoveredRoot
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    if workspaceRoot == "":
        return ""
    if v3ParserPackageId(workspaceRoot) == "cheng":
        return workspaceRoot
    let sharedV3Root = v3ParserSharedV3Root(workspaceRoot)
    if sharedV3Root != "":
        return sharedV3Root
    return ""

fn v3ParserSharedBuiltinSourceRoot(workspaceRootRaw: str): str =
    let envRoot = v3ParserNormalizePath(os.GetEnv("CHENG_ROOT"))
    if envRoot != "":
        return envRoot
    let discoveredRoot = v3ParserNormalizePath(rootdisco.v3CompilerRootAuto())
    if discoveredRoot != "" &&
       os.FileExists(v3path.V3PathAbsolute(discoveredRoot, "src/std/system.cheng")):
        return discoveredRoot
    return v3ParserNormalizePath(workspaceRootRaw)

fn v3ParserSharedBuiltinModulePathToSourcePath(sharedSourceRootRaw: str,
                                               modulePathRaw: str): str =
    let sharedSourceRoot = v3ParserNormalizePath(sharedSourceRootRaw)
    let modulePath = v3path.V3PathTrim(modulePathRaw)
    if sharedSourceRoot == "" || modulePath == "":
        return ""
    if v3ParserStartsWithExact(modulePath, "std/") && modulePath.len > 4:
        let rel: str = v3ParserModulePathTailExact(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(sharedSourceRoot, "/src/std/"), rel, ".cheng")
    if v3ParserStartsWithExact(modulePath, "runtime/") && modulePath.len > 8:
        let rel: str = v3ParserModulePathTailExact(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(sharedSourceRoot, "/src/runtime/"), rel, ".cheng")
    if v3ParserStartsWithExact(modulePath, "decentralized/") && modulePath.len > 14:
        let rel: str = v3ParserModulePathTailExact(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(sharedSourceRoot, "/src/decentralized/"), rel, ".cheng")
    return ""

fn v3ParserSharedBuiltinSourcePathToModulePath(sharedSourceRootRaw: str,
                                               sourcePathRaw: str): str =
    let sharedSourceRoot = v3ParserNormalizePath(sharedSourceRootRaw)
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sharedSourceRoot == "" || sourcePath == "":
        return ""
    let stdPrefix: str = v3ParserConcat2(sharedSourceRoot, "/src/std/")
    if v3ParserStartsWithExact(sourcePath, stdPrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                stdPrefix.len,
                                                                sourcePath.len - stdPrefix.len))
        if rel == "":
            return "std"
        return v3ParserConcat2("std/", rel)
    let runtimePrefix: str = v3ParserConcat2(sharedSourceRoot, "/src/runtime/")
    if v3ParserStartsWithExact(sourcePath, runtimePrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                runtimePrefix.len,
                                                                sourcePath.len - runtimePrefix.len))
        if rel == "":
            return "runtime"
        return v3ParserConcat2("runtime/", rel)
    let decentralizedPrefix: str = v3ParserConcat2(sharedSourceRoot, "/src/decentralized/")
    if v3ParserStartsWithExact(sourcePath, decentralizedPrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                decentralizedPrefix.len,
                                                                sourcePath.len - decentralizedPrefix.len))
        if rel == "":
            return "decentralized"
        return v3ParserConcat2("decentralized/", rel)
    return ""

fn v3ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot: str,
                                                                  packageRoot: str,
                                                                  sharedV3PackageRoot: str,
                                                                  packageId: str,
                                                                  packagePrefix: str,
                                                                  externalPackageRoots: V3ParserExternalPackageRoot[],
                                                                  modulePath: str): str =
    if modulePath == "":
        return ""
    let sharedBuiltinSourcePath = v3ParserSharedBuiltinModulePathToSourcePath(v3ParserSharedBuiltinSourceRoot(workspaceRoot),
                                                                              modulePath)
    if sharedBuiltinSourcePath != "":
        return sharedBuiltinSourcePath
    if packageId != "" && modulePath.len > packageId.len && v3ParserStartsWithExact(modulePath, packagePrefix):
        let rel: str = v3path.V3TextSlice(modulePath,
                                          packagePrefix.len,
                                          modulePath.len - packagePrefix.len)
        return v3ParserConcat3(v3ParserConcat2(packageRoot, "/src/"), rel, ".cheng")
    var externalPackageRoot = ""
    var externalPackageId = ""
    var externalPackagePrefix = ""
    if v3ParserExternalPackageRootByModulePath(modulePath,
                                               externalPackageRoots,
                                               externalPackageRoot,
                                               externalPackageId,
                                               externalPackagePrefix):
        let rel = v3path.V3TextSlice(modulePath,
                                     externalPackagePrefix.len,
                                     modulePath.len - externalPackagePrefix.len)
        return v3ParserConcat3(v3ParserConcat2(externalPackageRoot, "/src/"), rel, ".cheng")
    if sharedV3PackageRoot != "" &&
       v3ParserStartsWithExact(modulePath, "cheng/") &&
       modulePath.len > 6:
        let rel: str = v3ParserModulePathTailExact(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(sharedV3PackageRoot, "/src/"), rel, ".cheng")
    return ""

fn v3ParserModulePathToSourcePathPrepared(workspaceRoot: str,
                                          packageRoot: str,
                                          sharedV3PackageRoot: str,
                                          packageId: str,
                                          packagePrefix: str,
                                          modulePath: str): str =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                          packageRoot,
                                                                          sharedV3PackageRoot,
                                                                          packageId,
                                                                          packagePrefix,
                                                                          externalPackageRoots,
                                                                          modulePath)

fn v3ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRootRaw: str,
                                                          packageRootRaw: str,
                                                          externalPackageRoots: V3ParserExternalPackageRoot[],
                                                          modulePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let modulePath: str = v3path.V3PathTrim(modulePathRaw)
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    let packageId: str = v3ParserPackageId(packageRoot)
    let packagePrefix: str = v3ParserConcat2(packageId, "/")
    return v3ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                          packageRoot,
                                                                          sharedV3PackageRoot,
                                                                          packageId,
                                                                          packagePrefix,
                                                                          externalPackageRoots,
                                                                          modulePath)

fn v3ParserModulePathToSourcePath(workspaceRootRaw: str, packageRootRaw: str, modulePathRaw: str): str =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRootRaw,
                                                                  packageRootRaw,
                                                                  externalPackageRoots,
                                                                  modulePathRaw)

fn v3ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRootRaw: str,
                                                          packageRootRaw: str,
                                                          externalPackageRoots: V3ParserExternalPackageRoot[],
                                                          sourcePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    let packagePrefix: str = v3ParserConcat2(packageRoot, "/src/")
    if v3ParserStartsWithExact(sourcePath, packagePrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                packagePrefix.len,
                                                                sourcePath.len - packagePrefix.len))
        let packageId: str = v3ParserPackageId(packageRoot)
        if rel == "":
            return packageId
        return v3ParserConcat3(packageId, "/", rel)
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    let sharedV3Prefix: str = v3ParserConcat2(sharedV3PackageRoot, "/src/")
    if sharedV3PackageRoot != "" && v3ParserStartsWithExact(sourcePath, sharedV3Prefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                sharedV3Prefix.len,
                                                                sourcePath.len - sharedV3Prefix.len))
        if rel == "":
            return "cheng"
        return v3ParserConcat2("cheng/", rel)
    var externalPackageRoot = ""
    var externalPackageId = ""
    if v3ParserExternalPackageRootBySourcePath(sourcePath,
                                               externalPackageRoots,
                                               externalPackageRoot,
                                               externalPackageId):
        let externalPrefix: str = v3ParserConcat2(externalPackageRoot, "/src/")
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                externalPrefix.len,
                                                                sourcePath.len - externalPrefix.len))
        if rel == "":
            return externalPackageId
        return v3ParserConcat3(externalPackageId, "/", rel)
    let sharedBuiltinModulePath = v3ParserSharedBuiltinSourcePathToModulePath(v3ParserSharedBuiltinSourceRoot(workspaceRoot),
                                                                              sourcePath)
    if sharedBuiltinModulePath != "":
        return sharedBuiltinModulePath
    return v3ParserFileStem(sourcePath)

fn v3ParserSourcePathToModulePath(workspaceRootRaw: str, packageRootRaw: str, sourcePathRaw: str): str =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRootRaw,
                                                                  packageRootRaw,
                                                                  externalPackageRoots,
                                                                  sourcePathRaw)

fn v3ParserHasCompilerTopLevel(textRaw: str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    var decls: V3NormalizedFunctionDecl[]
    var err = ""
    if v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        if decls.len > 0:
            return true
    for i in 0..<lines.len:
        if v3ParserContainsCompilerPrefix(lines[i]):
            return true
    return false

fn v3ParserMainFunctionPresent(textRaw: str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    var decls: V3NormalizedFunctionDecl[]
    var err = ""
    if !v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        return false
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "main":
            return true
    return false

fn v3ParserAppendImportEdgeWithExternalPackageRoots(workspaceRoot: str,
                                                    packageRoot: str,
                                                    externalPackageRoots: V3ParserExternalPackageRoot[],
                                                    ownerModulePath: str,
                                                    modulePathRaw: str,
                                                    importAliasRaw: str,
                                                    edges: var V3ImportEdge[],
                                                    err: var str): bool =
    let normalizedWorkspaceRoot = v3ParserNormalizePath(workspaceRoot)
    let normalizedPackageRoot = v3ParserNormalizePath(packageRoot)
    let modulePath = v3path.V3PathTrim(modulePathRaw)
    let importAlias = v3path.V3PathTrim(importAliasRaw)
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(normalizedWorkspaceRoot)
    let packageId: str = v3ParserPackageId(normalizedPackageRoot)
    let packagePrefix: str = v3ParserConcat2(packageId, "/")
    return v3ParserAppendImportEdgePreparedWithExternalPackageRoots(normalizedWorkspaceRoot,
                                                                    normalizedPackageRoot,
                                                                    sharedV3PackageRoot,
                                                                    packageId,
                                                                    packagePrefix,
                                                                    externalPackageRoots,
                                                                    ownerModulePath,
                                                                    modulePath,
                                                                    importAlias,
                                                                    edges,
                                                                    err)

fn v3ParserAppendImportEdge(workspaceRoot: str,
                            packageRoot: str,
                            ownerModulePath: str,
                            modulePathRaw: str,
                            importAliasRaw: str,
                            edges: var V3ImportEdge[],
                            err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserAppendImportEdgeWithExternalPackageRoots(workspaceRoot,
                                                            packageRoot,
                                                            externalPackageRoots,
                                                            ownerModulePath,
                                                            modulePathRaw,
                                                            importAliasRaw,
                                                            edges,
                                                            err)

fn v3ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot: str,
                                                            packageRoot: str,
                                                            sharedV3PackageRoot: str,
                                                            packageId: str,
                                                            packagePrefix: str,
                                                            externalPackageRoots: V3ParserExternalPackageRoot[],
                                                            ownerModulePath: str,
                                                            modulePath: str,
                                                            importAlias: str,
                                                            edges: var V3ImportEdge[],
                                                            err: var str): bool =
    if modulePath == "":
        err = "v3 parser: malformed import"
        return false
    let sourcePath = v3ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                                    packageRoot,
                                                                                    sharedV3PackageRoot,
                                                                                    packageId,
                                                                                    packagePrefix,
                                                                                    externalPackageRoots,
                                                                                    modulePath)
    let resolved = v3ParserSourceExists(sourcePath)
    var edge: V3ImportEdge
    edge.ownerModulePath = ownerModulePath
    edge.targetModulePath = modulePath
    edge.targetSourcePath = sourcePath
    edge.targetSourcePathLen = sourcePath.len
    if sourcePath == "":
        edge.targetSourcePathFirstCode = 0
        edge.targetSourcePathLastCode = 0
        edge.targetSourcePathDotCount = 0
        edge.targetSourcePathHash = 0
    else:
        edge.targetSourcePathFirstCode = int32(sourcePath[0])
        edge.targetSourcePathLastCode = int32(sourcePath[sourcePath.len - 1])
        edge.targetSourcePathDotCount = v3ParserTextLookupDotCount(sourcePath)
        edge.targetSourcePathHash = v3ParserTextLookupContentHash(sourcePath)
    edge.targetProfileIndex = -1
    edge.importAlias = importAlias
    edge.qualifier = ""
    let aliasText = v3ParserIdentPrefix(edge.importAlias)
    if aliasText != "":
        edge.qualifier = aliasText
    else:
        let sourceStem = v3ParserFileStem(edge.targetSourcePath)
        if sourceStem != "":
            edge.qualifier = sourceStem
        else:
            edge.qualifier = v3ParserLastPathPiece(edge.targetModulePath)
    edge.allowsUnqualifiedCall = edge.importAlias == ""
    edge.resolved = resolved
    add(edges, edge)
    err = ""
    return true

fn v3ParserAppendImportEdgePrepared(workspaceRoot: str,
                                    packageRoot: str,
                                    sharedV3PackageRoot: str,
                                    packageId: str,
                                    packagePrefix: str,
                                    ownerModulePath: str,
                                    modulePath: str,
                                    importAlias: str,
                                    edges: var V3ImportEdge[],
                                    err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                    packageRoot,
                                                                    sharedV3PackageRoot,
                                                                    packageId,
                                                                    packagePrefix,
                                                                    externalPackageRoots,
                                                                    ownerModulePath,
                                                                    modulePath,
                                                                    importAlias,
                                                                    edges,
                                                                    err)

fn v3ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot: str,
                                                        packageRoot: str,
                                                        externalPackageRoots: V3ParserExternalPackageRoot[],
                                                        ownerModulePath: str,
                                                        lines: str[],
                                                        edges: var V3ImportEdge[],
                                                        err: var str): bool =
    edges = []
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    let packageId: str = v3ParserPackageId(packageRoot)
    let packagePrefix: str = v3ParserConcat2(packageId, "/")
    for i in 0..<lines.len:
        let rawLine = lines[i]
        var importTailStart: int32 = -1
        var importTailStop: int32 = -1
        if !v3ParserImportLineTailRange(rawLine, importTailStart, importTailStop):
            continue
        let importTail = v3ParserTrimmedSliceRange(rawLine, importTailStart, importTailStop)
        let asMarker = " as "
        let asPos = v3ParserFindText(importTail, asMarker)
        var importSpec = ""
        var importAlias = ""
        if asPos >= 0:
            importSpec = v3ParserTrimmedSliceRange(importTail, 0, asPos)
            let aliasTailStart = asPos + len(asMarker)
            if aliasTailStart < importTail.len:
                let aliasTail = v3ParserTrimmedSliceRange(importTail,
                                                          aliasTailStart,
                                                          importTail.len)
                importAlias = v3ParserIdentPrefix(aliasTail)
        else:
            importSpec = importTail
        let groupedOpenPos = v3ParserFindText(importSpec, "/[")
        if groupedOpenPos >= 0:
            if importAlias != "":
                err = "v3 parser: grouped import alias unsupported"
                return false
            let groupedClosePos = v3ParserFindText(importSpec, "]")
            if groupedClosePos < 0 || groupedClosePos != importSpec.len - 1:
                err = "v3 parser: malformed grouped import"
                return false
            let groupPrefix = v3ParserTrimmedSliceRange(importSpec, 0, groupedOpenPos)
            let groupItemsText = v3path.V3TextSlice(importSpec,
                                                    groupedOpenPos + 2,
                                                    groupedClosePos - (groupedOpenPos + 2))
            if groupPrefix == "" || groupItemsText == "":
                err = "v3 parser: malformed grouped import"
                return false
            var appended = false
            var start: int32
            var itemPos: int32
            while itemPos <= len(groupItemsText):
                let atEnd = itemPos >= len(groupItemsText)
                var stop = false
                if atEnd:
                    stop = true
                elif groupItemsText[itemPos] == ',':
                    stop = true
                if !stop:
                    itemPos = itemPos + 1
                    continue
                let item = v3ParserTrimmedSliceRange(groupItemsText, start, itemPos)
                if len(item) > 0:
                    if !v3ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                                 packageRoot,
                                                                                 sharedV3PackageRoot,
                                                                                 packageId,
                                                                                 packagePrefix,
                                                                                 externalPackageRoots,
                                                                                 ownerModulePath,
                                                                                 v3ParserConcat3(groupPrefix, "/", item),
                                                                                 "",
                                                                                 edges,
                                                                                 err):
                        return false
                    appended = true
                start = itemPos + 1
                itemPos = itemPos + 1
            if !appended:
                err = "v3 parser: malformed grouped import"
                return false
            continue
        if !v3ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                     packageRoot,
                                                                     sharedV3PackageRoot,
                                                                     packageId,
                                                                     packagePrefix,
                                                                     externalPackageRoots,
                                                                     ownerModulePath,
                                                                     importSpec,
                                                                     importAlias,
                                                                     edges,
                                                                     err):
            return false
    err = ""
    return true

fn v3ParserReadImportEdgesLines(workspaceRoot: str,
                                packageRoot: str,
                                ownerModulePath: str,
                                lines: str[],
                                edges: var V3ImportEdge[],
                                err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                packageRoot,
                                                                externalPackageRoots,
                                                                ownerModulePath,
                                                                lines,
                                                                edges,
                                                                err)

fn v3ParserReadImportEdgesWithExternalPackageRoots(workspaceRoot: str,
                                                   packageRoot: str,
                                                   externalPackageRoots: V3ParserExternalPackageRoot[],
                                                   ownerModulePath: str,
                                                   textRaw: str,
                                                   edges: var V3ImportEdge[],
                                                   err: var str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    return v3ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                packageRoot,
                                                                externalPackageRoots,
                                                                ownerModulePath,
                                                                lines,
                                                                edges,
                                                                err)

fn v3ParserReadImportEdges(workspaceRoot: str,
                           packageRoot: str,
                           ownerModulePath: str,
                           textRaw: str,
                           edges: var V3ImportEdge[],
                           err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserReadImportEdgesWithExternalPackageRoots(workspaceRoot,
                                                           packageRoot,
                                                           externalPackageRoots,
                                                           ownerModulePath,
                                                           textRaw,
                                                           edges,
                                                           err)

fn v3ImportEdgeTargetSourcePath(edge: V3ImportEdge): str =
    return edge.targetSourcePath

fn v3ParserAddUniqueImportEdge(edges: var V3ImportEdge[],
                               edge: V3ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn v3ParserAddUniqueText(items: var str[],
                         text: str) =
    let value = v3path.V3PathTrim(text)
    v3ParserAddUniqueTextExact(items, value)

fn v3ParserAddUniqueTextExact(items: var str[],
                              value: str) =
    if value == "":
        return
    for i in 0..<items.len:
        if v3ParserTextEqualsExact(items[i], value):
            return
    add(items, value)

fn v3ParserCollectClosureWithExternalPackageRoots(workspaceRoot: str,
                                                  packageRoot: str,
                                                  externalPackageRoots: V3ParserExternalPackageRoot[],
                                                  sourcePathRaw: str,
                                                  seen: var str[],
                                                  ordered: var str[],
                                                  importEdges: var V3ImportEdge[],
                                                  unresolved: var int32,
                                                  err: var str): bool =
    let sourcePath: str = v3path.V3PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing closure source path"
        return false
    if v3ParserStringSeqContainsExact(seen, sourcePath):
        err = ""
        return true
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: missing source"
        return false
    if !v3ParserStringSeqContainsExact(seen, sourcePath):
        add(seen, sourcePath)
        add(ordered, sourcePath)
    var scanPos: int32
    while scanPos < ordered.len:
        let currentSourcePath = ordered[scanPos]
        scanPos = scanPos + 1
        let text = v3ParserOwnedText(v3path.V3ReadTextFile("", currentSourcePath))
        let lines = v3ParserSplitChar(text, '\n')
        let ownerModulePath = v3ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                     packageRoot,
                                                                                     externalPackageRoots,
                                                                                     currentSourcePath)
        var edges: V3ImportEdge[]
        if !v3ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 ownerModulePath,
                                                                 lines,
                                                                 edges,
                                                                 err):
            return false
        for i in 0..<edges.len:
            v3ParserAddUniqueImportEdge(importEdges, edges[i])
            let childSourcePath = edges[i].targetSourcePath
            if !edges[i].resolved:
                unresolved = unresolved + 1
                continue
            if v3ParserStringSeqContainsExact(seen, childSourcePath):
                continue
            add(seen, childSourcePath)
            add(ordered, childSourcePath)
    err = ""
    return true

fn v3ParserCollectClosure(workspaceRoot: str,
                          packageRoot: str,
                          sourcePathRaw: str,
                          seen: var str[],
                          ordered: var str[],
                          importEdges: var V3ImportEdge[],
                          unresolved: var int32,
                          err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParserCollectClosureWithExternalPackageRoots(workspaceRoot,
                                                          packageRoot,
                                                          externalPackageRoots,
                                                          sourcePathRaw,
                                                          seen,
                                                          ordered,
                                                          importEdges,
                                                          unresolved,
                                                          err)

fn v3ParseOrdinarySourceStubWithExternalPackageRoots(packageRootRaw: str,
                                                     sourcePathRaw: str,
                                                     externalPackageRoots: V3ParserExternalPackageRoot[],
                                                     parsed: var V3ParsedSourceStub,
                                                     err: var str): bool =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing source path"
        return false
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: source file missing"
        return false
    let workspaceRoot: str = v3ParserWorkspaceRoot(packageRoot)
    let packageId: str = v3ParserPackageId(packageRoot)
    let moduleStem: str = v3ParserFileStem(sourcePath)
    let rootText: str = v3ParserOwnedText(v3path.V3ReadTextFile("", sourcePath))
    if rootText == "":
        err = "v3 parser: failed to read source"
        return false
    var rootDecls: V3NormalizedFunctionDecl[]
    if !v3ParserReadNormalizedFunctionDecls(rootText, rootDecls, err):
        return false
    var seen: str[]
    var ordered: str[]
    var importEdges: V3ImportEdge[]
    var exprLayer = V3NormalizedExprLayer()
    var unresolved: int32
    if !v3ParserCollectClosureWithExternalPackageRoots(workspaceRoot,
                                                       packageRoot,
                                                       externalPackageRoots,
                                                       sourcePath,
                                                       seen,
                                                       ordered,
                                                       importEdges,
                                                       unresolved,
                                                       err):
        return false
    var sourceProfiles: V3NormalizedExprCallProfile[]
    for i in 0..<ordered.len:
        let sourceText = v3ParserOwnedText(v3path.V3ReadTextFile("", ordered[i]))
        var profile: V3NormalizedExprCallProfile
        var profileErr = ""
        if !v3ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 ordered[i],
                                                                 sourceText,
                                                                 profile,
                                                                 profileErr):
            err = profileErr
            return false
        add(sourceProfiles, profile)
    let profileIndexLookup = v3ParserSourcePathIndexLookupBuild(sourceProfiles)
    v3ParserBindImportEdgeTargetProfileIndices(sourceProfiles, profileIndexLookup)
    for i in 0..<sourceProfiles.len:
        var sourceExprLayer = V3NormalizedExprLayer()
        var sourceExternalCallNames: str[]
        v3ParserCollectExternalCallNames(sourceProfiles,
                                         profileIndexLookup,
                                         i,
                                         sourceExternalCallNames)
        if !v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourceProfiles[i].sourcePath,
                                                                             sourceProfiles[i].text,
                                                                             sourceProfiles[i].importcCallNames,
                                                                             sourceProfiles[i].localCallNames,
                                                                             sourceExternalCallNames,
                                                                             sourceProfiles[i],
                                                                             sourceProfiles,
                                                                             profileIndexLookup,
                                                                             sourceExprLayer,
                                                                             err):
            err = v3ParserConcat4("v3 parser: ", sourceProfiles[i].sourcePath, ": ", err)
            return false
        v3NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
    var ownerModulePaths: str[]
    for i in 0..<ordered.len:
        v3ParserAddUniqueText(ownerModulePaths,
                              v3ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                    packageRoot,
                                                                                    externalPackageRoots,
                                                                                    ordered[i]))
    parsed.workspaceRoot = workspaceRoot
    parsed.packageRoot = packageRoot
    parsed.packageId = packageId
    parsed.entrySourcePath = sourcePath
    parsed.sourcePath = sourcePath
    parsed.moduleStem = moduleStem
    parsed.syntaxTag = "v3_normalized_source_v3"
    parsed.sourceKind = v3ParsedOrdinarySource
    parsed.ownerModulePaths = ownerModulePaths
    parsed.importEdges = importEdges
    parsed.orderedClosureSourcePaths = ordered
    parsed.normalizedExprLayer = exprLayer
    parsed.hasCompilerTopLevel = v3ParserHasCompilerTopLevel(rootText)
    parsed.mainFunctionPresent = false
    for i in 0..<rootDecls.len:
        if rootDecls[i].importc:
            continue
        if rootDecls[i].name == "main":
            parsed.mainFunctionPresent = true
    parsed.unresolvedImportCount = unresolved
    err = ""
    return true

fn v3ParseOrdinarySourceStub(packageRootRaw: str,
                             sourcePathRaw: str,
                             parsed: var V3ParsedSourceStub,
                             err: var str): bool =
    var externalPackageRoots: V3ParserExternalPackageRoot[]
    return v3ParseOrdinarySourceStubWithExternalPackageRoots(packageRootRaw,
                                                             sourcePathRaw,
                                                             externalPackageRoots,
                                                             parsed,
                                                             err)
