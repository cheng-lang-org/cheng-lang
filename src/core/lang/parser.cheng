type
    ParsedSourceKind = enum
        ParsedOrdinarySource

    ParserExternalPackageRoot =
        packageId: str
        packageRoot: str

    ImportEdge =
        ownerModulePath: str
        targetModulePath: str
        targetSourcePath: str
        targetSourcePathLen: int32
        targetSourcePathFirstCode: int32
        targetSourcePathLastCode: int32
        targetSourcePathDotCount: int32
        targetSourcePathHash: int32
        targetProfileIndex: int32
        importAlias: str
        qualifier: str
        allowsUnqualifiedCall: bool
        resolved: bool

    NormalizedExprKind = enum
        NormalizedExprIf
        NormalizedExprRange
        NormalizedExprComprehension
        NormalizedExprStrFormat
        NormalizedExprResultIntrinsic
        NormalizedExprCall
        NormalizedExprTry
        NormalizedExprDefaultInit
        NormalizedExprConstructor
        NormalizedExprReturn
        NormalizedExprAssign
        NormalizedExprIfStmt
        NormalizedExprElifStmt
        NormalizedExprElseStmt
        NormalizedExprForStmt

    NormalizedExprDetailKind = enum
        NormalizedExprDetailNone
        NormalizedExprDetailIfKeyword
        NormalizedExprDetailIfTernary
        NormalizedExprDetailTryPostfixQuestion
        NormalizedExprDetailRangeInclusive
        NormalizedExprDetailRangeExclusive
        NormalizedExprDetailComprehensionList
        NormalizedExprDetailStrFormatLiteral
        NormalizedExprDetailStrFormatCall
        NormalizedExprDetailResultOk
        NormalizedExprDetailResultErr
        NormalizedExprDetailResultValue
        NormalizedExprDetailResultError
        NormalizedExprDetailResultIsOk
        NormalizedExprDetailResultIsErr
        NormalizedExprDetailResultErrorInfoOf

    NormalizedExprSurfaceCallKind = enum
        NormalizedExprSurfaceCallNone
        NormalizedExprSurfaceCallLocal
        NormalizedExprSurfaceCallExternal
        NormalizedExprSurfaceCallImportc
        NormalizedExprSurfaceCallMember

    NormalizedExprCallReason = enum
        NormalizedExprCallReasonNone
        NormalizedExprCallReasonUnknownQualifiedTarget
        NormalizedExprCallReasonShadowedQualifiedTarget
        NormalizedExprCallReasonAmbiguousExternalTarget
        NormalizedExprCallReasonAmbiguousQualifiedTarget
        NormalizedExprCallReasonUnknownExternalTarget
        NormalizedExprCallReasonUnknownCallTarget

    NormalizedExpr =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: NormalizedExprKind
        detailKind: NormalizedExprDetailKind
        surfaceText: str
        callSurfaceKind: NormalizedExprSurfaceCallKind
        callResolved: bool
        callReason: NormalizedExprCallReason
        callQualifier: str
        callCallee: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callPrefixStyle: bool
        callArgCount: int32
        callArgsText: str

    NormalizedExprLookupBucket =
        sourcePathLen: int32
        sourcePathFirstCode: int32
        sourcePathLastCode: int32
        lineNumber: int32
        columnNumber: int32
        kindCode: int32
        detailCode: int32
        surfaceLen: int32
        surfaceFirstCode: int32
        surfaceLastCode: int32
        items: int32[]

    NormalizedExprLookupKey =
        sourcePathLen: int32
        sourcePathFirstCode: int32
        sourcePathLastCode: int32
        lineNumber: int32
        columnNumber: int32
        kindCode: int32
        detailCode: int32
        surfaceLen: int32
        surfaceFirstCode: int32
        surfaceLastCode: int32

    NormalizedExprLookup =
        slots: int32[]
        buckets: NormalizedExprLookupBucket[]

    NormalizedExprLayer =
        sourceCount: int32
        exprs: NormalizedExpr[]
        questionResidualCount: int32
        exprLookup: NormalizedExprLookup

    NormalizedExprLayerKindCounts =
        exprCount: int32
        ifCount: int32
        rangeCount: int32
        comprehensionCount: int32
        strFormatCount: int32
        resultIntrinsicCount: int32
        callCount: int32
        tryCount: int32
        defaultInitCount: int32
        constructorCount: int32
        returnCount: int32
        assignCount: int32
        ifStmtCount: int32
        elifStmtCount: int32
        elseStmtCount: int32
        forStmtCount: int32

    ParsedSourceStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entrySourcePath: str
        sourcePath: str
        moduleStem: str
        syntaxTag: str
        sourceKind: ParsedSourceKind
        ownerModulePaths: str[]
        importEdges: ImportEdge[]
        orderedClosureSourcePaths: str[]
        normalizedExprLayer: NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        unresolvedImportCount: int32

    NormalizedFunctionDecl =
        name: str
        lineIndex: int32
        importc: bool
        explicitExportName: str
        surfaceKeyword: str
        ffiMapPtrArg: int32
        ffiMapLenArg: int32
        ffiOutPtrArgs: str

    NormalizedTypeDecl =
        name: str
        refObject: bool

    NormalizedExprCallProfile =
        sourcePath: str
        ownerModulePath: str
        text: str
        lines: str[]
        decls: NormalizedFunctionDecl[]
        typeDecls: NormalizedTypeDecl[]
        importcCallNames: str[]
        localCallNames: str[]
        importEdges: ImportEdge[]
        maxQualifiedCallDepth: int32

    NormalizedExprResolvedCallTarget =
        sourcePath: str
        importc: bool
        reason: NormalizedExprCallReason

    ParserImportedTargetLookup =
        targetProfileIndex: int32
        reason: NormalizedExprCallReason

    ParserTextSeqCacheEntry =
        profileIndex: int32
        items: str[]

    ParserQualifiedTextSeqCacheEntry =
        profileIndex: int32
        prefix: str
        items: str[]

    ParserTextLookupKey =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32

    ParserTextLookupBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32
        items: str[]

    ParserTextLookup =
        slots: int32[]
        buckets: ParserTextLookupBucket[]
        totalCount: int32

    ParserSourcePathIndexEntry =
        sourcePath: str
        profileIndex: int32

    ParserSourcePathIndexBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        sourcePathHash: int32
        items: ParserSourcePathIndexEntry[]

    ParserSourcePathIndexLookup =
        slots: int32[]
        buckets: ParserSourcePathIndexBucket[]

type
    ParserProfileCallLookupCacheEntry =
        localLookup: ParserTextLookup
        importcLookup: ParserTextLookup

fn ParsedSourceKindText(kind: ParsedSourceKind): str =
    if kind == ParsedOrdinarySource:
        return "ordinary_cheng_source"
    return "unknown"

fn ParsedSourceWorkspaceRoot(parsed: ParsedSourceStub): str =
    return parsed.workspaceRoot

fn NormalizedExprKindText(kind: NormalizedExprKind): str =
    if kind == NormalizedExprIf:
        return "IfExpr"
    if kind == NormalizedExprRange:
        return "RangeExpr"
    if kind == NormalizedExprComprehension:
        return "ComprehensionExpr"
    if kind == NormalizedExprStrFormat:
        return "StrFormatExpr"
    if kind == NormalizedExprResultIntrinsic:
        return "ResultIntrinsic"
    if kind == NormalizedExprCall:
        return "CallExpr"
    if kind == NormalizedExprTry:
        return "TryExpr"
    if kind == NormalizedExprDefaultInit:
        return "DefaultInitExpr"
    if kind == NormalizedExprConstructor:
        return "ConstructorExpr"
    if kind == NormalizedExprReturn:
        return "ReturnStmt"
    if kind == NormalizedExprAssign:
        return "AssignStmt"
    if kind == NormalizedExprIfStmt:
        return "IfStmt"
    if kind == NormalizedExprElifStmt:
        return "ElifStmt"
    if kind == NormalizedExprElseStmt:
        return "ElseStmt"
    if kind == NormalizedExprForStmt:
        return "ForStmt"
    return "UnknownExpr"

fn NormalizedExprDetailKindCode(detailKind: NormalizedExprDetailKind): int32 =
    if detailKind == NormalizedExprDetailIfKeyword:
        return 1
    if detailKind == NormalizedExprDetailIfTernary:
        return 2
    if detailKind == NormalizedExprDetailTryPostfixQuestion:
        return 3
    if detailKind == NormalizedExprDetailRangeInclusive:
        return 4
    if detailKind == NormalizedExprDetailRangeExclusive:
        return 5
    if detailKind == NormalizedExprDetailComprehensionList:
        return 6
    if detailKind == NormalizedExprDetailStrFormatLiteral:
        return 7
    if detailKind == NormalizedExprDetailStrFormatCall:
        return 8
    if detailKind == NormalizedExprDetailResultOk:
        return 9
    if detailKind == NormalizedExprDetailResultErr:
        return 10
    if detailKind == NormalizedExprDetailResultValue:
        return 11
    if detailKind == NormalizedExprDetailResultError:
        return 12
    if detailKind == NormalizedExprDetailResultIsOk:
        return 13
    if detailKind == NormalizedExprDetailResultIsErr:
        return 14
    if detailKind == NormalizedExprDetailResultErrorInfoOf:
        return 15
    return 0

fn ParserCallSurfaceKindText(kind: NormalizedExprSurfaceCallKind): str =
    if kind == NormalizedExprSurfaceCallLocal:
        return "local_call"
    if kind == NormalizedExprSurfaceCallExternal:
        return "external_call"
    if kind == NormalizedExprSurfaceCallImportc:
        return "importc_call"
    if kind == NormalizedExprSurfaceCallMember:
        return "member_call"
    return ""

fn ParserCallReasonText(reason: NormalizedExprCallReason): str =
    if reason == NormalizedExprCallReasonUnknownQualifiedTarget:
        return "unknown_qualified_target"
    if reason == NormalizedExprCallReasonShadowedQualifiedTarget:
        return "shadowed_qualified_target"
    if reason == NormalizedExprCallReasonAmbiguousExternalTarget:
        return "ambiguous_external_target"
    if reason == NormalizedExprCallReasonAmbiguousQualifiedTarget:
        return "ambiguous_qualified_target"
    if reason == NormalizedExprCallReasonUnknownExternalTarget:
        return "unknown_external_target"
    if reason == NormalizedExprCallReasonUnknownCallTarget:
        return "unknown_call_target"
    return ""

fn NormalizedExprClone(expr: NormalizedExpr): NormalizedExpr =
    var out: NormalizedExpr
    out.exprId = expr.exprId
    out.sourcePath = expr.sourcePath
    out.lineNumber = expr.lineNumber
    out.columnNumber = expr.columnNumber
    out.endLineNumber = expr.endLineNumber
    out.endColumnNumber = expr.endColumnNumber
    out.kind = expr.kind
    out.detailKind = expr.detailKind
    out.surfaceText = expr.surfaceText
    out.callSurfaceKind = expr.callSurfaceKind
    out.callResolved = expr.callResolved
    out.callReason = expr.callReason
    out.callQualifier = expr.callQualifier
    out.callCallee = expr.callCallee
    out.callTarget = expr.callTarget
    out.callTargetSourcePath = expr.callTargetSourcePath
    out.callTargetImportc = expr.callTargetImportc
    out.callPrefixStyle = expr.callPrefixStyle
    out.callArgCount = expr.callArgCount
    out.callArgsText = expr.callArgsText
    return out

fn NormalizedExprEndColumn(columnNumber: int32,
                             surfaceText: str): int32 =
    if Len(surfaceText) <= 0:
        return columnNumber
    return columnNumber + Len(surfaceText) - 1

fn NormalizedExprKindCode(kind: NormalizedExprKind): int32 =
    if kind == NormalizedExprIf:
        return 1
    if kind == NormalizedExprRange:
        return 2
    if kind == NormalizedExprComprehension:
        return 3
    if kind == NormalizedExprStrFormat:
        return 4
    if kind == NormalizedExprResultIntrinsic:
        return 5
    if kind == NormalizedExprCall:
        return 6
    if kind == NormalizedExprTry:
        return 7
    if kind == NormalizedExprDefaultInit:
        return 8
    if kind == NormalizedExprConstructor:
        return 9
    if kind == NormalizedExprReturn:
        return 10
    if kind == NormalizedExprAssign:
        return 11
    if kind == NormalizedExprIfStmt:
        return 12
    if kind == NormalizedExprElifStmt:
        return 13
    if kind == NormalizedExprElseStmt:
        return 14
    if kind == NormalizedExprForStmt:
        return 15
    return 0

fn NormalizedExprLookupTextFirstCode(text: str): int32 =
    if text == "":
        return 0
    return Int32(text[0])

fn NormalizedExprLookupTextLastCode(text: str): int32 =
    if text == "":
        return 0
    return Int32(text[text.len - 1])

fn NormalizedExprLookupInit(minCap: int32): NormalizedExprLookup =
    var lookup: NormalizedExprLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    for i in 0..<cap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(lookup.slots, 0)
    return lookup

fn NormalizedExprLookupDetailKind(kind: NormalizedExprKind,
                                    detailKind: NormalizedExprDetailKind): NormalizedExprDetailKind =
    if kind == NormalizedExprCall:
        return NormalizedExprDetailNone
    return detailKind

fn NormalizedExprLookupKeyExact(sourcePath: str,
                                  lineNumber: int32,
                                  columnNumber: int32,
                                  kind: NormalizedExprKind,
                                  detailKind: NormalizedExprDetailKind,
                                  surfaceText: str): NormalizedExprLookupKey =
    var key: NormalizedExprLookupKey
    key.sourcePathLen = sourcePath.len
    key.sourcePathFirstCode = NormalizedExprLookupTextFirstCode(sourcePath)
    key.sourcePathLastCode = NormalizedExprLookupTextLastCode(sourcePath)
    key.lineNumber = lineNumber
    key.columnNumber = columnNumber
    key.kindCode = NormalizedExprKindCode(kind)
    key.detailCode = NormalizedExprDetailKindCode(NormalizedExprLookupDetailKind(kind, detailKind))
    key.surfaceLen = surfaceText.len
    key.surfaceFirstCode = NormalizedExprLookupTextFirstCode(surfaceText)
    key.surfaceLastCode = NormalizedExprLookupTextLastCode(surfaceText)
    return key

fn NormalizedExprLookupKeyFromExpr(expr: NormalizedExpr): NormalizedExprLookupKey =
    return NormalizedExprLookupKeyExact(expr.sourcePath,
                                          expr.lineNumber,
                                          expr.columnNumber,
                                          expr.kind,
                                          expr.detailKind,
                                          expr.surfaceText)

fn NormalizedExprLookupHash(key: NormalizedExprLookupKey): int64 =
    var h: int64 = Int64(key.sourcePathLen)
    h = h * 131 + Int64(key.sourcePathFirstCode)
    h = h * 131 + Int64(key.sourcePathLastCode)
    h = h * 131 + Int64(key.lineNumber)
    h = h * 131 + Int64(key.columnNumber)
    h = h * 131 + Int64(key.kindCode)
    h = h * 131 + Int64(key.detailCode)
    h = h * 131 + Int64(key.surfaceLen)
    h = h * 131 + Int64(key.surfaceFirstCode)
    h = h * 131 + Int64(key.surfaceLastCode)
    if h < 0:
        h = -h
    return h

fn NormalizedExprLookupKeyMatchesBucket(key: NormalizedExprLookupKey,
                                          bucket: NormalizedExprLookupBucket): bool =
    return bucket.sourcePathLen == key.sourcePathLen &&
           bucket.sourcePathFirstCode == key.sourcePathFirstCode &&
           bucket.sourcePathLastCode == key.sourcePathLastCode &&
           bucket.lineNumber == key.lineNumber &&
           bucket.columnNumber == key.columnNumber &&
           bucket.kindCode == key.kindCode &&
           bucket.detailCode == key.detailCode &&
           bucket.surfaceLen == key.surfaceLen &&
           bucket.surfaceFirstCode == key.surfaceFirstCode &&
           bucket.surfaceLastCode == key.surfaceLastCode

fn NormalizedExprLookupSlotForKey(lookup: NormalizedExprLookup,
                                    key: NormalizedExprLookupKey): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = Int32(NormalizedExprLookupHash(key) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucket = lookup.buckets[bucketIndexPlus1 - 1]
        if NormalizedExprLookupKeyMatchesBucket(key, bucket):
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn NormalizedExprLookupRehash(lookup: var NormalizedExprLookup,
                                newCap: int32) =
    var slots: int32[]
    for i in 0..<newCap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(slots, 0)
    lookup.slots = slots
    for bucketIndex in 0..<lookup.buckets.len:
        if bucketIndex % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let bucket = lookup.buckets[bucketIndex]
        var key: NormalizedExprLookupKey
        key.sourcePathLen = bucket.sourcePathLen
        key.sourcePathFirstCode = bucket.sourcePathFirstCode
        key.sourcePathLastCode = bucket.sourcePathLastCode
        key.lineNumber = bucket.lineNumber
        key.columnNumber = bucket.columnNumber
        key.kindCode = bucket.kindCode
        key.detailCode = bucket.detailCode
        key.surfaceLen = bucket.surfaceLen
        key.surfaceFirstCode = bucket.surfaceFirstCode
        key.surfaceLastCode = bucket.surfaceLastCode
        let slot = NormalizedExprLookupSlotForKey(lookup, key)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1

fn NormalizedExprLookupGrow(lookup: var NormalizedExprLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    NormalizedExprLookupRehash(lookup, nextCap)

fn NormalizedExprLookupEnsureBucket(lookup: var NormalizedExprLookup,
                                      sourcePath: str,
                                      lineNumber: int32,
                                      columnNumber: int32,
                                      kind: NormalizedExprKind,
                                      detailKind: NormalizedExprDetailKind,
                                      surfaceText: str): int32 =
    if lookup.slots.len <= 0:
        lookup = NormalizedExprLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        NormalizedExprLookupGrow(lookup)
    let key = NormalizedExprLookupKeyExact(sourcePath,
                                             lineNumber,
                                             columnNumber,
                                             kind,
                                             detailKind,
                                             surfaceText)
    let slot = NormalizedExprLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: NormalizedExprLookupBucket
    bucket.sourcePathLen = key.sourcePathLen
    bucket.sourcePathFirstCode = key.sourcePathFirstCode
    bucket.sourcePathLastCode = key.sourcePathLastCode
    bucket.lineNumber = key.lineNumber
    bucket.columnNumber = key.columnNumber
    bucket.kindCode = key.kindCode
    bucket.detailCode = key.detailCode
    bucket.surfaceLen = key.surfaceLen
    bucket.surfaceFirstCode = key.surfaceFirstCode
    bucket.surfaceLastCode = key.surfaceLastCode
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn NormalizedExprLookupBucketIndexExact(lookup: NormalizedExprLookup,
                                          sourcePath: str,
                                          lineNumber: int32,
                                          columnNumber: int32,
                                          kind: NormalizedExprKind,
                                          detailKind: NormalizedExprDetailKind,
                                          surfaceText: str): int32 =
    if sourcePath == "":
        return -1
    let key = NormalizedExprLookupKeyExact(sourcePath,
                                             lineNumber,
                                             columnNumber,
                                             kind,
                                             detailKind,
                                             surfaceText)
    let slot = NormalizedExprLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn NormalizedExprMatchesExact(expr: NormalizedExpr,
                                expected: NormalizedExpr): bool =
    if expr.sourcePath != expected.sourcePath:
        return false
    if expr.lineNumber != expected.lineNumber:
        return false
    if expr.columnNumber != expected.columnNumber:
        return false
    if expr.kind != expected.kind:
        return false
    if expr.detailKind != expected.detailKind:
        return false
    if expr.surfaceText != expected.surfaceText:
        return false
    if expr.callSurfaceKind != expected.callSurfaceKind:
        return false
    if expr.callResolved != expected.callResolved:
        return false
    if expr.callReason != expected.callReason:
        return false
    if expr.callQualifier != expected.callQualifier:
        return false
    if expr.callCallee != expected.callCallee:
        return false
    if expr.callTarget != expected.callTarget:
        return false
    if expr.callTargetSourcePath != expected.callTargetSourcePath:
        return false
    if expr.callTargetImportc != expected.callTargetImportc:
        return false
    if expr.callPrefixStyle != expected.callPrefixStyle:
        return false
    if expr.callArgCount != expected.callArgCount:
        return false
    if expr.callArgsText != expected.callArgsText:
        return false
    return true

fn NormalizedExprLayerContainsExpr(layer: NormalizedExprLayer,
                                     expr: NormalizedExpr): bool =
    let bucketIndex = NormalizedExprLookupBucketIndexExact(layer.exprLookup,
                                                             expr.sourcePath,
                                                             expr.lineNumber,
                                                             expr.columnNumber,
                                                             expr.kind,
                                                             expr.detailKind,
                                                             expr.surfaceText)
    if bucketIndex < 0 || bucketIndex >= layer.exprLookup.buckets.len:
        return false
    let bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        let exprIndex = bucket.items[i]
        if exprIndex < 0 || exprIndex >= layer.exprs.len:
            continue
        if NormalizedExprMatchesExact(layer.exprs[exprIndex], expr):
            return true
    return false

fn NormalizedExprLayerRememberExpr(layer: var NormalizedExprLayer,
                                     exprIndex: int32) =
    if exprIndex < 0 || exprIndex >= layer.exprs.len:
        return
    let expr = layer.exprs[exprIndex]
    let bucketIndex = NormalizedExprLookupEnsureBucket(layer.exprLookup,
                                                         expr.sourcePath,
                                                         expr.lineNumber,
                                                         expr.columnNumber,
                                                         expr.kind,
                                                         expr.detailKind,
                                                         expr.surfaceText)
    if bucketIndex < 0:
        return
    var bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        if bucket.items[i] == exprIndex:
            layer.exprLookup.buckets[bucketIndex] = bucket
            return
    add(bucket.items, exprIndex)
    layer.exprLookup.buckets[bucketIndex] = bucket

fn NormalizedExprLayerAppendExisting(layer: var NormalizedExprLayer,
                                       expr: NormalizedExpr) =
    if NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn ParserConcat2(a: str, b: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendText(buf, a)
    if b != "":
        buffer.AppendText(buf, b)
    return rawbytes.BytesToString(buffer.ToBytes(buf))

fn ParserConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendText(buf, a)
    if b != "":
        buffer.AppendText(buf, b)
    if c != "":
        buffer.AppendText(buf, c)
    return rawbytes.BytesToString(buffer.ToBytes(buf))

fn ParserConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendText(buf, a)
    if b != "":
        buffer.AppendText(buf, b)
    if c != "":
        buffer.AppendText(buf, c)
    if d != "":
        buffer.AppendText(buf, d)
    return rawbytes.BytesToString(buffer.ToBytes(buf))

fn ParserOwnedText(text: str): str =
    return NewStringCopy(StrDataPtr(text), StrLenFast(text))

fn ParserLineWithoutTrailingCr(lineRaw: str): str =
    if lineRaw.len <= 0:
        return lineRaw
    if Int32(lineRaw[lineRaw.len - 1]) == 13:
        return ParserTextSliceFast(lineRaw, 0, lineRaw.len - 1)
    return lineRaw

fn ParserOnlyInlineSpaces(text: str,
                            startRaw: int32,
                            stopRaw: int32): bool =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if stop < start:
        return false
    for i in start..<stop:
        if !ParserIsInlineSpace(text[i]):
            return false
    return true

fn ParserFindMultilineStringOpenOnLine(lineRaw: str): int32 =
    var inString = false
    var inChar = false
    var i: int32
    for i in i..<lineRaw.len:
        let ch = lineRaw[i]
        if !inString && !inChar && ch == Char(35):
            return -1
        if !inChar && ch == Char(34) && !ParserQuoteIsEscaped(lineRaw, i):
            if !inString &&
               i + 2 < lineRaw.len &&
               lineRaw[i + 1] == Char(34) &&
               lineRaw[i + 2] == Char(34):
                return i
            inString = !inString
            continue
        if !inString && ch == Char(39) && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            continue
    return -1

fn ParserLineIsMultilineStringClose(lineRaw: str,
                                      indentOut: var str): bool =
    indentOut = ""
    var start: int32
    var stop: int32
    if !ParserTrimmedLineRange(lineRaw, start, stop):
        return false
    if stop - start != 3:
        return false
    if !ParserTextRangeEquals(lineRaw, start, 3, "\"\"\""):
        return false
    indentOut = ParserTextSliceFast(lineRaw, 0, start)
    return true

fn ParserEscapedShortStringLen(text: str): int32 =
    var outLen: int32
    for i in 0..<text.len:
        let code = Int32(text[i])
        if code == 34 || code == 92 || code == 10 || code == 13 || code == 9:
            outLen = outLen + 2
        else:
            outLen = outLen + 1
    return outLen

fn ParserWriteShortStringEscaped(out: var str,
                                   writePos: var int32,
                                   text: str) =
    for i in 0..<text.len:
        let code = Int32(text[i])
        if code == 34:
            ParserWriteByteFast(out, writePos, 92)
            ParserWriteByteFast(out, writePos, 34)
        elif code == 92:
            ParserWriteByteFast(out, writePos, 92)
            ParserWriteByteFast(out, writePos, 92)
        elif code == 10:
            ParserWriteByteFast(out, writePos, 92)
            ParserWriteByteFast(out, writePos, 110)
        elif code == 13:
            ParserWriteByteFast(out, writePos, 92)
            ParserWriteByteFast(out, writePos, 110)
        elif code == 9:
            ParserWriteByteFast(out, writePos, 92)
            ParserWriteByteFast(out, writePos, 116)
        else:
            ParserWriteByteFast(out, writePos, code)

fn ParserMeasureMultilineStringRewrite(lines: str[],
                                         outLen: var int32,
                                         err: var str): bool =
    outLen = 0
    err = ""
    var i: int32
    while i < lines.len:
        let line = ParserLineWithoutTrailingCr(lines[i])
        let openPos = ParserFindMultilineStringOpenOnLine(line)
        if openPos < 0:
            outLen = outLen + line.len
            if i + 1 < lines.len:
                outLen = outLen + 1
            i = i + 1
            continue
        if !ParserOnlyInlineSpaces(line, openPos + 3, line.len):
            err = Fmt"multiline string opener must be followed by a newline at line {i + 1}"
            return false
        var closeIndex: int32 = -1
        var closeIndent = ""
        for candidate in i + 1..<lines.len:
            let closeLine = ParserLineWithoutTrailingCr(lines[candidate])
            if ParserLineIsMultilineStringClose(closeLine, closeIndent):
                closeIndex = candidate
                break
        if closeIndex < 0:
            err = Fmt"unterminated multiline string starting at line {i + 1}"
            return false
        outLen = outLen + openPos + 1
        for bodyIndex in i + 1..<closeIndex:
            let bodyLine = ParserLineWithoutTrailingCr(lines[bodyIndex])
            if ParserHasNonTrimChar(bodyLine):
                if closeIndent != "" && !ParserTextEqualsAt(bodyLine, 0, closeIndent):
                    err = Fmt"multiline string body indentation is shallower than closing delimiter at line {bodyIndex + 1}"
                    return false
                let bodyText = ParserTextSliceFast(bodyLine,
                                                    closeIndent.len,
                                                    bodyLine.len - closeIndent.len)
                outLen = outLen + ParserEscapedShortStringLen(bodyText)
            if bodyIndex + 1 < closeIndex:
                outLen = outLen + 2
        outLen = outLen + 1
        var newlineCount = closeIndex - i
        if closeIndex + 1 < lines.len:
            newlineCount = newlineCount + 1
        outLen = outLen + newlineCount
        i = closeIndex + 1
    return true

fn ParserRewriteMultilineStringSourceText(textRaw: str,
                                            rewrittenOut: var str,
                                            err: var str): bool =
    if !ParserSourceHasMultilineString(textRaw):
        rewrittenOut = textRaw
        err = ""
        return true
    let lines = ParserSplitChar(textRaw, '\n')
    var outLen: int32
    if !ParserMeasureMultilineStringRewrite(lines, outLen, err):
        return false
    if outLen <= 0:
        rewrittenOut = ""
        err = ""
        return true
    var out = NewStringAlloc(outLen)
    let outPtr = RawmemAsVoid(out)
    var writePos: int32
    var i: int32
    while i < lines.len:
        let line = ParserLineWithoutTrailingCr(lines[i])
        let openPos = ParserFindMultilineStringOpenOnLine(line)
        if openPos < 0:
            ParserWriteTextFast(outPtr, writePos, line)
            if i + 1 < lines.len:
                ParserWriteByteFast(out, writePos, 10)
            i = i + 1
            continue
        if !ParserOnlyInlineSpaces(line, openPos + 3, line.len):
            err = Fmt"multiline string opener must be followed by a newline at line {i + 1}"
            return false
        var closeIndex: int32 = -1
        var closeIndent = ""
        for candidate in i + 1..<lines.len:
            let closeLine = ParserLineWithoutTrailingCr(lines[candidate])
            if ParserLineIsMultilineStringClose(closeLine, closeIndent):
                closeIndex = candidate
                break
        if closeIndex < 0:
            err = Fmt"unterminated multiline string starting at line {i + 1}"
            return false
        ParserWriteTextFast(outPtr, writePos, ParserTextSliceFast(line, 0, openPos))
        ParserWriteByteFast(out, writePos, 34)
        for bodyIndex in i + 1..<closeIndex:
            let bodyLine = ParserLineWithoutTrailingCr(lines[bodyIndex])
            var bodyText = ""
            if ParserHasNonTrimChar(bodyLine):
                if closeIndent != "" && !ParserTextEqualsAt(bodyLine, 0, closeIndent):
                    err = Fmt"multiline string body indentation is shallower than closing delimiter at line {bodyIndex + 1}"
                    return false
                bodyText = ParserTextSliceFast(bodyLine,
                                                closeIndent.len,
                                                bodyLine.len - closeIndent.len)
            ParserWriteShortStringEscaped(out, writePos, bodyText)
            if bodyIndex + 1 < closeIndex:
                ParserWriteByteFast(out, writePos, 92)
                ParserWriteByteFast(out, writePos, 110)
        ParserWriteByteFast(out, writePos, 34)
        var newlineCount = closeIndex - i
        if closeIndex + 1 < lines.len:
            newlineCount = newlineCount + 1
        for _ in 0..<newlineCount:
            ParserWriteByteFast(out, writePos, 10)
        i = closeIndex + 1
    if writePos != outLen:
        panic("parser multiline string rewrite length mismatch")
    rewrittenOut = out
    err = ""
    return true

fn ParserSourceHasMultilineString(textRaw: str): bool =
    if textRaw.len < 3:
        return false
    for i in 0..<(textRaw.len - 2):
        if textRaw[i] == Char(34) &&
           textRaw[i + 1] == Char(34) &&
           textRaw[i + 2] == Char(34):
            return true
    return false

fn ParserWriteTextFast(outPtr: ptr,
                         writePos: var int32,
                         text: str) =
    let textLen = StrLenFast(text)
    if textLen <= 0:
        return
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, writePos),
                              RawmemAsVoid(text),
                              textLen)
    writePos = writePos + textLen

fn ParserWriteByteFast(out: var str,
                         writePos: var int32,
                         value: int32) =
    out[writePos] = Char(value)
    writePos = writePos + 1

fn NormalizedExprMakeId(sourcePath: str,
                          lineNumber: int32,
                          columnNumber: int32,
                          kind: NormalizedExprKind,
                          detailKind: NormalizedExprDetailKind): str =
    let lineText: str = Fmt"{lineNumber}"
    let columnText: str = Fmt"{columnNumber}"
    let kindText: str = Fmt"{NormalizedExprKindCode(kind)}"
    let detailCodeText: str = Fmt"{NormalizedExprDetailKindCode(detailKind)}"
    let totalLen = sourcePath.len + lineText.len + columnText.len + kindText.len + detailCodeText.len + 4
    if totalLen <= 0:
        return ""
    let out = NewStringAlloc(totalLen)
    let outPtr = RawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    ParserWriteTextFast(outPtr, writePos, sourcePath)
    ParserWriteByteFast(out, writePos, 35)
    ParserWriteTextFast(outPtr, writePos, lineText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, columnText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, kindText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, detailCodeText)
    return out

fn NormalizedExprMakeCallLikeId(sourcePath: str,
                                  lineNumber: int32,
                                  columnNumber: int32,
                                  kind: NormalizedExprKind,
                                  callSurfaceKind: NormalizedExprSurfaceCallKind,
                                  callResolved: bool,
                                  callReason: NormalizedExprCallReason,
                                  callQualifier: str,
                                  callCallee: str,
                                  callTarget: str,
                                  callTargetSourcePath: str,
                                  callTargetImportc: bool,
                                  callPrefixStyle: bool,
                                  callArgCount: int32,
                                  callArgsText: str): str =
    let callSurfaceKindText = ParserCallSurfaceKindText(callSurfaceKind)
    let callReasonText = ParserCallReasonText(callReason)
    let lineText: str = Fmt"{lineNumber}"
    let columnText: str = Fmt"{columnNumber}"
    let kindText: str = Fmt"{NormalizedExprKindCode(kind)}"
    let resolvedText = if callResolved: "1" else: "0"
    let targetImportcText = if callTargetImportc: "1" else: "0"
    let prefixStyleText = if callPrefixStyle: "1" else: "0"
    let argCountText: str = Fmt"{callArgCount}"
    let normalizedTargetSourcePath = ParserNormalizePath(callTargetSourcePath)
    let totalLen = sourcePath.len +
                   lineText.len +
                   columnText.len +
                   kindText.len +
                   callSurfaceKindText.len +
                   resolvedText.len +
                   callReasonText.len +
                   callQualifier.len +
                   callCallee.len +
                   callTarget.len +
                   normalizedTargetSourcePath.len +
                   targetImportcText.len +
                   prefixStyleText.len +
                   argCountText.len +
                   callArgsText.len +
                   14
    if totalLen <= 0:
        return ""
    let out = NewStringAlloc(totalLen)
    let outPtr = RawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    ParserWriteTextFast(outPtr, writePos, sourcePath)
    ParserWriteByteFast(out, writePos, 35)
    ParserWriteTextFast(outPtr, writePos, lineText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, columnText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, kindText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callSurfaceKindText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, resolvedText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callReasonText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callQualifier)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callCallee)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callTarget)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, normalizedTargetSourcePath)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, targetImportcText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, prefixStyleText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, argCountText)
    ParserWriteByteFast(out, writePos, 58)
    ParserWriteTextFast(outPtr, writePos, callArgsText)
    return out

fn NormalizedExprLayerClone(layer: NormalizedExprLayer): NormalizedExprLayer =
    return layer

fn NormalizedExprLayerAppend(layer: var NormalizedExprLayer,
                               sourcePath: str,
                               lineNumber: int32,
                               columnNumber: int32,
                               kind: NormalizedExprKind,
                               detailKind: NormalizedExprDetailKind,
                               surfaceText: str) =
    NormalizedExprLayerAppendSpan(layer,
                                    sourcePath,
                                    lineNumber,
                                    columnNumber,
                                    kind,
                                    detailKind,
                                    surfaceText,
                                    NormalizedExprEndColumn(columnNumber, surfaceText))

fn NormalizedExprLayerAppendSpan(layer: var NormalizedExprLayer,
                                   sourcePath: str,
                                   lineNumber: int32,
                                   columnNumber: int32,
                                   kind: NormalizedExprKind,
                                   detailKind: NormalizedExprDetailKind,
                                   surfaceText: str,
                                   endColumnNumberRaw: int32) =
    var expr: NormalizedExpr
    expr.exprId = NormalizedExprMakeId(sourcePath, lineNumber, columnNumber, kind, detailKind)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = NormalizedExprEndColumn(columnNumber, surfaceText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = kind
    expr.detailKind = detailKind
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = NormalizedExprSurfaceCallNone
    expr.callResolved = false
    expr.callReason = NormalizedExprCallReasonNone
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = false
    expr.callArgCount = 0
    expr.callArgsText = ""
    if NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn NormalizedExprLayerAppendCall(layer: var NormalizedExprLayer,
                                   sourcePath: str,
                                   lineNumber: int32,
                                   columnNumber: int32,
                                   surfaceText: str,
                                   callSurfaceKind: NormalizedExprSurfaceCallKind,
                                   callResolved: bool,
                                   callReason: NormalizedExprCallReason,
                                   callQualifier: str,
                                   callCallee: str,
                                   callTarget: str,
                                   callTargetSourcePath: str,
                                   callTargetImportc: bool,
                                   callArgsText: str,
                                   callArgCount: int32,
                                   callPrefixStyle: bool,
                                   endColumnNumberRaw: int32) =
    let normalizedTargetSourcePath = ParserNormalizePath(callTargetSourcePath)
    var expr: NormalizedExpr
    expr.exprId = NormalizedExprMakeCallLikeId(sourcePath,
                                                 lineNumber,
                                                 columnNumber,
                                                 NormalizedExprCall,
                                                 callSurfaceKind,
                                                 callResolved,
                                                 callReason,
                                                 callQualifier,
                                                 callCallee,
                                                 callTarget,
                                                 normalizedTargetSourcePath,
                                                 callTargetImportc,
                                                 callPrefixStyle,
                                                 callArgCount,
                                                 callArgsText)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = NormalizedExprEndColumn(columnNumber, surfaceText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = NormalizedExprCall
    expr.detailKind = NormalizedExprDetailNone
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = callSurfaceKind
    expr.callResolved = callResolved
    expr.callReason = callReason
    expr.callQualifier = callQualifier
    expr.callCallee = callCallee
    expr.callTarget = callTarget
    expr.callTargetSourcePath = normalizedTargetSourcePath
    expr.callTargetImportc = callTargetImportc
    expr.callPrefixStyle = callPrefixStyle
    expr.callArgCount = callArgCount
    expr.callArgsText = callArgsText
    if NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn NormalizedExprLayerAppendConstructor(layer: var NormalizedExprLayer,
                                          sourcePath: str,
                                          lineNumber: int32,
                                          columnNumber: int32,
                                          typeText: str,
                                          callArgsText: str,
                                          callArgCount: int32,
                                          callPrefixStyle: bool,
                                          endColumnNumberRaw: int32) =
    var expr: NormalizedExpr
    expr.exprId = NormalizedExprMakeCallLikeId(sourcePath,
                                                 lineNumber,
                                                 columnNumber,
                                                 NormalizedExprConstructor,
                                                 NormalizedExprSurfaceCallNone,
                                                 false,
                                                 NormalizedExprCallReasonNone,
                                                 "",
                                                 "",
                                                 "",
                                                 "",
                                                 false,
                                                 callPrefixStyle,
                                                 callArgCount,
                                                 callArgsText)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = NormalizedExprEndColumn(columnNumber, typeText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = NormalizedExprConstructor
    expr.detailKind = NormalizedExprDetailNone
    expr.surfaceText = typeText
    expr.callSurfaceKind = NormalizedExprSurfaceCallNone
    expr.callResolved = false
    expr.callReason = NormalizedExprCallReasonNone
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = callPrefixStyle
    expr.callArgCount = callArgCount
    expr.callArgsText = callArgsText
    if NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn NormalizedExprLayerAppendAssign(layer: var NormalizedExprLayer,
                                    sourcePath: str,
                                    lineNumber: int32,
                                    columnNumber: int32,
                                    lhsText: str,
                                    rhsText: str,
                                    endColumnNumberRaw: int32) =
    var expr: NormalizedExpr
    expr.exprId = NormalizedExprMakeCallLikeId(sourcePath,
                                                 lineNumber,
                                                 columnNumber,
                                                 NormalizedExprAssign,
                                                 NormalizedExprSurfaceCallNone,
                                                 false,
                                                 NormalizedExprCallReasonNone,
                                                 "",
                                                 "",
                                                 "",
                                                 "",
                                                 false,
                                                 false,
                                                 2,
                                                 rhsText)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = NormalizedExprEndColumn(columnNumber, lhsText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = NormalizedExprAssign
    expr.detailKind = NormalizedExprDetailNone
    expr.surfaceText = lhsText
    expr.callSurfaceKind = NormalizedExprSurfaceCallNone
    expr.callResolved = false
    expr.callReason = NormalizedExprCallReasonNone
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = false
    expr.callArgCount = 2
    expr.callArgsText = rhsText
    if NormalizedExprLayerContainsExpr(layer, expr):
        return
    add(layer.exprs, expr)
    NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn NormalizedExprLayerAdd(total: var NormalizedExprLayer,
                            delta: NormalizedExprLayer) =
    total.sourceCount = total.sourceCount + delta.sourceCount
    total.questionResidualCount = total.questionResidualCount + delta.questionResidualCount
    for i in 0..<delta.exprs.len:
        NormalizedExprLayerAppendExisting(total, NormalizedExprClone(delta.exprs[i]))

fn NormalizedExprLayerExprCount(layer: NormalizedExprLayer): int32 =
    return layer.exprs.len

fn NormalizedExprLayerCountKind(layer: NormalizedExprLayer,
                                  kind: NormalizedExprKind): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind == kind:
            count = count + 1
    return count

fn NormalizedExprLayerKindCountsBuild(layer: NormalizedExprLayer): NormalizedExprLayerKindCounts =
    var counts: NormalizedExprLayerKindCounts
    counts.exprCount = layer.exprs.len
    for i in 0..<layer.exprs.len:
        let kind = layer.exprs[i].kind
        if kind == NormalizedExprIf:
            counts.ifCount = counts.ifCount + 1
        elif kind == NormalizedExprRange:
            counts.rangeCount = counts.rangeCount + 1
        elif kind == NormalizedExprComprehension:
            counts.comprehensionCount = counts.comprehensionCount + 1
        elif kind == NormalizedExprStrFormat:
            counts.strFormatCount = counts.strFormatCount + 1
        elif kind == NormalizedExprResultIntrinsic:
            counts.resultIntrinsicCount = counts.resultIntrinsicCount + 1
        elif kind == NormalizedExprCall:
            counts.callCount = counts.callCount + 1
        elif kind == NormalizedExprTry:
            counts.tryCount = counts.tryCount + 1
        elif kind == NormalizedExprDefaultInit:
            counts.defaultInitCount = counts.defaultInitCount + 1
        elif kind == NormalizedExprConstructor:
            counts.constructorCount = counts.constructorCount + 1
        elif kind == NormalizedExprReturn:
            counts.returnCount = counts.returnCount + 1
        elif kind == NormalizedExprAssign:
            counts.assignCount = counts.assignCount + 1
        elif kind == NormalizedExprIfStmt:
            counts.ifStmtCount = counts.ifStmtCount + 1
        elif kind == NormalizedExprElifStmt:
            counts.elifStmtCount = counts.elifStmtCount + 1
        elif kind == NormalizedExprElseStmt:
            counts.elseStmtCount = counts.elseStmtCount + 1
        elif kind == NormalizedExprForStmt:
            counts.forStmtCount = counts.forStmtCount + 1
    return counts

fn NormalizedExprLayerIfCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprIf)

fn NormalizedExprLayerRangeCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprRange)

fn NormalizedExprLayerComprehensionCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprComprehension)

fn NormalizedExprLayerStrFormatCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprStrFormat)

fn NormalizedExprLayerResultIntrinsicCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprResultIntrinsic)

fn NormalizedExprLayerTryCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprTry)

fn NormalizedExprLayerDefaultInitCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprDefaultInit)

fn NormalizedExprLayerConstructorCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprConstructor)

fn NormalizedExprLayerReturnCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprReturn)

fn NormalizedExprLayerAssignCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprAssign)

fn NormalizedExprLayerIfStmtCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprIfStmt)

fn NormalizedExprLayerElifStmtCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprElifStmt)

fn NormalizedExprLayerElseStmtCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprElseStmt)

fn NormalizedExprLayerForStmtCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprForStmt)

fn NormalizedExprLayerCallCount(layer: NormalizedExprLayer): int32 =
    return NormalizedExprLayerCountKind(layer, NormalizedExprCall)

fn NormalizedExprDefaultInitType(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprDefaultInit:
        return ""
    return expr.surfaceText

fn NormalizedExprConstructorType(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprConstructor:
        return ""
    return expr.surfaceText

fn NormalizedExprCallSurfaceKind(expr: NormalizedExpr): NormalizedExprSurfaceCallKind =
    if expr.kind != NormalizedExprCall:
        return NormalizedExprSurfaceCallNone
    return expr.callSurfaceKind

fn NormalizedExprCallResolved(expr: NormalizedExpr): bool =
    if expr.kind != NormalizedExprCall:
        return false
    return expr.callResolved

fn NormalizedExprCallReasonKind(expr: NormalizedExpr): NormalizedExprCallReason =
    if expr.kind != NormalizedExprCall:
        return NormalizedExprCallReasonNone
    return expr.callReason

fn NormalizedExprCallQualifier(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprCall:
        return ""
    return expr.callQualifier

fn NormalizedExprCallCallee(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprCall:
        return ""
    return expr.callCallee

fn NormalizedExprCallTarget(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprCall:
        return ""
    return expr.callTarget

fn NormalizedExprCallTargetSourcePath(expr: NormalizedExpr): str =
    if expr.kind != NormalizedExprCall:
        return ""
    return expr.callTargetSourcePath

fn NormalizedExprCallTargetImportc(expr: NormalizedExpr): bool =
    if expr.kind != NormalizedExprCall:
        return false
    return expr.callTargetImportc

fn NormalizedExprLayerCallResolvedCount(layer: NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if expr.callResolved:
            count = count + 1
    return count

fn NormalizedExprLayerCallUnresolvedCount(layer: NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if !expr.callResolved:
            count = count + 1
    return count

fn NormalizedExprLayerCallKindCountExact(layer: NormalizedExprLayer,
                                           callKind: NormalizedExprSurfaceCallKind): int32 =
    if callKind == NormalizedExprSurfaceCallNone:
        return 0
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if expr.callSurfaceKind == callKind:
            count = count + 1
    return count

fn NormalizedExprLayerCallReasonCountExact(layer: NormalizedExprLayer,
                                             callReason: NormalizedExprCallReason): int32 =
    if callReason == NormalizedExprCallReasonNone:
        return 0
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if expr.callReason == callReason:
            count = count + 1
    return count

fn NormalizedExprLayerCallTargetImportcCount(layer: NormalizedExprLayer): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if expr.callTargetImportc:
            count = count + 1
    return count

fn NormalizedExprLayerHasExprExact(layer: NormalizedExprLayer,
                                     kind: NormalizedExprKind,
                                     detailKind: NormalizedExprDetailKind,
                                     lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != kind:
            continue
        if expr.detailKind != detailKind:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn NormalizedExprLayerHasCallExpr(layer: NormalizedExprLayer,
                                    callKind: NormalizedExprSurfaceCallKind,
                                    lineNumber: int32): bool =
    if callKind == NormalizedExprSurfaceCallNone:
        return false
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprCall:
            continue
        if expr.callSurfaceKind != callKind:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn NormalizedExprLayerHasConstructorExpr(layer: NormalizedExprLayer,
                                           lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != NormalizedExprConstructor:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn ParserNormalizePath(pathRaw: str): str =
    var path = chengpath.PathTrim(pathRaw)
    while path.len > 1:
        let last = path[path.len - 1]
        if last != '/' && last != '\\':
            break
        path = chengpath.TextSlice(path, 0, path.len - 1)
    return path

fn ParserBaseName(pathRaw: str): str =
    let path = ParserNormalizePath(pathRaw)
    return chengpath.PathBaseName(path)

fn ParserFileStem(pathRaw: str): str =
    let path = ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    var start: int32
    if lastSep >= 0:
        start = lastSep + 1
    var lastDot: int32 = -1
    for i in start..<path.len:
        if path[i] == '.':
            lastDot = i
    if lastDot <= start:
        return chengpath.TextSlice(path, start, path.len - start)
    return chengpath.TextSlice(path, start, lastDot - start)

fn ParserLastPathPiece(pathRaw: str): str =
    let path = ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    if lastSep + 1 >= path.len:
        return ""
    return chengpath.TextSlice(path, lastSep + 1, path.len - lastSep - 1)

fn ParserDirPart(pathRaw: str): str =
    let path = ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return chengpath.TextSlice(path, 0, lastSep)

fn ParserPackageManifestExists(dirRaw: str): bool =
    let dir = ParserNormalizePath(dirRaw)
    if dir == "":
        return false
    let manifestPath = chengpath.PathJoin(dir, "cheng-package.toml")
    return chengpath.PathFileExists(manifestPath)

fn ParserPackageManifestText(packageRootRaw: str): str =
    let packageRoot = ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    let manifestPath = chengpath.PathJoin(packageRoot, "cheng-package.toml")
    if !chengpath.PathFileExists(manifestPath):
        return ""
    return ParserOwnedText(chengpath.ReadTextFile("", manifestPath))

fn ParserManifestValue(manifestTextRaw: str,
                         keyRaw: str): str =
    let manifestText = ParserOwnedText(manifestTextRaw)
    let key = chengpath.PathTrim(keyRaw)
    if manifestText == "" || key == "":
        return ""
    let prefix = strutil.Join([key, " = "], "")
    let lines = ParserSplitChar(manifestText, '\n')
    for i in 0..<lines.len:
        let line = ParserTrimmedLineWithoutComment(lines[i])
        if !ParserStartsWithExact(line, prefix):
            continue
        let valueStart = prefix.len
        if valueStart >= line.len || line[valueStart] != '"':
            continue
        for valueStop in valueStart + 1..<line.len:
            if line[valueStop] == '"':
                return ParserTextSliceFast(line, valueStart + 1, valueStop - valueStart - 1)
    return ""

fn ParserSharedRoot(packageRootRaw: str): str =
    var cursor = ParserNormalizePath(packageRootRaw)
    while cursor != "":
        let manifestText = ParserPackageManifestText(cursor)
        let packageId = ParserManifestValue(manifestText, "package_id")
        if packageId == "pkg://cheng":
            return cursor
        let parent = chengpath.PathParentDir(cursor)
        if parent == "" || parent == cursor:
            break
        cursor = parent
    return ""

fn ParserWorkspaceRoot(packageRootRaw: str): str =
    let packageRoot = ParserNormalizePath(packageRootRaw)
    let sharedRoot = ParserSharedPackageRoot(packageRoot)
    if sharedRoot != "":
        return sharedRoot
    return packageRoot

fn ParserPackageId(packageRootRaw: str): str =
    let packageRoot: str = ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    let manifestText = ParserPackageManifestText(packageRoot)
    let manifestPackageId = ParserManifestValue(manifestText, "package_id")
    if ParserStartsWithExact(manifestPackageId, "pkg://"):
        return ParserTextSliceFast(manifestPackageId, 6, manifestPackageId.len - 6)
    if manifestPackageId != "":
        return manifestPackageId
    var lastSep: int32 = -1
    for i in 0..<packageRoot.len:
        if packageRoot[i] == '/' || packageRoot[i] == '\\':
            lastSep = i
    var name: str = packageRoot
    if lastSep >= 0:
        name = chengpath.TextSlice(packageRoot, lastSep + 1, packageRoot.len - lastSep - 1)
    if name == "cheng-lang":
        return "cheng"
    if name == "":
        return ""
    return ParserConcat2("cheng/", name)

fn ParserExternalPackageRootNew(packageIdRaw: str,
                                  packageRootRaw: str): ParserExternalPackageRoot =
    var out: ParserExternalPackageRoot
    out.packageId = chengpath.PathTrim(packageIdRaw)
    out.packageRoot = ParserNormalizePath(packageRootRaw)
    return out

fn ParserExternalPackageRootsClone(items: ParserExternalPackageRoot[]): ParserExternalPackageRoot[] =
    return items

fn ParserExternalPackageRootByModulePath(modulePathRaw: str,
                                           externalPackageRoots: ParserExternalPackageRoot[],
                                           outPackageRoot: var str,
                                           outPackageId: var str,
                                           outPackagePrefix: var str): bool =
    let modulePath = chengpath.PathTrim(modulePathRaw)
    outPackageRoot = ""
    outPackageId = ""
    outPackagePrefix = ""
    var bestLen: int32
    for i in 0..<externalPackageRoots.len:
        let packageId = chengpath.PathTrim(externalPackageRoots[i].packageId)
        let packageRoot = ParserNormalizePath(externalPackageRoots[i].packageRoot)
        if packageId == "" || packageRoot == "":
            continue
        let packagePrefix = ParserConcat2(packageId, "/")
        if modulePath.len <= packageId.len || !ParserStartsWithExact(modulePath, packagePrefix):
            continue
        if packageId.len <= bestLen:
            continue
        bestLen = packageId.len
        outPackageRoot = packageRoot
        outPackageId = packageId
        outPackagePrefix = packagePrefix
    return bestLen > 0

fn ParserExternalPackageRootBySourcePath(sourcePathRaw: str,
                                           externalPackageRoots: ParserExternalPackageRoot[],
                                           outPackageRoot: var str,
                                           outPackageId: var str): bool =
    let sourcePath = ParserNormalizePath(sourcePathRaw)
    outPackageRoot = ""
    outPackageId = ""
    var bestLen: int32
    for i in 0..<externalPackageRoots.len:
        let packageId = chengpath.PathTrim(externalPackageRoots[i].packageId)
        let packageRoot = ParserNormalizePath(externalPackageRoots[i].packageRoot)
        if packageId == "" || packageRoot == "":
            continue
        let sourcePrefix = ParserConcat2(packageRoot, "/src/")
        if !ParserStartsWithExact(sourcePath, sourcePrefix):
            continue
        if packageRoot.len <= bestLen:
            continue
        bestLen = packageRoot.len
        outPackageRoot = packageRoot
        outPackageId = packageId
    return bestLen > 0

fn ParserSourceExists(path: str): bool =
    if path == "":
        return false
    return chengpath.PathFileSize(path) > Int64(0)

fn ParserExprIsResultIntrinsicName(name: str): bool =
    if name == "Ok" || name == "Err":
        return true
    if name == "Value" || name == "Error":
        return true
    if name == "IsOk" || name == "IsErr":
        return true
    if name == "ErrorInfoOf":
        return true
    return false

fn ParserResultIntrinsicDetailKind(name: str): NormalizedExprDetailKind =
    if name == "Ok":
        return NormalizedExprDetailResultOk
    if name == "Err":
        return NormalizedExprDetailResultErr
    if name == "Value":
        return NormalizedExprDetailResultValue
    if name == "Error":
        return NormalizedExprDetailResultError
    if name == "IsOk":
        return NormalizedExprDetailResultIsOk
    if name == "IsErr":
        return NormalizedExprDetailResultIsErr
    if name == "ErrorInfoOf":
        return NormalizedExprDetailResultErrorInfoOf
    return NormalizedExprDetailNone

fn ParserFmtExprDetailKind(modeRaw: str): NormalizedExprDetailKind =
    if modeRaw == "fmt_literal":
        return NormalizedExprDetailStrFormatLiteral
    if modeRaw == "fmt_call":
        return NormalizedExprDetailStrFormatCall
    return NormalizedExprDetailNone

fn ParserIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn ParserPreviousToken(lineRaw: str,
                         stopExclusive: int32): str =
    if stopExclusive <= 0:
        return ""
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return ""
    let end = cursor - 1
    if end < 0:
        return ""
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return ""
    return ParserTextSliceFast(lineRaw, start, end - start + 1)

fn ParserPreviousTokenIsDeclKeyword(lineRaw: str,
                                      stopExclusive: int32): bool =
    if stopExclusive <= 0:
        return false
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return false
    let end = cursor - 1
    if end < 0:
        return false
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return false
    let tokenLen = end - start + 1
    if tokenLen == 2 && ParserTextEqualsAt(lineRaw, start, "fn"):
        return true
    if tokenLen == 4 &&
       (ParserTextEqualsAt(lineRaw, start, "func") ||
        ParserTextEqualsAt(lineRaw, start, "proc")):
        return true
    if tokenLen == 6 && ParserTextEqualsAt(lineRaw, start, "method"):
        return true
    if tokenLen == 7 && ParserTextEqualsAt(lineRaw, start, "importc"):
        return true
    if tokenLen == 9 && ParserTextEqualsAt(lineRaw, start, "converter"):
        return true
    return false

fn ParserDottedQualifierDepth(lineRaw: str,
                                identStart: int32): int32 =
    if identStart <= 1:
        return 0
    let qualifierStop = identStart - 1
    if lineRaw[qualifierStop] != '.':
        return 0
    var depth: int32
    var segmentStart: int32 = identStart
    var scanning = true
    while scanning && segmentStart > 1:
        let dotPos = segmentStart - 1
        if lineRaw[dotPos] != '.':
            break
        var identPos = dotPos
        while identPos > 0:
            let prevPos = identPos - 1
            if !ParserIsIdentChar(lineRaw[prevPos]):
                break
            identPos = prevPos
        if identPos >= dotPos:
            break
        depth = depth + 1
        segmentStart = identPos
        if segmentStart <= 1:
            break
        if lineRaw[segmentStart - 1] != '.':
            scanning = false
    return depth

fn ParserNextNonSpaceChar(lineRaw: str,
                            start: int32): char =
    for cursor in start..<lineRaw.len:
        if !ParserIsInlineSpace(lineRaw[cursor]):
            return lineRaw[cursor]
    return Char(0)

fn ParserSkipInlineSpaces(lineRaw: str,
                            start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn ParserStrictCallSyntaxEnabled(): bool =
    let raw: str = chengpath.PathTrim(os.GetEnv("CHENG_STRICT_CALL_SYNTAX"))
    return raw == "1" || raw == "true" || raw == "TRUE" || raw == "on" || raw == "yes"

fn ParserStrictAtomStart(ch: char): bool =
    if ParserIsIdentChar(ch):
        return true
    if ch >= '0' && ch <= '9':
        return true
    return ch == '"' || ch == '\'' || ch == '(' || ch == '[' || ch == '{'

fn ParserStrictQualifiedStart(lineRaw: str,
                                identStart: int32): int32 =
    var start = identStart
    var scanning = true
    while scanning && start >= 2:
        let dotPos = start - 1
        if lineRaw[dotPos] != '.':
            break
        var segmentStart = dotPos
        while segmentStart > 0:
            let prevPos = segmentStart - 1
            if !ParserIsIdentChar(lineRaw[prevPos]):
                break
            segmentStart = prevPos
        if segmentStart >= dotPos:
            scanning = false
        else:
            start = segmentStart
    return start

fn ParserStrictKnownCallNameAt(lineRaw: str,
                                 identStart: int32,
                                 identStop: int32,
                                 knownCallLookup: ParserTextLookup): str =
    if identStop <= identStart:
        return ""
    let callName: str = ParserTextSliceFast(lineRaw, identStart, identStop - identStart)
    let callNameKey: ParserTextLookupKey = ParserTextLookupKeyExact(callName)
    if ParserTextLookupContainsKey(knownCallLookup, callName, callNameKey):
        return callName
    let qualifiedStart = ParserStrictQualifiedStart(lineRaw, identStart)
    if qualifiedStart < identStart:
        let qualifiedName: str = ParserTextSliceFast(lineRaw, qualifiedStart, identStop - qualifiedStart)
        let qualifiedNameKey: ParserTextLookupKey = ParserTextLookupKeyExact(qualifiedName)
        if ParserTextLookupContainsKey(knownCallLookup, qualifiedName, qualifiedNameKey):
            return qualifiedName
    return ""

fn ParserRejectSpaceCallIfStrict(lineRaw: str,
                                   lineNumber: int32,
                                   knownCallLookup: ParserTextLookup,
                                   err: var str): bool =
    if !ParserStrictCallSyntaxEnabled():
        return false
    var inString = false
    var inChar = false
    var cursor: int32
    while cursor < lineRaw.len:
        let ch = lineRaw[cursor]
        if !inChar && ch == Char(34) && !ParserQuoteIsEscaped(lineRaw, cursor):
            inString = !inString
            cursor = cursor + 1
            continue
        if !inString && ch == Char(39) && !ParserQuoteIsEscaped(lineRaw, cursor):
            inChar = !inChar
            cursor = cursor + 1
            continue
        if inString || inChar:
            cursor = cursor + 1
            continue
        if ch == Char(35):
            break
        if !ParserIsIdentChar(ch):
            cursor = cursor + 1
            continue
        let identStart = cursor
        while cursor < lineRaw.len && ParserIsIdentChar(lineRaw[cursor]):
            cursor = cursor + 1
        let identStop = cursor
        if identStop >= lineRaw.len:
            continue
        if !ParserIsInlineSpace(lineRaw[identStop]):
            continue
        let callName: str = ParserStrictKnownCallNameAt(lineRaw, identStart, identStop, knownCallLookup)
        if callName == "":
            continue
        let argStart = ParserSkipInlineSpaces(lineRaw, identStop)
        if argStart >= lineRaw.len:
            continue
        let next = lineRaw[argStart]
        if ParserStrictAtomStart(next):
            err = Fmt"Space call syntax is removed in the elegant syntax profile; use f(x) at line {lineNumber} near {callName}"
            return true
    return false

fn ParserParseRangeExpr(textRaw: str,
                          startExprOut: var str,
                          endExprOut: var str,
                          endInclusiveOut: var bool): bool =
    startExprOut = ""
    endExprOut = ""
    endInclusiveOut = false
    let trimmed = chengpath.PathTrim(textRaw)
    if trimmed == "":
        return false
    var opPos = ParserFindTopLevelToken(trimmed, "..<")
    var opLen: int32 = 3
    if opPos < 0:
        opPos = ParserFindTopLevelToken(trimmed, "..")
        opLen = 2
        endInclusiveOut = true
    if opPos <= 0 || opPos + opLen >= trimmed.len:
        return false
    startExprOut = chengpath.PathTrim(ParserTextSliceFast(trimmed, 0, opPos))
    endExprOut = chengpath.PathTrim(ParserTextSliceFast(trimmed,
                                                         opPos + opLen,
                                                         trimmed.len - opPos - opLen))
    return startExprOut != "" && endExprOut != ""

fn ParserParseRangeExprAt(lineRaw: str,
                            opPos: int32,
                            startExprOut: var str,
                            endExprOut: var str,
                            endInclusiveOut: var bool): bool =
    startExprOut = ""
    endExprOut = ""
    endInclusiveOut = false
    if opPos < 0 || opPos + 1 >= lineRaw.len:
        return false
    if lineRaw[opPos] != '.' || lineRaw[opPos + 1] != '.':
        return false
    var opLen: int32 = 2
    var hasExclusiveMarker = false
    if opPos + 2 < lineRaw.len:
        hasExclusiveMarker = lineRaw[opPos + 2] == '<'
    if hasExclusiveMarker:
        opLen = 3
    else:
        endInclusiveOut = true
    var segmentStart: int32
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var i: int32
    while i < opPos:
        let ch = lineRaw[i]
        if !inChar && ch == Char(34) && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            i = i + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            i = i + 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            segmentStart = i + 1
            i = i + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            i = i + 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            segmentStart = i + 1
            i = i + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            i = i + 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           (ch == '=' || ch == ',' || ch == ':'):
            segmentStart = i + 1
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           ParserTextEqualsAt(lineRaw, i, "in"):
            var leftOk = true
            if i > 0:
                leftOk = !ParserIsIdentChar(lineRaw[i - 1])
            var rightOk = true
            if i + 2 < lineRaw.len:
                rightOk = !ParserIsIdentChar(lineRaw[i + 2])
            if leftOk && rightOk:
                segmentStart = i + 2
                i = i + 2
                continue
        i = i + 1
    var segmentStop = lineRaw.len
    inString = false
    inChar = false
    parenDepth = 0
    bracketDepth = 0
    braceDepth = 0
    i = opPos + opLen
    for i in i..<lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                segmentStop = i
                break
            braceDepth = braceDepth - 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           (ch == ',' || ch == ':'):
            segmentStop = i
            break
    let rangeText = chengpath.PathTrim(ParserTextSliceFast(lineRaw, segmentStart, segmentStop - segmentStart))
    return ParserParseRangeExpr(rangeText, startExprOut, endExprOut, endInclusiveOut)

fn ParserParseFmtExprAt(lineRaw: str,
                          fmtPos: int32,
                          modeOut: var str,
                          literalOut: var str,
                          argTextOut: var str,
                          endColumnOut: var int32): bool =
    modeOut = ""
    literalOut = ""
    argTextOut = ""
    endColumnOut = -1
    if fmtPos < 0 || fmtPos + 3 > lineRaw.len:
        return false
    if !ParserTextEqualsAt(lineRaw, fmtPos, "Fmt"):
        return false
    if fmtPos > 0:
        if ParserIsIdentChar(lineRaw[fmtPos - 1]):
            return false
    if fmtPos + 3 < lineRaw.len:
        if ParserIsIdentChar(lineRaw[fmtPos + 3]):
            return false
    if ParserPreviousTokenIsDeclKeyword(lineRaw, fmtPos):
        return false
    let cursor = ParserSkipInlineSpaces(lineRaw, fmtPos + 3)
    if cursor >= lineRaw.len:
        return false
    let nextChar = lineRaw[cursor]
    if nextChar == '"':
        for closePos in cursor + 1..<lineRaw.len:
            if lineRaw[closePos] == '"' && !ParserQuoteIsEscaped(lineRaw, closePos):
                modeOut = "fmt_literal"
                literalOut = ParserTextSliceFast(lineRaw, cursor + 1, closePos - cursor - 1)
                argTextOut = ParserTextSliceFast(lineRaw, cursor, closePos - cursor + 1)
                endColumnOut = closePos + 1
                return true
        return false
    if nextChar == '(':
        let closePos = ParserFindMatchingParen(lineRaw, cursor)
        if closePos <= cursor:
            return false
        modeOut = "fmt_call"
        argTextOut = chengpath.PathTrim(ParserTextSliceFast(lineRaw, cursor + 1, closePos - cursor - 1))
        endColumnOut = closePos + 1
        return true
    return false

fn ParserParseListComprehensionAt(lineRaw: str,
                                    openPos: int32,
                                    itemTextOut: var str,
                                    bindingTextOut: var str,
                                    sourceTextOut: var str,
                                    filterTextOut: var str,
                                    filterColumnOut: var int32,
                                    endColumnOut: var int32): bool =
    itemTextOut = ""
    bindingTextOut = ""
    sourceTextOut = ""
    filterTextOut = ""
    filterColumnOut = -1
    endColumnOut = -1
    if openPos < 0 || openPos >= lineRaw.len || lineRaw[openPos] != '[':
        return false
    let closePos = ParserFindMatchingBracket(lineRaw, openPos)
    if closePos <= openPos:
        return false
    let inner = chengpath.PathTrim(ParserTextSliceFast(lineRaw, openPos + 1, closePos - openPos - 1))
    if inner == "":
        return false
    let forPos = ParserFindTopLevelKeyword(inner, "for")
    if forPos <= 0:
        return false
    let inPos = ParserFindTopLevelKeyword(inner, "in")
    if inPos <= forPos + Len("for"):
        return false
    let ifPos = ParserFindTopLevelKeyword(inner, "if")
    itemTextOut = chengpath.PathTrim(ParserTextSliceFast(inner, 0, forPos))
    bindingTextOut = chengpath.PathTrim(ParserTextSliceFast(inner,
                                                             forPos + Len("for"),
                                                             inPos - forPos - Len("for")))
    let sourceStop = ifPos >= 0 ? ifPos : inner.len
    sourceTextOut = chengpath.PathTrim(ParserTextSliceFast(inner,
                                                            inPos + Len("in"),
                                                            sourceStop - inPos - Len("in")))
    if ifPos >= 0:
        filterTextOut = chengpath.PathTrim(ParserTextSliceFast(inner,
                                                                ifPos + Len("if"),
                                                                inner.len - ifPos - Len("if")))
        filterColumnOut = openPos + ifPos + 2
    endColumnOut = closePos + 1
    return itemTextOut != "" && bindingTextOut != "" && sourceTextOut != ""

fn ParserIsTrimChar(ch: char): bool =
    if ParserIsInlineSpace(ch):
        return true
    let code = Int32(ch)
    return code == 10 || code == 13

fn ParserTrimmedSliceRange(text: str,
                             startRaw: int32,
                             stopRaw: int32): str =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if stop <= start:
        return ""
    while start < stop:
        if !ParserIsTrimChar(text[start]):
            break
        start = start + 1
    while stop > start:
        if !ParserIsTrimChar(text[stop - 1]):
            break
        stop = stop - 1
    if stop <= start:
        return ""
    return ParserTextSliceFast(text, start, stop - start)

fn ParserTrimmedLineWithoutComment(lineRaw: str): str =
    let hashPos = ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return ParserTrimmedSliceRange(lineRaw, 0, lineRaw.len)
    return ParserTrimmedSliceRange(lineRaw, 0, hashPos)

fn ParserTrimmedLineRange(lineRaw: str,
                            startOut: var int32,
                            stopOut: var int32): bool =
    var start: int32
    var stop = lineRaw.len
    while start < stop:
        if !ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn ParserTrimmedCommentRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    var stop = lineRaw.len
    let hashPos = ParserFindText(lineRaw, "#")
    if hashPos >= 0:
        stop = hashPos
    var start: int32
    while start < stop:
        if !ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn ParserImportLineTailRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    startOut = -1
    stopOut = -1
    var lineStart: int32
    var lineStop: int32
    if !ParserTrimmedCommentRange(lineRaw, lineStart, lineStop):
        return false
    let importPrefix = "import "
    if lineStart + importPrefix.len > lineStop:
        return false
    if !ParserTextRangeEquals(lineRaw, lineStart, importPrefix.len, importPrefix):
        return false
    startOut = lineStart + importPrefix.len
    stopOut = lineStop
    return true

fn ParserHasNonTrimChar(lineRaw: str): bool =
    for i in 0..<lineRaw.len:
        if !ParserIsTrimChar(lineRaw[i]):
            return true
    return false

fn ParserStripLineComment(lineRaw: str): str =
    let hashPos = ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return lineRaw
    return ParserTextSliceFast(lineRaw, 0, hashPos)

fn ParserAppendSimpleSurfaceExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        appendIfExprs: bool,
                                        appendQuestionExprs: bool,
                                        appendResultIntrinsics: bool,
                                        layer: var NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if appendQuestionExprs && ch == '?':
            let nextChar = ParserNextNonSpaceChar(lineRaw, i + 1)
            if nextChar == Char(0) || nextChar == ',' || nextChar == ';' ||
               nextChar == ':' || nextChar == ')' || nextChar == ']' || nextChar == '}':
                NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            NormalizedExprTry,
                                            NormalizedExprDetailTryPostfixQuestion,
                                            "?")
            else:
                NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            NormalizedExprIf,
                                            NormalizedExprDetailIfTernary,
                                            "?")
            i = i + 1
            continue
        if !ParserIsIdentChar(ch):
            i = i + 1
            continue
        if i > 0:
            if ParserIsIdentChar(lineRaw[i - 1]):
                i = i + 1
                continue
        var stop = i + 1
        while stop < lineRaw.len:
            if !ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let ident = ParserTextSliceFast(lineRaw, i, stop - i)
        if appendIfExprs && ident == "if":
            NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        NormalizedExprIf,
                                        NormalizedExprDetailIfKeyword,
                                        "if")
        elif appendResultIntrinsics && ParserExprIsResultIntrinsicName(ident):
            NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        NormalizedExprResultIntrinsic,
                                        ParserResultIntrinsicDetailKind(ident),
                                        ident)
        i = stop

fn ParserPreviousNonSpaceChar(lineRaw: str,
                                stopExclusive: int32): char =
    if stopExclusive <= 0:
        return Char(0)
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !ParserIsInlineSpace(lineRaw[prevPos]):
            return lineRaw[prevPos]
        cursor = prevPos
    return Char(0)

fn ParserAppendReturnStmtExprsLine(sourcePath: str,
                                    lineNumber: int32,
                                    lineRaw: str,
                                    layer: var NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == Char(39) && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == Char(35):
            return
        if !ParserIsIdentChar(ch):
            i = i + 1
            continue
        if i > 0:
            if ParserIsIdentChar(lineRaw[i - 1]):
                i = i + 1
                continue
        var stop = i + 1
        while stop < lineRaw.len:
            if !ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let ident = ParserTextSliceFast(lineRaw, i, stop - i)
        if ident == "return":
            let prev = ParserPreviousNonSpaceChar(lineRaw, i)
            if prev == Char(0) || prev == ':' || prev == ';':
                let exprText = ParserTrimmedSliceRange(lineRaw,
                                                       stop,
                                                       lineRaw.len)
                NormalizedExprLayerAppendSpan(layer,
                                               sourcePath,
                                               lineNumber,
                                               i + 1,
                                               NormalizedExprReturn,
                                               NormalizedExprDetailNone,
                                               exprText,
                                               lineRaw.len)
        i = stop

fn ParserLineRangeStartsWithStatementKeyword(lineRaw: str,
                                               start: int32,
                                               stop: int32,
                                               keyword: str): bool =
    let keywordLen = keyword.len
    if keywordLen <= 0:
        return false
    let lineLen = stop - start
    if lineLen < keywordLen:
        return false
    for i in 0..<keywordLen:
        if lineRaw[start + i] != keyword[i]:
            return false
    if lineLen == keywordLen:
        return true
    let nextCh = lineRaw[start + keywordLen]
    if ParserIsInlineSpace(nextCh):
        return true
    return nextCh == ':'

fn ParserLineStartsWithStatementKeyword(lineRaw: str,
                                          keyword: str): bool =
    var start: int32
    var stop: int32
    if !ParserTrimmedCommentRange(lineRaw, start, stop):
        return false
    return ParserLineRangeStartsWithStatementKeyword(lineRaw,
                                                     start,
                                                     stop,
                                                     keyword)

fn ParserLineRangeEqualsElseControlKeyword(lineRaw: str,
                                             start: int32,
                                             stop: int32): bool =
    let keyword = "else"
    let keywordLen = keyword.len
    let lineLen = stop - start
    if lineLen != keywordLen && lineLen != keywordLen + 1:
        return false
    for i in 0..<keywordLen:
        if lineRaw[start + i] != keyword[i]:
            return false
    if lineLen == keywordLen:
        return true
    return lineRaw[start + keywordLen] == ':'

fn ParserLineTokenEquals(lineRaw: str,
                          start: int32,
                          stop: int32,
                          keyword: str): bool =
    let tokenLen = stop - start
    if tokenLen != keyword.len:
        return false
    for i in 0..<tokenLen:
        if lineRaw[start + i] != keyword[i]:
            return false
    return true

fn ParserLineIsAssignmentStmtCandidate(lineRaw: str): bool =
    var start: int32
    var stop: int32
    if !ParserTrimmedLineRange(lineRaw, start, stop):
        return false
    var tokenStop = start
    while tokenStop < stop:
        if !ParserIsIdentChar(lineRaw[tokenStop]):
            break
        tokenStop = tokenStop + 1
    if tokenStop <= start:
        return ParserFindTopLevelAssignmentEq(lineRaw) >= 0
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "let"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "var"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "const"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "fn"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "type"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "import"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "if"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "elif"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "else"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "for"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "while"):
        return false
    if ParserLineTokenEquals(lineRaw, start, tokenStop, "return"):
        return false
    return ParserFindTopLevelAssignmentEq(lineRaw) >= 0

fn ParserFindTopLevelTokenRange(textRaw: str,
                                  startRaw: int32,
                                  stopRaw: int32,
                                  target: str): int32 =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > textRaw.len:
        stop = textRaw.len
    if target == "" || stop <= start || target.len > stop - start:
        return -1
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var i = start
    while i < stop:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == Char(39) && !ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            i = i + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            i = i + 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            i = i + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            i = i + 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            i = i + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            i = i + 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           i + target.len <= stop &&
           ParserTextEqualsAt(textRaw, i, target):
            return i
        i = i + 1
    return -1

fn ParserAppendAssignStmtExprsLine(sourcePath: str,
                                    lineNumber: int32,
                                    lineRaw: str,
                                    layer: var NormalizedExprLayer) =
    if !ParserLineIsAssignmentStmtCandidate(lineRaw):
        return
    let eqPos = ParserFindTopLevelAssignmentEq(lineRaw)
    if eqPos < 0:
        return
    let lhsText = ParserTrimmedSliceRange(lineRaw, 0, eqPos)
    let rhsText = ParserTrimmedSliceRange(lineRaw,
                                          eqPos + 1,
                                          lineRaw.len)
    if lhsText == "" || rhsText == "":
        return
    NormalizedExprLayerAppendAssign(layer,
                                    sourcePath,
                                    lineNumber,
                                    eqPos + 1,
                                    lhsText,
                                    rhsText,
                                    lineRaw.len)

fn ParserAppendControlStmtExprsLine(sourcePath: str,
                                     lineNumber: int32,
                                     lineRaw: str,
                                     layer: var NormalizedExprLayer) =
    var lineStart: int32
    var lineStop: int32
    if !ParserTrimmedCommentRange(lineRaw, lineStart, lineStop):
        return
    var kind = NormalizedExprIfStmt
    var keyword = ""
    var payloadStart: int32
    if ParserLineRangeStartsWithStatementKeyword(lineRaw, lineStart, lineStop, "if"):
        kind = NormalizedExprIfStmt
        keyword = "if"
        payloadStart = lineStart + 3
    elif ParserLineRangeStartsWithStatementKeyword(lineRaw, lineStart, lineStop, "elif"):
        kind = NormalizedExprElifStmt
        keyword = "elif"
        payloadStart = lineStart + 5
    elif ParserLineRangeEqualsElseControlKeyword(lineRaw, lineStart, lineStop):
        kind = NormalizedExprElseStmt
        keyword = "else"
        payloadStart = lineStart + 4
    elif ParserLineRangeStartsWithStatementKeyword(lineRaw, lineStart, lineStop, "for"):
        kind = NormalizedExprForStmt
        keyword = "for"
        payloadStart = lineStart + 4
    else:
        return
    let keywordPos = lineStart
    var payload = ""
    if kind != NormalizedExprElseStmt:
        let colonPos = ParserFindTopLevelTokenRange(lineRaw,
                                                    lineStart,
                                                    lineStop,
                                                    ":")
        if colonPos <= payloadStart:
            return
        payload = ParserTrimmedSliceRange(lineRaw,
                                          payloadStart,
                                          colonPos)
        if payload == "":
            return
    NormalizedExprLayerAppendSpan(layer,
                                   sourcePath,
                                   lineNumber,
                                   keywordPos + 1,
                                   kind,
                                   NormalizedExprDetailNone,
                                   payload,
                                   lineRaw.len)

fn ParserAppendFmtExprsLine(sourcePath: str,
                              lineNumber: int32,
                              lineRaw: str,
                              layer: var NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        var mode = ""
        var literalText = ""
        var argText = ""
        var endColumn = -1
        if !ParserParseFmtExprAt(lineRaw, i, mode, literalText, argText, endColumn):
            continue
        NormalizedExprLayerAppendSpan(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        NormalizedExprStrFormat,
                                        ParserFmtExprDetailKind(mode),
                                        "Fmt",
                                        endColumn)
    return

fn ParserAppendStringifyCallExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        layer: var NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == Char(39) && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch == Char(35):
            return
        if ch != '$' || i + 1 >= lineRaw.len:
            i = i + 1
            continue
        if lineRaw[i + 1] == '(':
            var callArgsText = ""
            var callArgCount: int32
            var endColumnNumber: int32 = -1
            if !ParserCallSurfaceFromOpenParen(lineRaw,
                                                 i + 1,
                                                 callArgsText,
                                                 callArgCount,
                                                 endColumnNumber):
                i = i + 1
                continue
            NormalizedExprLayerAppendCall(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            "$",
                                            NormalizedExprSurfaceCallNone,
                                            true,
                                            NormalizedExprCallReasonNone,
                                            "",
                                            "$",
                                            "$",
                                            "",
                                            false,
                                            callArgsText,
                                            callArgCount,
                                            false,
                                            endColumnNumber)
            i = endColumnNumber
            continue
        if !ParserIsIdentChar(lineRaw[i + 1]):
            i = i + 1
            continue
        var stop = i + 1
        while stop < lineRaw.len:
            let operandCh = lineRaw[stop]
            if ParserIsIdentChar(operandCh) || operandCh == '.':
                stop = stop + 1
                continue
            break
        let callArgsText = ParserTextSliceFast(lineRaw, i + 1, stop - i - 1)
        if callArgsText == "":
            i = i + 1
            continue
        NormalizedExprLayerAppendCall(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        "$",
                                        NormalizedExprSurfaceCallNone,
                                        true,
                                        NormalizedExprCallReasonNone,
                                        "",
                                        "$",
                                        "$",
                                        "",
                                        false,
                                        callArgsText,
                                        1,
                                        true,
                                        stop)
        i = stop
    return

fn ParserAppendRangeExprsLine(sourcePath: str,
                                lineNumber: int32,
                                lineRaw: str,
                                layer: var NormalizedExprLayer) =
    var i: int32
    var inString = false
    var inChar = false
    while i + 1 < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if ch != '.' || lineRaw[i + 1] != '.':
            i = i + 1
            continue
        var detailKind = NormalizedExprDetailRangeInclusive
        var surfaceText = ".."
        var step: int32 = 2
        var hasExclusiveMarker = false
        if i + 2 < lineRaw.len:
            hasExclusiveMarker = lineRaw[i + 2] == '<'
        if hasExclusiveMarker:
            detailKind = NormalizedExprDetailRangeExclusive
            surfaceText = "..<"
            step = 3
        NormalizedExprLayerAppend(layer,
                                    sourcePath,
                                    lineNumber,
                                    i + 1,
                                    NormalizedExprRange,
                                    detailKind,
                                    surfaceText)
        i = i + step
        continue

fn ParserCallExprUsesDedicatedNormalization(callNameRaw: str): bool =
    let callName = callNameRaw
    if ParserTextEqualsExact(callName, "Fmt"):
        return true
    if ParserTextEqualsExact(callName, "Ok"):
        return true
    if ParserTextEqualsExact(callName, "Err"):
        return true
    if ParserTextEqualsExact(callName, "Value"):
        return true
    if ParserTextEqualsExact(callName, "Error"):
        return true
    if ParserTextEqualsExact(callName, "IsOk"):
        return true
    if ParserTextEqualsExact(callName, "IsErr"):
        return true
    if ParserTextEqualsExact(callName, "ErrorInfoOf"):
        return true
    return false

fn ParserTypeExprIsScalarDefaultForbidden(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    return typeText == "bool" ||
           typeText == "int8" ||
           typeText == "uint8" ||
           typeText == "int16" ||
           typeText == "uint16" ||
           typeText == "int32" ||
           typeText == "int" ||
           typeText == "uint32" ||
           typeText == "int64" ||
           typeText == "uint64" ||
           typeText == "float" ||
           typeText == "float32" ||
           typeText == "float64" ||
           typeText == "char" ||
           typeText == "str" ||
           typeText == "cstring" ||
           typeText == "ptr" ||
           ParserStartsWithExact(typeText, "ptr[") ||
           ParserStartsWithExact(typeText, "Pointer[")

fn ParserTypeExprIsTuple(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    if !ParserStartsWithExact(typeText, "tuple["):
        return false
    if typeText.len <= Len("tuple["):
        return false
    return typeText[typeText.len - 1] == ']'

fn ParserTypeExprIsSeq(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    return typeText.len >= 2 &&
           chengpath.TextSlice(typeText, typeText.len - 2, 2) == "[]"

fn ParserTypeExprIsFixedArray(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    if typeText.len < 4:
        return false
    if ParserTypeExprIsSeq(typeText):
        return false
    if typeText[typeText.len - 1] != ']':
        return false
    var depth: int32
    var openPos: int32 = -1
    var closePos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '[':
            if depth == 0:
                openPos = i
            depth = depth + 1
            continue
        if typeText[i] == ']':
            depth = depth - 1
            if depth < 0:
                return false
            if depth == 0:
                closePos = i
    if depth != 0 || openPos <= 0 || closePos != typeText.len - 1:
        return false
    let sizeText = chengpath.PathTrim(chengpath.TextSlice(typeText, openPos + 1, closePos - openPos - 1))
    if sizeText == "":
        return false
    for i in 0..<sizeText.len:
        let ch = sizeText[i]
        if ParserIsInlineSpace(ch):
            continue
        if ch < '0' || ch > '9':
            return false
    return true

fn ParserTypeExprDot(typeRaw: str): int32 =
    let typeText = chengpath.PathTrim(typeRaw)
    var dotPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '.':
            dotPos = i
    return dotPos

fn ParserTypeExprQualifier(typeRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    let dotPos = ParserTypeExprDot(typeText)
    if dotPos <= 0:
        return ""
    return chengpath.PathTrim(chengpath.TextSlice(typeText, 0, dotPos))

fn ParserTypeExprLeaf(typeRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    let dotPos = ParserTypeExprDot(typeText)
    if dotPos < 0:
        return ParserIdentPrefix(typeText)
    if dotPos + 1 >= typeText.len:
        return ""
    return ParserIdentPrefix(chengpath.TextSlice(typeText, dotPos + 1, typeText.len - dotPos - 1))

fn ParserTypeDeclNameFromTrimmedLine(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    if line == "":
        return ""
    let eqPos = ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return ""
    let headRaw = chengpath.PathTrim(chengpath.TextSlice(line, 0, eqPos))
    let genericPos = ParserFindTopLevelToken(headRaw, "[")
    var head = headRaw
    if genericPos > 0:
        head = chengpath.PathTrim(chengpath.TextSlice(headRaw, 0, genericPos))
    return ParserIdentPrefix(ParserFirstToken(head))

fn ParserTypeDeclIsRefObjectFromTrimmedLine(lineRaw: str): bool =
    let line = chengpath.PathTrim(lineRaw)
    let eqPos = ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return false
    let tail = chengpath.PathTrim(chengpath.TextSlice(line, eqPos + 1, line.len - eqPos - 1))
    return ParserStartsWithExact(tail, "ref object")

fn ParserAddUniqueTypeDecl(out: var NormalizedTypeDecl[],
                             nameRaw: str,
                             refObject: bool) =
    let name = ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    for i in 0..<out.len:
        if out[i].name != name:
            continue
        if refObject:
            out[i].refObject = true
        return
    var decl: NormalizedTypeDecl
    decl.name = name
    decl.refObject = refObject
    add(out, decl)

fn ParserReadNormalizedTypeDeclsLines(lines: str[],
                                        decls: var NormalizedTypeDecl[]) =
    decls = []
    var inTypeBlock = false
    for i in 0..<lines.len:
        let rawLine = lines[i]
        let trimmed = chengpath.PathTrim(ParserStripLineComment(rawLine))
        if !ParserHasLeadingIndent(rawLine):
            if trimmed == "":
                continue
            inTypeBlock = trimmed == "type"
            continue
        if !inTypeBlock:
            continue
        let declName = ParserTypeDeclNameFromTrimmedLine(trimmed)
        if declName == "":
            continue
        ParserAddUniqueTypeDecl(decls, declName, ParserTypeDeclIsRefObjectFromTrimmedLine(trimmed))

fn ParserProfileHasDeclaredType(profile: NormalizedExprCallProfile,
                                  nameRaw: str): bool =
    let name = ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return false
    for i in 0..<profile.typeDecls.len:
        if profile.typeDecls[i].name == name:
            return true
    return false

fn ParserProfileHasRefObjectType(profile: NormalizedExprCallProfile,
                                   nameRaw: str): bool =
    let name = ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return false
    for i in 0..<profile.typeDecls.len:
        if profile.typeDecls[i].name == name:
            return profile.typeDecls[i].refObject
    return false

fn ParserProfileImportTargetIndexForQualifier(profile: NormalizedExprCallProfile,
                                                qualifierRaw: str): int32 =
    let qualifier = ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    if qualifier == "":
        return -1
    var targetIndex = -1
    for i in 0..<profile.importEdges.len:
        let edge = profile.importEdges[i]
        if !edge.resolved || edge.targetProfileIndex < 0 || edge.qualifier != qualifier:
            continue
        if targetIndex < 0:
            targetIndex = edge.targetProfileIndex
            continue
        if targetIndex != edge.targetProfileIndex:
            return -1
    return targetIndex

fn ParserResolveQualifiedTypeProfileIndex(currentProfile: NormalizedExprCallProfile,
                                            profiles: NormalizedExprCallProfile[],
                                            qualifierChainRaw: str): int32 =
    let qualifierChain = chengpath.PathTrim(qualifierChainRaw)
    if qualifierChain == "":
        return -1
    let parts = ParserSplitChar(qualifierChain, '.')
    var profile = currentProfile
    var targetIndex = -1
    for i in 0..<parts.len:
        targetIndex = ParserProfileImportTargetIndexForQualifier(profile, parts[i])
        if targetIndex < 0 || targetIndex >= profiles.len:
            return -1
        profile = profiles[targetIndex]
    return targetIndex

fn ParserResolveUnqualifiedTypeProfileIndex(currentProfile: NormalizedExprCallProfile,
                                              profiles: NormalizedExprCallProfile[],
                                              typeNameRaw: str): int32 =
    let typeName = ParserIdentPrefix(chengpath.PathTrim(typeNameRaw))
    if typeName == "":
        return -1
    if ParserProfileHasDeclaredType(currentProfile, typeName):
        return -2
    var targetIndex = -1
    for i in 0..<currentProfile.importEdges.len:
        let edge = currentProfile.importEdges[i]
        if !edge.resolved || edge.targetProfileIndex < 0 || edge.targetProfileIndex >= profiles.len:
            continue
        if !ParserProfileHasDeclaredType(profiles[edge.targetProfileIndex], typeName):
            continue
        if targetIndex < 0:
            targetIndex = edge.targetProfileIndex
            continue
        if targetIndex != edge.targetProfileIndex:
            return -1
    return targetIndex

fn ParserDefaultInitRemovedDefaultError(exprRaw: str): str =
    let expr = chengpath.PathTrim(exprRaw)
    return strutil.Join(["[cheng_seed] default[T] removed expr=",
                         expr,
                         "; use T() for object/tuple, typed implicit init or literals for T[]/T[N], and new(T) for ref object"], "")

fn ParserDefaultInitScalarError(typeRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    return strutil.Join(["[cheng_seed] simple type T() unsupported expr=",
                         typeText,
                         "(); simple types use typed implicit init"], "")

fn ParserDefaultInitSeqOrFixedError(typeRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    return strutil.Join(["[cheng_seed] seq/fixed-array T() unsupported expr=",
                         typeText,
                         "(); use typed implicit init or literals"], "")

fn ParserDefaultInitRefObjectError(typeRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    return strutil.Join(["[cheng_seed] ref object T() unsupported expr=",
                         typeText,
                         "(); use new(T)"], "")

fn ParserRedundantExplicitDefaultError(typeRaw: str,
                                         exprRaw: str): str =
    let typeText = chengpath.PathTrim(typeRaw)
    let exprText = chengpath.PathTrim(exprRaw)
    return strutil.Join(["[cheng_seed] redundant explicit default init; omit initializer type=",
                         typeText,
                         " expr=",
                         exprText], "")

fn ParserCompactText(textRaw: str): str =
    var out = ""
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if ParserIsInlineSpace(ch):
            continue
        out = strutil.Join([out, chengpath.TextSlice(textRaw, i, 1)], "")
    return out

fn ParserFindTopLevelAssignmentEq(textRaw: str): int32 =
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           ch == '=':
            var prev: char
            var next: char
            if i > 0:
                prev = textRaw[i - 1]
            if i + 1 < textRaw.len:
                next = textRaw[i + 1]
            if prev == '=' || prev == '!' || prev == '<' || prev == '>' || next == '=':
                continue
            return i
    return -1

fn ParserLineIndent(lineRaw: str): int32 =
    var indent: int32
    while indent < lineRaw.len:
        let ch = lineRaw[indent]
        if ch != ' ' && ch != '\t':
            break
        indent = indent + 1
    return indent

fn ParserTypeExprIsIntDefaultType(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    return typeText == "int8" ||
           typeText == "uint8" ||
           typeText == "int16" ||
           typeText == "uint16" ||
           typeText == "int32" ||
           typeText == "int" ||
           typeText == "uint32" ||
           typeText == "uint" ||
           typeText == "int64" ||
           typeText == "uint64"

fn ParserTypeExprIsFloatDefaultType(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    return typeText == "float" || typeText == "float32" || typeText == "float64"

fn ParserTypeExprIsStringDefaultType(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    return typeText == "str" || typeText == "cstring"

fn ParserTypeExprLooksLikeLowerGenericFunction(typeRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    if typeText == "" ||
       typeText == "Bytes" ||
       ParserTypeExprIsTuple(typeText) ||
       ParserTypeExprIsSeq(typeText) ||
       ParserTypeExprIsFixedArray(typeText) ||
       ParserStartsWithExact(typeText, "Result["):
        return false
    var bracketPos: int32 = -1
    for i in 0..<typeText.len:
        if typeText[i] == '[':
            bracketPos = i
            break
    if bracketPos <= 0 || bracketPos + 1 >= typeText.len:
        return false
    let base = ParserTypeExprLeaf(typeText)
    if base == "":
        return false
    return base[0] >= 'a' && base[0] <= 'z'

fn ParserDefaultInitTypeStatus(currentProfile: NormalizedExprCallProfile,
                                 profiles: NormalizedExprCallProfile[],
                                 typeRaw: str,
                                 err: var str): int32 =
    err = ""
    let typeText = chengpath.PathTrim(typeRaw)
    if typeText == "":
        return 0
    if ParserTypeExprIsScalarDefaultForbidden(typeText):
        err = ParserDefaultInitScalarError(typeText)
        return -1
    if ParserTypeExprIsSeq(typeText) || ParserTypeExprIsFixedArray(typeText):
        err = ParserDefaultInitSeqOrFixedError(typeText)
        return -1
    if typeText == "Bytes" || ParserTypeExprIsTuple(typeText):
        return 1
    let qualifier = ParserTypeExprQualifier(typeText)
    let leaf = ParserTypeExprLeaf(typeText)
    if leaf == "":
        return 0
    if qualifier != "":
        let targetIndex = ParserResolveQualifiedTypeProfileIndex(currentProfile, profiles, qualifier)
        if targetIndex < 0:
            return 0
        if !ParserProfileHasDeclaredType(profiles[targetIndex], leaf):
            return 0
        if ParserProfileHasRefObjectType(profiles[targetIndex], leaf):
            err = ParserDefaultInitRefObjectError(typeText)
            return -1
        return 1
    let localType = ParserResolveUnqualifiedTypeProfileIndex(currentProfile, profiles, leaf)
    if localType == -2:
        if ParserProfileHasRefObjectType(currentProfile, leaf):
            err = ParserDefaultInitRefObjectError(typeText)
            return -1
        return 1
    if localType < 0:
        return 0
    if ParserProfileHasRefObjectType(profiles[localType], leaf):
        err = ParserDefaultInitRefObjectError(typeText)
        return -1
    return 1

fn ParserConstructorTypeStatus(currentProfile: NormalizedExprCallProfile,
                                 profiles: NormalizedExprCallProfile[],
                                 typeRaw: str): int32 =
    let typeText = chengpath.PathTrim(typeRaw)
    if typeText == "":
        return 0
    if ParserTypeExprIsScalarDefaultForbidden(typeText):
        return 0
    if typeText == "Bytes" || ParserTypeExprIsTuple(typeText) ||
       ParserTypeExprIsSeq(typeText) || ParserTypeExprIsFixedArray(typeText):
        return 1
    let qualifier = ParserTypeExprQualifier(typeText)
    let leaf = ParserTypeExprLeaf(typeText)
    if leaf == "":
        return 0
    if qualifier != "":
        let targetIndex = ParserResolveQualifiedTypeProfileIndex(currentProfile, profiles, qualifier)
        if targetIndex < 0:
            return 0
        if !ParserProfileHasDeclaredType(profiles[targetIndex], leaf):
            return 0
        if ParserProfileHasRefObjectType(profiles[targetIndex], leaf):
            return 0
        return 1
    let localType = ParserResolveUnqualifiedTypeProfileIndex(currentProfile, profiles, leaf)
    if localType == -2:
        if ParserProfileHasRefObjectType(currentProfile, leaf):
            return 0
        return 1
    if localType < 0:
        return 0
    if ParserProfileHasRefObjectType(profiles[localType], leaf):
        return 0
    return 1

fn ParserExprMatchesImplicitDefault(currentProfile: NormalizedExprCallProfile,
                                      profiles: NormalizedExprCallProfile[],
                                      typeRaw: str,
                                      exprRaw: str): bool =
    let typeText = chengpath.PathTrim(typeRaw)
    let exprText = chengpath.PathTrim(exprRaw)
    if typeText == "" || exprText == "":
        return false
    if typeText == "bool" && exprText == "false":
        return true
    if ParserTypeExprIsIntDefaultType(typeText) && exprText == "0":
        return true
    if ParserTypeExprIsFloatDefaultType(typeText) && (exprText == "0" || exprText == "0.0"):
        return true
    if ParserTypeExprIsStringDefaultType(typeText) && exprText == "\"\"":
        return true
    if typeText == "char" && exprText == "'\\0'":
        return true
    if (ParserTypeExprIsSeq(typeText) || ParserTypeExprIsFixedArray(typeText)) && exprText == "[]":
        return true
    let compactType = ParserCompactText(typeText)
    let compactExpr = ParserCompactText(exprText)
    if compactType != "" && compactExpr == strutil.Join([compactType, "()"], ""):
        var typeErr = ""
        return ParserDefaultInitTypeStatus(currentProfile, profiles, typeText, typeErr) > 0
    return false

fn ParserParseTypedInitializerLine(lineRaw: str,
                                     prefixRaw: str,
                                     typeOut: var str,
                                     exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let line = chengpath.PathTrim(lineRaw)
    if prefixRaw != "" && !ParserStartsWithExact(line, prefixRaw):
        return false
    var tail = line
    if prefixRaw != "":
        tail = chengpath.TextSlice(line, prefixRaw.len, line.len - prefixRaw.len)
    let eqPos = ParserFindTopLevelAssignmentEq(tail)
    if eqPos <= 0:
        return false
    let left = chengpath.PathTrim(chengpath.TextSlice(tail, 0, eqPos))
    let colonPos = ParserFindTopLevelToken(left, ":")
    if colonPos <= 0:
        return false
    typeOut = chengpath.PathTrim(chengpath.TextSlice(left, colonPos + 1, left.len - colonPos - 1))
    exprOut = chengpath.PathTrim(chengpath.TextSlice(tail, eqPos + 1, tail.len - eqPos - 1))
    return typeOut != "" && exprOut != ""

fn ParserParseTupleElemDefaultText(elemRaw: str,
                                     typeOut: var str,
                                     exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let elem = chengpath.PathTrim(elemRaw)
    if elem == "":
        return false
    let eqPos = ParserFindTopLevelAssignmentEq(elem)
    if eqPos <= 0:
        return false
    let head = chengpath.PathTrim(chengpath.TextSlice(elem, 0, eqPos))
    if head == "":
        return false
    let colonPos = ParserFindTopLevelToken(head, ":")
    if colonPos > 0:
        typeOut = chengpath.PathTrim(chengpath.TextSlice(head, colonPos + 1, head.len - colonPos - 1))
    else:
        typeOut = head
    exprOut = chengpath.PathTrim(chengpath.TextSlice(elem, eqPos + 1, elem.len - eqPos - 1))
    return typeOut != "" && exprOut != ""

fn ParserFindTupleTypeRedundantDefaultLine(lineRaw: str,
                                             currentProfile: NormalizedExprCallProfile,
                                             profiles: NormalizedExprCallProfile[],
                                             typeOut: var str,
                                             exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    let line = chengpath.PathTrim(ParserStripLineComment(lineRaw))
    if line == "":
        return false
    let eqPos = ParserFindTopLevelToken(line, "=")
    if eqPos <= 0:
        return false
    let tupleType = chengpath.PathTrim(chengpath.TextSlice(line, eqPos + 1, line.len - eqPos - 1))
    if !ParserTypeExprIsTuple(tupleType):
        return false
    let body = chengpath.TextSlice(tupleType, Len("tuple["), tupleType.len - Len("tuple[") - 1)
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var itemStart: int32
    var i: int32
    while i <= body.len:
        let atEnd = i >= body.len
        if !atEnd:
            let ch = body[i]
            if !inChar && ch == '"' && !ParserQuoteIsEscaped(body, i):
                inString = !inString
                i = i + 1
                continue
            if !inString && ch == '\'' && !ParserQuoteIsEscaped(body, i):
                inChar = !inChar
                i = i + 1
                continue
            if inString || inChar:
                i = i + 1
                continue
            if ch == '(':
                parenDepth = parenDepth + 1
                i = i + 1
                continue
            if ch == ')':
                parenDepth = parenDepth - 1
                i = i + 1
                continue
            if ch == '[':
                bracketDepth = bracketDepth + 1
                i = i + 1
                continue
            if ch == ']':
                bracketDepth = bracketDepth - 1
                i = i + 1
                continue
            if ch == '{':
                braceDepth = braceDepth + 1
                i = i + 1
                continue
            if ch == '}':
                braceDepth = braceDepth - 1
                i = i + 1
                continue
        var splitHere = atEnd
        if !splitHere:
            splitHere = body[i] == ',' &&
                        !inString &&
                        !inChar &&
                        parenDepth == 0 &&
                        bracketDepth == 0 &&
                        braceDepth == 0
        if splitHere:
            let item = chengpath.PathTrim(chengpath.TextSlice(body, itemStart, i - itemStart))
            var elemType = ""
            var elemExpr = ""
            if ParserParseTupleElemDefaultText(item, elemType, elemExpr) &&
               ParserExprMatchesImplicitDefault(currentProfile, profiles, elemType, elemExpr):
                typeOut = elemType
                exprOut = elemExpr
                return true
            itemStart = i + 1
        i = i + 1
    return false

fn ParserFindRedundantExplicitDefaultLine(lineRaw: str,
                                            inTypeBlock: bool,
                                            currentProfile: NormalizedExprCallProfile,
                                            profiles: NormalizedExprCallProfile[],
                                            typeOut: var str,
                                            exprOut: var str): bool =
    typeOut = ""
    exprOut = ""
    if ParserParseTypedInitializerLine(lineRaw, "let ", typeOut, exprOut) ||
       ParserParseTypedInitializerLine(lineRaw, "var ", typeOut, exprOut):
        return ParserExprMatchesImplicitDefault(currentProfile, profiles, typeOut, exprOut)
    if inTypeBlock:
        if ParserParseTypedInitializerLine(lineRaw, "", typeOut, exprOut):
            return ParserExprMatchesImplicitDefault(currentProfile, profiles, typeOut, exprOut)
        if ParserFindTupleTypeRedundantDefaultLine(lineRaw, currentProfile, profiles, typeOut, exprOut):
            return true
    return false

fn ParserIsTypeExprChar(ch: char): bool =
    return ParserIsIdentChar(ch) || ch == '.' || ch == '[' || ch == ']'

fn ParserFindRemovedDefaultExprLine(lineRaw: str,
                                      exprTextOut: var str,
                                      columnNumberOut: var int32): bool =
    exprTextOut = ""
    columnNumberOut = -1
    var inString = false
    var inChar = false
    var i: int32
    while i + Len("default[") <= lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar:
            i = i + 1
            continue
        if i > 0:
            if ParserIsIdentChar(lineRaw[i - 1]):
                i = i + 1
                continue
        if !ParserTextEqualsAt(lineRaw, i, "default["):
            i = i + 1
            continue
        let closePos = ParserFindMatchingBracket(lineRaw, i + Len("default"))
        if closePos < 0:
            return false
        exprTextOut = ParserTextSliceFast(lineRaw, i, closePos - i + 1)
        columnNumberOut = i + 1
        return true
    return false

fn ParserAppendDefaultInitExprsLine(sourcePath: str,
                                      lineNumber: int32,
                                      lineRaw: str,
                                      currentProfile: NormalizedExprCallProfile,
                                      profiles: NormalizedExprCallProfile[],
                                      layer: var NormalizedExprLayer,
                                      err: var str): bool =
    err = ""
    var removedExpr = ""
    var removedColumn = -1
    if ParserFindRemovedDefaultExprLine(lineRaw, removedExpr, removedColumn):
        let _ = removedColumn
        err = ParserDefaultInitRemovedDefaultError(removedExpr)
        return false
    var inString = false
    var inChar = false
    var i: int32
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar || ch != '(':
            i = i + 1
            continue
        let closePos = ParserFindMatchingParen(lineRaw, i)
        if closePos < 0:
            i = i + 1
            continue
        let argText = chengpath.PathTrim(ParserTextSliceFast(lineRaw, i + 1, closePos - i - 1))
        if argText != "":
            i = closePos + 1
            continue
        var calleeStop = i - 1
        while calleeStop >= 0:
            if !ParserIsInlineSpace(lineRaw[calleeStop]):
                break
            calleeStop = calleeStop - 1
        if calleeStop < 0:
            i = closePos + 1
            continue
        var calleeStart = 0
        for calleeOffset in 0..calleeStop:
            let calleeScan = calleeStop - calleeOffset
            if !ParserIsTypeExprChar(lineRaw[calleeScan]):
                calleeStart = calleeScan + 1
                break
        if calleeStart > calleeStop || ParserPreviousTokenIsDeclKeyword(lineRaw, calleeStart):
            i = closePos + 1
            continue
        let typeText = chengpath.PathTrim(ParserTextSliceFast(lineRaw, calleeStart, calleeStop - calleeStart + 1))
        var typeErr = ""
        let status = ParserDefaultInitTypeStatus(currentProfile, profiles, typeText, typeErr)
        if status < 0:
            err = typeErr
            return false
        if status > 0:
            NormalizedExprLayerAppendSpan(layer,
                                            sourcePath,
                                            lineNumber,
                                            calleeStart + 1,
                                            NormalizedExprDefaultInit,
                                            NormalizedExprDetailNone,
                                            typeText,
                                            closePos + 1)
        i = closePos + 1
    return true

fn ParserAppendConstructorExprsLine(sourcePath: str,
                                      lineNumber: int32,
                                      lineRaw: str,
                                      currentProfile: NormalizedExprCallProfile,
                                      profiles: NormalizedExprCallProfile[],
                                      layer: var NormalizedExprLayer) =
    var inString = false
    var inChar = false
    var i: int32
    while i < lineRaw.len:
        let ch = lineRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(lineRaw, i):
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(lineRaw, i):
            inChar = !inChar
            i = i + 1
            continue
        if inString || inChar || ch != '(':
            i = i + 1
            continue
        let closePos = ParserFindMatchingParen(lineRaw, i)
        if closePos < 0:
            i = i + 1
            continue
        let argsText = chengpath.PathTrim(ParserTextSliceFast(lineRaw, i + 1, closePos - i - 1))
        if argsText == "":
            i = closePos + 1
            continue
        var calleeStop = i - 1
        while calleeStop >= 0:
            if !ParserIsInlineSpace(lineRaw[calleeStop]):
                break
            calleeStop = calleeStop - 1
        if calleeStop < 0:
            i = closePos + 1
            continue
        var calleeStart = 0
        for calleeOffset2 in 0..calleeStop:
            let calleeScan2 = calleeStop - calleeOffset2
            if !ParserIsTypeExprChar(lineRaw[calleeScan2]):
                calleeStart = calleeScan2 + 1
                break
        if calleeStart > calleeStop || ParserPreviousTokenIsDeclKeyword(lineRaw, calleeStart):
            i = closePos + 1
            continue
        let typeText = chengpath.PathTrim(ParserTextSliceFast(lineRaw, calleeStart, calleeStop - calleeStart + 1))
        if ParserConstructorTypeStatus(currentProfile, profiles, typeText) > 0:
            NormalizedExprLayerAppendConstructor(layer,
                                                   sourcePath,
                                                   lineNumber,
                                                   calleeStart + 1,
                                                   typeText,
                                                   argsText,
                                                   ParserCountTopLevelArgs(argsText),
                                                   false,
                                                   closePos + 1)
        i = closePos + 1

fn ParserCallExprFirstDotExact(text: str): int32 =
    for i in 0..<text.len:
        if text[i] == '.':
            return i
    return -1

fn ParserCallExprLastDotExact(text: str): int32 =
    var dotPos: int32 = -1
    for i in 0..<text.len:
        if text[i] == '.':
            dotPos = i
    return dotPos

fn ParserCallExprLastDot(textRaw: str): int32 =
    return ParserCallExprLastDotExact(chengpath.PathTrim(textRaw))

fn ParserFindMatchingParen(textRaw: str,
                             openPos: int32): int32 =
    let openCh: char = '('
    let closeCh: char = ')'
    return ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn ParserFindMatchingBracket(textRaw: str,
                               openPos: int32): int32 =
    let openCh: char = '['
    let closeCh: char = ']'
    return ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn ParserFindMatchingBrace(textRaw: str,
                             openPos: int32): int32 =
    let openCh: char = '{'
    let closeCh: char = '}'
    return ParserFindMatchingPair(textRaw, openPos, openCh, closeCh)

fn ParserFindMatchingPair(textRaw: str,
                            openPos: int32,
                            openCh: char,
                            closeCh: char): int32 =
    if openPos < 0 || openPos >= textRaw.len:
        return -1
    if textRaw[openPos] != openCh:
        return -1
    var depth: int32
    var inString = false
    var inChar = false
    for i in openPos..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == openCh:
            depth = depth + 1
        elif ch == closeCh:
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn ParserFindTopLevelToken(textRaw: str,
                             target: str): int32 =
    if target == "" || target.len > textRaw.len:
        return -1
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth == 0 &&
           bracketDepth == 0 &&
           braceDepth == 0 &&
           ParserTextEqualsAt(textRaw, i, target):
            return i
    return -1

fn ParserFindTopLevelKeyword(textRaw: str,
                               keyword: str): int32 =
    if keyword == "" || keyword.len > textRaw.len:
        return -1
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let ch = textRaw[i]
        if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
            inString = !inString
            continue
        if !inString && ch == '\'' && !ParserQuoteIsEscaped(textRaw, i):
            inChar = !inChar
            continue
        if inString || inChar:
            continue
        if ch == '(':
            parenDepth = parenDepth + 1
            continue
        if ch == ')':
            parenDepth = parenDepth - 1
            continue
        if ch == '[':
            bracketDepth = bracketDepth + 1
            continue
        if ch == ']':
            bracketDepth = bracketDepth - 1
            continue
        if ch == '{':
            braceDepth = braceDepth + 1
            continue
        if ch == '}':
            braceDepth = braceDepth - 1
            continue
        if parenDepth != 0 || bracketDepth != 0 || braceDepth != 0:
            continue
        if !ParserTextEqualsAt(textRaw, i, keyword):
            continue
        var leftOk = true
        if i > 0:
            leftOk = !ParserIsIdentChar(textRaw[i - 1])
        let rightPos = i + keyword.len
        var rightOk = true
        if rightPos < textRaw.len:
            rightOk = !ParserIsIdentChar(textRaw[rightPos])
        if leftOk && rightOk:
            return i
    return -1

fn ParserSplitTopLevelCsv(textRaw: str): str[] =
    var out: str[]
    var start: int32
    var bracketDepth: int32
    var parenDepth: int32
    var braceDepth: int32
    for i in 0..<textRaw.len:
        let piece = textRaw[i]
        if piece == '[':
            bracketDepth = bracketDepth + 1
        elif piece == ']':
            bracketDepth = bracketDepth - 1
        elif piece == '(':
            parenDepth = parenDepth + 1
        elif piece == ')':
            parenDepth = parenDepth - 1
        elif piece == '{':
            braceDepth = braceDepth + 1
        elif piece == '}':
            braceDepth = braceDepth - 1
        elif piece == ',' && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            add(out, chengpath.PathTrim(chengpath.TextSlice(textRaw, start, i - start)))
            start = i + 1
    add(out, chengpath.PathTrim(chengpath.TextSlice(textRaw, start, textRaw.len - start)))
    return out

fn ParserQuoteIsEscaped(textRaw: str,
                          indexRaw: int32): bool =
    var index = indexRaw - 1
    var slashCount: int32
    let indexStart = index
    if indexStart >= 0:
        for indexOffset in 0..(indexStart - 0):
            index = indexStart - indexOffset
            if textRaw[index] != '\\':
                break
            slashCount = slashCount + 1
    return slashCount % 2 == 1

fn ParserCountTopLevelArgs(textRaw: str): int32 =
    let trimmedWhole = chengpath.PathTrim(textRaw)
    if trimmedWhole == "":
        return 0
    var inString = false
    var inChar = false
    var parenDepth: int32
    var bracketDepth: int32
    var braceDepth: int32
    var itemCount: int32
    var itemStart: int32
    var i: int32
    while i <= textRaw.len:
        let atEnd = i >= textRaw.len
        var splitHere = atEnd
        if !atEnd:
            let ch = textRaw[i]
            if !inChar && ch == '"' && !ParserQuoteIsEscaped(textRaw, i):
                inString = !inString
            elif !inString && ch == '\'' && !ParserQuoteIsEscaped(textRaw, i):
                inChar = !inChar
            elif !inString && !inChar && ch == '(':
                parenDepth = parenDepth + 1
            elif !inString && !inChar && ch == ')':
                parenDepth = parenDepth - 1
            elif !inString && !inChar && ch == '[':
                bracketDepth = bracketDepth + 1
            elif !inString && !inChar && ch == ']':
                bracketDepth = bracketDepth - 1
            elif !inString && !inChar && ch == '{':
                braceDepth = braceDepth + 1
            elif !inString && !inChar && ch == '}':
                braceDepth = braceDepth - 1
            elif !inString && !inChar &&
                 parenDepth == 0 &&
                 bracketDepth == 0 &&
                 braceDepth == 0 &&
                 ch == ',':
                splitHere = true
        if splitHere:
            let piece = chengpath.PathTrim(ParserTextSliceFast(textRaw, itemStart, i - itemStart))
            itemCount = itemCount + 1
            itemStart = i + 1
            if atEnd:
                break
        i = i + 1
    return itemCount

fn ParserCallSurfaceFromOpenParen(lineRaw: str,
                                    openPos: int32,
                                    callArgsTextOut: var str,
                                    callArgCountOut: var int32,
                                    endColumnOut: var int32): bool =
    callArgsTextOut = ""
    callArgCountOut = 0
    endColumnOut = -1
    if openPos < 0 || openPos >= lineRaw.len:
        return false
    if lineRaw[openPos] != '(':
        return false
    let closePos = ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    callArgsTextOut = ParserTextSliceFast(lineRaw, openPos + 1, closePos - openPos - 1)
    callArgCountOut = ParserCountTopLevelArgs(callArgsTextOut)
    endColumnOut = closePos + 1
    return true

fn ParserFunctionScopeDeclIndex(profile: NormalizedExprCallProfile,
                                  lineNumber: int32): int32 =
    var scopeIndex: int32 = -1
    for i in 0..<profile.decls.len:
        if profile.decls[i].importc:
            continue
        if profile.decls[i].lineIndex > lineNumber:
            break
        scopeIndex = i
    if scopeIndex < 0:
        return -1
    var endLine: int32 = 2147483647
    if scopeIndex + 1 < profile.decls.len:
        endLine = profile.decls[scopeIndex + 1].lineIndex - 1
    if lineNumber > endLine:
        return -1
    return scopeIndex

fn ParserTextEqualsAt(text: str,
                        startRaw: int32,
                        expected: str): bool =
    let start = startRaw
    if start < 0:
        return false
    if expected.len <= 0:
        return false
    if start + expected.len > text.len:
        return false
    for i in 0..<expected.len:
        if text[start + i] != expected[i]:
            return false
    return true

fn ParserTextRangeEquals(text: str,
                           startRaw: int32,
                           countRaw: int32,
                           expected: str): bool =
    let start = startRaw
    let count = countRaw
    if start < 0:
        return false
    if count != expected.len:
        return false
    if count <= 0:
        return false
    if start + count > text.len:
        return false
    if text[start] != expected[0]:
        return false
    if count == 1:
        return true
    if text[start + count - 1] != expected[count - 1]:
        return false
    for i in 1..<(count - 1):
        if text[start + i] != expected[i]:
            return false
    return true

fn ParserTextEqualsExact(left: str,
                           right: str): bool =
    if left.len != right.len:
        return false
    if left.len <= 0:
        return true
    if left[0] != right[0]:
        return false
    if left.len == 1:
        return true
    if left[left.len - 1] != right[right.len - 1]:
        return false
    for i in 1..<(left.len - 1):
        if left[i] != right[i]:
            return false
    return true

fn ParserIdentPrefixCountInRange(text: str,
                                   startRaw: int32,
                                   stopRaw: int32): int32 =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if start >= stop:
        return 0
    var cursor = start
    while cursor < stop:
        if !ParserIsIdentChar(text[cursor]):
            break
        cursor = cursor + 1
    return cursor - start

fn ParserBindingNameRange(lineRaw: str,
                            nameStartOut: var int32,
                            nameLenOut: var int32): bool =
    nameStartOut = -1
    nameLenOut = 0
    var cursor: int32
    cursor = ParserSkipInlineSpaces(lineRaw, cursor)
    var keywordLen: int32
    if ParserTextEqualsAt(lineRaw, cursor, "let"):
        keywordLen = 3
    elif ParserTextEqualsAt(lineRaw, cursor, "var"):
        keywordLen = 3
    elif ParserTextEqualsAt(lineRaw, cursor, "const"):
        keywordLen = 5
    if keywordLen <= 0:
        return false
    let afterKeyword = cursor + keywordLen
    if afterKeyword >= lineRaw.len || !ParserIsInlineSpace(lineRaw[afterKeyword]):
        return false
    cursor = ParserSkipInlineSpaces(lineRaw, afterKeyword)
    let nameStart = cursor
    while cursor < lineRaw.len:
        if !ParserIsIdentChar(lineRaw[cursor]):
            break
        cursor = cursor + 1
    if cursor <= nameStart:
        return false
    nameStartOut = nameStart
    nameLenOut = cursor - nameStart
    return true

fn ParserLineBindingMatches(lineRaw: str,
                              expectedRaw: str): bool =
    let expected = ParserIdentPrefix(chengpath.PathTrim(expectedRaw))
    return ParserLineBindingMatchesExact(lineRaw, expected)

fn ParserLineBindingMatchesExact(lineRaw: str,
                                   expected: str): bool =
    if expected == "":
        return false
    var nameStart: int32 = -1
    var nameLen: int32
    if !ParserBindingNameRange(lineRaw, nameStart, nameLen):
        return false
    if nameLen != expected.len:
        return false
    for i in 0..<nameLen:
        if lineRaw[nameStart + i] != expected[i]:
            return false
    return true

fn ParserLineBindingMatchesTextRange(lineRaw: str,
                                       expectedText: str,
                                       expectedStart: int32,
                                       expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if expectedStart < 0:
        return false
    if expectedStart + expectedLen > expectedText.len:
        return false
    var nameStart: int32 = -1
    var nameLen: int32
    if !ParserBindingNameRange(lineRaw, nameStart, nameLen):
        return false
    if nameLen != expectedLen:
        return false
    for i in 0..<nameLen:
        if lineRaw[nameStart + i] != expectedText[expectedStart + i]:
            return false
    return true

fn ParserFunctionParamsContainBinding(lineRaw: str,
                                        expectedRaw: str): bool =
    let expected = ParserIdentPrefix(chengpath.PathTrim(expectedRaw))
    return ParserFunctionParamsContainBindingExact(lineRaw, expected)

fn ParserFunctionParamsContainBindingExact(lineRaw: str,
                                             expected: str): bool =
    if expected == "":
        return false
    var openPos: int32 = -1
    openPos = ParserFindText(lineRaw, "(")
    if openPos < 0:
        return false
    var closePos: int32 = -1
    closePos = ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    var itemStart = openPos + 1
    var depthParen: int32
    var depthBracket: int32
    var depthBrace: int32
    for i in itemStart..closePos:
        var itemStop = i
        var endItem = false
        if i >= closePos:
            itemStop = closePos
            endItem = true
        elif lineRaw[i] == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            itemStop = i
            endItem = true
        elif lineRaw[i] == '(':
            depthParen = depthParen + 1
        elif lineRaw[i] == ')':
            if depthParen > 0:
                depthParen = depthParen - 1
        elif lineRaw[i] == '[':
            depthBracket = depthBracket + 1
        elif lineRaw[i] == ']':
            if depthBracket > 0:
                depthBracket = depthBracket - 1
        elif lineRaw[i] == '{':
            depthBrace = depthBrace + 1
        elif lineRaw[i] == '}':
            if depthBrace > 0:
                depthBrace = depthBrace - 1
        if endItem:
            var cursor = ParserSkipInlineSpaces(lineRaw, itemStart)
            if ParserTextEqualsAt(lineRaw, cursor, "var"):
                let afterVar = cursor + 3
                if afterVar < itemStop && ParserIsInlineSpace(lineRaw[afterVar]):
                    cursor = ParserSkipInlineSpaces(lineRaw, afterVar)
            let nameStart = cursor
            while cursor < itemStop:
                if !ParserIsIdentChar(lineRaw[cursor]):
                    break
                cursor = cursor + 1
            let nameLen = cursor - nameStart
            if nameLen == expected.len && nameLen > 0:
                var matched = true
                for partIndex in 0..<nameLen:
                    if lineRaw[nameStart + partIndex] != expected[partIndex]:
                        matched = false
                        break
                if matched:
                    return true
            itemStart = i + 1
    return false

fn ParserFunctionParamsContainBindingTextRange(lineRaw: str,
                                                 expectedText: str,
                                                 expectedStart: int32,
                                                 expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if expectedStart < 0:
        return false
    if expectedStart + expectedLen > expectedText.len:
        return false
    var openPos: int32 = -1
    openPos = ParserFindText(lineRaw, "(")
    if openPos < 0:
        return false
    var closePos: int32 = -1
    closePos = ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return false
    var itemStart = openPos + 1
    var depthParen: int32
    var depthBracket: int32
    var depthBrace: int32
    for i in itemStart..closePos:
        var itemStop = i
        var endItem = false
        if i >= closePos:
            itemStop = closePos
            endItem = true
        elif lineRaw[i] == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            itemStop = i
            endItem = true
        elif lineRaw[i] == '(':
            depthParen = depthParen + 1
        elif lineRaw[i] == ')':
            if depthParen > 0:
                depthParen = depthParen - 1
        elif lineRaw[i] == '[':
            depthBracket = depthBracket + 1
        elif lineRaw[i] == ']':
            if depthBracket > 0:
                depthBracket = depthBracket - 1
        elif lineRaw[i] == '{':
            depthBrace = depthBrace + 1
        elif lineRaw[i] == '}':
            if depthBrace > 0:
                depthBrace = depthBrace - 1
        if endItem:
            var cursor = ParserSkipInlineSpaces(lineRaw, itemStart)
            if ParserTextEqualsAt(lineRaw, cursor, "var"):
                let afterVar = cursor + 3
                if afterVar < itemStop && ParserIsInlineSpace(lineRaw[afterVar]):
                    cursor = ParserSkipInlineSpaces(lineRaw, afterVar)
            let nameStart = cursor
            while cursor < itemStop:
                if !ParserIsIdentChar(lineRaw[cursor]):
                    break
                cursor = cursor + 1
            let nameLen = cursor - nameStart
            if nameLen == expectedLen && nameLen > 0:
                var matched = true
                for partIndex in 0..<nameLen:
                    if lineRaw[nameStart + partIndex] != expectedText[expectedStart + partIndex]:
                        matched = false
                        break
                if matched:
                    return true
            itemStart = i + 1
    return false

fn ParserScopeHasVisibleBinding(profile: NormalizedExprCallProfile,
                                  scopeIndex: int32,
                                  lineNumber: int32,
                                  expectedRaw: str): bool =
    let expected = ParserIdentPrefix(chengpath.PathTrim(expectedRaw))
    return ParserScopeHasVisibleBindingExact(profile, scopeIndex, lineNumber, expected)

fn ParserScopeHasVisibleBindingExact(profile: NormalizedExprCallProfile,
                                       scopeIndex: int32,
                                       lineNumber: int32,
                                       expected: str): bool =
    if expected == "":
        return false
    if scopeIndex < 0 || scopeIndex >= profile.decls.len:
        return false
    let declLineIndex = profile.decls[scopeIndex].lineIndex
    if declLineIndex > 0 && declLineIndex <= profile.lines.len:
        if ParserFunctionParamsContainBindingExact(profile.lines[declLineIndex - 1], expected):
            return true
    var scanLine = declLineIndex + 1
    while scanLine < lineNumber && scanLine <= profile.lines.len:
        if ParserLineBindingMatchesExact(profile.lines[scanLine - 1], expected):
            return true
        scanLine = scanLine + 1
    return false

fn ParserScopeHasVisibleBindingTextRange(profile: NormalizedExprCallProfile,
                                           scopeIndex: int32,
                                           lineNumber: int32,
                                           expectedText: str,
                                           expectedStart: int32,
                                           expectedLen: int32): bool =
    if expectedLen <= 0:
        return false
    if scopeIndex < 0 || scopeIndex >= profile.decls.len:
        return false
    let declLineIndex = profile.decls[scopeIndex].lineIndex
    if declLineIndex > 0 && declLineIndex <= profile.lines.len:
        if ParserFunctionParamsContainBindingTextRange(profile.lines[declLineIndex - 1],
                                                         expectedText,
                                                         expectedStart,
                                                         expectedLen):
            return true
    var scanLine = declLineIndex + 1
    while scanLine < lineNumber && scanLine <= profile.lines.len:
        if ParserLineBindingMatchesTextRange(profile.lines[scanLine - 1],
                                               expectedText,
                                               expectedStart,
                                               expectedLen):
            return true
        scanLine = scanLine + 1
    return false

fn ParserQualifiedTargetRootQualifierExact(target: str): str =
    if target == "":
        return ""
    let dotPos = ParserCallExprFirstDotExact(target)
    if dotPos <= 0:
        return ""
    return ParserTextSliceFast(target, 0, dotPos)

fn ParserQualifiedTargetRootQualifier(targetRaw: str): str =
    return ParserQualifiedTargetRootQualifierExact(chengpath.PathTrim(targetRaw))

fn ParserQualifiedTargetQualifierChainExact(target: str): str =
    if target == "":
        return ""
    let dotPos = ParserCallExprLastDotExact(target)
    if dotPos <= 0:
        return ""
    return ParserTextSliceFast(target, 0, dotPos)

fn ParserQualifiedTargetQualifierChain(targetRaw: str): str =
    return ParserQualifiedTargetQualifierChainExact(chengpath.PathTrim(targetRaw))

fn ParserQualifiedTargetShadowReasonExact(currentProfile: NormalizedExprCallProfile,
                                            lineNumber: int32,
                                            target: str): NormalizedExprCallReason =
    let dotPos = ParserCallExprFirstDotExact(target)
    if dotPos <= 0:
        return NormalizedExprCallReasonNone
    let scopeIndex = ParserFunctionScopeDeclIndex(currentProfile, lineNumber)
    if ParserScopeHasVisibleBindingTextRange(currentProfile,
                                               scopeIndex,
                                               lineNumber,
                                               target,
                                               0,
                                               dotPos):
        return NormalizedExprCallReasonShadowedQualifiedTarget
    return NormalizedExprCallReasonNone

fn ParserCallExprDetailExact(kind: str,
                               callee: str,
                               qualifier: str,
                               target: str,
                               resolved: bool,
                               reason: NormalizedExprCallReason,
                               targetSourcePath: str,
                               targetImportc: bool): str =
    let reasonText = ParserCallReasonText(reason)
    var pairCount: int32 = 3
    var totalLen: int32 = 5 + kind.len +
                          7 + callee.len +
                          7 + target.len
    if qualifier != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 10 + qualifier.len
    if resolved:
        pairCount = pairCount + 1
        totalLen = totalLen + 10
    if reasonText != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 7 + reasonText.len
    if targetSourcePath != "":
        pairCount = pairCount + 1
        totalLen = totalLen + 19 + targetSourcePath.len
    if targetImportc:
        pairCount = pairCount + 1
        totalLen = totalLen + 16
    totalLen = totalLen + (pairCount - 1)
    if totalLen <= 0:
        return ""
    let out = NewStringAlloc(totalLen)
    let outPtr = RawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32
    var hasPairs: bool
    ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "kind", kind)
    ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "callee", callee)
    if qualifier != "":
        ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "qualifier", qualifier)
    ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target", target)
    if resolved:
        ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "resolved", "1")
    if reasonText != "":
        ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "reason", reasonText)
    if targetSourcePath != "":
        ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target_source_path", targetSourcePath)
    if targetImportc:
        ParserAppendCallExprDetailPair(out, outPtr, writePos, hasPairs, "target_importc", "1")
    return out

fn ParserAppendCallExprDetailPair(out: var str,
                                    outPtr: ptr,
                                    writePos: var int32,
                                    hasPairs: var bool,
                                    key: str,
                                    value: str) =
    if hasPairs:
        ParserWriteByteFast(out, writePos, 59)
    else:
        hasPairs = true
    ParserWriteTextFast(outPtr, writePos, key)
    ParserWriteByteFast(out, writePos, 61)
    ParserWriteTextFast(outPtr, writePos, value)

fn ParserAppendCallExprsLine(sourcePath: str,
                               lineNumber: int32,
                               lineRaw: str,
                               callLookup: ParserTextLookup*,
                               detailKind: NormalizedExprSurfaceCallKind,
                               currentProfile: NormalizedExprCallProfile,
                               profiles: NormalizedExprCallProfile[],
                               profileIndexLookup: ParserSourcePathIndexLookup,
                               profileCallLookupCache: var ParserProfileCallLookupCacheEntry[],
                               layer: var NormalizedExprLayer) =
    if callLookup == nil:
        return
    if callLookup->totalCount <= 0:
        return
    var i: int32
    while i < lineRaw.len:
        if !ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        var middleOfIdent = false
        if i > 0:
            middleOfIdent = ParserIsIdentChar(lineRaw[i - 1])
        if middleOfIdent:
            i = i + 1
            continue
        var stop = i
        while stop < lineRaw.len:
            if !ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        if ParserPreviousTokenIsDeclKeyword(lineRaw, i):
            i = stop
            continue
        let nextPos = ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        if !hasCallParen:
            i = stop
            continue
        let callName = ParserTextSliceFast(lineRaw, i, stop - i)
        if ParserCallExprUsesDedicatedNormalization(callName):
            i = stop
            continue
        var qualifierStart: int32 = -1
        var qualifierStop: int32 = -1
        var dottedStart: int32 = i
        if i > 1:
            let prevDotPos: int32 = i - 1
            if lineRaw[prevDotPos] == '.':
                qualifierStop = prevDotPos
                qualifierStart = prevDotPos
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                dottedStart = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
        let callNameKey = ParserTextLookupKeyExact(callName)
        var qualifiedCallName = callName
        var qualifiedCallNameKey = callNameKey
        var dottedCallName = callName
        var dottedCallNameKey = callNameKey
        var qualifierText = ""
        if qualifierStart >= 0 && qualifierStop > qualifierStart:
            qualifierText = ParserTextSliceFast(lineRaw, qualifierStart, qualifierStop - qualifierStart)
            qualifiedCallName = ParserConcat3(qualifierText, ".", callName)
            qualifiedCallNameKey = ParserTextLookupKeyExact(qualifiedCallName)
        if dottedStart < i:
            dottedCallName = ParserTextSliceFast(lineRaw, dottedStart, stop - dottedStart)
            dottedCallNameKey = ParserTextLookupKeyExact(dottedCallName)
        var matchedSurfaceText = ParserMatchKnownCallSurfaceTextKeysPtr(callLookup,
                                                                       callName,
                                                                       callNameKey,
                                                                       qualifiedCallName,
                                                                       qualifiedCallNameKey,
                                                                       dottedCallName,
                                                                       dottedCallNameKey)
        if detailKind == NormalizedExprSurfaceCallExternal && matchedSurfaceText != "":
            let shadowReason = ParserQualifiedTargetShadowReasonExact(currentProfile,
                                                                        lineNumber,
                                                                        matchedSurfaceText)
            if shadowReason != NormalizedExprCallReasonNone:
                matchedSurfaceText = ""
        if matchedSurfaceText != "":
            var callArgsText = ""
            var callArgCount: int32
            var endColumnNumber: int32 = -1
            let callSurfaceOk = ParserCallSurfaceFromOpenParen(lineRaw,
                                                                 nextPos,
                                                                 callArgsText,
                                                                 callArgCount,
                                                                 endColumnNumber)
            let _ = callSurfaceOk
            let resolvedTarget = ParserResolveCallTarget(currentProfile,
                                                           profiles,
                                                           profileIndexLookup,
                                                           profileCallLookupCache,
                                                           detailKind,
                                                           matchedSurfaceText,
                                                           callName)
            let resolved = resolvedTarget.sourcePath != ""
            NormalizedExprLayerAppendCall(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            matchedSurfaceText,
                                            detailKind,
                                            resolved,
                                            resolvedTarget.reason,
                                            qualifierText,
                                            callName,
                                            matchedSurfaceText,
                                            resolvedTarget.sourcePath,
                                            resolvedTarget.importc,
                                            callArgsText,
                                            callArgCount,
                                            false,
                                            endColumnNumber)
        i = stop
    return

fn ParserAppendMemberCallExprsLine(sourcePath: str,
                                     lineNumber: int32,
                                     lineRaw: str,
                                     knownCallLookup: ParserTextLookup,
                                     currentProfile: NormalizedExprCallProfile,
                                     layer: var NormalizedExprLayer) =
    if knownCallLookup.totalCount <= 0:
        return
    var i: int32
    while i < lineRaw.len:
        if !ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        let start = i
        var stop = i
        while stop < lineRaw.len:
            if !ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        if ParserPreviousTokenIsDeclKeyword(lineRaw, start):
            i = stop
            continue
        let nextPos = ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        if !hasCallParen:
            i = stop
            continue
        let callName = ParserTextSliceFast(lineRaw, start, stop - start)
        if ParserCallExprUsesDedicatedNormalization(callName):
            i = stop
            continue
        var qualifierStart: int32 = -1
        var qualifierStop: int32 = -1
        var dottedStart: int32 = start
        if start > 1:
            let prevDotPos: int32 = start - 1
            if lineRaw[prevDotPos] == '.':
                qualifierStop = prevDotPos
                qualifierStart = prevDotPos
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                dottedStart = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
        let callNameKey = ParserTextLookupKeyExact(callName)
        var dottedCallName = callName
        var dottedCallNameKey = callNameKey
        var qualifiedCallName = callName
        var qualifiedCallNameKey = callNameKey
        var qualifierText = ""
        if qualifierStart >= 0 && qualifierStop > qualifierStart:
            qualifierText = ParserTextSliceFast(lineRaw, qualifierStart, qualifierStop - qualifierStart)
            qualifiedCallName = ParserConcat3(qualifierText, ".", callName)
            qualifiedCallNameKey = ParserTextLookupKeyExact(qualifiedCallName)
        if dottedStart < start:
            dottedCallName = ParserTextSliceFast(lineRaw, dottedStart, stop - dottedStart)
            dottedCallNameKey = ParserTextLookupKeyExact(dottedCallName)
        if dottedCallName != callName:
            let shadowReason = ParserQualifiedTargetShadowReasonExact(currentProfile,
                                                                        lineNumber,
                                                                        dottedCallName)
            let knownCall = ParserMatchKnownCallSurfaceTextKeys(knownCallLookup,
                                                                  callName,
                                                                  callNameKey,
                                                                  qualifiedCallName,
                                                                  qualifiedCallNameKey,
                                                                  dottedCallName,
                                                                  dottedCallNameKey) != ""
            if shadowReason != NormalizedExprCallReasonNone || !knownCall:
                var reasonText = NormalizedExprCallReasonUnknownQualifiedTarget
                if shadowReason != NormalizedExprCallReasonNone:
                    reasonText = shadowReason
                var unresolvedSurfaceKind = NormalizedExprSurfaceCallMember
                if ParserProfileHasImportQualifier(currentProfile, qualifierText):
                    unresolvedSurfaceKind = NormalizedExprSurfaceCallExternal
                var callArgsText = ""
                var callArgCount: int32
                var endColumnNumber: int32 = -1
                let callSurfaceOk = ParserCallSurfaceFromOpenParen(lineRaw,
                                                                     nextPos,
                                                                     callArgsText,
                                                                     callArgCount,
                                                                     endColumnNumber)
                let _ = callSurfaceOk
                NormalizedExprLayerAppendCall(layer,
                                                sourcePath,
                                                lineNumber,
                                                start + 1,
                                                dottedCallName,
                                                unresolvedSurfaceKind,
                                                false,
                                                reasonText,
                                                qualifierText,
                                                callName,
                                                dottedCallName,
                                                "",
                                                false,
                                                callArgsText,
                                                callArgCount,
                                                false,
                                                endColumnNumber)
        i = stop
    return

fn ParserMaxQualifiedCallDepthLines(lines: str[]): int32 =
    var maxDepth: int32
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        if !ParserHasNonTrimChar(lineRaw):
            continue
        var pos: int32
        while pos < lineRaw.len:
            if !ParserIsIdentChar(lineRaw[pos]):
                pos = pos + 1
                continue
            let start = pos
            var stop = pos
            while stop < lineRaw.len:
                if !ParserIsIdentChar(lineRaw[stop]):
                    break
                stop = stop + 1
            let nextPos = ParserSkipInlineSpaces(lineRaw, stop)
            var hasCallParen = false
            if nextPos < lineRaw.len:
                hasCallParen = lineRaw[nextPos] == '('
            if hasCallParen && !ParserPreviousTokenIsDeclKeyword(lineRaw, start):
                let depth = ParserDottedQualifierDepth(lineRaw, start)
                if depth > maxDepth:
                    maxDepth = depth
            pos = stop
    return maxDepth

fn ParserMaxQualifiedCallDepth(text: str): int32 =
    var normalizedText = text
    if ParserSourceHasMultilineString(text):
        var err = ""
        if !ParserRewriteMultilineStringSourceText(text, normalizedText, err):
            return 0
    let lines = ParserPrepareCodeLines(ParserSplitChar(normalizedText, '\n'))
    return ParserMaxQualifiedCallDepthLines(lines)

fn ParserAppendComprehensionExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        layer: var NormalizedExprLayer) =
    for openPos in 0..<lineRaw.len:
        if lineRaw[openPos] != '[':
            continue
        var itemText = ""
        var bindingText = ""
        var sourceText = ""
        var filterText = ""
        var filterColumn = -1
        var endColumn = -1
        if !ParserParseListComprehensionAt(lineRaw,
                                             openPos,
                                             itemText,
                                             bindingText,
                                             sourceText,
                                             filterText,
                                             filterColumn,
                                             endColumn):
            continue
        NormalizedExprLayerAppendSpan(layer,
                                        sourcePath,
                                        lineNumber,
                                        openPos + 1,
                                        NormalizedExprComprehension,
                                        NormalizedExprDetailComprehensionList,
                                        "[for in]",
                                        endColumn)

fn ParserImportcCallNamesFromDecls(decls: NormalizedFunctionDecl[],
                                     names: var str[]) =
    var out: str[]
    for i in 0..<decls.len:
        if !decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        ParserAddUniqueText(out, decls[i].name)
    names = out

fn ParserLocalCallNamesFromDecls(decls: NormalizedFunctionDecl[],
                                   names: var str[]) =
    var out: str[]
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        ParserAddUniqueText(out, decls[i].name)
    names = out

fn ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRootRaw: str,
                                                        packageRootRaw: str,
                                                        externalPackageRoots: ParserExternalPackageRoot[],
                                                        sourcePathRaw: str,
                                                        text: str,
                                                        profile: var NormalizedExprCallProfile,
                                                        err: var str): bool =
    let workspaceRoot = ParserNormalizePath(workspaceRootRaw)
    let packageRoot = ParserNormalizePath(packageRootRaw)
    let sourcePath = ParserNormalizePath(sourcePathRaw)
    var normalizedText = text
    if ParserSourceHasMultilineString(text):
        if !ParserRewriteMultilineStringSourceText(text, normalizedText, err):
            return false
    if sourcePath == "":
        err = "missing source path"
        return false
    profile.sourcePath = sourcePath
    profile.ownerModulePath = ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                     packageRoot,
                                                                                     externalPackageRoots,
                                                                                     sourcePath)
    profile.text = normalizedText
    profile.lines = []
    profile.decls = []
    profile.typeDecls = []
    profile.importcCallNames = []
    profile.localCallNames = []
    profile.importEdges = []
    profile.maxQualifiedCallDepth = 0
    let lines = ParserSplitChar(normalizedText, '\n')
    profile.lines = lines
    let codeLines = ParserPrepareCodeLines(lines)
    if !ParserReadNormalizedFunctionDeclsLines(lines, profile.decls, err):
        return false
    ParserReadNormalizedTypeDeclsLines(lines, profile.typeDecls)
    if workspaceRoot != "" && packageRoot != "":
        if !ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 profile.ownerModulePath,
                                                                 lines,
                                                                 profile.importEdges,
                                                                 err):
            return false
    ParserImportcCallNamesFromDecls(profile.decls, profile.importcCallNames)
    ParserLocalCallNamesFromDecls(profile.decls, profile.localCallNames)
    profile.maxQualifiedCallDepth = ParserMaxQualifiedCallDepthLines(codeLines)
    err = ""
    return true

fn ParserBuildExprCallProfile(workspaceRootRaw: str,
                                packageRootRaw: str,
                                sourcePathRaw: str,
                                text: str,
                                profile: var NormalizedExprCallProfile,
                                err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRootRaw,
                                                                packageRootRaw,
                                                                externalPackageRoots,
                                                                sourcePathRaw,
                                                                text,
                                                                profile,
                                                                err)

fn ParserImportEdgeQualifier(edge: ImportEdge): str =
    return edge.qualifier

fn ParserImportEdgeAllowsUnqualifiedCall(edge: ImportEdge): bool =
    return edge.allowsUnqualifiedCall

fn ParserQualifiedCallPrefixExact(prefix: str,
                                    qualifier: str): str =
    if prefix == "":
        return qualifier
    if qualifier == "":
        return prefix
    return ParserConcat3(prefix, ".", qualifier)

fn ParserQualifiedCallPrefix(prefixRaw: str,
                               qualifierRaw: str): str =
    let prefix = chengpath.PathTrim(prefixRaw)
    let qualifier = chengpath.PathTrim(qualifierRaw)
    return ParserQualifiedCallPrefixExact(prefix, qualifier)

fn ParserResolvedCallTargetNew(sourcePathRaw: str,
                                 importc: bool,
                                 reasonRaw: NormalizedExprCallReason): NormalizedExprResolvedCallTarget =
    return ParserResolvedCallTargetNewExact(ParserNormalizePath(sourcePathRaw),
                                              importc,
                                              reasonRaw)

fn ParserResolvedCallTargetNewExact(sourcePath: str,
                                      importc: bool,
                                      reason: NormalizedExprCallReason): NormalizedExprResolvedCallTarget =
    var out: NormalizedExprResolvedCallTarget
    out.sourcePath = sourcePath
    out.importc = importc
    out.reason = reason
    return out

fn ParserResolvedCallTargetResolved(sourcePathRaw: str,
                                      importc: bool): NormalizedExprResolvedCallTarget =
    return ParserResolvedCallTargetNewExact(sourcePathRaw, importc, NormalizedExprCallReasonNone)

fn ParserResolvedCallTargetUnknown(reasonRaw: NormalizedExprCallReason): NormalizedExprResolvedCallTarget =
    return ParserResolvedCallTargetNewExact("", false, reasonRaw)

fn ParserResolvedCallTargetEmpty(): NormalizedExprResolvedCallTarget =
    return ParserResolvedCallTargetNewExact("", false, NormalizedExprCallReasonNone)

fn ParserResolvedCallTargetSame(lhs: NormalizedExprResolvedCallTarget,
                                  rhs: NormalizedExprResolvedCallTarget): bool =
    return lhs.sourcePath == rhs.sourcePath &&
           lhs.importc == rhs.importc &&
           lhs.reason == rhs.reason

fn ParserAppendUniqueResolvedCallTarget(out: var NormalizedExprResolvedCallTarget[],
                                          target: NormalizedExprResolvedCallTarget) =
    if target.sourcePath == "" || target.reason != NormalizedExprCallReasonNone:
        return
    for i in 0..<out.len:
        if ParserResolvedCallTargetSame(out[i], target):
            return
    add(out, target)

fn ParserImportedTargetLookupResolved(targetProfileIndex: int32): ParserImportedTargetLookup =
    var out: ParserImportedTargetLookup
    out.targetProfileIndex = targetProfileIndex
    out.reason = NormalizedExprCallReasonNone
    return out

fn ParserImportedTargetLookupUnknown(reasonRaw: NormalizedExprCallReason): ParserImportedTargetLookup =
    return ParserImportedTargetLookupUnknownExact(reasonRaw)

fn ParserImportedTargetLookupUnknownExact(reason: NormalizedExprCallReason): ParserImportedTargetLookup =
    var out: ParserImportedTargetLookup
    out.targetProfileIndex = -1
    out.reason = reason
    return out

fn ParserCallProfileHasImportcCall(profile: NormalizedExprCallProfile,
                                     nameRaw: str): bool =
    let name = ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return false
    return ParserStringSeqContainsExact(profile.importcCallNames, name)

fn ParserCallProfileHasLocalCall(profile: NormalizedExprCallProfile,
                                   nameRaw: str): bool =
    let name = ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return false
    return ParserStringSeqContainsExact(profile.localCallNames, name)

fn ParserCallProfileHasImportcCallExact(profiles: NormalizedExprCallProfile[],
                                          profileIndex: int32,
                                          cache: var ParserProfileCallLookupCacheEntry[],
                                          name: str): bool =
    if name == "":
        return false
    let cacheIndex = ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    return ParserTextLookupContainsKey(cache[cacheIndex].importcLookup,
                                         name,
                                         ParserTextLookupKeyExact(name))

fn ParserCallProfileHasLocalCallExact(profiles: NormalizedExprCallProfile[],
                                        profileIndex: int32,
                                        cache: var ParserProfileCallLookupCacheEntry[],
                                        name: str): bool =
    if name == "":
        return false
    let cacheIndex = ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    return ParserTextLookupContainsKey(cache[cacheIndex].localLookup,
                                         name,
                                         ParserTextLookupKeyExact(name))

fn ParserProfileCallLookupFlagsCached(cache: ParserProfileCallLookupCacheEntry[],
                                        profileIndex: int32,
                                        name: str,
                                        nameKey: ParserTextLookupKey,
                                        hasImportc: var bool,
                                        hasLocal: var bool): bool =
    hasImportc = false
    hasLocal = false
    if name == "":
        return false
    if nameKey.keyLen <= 0:
        return false
    if profileIndex < 0:
        return false
    if profileIndex >= cache.len:
        return false
    let entry = cache[profileIndex]
    hasImportc = ParserTextLookupContainsKey(entry.importcLookup, name, nameKey)
    hasLocal = ParserTextLookupContainsKey(entry.localLookup, name, nameKey)
    return true

fn ParserProfileCallLookupFlags(profiles: NormalizedExprCallProfile[],
                                  profileIndex: int32,
                                  cache: var ParserProfileCallLookupCacheEntry[],
                                  name: str,
                                  nameKey: ParserTextLookupKey,
                                  hasImportc: var bool,
                                  hasLocal: var bool): bool =
    hasImportc = false
    hasLocal = false
    if name == "":
        return false
    if nameKey.keyLen <= 0:
        return false
    let cacheIndex = ParserProfileCallLookupCacheEnsureIndex(profiles, profileIndex, cache)
    if cacheIndex < 0:
        return false
    let entry = cache[cacheIndex]
    hasImportc = ParserTextLookupContainsKey(entry.importcLookup, name, nameKey)
    hasLocal = ParserTextLookupContainsKey(entry.localLookup, name, nameKey)
    return true

fn ParserImportedTargetProfileIndex(currentProfile: NormalizedExprCallProfile,
                                      profiles: NormalizedExprCallProfile[],
                                      qualifierChainRaw: str): ParserImportedTargetLookup =
    let qualifierChain = qualifierChainRaw
    if qualifierChain == "":
        return ParserImportedTargetLookupUnknownExact(NormalizedExprCallReasonUnknownQualifiedTarget)
    var ctx = currentProfile
    var targetProfileIndex: int32 = -1
    var partStart: int32
    while partStart <= qualifierChain.len:
        var partStop = partStart
        while partStop < qualifierChain.len:
            if qualifierChain[partStop] == '.':
                break
            partStop = partStop + 1
        let qualifierLen = ParserIdentPrefixCountInRange(qualifierChain, partStart, partStop)
        if qualifierLen <= 0:
            return ParserImportedTargetLookupUnknownExact(NormalizedExprCallReasonUnknownQualifiedTarget)
        targetProfileIndex = -1
        for edgeIndex in 0..<ctx.importEdges.len:
            if !ctx.importEdges[edgeIndex].resolved:
                continue
            let edgeQualifier = ctx.importEdges[edgeIndex].qualifier
            if !ParserTextRangeEquals(qualifierChain, partStart, qualifierLen, edgeQualifier):
                continue
            let candidateIndex = ctx.importEdges[edgeIndex].targetProfileIndex
            if candidateIndex < 0:
                continue
            if targetProfileIndex < 0:
                targetProfileIndex = candidateIndex
                continue
            if targetProfileIndex != candidateIndex:
                return ParserImportedTargetLookupUnknownExact(NormalizedExprCallReasonAmbiguousQualifiedTarget)
        if targetProfileIndex < 0:
            return ParserImportedTargetLookupUnknownExact(NormalizedExprCallReasonUnknownQualifiedTarget)
        if partStop >= qualifierChain.len:
            return ParserImportedTargetLookupResolved(targetProfileIndex)
        ctx = profiles[targetProfileIndex]
        partStart = partStop + 1
    return ParserImportedTargetLookupResolved(targetProfileIndex)

fn ParserResolveQualifiedCallTarget(currentProfile: NormalizedExprCallProfile,
                                      profiles: NormalizedExprCallProfile[],
                                      profileIndexLookup: ParserSourcePathIndexLookup,
                                      profileCallLookupCache: var ParserProfileCallLookupCacheEntry[],
                                      targetRaw: str,
                                      calleeRaw: str): NormalizedExprResolvedCallTarget =
    let qualifier = ParserQualifiedTargetQualifierChainExact(targetRaw)
    let callee = ParserIdentPrefix(calleeRaw)
    if qualifier == "" || callee == "":
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownQualifiedTarget)
    let calleeKey = ParserTextLookupKeyExact(callee)
    let targetLookup = ParserImportedTargetProfileIndex(currentProfile,
                                                          profiles,
                                                          qualifier)
    if targetLookup.targetProfileIndex < 0:
        return ParserResolvedCallTargetUnknown(targetLookup.reason)
    let targetProfile = profiles[targetLookup.targetProfileIndex]
    var hasImportc = false
    var hasLocal = false
    let foundTarget = ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                           targetLookup.targetProfileIndex,
                                                           callee,
                                                           calleeKey,
                                                           hasImportc,
                                                           hasLocal)
    if foundTarget && hasImportc:
        return ParserResolvedCallTargetResolved(targetProfile.sourcePath, true)
    if foundTarget && hasLocal:
        return ParserResolvedCallTargetResolved(targetProfile.sourcePath, false)
    let visibleTarget = ParserResolveUnqualifiedExternalCallTarget(targetProfile,
                                                                    profiles,
                                                                    profileIndexLookup,
                                                                    profileCallLookupCache,
                                                                    callee)
    if visibleTarget.sourcePath != "":
        return visibleTarget
    if visibleTarget.reason == NormalizedExprCallReasonAmbiguousExternalTarget:
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonAmbiguousQualifiedTarget)
    return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownQualifiedTarget)

fn ParserResolveUnqualifiedExternalCallTarget(currentProfile: NormalizedExprCallProfile,
                                                profiles: NormalizedExprCallProfile[],
                                                profileIndexLookup: ParserSourcePathIndexLookup,
                                                profileCallLookupCache: var ParserProfileCallLookupCacheEntry[],
                                                calleeRaw: str): NormalizedExprResolvedCallTarget =
    let callee = ParserIdentPrefix(calleeRaw)
    if callee == "":
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownExternalTarget)
    let calleeKey = ParserTextLookupKeyExact(callee)
    let currentProfileIndex = ParserProfileIndexLookupForNormalizedSourcePathExact(profileIndexLookup,
                                                                                     currentProfile.sourcePath)
    if currentProfileIndex < 0:
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownExternalTarget)
    var visited: bool[] = ParserBoolSeqInit(profiles.len, false)
    visited[currentProfileIndex] = true
    var pending: int32[]
    add(pending, currentProfileIndex)
    var pendingIndex: int32
    var found: NormalizedExprResolvedCallTarget[]
    while pendingIndex < pending.len:
        if pendingIndex % 64 == 0:
            os.ProcessResourceGuardCheck()
        let workingProfileIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let workingProfile = profiles[workingProfileIndex]
        for edgeIndex in 0..<workingProfile.importEdges.len:
            if !workingProfile.importEdges[edgeIndex].resolved:
                continue
            if !workingProfile.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = workingProfile.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            var hasImportc = false
            var hasLocal = false
            let foundTarget = ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                                   targetProfileIndex,
                                                                   callee,
                                                                   calleeKey,
                                                                   hasImportc,
                                                                   hasLocal)
            if !foundTarget:
                continue
            if hasImportc || hasLocal:
                ParserAppendUniqueResolvedCallTarget(found,
                                                       ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)
    if found.len <= 0:
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownExternalTarget)
    if found.len > 1:
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonAmbiguousExternalTarget)
    return found[0]

fn ParserResolveCallTarget(currentProfile: NormalizedExprCallProfile,
                             profiles: NormalizedExprCallProfile[],
                             profileIndexLookup: ParserSourcePathIndexLookup,
                             profileCallLookupCache: var ParserProfileCallLookupCacheEntry[],
                             detailKind: NormalizedExprSurfaceCallKind,
                             targetRaw: str,
                             calleeRaw: str): NormalizedExprResolvedCallTarget =
    if detailKind == NormalizedExprSurfaceCallLocal:
        return ParserResolvedCallTargetResolved(currentProfile.sourcePath, false)
    if detailKind == NormalizedExprSurfaceCallImportc:
        return ParserResolvedCallTargetResolved(currentProfile.sourcePath, true)
    if detailKind != NormalizedExprSurfaceCallExternal:
        return ParserResolvedCallTargetUnknown(NormalizedExprCallReasonUnknownCallTarget)
    let target = targetRaw
    if ParserCallExprLastDotExact(target) >= 0:
        return ParserResolveQualifiedCallTarget(currentProfile,
                                                  profiles,
                                                  profileIndexLookup,
                                                  profileCallLookupCache,
                                                  target,
                                                  calleeRaw)
    return ParserResolveUnqualifiedExternalCallTarget(currentProfile,
                                                        profiles,
                                                        profileIndexLookup,
                                                        profileCallLookupCache,
                                                        calleeRaw)

fn ParserQualifiedCallDepth(prefixRaw: str): int32 =
    let prefix = chengpath.PathTrim(prefixRaw)
    if prefix == "":
        return 0
    var depth: int32 = 1
    for i in 0..<prefix.len:
        if prefix[i] == '.':
            depth = depth + 1
    return depth

fn ParserAppendQualifiedCallNames(out: var str[],
                                    seen: var ParserTextLookup,
                                    prefixRaw: str,
                                    callNames: str[]) =
    let prefix = chengpath.PathTrim(prefixRaw)
    ParserAppendQualifiedCallNamesExact(out, seen, prefix, callNames)

fn ParserAppendQualifiedCallNamesExact(out: var str[],
                                         seen: var ParserTextLookup,
                                         prefix: str,
                                         callNames: str[]) =
    if prefix == "":
        return
    let prefixWithDot = ParserConcat2(prefix, ".")
    for i in 0..<callNames.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let callName = callNames[i]
        if callName == "":
            continue
        let qualifiedName = ParserConcat2(prefixWithDot, callName)
        ParserAppendUniqueLookupTextKey(out,
                                          seen,
                                          qualifiedName,
                                          ParserTextLookupKeyExact(qualifiedName))

fn ParserAppendDirectExternalCallNames(out: var str[],
                                         seen: var ParserTextLookup,
                                         callNames: str[]) =
    for i in 0..<callNames.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let callName = callNames[i]
        if callName == "":
            continue
        ParserAppendUniqueLookupTextKey(out, seen, callName, ParserTextLookupKeyExact(callName))

fn ParserAppendVisibleDirectExternalCallNames(out: var str[],
                                                seen: var ParserTextLookup,
                                                callNames: str[],
                                                localLookup: ParserTextLookup,
                                                importcLookup: ParserTextLookup) =
    for i in 0..<callNames.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let callName = callNames[i]
        if callName == "":
            continue
        let callNameKey = ParserTextLookupKeyExact(callName)
        if ParserTextLookupContainsKey(localLookup, callName, callNameKey):
            continue
        if ParserTextLookupContainsKey(importcLookup, callName, callNameKey):
            continue
        ParserAppendUniqueLookupTextKey(out, seen, callName, callNameKey)

fn ParserCloneTextSeq(items: str[]): str[] =
    var out: str[]
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn ParserPrepareCodeLines(lines: str[]): str[] =
    var out: str[]
    for i in 0..<lines.len:
        add(out, ParserStripLineComment(lines[i]))
    return out

fn ParserBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    for i in 0..<count:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(out, value)
    return out

fn ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(profiles: NormalizedExprCallProfile[],
                                                               profileIndexLookup: ParserSourcePathIndexLookup,
                                                               profileIndex: int32,
                                                               rootLocalLookup: ParserTextLookup,
                                                               rootImportcLookup: ParserTextLookup,
                                                               seen: var ParserTextLookup,
                                                               out: var str[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    var visited: bool[] = ParserBoolSeqInit(profiles.len, false)
    visited[profileIndex] = true
    var pending: int32[]
    add(pending, profileIndex)
    var pendingIndex: int32
    while pendingIndex < pending.len:
        if pendingIndex % 64 == 0:
            os.ProcessResourceGuardCheck()
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            if !current.importEdges[edgeIndex].resolved:
                continue
            if !current.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = current.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            ParserAppendVisibleDirectExternalCallNames(out,
                                                         seen,
                                                         targetProfile.localCallNames,
                                                         rootLocalLookup,
                                                         rootImportcLookup)
            ParserAppendVisibleDirectExternalCallNames(out,
                                                         seen,
                                                         targetProfile.importcCallNames,
                                                         rootLocalLookup,
                                                         rootImportcLookup)
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)

fn ParserCollectResolvedUnqualifiedExternalTargetsRecursive(profiles: NormalizedExprCallProfile[],
                                                              profileIndexLookup: ParserSourcePathIndexLookup,
                                                              profileIndex: int32,
                                                              calleeRaw: str,
                                                              out: var NormalizedExprResolvedCallTarget[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    let callee = ParserIdentPrefix(chengpath.PathTrim(calleeRaw))
    if callee == "":
        return
    let calleeKey = ParserTextLookupKeyExact(callee)
    var visited: bool[] = ParserBoolSeqInit(profiles.len, false)
    visited[profileIndex] = true
    var pending: int32[]
    add(pending, profileIndex)
    var pendingIndex: int32
    os.ProcessResourceGuardCheck()
    var profileCallLookupCache = ParserBuildProfileCallLookupCache(profiles)
    while pendingIndex < pending.len:
        if pendingIndex % 64 == 0:
            os.ProcessResourceGuardCheck()
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            if !current.importEdges[edgeIndex].resolved:
                continue
            if !current.importEdges[edgeIndex].allowsUnqualifiedCall:
                continue
            let targetProfileIndex = current.importEdges[edgeIndex].targetProfileIndex
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            var hasImportc = false
            var hasLocal = false
            let foundTarget = ParserProfileCallLookupFlagsCached(profileCallLookupCache,
                                                                   targetProfileIndex,
                                                                   callee,
                                                                   calleeKey,
                                                                   hasImportc,
                                                                   hasLocal)
            if !foundTarget:
                continue
            if hasImportc || hasLocal:
                ParserAppendUniqueResolvedCallTarget(out,
                                                       ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if visited[targetProfileIndex]:
                continue
            visited[targetProfileIndex] = true
            add(pending, targetProfileIndex)

fn ParserCachedVisibleUnqualifiedExternalCallNames(profiles: NormalizedExprCallProfile[],
                                                     profileIndexLookup: ParserSourcePathIndexLookup,
                                                     profileIndex: int32,
                                                     cache: var ParserTextSeqCacheEntry[]): str[] =
    for i in 0..<cache.len:
        if i % 128 == 0:
            os.ProcessResourceGuardCheck()
        let entry = cache[i]
        if entry.profileIndex == profileIndex:
            return entry.items
    var out: str[]
    if profileIndex < 0:
        return out
    if profileIndex >= profiles.len:
        return out
    let rootProfile = profiles[profileIndex]
    os.ProcessResourceGuardCheck()
    let rootLocalLookup = ParserTextLookupBuildExact(rootProfile.localCallNames)
    let rootImportcLookup = ParserTextLookupBuildExact(rootProfile.importcCallNames)
    var seen: ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(profiles,
                                                                profileIndexLookup,
                                                                profileIndex,
                                                                rootLocalLookup,
                                                                rootImportcLookup,
                                                                seen,
                                                                out)
    var entry: ParserTextSeqCacheEntry
    entry.profileIndex = profileIndex
    entry.items = out
    add(cache, entry)
    return out

fn ParserCachedQualifiedExternalCallNames(profiles: NormalizedExprCallProfile[],
                                            profileIndexLookup: ParserSourcePathIndexLookup,
                                            profileIndex: int32,
                                            prefix: str,
                                            visibleNameCache: var ParserTextSeqCacheEntry[],
                                            cache: var ParserQualifiedTextSeqCacheEntry[]): str[] =
    for i in 0..<cache.len:
        if i % 128 == 0:
            os.ProcessResourceGuardCheck()
        let entry = cache[i]
        if entry.profileIndex != profileIndex:
            continue
        if entry.prefix == prefix:
            return entry.items
    var out: str[]
    if profileIndex < 0:
        return out
    if profileIndex >= profiles.len:
        return out
    if prefix == "":
        return out
    let targetProfile = profiles[profileIndex]
    let visibleNames = ParserCachedVisibleUnqualifiedExternalCallNames(profiles,
                                                                         profileIndexLookup,
                                                                         profileIndex,
                                                                         visibleNameCache)
    os.ProcessResourceGuardCheck()
    var seen = ParserTextLookupInit(targetProfile.localCallNames.len +
                                      targetProfile.importcCallNames.len +
                                      visibleNames.len + 8)
    ParserAppendQualifiedCallNamesExact(out, seen, prefix, targetProfile.localCallNames)
    ParserAppendQualifiedCallNamesExact(out, seen, prefix, targetProfile.importcCallNames)
    ParserAppendQualifiedCallNamesExact(out, seen, prefix, visibleNames)
    var entry: ParserQualifiedTextSeqCacheEntry
    entry.profileIndex = profileIndex
    entry.prefix = prefix
    entry.items = out
    add(cache, entry)
    return out

fn ParserCollectExternalCallNamesRecursive(profiles: NormalizedExprCallProfile[],
                                             profileIndexLookup: ParserSourcePathIndexLookup,
                                             profileIndex: int32,
                                             prefix: str,
                                             prefixDepth: int32,
                                             maxQualifiedCallDepth: int32,
                                             activeProfileFlags: var bool[],
                                             visibleNameCache: var ParserTextSeqCacheEntry[],
                                             qualifiedNameCache: var ParserQualifiedTextSeqCacheEntry[],
                                             seen: var ParserTextLookup,
                                             out: var str[]) =
    os.ProcessResourceGuardCheck()
    if profileIndex < 0:
        return
    if profileIndex >= profiles.len:
        return
    let current = profiles[profileIndex]
    for edgeIndex in 0..<current.importEdges.len:
        if edgeIndex % 64 == 0:
            os.ProcessResourceGuardCheck()
        let edge = current.importEdges[edgeIndex]
        if !edge.resolved:
            continue
        let targetProfileIndex = edge.targetProfileIndex
        if targetProfileIndex < 0:
            continue
        if targetProfileIndex >= profiles.len:
            continue
        let qualifier = edge.qualifier
        if qualifier == "":
            continue
        let nextPrefix = ParserQualifiedCallPrefixExact(prefix, qualifier)
        let nextDepth = prefixDepth + 1
        if nextDepth > maxQualifiedCallDepth:
            continue
        let qualifiedNames = ParserCachedQualifiedExternalCallNames(profiles,
                                                                      profileIndexLookup,
                                                                      targetProfileIndex,
                                                                      nextPrefix,
                                                                      visibleNameCache,
                                                                      qualifiedNameCache)
        ParserAppendDirectExternalCallNames(out, seen, qualifiedNames)
        if nextDepth >= maxQualifiedCallDepth:
            continue
        if activeProfileFlags[targetProfileIndex]:
            continue
        activeProfileFlags[targetProfileIndex] = true
        ParserCollectExternalCallNamesRecursive(profiles,
                                                  profileIndexLookup,
                                                  targetProfileIndex,
                                                  nextPrefix,
                                                  nextDepth,
                                                  maxQualifiedCallDepth,
                                                  activeProfileFlags,
                                                  visibleNameCache,
                                                  qualifiedNameCache,
                                                  seen,
                                                  out)
        activeProfileFlags[targetProfileIndex] = false

fn ParserCollectExternalCallNames(profiles: NormalizedExprCallProfile[],
                                    profileIndexLookup: ParserSourcePathIndexLookup,
                                    profileIndex: int32,
                                    names: var str[]) =
    var visibleNameCache: ParserTextSeqCacheEntry[]
    var qualifiedNameCache: ParserQualifiedTextSeqCacheEntry[]
    ParserCollectExternalCallNamesCached(profiles,
                                           profileIndexLookup,
                                           profileIndex,
                                           visibleNameCache,
                                           qualifiedNameCache,
                                           names)

fn ParserCollectExternalCallNamesCached(profiles: NormalizedExprCallProfile[],
                                          profileIndexLookup: ParserSourcePathIndexLookup,
                                          profileIndex: int32,
                                          visibleNameCache: var ParserTextSeqCacheEntry[],
                                          qualifiedNameCache: var ParserQualifiedTextSeqCacheEntry[],
                                          names: var str[]) =
    var out: str[]
    if profileIndex < 0:
        names = out
        return
    if profileIndex >= profiles.len:
        names = out
        return
    var seen: ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    os.ProcessResourceGuardCheck()
    let visibleNames = ParserCachedVisibleUnqualifiedExternalCallNames(profiles,
                                                                         profileIndexLookup,
                                                                         profileIndex,
                                                                         visibleNameCache)
    ParserAppendDirectExternalCallNames(out, seen, visibleNames)
    var activeProfileFlags: bool[] = ParserBoolSeqInit(profiles.len, false)
    activeProfileFlags[profileIndex] = true
    os.ProcessResourceGuardCheck()
    ParserCollectExternalCallNamesRecursive(profiles,
                                              profileIndexLookup,
                                              profileIndex,
                                              "",
                                              0,
                                              profiles[profileIndex].maxQualifiedCallDepth,
                                              activeProfileFlags,
                                              visibleNameCache,
                                              qualifiedNameCache,
                                              seen,
                                              out)
    names = out

fn ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfilesCached(sourcePathRaw: str,
                                                                         text: str,
                                                                         importcCallNames: str[],
                                                                         localCallNames: str[],
                                                                         externalCallNames: str[],
                                                                         currentProfile: NormalizedExprCallProfile,
                                                                         profiles: NormalizedExprCallProfile[],
                                                                         profileIndexLookup: ParserSourcePathIndexLookup,
                                                                         profileCallLookupCache: var ParserProfileCallLookupCacheEntry[],
                                                                         layer: var NormalizedExprLayer,
                                                                         err: var str): bool =
    let sourcePath = ParserNormalizePath(sourcePathRaw)
    var normalizedText = text
    if ParserSourceHasMultilineString(text):
        if !ParserRewriteMultilineStringSourceText(text, normalizedText, err):
            return false
    if sourcePath == "":
        err = "missing source path"
        return false
    layer = NormalizedExprLayer()
    layer.sourceCount = 1
    var localCallLookup = ParserTextLookupBuildExact(localCallNames)
    var externalCallLookup = ParserTextLookupBuildExact(externalCallNames)
    var importcCallLookup = ParserTextLookupBuildExact(importcCallNames)
    var knownCallLookup = ParserTextLookupInit(localCallNames.len +
                                                 externalCallNames.len +
                                                 importcCallNames.len + 8)
    ParserTextLookupAddAllExact(knownCallLookup, localCallNames)
    ParserTextLookupAddAllExact(knownCallLookup, externalCallNames)
    ParserTextLookupAddAllExact(knownCallLookup, importcCallNames)
    let codeLines = ParserPrepareCodeLines(ParserSplitChar(normalizedText, '\n'))
    var inTypeBlock = false
    var typeBlockIndent: int32 = -1
    for i in 0..<codeLines.len:
        if i % 128 == 0:
            os.ProcessResourceGuardCheck()
        let line = codeLines[i]
        if !ParserHasNonTrimChar(line):
            continue
        let lineNumber = i + 1
        let trimmedLine = chengpath.PathTrim(line)
        let lineIndent: int32 = ParserLineIndent(line)
        if inTypeBlock && lineIndent <= typeBlockIndent:
            inTypeBlock = false
        if !ParserHasLeadingIndent(line):
            inTypeBlock = trimmedLine == "type"
            if inTypeBlock:
                typeBlockIndent = lineIndent
        var redundantType = ""
        var redundantExpr = ""
        if ParserFindRedundantExplicitDefaultLine(line,
                                                    inTypeBlock,
                                                    currentProfile,
                                                    profiles,
                                                    redundantType,
                                                    redundantExpr):
            err = ParserRedundantExplicitDefaultError(redundantType, redundantExpr)
            return false
        if ParserRejectSpaceCallIfStrict(line, lineNumber, knownCallLookup, err):
            return false
        ParserAppendSimpleSurfaceExprsLine(sourcePath,
                                             lineNumber,
                                             line,
                                             true,
                                             true,
                                             true,
                                             layer)
        ParserAppendReturnStmtExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendAssignStmtExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendControlStmtExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        ParserAppendStringifyCallExprsLine(sourcePath,
                                             lineNumber,
                                             line,
                                             layer)
        if !ParserAppendDefaultInitExprsLine(sourcePath,
                                               lineNumber,
                                               line,
                                               currentProfile,
                                               profiles,
                                               layer,
                                               err):
            return false
        ParserAppendConstructorExprsLine(sourcePath,
                                           lineNumber,
                                           line,
                                           currentProfile,
                                           profiles,
                                           layer)
        ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &localCallLookup,
                                    NormalizedExprSurfaceCallLocal,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &externalCallLookup,
                                    NormalizedExprSurfaceCallExternal,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    &importcCallLookup,
                                    NormalizedExprSurfaceCallImportc,
                                    currentProfile,
                                    profiles,
                                    profileIndexLookup,
                                    profileCallLookupCache,
                                    layer)
        ParserAppendMemberCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          knownCallLookup,
                                          currentProfile,
                                          layer)
    layer.questionResidualCount = 0
    err = ""
    return true

fn ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw: str,
                                                                    text: str,
                                                                    importcCallNames: str[],
                                                                    localCallNames: str[],
                                                                    externalCallNames: str[],
                                                                    currentProfile: NormalizedExprCallProfile,
                                                                    profiles: NormalizedExprCallProfile[],
                                                                    profileIndexLookup: ParserSourcePathIndexLookup,
                                                                    layer: var NormalizedExprLayer,
                                                                    err: var str): bool =
    var profileCallLookupCache = ParserBuildProfileCallLookupCache(profiles)
    return ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfilesCached(sourcePathRaw,
                                                                                text,
                                                                                importcCallNames,
                                                                                localCallNames,
                                                                                externalCallNames,
                                                                                currentProfile,
                                                                                profiles,
                                                                                profileIndexLookup,
                                                                                profileCallLookupCache,
                                                                                layer,
                                                                                err)

fn ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePathRaw: str,
                                                         text: str,
                                                         importcCallNames: str[],
                                                         localCallNames: str[],
                                                         externalCallNames: str[],
                                                         layer: var NormalizedExprLayer,
                                                         err: var str): bool =
    var normalizedText = text
    if ParserSourceHasMultilineString(text):
        if !ParserRewriteMultilineStringSourceText(text, normalizedText, err):
            return false
    var currentProfile: NormalizedExprCallProfile
    currentProfile.sourcePath = ParserNormalizePath(sourcePathRaw)
    currentProfile.ownerModulePath = ""
    currentProfile.text = normalizedText
    currentProfile.lines = ParserSplitChar(normalizedText, '\n')
    currentProfile.decls = []
    currentProfile.typeDecls = []
    currentProfile.importcCallNames = ParserCloneTextSeq(importcCallNames)
    currentProfile.localCallNames = ParserCloneTextSeq(localCallNames)
    currentProfile.importEdges = []
    currentProfile.maxQualifiedCallDepth = ParserMaxQualifiedCallDepthLines(
        ParserPrepareCodeLines(currentProfile.lines))
    ParserReadNormalizedTypeDeclsLines(currentProfile.lines, currentProfile.typeDecls)
    var profiles: NormalizedExprCallProfile[]
    let profileIndexLookup = ParserSourcePathIndexLookupBuild(profiles)
    return ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw,
                                                                            normalizedText,
                                                                            importcCallNames,
                                                                            localCallNames,
                                                                            externalCallNames,
                                                                            currentProfile,
                                                                            profiles,
                                                                            profileIndexLookup,
                                                                            layer,
                                                                            err)

fn ParserReadNormalizedExprLayerFromText(sourcePathRaw: str,
                                           text: str,
                                           layer: var NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath = ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    var decls: NormalizedFunctionDecl[]
    var declErr = ""
    if !ParserReadNormalizedFunctionDecls(text, decls, declErr):
        err = declErr
        return false
    var importcCallNames: str[]
    var localCallNames: str[]
    ParserImportcCallNamesFromDecls(decls, importcCallNames)
    ParserLocalCallNamesFromDecls(decls, localCallNames)
    return ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePath,
                                                                 text,
                                                                 importcCallNames,
                                                                 localCallNames,
                                                                 [],
                                                                 layer,
                                                                 err)

fn ParserReadNormalizedExprLayerFromPath(sourcePathRaw: str,
                                           layer: var NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath: str = ParserNormalizePath(sourcePathRaw)
    if !ParserSourceExists(sourcePath):
        err = "source file missing"
        return false
    let text: str = chengpath.ReadTextFile("", sourcePath)
    if text == "":
        err = "failed to read source"
        return false
    return ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err)

fn ParserStringSeqContains(items: str[], targetRaw: str): bool =
    let target = chengpath.PathTrim(targetRaw)
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i], target):
            return true
    return false

fn ParserTextLookupDotCount(text: str): int32 =
    var count: int32
    var i: int32
    for i in i..<text.len:
        if text[i] == '.':
            count = count + 1
    return count

fn ParserTextLookupContentHash(text: str): int32 =
    var h: int32
    var i: int32
    for i in i..<text.len:
        h = h * 131 + Int32(text[i])
    if h < 0:
        h = -h
    return h

fn ParserTextLookupKeyExact(text: str): ParserTextLookupKey =
    var key: ParserTextLookupKey
    key.keyLen = text.len
    if text == "":
        key.firstCode = 0
        key.lastCode = 0
        key.dotCount = 0
        key.textHash = 0
        return key
    key.firstCode = Int32(text[0])
    key.lastCode = Int32(text[text.len - 1])
    var dotCount: int32
    var h: int32
    var i: int32
    for i in i..<text.len:
        let ch = text[i]
        if ch == '.':
            dotCount = dotCount + 1
        h = h * 131 + Int32(ch)
    if h < 0:
        h = -h
    key.dotCount = dotCount
    key.textHash = h
    return key

fn ParserTextLookupInit(minCap: int32): ParserTextLookup =
    var lookup: ParserTextLookup
    lookup.slots = []
    lookup.buckets = []
    lookup.totalCount = 0
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    for i in 0..<cap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(lookup.slots, 0)
    return lookup

fn ParserTextLookupHash(keyLen: int32,
                          firstCode: int32,
                          lastCode: int32,
                          dotCount: int32,
                          textHash: int32): int64 =
    var h: int64 = Int64(textHash)
    h = h * 131 + Int64(firstCode)
    h = h * 131 + Int64(lastCode)
    h = h * 131 + Int64(dotCount)
    h = h * 131 + Int64(keyLen)
    if h < 0:
        h = -h
    return h

fn ParserTextLookupSlotForParts(lookup: ParserTextLookup,
                                  keyLen: int32,
                                  firstCode: int32,
                                  lastCode: int32,
                                  dotCount: int32,
                                  textHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = Int32(ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    textHash) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        if lookup.buckets[bucketIndexPlus1 - 1].keyLen == keyLen &&
           lookup.buckets[bucketIndexPlus1 - 1].firstCode == firstCode &&
           lookup.buckets[bucketIndexPlus1 - 1].lastCode == lastCode &&
           lookup.buckets[bucketIndexPlus1 - 1].dotCount == dotCount &&
           lookup.buckets[bucketIndexPlus1 - 1].textHash == textHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn ParserTextLookupSlotForKey(lookup: ParserTextLookup,
                                key: ParserTextLookupKey): int32 =
    return ParserTextLookupSlotForParts(lookup,
                                          key.keyLen,
                                          key.firstCode,
                                          key.lastCode,
                                          key.dotCount,
                                          key.textHash)

fn ParserTextLookupRehash(lookup: var ParserTextLookup,
                            newCap: int32) =
    var slots: int32[]
    for i in 0..<newCap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(slots, 0)
    lookup.slots = slots
    for bucketIndex in 0..<lookup.buckets.len:
        if bucketIndex % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let slot = ParserTextLookupSlotForParts(lookup,
                                                  lookup.buckets[bucketIndex].keyLen,
                                                  lookup.buckets[bucketIndex].firstCode,
                                                  lookup.buckets[bucketIndex].lastCode,
                                                  lookup.buckets[bucketIndex].dotCount,
                                                  lookup.buckets[bucketIndex].textHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1

fn ParserTextLookupGrow(lookup: var ParserTextLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    ParserTextLookupRehash(lookup, nextCap)

fn ParserTextLookupBucketIndexExact(lookup: ParserTextLookup,
                                      text: str): int32 =
    if text == "":
        return -1
    return ParserTextLookupBucketIndexKey(lookup, ParserTextLookupKeyExact(text))

fn ParserTextLookupBucketIndexKey(lookup: ParserTextLookup,
                                    key: ParserTextLookupKey): int32 =
    if key.keyLen <= 0:
        return -1
    let slot = ParserTextLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn ParserTextLookupEnsureBucket(lookup: var ParserTextLookup,
                                  text: str): int32 =
    if text == "":
        return -1
    return ParserTextLookupEnsureBucketKey(lookup, ParserTextLookupKeyExact(text))

fn ParserTextLookupEnsureBucketKey(lookup: var ParserTextLookup,
                                     key: ParserTextLookupKey): int32 =
    if lookup.slots.len <= 0:
        lookup = ParserTextLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        ParserTextLookupGrow(lookup)
    let slot = ParserTextLookupSlotForKey(lookup, key)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: ParserTextLookupBucket
    bucket.keyLen = key.keyLen
    bucket.firstCode = key.firstCode
    bucket.lastCode = key.lastCode
    bucket.dotCount = key.dotCount
    bucket.textHash = key.textHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn ParserTextLookupInsertExact(lookup: var ParserTextLookup,
                                 value: str): bool =
    if value == "":
        return false
    return ParserTextLookupInsertKey(lookup, value, ParserTextLookupKeyExact(value))

fn ParserTextLookupInsertKey(lookup: var ParserTextLookup,
                               value: str,
                               key: ParserTextLookupKey): bool =
    if value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = ParserTextLookupEnsureBucketKey(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        if ParserTextEqualsExact(lookup.buckets[bucketIndex].items[i], value):
            return false
    add(lookup.buckets[bucketIndex].items, value)
    lookup.totalCount = lookup.totalCount + 1
    return true

fn ParserTextLookupAddExact(lookup: var ParserTextLookup,
                              value: str) =
    let _ = ParserTextLookupInsertExact(lookup, value)

fn ParserTextLookupAdd(lookup: var ParserTextLookup,
                         text: str) =
    let value = chengpath.PathTrim(text)
    ParserTextLookupAddExact(lookup, value)

fn ParserTextLookupAddAll(lookup: var ParserTextLookup,
                            items: str[]) =
    for i in 0..<items.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        ParserTextLookupAdd(lookup, items[i])

fn ParserTextLookupAddAllExact(lookup: var ParserTextLookup,
                                 items: str[]) =
    for i in 0..<items.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let value = items[i]
        if value == "":
            continue
        let _ = ParserTextLookupInsertKey(lookup, value, ParserTextLookupKeyExact(value))

fn ParserTextLookupBuild(items: str[]): ParserTextLookup =
    var lookup = ParserTextLookupInit(items.len * 2 + 8)
    ParserTextLookupAddAll(lookup, items)
    return lookup

fn ParserTextLookupBuildExact(items: str[]): ParserTextLookup =
    var lookup = ParserTextLookupInit(items.len * 2 + 8)
    ParserTextLookupAddAllExact(lookup, items)
    return lookup

fn ParserTextLookupContainsExact(lookup: ParserTextLookup,
                                   target: str): bool =
    if target == "":
        return false
    return ParserTextLookupContainsKey(lookup, target, ParserTextLookupKeyExact(target))

fn ParserTextLookupContainsKey(lookup: ParserTextLookup,
                                 value: str,
                                 key: ParserTextLookupKey): bool =
    if value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = ParserTextLookupBucketIndexKey(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup.buckets[bucketIndex].items.len:
        if ParserTextEqualsExact(lookup.buckets[bucketIndex].items[i], value):
            return true
    return false

fn ParserTextLookupSlotForPartsPtr(lookup: ParserTextLookup*,
                                     keyLen: int32,
                                     firstCode: int32,
                                     lastCode: int32,
                                     dotCount: int32,
                                     textHash: int32): int32 =
    if lookup == nil || lookup->slots.len <= 0:
        return -1
    let mask = lookup->slots.len - 1
    var probe: int32 = Int32(ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    textHash) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup->slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucketIndex = bucketIndexPlus1 - 1
        if lookup->buckets[bucketIndex].keyLen == keyLen &&
           lookup->buckets[bucketIndex].firstCode == firstCode &&
           lookup->buckets[bucketIndex].lastCode == lastCode &&
           lookup->buckets[bucketIndex].dotCount == dotCount &&
           lookup->buckets[bucketIndex].textHash == textHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn ParserTextLookupSlotForKeyPtr(lookup: ParserTextLookup*,
                                   key: ParserTextLookupKey): int32 =
    return ParserTextLookupSlotForPartsPtr(lookup,
                                             key.keyLen,
                                             key.firstCode,
                                             key.lastCode,
                                             key.dotCount,
                                             key.textHash)

fn ParserTextLookupBucketIndexKeyPtr(lookup: ParserTextLookup*,
                                       key: ParserTextLookupKey): int32 =
    if lookup == nil || key.keyLen <= 0:
        return -1
    let slot = ParserTextLookupSlotForKeyPtr(lookup, key)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup->slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn ParserTextLookupContainsKeyPtr(lookup: ParserTextLookup*,
                                    value: str,
                                    key: ParserTextLookupKey): bool =
    if lookup == nil || value == "" || key.keyLen <= 0:
        return false
    let bucketIndex = ParserTextLookupBucketIndexKeyPtr(lookup, key)
    if bucketIndex < 0:
        return false
    for i in 0..<lookup->buckets[bucketIndex].items.len:
        if ParserTextEqualsExact(lookup->buckets[bucketIndex].items[i], value):
            return true
    return false

fn ParserMatchKnownCallSurfaceTextKeysPtr(callLookup: ParserTextLookup*,
                                            callName: str,
                                            callNameKey: ParserTextLookupKey,
                                            qualifiedCallName: str,
                                            qualifiedCallNameKey: ParserTextLookupKey,
                                            dottedCallName: str,
                                            dottedCallNameKey: ParserTextLookupKey): str =
    if dottedCallName != callName &&
       ParserTextLookupContainsKeyPtr(callLookup,
                                        dottedCallName,
                                        dottedCallNameKey):
        return dottedCallName
    if qualifiedCallName != callName &&
       ParserTextLookupContainsKeyPtr(callLookup,
                                        qualifiedCallName,
                                        qualifiedCallNameKey):
        return qualifiedCallName
    if dottedCallName != callName:
        return ""
    if ParserTextLookupContainsKeyPtr(callLookup, callName, callNameKey):
        return callName
    return ""

fn ParserSourcePathIndexLookupInit(minCap: int32): ParserSourcePathIndexLookup =
    var lookup: ParserSourcePathIndexLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    for i in 0..<cap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(lookup.slots, 0)
    return lookup

fn ParserSourcePathIndexLookupSlotForParts(lookup: ParserSourcePathIndexLookup,
                                             keyLen: int32,
                                             firstCode: int32,
                                             lastCode: int32,
                                             dotCount: int32,
                                             sourcePathHash: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = Int32(ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount,
                                                    sourcePathHash) & Int64(mask))
    var scanned: int32
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        if lookup.buckets[bucketIndexPlus1 - 1].keyLen == keyLen &&
           lookup.buckets[bucketIndexPlus1 - 1].firstCode == firstCode &&
           lookup.buckets[bucketIndexPlus1 - 1].lastCode == lastCode &&
           lookup.buckets[bucketIndexPlus1 - 1].dotCount == dotCount &&
           lookup.buckets[bucketIndexPlus1 - 1].sourcePathHash == sourcePathHash:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn ParserSourcePathIndexLookupRehash(lookup: var ParserSourcePathIndexLookup,
                                       newCap: int32) =
    var slots: int32[]
    for i in 0..<newCap:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(slots, 0)
    lookup.slots = slots
    for bucketIndex in 0..<lookup.buckets.len:
        if bucketIndex % 4096 == 0:
            os.ProcessResourceGuardCheck()
        let slot = ParserSourcePathIndexLookupSlotForParts(lookup,
                                                             lookup.buckets[bucketIndex].keyLen,
                                                             lookup.buckets[bucketIndex].firstCode,
                                                             lookup.buckets[bucketIndex].lastCode,
                                                             lookup.buckets[bucketIndex].dotCount,
                                                             lookup.buckets[bucketIndex].sourcePathHash)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1

fn ParserSourcePathIndexLookupGrow(lookup: var ParserSourcePathIndexLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    ParserSourcePathIndexLookupRehash(lookup, nextCap)

fn ParserSourcePathIndexBucketIndexExact(lookup: ParserSourcePathIndexLookup,
                                           sourcePath: str): int32 =
    if sourcePath == "":
        return -1
    let keyLen = sourcePath.len
    let firstCode = Int32(sourcePath[0])
    let lastCode = Int32(sourcePath[keyLen - 1])
    let dotCount = ParserTextLookupDotCount(sourcePath)
    let sourcePathHash = ParserTextLookupContentHash(sourcePath)
    let slot = ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         keyLen,
                                                         firstCode,
                                                         lastCode,
                                                         dotCount,
                                                         sourcePathHash)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn ParserSourcePathIndexEnsureBucket(lookup: var ParserSourcePathIndexLookup,
                                       sourcePath: str): int32 =
    if lookup.slots.len <= 0:
        lookup = ParserSourcePathIndexLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        ParserSourcePathIndexLookupGrow(lookup)
    let keyLen = sourcePath.len
    let firstCode = Int32(sourcePath[0])
    let lastCode = Int32(sourcePath[keyLen - 1])
    let dotCount = ParserTextLookupDotCount(sourcePath)
    let sourcePathHash = ParserTextLookupContentHash(sourcePath)
    let slot = ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         keyLen,
                                                         firstCode,
                                                         lastCode,
                                                         dotCount,
                                                         sourcePathHash)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: ParserSourcePathIndexBucket
    bucket.keyLen = keyLen
    bucket.firstCode = firstCode
    bucket.lastCode = lastCode
    bucket.dotCount = dotCount
    bucket.sourcePathHash = sourcePathHash
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn ParserSourcePathIndexLookupInsertExact(lookup: var ParserSourcePathIndexLookup,
                                            sourcePath: str,
                                            profileIndex: int32) =
    if sourcePath == "" || profileIndex < 0:
        return
    let bucketIndex = ParserSourcePathIndexEnsureBucket(lookup, sourcePath)
    if bucketIndex < 0:
        return
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i].sourcePath, sourcePath):
            return
    var entry: ParserSourcePathIndexEntry
    entry.sourcePath = sourcePath
    entry.profileIndex = profileIndex
    add(lookup.buckets[bucketIndex].items, entry)

fn ParserSourcePathIndexLookupBuild(profiles: NormalizedExprCallProfile[]): ParserSourcePathIndexLookup =
    var lookup = ParserSourcePathIndexLookupInit(profiles.len * 2 + 8)
    for i in 0..<profiles.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        ParserSourcePathIndexLookupInsertExact(lookup,
                                                 ParserNormalizePath(profiles[i].sourcePath),
                                                 i)
    return lookup

fn ParserProfileIndexLookupForNormalizedSourcePathExact(lookup: ParserSourcePathIndexLookup,
                                                          sourcePath: str): int32 =
    if sourcePath == "":
        return -1
    let bucketIndex = ParserSourcePathIndexBucketIndexExact(lookup, sourcePath)
    if bucketIndex < 0:
        return -1
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i].sourcePath, sourcePath):
            return items[i].profileIndex
    return -1

fn ParserSourcePathIndexBucketIndexForImportEdgeTargetSourcePath(lookup: ParserSourcePathIndexLookup,
                                                                   edge: ImportEdge): int32 =
    if edge.targetSourcePath == "":
        return -1
    let slot = ParserSourcePathIndexLookupSlotForParts(lookup,
                                                         edge.targetSourcePathLen,
                                                         edge.targetSourcePathFirstCode,
                                                         edge.targetSourcePathLastCode,
                                                         edge.targetSourcePathDotCount,
                                                         edge.targetSourcePathHash)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn ParserProfileIndexLookupForImportEdgeTargetSourcePath(lookup: ParserSourcePathIndexLookup,
                                                           edge: ImportEdge): int32 =
    let bucketIndex = ParserSourcePathIndexBucketIndexForImportEdgeTargetSourcePath(lookup, edge)
    if bucketIndex < 0:
        return -1
    let items = lookup.buckets[bucketIndex].items
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i].sourcePath, edge.targetSourcePath):
            return items[i].profileIndex
    return -1

fn ParserImportEdgeTargetProfileIndex(edge: ImportEdge,
                                        profileIndexLookup: ParserSourcePathIndexLookup): int32 =
    if edge.targetProfileIndex >= 0:
        return edge.targetProfileIndex
    return ParserProfileIndexLookupForImportEdgeTargetSourcePath(profileIndexLookup, edge)

fn ParserBindImportEdgeTargetProfileIndices(profiles: var NormalizedExprCallProfile[],
                                              profileIndexLookup: ParserSourcePathIndexLookup) =
    for profileIndex in 0..<profiles.len:
        if profileIndex % 256 == 0:
            os.ProcessResourceGuardCheck()
        var profile = profiles[profileIndex]
        for edgeIndex in 0..<profile.importEdges.len:
            if edgeIndex % 256 == 0:
                os.ProcessResourceGuardCheck()
            var edge = profile.importEdges[edgeIndex]
            edge.targetProfileIndex = -1
            if edge.resolved:
                edge.targetProfileIndex = ParserProfileIndexLookupForImportEdgeTargetSourcePath(profileIndexLookup,
                                                                                                  edge)
            profile.importEdges[edgeIndex] = edge
        profiles[profileIndex] = profile

fn ParserProfileIndexLookupForSourcePath(lookup: ParserSourcePathIndexLookup,
                                           sourcePathRaw: str): int32 =
    return ParserProfileIndexLookupForNormalizedSourcePathExact(lookup,
                                                                  ParserNormalizePath(sourcePathRaw))

fn ParserBuildProfileCallLookups(profile: NormalizedExprCallProfile): ParserProfileCallLookupCacheEntry =
    var entry: ParserProfileCallLookupCacheEntry
    entry.localLookup = ParserTextLookupBuildExact(profile.localCallNames)
    entry.importcLookup = ParserTextLookupBuildExact(profile.importcCallNames)
    return entry

fn ParserBuildProfileCallLookupCache(profiles: NormalizedExprCallProfile[]): ParserProfileCallLookupCacheEntry[] =
    var out: ParserProfileCallLookupCacheEntry[]
    for i in 0..<profiles.len:
        if i % 16 == 0:
            os.ProcessResourceGuardCheck()
        add(out, ParserBuildProfileCallLookups(profiles[i]))
    return out

fn ParserProfileCallLookupCacheEnsureIndex(profiles: NormalizedExprCallProfile[],
                                             profileIndex: int32,
                                             cache: var ParserProfileCallLookupCacheEntry[]): int32 =
    if profileIndex < 0:
        return -1
    if profileIndex >= profiles.len:
        return -1
    while cache.len <= profileIndex:
        if cache.len % 256 == 0:
            os.ProcessResourceGuardCheck()
        var empty: ParserProfileCallLookupCacheEntry
        empty.localLookup.slots = []
        empty.localLookup.buckets = []
        empty.localLookup.totalCount = 0
        empty.importcLookup.slots = []
        empty.importcLookup.buckets = []
        empty.importcLookup.totalCount = 0
        add(cache, empty)
    let entry = cache[profileIndex]
    var shouldBuild = false
    if entry.localLookup.slots.len <= 0:
        if entry.importcLookup.slots.len <= 0:
            shouldBuild = true
    if shouldBuild:
        os.ProcessResourceGuardCheck()
        cache[profileIndex] = ParserBuildProfileCallLookups(profiles[profileIndex])
    return profileIndex

fn ParserAppendUniqueLookupTextExact(out: var str[],
                                       seen: var ParserTextLookup,
                                       value: str) =
    if value == "":
        return
    ParserAppendUniqueLookupTextKey(out, seen, value, ParserTextLookupKeyExact(value))

fn ParserAppendUniqueLookupTextKey(out: var str[],
                                     seen: var ParserTextLookup,
                                     value: str,
                                     valueKey: ParserTextLookupKey) =
    if value == "" || valueKey.keyLen <= 0:
        return
    if ParserTextLookupInsertKey(seen, value, valueKey):
        add(out, value)

fn ParserAppendUniqueLookupText(out: var str[],
                                  seen: var ParserTextLookup,
                                  text: str) =
    let value = chengpath.PathTrim(text)
    ParserAppendUniqueLookupTextExact(out, seen, value)

fn ParserMatchKnownCallSurfaceText(callLookup: ParserTextLookup,
                                     callName: str,
                                     qualifiedCallName: str,
                                     dottedCallName: str): str =
    let callNameKey = ParserTextLookupKeyExact(callName)
    let qualifiedCallNameKey = ParserTextLookupKeyExact(qualifiedCallName)
    let dottedCallNameKey = ParserTextLookupKeyExact(dottedCallName)
    return ParserMatchKnownCallSurfaceTextKeys(callLookup,
                                                 callName,
                                                 callNameKey,
                                                 qualifiedCallName,
                                                 qualifiedCallNameKey,
                                                 dottedCallName,
                                                 dottedCallNameKey)

fn ParserMatchKnownCallSurfaceTextKeys(callLookup: ParserTextLookup,
                                         callName: str,
                                         callNameKey: ParserTextLookupKey,
                                         qualifiedCallName: str,
                                         qualifiedCallNameKey: ParserTextLookupKey,
                                         dottedCallName: str,
                                         dottedCallNameKey: ParserTextLookupKey): str =
    if dottedCallName != callName &&
       ParserTextLookupContainsKey(callLookup,
                                     dottedCallName,
                                     dottedCallNameKey):
        return dottedCallName
    if qualifiedCallName != callName &&
       ParserTextLookupContainsKey(callLookup,
                                     qualifiedCallName,
                                     qualifiedCallNameKey):
        return qualifiedCallName
    if dottedCallName != callName:
        return ""
    if ParserTextLookupContainsKey(callLookup, callName, callNameKey):
        return callName
    return ""

fn ParserProfileHasImportQualifier(profile: NormalizedExprCallProfile,
                                     qualifierRaw: str): bool =
    let qualifier = ParserIdentPrefix(chengpath.PathTrim(qualifierRaw))
    if qualifier == "":
        return false
    for i in 0..<profile.importEdges.len:
        if !profile.importEdges[i].resolved:
            continue
        if profile.importEdges[i].qualifier == qualifier:
            return true
    return false

fn ParserStringSeqContainsExact(items: str[], target: str): bool =
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i], target):
            return true
    return false

fn ParserIsInlineSpace(ch: char): bool =
    let code = Int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    return false

fn ParserFirstToken(textRaw: str): str =
    let text = chengpath.PathTrim(textRaw)
    if text == "":
        return ""
    var start: int32
    while start < text.len:
        if !ParserIsInlineSpace(text[start]):
            break
        start = start + 1
    var stop: int32 = start
    while stop < text.len:
        if ParserIsInlineSpace(text[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return ParserTextSliceFast(text, start, stop - start)

fn ParserIdentPrefix(text: str): str =
    var stop: int32
    for i in 0..<text.len:
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            stop = i + 1
        else:
            break
    if stop <= 0:
        return ""
    return ParserTextSliceFast(text, 0, stop)

fn ParserTextSliceFast(text: str,
                         startRaw: int32,
                         countRaw: int32): str =
    if countRaw <= 0:
        return ""
    let textLen = text.len
    if textLen <= 0:
        return ""
    var start = startRaw
    if start < 0:
        start = 0
    if start >= textLen:
        return ""
    var count = countRaw
    if start + count > textLen:
        count = textLen - start
    if count <= 0:
        return ""
    let data = StrDataPtr(text)
    if data == nil:
        return ""
    var out: str
    out.data = SystemPtrAdd(data, start)
    out.len = count
    out.store_id = text.store_id
    out.flags = 0
    return out

fn ParserSplitChar(textRaw: str, sep: char): str[] =
    let text = textRaw
    var partCount: int32 = 1
    for i in 0..<text.len:
        if text[i] == sep:
            partCount = partCount + 1
    var out: str[]
    setLen(out, partCount)
    var start: int32
    var outIndex: int32
    for i in 0..<text.len:
        if text[i] == sep:
            out[outIndex] = ParserTextSliceFast(text, start, i - start)
            outIndex = outIndex + 1
            start = i + 1
    if start <= text.len:
        out[outIndex] = ParserTextSliceFast(text, start, text.len - start)
    return out

fn ParserJoinSlash(items: str[]): str =
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    for i in 0..<items.len:
        if items[i] == "":
            continue
        if wrote:
            buffer.AppendText(out, slash)
        buffer.AppendText(out, items[i])
        wrote = true
    return rawbytes.BytesToString(buffer.ToBytes(out))

fn ParserStartsWith(textRaw: str, prefixRaw: str): bool =
    let text = chengpath.PathTrim(textRaw)
    let prefix = chengpath.PathTrim(prefixRaw)
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn ParserStartsWithExact(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn ParserLineStartsWith(lineRaw: str, prefix: str): bool =
    return ParserStartsWith(lineRaw, prefix)

fn ParserFindText(text: str, needle: str): int32 =
    if needle.len <= 0:
        return 0
    if needle.len == 1:
        let target = needle[0]
        for i in 0..<text.len:
            if text[i] == target:
                return i
        return -1
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn ParserCompilerTopLevelExportName(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    if !ParserStartsWithExact(line, "@compiler_top_level("):
        return ""
    let exportPos = ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = ParserFindText(chengpath.TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = chengpath.TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return chengpath.TextSlice(line, valueStart, quoteEnd)

fn ParserCompilerTopLevelExportNameExact(line: str): str =
    if !ParserStartsWithExact(line, "@compiler_top_level("):
        return ""
    let exportPos = ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = ParserFindText(chengpath.TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = chengpath.TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return chengpath.TextSlice(line, valueStart, quoteEnd)

fn ParserExportcNameFromAnnotation(lineRaw: str): str =
    let line = chengpath.PathTrim(lineRaw)
    if !ParserStartsWithExact(line, "@exportc("):
        return ""
    let quoteStart = ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = chengpath.TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return chengpath.TextSlice(line, quoteStart + 1, quoteEnd)

fn ParserExportcNameFromAnnotationExact(line: str): str =
    if !ParserStartsWithExact(line, "@exportc("):
        return ""
    let quoteStart = ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = chengpath.TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return chengpath.TextSlice(line, quoteStart + 1, quoteEnd)

fn ParserIsImportcAnnotation(lineRaw: str): bool =
    return ParserStartsWith(lineRaw, "@importc(")

fn ParserIsImportcAnnotationExact(line: str): bool =
    return ParserStartsWithExact(line, "@importc(")

fn ParserFfiMapAnnotationExact(line: str): bool =
    return ParserStartsWithExact(line, "@ffi_map(")

fn ParserFfiOutPtrsAnnotationExact(line: str): bool =
    return ParserStartsWithExact(line, "@ffi_out_ptrs(")

fn ParserArgIndexFromName(name: str): int32 =
    if !ParserStartsWithExact(name, "arg"):
        return -1
    let numPart = chengpath.TextSlice(name, 3, name.len - 3)
    if numPart.len <= 0:
        return -1
    var val: int32
    for i in 0..<numPart.len:
        let ch = numPart[i]
        if ch < '0' || ch > '9':
            return -1
        val = val * 10 + Int32(ch - '0')
    return val

fn ParserParseFfiMapAnnotation(line: str,
                                ptrArg: var int32,
                                lenArg: var int32): bool =
    ptrArg = -1
    lenArg = -1
    if !ParserFfiMapAnnotationExact(line):
        return false
    let openPos = ParserFindText(line, "(")
    let closePos = ParserFindText(line, ")")
    if openPos < 0 || closePos <= openPos:
        return false
    let content = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let parts = ParserSplitTopLevelCsv(content)
    if parts.len == 0:
        return false
    var hasEquals = false
    for i in 0..<parts.len:
        if ParserFindText(chengpath.PathTrim(parts[i]), "=") >= 0:
            hasEquals = true
            break
    if !hasEquals && parts.len == 2:
        ptrArg = ParserArgIndexFromName(chengpath.PathTrim(parts[0]))
        lenArg = ParserArgIndexFromName(chengpath.PathTrim(parts[1]))
    else:
        for i in 0..<parts.len:
            let part = chengpath.PathTrim(parts[i])
            let eqPos = ParserFindText(part, "=")
            if eqPos < 0:
                continue
            let key = chengpath.PathTrim(chengpath.TextSlice(part, 0, eqPos))
            let value = chengpath.PathTrim(chengpath.TextSlice(part, eqPos + 1, part.len - eqPos - 1))
            let idx = ParserArgIndexFromName(value)
            if idx < 0:
                continue
            if key == "ptr":
                ptrArg = idx
            elif key == "len":
                lenArg = idx
    return true

fn ParserParseFfiOutPtrsAnnotation(line: str): str =
    if !ParserFfiOutPtrsAnnotationExact(line):
        return ""
    let openPos = ParserFindText(line, "(")
    let closePos = ParserFindText(line, ")")
    if openPos < 0 || closePos <= openPos:
        return ""
    let content = chengpath.TextSlice(line, openPos + 1, closePos - openPos - 1)
    let parts = ParserSplitTopLevelCsv(content)
    if parts.len == 0:
        return ""
    var indices: int32[]
    for i in 0..<parts.len:
        let idx = ParserArgIndexFromName(chengpath.PathTrim(parts[i]))
        if idx >= 0:
            add(indices, idx)
    if indices.len <= 0:
        return ""
    var out: str = IntToStr(indices[0])
    for i in 1..<indices.len:
        out = ParserConcat3(out, ",", IntToStr(indices[i]))
    return out

fn ParserHasLeadingIndent(lineRaw: str): bool =
    if Len(lineRaw) <= 0:
        return false
    let head = Int32(lineRaw[0])
    return head == 32 || head == 9

fn ParserTopLevelFunctionPrefixLenKeywordExact(line: str,
                                                 keyword: var str): int32 =
    if ParserStartsWithExact(line, "importc fn "):
        keyword = "fn"
        return Len("importc fn ")
    if ParserStartsWithExact(line, "fn "):
        keyword = "fn"
        return Len("fn ")
    if ParserStartsWithExact(line, "func "):
        keyword = "func"
        return Len("func ")
    if ParserStartsWithExact(line, "proc "):
        keyword = "proc"
        return Len("proc ")
    if ParserStartsWithExact(line, "method "):
        keyword = "method"
        return Len("method ")
    if ParserStartsWithExact(line, "converter "):
        keyword = "converter"
        return Len("converter ")
    keyword = ""
    return 0

fn ParserTopLevelFunctionPrefixLenKeywordRange(lineRaw: str,
                                                 lineStart: int32,
                                                 lineStop: int32,
                                                 keyword: var str): int32 =
    if lineStart + Len("importc fn ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("importc fn "), "importc fn "):
        keyword = "fn"
        return Len("importc fn ")
    if lineStart + Len("fn ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("fn "), "fn "):
        keyword = "fn"
        return Len("fn ")
    if lineStart + Len("func ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("func "), "func "):
        keyword = "func"
        return Len("func ")
    if lineStart + Len("proc ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("proc "), "proc "):
        keyword = "proc"
        return Len("proc ")
    if lineStart + Len("method ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("method "), "method "):
        keyword = "method"
        return Len("method ")
    if lineStart + Len("converter ") <= lineStop &&
       ParserTextRangeEquals(lineRaw, lineStart, Len("converter "), "converter "):
        keyword = "converter"
        return Len("converter ")
    keyword = ""
    return 0

fn ParserTopLevelFunctionKeywordExact(line: str): str =
    var keyword: str
    let prefixLen = ParserTopLevelFunctionPrefixLenKeywordExact(line, keyword)
    if prefixLen < 0:
        return ""
    return keyword

fn ParserTopLevelFunctionKeyword(lineRaw: str): str =
    if ParserHasLeadingIndent(lineRaw):
        return ""
    let line = chengpath.PathTrim(lineRaw)
    return ParserTopLevelFunctionKeywordExact(line)

fn ParserFunctionNameFromTrimmedLineWithPrefix(line: str,
                                                 prefixLen: int32): str =
    if prefixLen <= 0:
        return ""
    if prefixLen >= line.len:
        return ""
    var start = prefixLen
    while start < line.len:
        if !ParserIsInlineSpace(line[start]):
            break
        start = start + 1
    if start >= line.len:
        return ""
    var stop = start
    while stop < line.len:
        if !ParserIsIdentChar(line[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return ParserTextSliceFast(line, start, stop - start)

fn ParserFunctionNameFromTrimmedRangeWithPrefix(lineRaw: str,
                                                  lineStart: int32,
                                                  lineStop: int32,
                                                  prefixLen: int32): str =
    if prefixLen <= 0:
        return ""
    let startBase = lineStart + prefixLen
    if startBase >= lineStop:
        return ""
    var start = startBase
    while start < lineStop:
        if !ParserIsInlineSpace(lineRaw[start]):
            break
        start = start + 1
    if start >= lineStop:
        return ""
    var stop = start
    while stop < lineStop:
        if !ParserIsIdentChar(lineRaw[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return ParserTextSliceFast(lineRaw, start, stop - start)

fn ParserFunctionNameFromTrimmedLine(line: str): str =
    var keyword: str
    let prefixLen = ParserTopLevelFunctionPrefixLenKeywordExact(line, keyword)
    return ParserFunctionNameFromTrimmedLineWithPrefix(line, prefixLen)

fn ParserFunctionNameFromLine(lineRaw: str): str =
    if ParserHasLeadingIndent(lineRaw):
        return ""
    let line = chengpath.PathTrim(lineRaw)
    return ParserFunctionNameFromTrimmedLine(line)

fn ParserReadNormalizedFunctionDeclsLines(lines: str[],
                                            decls: var NormalizedFunctionDecl[],
                                            err: var str): bool =
    var emptyDecls: NormalizedFunctionDecl[]
    decls = emptyDecls
    var pendingImportc = false
    var pendingExplicitExportName: str
    var pendingFfiMapPtrArg: int32 = -1
    var pendingFfiMapLenArg: int32 = -1
    var pendingFfiOutPtrArgs: str
    for i in 0..<lines.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let lineRaw = lines[i]
        var lineStart: int32
        var lineStop: int32
        if !ParserTrimmedLineRange(lineRaw, lineStart, lineStop):
            continue
        if ParserHasLeadingIndent(lineRaw):
            continue
        if lineRaw[lineStart] == '@':
            let trimmed = ParserTextSliceFast(lineRaw, lineStart, lineStop - lineStart)
            let compilerExportName = ParserCompilerTopLevelExportNameExact(trimmed)
            if compilerExportName != "":
                pendingExplicitExportName = compilerExportName
                continue
            let exportcName = ParserExportcNameFromAnnotationExact(trimmed)
            if exportcName != "":
                pendingExplicitExportName = exportcName
                continue
            if ParserIsImportcAnnotationExact(trimmed):
                pendingImportc = true
                pendingExplicitExportName = ""
                continue
            var ffiMapPtr: int32
            var ffiMapLen: int32
            if ParserParseFfiMapAnnotation(trimmed, ffiMapPtr, ffiMapLen):
                pendingFfiMapPtrArg = ffiMapPtr
                pendingFfiMapLenArg = ffiMapLen
                continue
            if ParserFfiOutPtrsAnnotationExact(trimmed):
                pendingFfiOutPtrArgs = ParserParseFfiOutPtrsAnnotation(trimmed)
                continue
            continue
        var keyword: str
        let prefixLen = ParserTopLevelFunctionPrefixLenKeywordRange(lineRaw,
                                                                      lineStart,
                                                                      lineStop,
                                                                      keyword)
        if keyword == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            pendingFfiMapPtrArg = -1
            pendingFfiMapLenArg = -1
            pendingFfiOutPtrArgs = ""
            continue
        if keyword != "fn":
            err = ParserConcat3("unsupported top-level function alias '", keyword, "'")
            return false
        let functionName = ParserFunctionNameFromTrimmedRangeWithPrefix(lineRaw,
                                                                          lineStart,
                                                                          lineStop,
                                                                          prefixLen)
        if functionName == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            pendingFfiMapPtrArg = -1
            pendingFfiMapLenArg = -1
            pendingFfiOutPtrArgs = ""
            continue
        let inlineImportc = prefixLen == Len("importc fn ")
        var decl: NormalizedFunctionDecl
        decl.name = functionName
        decl.lineIndex = i + 1
        decl.importc = pendingImportc || inlineImportc
        decl.explicitExportName = decl.importc ? "" : pendingExplicitExportName
        decl.surfaceKeyword = inlineImportc ? "importc fn" : "fn"
        decl.ffiMapPtrArg = pendingFfiMapPtrArg
        decl.ffiMapLenArg = pendingFfiMapLenArg
        decl.ffiOutPtrArgs = pendingFfiOutPtrArgs
        add(decls, decl)
        pendingImportc = false
        pendingExplicitExportName = ""
        pendingFfiMapPtrArg = -1
        pendingFfiMapLenArg = -1
        pendingFfiOutPtrArgs = ""
    err = ""
    return true

fn ParserReadNormalizedFunctionDecls(textRaw: str,
                                       decls: var NormalizedFunctionDecl[],
                                       err: var str): bool =
    var text = textRaw
    if ParserSourceHasMultilineString(textRaw):
        if !ParserRewriteMultilineStringSourceText(textRaw, text, err):
            return false
    let lines = ParserSplitChar(text, '\n')
    return ParserReadNormalizedFunctionDeclsLines(lines, decls, err)

fn ParserContainsCompilerPrefix(lineRaw: str): bool =
    let line = chengpath.PathTrim(lineRaw)
    if ParserStartsWithExact(line, "import "):
        return true
    if ParserStartsWithExact(line, "type"):
        return true
    if ParserTopLevelFunctionKeywordExact(line) != "":
        return true
    if ParserStartsWithExact(line, "iterator "):
        return true
    if ParserStartsWithExact(line, "const "):
        return true
    if ParserStartsWithExact(line, "let "):
        return true
    if ParserStartsWithExact(line, "var "):
        return true
    return false

fn ParserModulePathTail(modulePath: str, skipCount: int32): str =
    let modulePathTrim = chengpath.PathTrim(modulePath)
    let parts = ParserSplitChar(modulePathTrim, '/')
    var out: str[]
    for i in skipCount..<parts.len:
        let rawPiece = parts[i]
        let piece = chengpath.PathTrim(rawPiece)
        if piece != "":
            add(out, piece)
    return ParserJoinSlash(out)

fn ParserModulePathTailExact(modulePath: str, skipCount: int32): str =
    if modulePath == "":
        return ""
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    var pieceIndex: int32
    var start: int32
    var cursor: int32
    while cursor <= modulePath.len:
        let atEnd = cursor >= modulePath.len
        var stop = false
        if atEnd:
            stop = true
        elif modulePath[cursor] == '/':
            stop = true
        if !stop:
            cursor = cursor + 1
            continue
        if pieceIndex >= skipCount && cursor > start:
            if wrote:
                buffer.AppendText(out, slash)
            buffer.AppendText(out, ParserTextSliceFast(modulePath, start, cursor - start))
            wrote = true
        pieceIndex = pieceIndex + 1
        start = cursor + 1
        cursor = cursor + 1
    return rawbytes.BytesToString(buffer.ToBytes(out))

fn ParserPathSlash(pathRaw: str): str =
    return ParserJoinSlash(ParserSplitChar(pathRaw, '\\'))

fn ParserRelWithoutExt(pathRaw: str): str =
    let path = ParserPathSlash(ParserNormalizePath(pathRaw))
    if path.len >= 6 && chengpath.TextSlice(path, path.len - 6, 6) == ".cheng":
        return chengpath.TextSlice(path, 0, path.len - 6)
    return path

fn ParserSharedPackageRoot(workspaceRootRaw: str): str =
    let envRoot = ParserNormalizePath(os.GetEnv("CHENG_ROOT"))
    if envRoot != "":
        if ParserPackageId(envRoot) == "cheng":
            return envRoot
    let workspaceRoot = ParserNormalizePath(workspaceRootRaw)
    if workspaceRoot == "":
        return ""
    if ParserPackageId(workspaceRoot) == "cheng":
        return workspaceRoot
    let sharedRoot = ParserSharedRoot(workspaceRoot)
    if sharedRoot != "":
        return sharedRoot
    return ""

fn ParserSharedBuiltinSourceRoot(workspaceRootRaw: str): str =
    let envRoot = ParserNormalizePath(os.GetEnv("CHENG_ROOT"))
    if envRoot != "":
        return envRoot
    return ParserNormalizePath(workspaceRootRaw)

fn ParserSharedBuiltinModulePathToSourcePath(sharedSourceRootRaw: str,
                                               modulePathRaw: str): str =
    let sharedSourceRoot = ParserNormalizePath(sharedSourceRootRaw)
    let modulePath = chengpath.PathTrim(modulePathRaw)
    if sharedSourceRoot == "" || modulePath == "":
        return ""
    if ParserStartsWithExact(modulePath, "std/") && modulePath.len > 4:
        let rel: str = ParserModulePathTailExact(modulePath, 1)
        return ParserConcat3(ParserConcat2(sharedSourceRoot, "/src/std/"), rel, ".cheng")
    if ParserStartsWithExact(modulePath, "runtime/") && modulePath.len > 8:
        let rel: str = ParserModulePathTailExact(modulePath, 1)
        return ParserConcat3(ParserConcat2(sharedSourceRoot, "/src/runtime/"), rel, ".cheng")
    return ""

fn ParserSharedBuiltinSourcePathToModulePath(sharedSourceRootRaw: str,
                                               sourcePathRaw: str): str =
    let sharedSourceRoot = ParserNormalizePath(sharedSourceRootRaw)
    let sourcePath = ParserNormalizePath(sourcePathRaw)
    if sharedSourceRoot == "" || sourcePath == "":
        return ""
    let stdPrefix: str = ParserConcat2(sharedSourceRoot, "/src/std/")
    if ParserStartsWithExact(sourcePath, stdPrefix):
        let rel: str = ParserRelWithoutExt(chengpath.TextSlice(sourcePath,
                                                                stdPrefix.len,
                                                                sourcePath.len - stdPrefix.len))
        if rel == "":
            return "std"
        return ParserConcat2("std/", rel)
    let runtimePrefix: str = ParserConcat2(sharedSourceRoot, "/src/runtime/")
    if ParserStartsWithExact(sourcePath, runtimePrefix):
        let rel: str = ParserRelWithoutExt(chengpath.TextSlice(sourcePath,
                                                                runtimePrefix.len,
                                                                sourcePath.len - runtimePrefix.len))
        if rel == "":
            return "runtime"
        return ParserConcat2("runtime/", rel)
    return ""

fn ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot: str,
                                                                  packageRoot: str,
                                                                  sharedPackageRoot: str,
                                                                  packageId: str,
                                                                  packagePrefix: str,
                                                                  externalPackageRoots: ParserExternalPackageRoot[],
                                                                  modulePath: str): str =
    if modulePath == "":
        return ""
    let sharedBuiltinSourcePath = ParserSharedBuiltinModulePathToSourcePath(ParserSharedBuiltinSourceRoot(workspaceRoot),
                                                                              modulePath)
    if sharedBuiltinSourcePath != "":
        return sharedBuiltinSourcePath
    if packageId != "" && modulePath.len > packageId.len && ParserStartsWithExact(modulePath, packagePrefix):
        let rel: str = chengpath.TextSlice(modulePath,
                                          packagePrefix.len,
                                          modulePath.len - packagePrefix.len)
        return ParserConcat3(ParserConcat2(packageRoot, "/src/"), rel, ".cheng")
    var externalPackageRoot = ""
    var externalPackageId = ""
    var externalPackagePrefix = ""
    if ParserExternalPackageRootByModulePath(modulePath,
                                               externalPackageRoots,
                                               externalPackageRoot,
                                               externalPackageId,
                                               externalPackagePrefix):
        let rel = chengpath.TextSlice(modulePath,
                                     externalPackagePrefix.len,
                                     modulePath.len - externalPackagePrefix.len)
        return ParserConcat3(ParserConcat2(externalPackageRoot, "/src/"), rel, ".cheng")
    if sharedPackageRoot != "" &&
       ParserStartsWithExact(modulePath, "cheng/") &&
       modulePath.len > 6:
        let rel: str = ParserModulePathTailExact(modulePath, 1)
        return ParserConcat3(ParserConcat2(sharedPackageRoot, "/src/"), rel, ".cheng")
    return ""

fn ParserModulePathToSourcePathPrepared(workspaceRoot: str,
                                          packageRoot: str,
                                          sharedPackageRoot: str,
                                          packageId: str,
                                          packagePrefix: str,
                                          modulePath: str): str =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                          packageRoot,
                                                                          sharedPackageRoot,
                                                                          packageId,
                                                                          packagePrefix,
                                                                          externalPackageRoots,
                                                                          modulePath)

fn ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRootRaw: str,
                                                          packageRootRaw: str,
                                                          externalPackageRoots: ParserExternalPackageRoot[],
                                                          modulePathRaw: str): str =
    let workspaceRoot: str = ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = ParserNormalizePath(packageRootRaw)
    let modulePath: str = chengpath.PathTrim(modulePathRaw)
    let sharedPackageRoot: str = ParserSharedPackageRoot(workspaceRoot)
    let packageId: str = ParserPackageId(packageRoot)
    let packagePrefix: str = ParserConcat2(packageId, "/")
    return ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                          packageRoot,
                                                                          sharedPackageRoot,
                                                                          packageId,
                                                                          packagePrefix,
                                                                          externalPackageRoots,
                                                                          modulePath)

fn ParserModulePathToSourcePath(workspaceRootRaw: str, packageRootRaw: str, modulePathRaw: str): str =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRootRaw,
                                                                  packageRootRaw,
                                                                  externalPackageRoots,
                                                                  modulePathRaw)

fn ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRootRaw: str,
                                                          packageRootRaw: str,
                                                          externalPackageRoots: ParserExternalPackageRoot[],
                                                          sourcePathRaw: str): str =
    let workspaceRoot: str = ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = ParserNormalizePath(packageRootRaw)
    let sourcePath: str = ParserNormalizePath(sourcePathRaw)
    let sharedBuiltinModulePath = ParserSharedBuiltinSourcePathToModulePath(ParserSharedBuiltinSourceRoot(workspaceRoot),
                                                                              sourcePath)
    if sharedBuiltinModulePath != "":
        return sharedBuiltinModulePath
    let packagePrefix: str = ParserConcat2(packageRoot, "/src/")
    if ParserStartsWithExact(sourcePath, packagePrefix):
        let rel: str = ParserRelWithoutExt(chengpath.TextSlice(sourcePath,
                                                                packagePrefix.len,
                                                                sourcePath.len - packagePrefix.len))
        let packageId: str = ParserPackageId(packageRoot)
        if rel == "":
            return packageId
        return ParserConcat3(packageId, "/", rel)
    let sharedPackageRoot: str = ParserSharedPackageRoot(workspaceRoot)
    let sharedPrefix: str = ParserConcat2(sharedPackageRoot, "/src/")
    if sharedPackageRoot != "" && ParserStartsWithExact(sourcePath, sharedPrefix):
        let rel: str = ParserRelWithoutExt(chengpath.TextSlice(sourcePath,
                                                                sharedPrefix.len,
                                                                sourcePath.len - sharedPrefix.len))
        if rel == "":
            return "cheng"
        return ParserConcat2("cheng/", rel)
    var externalPackageRoot = ""
    var externalPackageId = ""
    if ParserExternalPackageRootBySourcePath(sourcePath,
                                               externalPackageRoots,
                                               externalPackageRoot,
                                               externalPackageId):
        let externalPrefix: str = ParserConcat2(externalPackageRoot, "/src/")
        let rel: str = ParserRelWithoutExt(chengpath.TextSlice(sourcePath,
                                                                externalPrefix.len,
                                                                sourcePath.len - externalPrefix.len))
        if rel == "":
            return externalPackageId
        return ParserConcat3(externalPackageId, "/", rel)
    return ParserFileStem(sourcePath)

fn ParserSourcePathToModulePath(workspaceRootRaw: str, packageRootRaw: str, sourcePathRaw: str): str =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRootRaw,
                                                                  packageRootRaw,
                                                                  externalPackageRoots,
                                                                  sourcePathRaw)

fn ParserHasCompilerTopLevel(textRaw: str): bool =
    var text = textRaw
    var err = ""
    if ParserSourceHasMultilineString(textRaw):
        if !ParserRewriteMultilineStringSourceText(textRaw, text, err):
            return false
    let lines = ParserSplitChar(text, '\n')
    var decls: NormalizedFunctionDecl[]
    if ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        if decls.len > 0:
            return true
    for i in 0..<lines.len:
        if ParserContainsCompilerPrefix(lines[i]):
            return true
    return false

fn ParserMainFunctionPresent(textRaw: str): bool =
    var text = textRaw
    var err = ""
    if ParserSourceHasMultilineString(textRaw):
        if !ParserRewriteMultilineStringSourceText(textRaw, text, err):
            return false
    let lines = ParserSplitChar(text, '\n')
    var decls: NormalizedFunctionDecl[]
    if !ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        return false
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "main":
            return true
    return false

fn ParserAppendImportEdgeWithExternalPackageRoots(workspaceRoot: str,
                                                    packageRoot: str,
                                                    externalPackageRoots: ParserExternalPackageRoot[],
                                                    ownerModulePath: str,
                                                    modulePathRaw: str,
                                                    importAliasRaw: str,
                                                    edges: var ImportEdge[],
                                                    err: var str): bool =
    let normalizedWorkspaceRoot = ParserNormalizePath(workspaceRoot)
    let normalizedPackageRoot = ParserNormalizePath(packageRoot)
    let modulePath = chengpath.PathTrim(modulePathRaw)
    let importAlias = chengpath.PathTrim(importAliasRaw)
    let sharedPackageRoot: str = ParserSharedPackageRoot(normalizedWorkspaceRoot)
    let packageId: str = ParserPackageId(normalizedPackageRoot)
    let packagePrefix: str = ParserConcat2(packageId, "/")
    return ParserAppendImportEdgePreparedWithExternalPackageRoots(normalizedWorkspaceRoot,
                                                                    normalizedPackageRoot,
                                                                    sharedPackageRoot,
                                                                    packageId,
                                                                    packagePrefix,
                                                                    externalPackageRoots,
                                                                    ownerModulePath,
                                                                    modulePath,
                                                                    importAlias,
                                                                    edges,
                                                                    err)

fn ParserAppendImportEdge(workspaceRoot: str,
                            packageRoot: str,
                            ownerModulePath: str,
                            modulePathRaw: str,
                            importAliasRaw: str,
                            edges: var ImportEdge[],
                            err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserAppendImportEdgeWithExternalPackageRoots(workspaceRoot,
                                                            packageRoot,
                                                            externalPackageRoots,
                                                            ownerModulePath,
                                                            modulePathRaw,
                                                            importAliasRaw,
                                                            edges,
                                                            err)

fn ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot: str,
                                                            packageRoot: str,
                                                            sharedPackageRoot: str,
                                                            packageId: str,
                                                            packagePrefix: str,
                                                            externalPackageRoots: ParserExternalPackageRoot[],
                                                            ownerModulePath: str,
                                                            modulePath: str,
                                                            importAlias: str,
                                                            edges: var ImportEdge[],
                                                            err: var str): bool =
    if modulePath == "":
        err = " parser: malformed import"
        return false
    let sourcePath = ParserModulePathToSourcePathPreparedWithExternalPackageRoots(workspaceRoot,
                                                                                    packageRoot,
                                                                                    sharedPackageRoot,
                                                                                    packageId,
                                                                                    packagePrefix,
                                                                                    externalPackageRoots,
                                                                                    modulePath)
    let resolved = ParserSourceExists(sourcePath)
    var edge: ImportEdge
    edge.ownerModulePath = ownerModulePath
    edge.targetModulePath = modulePath
    edge.targetSourcePath = sourcePath
    edge.targetSourcePathLen = sourcePath.len
    if sourcePath == "":
        edge.targetSourcePathFirstCode = 0
        edge.targetSourcePathLastCode = 0
        edge.targetSourcePathDotCount = 0
        edge.targetSourcePathHash = 0
    else:
        edge.targetSourcePathFirstCode = Int32(sourcePath[0])
        edge.targetSourcePathLastCode = Int32(sourcePath[sourcePath.len - 1])
        edge.targetSourcePathDotCount = ParserTextLookupDotCount(sourcePath)
        edge.targetSourcePathHash = ParserTextLookupContentHash(sourcePath)
    edge.targetProfileIndex = -1
    edge.importAlias = importAlias
    edge.qualifier = ""
    let aliasText = ParserIdentPrefix(edge.importAlias)
    if aliasText != "":
        edge.qualifier = aliasText
    else:
        let sourceStem = ParserFileStem(edge.targetSourcePath)
        if sourceStem != "":
            edge.qualifier = sourceStem
        else:
            edge.qualifier = ParserLastPathPiece(edge.targetModulePath)
    edge.allowsUnqualifiedCall = edge.importAlias == ""
    edge.resolved = resolved
    add(edges, edge)
    err = ""
    return true

fn ParserAppendImportEdgePrepared(workspaceRoot: str,
                                    packageRoot: str,
                                    sharedPackageRoot: str,
                                    packageId: str,
                                    packagePrefix: str,
                                    ownerModulePath: str,
                                    modulePath: str,
                                    importAlias: str,
                                    edges: var ImportEdge[],
                                    err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                    packageRoot,
                                                                    sharedPackageRoot,
                                                                    packageId,
                                                                    packagePrefix,
                                                                    externalPackageRoots,
                                                                    ownerModulePath,
                                                                    modulePath,
                                                                    importAlias,
                                                                    edges,
                                                                    err)

fn ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot: str,
                                                        packageRoot: str,
                                                        externalPackageRoots: ParserExternalPackageRoot[],
                                                        ownerModulePath: str,
                                                        lines: str[],
                                                        edges: var ImportEdge[],
                                                        err: var str): bool =
    edges = []
    let sharedPackageRoot: str = ParserSharedPackageRoot(workspaceRoot)
    let packageId: str = ParserPackageId(packageRoot)
    let packagePrefix: str = ParserConcat2(packageId, "/")
    for i in 0..<lines.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        let rawLine = lines[i]
        var importTailStart: int32 = -1
        var importTailStop: int32 = -1
        if !ParserImportLineTailRange(rawLine, importTailStart, importTailStop):
            continue
        let importTail = ParserTrimmedSliceRange(rawLine, importTailStart, importTailStop)
        let asMarker = " as "
        let asPos = ParserFindText(importTail, asMarker)
        var importSpec = ""
        var importAlias = ""
        if asPos >= 0:
            importSpec = ParserTrimmedSliceRange(importTail, 0, asPos)
            let aliasTailStart = asPos + Len(asMarker)
            if aliasTailStart < importTail.len:
                let aliasTail = ParserTrimmedSliceRange(importTail,
                                                          aliasTailStart,
                                                          importTail.len)
                importAlias = ParserIdentPrefix(aliasTail)
        else:
            importSpec = importTail
        let groupedOpenPos = ParserFindText(importSpec, "/[")
        if groupedOpenPos >= 0:
            if importAlias != "":
                err = " parser: grouped import alias unsupported"
                return false
            let groupedClosePos = ParserFindText(importSpec, "]")
            if groupedClosePos < 0 || groupedClosePos != importSpec.len - 1:
                err = " parser: malformed grouped import"
                return false
            let groupPrefix = ParserTrimmedSliceRange(importSpec, 0, groupedOpenPos)
            let groupItemsText = chengpath.TextSlice(importSpec,
                                                    groupedOpenPos + 2,
                                                    groupedClosePos - (groupedOpenPos + 2))
            if groupPrefix == "" || groupItemsText == "":
                err = " parser: malformed grouped import"
                return false
            var appended = false
            var start: int32
            var itemPos: int32
            while itemPos <= Len(groupItemsText):
                let atEnd = itemPos >= Len(groupItemsText)
                var stop = false
                if atEnd:
                    stop = true
                elif groupItemsText[itemPos] == ',':
                    stop = true
                if !stop:
                    itemPos = itemPos + 1
                    continue
                let item = ParserTrimmedSliceRange(groupItemsText, start, itemPos)
                if Len(item) > 0:
                    if !ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                                 packageRoot,
                                                                                 sharedPackageRoot,
                                                                                 packageId,
                                                                                 packagePrefix,
                                                                                 externalPackageRoots,
                                                                                 ownerModulePath,
                                                                                 ParserConcat3(groupPrefix, "/", item),
                                                                                 "",
                                                                                 edges,
                                                                                 err):
                        return false
                    appended = true
                start = itemPos + 1
                itemPos = itemPos + 1
            if !appended:
                err = " parser: malformed grouped import"
                return false
            continue
        if !ParserAppendImportEdgePreparedWithExternalPackageRoots(workspaceRoot,
                                                                     packageRoot,
                                                                     sharedPackageRoot,
                                                                     packageId,
                                                                     packagePrefix,
                                                                     externalPackageRoots,
                                                                     ownerModulePath,
                                                                     importSpec,
                                                                     importAlias,
                                                                     edges,
                                                                     err):
            return false
    err = ""
    return true

fn ParserReadImportEdgesLines(workspaceRoot: str,
                                packageRoot: str,
                                ownerModulePath: str,
                                lines: str[],
                                edges: var ImportEdge[],
                                err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                packageRoot,
                                                                externalPackageRoots,
                                                                ownerModulePath,
                                                                lines,
                                                                edges,
                                                                err)

fn ParserReadImportEdgesWithExternalPackageRoots(workspaceRoot: str,
                                                   packageRoot: str,
                                                   externalPackageRoots: ParserExternalPackageRoot[],
                                                   ownerModulePath: str,
                                                   textRaw: str,
                                                   edges: var ImportEdge[],
                                                   err: var str): bool =
    var text = textRaw
    if ParserSourceHasMultilineString(textRaw):
        if !ParserRewriteMultilineStringSourceText(textRaw, text, err):
            return false
    let lines = ParserSplitChar(text, '\n')
    return ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                packageRoot,
                                                                externalPackageRoots,
                                                                ownerModulePath,
                                                                lines,
                                                                edges,
                                                                err)

fn ParserReadImportEdges(workspaceRoot: str,
                           packageRoot: str,
                           ownerModulePath: str,
                           textRaw: str,
                           edges: var ImportEdge[],
                           err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserReadImportEdgesWithExternalPackageRoots(workspaceRoot,
                                                           packageRoot,
                                                           externalPackageRoots,
                                                           ownerModulePath,
                                                           textRaw,
                                                           edges,
                                                           err)

fn ImportEdgeTargetSourcePath(edge: ImportEdge): str =
    return edge.targetSourcePath

fn ParserAddUniqueImportEdge(edges: var ImportEdge[],
                               edge: ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn ParserAddUniqueText(items: var str[],
                         text: str) =
    let value = chengpath.PathTrim(text)
    ParserAddUniqueTextExact(items, value)

fn ParserAddUniqueTextExact(items: var str[],
                              value: str) =
    if value == "":
        return
    for i in 0..<items.len:
        if ParserTextEqualsExact(items[i], value):
            return
    add(items, value)

fn ParserCollectClosureWithExternalPackageRoots(workspaceRoot: str,
                                                  packageRoot: str,
                                                  externalPackageRoots: ParserExternalPackageRoot[],
                                                  sourcePathRaw: str,
                                                  seen: var str[],
                                                  ordered: var str[],
                                                  importEdges: var ImportEdge[],
                                                  unresolved: var int32,
                                                  err: var str): bool =
    let sourcePath: str = chengpath.PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = " parser: missing closure source path"
        return false
    if ParserStringSeqContainsExact(seen, sourcePath):
        err = ""
        return true
    if !ParserSourceExists(sourcePath):
        err = " parser: missing source"
        return false
    if !ParserStringSeqContainsExact(seen, sourcePath):
        add(seen, sourcePath)
        add(ordered, sourcePath)
    var scanPos: int32
    while scanPos < ordered.len:
        os.ProcessResourceGuardCheck()
        let currentSourcePath = ordered[scanPos]
        scanPos = scanPos + 1
        let rawText = ParserOwnedText(chengpath.ReadTextFile("", currentSourcePath))
        var text = rawText
        if ParserSourceHasMultilineString(rawText):
            if !ParserRewriteMultilineStringSourceText(rawText, text, err):
                return false
        let lines = ParserSplitChar(text, '\n')
        let ownerModulePath = ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                     packageRoot,
                                                                                     externalPackageRoots,
                                                                                     currentSourcePath)
        var edges: ImportEdge[]
        if !ParserReadImportEdgesLinesWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 ownerModulePath,
                                                                 lines,
                                                                 edges,
                                                                 err):
            return false
        for i in 0..<edges.len:
            ParserAddUniqueImportEdge(importEdges, edges[i])
            let childSourcePath = edges[i].targetSourcePath
            if !edges[i].resolved:
                unresolved = unresolved + 1
                continue
            if ParserStringSeqContainsExact(seen, childSourcePath):
                continue
            add(seen, childSourcePath)
            add(ordered, childSourcePath)
    err = ""
    return true

fn ParserCollectClosure(workspaceRoot: str,
                          packageRoot: str,
                          sourcePathRaw: str,
                          seen: var str[],
                          ordered: var str[],
                          importEdges: var ImportEdge[],
                          unresolved: var int32,
                          err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParserCollectClosureWithExternalPackageRoots(workspaceRoot,
                                                          packageRoot,
                                                          externalPackageRoots,
                                                          sourcePathRaw,
                                                          seen,
                                                          ordered,
                                                          importEdges,
                                                          unresolved,
                                                          err)

fn ParserReadNormalizedExprLayerForSourceClosureWithExternalPackageRoots(workspaceRoot: str,
                                                                           packageRoot: str,
                                                                           externalPackageRoots: ParserExternalPackageRoot[],
                                                                           ordered: str[],
                                                                           exprLayer: var NormalizedExprLayer,
                                                                           err: var str): bool =
    exprLayer = NormalizedExprLayer()
    var sourceProfiles: NormalizedExprCallProfile[]
    for i in 0..<ordered.len:
        os.ProcessResourceGuardCheck()
        let sourceText = ParserOwnedText(chengpath.ReadTextFile("", ordered[i]))
        var profile: NormalizedExprCallProfile
        var profileErr = ""
        if !ParserBuildExprCallProfileWithExternalPackageRoots(workspaceRoot,
                                                                 packageRoot,
                                                                 externalPackageRoots,
                                                                 ordered[i],
                                                                 sourceText,
                                                                 profile,
                                                                 profileErr):
            err = profileErr
            return false
        add(sourceProfiles, profile)
    let profileIndexLookup = ParserSourcePathIndexLookupBuild(sourceProfiles)
    ParserBindImportEdgeTargetProfileIndices(sourceProfiles, profileIndexLookup)
    var externalVisibleNameCache: ParserTextSeqCacheEntry[]
    var externalQualifiedNameCache: ParserQualifiedTextSeqCacheEntry[]
    var profileCallLookupCache = ParserBuildProfileCallLookupCache(sourceProfiles)
    for i in 0..<sourceProfiles.len:
        os.ProcessResourceGuardCheck()
        if os.GetEnv("CHENG_TRACE_PARSE_SOURCE") == "1":
            let tracePath = sourceProfiles[i].sourcePath
            echo(strutil.Join(["parse_source ", tracePath], ""))
        var sourceExprLayer = NormalizedExprLayer()
        var sourceExternalCallNames: str[]
        ParserCollectExternalCallNamesCached(sourceProfiles,
                                               profileIndexLookup,
                                               i,
                                               externalVisibleNameCache,
                                               externalQualifiedNameCache,
                                               sourceExternalCallNames)
        if !ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfilesCached(sourceProfiles[i].sourcePath,
                                                                                  sourceProfiles[i].text,
                                                                                  sourceProfiles[i].importcCallNames,
                                                                                  sourceProfiles[i].localCallNames,
                                                                                  sourceExternalCallNames,
                                                                                  sourceProfiles[i],
                                                                                  sourceProfiles,
                                                                                  profileIndexLookup,
                                                                                  profileCallLookupCache,
                                                                                  sourceExprLayer,
                                                                                  err):
            err = ParserConcat4(" parser: ", sourceProfiles[i].sourcePath, ": ", err)
            return false
        NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
    err = ""
    return true

fn ParseOrdinarySourceStubCoreWithExternalPackageRoots(packageRootRaw: str,
                                                        sourcePathRaw: str,
                                                        externalPackageRoots: ParserExternalPackageRoot[],
                                                        buildExprLayer: bool,
                                                        parsed: var ParsedSourceStub,
                                                        err: var str): bool =
    let packageRoot: str = ParserNormalizePath(packageRootRaw)
    let sourcePath: str = ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = " parser: missing source path"
        return false
    if !ParserSourceExists(sourcePath):
        err = " parser: source file missing"
        return false
    let workspaceRoot: str = ParserWorkspaceRoot(packageRoot)
    let packageId: str = ParserPackageId(packageRoot)
    let moduleStem: str = ParserFileStem(sourcePath)
    let rawRootText: str = ParserOwnedText(chengpath.ReadTextFile("", sourcePath))
    var rootText = rawRootText
    if ParserSourceHasMultilineString(rawRootText):
        if !ParserRewriteMultilineStringSourceText(rawRootText, rootText, err):
            return false
    if rootText == "":
        err = " parser: failed to read source"
        return false
    var rootDecls: NormalizedFunctionDecl[]
    if !ParserReadNormalizedFunctionDecls(rootText, rootDecls, err):
        return false
    var seen: str[]
    var ordered: str[]
    var importEdges: ImportEdge[]
    var unresolved: int32
    if !ParserCollectClosureWithExternalPackageRoots(workspaceRoot,
                                                       packageRoot,
                                                       externalPackageRoots,
                                                       sourcePath,
                                                       seen,
                                                       ordered,
                                                       importEdges,
                                                       unresolved,
                                                       err):
        return false
    var exprLayer = NormalizedExprLayer()
    if buildExprLayer:
        if !ParserReadNormalizedExprLayerForSourceClosureWithExternalPackageRoots(workspaceRoot,
                                                                                   packageRoot,
                                                                                   externalPackageRoots,
                                                                                   ordered,
                                                                                   exprLayer,
                                                                                   err):
            return false
    var ownerModulePaths: str[]
    for i in 0..<ordered.len:
        ParserAddUniqueText(ownerModulePaths,
                              ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                    packageRoot,
                                                                                    externalPackageRoots,
                                                                                    ordered[i]))
    parsed.workspaceRoot = workspaceRoot
    parsed.packageRoot = packageRoot
    parsed.packageId = packageId
    parsed.entrySourcePath = sourcePath
    parsed.sourcePath = sourcePath
    parsed.moduleStem = moduleStem
    parsed.syntaxTag = "cheng_normalized_source"
    parsed.sourceKind = ParsedOrdinarySource
    parsed.ownerModulePaths = ownerModulePaths
    parsed.importEdges = importEdges
    parsed.orderedClosureSourcePaths = ordered
    parsed.normalizedExprLayer = exprLayer
    parsed.hasCompilerTopLevel = ParserHasCompilerTopLevel(rootText)
    parsed.mainFunctionPresent = false
    for i in 0..<rootDecls.len:
        if rootDecls[i].importc:
            continue
        if rootDecls[i].name == "main":
            parsed.mainFunctionPresent = true
    parsed.unresolvedImportCount = unresolved
    err = ""
    return true

fn ParseOrdinarySourceHeaderStubWithExternalPackageRoots(packageRootRaw: str,
                                                          sourcePathRaw: str,
                                                          externalPackageRoots: ParserExternalPackageRoot[],
                                                          parsed: var ParsedSourceStub,
                                                          err: var str): bool =
    let buildExprLayer = false
    return ParseOrdinarySourceStubCoreWithExternalPackageRoots(packageRootRaw,
                                                                sourcePathRaw,
                                                                externalPackageRoots,
                                                                buildExprLayer,
                                                                parsed,
                                                                err)

fn ParseOrdinarySourceStubWithExternalPackageRoots(packageRootRaw: str,
                                                     sourcePathRaw: str,
                                                     externalPackageRoots: ParserExternalPackageRoot[],
                                                     parsed: var ParsedSourceStub,
                                                     err: var str): bool =
    let buildExprLayer = true
    return ParseOrdinarySourceStubCoreWithExternalPackageRoots(packageRootRaw,
                                                                sourcePathRaw,
                                                                externalPackageRoots,
                                                                buildExprLayer,
                                                                parsed,
                                                                err)

fn ParseOrdinarySourceStub(packageRootRaw: str,
                             sourcePathRaw: str,
                             parsed: var ParsedSourceStub,
                             err: var str): bool =
    var externalPackageRoots: ParserExternalPackageRoot[]
    return ParseOrdinarySourceStubWithExternalPackageRoots(packageRootRaw,
                                                             sourcePathRaw,
                                                             externalPackageRoots,
                                                             parsed,
                                                             err)
