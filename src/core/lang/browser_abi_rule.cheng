type
    V3BrowserAbiInputKind = enum
        v3BrowserAbiInputNone
        v3BrowserAbiInputScalarNone
        v3BrowserAbiInputScalarI32_1
        v3BrowserAbiInputScalarI32_2
        v3BrowserAbiInputScalarI32_4
        v3BrowserAbiInputBytesRequired
        v3BrowserAbiInputTextRequired
        v3BrowserAbiInputTextOptional

    V3BrowserAbiOutputKind = enum
        v3BrowserAbiOutputNone
        v3BrowserAbiOutputScalarI32
        v3BrowserAbiOutputBytes
        v3BrowserAbiOutputText

    V3BrowserAbiErrorKind = enum
        v3BrowserAbiErrorInlineNone
        v3BrowserAbiErrorInlineResultError
        v3BrowserAbiErrorMoqFountainLastError

    V3BrowserAbiResultKind = enum
        v3BrowserAbiResultNone
        v3BrowserAbiResultScalarI32
        v3BrowserAbiResultBytes
        v3BrowserAbiResultText
        v3BrowserAbiResultHandle
        v3BrowserAbiResultStatusI32

    V3BrowserAbiOutBufferKind = enum
        v3BrowserAbiOutBufferNone
        v3BrowserAbiOutBufferRawHandle
        v3BrowserAbiOutBufferTextHandle

    V3BrowserAbiBridgeStage = enum
        v3BrowserAbiBridgeStageInputRead
        v3BrowserAbiBridgeStageOutputWrite
        v3BrowserAbiBridgeStageResultExport
        v3BrowserAbiBridgeStageErrorHandleRead
        v3BrowserAbiBridgeStageScalarCall

    V3BrowserAbiOutputSchemaKind = enum
        v3BrowserAbiOutputSchemaNone
        v3BrowserAbiOutputSchemaScalarI32
        v3BrowserAbiOutputSchemaBytesHandle
        v3BrowserAbiOutputSchemaTextHandle

    V3BrowserAbiRule =
        sourcePath: str
        ruleName: str
        inputKind: V3BrowserAbiInputKind
        outputKind: V3BrowserAbiOutputKind
        errorKind: V3BrowserAbiErrorKind
        resultKind: V3BrowserAbiResultKind
        outBufferKind: V3BrowserAbiOutBufferKind
        ruleKey: str

    V3BrowserAbiBridgeSpec =
        sourcePath: str
        ruleName: str
        bridgeStage: V3BrowserAbiBridgeStage
        inputSchemaKind: V3BrowserAbiInputKind
        outputSchemaKind: V3BrowserAbiOutputSchemaKind
        errorSchemaKind: V3BrowserAbiErrorKind
        resultKind: V3BrowserAbiResultKind
        outBufferKind: V3BrowserAbiOutBufferKind
        bridgeKey: str

    V3BrowserAbiBridgePlan =
        sourcePath: str
        ruleName: str
        bridgeStage: V3BrowserAbiBridgeStage
        inputSchemaKind: V3BrowserAbiInputKind
        outputSchemaKind: V3BrowserAbiOutputSchemaKind
        errorSchemaKind: V3BrowserAbiErrorKind
        resultKind: V3BrowserAbiResultKind
        outBufferKind: V3BrowserAbiOutBufferKind
        bridgeKey: str
        helperName: str
        emitLine: str

fn v3BrowserAbiInputKindText(kind: V3BrowserAbiInputKind): str =
    if kind == v3BrowserAbiInputScalarNone:
        return "scalar_none"
    if kind == v3BrowserAbiInputScalarI32_1:
        return "scalar_i32_1"
    if kind == v3BrowserAbiInputScalarI32_2:
        return "scalar_i32_2"
    if kind == v3BrowserAbiInputScalarI32_4:
        return "scalar_i32_4"
    if kind == v3BrowserAbiInputBytesRequired:
        return "bytes_required"
    if kind == v3BrowserAbiInputTextRequired:
        return "text_required"
    if kind == v3BrowserAbiInputTextOptional:
        return "text_optional"
    return "none"

fn v3BrowserAbiOutputKindText(kind: V3BrowserAbiOutputKind): str =
    if kind == v3BrowserAbiOutputScalarI32:
        return "scalar_i32"
    if kind == v3BrowserAbiOutputBytes:
        return "bytes"
    if kind == v3BrowserAbiOutputText:
        return "text"
    return "none"

fn v3BrowserAbiErrorKindText(kind: V3BrowserAbiErrorKind): str =
    if kind == v3BrowserAbiErrorInlineResultError:
        return "inline_result_error"
    if kind == v3BrowserAbiErrorMoqFountainLastError:
        return "moq_fountain_last_error"
    return "inline_none"

fn v3BrowserAbiResultKindText(kind: V3BrowserAbiResultKind): str =
    if kind == v3BrowserAbiResultScalarI32:
        return "scalar_i32"
    if kind == v3BrowserAbiResultBytes:
        return "result_bytes"
    if kind == v3BrowserAbiResultText:
        return "result_text"
    if kind == v3BrowserAbiResultHandle:
        return "handle_result"
    if kind == v3BrowserAbiResultStatusI32:
        return "status_i32"
    return "none"

fn v3BrowserAbiOutBufferKindText(kind: V3BrowserAbiOutBufferKind): str =
    if kind == v3BrowserAbiOutBufferRawHandle:
        return "raw_handle"
    if kind == v3BrowserAbiOutBufferTextHandle:
        return "text_handle"
    return "none"

fn v3BrowserAbiBridgeStageText(stage: V3BrowserAbiBridgeStage): str =
    if stage == v3BrowserAbiBridgeStageOutputWrite:
        return "output_write"
    if stage == v3BrowserAbiBridgeStageResultExport:
        return "result_export"
    if stage == v3BrowserAbiBridgeStageErrorHandleRead:
        return "error_handle_read"
    if stage == v3BrowserAbiBridgeStageScalarCall:
        return "scalar_call"
    return "input_read"

fn v3BrowserAbiOutputSchemaKindText(kind: V3BrowserAbiOutputSchemaKind): str =
    if kind == v3BrowserAbiOutputSchemaScalarI32:
        return "scalar_i32"
    if kind == v3BrowserAbiOutputSchemaBytesHandle:
        return "bytes_handle"
    if kind == v3BrowserAbiOutputSchemaTextHandle:
        return "text_handle"
    return "none"

fn v3BrowserAbiRuleKey(inputKind: V3BrowserAbiInputKind,
                       outputKind: V3BrowserAbiOutputKind,
                       errorKind: V3BrowserAbiErrorKind,
                       resultKind: V3BrowserAbiResultKind,
                       outBufferKind: V3BrowserAbiOutBufferKind): str =
    return Fmt(["input=",
                v3BrowserAbiInputKindText(inputKind),
                "|output=",
                v3BrowserAbiOutputKindText(outputKind),
                "|error=",
                v3BrowserAbiErrorKindText(errorKind),
                "|result=",
                v3BrowserAbiResultKindText(resultKind),
                "|out_buffer=",
                v3BrowserAbiOutBufferKindText(outBufferKind)])

fn v3BrowserAbiBridgeKey(bridgeStage: V3BrowserAbiBridgeStage,
                         inputSchemaKind: V3BrowserAbiInputKind,
                         outputSchemaKind: V3BrowserAbiOutputSchemaKind,
                         errorSchemaKind: V3BrowserAbiErrorKind,
                         resultKind: V3BrowserAbiResultKind,
                         outBufferKind: V3BrowserAbiOutBufferKind): str =
    return Fmt(["stage=",
                v3BrowserAbiBridgeStageText(bridgeStage),
                "|input_schema=",
                v3BrowserAbiInputKindText(inputSchemaKind),
                "|output_schema=",
                v3BrowserAbiOutputSchemaKindText(outputSchemaKind),
                "|error_schema=",
                v3BrowserAbiErrorKindText(errorSchemaKind),
                "|result=",
                v3BrowserAbiResultKindText(resultKind),
                "|out_buffer=",
                v3BrowserAbiOutBufferKindText(outBufferKind)])

fn v3BrowserAbiRuleNew(sourcePath: str,
                       ruleName: str,
                       inputKind: V3BrowserAbiInputKind,
                       outputKind: V3BrowserAbiOutputKind,
                       errorKind: V3BrowserAbiErrorKind,
                       resultKind: V3BrowserAbiResultKind,
                       outBufferKind: V3BrowserAbiOutBufferKind): V3BrowserAbiRule =
    var out: V3BrowserAbiRule
    out.sourcePath = sourcePath
    out.ruleName = ruleName
    out.inputKind = inputKind
    out.outputKind = outputKind
    out.errorKind = errorKind
    out.resultKind = resultKind
    out.outBufferKind = outBufferKind
    out.ruleKey = v3BrowserAbiRuleKey(inputKind,
                                      outputKind,
                                      errorKind,
                                      resultKind,
                                      outBufferKind)
    return out

fn v3BrowserAbiRuleClone(rule: V3BrowserAbiRule): V3BrowserAbiRule =
    var out: V3BrowserAbiRule
    out.sourcePath = rule.sourcePath
    out.ruleName = rule.ruleName
    out.inputKind = rule.inputKind
    out.outputKind = rule.outputKind
    out.errorKind = rule.errorKind
    out.resultKind = rule.resultKind
    out.outBufferKind = rule.outBufferKind
    out.ruleKey = rule.ruleKey
    return out

fn v3BrowserAbiRulesClone(rules: V3BrowserAbiRule[]): V3BrowserAbiRule[] =
    var out: V3BrowserAbiRule[]
    for i in 0..<rules.len:
        add(out, v3BrowserAbiRuleClone(rules[i]))
    return out

fn v3BrowserAbiRuleEqual(lhs: V3BrowserAbiRule,
                         rhs: V3BrowserAbiRule): bool =
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.ruleName != rhs.ruleName:
        return false
    if lhs.inputKind != rhs.inputKind:
        return false
    if lhs.outputKind != rhs.outputKind:
        return false
    if lhs.errorKind != rhs.errorKind:
        return false
    if lhs.resultKind != rhs.resultKind:
        return false
    if lhs.outBufferKind != rhs.outBufferKind:
        return false
    return lhs.ruleKey == rhs.ruleKey

fn v3BrowserAbiRulesEqual(lhs: V3BrowserAbiRule[],
                          rhs: V3BrowserAbiRule[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !v3BrowserAbiRuleEqual(lhs[i], rhs[i]):
            return false
    return true

fn v3BrowserAbiRuleUniqueKeyCount(rules: V3BrowserAbiRule[]): int32 =
    var count: int32
    var keys: str[]
    for i in 0..<rules.len:
        var seen = false
        for j in 0..<keys.len:
            if keys[j] == rules[i].ruleKey:
                seen = true
                break
        if seen:
            continue
        add(keys, rules[i].ruleKey)
        count = count + 1
    return count

fn v3BrowserAbiRuleCountInputKind(rules: V3BrowserAbiRule[],
                                  kind: V3BrowserAbiInputKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].inputKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiRuleCountOutputKind(rules: V3BrowserAbiRule[],
                                   kind: V3BrowserAbiOutputKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].outputKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiRuleCountErrorKind(rules: V3BrowserAbiRule[],
                                  kind: V3BrowserAbiErrorKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].errorKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiRuleCountResultKind(rules: V3BrowserAbiRule[],
                                   kind: V3BrowserAbiResultKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].resultKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiRuleCountOutBufferKind(rules: V3BrowserAbiRule[],
                                      kind: V3BrowserAbiOutBufferKind): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].outBufferKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiRuleCountRuleName(rules: V3BrowserAbiRule[],
                                 ruleName: str): int32 =
    var count: int32
    for i in 0..<rules.len:
        if rules[i].ruleName == ruleName:
            count = count + 1
    return count

fn v3BrowserAbiRuleHasRuleName(rules: V3BrowserAbiRule[],
                               ruleName: str): bool =
    return v3BrowserAbiRuleCountRuleName(rules, ruleName) > 0

fn v3BrowserAbiRulesForSource(rules: V3BrowserAbiRule[],
                              sourcePath: str): V3BrowserAbiRule[] =
    var out: V3BrowserAbiRule[]
    for i in 0..<rules.len:
        if rules[i].sourcePath != sourcePath:
            continue
        add(out, v3BrowserAbiRuleClone(rules[i]))
    return out

fn v3BrowserAbiBridgeStageForRule(rule: V3BrowserAbiRule): V3BrowserAbiBridgeStage =
    if rule.outputKind == v3BrowserAbiOutputScalarI32 && rule.resultKind == v3BrowserAbiResultScalarI32:
        return v3BrowserAbiBridgeStageScalarCall
    if rule.inputKind != v3BrowserAbiInputNone:
        return v3BrowserAbiBridgeStageInputRead
    if rule.resultKind == v3BrowserAbiResultStatusI32:
        return v3BrowserAbiBridgeStageResultExport
    if rule.errorKind != v3BrowserAbiErrorInlineResultError:
        return v3BrowserAbiBridgeStageErrorHandleRead
    return v3BrowserAbiBridgeStageOutputWrite

fn v3BrowserAbiInputSchemaKindForRule(rule: V3BrowserAbiRule): V3BrowserAbiInputKind =
    if rule.inputKind == v3BrowserAbiInputScalarNone ||
       rule.inputKind == v3BrowserAbiInputScalarI32_1 ||
       rule.inputKind == v3BrowserAbiInputScalarI32_2 ||
       rule.inputKind == v3BrowserAbiInputScalarI32_4 ||
       rule.inputKind == v3BrowserAbiInputBytesRequired ||
       rule.inputKind == v3BrowserAbiInputTextRequired ||
       rule.inputKind == v3BrowserAbiInputTextOptional:
        return rule.inputKind
    return v3BrowserAbiInputNone

fn v3BrowserAbiOutputSchemaKindForRule(rule: V3BrowserAbiRule): V3BrowserAbiOutputSchemaKind =
    if rule.outputKind == v3BrowserAbiOutputScalarI32:
        return v3BrowserAbiOutputSchemaScalarI32
    if rule.outputKind == v3BrowserAbiOutputBytes && rule.outBufferKind == v3BrowserAbiOutBufferRawHandle:
        return v3BrowserAbiOutputSchemaBytesHandle
    if rule.outputKind == v3BrowserAbiOutputText && rule.outBufferKind == v3BrowserAbiOutBufferTextHandle:
        return v3BrowserAbiOutputSchemaTextHandle
    return v3BrowserAbiOutputSchemaNone

fn v3BrowserAbiErrorSchemaKindForRule(rule: V3BrowserAbiRule): V3BrowserAbiErrorKind =
    if rule.errorKind == v3BrowserAbiErrorInlineNone ||
       rule.errorKind == v3BrowserAbiErrorMoqFountainLastError:
        return rule.errorKind
    return v3BrowserAbiErrorInlineResultError

fn v3BrowserAbiBridgeSpecNew(sourcePath: str,
                             ruleName: str,
                             bridgeStage: V3BrowserAbiBridgeStage,
                             inputSchemaKind: V3BrowserAbiInputKind,
                             outputSchemaKind: V3BrowserAbiOutputSchemaKind,
                             errorSchemaKind: V3BrowserAbiErrorKind,
                             resultKind: V3BrowserAbiResultKind,
                             outBufferKind: V3BrowserAbiOutBufferKind): V3BrowserAbiBridgeSpec =
    var out: V3BrowserAbiBridgeSpec
    out.sourcePath = sourcePath
    out.ruleName = ruleName
    out.bridgeStage = bridgeStage
    out.inputSchemaKind = inputSchemaKind
    out.outputSchemaKind = outputSchemaKind
    out.errorSchemaKind = errorSchemaKind
    out.resultKind = resultKind
    out.outBufferKind = outBufferKind
    out.bridgeKey = v3BrowserAbiBridgeKey(bridgeStage,
                                          inputSchemaKind,
                                          outputSchemaKind,
                                          errorSchemaKind,
                                          resultKind,
                                          outBufferKind)
    return out

fn v3BrowserAbiBridgeSpecForRule(rule: V3BrowserAbiRule): V3BrowserAbiBridgeSpec =
    return v3BrowserAbiBridgeSpecNew(rule.sourcePath,
                                     rule.ruleName,
                                     v3BrowserAbiBridgeStageForRule(rule),
                                     v3BrowserAbiInputSchemaKindForRule(rule),
                                     v3BrowserAbiOutputSchemaKindForRule(rule),
                                     v3BrowserAbiErrorSchemaKindForRule(rule),
                                     rule.resultKind,
                                     rule.outBufferKind)

fn v3BrowserAbiBridgeSpecClone(spec: V3BrowserAbiBridgeSpec): V3BrowserAbiBridgeSpec =
    var out: V3BrowserAbiBridgeSpec
    out.sourcePath = spec.sourcePath
    out.ruleName = spec.ruleName
    out.bridgeStage = spec.bridgeStage
    out.inputSchemaKind = spec.inputSchemaKind
    out.outputSchemaKind = spec.outputSchemaKind
    out.errorSchemaKind = spec.errorSchemaKind
    out.resultKind = spec.resultKind
    out.outBufferKind = spec.outBufferKind
    out.bridgeKey = spec.bridgeKey
    return out

fn v3BrowserAbiBridgeSpecsFromRules(rules: V3BrowserAbiRule[]): V3BrowserAbiBridgeSpec[] =
    var out: V3BrowserAbiBridgeSpec[]
    for i in 0..<rules.len:
        add(out, v3BrowserAbiBridgeSpecForRule(rules[i]))
    return out

fn v3BrowserAbiBridgeSpecEqual(lhs: V3BrowserAbiBridgeSpec,
                               rhs: V3BrowserAbiBridgeSpec): bool =
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.ruleName != rhs.ruleName:
        return false
    if lhs.bridgeStage != rhs.bridgeStage:
        return false
    if lhs.inputSchemaKind != rhs.inputSchemaKind:
        return false
    if lhs.outputSchemaKind != rhs.outputSchemaKind:
        return false
    if lhs.errorSchemaKind != rhs.errorSchemaKind:
        return false
    if lhs.resultKind != rhs.resultKind:
        return false
    if lhs.outBufferKind != rhs.outBufferKind:
        return false
    return lhs.bridgeKey == rhs.bridgeKey

fn v3BrowserAbiBridgeSpecsEqual(lhs: V3BrowserAbiBridgeSpec[],
                                rhs: V3BrowserAbiBridgeSpec[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !v3BrowserAbiBridgeSpecEqual(lhs[i], rhs[i]):
            return false
    return true

fn v3BrowserAbiBridgeSpecUniqueKeyCount(specs: V3BrowserAbiBridgeSpec[]): int32 =
    var count: int32
    var keys: str[]
    for i in 0..<specs.len:
        var seen = false
        for j in 0..<keys.len:
            if keys[j] == specs[i].bridgeKey:
                seen = true
                break
        if seen:
            continue
        add(keys, specs[i].bridgeKey)
        count = count + 1
    return count

fn v3BrowserAbiBridgeSpecCountStage(specs: V3BrowserAbiBridgeSpec[],
                                    stage: V3BrowserAbiBridgeStage): int32 =
    var count: int32
    for i in 0..<specs.len:
        if specs[i].bridgeStage == stage:
            count = count + 1
    return count

fn v3BrowserAbiBridgeSpecCountInputSchemaKind(specs: V3BrowserAbiBridgeSpec[],
                                              kind: V3BrowserAbiInputKind): int32 =
    var count: int32
    for i in 0..<specs.len:
        if specs[i].inputSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgeSpecCountOutputSchemaKind(specs: V3BrowserAbiBridgeSpec[],
                                               kind: V3BrowserAbiOutputSchemaKind): int32 =
    var count: int32
    for i in 0..<specs.len:
        if specs[i].outputSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgeSpecCountErrorSchemaKind(specs: V3BrowserAbiBridgeSpec[],
                                              kind: V3BrowserAbiErrorKind): int32 =
    var count: int32
    for i in 0..<specs.len:
        if specs[i].errorSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgeSpecsForSource(specs: V3BrowserAbiBridgeSpec[],
                                    sourcePath: str): V3BrowserAbiBridgeSpec[] =
    var out: V3BrowserAbiBridgeSpec[]
    for i in 0..<specs.len:
        if specs[i].sourcePath != sourcePath:
            continue
        add(out, v3BrowserAbiBridgeSpecClone(specs[i]))
    return out

fn v3BrowserAbiBridgeHelperName(spec: V3BrowserAbiBridgeSpec): str =
    return Fmt(["v3_browser_bridge_", v3BrowserAbiBridgeStageText(spec.bridgeStage), "_", spec.ruleName])

fn v3BrowserAbiBridgeEmitLine(spec: V3BrowserAbiBridgeSpec): str =
    return Fmt(["source=",
                spec.sourcePath,
                "|rule=",
                spec.ruleName,
                "|stage=",
                v3BrowserAbiBridgeStageText(spec.bridgeStage),
                "|helper=",
                v3BrowserAbiBridgeHelperName(spec),
                "|input_schema=",
                v3BrowserAbiInputKindText(spec.inputSchemaKind),
                "|output_schema=",
                v3BrowserAbiOutputSchemaKindText(spec.outputSchemaKind),
                "|error_schema=",
                v3BrowserAbiErrorKindText(spec.errorSchemaKind),
                "|result=",
                v3BrowserAbiResultKindText(spec.resultKind),
                "|out_buffer=",
                v3BrowserAbiOutBufferKindText(spec.outBufferKind)])

fn v3BrowserAbiBridgeManifestAppendLine(out: var str,
                                        line: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + line

fn v3BrowserAbiBridgeManifestText(specs: V3BrowserAbiBridgeSpec[]): str =
    var out = ""
    var header = ""
    header = header + "format=browser_abi_bridge_manifest_v1"
    v3BrowserAbiBridgeManifestAppendLine(out, header)
    var countLine = ""
    countLine = countLine + "bridge_count="
    countLine = countLine + intToStr(specs.len)
    v3BrowserAbiBridgeManifestAppendLine(out, countLine)
    var uniqueLine = ""
    uniqueLine = uniqueLine + "bridge_unique_key_count="
    uniqueLine = uniqueLine + intToStr(v3BrowserAbiBridgeSpecUniqueKeyCount(specs))
    v3BrowserAbiBridgeManifestAppendLine(out, uniqueLine)
    for i in 0..<specs.len:
        var line = ""
        line = line + "bridge["
        line = line + intToStr(i)
        line = line + "]="
        line = line + v3BrowserAbiBridgeEmitLine(specs[i])
        v3BrowserAbiBridgeManifestAppendLine(out, line)
    return out

fn v3BrowserAbiBridgeManifestTextFromRules(rules: V3BrowserAbiRule[]): str =
    let specs = v3BrowserAbiBridgeSpecsFromRules(rules)
    return v3BrowserAbiBridgeManifestText(specs)

fn v3BrowserAbiBridgePlanNew(spec: V3BrowserAbiBridgeSpec): V3BrowserAbiBridgePlan =
    var out: V3BrowserAbiBridgePlan
    out.sourcePath = spec.sourcePath
    out.ruleName = spec.ruleName
    out.bridgeStage = spec.bridgeStage
    out.inputSchemaKind = spec.inputSchemaKind
    out.outputSchemaKind = spec.outputSchemaKind
    out.errorSchemaKind = spec.errorSchemaKind
    out.resultKind = spec.resultKind
    out.outBufferKind = spec.outBufferKind
    out.bridgeKey = spec.bridgeKey
    out.helperName = v3BrowserAbiBridgeHelperName(spec)
    out.emitLine = v3BrowserAbiBridgeEmitLine(spec)
    return out

fn v3BrowserAbiBridgePlanForRule(rule: V3BrowserAbiRule): V3BrowserAbiBridgePlan =
    let spec = v3BrowserAbiBridgeSpecForRule(rule)
    return v3BrowserAbiBridgePlanNew(spec)

fn v3BrowserAbiBridgePlanClone(plan: V3BrowserAbiBridgePlan): V3BrowserAbiBridgePlan =
    var out: V3BrowserAbiBridgePlan
    out.sourcePath = plan.sourcePath
    out.ruleName = plan.ruleName
    out.bridgeStage = plan.bridgeStage
    out.inputSchemaKind = plan.inputSchemaKind
    out.outputSchemaKind = plan.outputSchemaKind
    out.errorSchemaKind = plan.errorSchemaKind
    out.resultKind = plan.resultKind
    out.outBufferKind = plan.outBufferKind
    out.bridgeKey = plan.bridgeKey
    out.helperName = plan.helperName
    out.emitLine = plan.emitLine
    return out

fn v3BrowserAbiBridgePlansFromSpecs(specs: V3BrowserAbiBridgeSpec[]): V3BrowserAbiBridgePlan[] =
    var out: V3BrowserAbiBridgePlan[]
    for i in 0..<specs.len:
        add(out, v3BrowserAbiBridgePlanNew(specs[i]))
    return out

fn v3BrowserAbiBridgePlansFromRules(rules: V3BrowserAbiRule[]): V3BrowserAbiBridgePlan[] =
    var out: V3BrowserAbiBridgePlan[]
    for i in 0..<rules.len:
        add(out, v3BrowserAbiBridgePlanForRule(rules[i]))
    return out

fn v3BrowserAbiBridgePlanEqual(lhs: V3BrowserAbiBridgePlan,
                               rhs: V3BrowserAbiBridgePlan): bool =
    if lhs.sourcePath != rhs.sourcePath:
        return false
    if lhs.ruleName != rhs.ruleName:
        return false
    if lhs.bridgeStage != rhs.bridgeStage:
        return false
    if lhs.inputSchemaKind != rhs.inputSchemaKind:
        return false
    if lhs.outputSchemaKind != rhs.outputSchemaKind:
        return false
    if lhs.errorSchemaKind != rhs.errorSchemaKind:
        return false
    if lhs.resultKind != rhs.resultKind:
        return false
    if lhs.outBufferKind != rhs.outBufferKind:
        return false
    if lhs.bridgeKey != rhs.bridgeKey:
        return false
    if lhs.helperName != rhs.helperName:
        return false
    return lhs.emitLine == rhs.emitLine

fn v3BrowserAbiBridgePlansEqual(lhs: V3BrowserAbiBridgePlan[],
                                rhs: V3BrowserAbiBridgePlan[]): bool =
    if lhs.len != rhs.len:
        return false
    for i in 0..<lhs.len:
        if !v3BrowserAbiBridgePlanEqual(lhs[i], rhs[i]):
            return false
    return true

fn v3BrowserAbiBridgePlanUniqueKeyCount(plans: V3BrowserAbiBridgePlan[]): int32 =
    var count: int32
    var keys: str[]
    for i in 0..<plans.len:
        var seen = false
        for j in 0..<keys.len:
            if keys[j] == plans[i].bridgeKey:
                seen = true
                break
        if seen:
            continue
        add(keys, plans[i].bridgeKey)
        count = count + 1
    return count

fn v3BrowserAbiBridgePlanCountStage(plans: V3BrowserAbiBridgePlan[],
                                    stage: V3BrowserAbiBridgeStage): int32 =
    var count: int32
    for i in 0..<plans.len:
        if plans[i].bridgeStage == stage:
            count = count + 1
    return count

fn v3BrowserAbiBridgePlanCountInputSchemaKind(plans: V3BrowserAbiBridgePlan[],
                                              kind: V3BrowserAbiInputKind): int32 =
    var count: int32
    for i in 0..<plans.len:
        if plans[i].inputSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgePlanCountOutputSchemaKind(plans: V3BrowserAbiBridgePlan[],
                                               kind: V3BrowserAbiOutputSchemaKind): int32 =
    var count: int32
    for i in 0..<plans.len:
        if plans[i].outputSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgePlanCountErrorSchemaKind(plans: V3BrowserAbiBridgePlan[],
                                              kind: V3BrowserAbiErrorKind): int32 =
    var count: int32
    for i in 0..<plans.len:
        if plans[i].errorSchemaKind == kind:
            count = count + 1
    return count

fn v3BrowserAbiBridgePlansForSource(plans: V3BrowserAbiBridgePlan[],
                                    sourcePath: str): V3BrowserAbiBridgePlan[] =
    var out: V3BrowserAbiBridgePlan[]
    for i in 0..<plans.len:
        if plans[i].sourcePath != sourcePath:
            continue
        add(out, v3BrowserAbiBridgePlanClone(plans[i]))
    return out

fn v3BrowserAbiBridgePlanHelperName(plan: V3BrowserAbiBridgePlan): str =
    return plan.helperName

fn v3BrowserAbiBridgePlanEmitLine(plan: V3BrowserAbiBridgePlan): str =
    return plan.emitLine

fn v3BrowserAbiBridgePlanManifestFormat(): str =
    return "browser_abi_bridge_plan_v1"

fn v3BrowserAbiBridgeSourceFormat(): str =
    return "browser_abi_bridge_source_v1"

fn v3BrowserAbiBridgeSourceAppendLine(out: var str,
                                      line: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + line

fn v3BrowserAbiBridgeSourceAppendUnique(lines: var str[],
                                        line: str) =
    for i in 0..<lines.len:
        if lines[i] == line:
            return
    add(lines, line)

fn v3BrowserAbiBridgeSourceScalarImportLine(plan: V3BrowserAbiBridgePlan): str =
    let symbolName = "cheng_browser_" + plan.ruleName + "_bridge"
    if plan.inputSchemaKind == v3BrowserAbiInputScalarNone:
        return "importc fn " + symbolName + "(): int32"
    if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_1:
        return "importc fn " + symbolName + "(arg0: int32): int32"
    if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_2:
        return "importc fn " + symbolName + "(arg0: int32, arg1: int32): int32"
    if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_4:
        return "importc fn " + symbolName + "(arg0: int32, arg1: int32, arg2: int32, arg3: int32): int32"
    return ""

fn v3BrowserAbiBridgeSourceSharedImportLines(): str[] =
    return [
        "import std/result",
        "import std/rawbytes",
        "@importc(\"cheng_browser_input_len_bridge\")",
        "fn cheng_browser_input_len_bridge(handle: int32): int32",
        "@importc(\"cheng_browser_input_copy_bridge\")",
        "fn cheng_browser_input_copy_bridge(handle: int32, data: ptr, n: int32): int32",
        "@importc(\"cheng_buffer_handle_from_raw_bridge\")",
        "fn cheng_buffer_handle_from_raw_bridge(data: ptr, n: int32): int32",
        "@importc(\"cheng_buffer_handle_from_text_bridge\")",
        "fn cheng_buffer_handle_from_text_bridge(text: str): int32",
        "importc fn cheng_browser_moq_fountain_last_error_store_bridge(text: str): int32",
        "importc fn cheng_browser_moq_fountain_last_error_handle_bridge(): int32"
    ]

fn v3BrowserAbiBridgeSourceInputBytesRequiredText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(handle: int32,\n"
    out = out + "                                missingError: str,\n"
    out = out + "                                copyError: str): Result[Bytes] =\n"
    out = out + "    let inputLen = cheng_browser_input_len_bridge(handle)\n"
    out = out + "    if handle <= 0 || inputLen <= 0:\n"
    out = out + "        return Err[Bytes](missingError)\n"
    out = out + "    var inputBytes = bytesAlloc(inputLen)\n"
    out = out + "    if cheng_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:\n"
    out = out + "        return Err[Bytes](copyError)\n"
    out = out + "    return Ok[Bytes](inputBytes)"
    return out

fn v3BrowserAbiBridgeSourceInputTextRequiredText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(handle: int32,\n"
    out = out + "                                missingError: str,\n"
    out = out + "                                copyError: str): Result[str] =\n"
    out = out + "    let inputLen = cheng_browser_input_len_bridge(handle)\n"
    out = out + "    if handle <= 0 || inputLen <= 0:\n"
    out = out + "        return Err[str](missingError)\n"
    out = out + "    var inputBytes = bytesAlloc(inputLen)\n"
    out = out + "    if cheng_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:\n"
    out = out + "        return Err[str](copyError)\n"
    out = out + "    return Ok[str](bytesToString(inputBytes))"
    return out

fn v3BrowserAbiBridgeSourceInputTextOptionalText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(handle: int32,\n"
    out = out + "                                copyError: str): Result[str] =\n"
    out = out + "    let inputLen = cheng_browser_input_len_bridge(handle)\n"
    out = out + "    if handle <= 0 || inputLen <= 0:\n"
    out = out + "        return Ok[str](\"\")\n"
    out = out + "    var inputBytes = bytesAlloc(inputLen)\n"
    out = out + "    if cheng_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:\n"
    out = out + "        return Err[str](copyError)\n"
    out = out + "    return Ok[str](bytesToString(inputBytes))"
    return out

fn v3BrowserAbiBridgeSourceOutputBytesHandleText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(payload: Bytes,\n"
    out = out + "                                handleError: str): Result[int32] =\n"
    out = out + "    let handle = cheng_buffer_handle_from_raw_bridge(payload.data, bytesLen(payload))\n"
    out = out + "    if handle <= 0:\n"
    out = out + "        return Err[int32](handleError)\n"
    out = out + "    return Ok[int32](handle)"
    return out

fn v3BrowserAbiBridgeSourceOutputTextHandleText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(text: str,\n"
    out = out + "                                handleError: str): Result[int32] =\n"
    out = out + "    if len(text) <= 0:\n"
    out = out + "        return Err[int32](handleError)\n"
    out = out + "    let handle = cheng_buffer_handle_from_text_bridge(text)\n"
    out = out + "    if handle <= 0:\n"
    out = out + "        return Err[int32](handleError)\n"
    out = out + "    return Ok[int32](handle)"
    return out

fn v3BrowserAbiBridgeSourceResultExportBytesText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(bytesRes: Result[Bytes],\n"
    out = out + "                                handleError: str): int32 =\n"
    out = out + "    cheng_browser_moq_fountain_last_error_store_bridge(\"\")\n"
    out = out + "    if IsErr(bytesRes):\n"
    out = out + "        cheng_browser_moq_fountain_last_error_store_bridge(Error(bytesRes))\n"
    out = out + "        return 0\n"
    out = out + "    let payload = Value(bytesRes)\n"
    out = out + "    let handle = cheng_buffer_handle_from_raw_bridge(payload.data, bytesLen(payload))\n"
    out = out + "    if handle <= 0:\n"
    out = out + "        cheng_browser_moq_fountain_last_error_store_bridge(handleError)\n"
    out = out + "        return 0\n"
    out = out + "    return handle"
    return out

fn v3BrowserAbiBridgeSourceResultExportTextText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(textRes: Result[str],\n"
    out = out + "                                handleError: str): int32 =\n"
    out = out + "    cheng_browser_moq_fountain_last_error_store_bridge(\"\")\n"
    out = out + "    if IsErr(textRes):\n"
    out = out + "        cheng_browser_moq_fountain_last_error_store_bridge(Error(textRes))\n"
    out = out + "        return 0\n"
    out = out + "    let text = Value(textRes)\n"
    out = out + "    if len(text) <= 0:\n"
    out = out + "        cheng_browser_moq_fountain_last_error_store_bridge(handleError)\n"
    out = out + "        return 0\n"
    out = out + "    let handle = cheng_buffer_handle_from_text_bridge(text)\n"
    out = out + "    if handle <= 0:\n"
    out = out + "        cheng_browser_moq_fountain_last_error_store_bridge(handleError)\n"
    out = out + "        return 0\n"
    out = out + "    return handle"
    return out

fn v3BrowserAbiBridgeSourceErrorHandleText(helper: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(): int32 =\n"
    out = out + "    return cheng_browser_moq_fountain_last_error_handle_bridge()"
    return out

fn v3BrowserAbiBridgeSourceScalarCallNoneText(helper: str,
                                              symbolName: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(): int32 =\n"
    out = out + "    return "
    out = out + symbolName
    out = out + "()"
    return out

fn v3BrowserAbiBridgeSourceScalarCall1Text(helper: str,
                                           symbolName: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(arg0: int32): int32 =\n"
    out = out + "    return "
    out = out + symbolName
    out = out + "(arg0)"
    return out

fn v3BrowserAbiBridgeSourceScalarCall2Text(helper: str,
                                           symbolName: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(arg0: int32,\n"
    out = out + "                                arg1: int32): int32 =\n"
    out = out + "    return "
    out = out + symbolName
    out = out + "(arg0, arg1)"
    return out

fn v3BrowserAbiBridgeSourceScalarCall4Text(helper: str,
                                           symbolName: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(arg0: int32,\n"
    out = out + "                                arg1: int32,\n"
    out = out + "                                arg2: int32,\n"
    out = out + "                                arg3: int32): int32 =\n"
    out = out + "    return "
    out = out + symbolName
    out = out + "(arg0, arg1, arg2, arg3)"
    return out

fn v3BrowserAbiBridgeSourceFunctionText(plan: V3BrowserAbiBridgePlan): str =
    let helper = plan.helperName
    if plan.bridgeStage == v3BrowserAbiBridgeStageInputRead:
        if plan.inputSchemaKind == v3BrowserAbiInputBytesRequired:
            return v3BrowserAbiBridgeSourceInputBytesRequiredText(helper)
        if plan.inputSchemaKind == v3BrowserAbiInputTextRequired:
            return v3BrowserAbiBridgeSourceInputTextRequiredText(helper)
        if plan.inputSchemaKind == v3BrowserAbiInputTextOptional:
            return v3BrowserAbiBridgeSourceInputTextOptionalText(helper)
    if plan.bridgeStage == v3BrowserAbiBridgeStageOutputWrite:
        if plan.outputSchemaKind == v3BrowserAbiOutputSchemaBytesHandle:
            return v3BrowserAbiBridgeSourceOutputBytesHandleText(helper)
        if plan.outputSchemaKind == v3BrowserAbiOutputSchemaTextHandle:
            return v3BrowserAbiBridgeSourceOutputTextHandleText(helper)
    if plan.bridgeStage == v3BrowserAbiBridgeStageResultExport:
        if plan.outputSchemaKind == v3BrowserAbiOutputSchemaBytesHandle:
            return v3BrowserAbiBridgeSourceResultExportBytesText(helper)
        if plan.outputSchemaKind == v3BrowserAbiOutputSchemaTextHandle:
            return v3BrowserAbiBridgeSourceResultExportTextText(helper)
    if plan.bridgeStage == v3BrowserAbiBridgeStageErrorHandleRead:
        return v3BrowserAbiBridgeSourceErrorHandleText(helper)
    if plan.bridgeStage == v3BrowserAbiBridgeStageScalarCall:
        let symbolName = "cheng_browser_" + plan.ruleName + "_bridge"
        if plan.inputSchemaKind == v3BrowserAbiInputScalarNone:
            return v3BrowserAbiBridgeSourceScalarCallNoneText(helper, symbolName)
        if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_1:
            return v3BrowserAbiBridgeSourceScalarCall1Text(helper, symbolName)
        if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_2:
            return v3BrowserAbiBridgeSourceScalarCall2Text(helper, symbolName)
        if plan.inputSchemaKind == v3BrowserAbiInputScalarI32_4:
            return v3BrowserAbiBridgeSourceScalarCall4Text(helper, symbolName)
    return ""

fn v3BrowserAbiBridgeSourceText(plans: V3BrowserAbiBridgePlan[]): str =
    var out = ""
    let sharedImports = v3BrowserAbiBridgeSourceSharedImportLines()
    for i in 0..<sharedImports.len:
        if len(out) > 0:
            out = out + "\n"
        out = out + sharedImports[i]
    var scalarImports: str[]
    for i in 0..<plans.len:
        if plans[i].bridgeStage != v3BrowserAbiBridgeStageScalarCall:
            continue
        let importLine = v3BrowserAbiBridgeSourceScalarImportLine(plans[i])
        v3BrowserAbiBridgeSourceAppendUnique(scalarImports, importLine)
    for i in 0..<scalarImports.len:
        if len(out) > 0:
            out = out + "\n"
        out = out + scalarImports[i]
    out = out + "\n\n"
    out = out + "fn v3BrowserBridgeGeneratedSourceFormat(): str =\n"
    out = out + "    return \""
    out = out + v3BrowserAbiBridgeSourceFormat()
    out = out + "\""
    for i in 0..<plans.len:
        let fnText = v3BrowserAbiBridgeSourceFunctionText(plans[i])
        out = out + "\n\n"
        out = out + fnText
    return out

fn v3BrowserAbiBridgePlanManifestText(plans: V3BrowserAbiBridgePlan[]): str =
    var out = ""
    var header = ""
    header = header + "format="
    header = header + v3BrowserAbiBridgePlanManifestFormat()
    v3BrowserAbiBridgeManifestAppendLine(out, header)
    var countLine = ""
    countLine = countLine + "bridge_count="
    countLine = countLine + intToStr(plans.len)
    v3BrowserAbiBridgeManifestAppendLine(out, countLine)
    var uniqueLine = ""
    uniqueLine = uniqueLine + "bridge_unique_key_count="
    uniqueLine = uniqueLine + intToStr(v3BrowserAbiBridgePlanUniqueKeyCount(plans))
    v3BrowserAbiBridgeManifestAppendLine(out, uniqueLine)
    for i in 0..<plans.len:
        var line = ""
        line = line + "bridge["
        line = line + intToStr(i)
        line = line + "]="
        line = line + plans[i].emitLine
        v3BrowserAbiBridgeManifestAppendLine(out, line)
    return out

fn v3BrowserAbiBridgePlanManifestTextFromRules(rules: V3BrowserAbiRule[]): str =
    let plans = v3BrowserAbiBridgePlansFromRules(rules)
    return v3BrowserAbiBridgePlanManifestText(plans)
