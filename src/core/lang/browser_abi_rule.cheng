fn BrowserAbiBridgePlansForSource(plans: BrowserAbiBridgePlan[],
                                    sourcePath: str): BrowserAbiBridgePlan[] =
    var out: BrowserAbiBridgePlan[]
    for i in 0..<plans.len:
        if plans[i].sourcePath != sourcePath:
            continue
        add(out, BrowserAbiBridgePlanClone(plans[i]))
    return out

fn BrowserAbiBridgePlanHelperName(plan: BrowserAbiBridgePlan): str =
    return plan.helperName

fn BrowserAbiBridgePlanEmitLine(plan: BrowserAbiBridgePlan): str =
    return plan.emitLine

fn BrowserAbiBridgePlanManifestFormat(): str =
    return "browser_abi_bridge_plan_v1"

fn BrowserAbiBridgeSourceFormat(): str =
    return "browser_abi_bridge_source_v1"

fn BrowserAbiBridgeSourceAppendUnique(lines: var str[],
                                        line: str) =
    for i in 0..<lines.len:
        if lines[i] == line:
            return
    add(lines, line)

fn BrowserAbiBridgeSourceScalarImportLine(plan: BrowserAbiBridgePlan): str =
    let symbolName = strutil.Join(["cheng_browser_", plan.ruleName, "_bridge"], "")
    if plan.inputSchemaKind == BrowserAbiInputScalarNone:
        return strutil.Join(["importc fn ", symbolName, "(): int32"], "")
    if plan.inputSchemaKind == BrowserAbiInputScalarI32_1:
        return strutil.Join(["importc fn ", symbolName, "(arg0: int32): int32"], "")
    if plan.inputSchemaKind == BrowserAbiInputScalarI32_2:
        return strutil.Join(["importc fn ", symbolName, "(arg0: int32, arg1: int32): int32"], "")
    if plan.inputSchemaKind == BrowserAbiInputScalarI32_4:
        return strutil.Join(["importc fn ", symbolName, "(arg0: int32, arg1: int32, arg2: int32, arg3: int32): int32"], "")
    return ""

fn BrowserAbiBridgeSourceSharedImportLines(): str[] =
    return [
        "import std/result",
        "import std/rawbytes",
        "@importc(\"cheng_browser_input_len_bridge\")",
        "fn cheng_browser_input_len_bridge(handle: int32): int32",
        "@importc(\"cheng_browser_input_copy_bridge\")",
        "fn cheng_browser_input_copy_bridge(handle: int32, data: ptr, n: int32): int32",
        "@importc(\"cheng_browser_buffer_handle_from_raw_bridge\")",
        "fn cheng_browser_buffer_handle_from_raw_bridge(data: ptr, n: int32): int32",
        "@importc(\"cheng_browser_buffer_handle_from_text_bridge\")",
        "fn cheng_browser_buffer_handle_from_text_bridge(text: str): int32",
        "importc fn cheng_browser_moq_fountain_last_error_store_bridge(text: str): int32",
        "importc fn cheng_browser_moq_fountain_last_error_handle_bridge(): int32"
    ]

fn BrowserAbiBridgeSourceInputBytesRequiredText(helper: str): str =
    var out = ""
    out = strutil.Join([out, "fn "], "")
    out = strutil.Join([out, helper], "")
    out = strutil.Join([out, "(handle: int32,\n"], "")
    out = strutil.Join([out, "                                missingError: str,\n"], "")
    out = strutil.Join([out, "                                copyError: str): Result[Bytes] =\n"], "")
    out = strutil.Join([out, "    let inputLen = cheng_browser_input_len_bridge(handle)\n"], "")
    out = strutil.Join([out, "    if handle <= 0 || inputLen <= 0:\n"], "")
    out = strutil.Join([out, "        return Err[Bytes](missingError)\n"], "")
    out = strutil.Join([out, "    var inputBytes = bytesAlloc(inputLen)\n"], "")
    out = strutil.Join([out, "    if cheng_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:\n"], "")
    out = strutil.Join([out, "        return Err[Bytes](copyError)\n"], "")
    out = strutil.Join([out, "    return Ok[Bytes](inputBytes)"], "")
    return out

