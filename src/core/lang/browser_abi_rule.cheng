fn BrowserAbiBridgeSourceFunctionText(plan: BrowserAbiBridgePlan): str =
    let helper = plan.helperName
    if plan.bridgeStage == BrowserAbiBridgeStageInputRead:
        if plan.inputSchemaKind == BrowserAbiInputBytesRequired:
            return BrowserAbiBridgeSourceInputBytesRequiredText(helper)
        if plan.inputSchemaKind == BrowserAbiInputTextRequired:
            return BrowserAbiBridgeSourceInputTextRequiredText(helper)
        if plan.inputSchemaKind == BrowserAbiInputTextOptional:
            return BrowserAbiBridgeSourceInputTextOptionalText(helper)
    if plan.bridgeStage == BrowserAbiBridgeStageOutputWrite:
        if plan.outputSchemaKind == BrowserAbiOutputSchemaBytesHandle:
            return BrowserAbiBridgeSourceOutputBytesHandleText(helper)
        if plan.outputSchemaKind == BrowserAbiOutputSchemaTextHandle:
            return BrowserAbiBridgeSourceOutputTextHandleText(helper)
    if plan.bridgeStage == BrowserAbiBridgeStageResultExport:
        if plan.outputSchemaKind == BrowserAbiOutputSchemaBytesHandle:
            return BrowserAbiBridgeSourceResultExportBytesText(helper)
        if plan.outputSchemaKind == BrowserAbiOutputSchemaTextHandle:
            return BrowserAbiBridgeSourceResultExportTextText(helper)
    if plan.bridgeStage == BrowserAbiBridgeStageErrorHandleRead:
        return BrowserAbiBridgeSourceErrorHandleText(helper)
    if plan.bridgeStage == BrowserAbiBridgeStageScalarCall:
        let symbolName = strutil.Join(["cheng_browser_", plan.ruleName, "_bridge"], "")
        if plan.inputSchemaKind == BrowserAbiInputScalarNone:
            return BrowserAbiBridgeSourceScalarCallNoneText(helper, symbolName)
        if plan.inputSchemaKind == BrowserAbiInputScalarI32_1:
            return BrowserAbiBridgeSourceScalarCall1Text(helper, symbolName)
        if plan.inputSchemaKind == BrowserAbiInputScalarI32_2:
            return BrowserAbiBridgeSourceScalarCall2Text(helper, symbolName)
        if plan.inputSchemaKind == BrowserAbiInputScalarI32_4:
            return BrowserAbiBridgeSourceScalarCall4Text(helper, symbolName)
    return ""

fn BrowserAbiBridgeSourceText(plans: BrowserAbiBridgePlan[]): str =
    var lines: str[]
    let sharedImports = BrowserAbiBridgeSourceSharedImportLines()
    for i in 0..<sharedImports.len:
        add(lines, sharedImports[i])
    var scalarImports: str[]
    for i in 0..<plans.len:
        if plans[i].bridgeStage != BrowserAbiBridgeStageScalarCall:
            continue
        let importLine = BrowserAbiBridgeSourceScalarImportLine(plans[i])
        BrowserAbiBridgeSourceAppendUnique(scalarImports, importLine)
    for i in 0..<scalarImports.len:
        add(lines, scalarImports[i])
    add(lines, "")
    add(lines, strutil.Join(["fn BrowserBridgeGeneratedSourceFormat(): str =\n",
                             "    return \"",
                             BrowserAbiBridgeSourceFormat(),
                             "\""], ""))
    for i in 0..<plans.len:
        let fnText = BrowserAbiBridgeSourceFunctionText(plans[i])
        add(lines, "")
        add(lines, fnText)
    return strutil.Join(lines, "\n")

fn BrowserAbiBridgePlanManifestText(plans: BrowserAbiBridgePlan[]): str =
    var buf = newByteBuffer()
    buf.AppendBytes(strutil.Join(["format=", BrowserAbiBridgePlanManifestFormat()], ""))
    buf.AppendBytes("\n")
    buf.AppendBytes(strutil.Join(["bridge_count=", intToStr(plans.len)], ""))
    buf.AppendBytes("\n")
    buf.AppendBytes(strutil.Join(["bridge_unique_key_count=",
                                 intToStr(BrowserAbiBridgePlanUniqueKeyCount(plans))], ""))
    for i in 0..<plans.len:
        buf.AppendBytes("\n")
        buf.AppendBytes(strutil.Join(["bridge[", intToStr(i), "]=", plans[i].emitLine], ""))
    return rawbytes.bytesToString(buf.ToBytes())

fn BrowserAbiBridgePlanManifestTextFromRules(rules: BrowserAbiRule[]): str =
    let plans = BrowserAbiBridgePlansFromRules(rules)
    return BrowserAbiBridgePlanManifestText(plans)
