import std/result
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/transports/quic_transport
import cheng/DiLoCo/protocol/wire

fn DiLoCoClientStartsWith(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn DiLoCoClientFetchLeaseRetryable(err: str): bool =
    return err == "msquic native: pipe read timeout" ||
           DiLoCoClientStartsWith(err, "libp2p quic: dial: msquic native: pipe read timeout")

fn DiLoCoHostRequestResponseNamed(host: str,
                                    port: int32,
                                    serverName: str,
                                    payload: Bytes): Result[Bytes] =
    return quic_transport.Libp2pQuicRequestResponseNamed(host,
                                                           port,
                                                           serverName,
                                                           types.Libp2pProtocolDiLoCo,
                                                           payload)

fn DiLoCoOpenJobRequestNamed(host: str,
                               port: int32,
                               serverName: str,
                               req: wire.DiLoCoOpenJobRequest): Result[wire.DiLoCoOpenJobResponse] =
    let responseBytesRes = DiLoCoHostRequestResponseNamed(host,
                                                            port,
                                                            serverName,
                                                            wire.DiLoCoOpenJobRequestEncode(req))
    if IsErr(responseBytesRes):
        return Err[wire.DiLoCoOpenJobResponse](Error(responseBytesRes))
    var out = wire.DiLoCoOpenJobResponse()
    let decodeRes = wire.DiLoCoOpenJobResponseDecodeFill(out, Value(responseBytesRes))
    if IsErr(decodeRes):
        return Err[wire.DiLoCoOpenJobResponse](Error(decodeRes))
    return Ok[wire.DiLoCoOpenJobResponse](out)

