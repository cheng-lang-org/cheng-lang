fn DiLoCoFetchLeaseRequestNamed(host: str,
                                  port: int32,
                                  serverName: str,
                                  req: wire.DiLoCoFetchLeaseRequest): Result[wire.DiLoCoFetchLeaseResponse] =
    let responseBytesRes = DiLoCoHostRequestResponseNamed(host,
                                                            port,
                                                            serverName,
                                                            wire.DiLoCoFetchLeaseRequestEncode(req))
    var finalResponseBytesRes = responseBytesRes
    if IsErr(finalResponseBytesRes) && DiLoCoClientFetchLeaseRetryable(Error(finalResponseBytesRes)):
        finalResponseBytesRes = DiLoCoHostRequestResponseNamed(host,
                                                               port,
                                                               serverName,
                                                               wire.DiLoCoFetchLeaseRequestEncode(req))
    if IsErr(finalResponseBytesRes):
        return Err[wire.DiLoCoFetchLeaseResponse](Error(finalResponseBytesRes))
    var out = wire.DiLoCoFetchLeaseResponse()
    let decodeRes = wire.DiLoCoFetchLeaseResponseDecodeFill(out, Value(finalResponseBytesRes))
    if IsErr(decodeRes):
        return Err[wire.DiLoCoFetchLeaseResponse](Error(decodeRes))
    return Ok[wire.DiLoCoFetchLeaseResponse](out)

