    let reqRes = wire.DiLoCoFetchLineageRequestDecodeFill(req, payload)
    if IsErr(reqRes):
        return Err[bool](Error(reqRes))
    var versions: core.DiLoCoGlobalVersion[]
    let versionsRes = core.DiLoCoFetchLineageFill(versions, node.state, req.jobBundleCid)
    if IsErr(versionsRes):
        out = wire.DiLoCoWireEncodeErrorEnvelope(wire.DiLoCoMessageFetchLineage, Error(versionsRes))
        return Ok[bool](true)
    var resp = wire.DiLoCoFetchLineageResponse()
