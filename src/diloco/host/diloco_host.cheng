    out = wire.DiLoCoFetchLineageResponseEncode(resp)
    return Ok[bool](true)

fn DiLoCoHostServePayload(out: var Bytes,
                            node: var DiLoCoHostNode,
                            payload: Bytes): Result[bool] =
    var envelope = wire.DiLoCoEnvelope()
    let envelopeRes = wire.DiLoCoEnvelopeDecodeFill(envelope, payload)
    if IsErr(envelopeRes):
        return Err[bool](Error(envelopeRes))
    if !envelope.ok:
        return Err[bool](" diloco host: request envelope not ok")
    if envelope.kind == wire.DiLoCoMessageOpenJob:
        return DiLoCoHostServeOpenJob(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageJoinCohort:
        return DiLoCoHostServeJoinCohort(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageFetchLease:
        return DiLoCoHostServeFetchLease(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageReportInnerStepDone:
        return DiLoCoHostServeReportInnerStepDone(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageSubmitOuterDelta:
        return DiLoCoHostServeSubmitOuterDelta(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageFetchStepStatus:
        return DiLoCoHostServeFetchStepStatus(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessagePublishMergeCommit:
        return DiLoCoHostServePublishMergeCommit(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageFetchGlobalVersion:
        return DiLoCoHostServeFetchGlobalVersion(out, node, payload)
    elif envelope.kind == wire.DiLoCoMessageFetchLineage:
        return DiLoCoHostServeFetchLineage(out, node, payload)
    return Err[bool](" diloco host: unsupported kind")

fn DiLoCoHostRequestResponseNamed(host: str,
                                    port: int32,
                                    serverName: str,
                                    payload: Bytes): Result[Bytes] =
    return quic_transport.Libp2pQuicRequestResponseNamed(host,
                                                           port,
                                                           serverName,
                                                           types.Libp2pProtocolDiLoCo,
                                                           payload)

fn DiLoCoHostServeWindowNamed(node: var DiLoCoHostNode,
                                host: str,
                                port: int32,
                                serverName: str,
                                readyPath: str,
                                maxServeCount: int32,
                                waitMs: int32): Result[bool] =
    var listener = qtransport.InitMsQuicTransport()
    let startRes = quic_transport.Libp2pQuicStartListenerNamed(listener, host, port, serverName)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    if !quic_transport.Libp2pQuicWriteReadyPort(readyPath, Value(startRes)):
        qtransport.Stop(listener)
        return Err[bool](" diloco host: ready path write failed")
    var servedCount = 0
    while maxServeCount <= 0 || servedCount < maxServeCount:
        let acceptRes = qtransport.AcceptTimed(listener, waitMs)
        if IsErr(acceptRes):
            if ErrorText(acceptRes) == "msquic: accept timeout":
                break
            if quic_transport.Libp2pQuicRetryableAcceptError(ErrorText(acceptRes)):
                os.SleepMs(10)
                continue
            os.WriteLine(os.GetStderr(), " diloco host accept error: " + ErrorText(acceptRes))
            qtransport.Stop(listener)
            return Err[bool](" diloco host: accept: " + ErrorText(acceptRes))
        var conn = Value(acceptRes)
        var dropConn = false
        let selectRes = quic_transport.Libp2pQuicServerSelectProtocol(listener,
                                                                        conn,
                                                                        types.Libp2pProtocolDiLoCo)
        var responsePayload = emptyBytes()
        if IsErr(selectRes):
            os.WriteLine(os.GetStderr(), " diloco host select error: " + Error(selectRes))
            dropConn = true
        if !dropConn:
            let requestRes = quic_transport.Libp2pQuicReadFrame(listener, conn)
            if IsErr(requestRes):
                os.WriteLine(os.GetStderr(), " diloco host read error: " + Error(requestRes))
                dropConn = true
            else:
                let serveRes = DiLoCoHostServePayload(responsePayload, node, Value(requestRes))
                if IsErr(serveRes):
                    os.WriteLine(os.GetStderr(), " diloco host serve error: " + Error(serveRes))
                    dropConn = true
                else:
                    let autoLeaderRes = DiLoCoHostMaybeAdvanceAutoLeader(node)
                    if IsErr(autoLeaderRes):
                        qconn.ConnClose(conn)
                        qtransport.Stop(listener)
                        return Err[bool](" diloco host: auto leader: " + Error(autoLeaderRes))
        if !dropConn:
            let writeRes = quic_transport.Libp2pQuicWriteExact(listener,
                                                                 conn,
                                                                 quic_transport.Libp2pQuicEncodeFrame(responsePayload))
            if IsErr(writeRes):
                os.WriteLine(os.GetStderr(), " diloco host write error: " + Error(writeRes))
                dropConn = true
        qconn.ConnClose(conn)
        if dropConn:
            continue
        servedCount = servedCount + 1
    qtransport.Stop(listener)
    return Ok[bool](true)

fn DiLoCoOpenJobRequestNamed(host: str,
                               port: int32,
                               serverName: str,
                               req: wire.DiLoCoOpenJobRequest): Result[wire.DiLoCoOpenJobResponse] =
    let responseBytesRes = DiLoCoHostRequestResponseNamed(host,
                                                            port,
                                                            serverName,
                                                            wire.DiLoCoOpenJobRequestEncode(req))
    if IsErr(responseBytesRes):
        return Err[wire.DiLoCoOpenJobResponse](Error(responseBytesRes))
    var out = wire.DiLoCoOpenJobResponse()
    let decodeRes = wire.DiLoCoOpenJobResponseDecodeFill(out, Value(responseBytesRes))
    if IsErr(decodeRes):
        return Err[wire.DiLoCoOpenJobResponse](Error(decodeRes))
    return Ok[wire.DiLoCoOpenJobResponse](out)

