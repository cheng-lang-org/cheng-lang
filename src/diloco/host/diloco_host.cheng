import std/result
import std/os
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/transports/quic_transport
import cheng/quic/connection as qconn
import cheng/quic/msquictransport_native as qtransport
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/protocol/wire

type
    DiLoCoHostNode =
        state: core.DiLoCoState
        autoLeaderEnabled: bool
        autoLeaderJobBundleCid: layout.FixedBytes32
        autoLeaderPeerId: types.Libp2pPeerId
        autoLeaderModelDeltaRef: core.DiLoCoArtifactRef
        autoLeaderOptimizerDeltaRef: core.DiLoCoArtifactRef
        autoLeaderSampleCount: int32
        autoLeaderTokenCount: int32
        autoLeaderInnerStepCount: int32
        autoLeaderWeightNumerator: int32
        autoLeaderWeightDenominator: int32

fn DiLoCoHostInit(label: str): DiLoCoHostNode =
    return DiLoCoHostNode(state: core.DiLoCoStateInit(label))

fn DiLoCoHostEnableAutoLeader(node: var DiLoCoHostNode,
                                jobBundleCid: layout.FixedBytes32,
                                leaderPeerId: types.Libp2pPeerId,
                                modelDeltaRef: core.DiLoCoArtifactRef,
                                optimizerDeltaRef: core.DiLoCoArtifactRef,
                                sampleCount: int32,
                                tokenCount: int32,
                                innerStepCount: int32,
                                weightNumerator: int32,
                                weightDenominator: int32) =
    node.autoLeaderEnabled = true
    node.autoLeaderJobBundleCid = jobBundleCid
    node.autoLeaderPeerId = leaderPeerId
    node.autoLeaderModelDeltaRef = modelDeltaRef
    node.autoLeaderOptimizerDeltaRef = optimizerDeltaRef
    node.autoLeaderSampleCount = sampleCount
    node.autoLeaderTokenCount = tokenCount
    node.autoLeaderInnerStepCount = innerStepCount
    node.autoLeaderWeightNumerator = weightNumerator
    node.autoLeaderWeightDenominator = weightDenominator

fn DiLoCoHostMaybeAdvanceAutoLeader(node: var DiLoCoHostNode): Result[bool] =
    if !node.autoLeaderEnabled:
        return Ok[bool](false)
    let jobPos = core.DiLoCoJobPos(node.state, node.autoLeaderJobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco host: auto leader job missing")
    let job = node.state.jobs[jobPos]
    if !job.sealed:
        return Ok[bool](false)
    var leaderLease = core.DiLoCoLease()
    let leaderLeaseRes = core.DiLoCoFetchLeaseFill(leaderLease,
                                                     node.state,
                                                     node.autoLeaderJobBundleCid,
                                                     node.autoLeaderPeerId)
    if IsErr(leaderLeaseRes):
        return Err[bool](Error(leaderLeaseRes))
    let barrierPos = core.DiLoCoBarrierPos(node.state,
                                             node.autoLeaderJobBundleCid,
                                             job.currentGlobalVersionCid,
                                             job.currentOuterStep)
    if barrierPos >= 0:
        let barrier = node.state.barriers[barrierPos]
        if barrier.completedPeerIds.len > 0 &&
           !core.DiLoCoBarrierHasPeer(barrier, node.autoLeaderPeerId):
            var barrierOut = core.DiLoCoBarrier()
            let barrierRes = core.DiLoCoReportInnerStepDoneFill(barrierOut,
                                                                  node.state,
                                                                  node.autoLeaderJobBundleCid,
                                                                  node.autoLeaderPeerId)
            if IsErr(barrierRes):
                return Err[bool](Error(barrierRes))
    let readyBarrierPos = core.DiLoCoBarrierPos(node.state,
                                                  node.autoLeaderJobBundleCid,
                                                  job.currentGlobalVersionCid,
                                                  job.currentOuterStep)
    if readyBarrierPos < 0:
        return Ok[bool](false)
    let readyBarrier = node.state.barriers[readyBarrierPos]
    if !readyBarrier.sealed:
        return Ok[bool](false)
    if core.DiLoCoDeltaPos(node.state,
                             node.autoLeaderJobBundleCid,
                             job.currentGlobalVersionCid,
                             job.currentOuterStep,
                             node.autoLeaderPeerId) >= 0:
        return Ok[bool](false)
    var leaderDelta = core.DiLoCoOuterDelta()
    let leaderDeltaRes = core.DiLoCoSubmitOuterDeltaFill(leaderDelta,
                                                           node.state,
                                                           node.autoLeaderJobBundleCid,
                                                           job.currentGlobalVersionCid,
                                                           job.currentOuterStep,
                                                           node.autoLeaderPeerId,
                                                           node.autoLeaderModelDeltaRef,
                                                           node.autoLeaderOptimizerDeltaRef,
                                                           node.autoLeaderSampleCount,
                                                           node.autoLeaderTokenCount,
                                                           node.autoLeaderInnerStepCount,
                                                           node.autoLeaderWeightNumerator,
                                                           node.autoLeaderWeightDenominator)
    if IsErr(leaderDeltaRes):
        return Err[bool](Error(leaderDeltaRes))
    return Ok[bool](true)

fn DiLoCoHostServeOpenJob(out: var Bytes,
                            node: var DiLoCoHostNode,
                            payload: Bytes): Result[bool] =
    var req = wire.DiLoCoOpenJobRequest()
    let reqRes = wire.DiLoCoOpenJobRequestDecodeFill(req, payload)
    if IsErr(reqRes):
        return Err[bool](Error(reqRes))
    var job = core.DiLoCoJob()
    var version = core.DiLoCoGlobalVersion()
    let openRes = core.DiLoCoOpenJobFill(job,
                                           version,
                                           node.state,
                                           req.jobBundleCid,
                                           req.requestedWorkerCount,
                                           req.innerStepBudget,
                                           req.outerStepTimeoutSeconds,
                                           req.initialModelRef,
                                           req.initialOptimizerRef)
    if IsErr(openRes):
        out = wire.DiLoCoWireEncodeErrorEnvelope(wire.DiLoCoMessageOpenJob, Error(openRes))
        return Ok[bool](true)
    var resp = wire.DiLoCoOpenJobResponse()
    resp.job = job
    resp.version = version
    out = wire.DiLoCoOpenJobResponseEncode(resp)
    return Ok[bool](true)

