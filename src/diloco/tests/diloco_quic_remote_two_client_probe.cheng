import std/cmdline as cmdline
import cheng/std/bytes_layout as layout
import cheng/DiLoCo/host/diloco_client
import cheng/DiLoCo/protocol/wire
import cheng/DiLoCo/tests/support
import std/strutils as strutil

fn joinPeer(port: int32,
            jobBundleCid: layout.FixedBytes32,
            seed: str,
            expectedFixedCount: int32): int32 =
    var joinReq = wire.DiLoCoJoinCohortRequest()
    joinReq.jobBundleCid = jobBundleCid
    joinReq.peerId = support.DiLoCoTestPeer(seed)
    let joinRes = diloco_client.DiLoCoJoinCohortRequestNamed("127.0.0.1",
                                                             port,
                                                             "localhost",
                                                             joinReq)
    if !joinRes.ok:
        echo(strutil.Join(["join failed seed=", seed, " err=", Error(joinRes)], ""))
        return 1
    if Value(joinRes).cohort.fixedMemberCount != expectedFixedCount:
        echo(strutil.Join(["join fixed count mismatch seed=", seed], ""))
        return 1
    return 0

fn fetchLease(port: int32,
              jobBundleCid: layout.FixedBytes32,
              seed: str): int32 =
    var leaseReq = wire.DiLoCoFetchLeaseRequest()
    leaseReq.jobBundleCid = jobBundleCid
    leaseReq.peerId = support.DiLoCoTestPeer(seed)
    let leaseRes = diloco_client.DiLoCoFetchLeaseRequestNamed("127.0.0.1",
                                                              port,
                                                              "localhost",
                                                              leaseReq)
    if !leaseRes.ok:
        echo(strutil.Join(["lease failed seed=", seed, " err=", Error(leaseRes)], ""))
        return 1
    if Value(leaseRes).lease.outerStep != 1:
        echo(strutil.Join(["lease outer step mismatch seed=", seed], ""))
        return 1
    return 0

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    assert(port > 0, " diloco quic remote two: client port")
    let jobBundleCid = support.DiLoCoTestJobBundleCid("quic-remote-two")

    let join0 = joinPeer(port, jobBundleCid, "diloco.quic.remote.worker.0", 0)
    if join0 != 0:
        return join0
    let join1 = joinPeer(port, jobBundleCid, "diloco.quic.remote.worker.1", 2)
    if join1 != 0:
        return join1
    let lease0 = fetchLease(port, jobBundleCid, "diloco.quic.remote.worker.0")
    if lease0 != 0:
        return lease0
    let lease1 = fetchLease(port, jobBundleCid, "diloco.quic.remote.worker.1")
    if lease1 != 0:
        return lease1
    echo(" diloco_quic_remote_two_client_probe ok")
    return 0
