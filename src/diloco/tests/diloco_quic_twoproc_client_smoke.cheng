import std/cmdline as cmdline
import cheng/std/bytes_layout as layout
import cheng/DiLoCo/host/diloco_client as diloco_host
import cheng/DiLoCo/protocol/wire
import cheng/DiLoCo/tests/support

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    assert(port > 0, " diloco quic twoproc: client port")

    let jobBundleCid = support.DiLoCoTestJobBundleCid("quic-twoproc")
    let leaderPeerId = support.DiLoCoTestPeer("diloco.quic.leader")
    let workerPeerId = support.DiLoCoTestPeer("diloco.quic.worker")
    let workerModelDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-worker-model-delta")
    let workerOptimizerDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-worker-optimizer-delta")
    let mergedModelRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-merged-model")
    let mergedOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-merged-optimizer")

    var joinReq = wire.DiLoCoJoinCohortRequest()
    joinReq.jobBundleCid = jobBundleCid
    joinReq.peerId = workerPeerId
    let joinRes = diloco_host.DiLoCoJoinCohortRequestNamed("127.0.0.1", port, "localhost", joinReq)
    assert(joinRes.ok, " diloco quic twoproc: join")
    assert(Value(joinRes).cohort.fixedMemberCount == 2, " diloco quic twoproc: fixed cohort")
    assert(layout.FixedBytes32Equal(Value(joinRes).cohort.jobBundleCid, jobBundleCid),
        " diloco quic twoproc: cohort job cid")

    var leaseReq = wire.DiLoCoFetchLeaseRequest()
    leaseReq.jobBundleCid = jobBundleCid
    leaseReq.peerId = workerPeerId
    let leaseRes = diloco_host.DiLoCoFetchLeaseRequestNamed("127.0.0.1", port, "localhost", leaseReq)
    assert(leaseRes.ok, " diloco quic twoproc: lease")
    let lease = Value(leaseRes).lease
    assert(lease.outerStep == 1, " diloco quic twoproc: lease outer step")

    var barrierReq = wire.DiLoCoReportInnerStepDoneRequest()
    barrierReq.jobBundleCid = jobBundleCid
    barrierReq.peerId = workerPeerId
    let barrierRes = diloco_host.DiLoCoReportInnerStepDoneRequestNamed("127.0.0.1", port, "localhost", barrierReq)
    assert(barrierRes.ok, " diloco quic twoproc: barrier")

    var deltaReq = wire.DiLoCoSubmitOuterDeltaRequest()
    deltaReq.jobBundleCid = jobBundleCid
    deltaReq.baseVersionCid = lease.baseVersionCid
    deltaReq.outerStep = lease.outerStep
    deltaReq.publisherPeerId = workerPeerId
    deltaReq.modelDeltaRef = workerModelDeltaRef
    deltaReq.optimizerDeltaRef = workerOptimizerDeltaRef
    deltaReq.sampleCount = 9
    deltaReq.tokenCount = 72
    deltaReq.innerStepCount = lease.innerStepBudget
    deltaReq.weightNumerator = 9
    deltaReq.weightDenominator = 16
    let deltaRes = diloco_host.DiLoCoSubmitOuterDeltaRequestNamed("127.0.0.1", port, "localhost", deltaReq)
    assert(deltaRes.ok, " diloco quic twoproc: delta")

    var statusReq = wire.DiLoCoFetchStepStatusRequest()
    statusReq.jobBundleCid = jobBundleCid
    let statusRes = diloco_host.DiLoCoFetchStepStatusRequestNamed("127.0.0.1", port, "localhost", statusReq)
    assert(statusRes.ok, " diloco quic twoproc: status")
    let status = Value(statusRes).status
    assert(status.barrierReady, " diloco quic twoproc: status barrier")
    assert(status.contributionCount != 0, " diloco quic twoproc: status contributions zero")
    assert(status.contributionCount != 1, " diloco quic twoproc: status contributions one")
    assert(status.contributionCount == 2, " diloco quic twoproc: status contributions")

    var commitReq = wire.DiLoCoPublishMergeCommitRequest()
    commitReq.jobBundleCid = jobBundleCid
    commitReq.publisherPeerId = leaderPeerId
    commitReq.mergedModelRef = mergedModelRef
    commitReq.mergedOptimizerRef = mergedOptimizerRef
    let commitRes = diloco_host.DiLoCoPublishMergeCommitRequestNamed("127.0.0.1", port, "localhost", commitReq)
    assert(commitRes.ok, " diloco quic twoproc: commit")
    let commitVersion = Value(commitRes).version
    assert(commitVersion.committedOuterStep == 1, " diloco quic twoproc: committed outer step")

    var versionReq = wire.DiLoCoFetchGlobalVersionRequest()
    versionReq.jobBundleCid = jobBundleCid
    let versionRes = diloco_host.DiLoCoFetchGlobalVersionRequestNamed("127.0.0.1", port, "localhost", versionReq)
    assert(versionRes.ok, " diloco quic twoproc: version")
    assert(layout.FixedBytes32Equal(Value(versionRes).version.versionCid, commitVersion.versionCid),
        " diloco quic twoproc: version cid")

    var lineageReq = wire.DiLoCoFetchLineageRequest()
    lineageReq.jobBundleCid = jobBundleCid
    let lineageRes = diloco_host.DiLoCoFetchLineageRequestNamed("127.0.0.1", port, "localhost", lineageReq)
    assert(lineageRes.ok, " diloco quic twoproc: lineage")
    assert(Value(lineageRes).versions.len == 2, " diloco quic twoproc: lineage len")
    assert(layout.FixedBytes32Equal(Value(lineageRes).versions[0].versionCid, commitVersion.versionCid),
        " diloco quic twoproc: lineage head")

    echo(" diloco_quic_twoproc_client_smoke ok")
    return 0
