import std/cmdline as cmdline
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/host/diloco_host
import cheng/DiLoCo/tests/support

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    var readyPathRaw: str
    let hasReady = cmdline.ReadFirstFlagValue("--ready-path", readyPathRaw)
    let readyPath = if hasReady: readyPathRaw else: ""

    let jobBundleCid = support.DiLoCoTestJobBundleCid("quic-twoproc")
    let leaderPeerId = support.DiLoCoTestPeer("diloco.quic.leader")
    let initialModelRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-initial-model")
    let initialOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-initial-optimizer")
    let leaderModelDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-leader-model-delta")
    let leaderOptimizerDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-leader-optimizer-delta")
    let mergedModelRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-merged-model")
    let mergedOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "quic-merged-optimizer")

    var node = diloco_host.DiLoCoHostInit("diloco.quic.server")
    var job = core.DiLoCoJob()
    var version = core.DiLoCoGlobalVersion()
    let openRes = core.DiLoCoOpenJobFill(job,
                                           version,
                                           node.state,
                                           jobBundleCid,
                                           2,
                                           5,
                                           60,
                                           initialModelRef,
                                           initialOptimizerRef)
    assert(openRes.ok, " diloco quic twoproc: open")
    var cohort = core.DiLoCoCohort()
    let joinLeaderRes = core.DiLoCoJoinCohortFill(cohort, node.state, jobBundleCid, leaderPeerId)
    assert(joinLeaderRes.ok, " diloco quic twoproc: join leader")
    diloco_host.DiLoCoHostEnableAutoLeader(node,
                                             jobBundleCid,
                                             leaderPeerId,
                                             leaderModelDeltaRef,
                                             leaderOptimizerDeltaRef,
                                             8,
                                             64,
                                             5,
                                             8,
                                             16)

    let serveRes = diloco_host.DiLoCoHostServeWindowNamed(node,
                                                            "127.0.0.1",
                                                            port,
                                                            "localhost",
                                                            readyPath,
                                                            8,
                                                            -1)
    assert(serveRes.ok, " diloco quic twoproc: serve")

    var currentVersion = core.DiLoCoGlobalVersion()
    let versionRes = core.DiLoCoFetchGlobalVersionFill(currentVersion, node.state, jobBundleCid)
    assert(versionRes.ok, " diloco quic twoproc: fetch current version")
    assert(currentVersion.committedOuterStep == 1, " diloco quic twoproc: committed outer step")
    assert(node.state.jobs[0].currentOuterStep == 2, " diloco quic twoproc: advanced outer step")
    let mergedModelContract = core.DiLoCoArtifactRefValidate(mergedModelRef)
    assert(mergedModelContract.ok, " diloco quic twoproc: merged model contract")
    let mergedOptimizerContract = core.DiLoCoArtifactRefValidate(mergedOptimizerRef)
    assert(mergedOptimizerContract.ok, " diloco quic twoproc: merged optimizer contract")
    echo(" diloco_quic_twoproc_server_smoke ok")
    return 0
