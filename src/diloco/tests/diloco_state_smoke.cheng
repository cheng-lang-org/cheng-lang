import cheng/std/bytes_layout as layout
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/tests/support

fn main(): int32 =
    let jobBundleCid = support.DiLoCoTestJobBundleCid("state-smoke")
    let initialModelRef = support.DiLoCoTestArtifact(jobBundleCid, "initial-model")
    let initialOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "initial-optimizer")
    let leaderModelDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "leader-model-delta")
    let leaderOptimizerDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "leader-optimizer-delta")
    let workerModelDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "worker-model-delta")
    let workerOptimizerDeltaRef = support.DiLoCoTestArtifact(jobBundleCid, "worker-optimizer-delta")
    let mergedModelRef = support.DiLoCoTestArtifact(jobBundleCid, "merged-model")
    let mergedOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "merged-optimizer")
    let leaderPeerId = support.DiLoCoTestPeer("diloco.state.leader")
    let workerPeerId = support.DiLoCoTestPeer("diloco.state.worker")
    var state = core.DiLoCoStateInit("diloco.state.smoke")

    var openedJob = core.DiLoCoJob()
    var genesisVersion = core.DiLoCoGlobalVersion()
    let openRes = core.DiLoCoOpenJobFill(openedJob,
                                           genesisVersion,
                                           state,
                                           jobBundleCid,
                                           2,
                                           5,
                                           60,
                                           initialModelRef,
                                           initialOptimizerRef)
    assert(openRes.ok, " diloco state smoke: open job")
    assert(openedJob.currentOuterStep == 1, " diloco state smoke: current outer step")
    assert(layout.FixedBytes32Equal(state.jobs[0].currentGlobalVersionCid, state.versions[0].versionCid),
        " diloco state smoke: state open current version")
    assert(layout.FixedBytes32Equal(genesisVersion.versionCid, state.versions[0].versionCid),
        " diloco state smoke: genesis version output")
    assert(layout.FixedBytes32Equal(openedJob.currentGlobalVersionCid, state.jobs[0].currentGlobalVersionCid),
        " diloco state smoke: opened job output")

    var cohort = core.DiLoCoCohort()
    let joinLeaderRes = core.DiLoCoJoinCohortFill(cohort, state, jobBundleCid, leaderPeerId)
    assert(joinLeaderRes.ok, " diloco state smoke: join leader")
    let joinWorkerRes = core.DiLoCoJoinCohortFill(cohort, state, jobBundleCid, workerPeerId)
    assert(joinWorkerRes.ok, " diloco state smoke: join worker")
    assert(layout.FixedBytes32Equal(state.jobs[0].currentGlobalVersionCid, genesisVersion.versionCid),
        " diloco state smoke: state job current version after join")
    assert(cohort.fixedMemberCount == 2, " diloco state smoke: fixed cohort")
    assert(layout.FixedBytes32Equal(state.jobs[0].cohortCid, cohort.cohortCid),
        " diloco state smoke: job cohort cid")

    var leaderLease = core.DiLoCoLease()
    var workerLease = core.DiLoCoLease()
    let leaderLeaseRes = core.DiLoCoFetchLeaseFill(leaderLease, state, jobBundleCid, leaderPeerId)
    let workerLeaseRes = core.DiLoCoFetchLeaseFill(workerLease, state, jobBundleCid, workerPeerId)
    assert(leaderLeaseRes.ok, " diloco state smoke: leader lease")
    assert(workerLeaseRes.ok, " diloco state smoke: worker lease")
    assert(!layout.FixedBytes32Equal(genesisVersion.versionCid, layout.FixedBytes32()),
        " diloco state smoke: genesis version nonzero")
    assert(layout.FixedBytes32Equal(state.jobs[0].currentGlobalVersionCid, genesisVersion.versionCid),
        " diloco state smoke: job current version")
    assert(layout.FixedBytes32Equal(leaderLease.baseVersionCid, state.jobs[0].currentGlobalVersionCid),
        " diloco state smoke: lease current version")
    assert(layout.FixedBytes32Equal(leaderLease.baseVersionCid, genesisVersion.versionCid),
        " diloco state smoke: lease base version")

    var barrier = core.DiLoCoBarrier()
    let leaderBarrierRes = core.DiLoCoReportInnerStepDoneFill(barrier, state, jobBundleCid, leaderPeerId)
    assert(leaderBarrierRes.ok, " diloco state smoke: leader barrier")
    let workerBarrierRes = core.DiLoCoReportInnerStepDoneFill(barrier, state, jobBundleCid, workerPeerId)
    assert(workerBarrierRes.ok, " diloco state smoke: worker barrier")
    assert(barrier.sealed, " diloco state smoke: barrier sealed")

    let leaderBaseVersionCid: layout.FixedBytes32 = leaderLease.baseVersionCid
    let leaderOuterStep: int32 = leaderLease.outerStep
    let leaderInnerStepBudget: int32 = leaderLease.innerStepBudget
    assert(core.DiLoCoCohortHasPeer(state.cohorts[0], leaderPeerId),
        " diloco state smoke: state cohort has leader")
    assert(state.cohorts[0].fixedMemberCount == 2,
        " diloco state smoke: state cohort fixed count")
    assert(layout.FixedBytes32Equal(leaderBaseVersionCid, state.jobs[0].currentGlobalVersionCid),
        " diloco state smoke: submit base version current")
    assert(leaderOuterStep == state.jobs[0].currentOuterStep,
        " diloco state smoke: submit outer step current")
    assert(state.barriers.len == 1,
        " diloco state smoke: state barrier count")
    assert(state.barriers[0].sealed,
        " diloco state smoke: state barrier sealed")
    assert(state.barriers[0].completedPeerIds.len == 2,
        " diloco state smoke: state barrier completed count")
    let leaderModelRefOk = core.DiLoCoArtifactRefValidate(leaderModelDeltaRef)
    let leaderOptimizerRefOk = core.DiLoCoArtifactRefValidate(leaderOptimizerDeltaRef)
    assert(leaderModelRefOk.ok,
        " diloco state smoke: leader model ref valid")
    assert(leaderOptimizerRefOk.ok,
        " diloco state smoke: leader optimizer ref valid")
    assert(core.DiLoCoDeltaPos(state,
                                 jobBundleCid,
                                 leaderBaseVersionCid,
                                 leaderOuterStep,
                                 leaderPeerId) < 0,
        " diloco state smoke: submit duplicate absent")
    var leaderDelta = core.DiLoCoOuterDelta()
    let leaderDeltaRes = core.DiLoCoSubmitOuterDeltaFill(leaderDelta,
                                                           state,
                                                           jobBundleCid,
                                                           leaderBaseVersionCid,
                                                           leaderOuterStep,
                                                           leaderPeerId,
                                                           leaderModelDeltaRef,
                                                           leaderOptimizerDeltaRef,
                                                           8,
                                                           64,
                                                           leaderInnerStepBudget,
                                                           8,
                                                           16)
    assert(leaderDeltaRes.ok, " diloco state smoke: leader delta")
    let workerBaseVersionCid: layout.FixedBytes32 = workerLease.baseVersionCid
    let workerOuterStep: int32 = workerLease.outerStep
    let workerInnerStepBudget: int32 = workerLease.innerStepBudget
    var workerDelta = core.DiLoCoOuterDelta()
    let workerDeltaRes = core.DiLoCoSubmitOuterDeltaFill(workerDelta,
                                                           state,
                                                           jobBundleCid,
                                                           workerBaseVersionCid,
                                                           workerOuterStep,
                                                           workerPeerId,
                                                           workerModelDeltaRef,
                                                           workerOptimizerDeltaRef,
                                                           9,
                                                           72,
                                                           workerInnerStepBudget,
                                                           9,
                                                           16)
    assert(workerDeltaRes.ok, " diloco state smoke: worker delta")

    var status = core.DiLoCoStepStatus()
    let statusRes = core.DiLoCoFetchStepStatusFill(status, state, jobBundleCid)
    assert(statusRes.ok, " diloco state smoke: fetch status")
    assert(status.barrierReady, " diloco state smoke: status barrier")
    assert(status.contributionCount == 2, " diloco state smoke: status contributions")

    var mergeCommit = core.DiLoCoMergeCommit()
    var mergedVersion = core.DiLoCoGlobalVersion()
    let commitRes = core.DiLoCoPublishMergeCommitFill(mergeCommit,
                                                        mergedVersion,
                                                        state,
                                                        jobBundleCid,
                                                        leaderPeerId,
                                                        mergedModelRef,
                                                        mergedOptimizerRef)
    assert(commitRes.ok, " diloco state smoke: publish commit")
    assert(mergedVersion.committedOuterStep == 1, " diloco state smoke: committed outer step")
    assert(layout.FixedBytes32Equal(mergedVersion.baseVersionCid, genesisVersion.versionCid),
        " diloco state smoke: merged version base")
    assert(state.jobs[0].currentOuterStep == 2, " diloco state smoke: advanced outer step")
    assert(state.versions.len == 2, " diloco state smoke: state versions len")
    assert(state.versions[0].committedOuterStep == 0, " diloco state smoke: state genesis step")
    assert(state.versions[1].committedOuterStep == 1, " diloco state smoke: state merged step")
    assert(layout.FixedBytes32Equal(state.versions[1].baseVersionCid, genesisVersion.versionCid),
        " diloco state smoke: state merged base")

    var currentVersion = core.DiLoCoGlobalVersion()
    let versionRes = core.DiLoCoFetchGlobalVersionFill(currentVersion, state, jobBundleCid)
    assert(versionRes.ok, " diloco state smoke: fetch global version")
    assert(layout.FixedBytes32Equal(currentVersion.versionCid, mergedVersion.versionCid),
        " diloco state smoke: current version")
    assert(layout.FixedBytes32Equal(currentVersion.baseVersionCid, genesisVersion.versionCid),
        " diloco state smoke: current version base")

    var lineage: core.DiLoCoGlobalVersion[]
    let lineageRes = core.DiLoCoFetchLineageFill(lineage, state, jobBundleCid)
    assert(lineageRes.ok, " diloco state smoke: fetch lineage")
    assert(lineage.len == 2, " diloco state smoke: lineage length")
    assert(layout.FixedBytes32Equal(lineage[0].versionCid, mergedVersion.versionCid),
        " diloco state smoke: lineage head")
    assert(lineage[1].committedOuterStep == 0, " diloco state smoke: lineage genesis")

    var staleDelta = core.DiLoCoOuterDelta()
    let staleRes = core.DiLoCoSubmitOuterDeltaFill(staleDelta,
                                                     state,
                                                     jobBundleCid,
                                                     leaderBaseVersionCid,
                                                     leaderOuterStep,
                                                     leaderPeerId,
                                                     leaderModelDeltaRef,
                                                     leaderOptimizerDeltaRef,
                                                     8,
                                                     64,
                                                     leaderInnerStepBudget,
                                                     8,
                                                     16)
    assert(!staleRes.ok, " diloco state smoke: stale submit rejected")

    echo(" diloco_state_smoke ok")
    return 0
