import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/DiLoCo/core/diloco as core

fn DiLoCoTestJobBundleCid(label: str): layout.FixedBytes32 =
    var buf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.test.job"))
    layout.ByteBufAppendBytes(buf, bytesFromString(label))
    return lt.FixedCidFromBuf(buf)

fn DiLoCoTestPeer(seed: str): types.Libp2pPeerId =
    return peer_id.Libp2pPeerIdFromSeed(seed)

fn DiLoCoTestArtifact(jobBundleCid: layout.FixedBytes32,
                        label: str): core.DiLoCoArtifactRef =
    var out = core.DiLoCoArtifactRef()
    let fillRes = core.DiLoCoArtifactRefFromBytesFill(out,
                                                        jobBundleCid,
                                                        bytesFromString("artifact:" + label),
                                                        64,
                                                        label)
    assert(fillRes.ok, " diloco test artifact")
    return out
