import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/protocol/wire
import cheng/DiLoCo/tests/support

fn DiLoCoWireSmokeCopyBytes(value: Bytes): Bytes =
    let out = bytesAlloc(bytesLen(value))
    for i in 0..<bytesLen(value):
        bytesSet(out, i, bytesGet(value, i))
    return out

fn DiLoCoWireSmokeVerifyEnvelopeFailures(openReqBytes: Bytes): Result[bool] =
    var badVersion: Bytes = DiLoCoWireSmokeCopyBytes(openReqBytes)
    bytesSet(badVersion, 7, 2)
    var envelope = wire.DiLoCoEnvelope()
    let badVersionRes: Result[bool] = wire.DiLoCoEnvelopeDecodeFill(envelope, badVersion)
    if badVersionRes.ok:
        return Err[bool](" diloco wire smoke: bad version reject")

    var badKind: Bytes = DiLoCoWireSmokeCopyBytes(openReqBytes)
    bytesSet(badKind, 11, 99)
    let badKindRes: Result[bool] = wire.DiLoCoEnvelopeDecodeFill(envelope, badKind)
    if badKindRes.ok:
        return Err[bool](" diloco wire smoke: bad kind reject")

    let shortPayload: Bytes = bytesSlice(openReqBytes, 0, bytesLen(openReqBytes) - 1)
    let shortRes: Result[bool] = wire.DiLoCoEnvelopeDecodeFill(envelope, shortPayload)
    if shortRes.ok:
        return Err[bool](" diloco wire smoke: short shape reject")

    let errorPayload: Bytes = wire.DiLoCoWireEncodeErrorEnvelope(wire.DiLoCoMessageFetchGlobalVersion,
                                                                   "forced-error")
    var errorResponse = wire.DiLoCoFetchGlobalVersionResponse()
    let errorRes: Result[bool] = wire.DiLoCoFetchGlobalVersionResponseDecodeFill(errorResponse,
                                                                                   errorPayload)
    if errorRes.ok:
        return Err[bool](" diloco wire smoke: error envelope reject")
    return Ok[bool](true)

fn main(): int32 =
    let jobBundleCid = support.DiLoCoTestJobBundleCid("wire-smoke")
    let leaderPeerId = support.DiLoCoTestPeer("diloco.wire.leader")
    let workerPeerId = support.DiLoCoTestPeer("diloco.wire.worker")
    let initialModelRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-initial-model")
    let initialOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-initial-optimizer")
    let deltaModelRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-delta-model")
    let deltaOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-delta-optimizer")
    let mergedModelRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-merged-model")
    let mergedOptimizerRef = support.DiLoCoTestArtifact(jobBundleCid, "wire-merged-optimizer")

    var job = core.DiLoCoJob()
    job.jobBundleCid = jobBundleCid
    job.requestedWorkerCount = 2
    job.innerStepBudget = 5
    job.outerStepTimeoutSeconds = 60
    job.currentGlobalVersionCid = support.DiLoCoTestJobBundleCid("wire-current-version")
    job.currentOuterStep = 1
    job.sealed = true
    job.cohortCid = support.DiLoCoTestJobBundleCid("wire-cohort")
    job.openedAtEpochSeconds = int64(11)

    var cohort = core.DiLoCoCohort()
    cohort.jobBundleCid = jobBundleCid
    cohort.cohortCid = job.cohortCid
    cohort.leaderPeerId = leaderPeerId
    cohort.members = [leaderPeerId, workerPeerId]
    cohort.sealedAtEpochSeconds = int64(12)
    cohort.fixedMemberCount = 2

    var lease = core.DiLoCoLease()
    lease.jobBundleCid = jobBundleCid
    lease.cohortCid = cohort.cohortCid
    lease.peerId = workerPeerId
    lease.baseVersionCid = job.currentGlobalVersionCid
    lease.outerStep = 1
    lease.innerStepBudget = 5
    lease.leasedAtEpochSeconds = int64(13)
    lease.expiresAtEpochSeconds = int64(73)
    lease.active = true

    var barrier = core.DiLoCoBarrier()
    barrier.jobBundleCid = jobBundleCid
    barrier.cohortCid = cohort.cohortCid
    barrier.baseVersionCid = lease.baseVersionCid
    barrier.outerStep = 1
    barrier.expectedMemberCount = 2
    barrier.completedPeerIds = [leaderPeerId, workerPeerId]
    barrier.sealed = true

    var delta = core.DiLoCoOuterDelta()
    delta.jobBundleCid = jobBundleCid
    delta.deltaCid = support.DiLoCoTestJobBundleCid("wire-delta")
    delta.baseVersionCid = lease.baseVersionCid
    delta.outerStep = 1
    delta.publisherPeerId = workerPeerId
    delta.modelDeltaRef = deltaModelRef
    delta.optimizerDeltaRef = deltaOptimizerRef
    delta.sampleCount = 9
    delta.tokenCount = 72
    delta.innerStepCount = 5
    delta.weightNumerator = 9
    delta.weightDenominator = 16
    delta.submittedAtEpochSeconds = int64(14)

    var status = core.DiLoCoStepStatus()
    status.jobBundleCid = jobBundleCid
    status.baseVersionCid = lease.baseVersionCid
    status.outerStep = 1
    status.barrierReady = true
    status.barrierArrivedCount = 2
    status.expectedMemberCount = 2
    status.contributionCount = 2
    status.commitPublished = true
    status.mergeCommitCid = support.DiLoCoTestJobBundleCid("wire-commit")

    var version = core.DiLoCoGlobalVersion()
    version.jobBundleCid = jobBundleCid
    version.versionCid = support.DiLoCoTestJobBundleCid("wire-version")
    version.baseVersionCid = lease.baseVersionCid
    version.committedOuterStep = 1
    version.publisherPeerId = leaderPeerId
    version.modelRef = mergedModelRef
    version.optimizerRef = mergedOptimizerRef
    version.acceptedCount = 2
    version.committedAtEpochSeconds = int64(15)

    var commit = core.DiLoCoMergeCommit()
    commit.jobBundleCid = jobBundleCid
    commit.commitCid = status.mergeCommitCid
    commit.baseVersionCid = lease.baseVersionCid
    commit.nextGlobalVersionCid = version.versionCid
    commit.outerStep = 1
    commit.leaderPeerId = leaderPeerId
    commit.acceptedCount = 2
    commit.contributionCids = [delta.deltaCid, support.DiLoCoTestJobBundleCid("wire-delta-leader")]
    commit.publishedAtEpochSeconds = int64(15)

    var openReq = wire.DiLoCoOpenJobRequest()
    openReq.jobBundleCid = jobBundleCid
    openReq.requestedWorkerCount = 2
    openReq.innerStepBudget = 5
    openReq.outerStepTimeoutSeconds = 60
    openReq.initialModelRef = initialModelRef
    openReq.initialOptimizerRef = initialOptimizerRef
    let openReqBytes = wire.DiLoCoOpenJobRequestEncode(openReq)
    var openReqRoundtrip = wire.DiLoCoOpenJobRequest()
    let openReqRes = wire.DiLoCoOpenJobRequestDecodeFill(openReqRoundtrip, openReqBytes)
    assert(openReqRes.ok, " diloco wire smoke: open request")
    assert(layout.FixedBytes32Equal(openReqRoundtrip.jobBundleCid, jobBundleCid), " diloco wire smoke: open request cid")

    var openResp = wire.DiLoCoOpenJobResponse()
    openResp.job = job
    openResp.version = version
    let openRespBytes = wire.DiLoCoOpenJobResponseEncode(openResp)
    var openRespRoundtrip = wire.DiLoCoOpenJobResponse()
    let openRespRes = wire.DiLoCoOpenJobResponseDecodeFill(openRespRoundtrip, openRespBytes)
    assert(openRespRes.ok, " diloco wire smoke: open response")
    assert(layout.FixedBytes32Equal(openRespRoundtrip.version.versionCid, version.versionCid), " diloco wire smoke: open response version")

    var joinReq = wire.DiLoCoJoinCohortRequest()
    joinReq.jobBundleCid = jobBundleCid
    joinReq.peerId = workerPeerId
    let joinReqBytes = wire.DiLoCoJoinCohortRequestEncode(joinReq)
    var joinReqRoundtrip = wire.DiLoCoJoinCohortRequest()
    let joinReqRes = wire.DiLoCoJoinCohortRequestDecodeFill(joinReqRoundtrip, joinReqBytes)
    assert(joinReqRes.ok,
        " diloco wire smoke: join request")
    var joinResp = wire.DiLoCoJoinCohortResponse()
    joinResp.cohort = cohort
    let joinRespBytes = wire.DiLoCoJoinCohortResponseEncode(joinResp)
    var joinRespRoundtrip = wire.DiLoCoJoinCohortResponse()
    let joinRespRes = wire.DiLoCoJoinCohortResponseDecodeFill(joinRespRoundtrip, joinRespBytes)
    assert(joinRespRes.ok,
        " diloco wire smoke: join response")

    var leaseReq = wire.DiLoCoFetchLeaseRequest()
    leaseReq.jobBundleCid = jobBundleCid
    leaseReq.peerId = workerPeerId
    let leaseReqBytes = wire.DiLoCoFetchLeaseRequestEncode(leaseReq)
    var leaseReqRoundtrip = wire.DiLoCoFetchLeaseRequest()
    let leaseReqRes = wire.DiLoCoFetchLeaseRequestDecodeFill(leaseReqRoundtrip, leaseReqBytes)
    assert(leaseReqRes.ok,
        " diloco wire smoke: lease request")
    var leaseResp = wire.DiLoCoFetchLeaseResponse()
    leaseResp.lease = lease
    let leaseRespBytes = wire.DiLoCoFetchLeaseResponseEncode(leaseResp)
    var leaseRespRoundtrip = wire.DiLoCoFetchLeaseResponse()
    let leaseRespRes = wire.DiLoCoFetchLeaseResponseDecodeFill(leaseRespRoundtrip, leaseRespBytes)
    assert(leaseRespRes.ok,
        " diloco wire smoke: lease response")

    var barrierReq = wire.DiLoCoReportInnerStepDoneRequest()
    barrierReq.jobBundleCid = jobBundleCid
    barrierReq.peerId = workerPeerId
    let barrierReqBytes = wire.DiLoCoReportInnerStepDoneRequestEncode(barrierReq)
    var barrierReqRoundtrip = wire.DiLoCoReportInnerStepDoneRequest()
    let barrierReqRes = wire.DiLoCoReportInnerStepDoneRequestDecodeFill(barrierReqRoundtrip, barrierReqBytes)
    assert(barrierReqRes.ok,
        " diloco wire smoke: barrier request")
    var barrierResp = wire.DiLoCoReportInnerStepDoneResponse()
    barrierResp.barrier = barrier
    let barrierRespBytes = wire.DiLoCoReportInnerStepDoneResponseEncode(barrierResp)
    var barrierRespRoundtrip = wire.DiLoCoReportInnerStepDoneResponse()
    let barrierRespRes = wire.DiLoCoReportInnerStepDoneResponseDecodeFill(barrierRespRoundtrip, barrierRespBytes)
    assert(barrierRespRes.ok,
        " diloco wire smoke: barrier response")

    var deltaReq = wire.DiLoCoSubmitOuterDeltaRequest()
    deltaReq.jobBundleCid = jobBundleCid
    deltaReq.baseVersionCid = lease.baseVersionCid
    deltaReq.outerStep = 1
    deltaReq.publisherPeerId = workerPeerId
    deltaReq.modelDeltaRef = deltaModelRef
    deltaReq.optimizerDeltaRef = deltaOptimizerRef
    deltaReq.sampleCount = 9
    deltaReq.tokenCount = 72
    deltaReq.innerStepCount = 5
    deltaReq.weightNumerator = 9
    deltaReq.weightDenominator = 16
    let deltaReqBytes = wire.DiLoCoSubmitOuterDeltaRequestEncode(deltaReq)
    var deltaReqRoundtrip = wire.DiLoCoSubmitOuterDeltaRequest()
    let deltaReqRes = wire.DiLoCoSubmitOuterDeltaRequestDecodeFill(deltaReqRoundtrip, deltaReqBytes)
    assert(deltaReqRes.ok,
        " diloco wire smoke: delta request")
    assert(deltaReqRoundtrip.outerStep == 1, " diloco wire smoke: delta request outer step")
    var deltaResp = wire.DiLoCoSubmitOuterDeltaResponse()
    deltaResp.delta = delta
    let deltaRespBytes = wire.DiLoCoSubmitOuterDeltaResponseEncode(deltaResp)
    var deltaRespRoundtrip = wire.DiLoCoSubmitOuterDeltaResponse()
    let deltaRespRes = wire.DiLoCoSubmitOuterDeltaResponseDecodeFill(deltaRespRoundtrip, deltaRespBytes)
    assert(deltaRespRes.ok,
        " diloco wire smoke: delta response")

    var statusReq = wire.DiLoCoFetchStepStatusRequest()
    statusReq.jobBundleCid = jobBundleCid
    let statusReqBytes = wire.DiLoCoFetchStepStatusRequestEncode(statusReq)
    var statusReqRoundtrip = wire.DiLoCoFetchStepStatusRequest()
    let statusReqRes = wire.DiLoCoFetchStepStatusRequestDecodeFill(statusReqRoundtrip, statusReqBytes)
    assert(statusReqRes.ok,
        " diloco wire smoke: status request")
    var statusResp = wire.DiLoCoFetchStepStatusResponse()
    statusResp.status = status
    let statusRespBytes = wire.DiLoCoFetchStepStatusResponseEncode(statusResp)
    var statusRespRoundtrip = wire.DiLoCoFetchStepStatusResponse()
    let statusRespRes = wire.DiLoCoFetchStepStatusResponseDecodeFill(statusRespRoundtrip, statusRespBytes)
    assert(statusRespRes.ok,
        " diloco wire smoke: status response")

    var commitReq = wire.DiLoCoPublishMergeCommitRequest()
    commitReq.jobBundleCid = jobBundleCid
    commitReq.publisherPeerId = leaderPeerId
    commitReq.mergedModelRef = mergedModelRef
    commitReq.mergedOptimizerRef = mergedOptimizerRef
    let commitReqBytes = wire.DiLoCoPublishMergeCommitRequestEncode(commitReq)
    var commitReqRoundtrip = wire.DiLoCoPublishMergeCommitRequest()
    let commitReqRes = wire.DiLoCoPublishMergeCommitRequestDecodeFill(commitReqRoundtrip, commitReqBytes)
    assert(commitReqRes.ok,
        " diloco wire smoke: commit request")
    var commitResp = wire.DiLoCoPublishMergeCommitResponse()
    commitResp.commit = commit
    commitResp.version = version
    let commitRespBytes = wire.DiLoCoPublishMergeCommitResponseEncode(commitResp)
    var commitRespRoundtrip = wire.DiLoCoPublishMergeCommitResponse()
    let commitRespRes = wire.DiLoCoPublishMergeCommitResponseDecodeFill(commitRespRoundtrip, commitRespBytes)
    assert(commitRespRes.ok,
        " diloco wire smoke: commit response")

    var versionReq = wire.DiLoCoFetchGlobalVersionRequest()
    versionReq.jobBundleCid = jobBundleCid
    let versionReqBytes = wire.DiLoCoFetchGlobalVersionRequestEncode(versionReq)
    var versionReqRoundtrip = wire.DiLoCoFetchGlobalVersionRequest()
    let versionReqRes = wire.DiLoCoFetchGlobalVersionRequestDecodeFill(versionReqRoundtrip, versionReqBytes)
    assert(versionReqRes.ok,
        " diloco wire smoke: version request")
    var versionResp = wire.DiLoCoFetchGlobalVersionResponse()
    versionResp.version = version
    let versionRespBytes = wire.DiLoCoFetchGlobalVersionResponseEncode(versionResp)
    var versionRespRoundtrip = wire.DiLoCoFetchGlobalVersionResponse()
    let versionRespRes = wire.DiLoCoFetchGlobalVersionResponseDecodeFill(versionRespRoundtrip, versionRespBytes)
    assert(versionRespRes.ok,
        " diloco wire smoke: version response")

    let lineageReq = wire.DiLoCoFetchLineageRequest(jobBundleCid: jobBundleCid)
    let lineageReqBytes = wire.DiLoCoFetchLineageRequestEncode(lineageReq)
    var lineageReqRoundtrip = wire.DiLoCoFetchLineageRequest()
    let lineageReqRes = wire.DiLoCoFetchLineageRequestDecodeFill(lineageReqRoundtrip, lineageReqBytes)
    assert(lineageReqRes.ok, " diloco wire smoke: lineage request")
    var lineageRespRoundtrip = wire.DiLoCoFetchLineageResponse()
    var lineageTail = core.DiLoCoGlobalVersion()
    let lineageRespPayload = wire.DiLoCoFetchLineageResponseEncodePair(version, lineageTail)
    if !wire.DiLoCoFetchLineageResponseDecodeOkFill(lineageRespRoundtrip, lineageRespPayload):
        echo(" diloco wire smoke: lineage response")
        return 1
    assert(lineageRespRoundtrip.versions.len == 2, " diloco wire smoke: lineage count")
    assert(layout.FixedBytes32Equal(lineageRespRoundtrip.versions[0].versionCid, version.versionCid),
        " diloco wire smoke: lineage version")
    let failureCheckRes: Result[bool] = DiLoCoWireSmokeVerifyEnvelopeFailures(openReqBytes)
    assert(failureCheckRes.ok, " diloco wire smoke: failure helper")

    echo(" diloco_wire_smoke ok")
    return 0
