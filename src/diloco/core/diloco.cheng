import std/result
import std/times
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/libp2p/core/types

const
    DiLoCoArtifactBlobCodecRaw: int32 = 1
    DiLoCoArtifactLayoutRsSystematic: int32 = 1

type
    DiLoCoArtifactRef =
        stubCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        payloadLen: int32
        paramsCid: layout.FixedBytes32
        layoutKind: int32
        dataShardCount: int32
        parityShardCount: int32
        shardPayloadBytes: int32

    DiLoCoJob =
        jobBundleCid: layout.FixedBytes32
        requestedWorkerCount: int32
        innerStepBudget: int32
        outerStepTimeoutSeconds: int32
        currentGlobalVersionCid: layout.FixedBytes32
        currentOuterStep: int32
        sealed: bool
        cohortCid: layout.FixedBytes32
        openedAtEpochSeconds: int64

    DiLoCoCohort =
        jobBundleCid: layout.FixedBytes32
        cohortCid: layout.FixedBytes32
        leaderPeerId: types.Libp2pPeerId
        members: types.Libp2pPeerId[]
        sealedAtEpochSeconds: int64
        fixedMemberCount: int32

    DiLoCoLease =
        jobBundleCid: layout.FixedBytes32
        cohortCid: layout.FixedBytes32
        peerId: types.Libp2pPeerId
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        innerStepBudget: int32
        leasedAtEpochSeconds: int64
        expiresAtEpochSeconds: int64
        active: bool

    DiLoCoBarrier =
        jobBundleCid: layout.FixedBytes32
        cohortCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        expectedMemberCount: int32
        completedPeerIds: types.Libp2pPeerId[]
        sealed: bool

    DiLoCoOuterDelta =
        jobBundleCid: layout.FixedBytes32
        deltaCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        publisherPeerId: types.Libp2pPeerId
        modelDeltaRef: DiLoCoArtifactRef
        optimizerDeltaRef: DiLoCoArtifactRef
        sampleCount: int32
        tokenCount: int32
        innerStepCount: int32
        weightNumerator: int32
        weightDenominator: int32
        submittedAtEpochSeconds: int64

    DiLoCoMergeCommit =
        jobBundleCid: layout.FixedBytes32
        commitCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        nextGlobalVersionCid: layout.FixedBytes32
        outerStep: int32
        leaderPeerId: types.Libp2pPeerId
        acceptedCount: int32
        contributionCids: layout.FixedBytes32[]
        publishedAtEpochSeconds: int64

    DiLoCoGlobalVersion =
        jobBundleCid: layout.FixedBytes32
        versionCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        committedOuterStep: int32
        publisherPeerId: types.Libp2pPeerId
        modelRef: DiLoCoArtifactRef
        optimizerRef: DiLoCoArtifactRef
        acceptedCount: int32
        committedAtEpochSeconds: int64

    DiLoCoStepStatus =
        jobBundleCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        barrierReady: bool
        barrierArrivedCount: int32
        expectedMemberCount: int32
        contributionCount: int32
        commitPublished: bool
        mergeCommitCid: layout.FixedBytes32

    DiLoCoState =
        stateId: layout.FixedBytes32
        jobs: DiLoCoJob[]
        cohorts: DiLoCoCohort[]
        leases: DiLoCoLease[]
        barriers: DiLoCoBarrier[]
        deltas: DiLoCoOuterDelta[]
        commits: DiLoCoMergeCommit[]
        versions: DiLoCoGlobalVersion[]

fn DiLoCoArtifactRefCopyFill(out: var DiLoCoArtifactRef,
                               src: DiLoCoArtifactRef) =
    out.stubCid = src.stubCid
    out.blobSummaryCid = src.blobSummaryCid
    out.manifestCid = src.manifestCid
    out.blobCid = src.blobCid
    out.payloadLen = src.payloadLen
    out.paramsCid = src.paramsCid
    out.layoutKind = src.layoutKind
    out.dataShardCount = src.dataShardCount
    out.parityShardCount = src.parityShardCount
    out.shardPayloadBytes = src.shardPayloadBytes

fn DiLoCoPeerIdCopyFill(out: var types.Libp2pPeerId,
                          src: types.Libp2pPeerId) =
    out.value = src.value

fn DiLoCoJobCopyFill(out: var DiLoCoJob,
                       src: DiLoCoJob) =
    out.jobBundleCid = src.jobBundleCid
    out.requestedWorkerCount = src.requestedWorkerCount
    out.innerStepBudget = src.innerStepBudget
    out.outerStepTimeoutSeconds = src.outerStepTimeoutSeconds
    out.currentGlobalVersionCid = src.currentGlobalVersionCid
    out.currentOuterStep = src.currentOuterStep
    out.sealed = src.sealed
    out.cohortCid = src.cohortCid
    out.openedAtEpochSeconds = src.openedAtEpochSeconds

fn DiLoCoCohortCopyFill(out: var DiLoCoCohort,
                          src: DiLoCoCohort) =
    out.jobBundleCid = src.jobBundleCid
    out.cohortCid = src.cohortCid
    DiLoCoPeerIdCopyFill(out.leaderPeerId, src.leaderPeerId)
    out.members = []
    for i in 0..<src.members.len:
        add(out.members, src.members[i])
    out.sealedAtEpochSeconds = src.sealedAtEpochSeconds
    out.fixedMemberCount = src.fixedMemberCount

fn DiLoCoLeaseCopyFill(out: var DiLoCoLease,
                         src: DiLoCoLease) =
    out.jobBundleCid = src.jobBundleCid
    out.cohortCid = src.cohortCid
    DiLoCoPeerIdCopyFill(out.peerId, src.peerId)
    out.baseVersionCid = src.baseVersionCid
    out.outerStep = src.outerStep
    out.innerStepBudget = src.innerStepBudget
    out.leasedAtEpochSeconds = src.leasedAtEpochSeconds
    out.expiresAtEpochSeconds = src.expiresAtEpochSeconds
    out.active = src.active

fn DiLoCoBarrierCopyFill(out: var DiLoCoBarrier,
                           src: DiLoCoBarrier) =
    out.jobBundleCid = src.jobBundleCid
    out.cohortCid = src.cohortCid
    out.baseVersionCid = src.baseVersionCid
    out.outerStep = src.outerStep
    out.expectedMemberCount = src.expectedMemberCount
    out.completedPeerIds = []
    for i in 0..<src.completedPeerIds.len:
        add(out.completedPeerIds, src.completedPeerIds[i])
    out.sealed = src.sealed

fn DiLoCoOuterDeltaCopyFill(out: var DiLoCoOuterDelta,
                              src: DiLoCoOuterDelta) =
    out.jobBundleCid = src.jobBundleCid
    out.deltaCid = src.deltaCid
    out.baseVersionCid = src.baseVersionCid
    out.outerStep = src.outerStep
    DiLoCoPeerIdCopyFill(out.publisherPeerId, src.publisherPeerId)
    DiLoCoArtifactRefCopyFill(out.modelDeltaRef, src.modelDeltaRef)
    DiLoCoArtifactRefCopyFill(out.optimizerDeltaRef, src.optimizerDeltaRef)
    out.sampleCount = src.sampleCount
    out.tokenCount = src.tokenCount
    out.innerStepCount = src.innerStepCount
    out.weightNumerator = src.weightNumerator
    out.weightDenominator = src.weightDenominator
    out.submittedAtEpochSeconds = src.submittedAtEpochSeconds

fn DiLoCoMergeCommitCopyFill(out: var DiLoCoMergeCommit,
                               src: DiLoCoMergeCommit) =
    out.jobBundleCid = src.jobBundleCid
    out.commitCid = src.commitCid
    out.baseVersionCid = src.baseVersionCid
    out.nextGlobalVersionCid = src.nextGlobalVersionCid
    out.outerStep = src.outerStep
    DiLoCoPeerIdCopyFill(out.leaderPeerId, src.leaderPeerId)
    out.acceptedCount = src.acceptedCount
    out.contributionCids = []
    for i in 0..<src.contributionCids.len:
        add(out.contributionCids, src.contributionCids[i])
    out.publishedAtEpochSeconds = src.publishedAtEpochSeconds

fn DiLoCoGlobalVersionCopyFill(out: var DiLoCoGlobalVersion,
                                 src: var DiLoCoGlobalVersion) =
    out.jobBundleCid = src.jobBundleCid
    out.versionCid = src.versionCid
    out.baseVersionCid = src.baseVersionCid
    out.committedOuterStep = src.committedOuterStep
    out.publisherPeerId.value = src.publisherPeerId.value
    out.modelRef.stubCid = src.modelRef.stubCid
    out.modelRef.blobSummaryCid = src.modelRef.blobSummaryCid
    out.modelRef.manifestCid = src.modelRef.manifestCid
    out.modelRef.blobCid = src.modelRef.blobCid
    out.modelRef.payloadLen = src.modelRef.payloadLen
    out.modelRef.paramsCid = src.modelRef.paramsCid
    out.modelRef.layoutKind = src.modelRef.layoutKind
    out.modelRef.dataShardCount = src.modelRef.dataShardCount
    out.modelRef.parityShardCount = src.modelRef.parityShardCount
    out.modelRef.shardPayloadBytes = src.modelRef.shardPayloadBytes
    out.optimizerRef.stubCid = src.optimizerRef.stubCid
    out.optimizerRef.blobSummaryCid = src.optimizerRef.blobSummaryCid
    out.optimizerRef.manifestCid = src.optimizerRef.manifestCid
    out.optimizerRef.blobCid = src.optimizerRef.blobCid
    out.optimizerRef.payloadLen = src.optimizerRef.payloadLen
    out.optimizerRef.paramsCid = src.optimizerRef.paramsCid
    out.optimizerRef.layoutKind = src.optimizerRef.layoutKind
    out.optimizerRef.dataShardCount = src.optimizerRef.dataShardCount
    out.optimizerRef.parityShardCount = src.optimizerRef.parityShardCount
    out.optimizerRef.shardPayloadBytes = src.optimizerRef.shardPayloadBytes
    out.acceptedCount = src.acceptedCount
    out.committedAtEpochSeconds = src.committedAtEpochSeconds

fn DiLoCoStateInit(label: str): DiLoCoState =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.state"))
    layout.ByteBufAppendBytes(buf, bytesFromString(label))
    return DiLoCoState(stateId: lt.FixedCidFromBuf(buf))

fn DiLoCoArtifactAuxCid(jobBundleCid: layout.FixedBytes32,
                          anchorCid: layout.FixedBytes32,
                          tag: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(160)
    layout.ByteBufAppendBytes(buf, bytesFromString(tag))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendFixed32(buf, anchorCid)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactBytesCid(payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(bytesLen(payload))
    layout.ByteBufAppendBytes(buf, payload)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactChunkCount(payloadLen: int32,
                              chunkSize: int32): Result[int32] =
    if payloadLen <= 0:
        return Err[int32](" diloco: artifact payload length")
    if chunkSize <= 0:
        return Err[int32](" diloco: artifact chunk size")
    return Ok[int32]((payloadLen + chunkSize - 1) / chunkSize)

fn DiLoCoArtifactBlobSummaryCid(blobCid: layout.FixedBytes32,
                                  payloadLen: int32,
                                  chunkSize: int32,
                                  chunkCount: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.dag_mempool.blob_summary"))
    lt.AppendU32BE(buf, 1)
    lt.AppendU32BE(buf, DiLoCoArtifactBlobCodecRaw)
    lt.AppendFixed32(buf, blobCid)
    lt.AppendU32BE(buf, payloadLen)
    lt.AppendU32BE(buf, chunkSize)
    lt.AppendU32BE(buf, chunkCount)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactParamsCid(layoutKind: int32,
                             dataShardCount: int32,
                             parityShardCount: int32,
                             shardPayloadBytes: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(64)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.erasure.params"))
    lt.AppendU32BE(buf, layoutKind)
    lt.AppendU32BE(buf, dataShardCount)
    lt.AppendU32BE(buf, parityShardCount)
    lt.AppendU32BE(buf, shardPayloadBytes)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactManifestCid(blobCid: layout.FixedBytes32,
                               blobByteLen: int32,
                               paramsCid: layout.FixedBytes32,
                               shardPayloadCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(160)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.erasure.manifest"))
    lt.AppendFixed32(buf, blobCid)
    lt.AppendU32BE(buf, blobByteLen)
    lt.AppendFixed32(buf, paramsCid)
    lt.AppendU32BE(buf, 1)
    lt.AppendU32BE(buf, 0)
    lt.AppendFixed32(buf, shardPayloadCid)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactStubCid(topicCid: layout.FixedBytes32,
                           bundleCid: layout.FixedBytes32,
                           blobSummaryCid: layout.FixedBytes32,
                           advertCid: layout.FixedBytes32,
                           manifestCid: layout.FixedBytes32,
                           recoveryPlanCid: layout.FixedBytes32,
                           payloadLen: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.content.stub.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, topicCid)
    lt.AppendFixed32(buf, bundleCid)
    lt.AppendFixed32(buf, blobSummaryCid)
    lt.AppendFixed32(buf, advertCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendFixed32(buf, recoveryPlanCid)
    lt.AppendU32BE(buf, payloadLen)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoArtifactRefValidate(ref: DiLoCoArtifactRef): Result[bool] =
    if layout.FixedBytes32Equal(ref.stubCid, layout.FixedBytes32()):
        return Err[bool](" diloco: artifact stub cid missing")
    if layout.FixedBytes32Equal(ref.blobSummaryCid, layout.FixedBytes32()):
        return Err[bool](" diloco: artifact blob summary cid missing")
    if layout.FixedBytes32Equal(ref.manifestCid, layout.FixedBytes32()):
        return Err[bool](" diloco: artifact manifest cid missing")
    if layout.FixedBytes32Equal(ref.blobCid, layout.FixedBytes32()):
        return Err[bool](" diloco: artifact blob cid missing")
    if ref.payloadLen <= 0:
        return Err[bool](" diloco: artifact payload len")
    if ref.layoutKind != DiLoCoArtifactLayoutRsSystematic:
        return Err[bool](" diloco: unsupported artifact layout")
    if ref.dataShardCount <= 0:
        return Err[bool](" diloco: artifact data shard count")
    if ref.parityShardCount < 0:
        return Err[bool](" diloco: artifact parity shard count")
    if ref.shardPayloadBytes <= 0:
        return Err[bool](" diloco: artifact shard payload bytes")
    let expectedParamsCid = DiLoCoArtifactParamsCid(ref.layoutKind,
                                                     ref.dataShardCount,
                                                     ref.parityShardCount,
                                                     ref.shardPayloadBytes)
    if !layout.FixedBytes32Equal(ref.paramsCid, expectedParamsCid):
        return Err[bool](" diloco: artifact params cid mismatch")
    return Ok[bool](true)

fn DiLoCoArtifactRefFromBytesFill(out: var DiLoCoArtifactRef,
                                    jobBundleCid: layout.FixedBytes32,
                                    payload: Bytes,
                                    shardPayloadBytes: int32,
                                    tag: str): Result[bool] =
    if layout.FixedBytes32Equal(jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" diloco: artifact bundle cid missing")
    if bytesLen(payload) <= 0:
        return Err[bool](" diloco: artifact payload missing")
    if shardPayloadBytes <= 0:
        return Err[bool](" diloco: artifact shard payload bytes")
    let payloadLen = bytesLen(payload)
    let chunkCountRes = DiLoCoArtifactChunkCount(payloadLen, shardPayloadBytes)
    if IsErr(chunkCountRes):
        return Err[bool](Error(chunkCountRes))
    let blobCid = DiLoCoArtifactBytesCid(payload)
    let blobSummaryCid = DiLoCoArtifactBlobSummaryCid(blobCid,
                                                       payloadLen,
                                                       shardPayloadBytes,
                                                       Value(chunkCountRes))
    let paramsCid = DiLoCoArtifactParamsCid(DiLoCoArtifactLayoutRsSystematic,
                                             1,
                                             0,
                                             shardPayloadBytes)
    let shardPayloadCid = DiLoCoArtifactBytesCid(payload)
    let manifestCid = DiLoCoArtifactManifestCid(blobCid,
                                                 payloadLen,
                                                 paramsCid,
                                                 shardPayloadCid)
    let topicCid = DiLoCoArtifactAuxCid(jobBundleCid, blobCid, "cheng.diloco.artifact.topic")
    let advertCid = DiLoCoArtifactAuxCid(jobBundleCid, manifestCid, "cheng.diloco.artifact.advert")
    let recoveryPlanCid = DiLoCoArtifactAuxCid(jobBundleCid, manifestCid, "cheng.diloco.artifact.recovery")
    out = DiLoCoArtifactRef()
    out.stubCid = DiLoCoArtifactStubCid(topicCid,
                                          jobBundleCid,
                                          blobSummaryCid,
                                          advertCid,
                                          manifestCid,
                                          recoveryPlanCid,
                                          payloadLen)
    out.blobSummaryCid = blobSummaryCid
    out.manifestCid = manifestCid
    out.blobCid = blobCid
    out.payloadLen = payloadLen
    out.paramsCid = paramsCid
    out.layoutKind = DiLoCoArtifactLayoutRsSystematic
    out.dataShardCount = 1
    out.parityShardCount = 0
    out.shardPayloadBytes = shardPayloadBytes
    return Ok[bool](true)

fn DiLoCoCohortHasPeer(cohort: DiLoCoCohort,
                         peerId: types.Libp2pPeerId): bool =
    for i in 0..<cohort.members.len:
        if types.Libp2pPeerIdEqual(cohort.members[i], peerId):
            return true
    return false

fn DiLoCoBarrierHasPeer(barrier: DiLoCoBarrier,
                          peerId: types.Libp2pPeerId): bool =
    for i in 0..<barrier.completedPeerIds.len:
        if types.Libp2pPeerIdEqual(barrier.completedPeerIds[i], peerId):
            return true
    return false

fn DiLoCoJobPos(state: DiLoCoState,
                  jobBundleCid: layout.FixedBytes32): int32 =
    for i in 0..<state.jobs.len:
        if layout.FixedBytes32Equal(state.jobs[i].jobBundleCid, jobBundleCid):
            return i
    return -1

fn DiLoCoCohortPos(state: DiLoCoState,
                     jobBundleCid: layout.FixedBytes32): int32 =
    for i in 0..<state.cohorts.len:
        if layout.FixedBytes32Equal(state.cohorts[i].jobBundleCid, jobBundleCid):
            return i
    return -1

fn DiLoCoLeasePos(state: DiLoCoState,
                    jobBundleCid: layout.FixedBytes32,
                    peerId: types.Libp2pPeerId,
                    baseVersionCid: layout.FixedBytes32,
                    outerStep: int32): int32 =
    for i in 0..<state.leases.len:
        let lease = state.leases[i]
        if !layout.FixedBytes32Equal(lease.jobBundleCid, jobBundleCid):
            continue
        if !types.Libp2pPeerIdEqual(lease.peerId, peerId):
            continue
        if !layout.FixedBytes32Equal(lease.baseVersionCid, baseVersionCid):
            continue
        if lease.outerStep != outerStep:
            continue
        return i
    return -1

fn DiLoCoBarrierPos(state: DiLoCoState,
                      jobBundleCid: layout.FixedBytes32,
                      baseVersionCid: layout.FixedBytes32,
                      outerStep: int32): int32 =
    for i in 0..<state.barriers.len:
        let barrier = state.barriers[i]
        if !layout.FixedBytes32Equal(barrier.jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(barrier.baseVersionCid, baseVersionCid):
            continue
        if barrier.outerStep != outerStep:
            continue
        return i
    return -1

fn DiLoCoDeltaPos(state: DiLoCoState,
                    jobBundleCid: layout.FixedBytes32,
                    baseVersionCid: layout.FixedBytes32,
                    outerStep: int32,
                    peerId: types.Libp2pPeerId): int32 =
    for i in 0..<state.deltas.len:
        let delta = state.deltas[i]
        if !layout.FixedBytes32Equal(delta.jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(delta.baseVersionCid, baseVersionCid):
            continue
        if delta.outerStep != outerStep:
            continue
        if !types.Libp2pPeerIdEqual(delta.publisherPeerId, peerId):
            continue
        return i
    return -1

fn DiLoCoCommitPos(state: DiLoCoState,
                     jobBundleCid: layout.FixedBytes32,
                     baseVersionCid: layout.FixedBytes32,
                     outerStep: int32): int32 =
    for i in 0..<state.commits.len:
        let commit = state.commits[i]
        if !layout.FixedBytes32Equal(commit.jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(commit.baseVersionCid, baseVersionCid):
            continue
        if commit.outerStep != outerStep:
            continue
        return i
    return -1

fn DiLoCoVersionPos(state: DiLoCoState,
                      versionCid: layout.FixedBytes32): int32 =
    for i in 0..<state.versions.len:
        if layout.FixedBytes32Equal(state.versions[i].versionCid, versionCid):
            return i
    return -1

fn DiLoCoGlobalVersionCid(jobBundleCid: layout.FixedBytes32,
                            baseVersionCid: layout.FixedBytes32,
                            committedOuterStep: int32,
                            publisherPeerId: types.Libp2pPeerId,
                            modelRef: DiLoCoArtifactRef,
                            optimizerRef: DiLoCoArtifactRef): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.global.version"))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendFixed32(buf, baseVersionCid)
    lt.AppendU32BE(buf, committedOuterStep)
    lt.AppendFixed32(buf, publisherPeerId.value)
    lt.AppendFixed32(buf, modelRef.blobCid)
    lt.AppendFixed32(buf, optimizerRef.blobCid)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoCohortCid(jobBundleCid: layout.FixedBytes32,
                     ordinal: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.cohort"))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendU32BE(buf, ordinal)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoOuterDeltaCid(jobBundleCid: layout.FixedBytes32,
                         baseVersionCid: layout.FixedBytes32,
                         outerStep: int32,
                         publisherPeerId: types.Libp2pPeerId,
                         modelRef: DiLoCoArtifactRef,
                         optimizerRef: DiLoCoArtifactRef,
                         weightNumerator: int32,
                         weightDenominator: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.outer.delta"))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendFixed32(buf, baseVersionCid)
    lt.AppendU32BE(buf, outerStep)
    lt.AppendFixed32(buf, publisherPeerId.value)
    lt.AppendFixed32(buf, modelRef.blobCid)
    lt.AppendFixed32(buf, optimizerRef.blobCid)
    lt.AppendU32BE(buf, weightNumerator)
    lt.AppendU32BE(buf, weightDenominator)
    return lt.FixedCidFromBuf(buf)

fn DiLoCoMergeCommitCid(jobBundleCid: layout.FixedBytes32,
                          baseVersionCid: layout.FixedBytes32,
                          outerStep: int32,
                          leaderPeerId: types.Libp2pPeerId,
                          nextGlobalVersionCid: layout.FixedBytes32,
                          contributionCids: layout.FixedBytes32[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(320)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.diloco.merge.commit"))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendFixed32(buf, baseVersionCid)
    lt.AppendU32BE(buf, outerStep)
    lt.AppendFixed32(buf, leaderPeerId.value)
    lt.AppendFixed32(buf, nextGlobalVersionCid)
    lt.AppendU32BE(buf, contributionCids.len)
    for i in 0..<contributionCids.len:
        lt.AppendFixed32(buf, contributionCids[i])
    return lt.FixedCidFromBuf(buf)

fn DiLoCoCurrentVersionFill(out: var DiLoCoGlobalVersion,
                              state: DiLoCoState,
                              currentGlobalVersionCid: layout.FixedBytes32): bool =
    let pos = DiLoCoVersionPos(state, currentGlobalVersionCid)
    if pos < 0 || pos >= state.versions.len:
        out = DiLoCoGlobalVersion()
        return false
    out = DiLoCoGlobalVersion()
    DiLoCoGlobalVersionCopyFill(out, state.versions[pos])
    return true

fn DiLoCoOuterDeltaValidate(delta: DiLoCoOuterDelta): Result[bool] =
    if layout.FixedBytes32Equal(delta.jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" diloco: outer delta job bundle cid missing")
    if layout.FixedBytes32Equal(delta.baseVersionCid, layout.FixedBytes32()):
        return Err[bool](" diloco: outer delta base version cid missing")
    if delta.outerStep <= 0:
        return Err[bool](" diloco: outer delta outer step")
    let modelOk = DiLoCoArtifactRefValidate(delta.modelDeltaRef)
    if IsErr(modelOk):
        return Err[bool](Error(modelOk))
    let optimizerOk = DiLoCoArtifactRefValidate(delta.optimizerDeltaRef)
    if IsErr(optimizerOk):
        return Err[bool](Error(optimizerOk))
    if delta.sampleCount <= 0:
        return Err[bool](" diloco: outer delta sample count")
    if delta.tokenCount <= 0:
        return Err[bool](" diloco: outer delta token count")
    if delta.innerStepCount <= 0:
        return Err[bool](" diloco: outer delta inner step count")
    if delta.weightNumerator <= 0 || delta.weightDenominator <= 0:
        return Err[bool](" diloco: outer delta weight")
    return Ok[bool](true)

fn DiLoCoOpenJobFill(outJob: var DiLoCoJob,
                       outVersion: var DiLoCoGlobalVersion,
                       state: var DiLoCoState,
                       jobBundleCid: layout.FixedBytes32,
                       requestedWorkerCount: int32,
                       innerStepBudget: int32,
                       outerStepTimeoutSeconds: int32,
                       initialModelRef: DiLoCoArtifactRef,
                       initialOptimizerRef: DiLoCoArtifactRef): Result[bool] =
    if DiLoCoJobPos(state, jobBundleCid) >= 0:
        return Err[bool](" diloco: job duplicate")
    if layout.FixedBytes32Equal(jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" diloco: job bundle cid missing")
    if requestedWorkerCount <= 0:
        return Err[bool](" diloco: requested worker count")
    if innerStepBudget <= 0:
        return Err[bool](" diloco: inner step budget")
    if outerStepTimeoutSeconds <= 0:
        return Err[bool](" diloco: outer step timeout")
    let modelOk = DiLoCoArtifactRefValidate(initialModelRef)
    if IsErr(modelOk):
        return Err[bool](Error(modelOk))
    let optimizerOk = DiLoCoArtifactRefValidate(initialOptimizerRef)
    if IsErr(optimizerOk):
        return Err[bool](Error(optimizerOk))
    add(state.versions, DiLoCoGlobalVersion())
    let versionPos = state.versions.len - 1
    state.versions[versionPos].jobBundleCid = jobBundleCid
    state.versions[versionPos].committedOuterStep = 0
    DiLoCoPeerIdCopyFill(state.versions[versionPos].publisherPeerId, types.Libp2pPeerId())
    DiLoCoArtifactRefCopyFill(state.versions[versionPos].modelRef, initialModelRef)
    DiLoCoArtifactRefCopyFill(state.versions[versionPos].optimizerRef, initialOptimizerRef)
    state.versions[versionPos].acceptedCount = 0
    state.versions[versionPos].committedAtEpochSeconds = times.EpochTimeSeconds()
    state.versions[versionPos].versionCid = DiLoCoGlobalVersionCid(jobBundleCid,
                                                                     state.versions[versionPos].baseVersionCid,
                                                                     state.versions[versionPos].committedOuterStep,
                                                                     state.versions[versionPos].publisherPeerId,
                                                                     state.versions[versionPos].modelRef,
                                                                     state.versions[versionPos].optimizerRef)
    outVersion.jobBundleCid = state.versions[versionPos].jobBundleCid
    outVersion.versionCid = state.versions[versionPos].versionCid
    outVersion.baseVersionCid = state.versions[versionPos].baseVersionCid
    outVersion.committedOuterStep = state.versions[versionPos].committedOuterStep
    outVersion.publisherPeerId.value = state.versions[versionPos].publisherPeerId.value
    outVersion.modelRef.stubCid = state.versions[versionPos].modelRef.stubCid
    outVersion.modelRef.blobSummaryCid = state.versions[versionPos].modelRef.blobSummaryCid
    outVersion.modelRef.manifestCid = state.versions[versionPos].modelRef.manifestCid
    outVersion.modelRef.blobCid = state.versions[versionPos].modelRef.blobCid
    outVersion.modelRef.payloadLen = state.versions[versionPos].modelRef.payloadLen
    outVersion.modelRef.paramsCid = state.versions[versionPos].modelRef.paramsCid
    outVersion.modelRef.layoutKind = state.versions[versionPos].modelRef.layoutKind
    outVersion.modelRef.dataShardCount = state.versions[versionPos].modelRef.dataShardCount
    outVersion.modelRef.parityShardCount = state.versions[versionPos].modelRef.parityShardCount
    outVersion.modelRef.shardPayloadBytes = state.versions[versionPos].modelRef.shardPayloadBytes
    outVersion.optimizerRef.stubCid = state.versions[versionPos].optimizerRef.stubCid
    outVersion.optimizerRef.blobSummaryCid = state.versions[versionPos].optimizerRef.blobSummaryCid
    outVersion.optimizerRef.manifestCid = state.versions[versionPos].optimizerRef.manifestCid
    outVersion.optimizerRef.blobCid = state.versions[versionPos].optimizerRef.blobCid
    outVersion.optimizerRef.payloadLen = state.versions[versionPos].optimizerRef.payloadLen
    outVersion.optimizerRef.paramsCid = state.versions[versionPos].optimizerRef.paramsCid
    outVersion.optimizerRef.layoutKind = state.versions[versionPos].optimizerRef.layoutKind
    outVersion.optimizerRef.dataShardCount = state.versions[versionPos].optimizerRef.dataShardCount
    outVersion.optimizerRef.parityShardCount = state.versions[versionPos].optimizerRef.parityShardCount
    outVersion.optimizerRef.shardPayloadBytes = state.versions[versionPos].optimizerRef.shardPayloadBytes
    outVersion.acceptedCount = state.versions[versionPos].acceptedCount
    outVersion.committedAtEpochSeconds = state.versions[versionPos].committedAtEpochSeconds
    add(state.jobs, DiLoCoJob())
    let jobWritePos = state.jobs.len - 1
    state.jobs[jobWritePos].jobBundleCid = jobBundleCid
    state.jobs[jobWritePos].requestedWorkerCount = requestedWorkerCount
    state.jobs[jobWritePos].innerStepBudget = innerStepBudget
    state.jobs[jobWritePos].outerStepTimeoutSeconds = outerStepTimeoutSeconds
    state.jobs[jobWritePos].currentGlobalVersionCid = state.versions[versionPos].versionCid
    state.jobs[jobWritePos].currentOuterStep = 1
    state.jobs[jobWritePos].sealed = false
    state.jobs[jobWritePos].openedAtEpochSeconds = times.EpochTimeSeconds()
    outJob.jobBundleCid = state.jobs[jobWritePos].jobBundleCid
    outJob.requestedWorkerCount = state.jobs[jobWritePos].requestedWorkerCount
    outJob.innerStepBudget = state.jobs[jobWritePos].innerStepBudget
    outJob.outerStepTimeoutSeconds = state.jobs[jobWritePos].outerStepTimeoutSeconds
    outJob.currentGlobalVersionCid = state.jobs[jobWritePos].currentGlobalVersionCid
    outJob.currentOuterStep = state.jobs[jobWritePos].currentOuterStep
    outJob.sealed = state.jobs[jobWritePos].sealed
    outJob.cohortCid = state.jobs[jobWritePos].cohortCid
    outJob.openedAtEpochSeconds = state.jobs[jobWritePos].openedAtEpochSeconds
    return Ok[bool](true)

fn DiLoCoJoinCohortFill(out: var DiLoCoCohort,
                          state: var DiLoCoState,
                          jobBundleCid: layout.FixedBytes32,
                          peerId: types.Libp2pPeerId): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos >= 0:
        if DiLoCoCohortHasPeer(state.cohorts[cohortPos], peerId):
            out = DiLoCoCohort()
            DiLoCoCohortCopyFill(out, state.cohorts[cohortPos])
            return Ok[bool](true)
        if state.jobs[jobPos].sealed:
            return Err[bool](" diloco: cohort sealed")
        add(state.cohorts[cohortPos].members, peerId)
        if state.cohorts[cohortPos].members.len == state.jobs[jobPos].requestedWorkerCount:
            state.cohorts[cohortPos].fixedMemberCount = state.cohorts[cohortPos].members.len
            state.cohorts[cohortPos].sealedAtEpochSeconds = times.EpochTimeSeconds()
            DiLoCoPeerIdCopyFill(state.cohorts[cohortPos].leaderPeerId, state.cohorts[cohortPos].members[0])
            state.jobs[jobPos].sealed = true
            state.jobs[jobPos].cohortCid = state.cohorts[cohortPos].cohortCid
        out = DiLoCoCohort()
        DiLoCoCohortCopyFill(out, state.cohorts[cohortPos])
        return Ok[bool](true)
    add(state.cohorts, DiLoCoCohort())
    let newPos = state.cohorts.len - 1
    state.cohorts[newPos].jobBundleCid = jobBundleCid
    state.cohorts[newPos].cohortCid = DiLoCoCohortCid(jobBundleCid, state.cohorts.len)
    add(state.cohorts[newPos].members, peerId)
    if state.cohorts[newPos].members.len == state.jobs[jobPos].requestedWorkerCount:
        state.cohorts[newPos].fixedMemberCount = state.cohorts[newPos].members.len
        state.cohorts[newPos].sealedAtEpochSeconds = times.EpochTimeSeconds()
        DiLoCoPeerIdCopyFill(state.cohorts[newPos].leaderPeerId, state.cohorts[newPos].members[0])
        state.jobs[jobPos].sealed = true
        state.jobs[jobPos].cohortCid = state.cohorts[newPos].cohortCid
    out = DiLoCoCohort()
    DiLoCoCohortCopyFill(out, state.cohorts[newPos])
    return Ok[bool](true)

fn DiLoCoFetchLeaseFill(out: var DiLoCoLease,
                          state: var DiLoCoState,
                          jobBundleCid: layout.FixedBytes32,
                          peerId: types.Libp2pPeerId): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    if !state.jobs[jobPos].sealed:
        return Err[bool](" diloco: cohort not sealed")
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos < 0:
        return Err[bool](" diloco: cohort missing")
    if !DiLoCoCohortHasPeer(state.cohorts[cohortPos], peerId):
        return Err[bool](" diloco: peer missing from cohort")
    let leasePos = DiLoCoLeasePos(state,
                                    jobBundleCid,
                                    peerId,
                                    state.jobs[jobPos].currentGlobalVersionCid,
                                    state.jobs[jobPos].currentOuterStep)
    if leasePos >= 0:
        out = DiLoCoLease()
        DiLoCoLeaseCopyFill(out, state.leases[leasePos])
        return Ok[bool](true)
    add(state.leases, DiLoCoLease())
    let newPos = state.leases.len - 1
    state.leases[newPos].jobBundleCid = jobBundleCid
    state.leases[newPos].cohortCid = state.cohorts[cohortPos].cohortCid
    DiLoCoPeerIdCopyFill(state.leases[newPos].peerId, peerId)
    state.leases[newPos].baseVersionCid = state.jobs[jobPos].currentGlobalVersionCid
    state.leases[newPos].outerStep = state.jobs[jobPos].currentOuterStep
    state.leases[newPos].innerStepBudget = state.jobs[jobPos].innerStepBudget
    state.leases[newPos].leasedAtEpochSeconds = times.EpochTimeSeconds()
    state.leases[newPos].expiresAtEpochSeconds = state.leases[newPos].leasedAtEpochSeconds + int64(state.jobs[jobPos].outerStepTimeoutSeconds)
    state.leases[newPos].active = true
    out = DiLoCoLease()
    DiLoCoLeaseCopyFill(out, state.leases[newPos])
    return Ok[bool](true)

fn DiLoCoReportInnerStepDoneFill(out: var DiLoCoBarrier,
                                   state: var DiLoCoState,
                                   jobBundleCid: layout.FixedBytes32,
                                   peerId: types.Libp2pPeerId): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    if !state.jobs[jobPos].sealed:
        return Err[bool](" diloco: cohort not sealed")
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos < 0:
        return Err[bool](" diloco: cohort missing")
    if !DiLoCoCohortHasPeer(state.cohorts[cohortPos], peerId):
        return Err[bool](" diloco: barrier peer missing")
    let leasePos = DiLoCoLeasePos(state,
                                    jobBundleCid,
                                    peerId,
                                    state.jobs[jobPos].currentGlobalVersionCid,
                                    state.jobs[jobPos].currentOuterStep)
    if leasePos < 0:
        return Err[bool](" diloco: worker lease missing")
    if !state.leases[leasePos].active:
        return Err[bool](" diloco: worker lease inactive")
    if times.EpochTimeSeconds() > state.leases[leasePos].expiresAtEpochSeconds:
        return Err[bool](" diloco: worker lease expired")
    let barrierPos = DiLoCoBarrierPos(state,
                                        jobBundleCid,
                                        state.jobs[jobPos].currentGlobalVersionCid,
                                        state.jobs[jobPos].currentOuterStep)
    if barrierPos >= 0:
        if DiLoCoBarrierHasPeer(state.barriers[barrierPos], peerId):
            return Err[bool](" diloco: barrier duplicate peer")
        add(state.barriers[barrierPos].completedPeerIds, peerId)
        if state.barriers[barrierPos].completedPeerIds.len == state.barriers[barrierPos].expectedMemberCount:
            state.barriers[barrierPos].sealed = true
        out = DiLoCoBarrier()
        DiLoCoBarrierCopyFill(out, state.barriers[barrierPos])
        return Ok[bool](true)
    add(state.barriers, DiLoCoBarrier())
    let newPos = state.barriers.len - 1
    state.barriers[newPos].jobBundleCid = jobBundleCid
    state.barriers[newPos].cohortCid = state.cohorts[cohortPos].cohortCid
    state.barriers[newPos].baseVersionCid = state.jobs[jobPos].currentGlobalVersionCid
    state.barriers[newPos].outerStep = state.jobs[jobPos].currentOuterStep
    state.barriers[newPos].expectedMemberCount = state.cohorts[cohortPos].fixedMemberCount
    add(state.barriers[newPos].completedPeerIds, peerId)
    if state.barriers[newPos].completedPeerIds.len == state.barriers[newPos].expectedMemberCount:
        state.barriers[newPos].sealed = true
    out = DiLoCoBarrier()
    DiLoCoBarrierCopyFill(out, state.barriers[newPos])
    return Ok[bool](true)

fn DiLoCoSubmitOuterDeltaFill(out: var DiLoCoOuterDelta,
                                state: var DiLoCoState,
                                jobBundleCid: layout.FixedBytes32,
                                baseVersionCid: layout.FixedBytes32,
                                outerStep: int32,
                                publisherPeerId: types.Libp2pPeerId,
                                modelDeltaRef: DiLoCoArtifactRef,
                                optimizerDeltaRef: DiLoCoArtifactRef,
                                sampleCount: int32,
                                tokenCount: int32,
                                innerStepCount: int32,
                                weightNumerator: int32,
                                weightDenominator: int32): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    if !state.jobs[jobPos].sealed:
        return Err[bool](" diloco: cohort not sealed")
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos < 0:
        return Err[bool](" diloco: cohort missing")
    if !DiLoCoCohortHasPeer(state.cohorts[cohortPos], publisherPeerId):
        return Err[bool](" diloco: submit peer missing")
    if !layout.FixedBytes32Equal(baseVersionCid, state.jobs[jobPos].currentGlobalVersionCid):
        return Err[bool](" diloco: stale base version")
    if outerStep != state.jobs[jobPos].currentOuterStep:
        return Err[bool](" diloco: stale outer step")
    let barrierPos = DiLoCoBarrierPos(state, jobBundleCid, baseVersionCid, outerStep)
    if barrierPos < 0:
        return Err[bool](" diloco: barrier missing")
    if !state.barriers[barrierPos].sealed:
        return Err[bool](" diloco: barrier not ready")
    if DiLoCoDeltaPos(state,
                        jobBundleCid,
                        baseVersionCid,
                        outerStep,
                        publisherPeerId) >= 0:
        return Err[bool](" diloco: outer delta duplicate")
    let modelOk = DiLoCoArtifactRefValidate(modelDeltaRef)
    if IsErr(modelOk):
        return Err[bool](Error(modelOk))
    let optimizerOk = DiLoCoArtifactRefValidate(optimizerDeltaRef)
    if IsErr(optimizerOk):
        return Err[bool](Error(optimizerOk))
    if sampleCount <= 0:
        return Err[bool](" diloco: outer delta sample count")
    if tokenCount <= 0:
        return Err[bool](" diloco: outer delta token count")
    if innerStepCount <= 0:
        return Err[bool](" diloco: outer delta inner step count")
    if weightNumerator <= 0 || weightDenominator <= 0:
        return Err[bool](" diloco: outer delta weight")
    add(state.deltas, DiLoCoOuterDelta())
    let deltaPos = state.deltas.len - 1
    state.deltas[deltaPos].jobBundleCid = jobBundleCid
    state.deltas[deltaPos].baseVersionCid = baseVersionCid
    state.deltas[deltaPos].outerStep = outerStep
    DiLoCoPeerIdCopyFill(state.deltas[deltaPos].publisherPeerId, publisherPeerId)
    DiLoCoArtifactRefCopyFill(state.deltas[deltaPos].modelDeltaRef, modelDeltaRef)
    DiLoCoArtifactRefCopyFill(state.deltas[deltaPos].optimizerDeltaRef, optimizerDeltaRef)
    state.deltas[deltaPos].sampleCount = sampleCount
    state.deltas[deltaPos].tokenCount = tokenCount
    state.deltas[deltaPos].innerStepCount = innerStepCount
    state.deltas[deltaPos].weightNumerator = weightNumerator
    state.deltas[deltaPos].weightDenominator = weightDenominator
    state.deltas[deltaPos].submittedAtEpochSeconds = times.EpochTimeSeconds()
    state.deltas[deltaPos].deltaCid = DiLoCoOuterDeltaCid(jobBundleCid,
                                                            baseVersionCid,
                                                            outerStep,
                                                            publisherPeerId,
                                                            modelDeltaRef,
                                                            optimizerDeltaRef,
                                                            weightNumerator,
                                                            weightDenominator)
    out = DiLoCoOuterDelta()
    DiLoCoOuterDeltaCopyFill(out, state.deltas[deltaPos])
    return Ok[bool](true)

fn DiLoCoFetchStepStatusFill(out: var DiLoCoStepStatus,
                               state: DiLoCoState,
                               jobBundleCid: layout.FixedBytes32): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    let job = state.jobs[jobPos]
    out = DiLoCoStepStatus()
    out.jobBundleCid = jobBundleCid
    out.baseVersionCid = job.currentGlobalVersionCid
    out.outerStep = job.currentOuterStep
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos >= 0:
        out.expectedMemberCount = state.cohorts[cohortPos].fixedMemberCount
    let barrierPos = DiLoCoBarrierPos(state, jobBundleCid, job.currentGlobalVersionCid, job.currentOuterStep)
    if barrierPos >= 0:
        let barrier = state.barriers[barrierPos]
        out.barrierReady = barrier.sealed
        out.barrierArrivedCount = barrier.completedPeerIds.len
        out.expectedMemberCount = barrier.expectedMemberCount
    for i in 0..<state.deltas.len:
        let delta = state.deltas[i]
        if !layout.FixedBytes32Equal(delta.jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(delta.baseVersionCid, job.currentGlobalVersionCid):
            continue
        if delta.outerStep != job.currentOuterStep:
            continue
        out.contributionCount = out.contributionCount + 1
    let commitPos = DiLoCoCommitPos(state, jobBundleCid, job.currentGlobalVersionCid, job.currentOuterStep)
    if commitPos >= 0:
        out.commitPublished = true
        out.mergeCommitCid = state.commits[commitPos].commitCid
    return Ok[bool](true)

fn DiLoCoPublishMergeCommitFill(outCommit: var DiLoCoMergeCommit,
                                  outVersion: var DiLoCoGlobalVersion,
                                  state: var DiLoCoState,
                                  jobBundleCid: layout.FixedBytes32,
                                  publisherPeerId: types.Libp2pPeerId,
                                  mergedModelRef: DiLoCoArtifactRef,
                                  mergedOptimizerRef: DiLoCoArtifactRef): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    if !state.jobs[jobPos].sealed:
        return Err[bool](" diloco: cohort not sealed")
    let cohortPos = DiLoCoCohortPos(state, jobBundleCid)
    if cohortPos < 0:
        return Err[bool](" diloco: cohort missing")
    if !types.Libp2pPeerIdEqual(state.cohorts[cohortPos].leaderPeerId, publisherPeerId):
        return Err[bool](" diloco: merge leader required")
    let barrierPos = DiLoCoBarrierPos(state,
                                        jobBundleCid,
                                        state.jobs[jobPos].currentGlobalVersionCid,
                                        state.jobs[jobPos].currentOuterStep)
    if barrierPos < 0:
        return Err[bool](" diloco: barrier missing")
    if !state.barriers[barrierPos].sealed ||
            state.barriers[barrierPos].completedPeerIds.len != state.barriers[barrierPos].expectedMemberCount:
        return Err[bool](" diloco: barrier not ready")
    if DiLoCoCommitPos(state,
                         jobBundleCid,
                         state.jobs[jobPos].currentGlobalVersionCid,
                         state.jobs[jobPos].currentOuterStep) >= 0:
        return Err[bool](" diloco: merge commit duplicate")
    let modelOk = DiLoCoArtifactRefValidate(mergedModelRef)
    if IsErr(modelOk):
        return Err[bool](Error(modelOk))
    let optimizerOk = DiLoCoArtifactRefValidate(mergedOptimizerRef)
    if IsErr(optimizerOk):
        return Err[bool](Error(optimizerOk))
    var contributionCids: layout.FixedBytes32[]
    contributionCids = []
    for i in 0..<state.deltas.len:
        let delta = state.deltas[i]
        if !layout.FixedBytes32Equal(delta.jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(delta.baseVersionCid, state.jobs[jobPos].currentGlobalVersionCid):
            continue
        if delta.outerStep != state.jobs[jobPos].currentOuterStep:
            continue
        add(contributionCids, delta.deltaCid)
    if contributionCids.len != state.cohorts[cohortPos].fixedMemberCount:
        return Err[bool](" diloco: contribution quorum missing")
    add(state.versions, DiLoCoGlobalVersion())
    let versionPos = state.versions.len - 1
    state.versions[versionPos].jobBundleCid = jobBundleCid
    state.versions[versionPos].baseVersionCid = state.jobs[jobPos].currentGlobalVersionCid
    state.versions[versionPos].committedOuterStep = state.jobs[jobPos].currentOuterStep
    DiLoCoPeerIdCopyFill(state.versions[versionPos].publisherPeerId, publisherPeerId)
    DiLoCoArtifactRefCopyFill(state.versions[versionPos].modelRef, mergedModelRef)
    DiLoCoArtifactRefCopyFill(state.versions[versionPos].optimizerRef, mergedOptimizerRef)
    state.versions[versionPos].acceptedCount = contributionCids.len
    state.versions[versionPos].committedAtEpochSeconds = times.EpochTimeSeconds()
    state.versions[versionPos].versionCid = DiLoCoGlobalVersionCid(jobBundleCid,
                                                                     state.versions[versionPos].baseVersionCid,
                                                                     state.versions[versionPos].committedOuterStep,
                                                                     state.versions[versionPos].publisherPeerId,
                                                                     state.versions[versionPos].modelRef,
                                                                     state.versions[versionPos].optimizerRef)
    outVersion = DiLoCoGlobalVersion()
    DiLoCoGlobalVersionCopyFill(outVersion, state.versions[versionPos])
    add(state.commits, DiLoCoMergeCommit())
    let commitPos = state.commits.len - 1
    state.commits[commitPos].jobBundleCid = jobBundleCid
    state.commits[commitPos].baseVersionCid = state.jobs[jobPos].currentGlobalVersionCid
    state.commits[commitPos].nextGlobalVersionCid = state.versions[versionPos].versionCid
    state.commits[commitPos].outerStep = state.jobs[jobPos].currentOuterStep
    DiLoCoPeerIdCopyFill(state.commits[commitPos].leaderPeerId, publisherPeerId)
    state.commits[commitPos].acceptedCount = contributionCids.len
    state.commits[commitPos].contributionCids = []
    for i in 0..<contributionCids.len:
        add(state.commits[commitPos].contributionCids, contributionCids[i])
    state.commits[commitPos].publishedAtEpochSeconds = state.versions[versionPos].committedAtEpochSeconds
    state.commits[commitPos].commitCid = DiLoCoMergeCommitCid(jobBundleCid,
                                                                state.commits[commitPos].baseVersionCid,
                                                                state.commits[commitPos].outerStep,
                                                                state.commits[commitPos].leaderPeerId,
                                                                state.commits[commitPos].nextGlobalVersionCid,
                                                                state.commits[commitPos].contributionCids)
    outCommit = DiLoCoMergeCommit()
    DiLoCoMergeCommitCopyFill(outCommit, state.commits[commitPos])
    for i in 0..<state.leases.len:
        if !layout.FixedBytes32Equal(state.leases[i].jobBundleCid, jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(state.leases[i].baseVersionCid, outCommit.baseVersionCid):
            continue
        if state.leases[i].outerStep != outCommit.outerStep:
            continue
        state.leases[i].active = false
    state.jobs[jobPos].currentGlobalVersionCid = outVersion.versionCid
    state.jobs[jobPos].currentOuterStep = state.jobs[jobPos].currentOuterStep + 1
    return Ok[bool](true)

fn DiLoCoFetchGlobalVersionFill(out: var DiLoCoGlobalVersion,
                                  state: DiLoCoState,
                                  jobBundleCid: layout.FixedBytes32): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    if !DiLoCoCurrentVersionFill(out, state, state.jobs[jobPos].currentGlobalVersionCid):
        return Err[bool](" diloco: current version missing")
    return Ok[bool](true)

fn DiLoCoFetchLineageFill(out: var DiLoCoGlobalVersion[],
                            state: DiLoCoState,
                            jobBundleCid: layout.FixedBytes32): Result[bool] =
    let jobPos = DiLoCoJobPos(state, jobBundleCid)
    if jobPos < 0:
        return Err[bool](" diloco: job missing")
    out = []
    var currentCid = state.jobs[jobPos].currentGlobalVersionCid
    var remaining = state.versions.len
    while !layout.FixedBytes32Equal(currentCid, layout.FixedBytes32()):
        if remaining <= 0:
            return Err[bool](" diloco: lineage cycle")
        let versionPos = DiLoCoVersionPos(state, currentCid)
        if versionPos < 0:
            return Err[bool](" diloco: lineage version missing")
        add(out, state.versions[versionPos])
        currentCid = state.versions[versionPos].baseVersionCid
        remaining = remaining - 1
    return Ok[bool](out.len > 0)
