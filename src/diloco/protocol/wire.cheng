    let expectedCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "expected_member_count"))
    if IsErr(expectedCountRes):
        return Err[bool](Error(expectedCountRes))
    let contributionCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "contribution_count"))
    if IsErr(contributionCountRes):
        return Err[bool](Error(contributionCountRes))
    let commitPublishedRes = DiLoCoWireRequireBool(wire, DiLoCoWireField(prefix, "commit_published"))
    if IsErr(commitPublishedRes):
