fn DiLoCoWireAppendBarrier(out: str,
                             prefix: str,
                             barrier: core.DiLoCoBarrier): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(barrier.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(barrier.cohortCid))
