fn DiLoCoWireAppendGlobalVersionArray(out: str,
                                        prefix: str,
                                        versions: core.DiLoCoGlobalVersion[]): str =
    var next = DiLoCoWireAppendLine(out, DiLoCoWireField(prefix, "count"), IntToStr(versions.len))
    for i in 0..<versions.len:
        next = DiLoCoWireAppendGlobalVersion(next,
                                               DiLoCoWireField(prefix, IntToStr(i)),
                                               versions[i])
    return next

fn DiLoCoWireParseGlobalVersionArrayFill(out: var core.DiLoCoGlobalVersion[],
                                           wire: str,
                                           prefix: str): Result[bool] =
    let countRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        add(out, core.DiLoCoGlobalVersion())
        let versionRes = DiLoCoWireParseGlobalVersionFill(out[out.len - 1],
                                                            wire,
                                                            DiLoCoWireField(prefix, IntToStr(i)))
        if IsErr(versionRes):
            return Err[bool](Error(versionRes))
