    let tokenCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "token_count"))
    if IsErr(tokenCountRes):
        return Err[bool](Error(tokenCountRes))
    let innerStepCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "inner_step_count"))
    if IsErr(innerStepCountRes):
