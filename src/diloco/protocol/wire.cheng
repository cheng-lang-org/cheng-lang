    if IsErr(weightDenominatorRes):
        return Err[bool](Error(weightDenominatorRes))
    let submittedAtRes = DiLoCoWireRequireI64(wire, DiLoCoWireField(prefix, "submitted_at_epoch_seconds"))
    if IsErr(submittedAtRes):
        return Err[bool](Error(submittedAtRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.deltaCid = Value(deltaCidRes)
    out.baseVersionCid = Value(baseVersionCidRes)
    out.outerStep = Value(outerStepRes)
    out.publisherPeerId = Value(publisherPeerIdRes)
    out.modelDeltaRef = modelDeltaRef
    out.optimizerDeltaRef = optimizerDeltaRef
    out.sampleCount = Value(sampleCountRes)
    out.tokenCount = Value(tokenCountRes)
    out.innerStepCount = Value(innerStepCountRes)
    out.weightNumerator = Value(weightNumeratorRes)
    out.weightDenominator = Value(weightDenominatorRes)
    out.submittedAtEpochSeconds = Value(submittedAtRes)
    return Ok[bool](true)

fn DiLoCoWireAppendMergeCommit(out: str,
                                 prefix: str,
                                 commit: core.DiLoCoMergeCommit): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(commit.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "commit_cid"), layout.FixedBytes32Hex(commit.commitCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(commit.baseVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "next_global_version_cid"), layout.FixedBytes32Hex(commit.nextGlobalVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "outer_step"), IntToStr(commit.outerStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "leader_peer_id"), peer_id.Libp2pPeerIdText(commit.leaderPeerId))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "accepted_count"), IntToStr(commit.acceptedCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "published_at_epoch_seconds"), IntToStr(int32(commit.publishedAtEpochSeconds)))
    next = DiLoCoWireAppendFixed32Array(next, DiLoCoWireField(prefix, "contribution_cids"), commit.contributionCids)
    return next

fn DiLoCoWireParseMergeCommitFill(out: var core.DiLoCoMergeCommit,
                                    wire: str,
                                    prefix: str): Result[bool] =
    out = core.DiLoCoMergeCommit()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let commitCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "commit_cid"))
    if IsErr(commitCidRes):
        return Err[bool](Error(commitCidRes))
    let baseVersionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "base_version_cid"))
    if IsErr(baseVersionCidRes):
        return Err[bool](Error(baseVersionCidRes))
    let nextGlobalVersionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "next_global_version_cid"))
    if IsErr(nextGlobalVersionCidRes):
        return Err[bool](Error(nextGlobalVersionCidRes))
    let outerStepRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "outer_step"))
    if IsErr(outerStepRes):
        return Err[bool](Error(outerStepRes))
    let leaderPeerIdRes = DiLoCoWireRequirePeerId(wire, DiLoCoWireField(prefix, "leader_peer_id"))
    if IsErr(leaderPeerIdRes):
        return Err[bool](Error(leaderPeerIdRes))
    let acceptedCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "accepted_count"))
    if IsErr(acceptedCountRes):
        return Err[bool](Error(acceptedCountRes))
    let publishedAtRes = DiLoCoWireRequireI64(wire, DiLoCoWireField(prefix, "published_at_epoch_seconds"))
    if IsErr(publishedAtRes):
        return Err[bool](Error(publishedAtRes))
    var contributionCids: layout.FixedBytes32[]
    let contributionsRes = DiLoCoWireParseFixed32ArrayFill(contributionCids, wire, DiLoCoWireField(prefix, "contribution_cids"))
    if IsErr(contributionsRes):
        return Err[bool](Error(contributionsRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.commitCid = Value(commitCidRes)
    out.baseVersionCid = Value(baseVersionCidRes)
    out.nextGlobalVersionCid = Value(nextGlobalVersionCidRes)
    out.outerStep = Value(outerStepRes)
    out.leaderPeerId = Value(leaderPeerIdRes)
    out.acceptedCount = Value(acceptedCountRes)
    out.contributionCids = contributionCids
    out.publishedAtEpochSeconds = Value(publishedAtRes)
    return Ok[bool](true)

fn DiLoCoWireAppendGlobalVersion(out: str,
                                   prefix: str,
                                   version: core.DiLoCoGlobalVersion): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(version.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "version_cid"), layout.FixedBytes32Hex(version.versionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(version.baseVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "committed_outer_step"), IntToStr(version.committedOuterStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "publisher_peer_id"), peer_id.Libp2pPeerIdText(version.publisherPeerId))
    next = DiLoCoWireAppendArtifactRef(next, DiLoCoWireField(prefix, "model_ref"), version.modelRef)
    next = DiLoCoWireAppendArtifactRef(next, DiLoCoWireField(prefix, "optimizer_ref"), version.optimizerRef)
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "accepted_count"), IntToStr(version.acceptedCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "committed_at_epoch_seconds"), IntToStr(int32(version.committedAtEpochSeconds)))
    return next

fn DiLoCoWireParseGlobalVersionFill(out: var core.DiLoCoGlobalVersion,
                                      wire: str,
                                      prefix: str): Result[bool] =
    out = core.DiLoCoGlobalVersion()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let versionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "version_cid"))
    if IsErr(versionCidRes):
        return Err[bool](Error(versionCidRes))
    let baseVersionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "base_version_cid"))
    if IsErr(baseVersionCidRes):
        return Err[bool](Error(baseVersionCidRes))
    let committedOuterStepRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "committed_outer_step"))
    if IsErr(committedOuterStepRes):
        return Err[bool](Error(committedOuterStepRes))
    let publisherPeerIdRes = DiLoCoWireRequirePeerId(wire, DiLoCoWireField(prefix, "publisher_peer_id"))
    if IsErr(publisherPeerIdRes):
        return Err[bool](Error(publisherPeerIdRes))
    var modelRef = core.DiLoCoArtifactRef()
    let modelRefRes = DiLoCoWireParseArtifactRefFill(modelRef, wire, DiLoCoWireField(prefix, "model_ref"))
    if IsErr(modelRefRes):
        return Err[bool](Error(modelRefRes))
    var optimizerRef = core.DiLoCoArtifactRef()
    let optimizerRefRes = DiLoCoWireParseArtifactRefFill(optimizerRef, wire, DiLoCoWireField(prefix, "optimizer_ref"))
    if IsErr(optimizerRefRes):
        return Err[bool](Error(optimizerRefRes))
    let acceptedCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "accepted_count"))
    if IsErr(acceptedCountRes):
        return Err[bool](Error(acceptedCountRes))
    let committedAtRes = DiLoCoWireRequireI64(wire, DiLoCoWireField(prefix, "committed_at_epoch_seconds"))
    if IsErr(committedAtRes):
        return Err[bool](Error(committedAtRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.versionCid = Value(versionCidRes)
    out.baseVersionCid = Value(baseVersionCidRes)
    out.committedOuterStep = Value(committedOuterStepRes)
    out.publisherPeerId.value = Value(publisherPeerIdRes).value
    out.modelRef.stubCid = modelRef.stubCid
    out.modelRef.blobSummaryCid = modelRef.blobSummaryCid
    out.modelRef.manifestCid = modelRef.manifestCid
    out.modelRef.blobCid = modelRef.blobCid
    out.modelRef.payloadLen = modelRef.payloadLen
    out.modelRef.paramsCid = modelRef.paramsCid
    out.modelRef.layoutKind = modelRef.layoutKind
    out.modelRef.dataShardCount = modelRef.dataShardCount
    out.modelRef.parityShardCount = modelRef.parityShardCount
    out.modelRef.shardPayloadBytes = modelRef.shardPayloadBytes
    out.optimizerRef.stubCid = optimizerRef.stubCid
    out.optimizerRef.blobSummaryCid = optimizerRef.blobSummaryCid
    out.optimizerRef.manifestCid = optimizerRef.manifestCid
    out.optimizerRef.blobCid = optimizerRef.blobCid
    out.optimizerRef.payloadLen = optimizerRef.payloadLen
    out.optimizerRef.paramsCid = optimizerRef.paramsCid
    out.optimizerRef.layoutKind = optimizerRef.layoutKind
    out.optimizerRef.dataShardCount = optimizerRef.dataShardCount
    out.optimizerRef.parityShardCount = optimizerRef.parityShardCount
    out.optimizerRef.shardPayloadBytes = optimizerRef.shardPayloadBytes
    out.acceptedCount = Value(acceptedCountRes)
    out.committedAtEpochSeconds = Value(committedAtRes)
    return Ok[bool](true)

fn DiLoCoWireAppendStepStatus(out: str,
                                prefix: str,
                                status: core.DiLoCoStepStatus): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(status.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(status.baseVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "outer_step"), IntToStr(status.outerStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "barrier_ready"), DiLoCoWireBoolText(status.barrierReady))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "barrier_arrived_count"), IntToStr(status.barrierArrivedCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "expected_member_count"), IntToStr(status.expectedMemberCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "contribution_count"), IntToStr(status.contributionCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "commit_published"), DiLoCoWireBoolText(status.commitPublished))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "merge_commit_cid"), layout.FixedBytes32Hex(status.mergeCommitCid))
    return next

fn DiLoCoWireParseStepStatusFill(out: var core.DiLoCoStepStatus,
                                   wire: str,
                                   prefix: str): Result[bool] =
    out = core.DiLoCoStepStatus()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
