fn DiLoCoFetchLineageResponseEncodePair(head: core.DiLoCoGlobalVersion,
                                          tail: core.DiLoCoGlobalVersion): Bytes =
    var versions: core.DiLoCoGlobalVersion[]
    versions = []
    add(versions, head)
    add(versions, tail)
    return DiLoCoFetchLineageResponseEncodeVersions(versions)

