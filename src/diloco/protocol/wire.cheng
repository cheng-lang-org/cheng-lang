    out.outerStep = Value(outerStepRes)
    out.expectedMemberCount = Value(expectedCountRes)
    out.completedPeerIds = completedPeerIds
    out.sealed = Value(sealedRes)
    return Ok[bool](true)

fn DiLoCoWireAppendOuterDelta(out: str,
                                prefix: str,
                                delta: core.DiLoCoOuterDelta): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(delta.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "delta_cid"), layout.FixedBytes32Hex(delta.deltaCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(delta.baseVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "outer_step"), IntToStr(delta.outerStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "publisher_peer_id"), peer_id.Libp2pPeerIdText(delta.publisherPeerId))
    next = DiLoCoWireAppendArtifactRef(next, DiLoCoWireField(prefix, "model_delta_ref"), delta.modelDeltaRef)
    next = DiLoCoWireAppendArtifactRef(next, DiLoCoWireField(prefix, "optimizer_delta_ref"), delta.optimizerDeltaRef)
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "sample_count"), IntToStr(delta.sampleCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "token_count"), IntToStr(delta.tokenCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "inner_step_count"), IntToStr(delta.innerStepCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "weight_numerator"), IntToStr(delta.weightNumerator))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "weight_denominator"), IntToStr(delta.weightDenominator))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "submitted_at_epoch_seconds"), IntToStr(int32(delta.submittedAtEpochSeconds)))
    return next

fn DiLoCoWireParseOuterDeltaFill(out: var core.DiLoCoOuterDelta,
                                   wire: str,
                                   prefix: str): Result[bool] =
    out = core.DiLoCoOuterDelta()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let deltaCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "delta_cid"))
    if IsErr(deltaCidRes):
        return Err[bool](Error(deltaCidRes))
    let baseVersionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "base_version_cid"))
