    if IsErr(cohortCidRes):
        return Err[bool](Error(cohortCidRes))
    let baseVersionCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "base_version_cid"))
    if IsErr(baseVersionCidRes):
        return Err[bool](Error(baseVersionCidRes))
    let outerStepRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "outer_step"))
    if IsErr(outerStepRes):
        return Err[bool](Error(outerStepRes))
    let expectedCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "expected_member_count"))
    if IsErr(expectedCountRes):
        return Err[bool](Error(expectedCountRes))
    let sealedRes = DiLoCoWireRequireBool(wire, DiLoCoWireField(prefix, "sealed"))
    if IsErr(sealedRes):
        return Err[bool](Error(sealedRes))
    var completedPeerIds: types.Libp2pPeerId[]
    let peersRes = DiLoCoWireParsePeerIdArrayFill(completedPeerIds, wire, DiLoCoWireField(prefix, "completed_peer_ids"))
    if IsErr(peersRes):
