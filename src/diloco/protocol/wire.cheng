import std/result
import std/rawbytes
import std/strings
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/DiLoCo/core/diloco as core
import std/strutils as strutil

const
    DiLoCoWireVersion: int32 = 1
    DiLoCoWireMagic: int32 = 0x444c4331

    DiLoCoMessageOpenJob: int32 = 1
    DiLoCoMessageJoinCohort: int32 = 2
    DiLoCoMessageFetchLease: int32 = 3
    DiLoCoMessageReportInnerStepDone: int32 = 4
    DiLoCoMessageSubmitOuterDelta: int32 = 5
    DiLoCoMessageFetchStepStatus: int32 = 6
    DiLoCoMessagePublishMergeCommit: int32 = 7
    DiLoCoMessageFetchGlobalVersion: int32 = 8
    DiLoCoMessageFetchLineage: int32 = 9

type
    DiLoCoEnvelope =
        version: int32 = 1
        kind: int32
        ok: bool = true
        errorText: str
        body: Bytes

    DiLoCoOpenJobRequest =
        jobBundleCid: layout.FixedBytes32
        requestedWorkerCount: int32
        innerStepBudget: int32
        outerStepTimeoutSeconds: int32
        initialModelRef: core.DiLoCoArtifactRef
        initialOptimizerRef: core.DiLoCoArtifactRef

    DiLoCoOpenJobResponse =
        job: core.DiLoCoJob
        version: core.DiLoCoGlobalVersion

    DiLoCoJoinCohortRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.Libp2pPeerId

    DiLoCoJoinCohortResponse =
        cohort: core.DiLoCoCohort

    DiLoCoFetchLeaseRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.Libp2pPeerId

    DiLoCoFetchLeaseResponse =
        lease: core.DiLoCoLease

    DiLoCoReportInnerStepDoneRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.Libp2pPeerId

    DiLoCoReportInnerStepDoneResponse =
        barrier: core.DiLoCoBarrier

    DiLoCoSubmitOuterDeltaRequest =
        jobBundleCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        publisherPeerId: types.Libp2pPeerId
        modelDeltaRef: core.DiLoCoArtifactRef
        optimizerDeltaRef: core.DiLoCoArtifactRef
        sampleCount: int32
        tokenCount: int32
        innerStepCount: int32
        weightNumerator: int32
        weightDenominator: int32

    DiLoCoSubmitOuterDeltaResponse =
        delta: core.DiLoCoOuterDelta

    DiLoCoFetchStepStatusRequest =
        jobBundleCid: layout.FixedBytes32

    DiLoCoFetchStepStatusResponse =
        status: core.DiLoCoStepStatus

    DiLoCoPublishMergeCommitRequest =
        jobBundleCid: layout.FixedBytes32
        publisherPeerId: types.Libp2pPeerId
        mergedModelRef: core.DiLoCoArtifactRef
        mergedOptimizerRef: core.DiLoCoArtifactRef

    DiLoCoPublishMergeCommitResponse =
        commit: core.DiLoCoMergeCommit
        version: core.DiLoCoGlobalVersion

    DiLoCoFetchGlobalVersionRequest =
        jobBundleCid: layout.FixedBytes32

    DiLoCoFetchGlobalVersionResponse =
        version: core.DiLoCoGlobalVersion

    DiLoCoFetchLineageRequest =
        jobBundleCid: layout.FixedBytes32

    DiLoCoFetchLineageResponse =
        versions: core.DiLoCoGlobalVersion[]

fn DiLoCoWireKnownKind(kind: int32): bool =
    return kind == DiLoCoMessageOpenJob ||
           kind == DiLoCoMessageJoinCohort ||
           kind == DiLoCoMessageFetchLease ||
           kind == DiLoCoMessageReportInnerStepDone ||
           kind == DiLoCoMessageSubmitOuterDelta ||
           kind == DiLoCoMessageFetchStepStatus ||
           kind == DiLoCoMessagePublishMergeCommit ||
           kind == DiLoCoMessageFetchGlobalVersion ||
           kind == DiLoCoMessageFetchLineage

fn DiLoCoWireAppendU32(buf: var layout.ByteBuf, value: int32) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn DiLoCoWireAppendI64(buf: var layout.ByteBuf, value: int64) =
    DiLoCoWireAppendU32(buf, int32((value >> 32) & int64(0xffffffff)))
    DiLoCoWireAppendU32(buf, int32(value & int64(0xffffffff)))

fn DiLoCoWireReadU32(span: layout.ByteSpan, offset: int32): Result[int32] =
    if offset < 0 || offset + 4 > layout.ByteSpanLen(span):
        return Err[int32](" diloco wire: short u32")
    let b0 = layout.ByteSpanAt(span, offset)
    let b1 = layout.ByteSpanAt(span, offset + 1)
    let b2 = layout.ByteSpanAt(span, offset + 2)
    let b3 = layout.ByteSpanAt(span, offset + 3)
    return Ok[int32]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn DiLoCoWireReadI64(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = DiLoCoWireReadU32(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = DiLoCoWireReadU32(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    return Ok[int64]((int64(Value(hiRes)) << 32) | (int64(Value(loRes)) & int64(0xffffffff)))

fn DiLoCoWireField(prefix: str, name: str): str =
    if len(prefix) <= 0:
        return name
    return strutil.Join([prefix, "_", name], "")

fn DiLoCoWireAppendLine(out: str, key: str, value: str): str =
    return strutil.Join([out, key, "=", value, "\n"], "")

fn DiLoCoWireBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn DiLoCoWireParseInt64(text: str): Result[int64] =
    if len(text) <= 0:
        return Err[int64](" diloco wire: empty integer")
    var negative = false
    var start = 0
    if text[0] == '-':
        negative = true
        start = 1
    if start >= len(text):
        return Err[int64](" diloco wire: invalid integer")
    var value: int64 = int64(0)
    for i in start..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64](" diloco wire: invalid integer")
        value = value * int64(10) + int64(ch - '0')
    if negative:
        value = -value
    return Ok[int64](value)

fn DiLoCoWireFindValue(wire: str, key: str): Result[str] =
    let prefix = strutil.Join([key, "="], "")
    var lineStart = 0
    while lineStart < len(wire):
        var lineEnd = lineStart
        while lineEnd < len(wire) && wire[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        if lineEnd - lineStart >= len(prefix):
            var matched = true
            for i in 0..<len(prefix):
                if wire[lineStart + i] != prefix[i]:
                    matched = false
                    break
            if matched:
                return Ok[str](strings.SliceBytes(wire,
                                                  lineStart + len(prefix),
                                                  lineEnd - lineStart - len(prefix)))
        lineStart = lineEnd + 1
    return Err[str](strutil.Join([" diloco wire: missing key ", key], ""))

fn DiLoCoWireRequireInt32(wire: str, key: str): Result[int32] =
    let valueRes = DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[int32](Error(valueRes))
    let parsedRes = DiLoCoWireParseInt64(Value(valueRes))
    if IsErr(parsedRes):
        return Err[int32](Error(parsedRes))
    return Ok[int32](int32(Value(parsedRes)))

fn DiLoCoWireRequireI64(wire: str, key: str): Result[int64] =
    let valueRes = DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[int64](Error(valueRes))
    return DiLoCoWireParseInt64(Value(valueRes))

fn DiLoCoWireRequireBool(wire: str, key: str): Result[bool] =
    let valueRes = DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[bool](Error(valueRes))
    if Value(valueRes) == "1":
        return Ok[bool](true)
    if Value(valueRes) == "0":
        return Ok[bool](false)
    return Err[bool](" diloco wire: invalid bool")

fn DiLoCoWireRequireFixed32(wire: str, key: str): Result[layout.FixedBytes32] =
    let valueRes = DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[layout.FixedBytes32](Error(valueRes))
    return layout.FixedBytes32FromHex(Value(valueRes))

fn DiLoCoWireRequirePeerId(wire: str, key: str): Result[types.Libp2pPeerId] =
    let valueRes = DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[types.Libp2pPeerId](Error(valueRes))
    var out: types.Libp2pPeerId
    let fillRes = peer_id.Libp2pPeerIdFillFromText(out, Value(valueRes))
    if IsErr(fillRes):
        return Err[types.Libp2pPeerId](Error(fillRes))
    return Ok[types.Libp2pPeerId](out)

fn DiLoCoEnvelopeEncode(envelope: DiLoCoEnvelope): Bytes =
    let errorBytes = bytesFromString(envelope.errorText)
    let bodyBytes = envelope.body
    var buf = layout.ByteBufInit(32 + bytesLen(errorBytes) + bytesLen(bodyBytes))
    DiLoCoWireAppendU32(buf, DiLoCoWireMagic)
    DiLoCoWireAppendU32(buf, envelope.version)
    DiLoCoWireAppendU32(buf, envelope.kind)
    DiLoCoWireAppendU32(buf, int32(envelope.ok))
    DiLoCoWireAppendU32(buf, bytesLen(errorBytes))
    DiLoCoWireAppendU32(buf, bytesLen(bodyBytes))
    layout.ByteBufAppendBytes(buf, errorBytes)
    layout.ByteBufAppendBytes(buf, bodyBytes)
    return layout.ByteBufToBytes(buf)

fn DiLoCoEnvelopeDecodeFill(out: var DiLoCoEnvelope, payload: Bytes): Result[bool] =
    var span = layout.ByteSpanFromBytes(payload)
    let magicRes = DiLoCoWireReadU32(span, 0)
    if IsErr(magicRes):
        return Err[bool](Error(magicRes))
    if Value(magicRes) != DiLoCoWireMagic:
        return Err[bool](" diloco wire: envelope magic")
    let versionRes = DiLoCoWireReadU32(span, 4)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    if Value(versionRes) != DiLoCoWireVersion:
        return Err[bool](" diloco wire: envelope version")
    let kindRes = DiLoCoWireReadU32(span, 8)
    if IsErr(kindRes):
        return Err[bool](Error(kindRes))
    if !DiLoCoWireKnownKind(Value(kindRes)):
        return Err[bool](" diloco wire: envelope kind")
    let okRes = DiLoCoWireReadU32(span, 12)
    if IsErr(okRes):
        return Err[bool](Error(okRes))
    let errorLenRes = DiLoCoWireReadU32(span, 16)
    if IsErr(errorLenRes):
        return Err[bool](Error(errorLenRes))
    let bodyLenRes = DiLoCoWireReadU32(span, 20)
    if IsErr(bodyLenRes):
        return Err[bool](Error(bodyLenRes))
    let errorLen = Value(errorLenRes)
    let bodyLen = Value(bodyLenRes)
    if errorLen < 0 || bodyLen < 0:
        return Err[bool](" diloco wire: envelope lengths")
    let total = 24 + errorLen + bodyLen
    if total != bytesLen(payload):
        return Err[bool](" diloco wire: envelope shape")
    out = DiLoCoEnvelope()
    out.version = Value(versionRes)
    out.kind = Value(kindRes)
    out.ok = Value(okRes) != 0
    out.errorText = bytesToString(layout.ByteSpanToBytes(layout.ByteSpanSlice(span, 24, errorLen)))
    out.body = layout.ByteSpanToBytes(layout.ByteSpanSlice(span, 24 + errorLen, bodyLen))
    return Ok[bool](true)

fn DiLoCoWireEncodeBodyEnvelope(kind: int32, bodyText: str): Bytes =
    var envelope = DiLoCoEnvelope()
    envelope.kind = kind
    envelope.ok = true
    envelope.body = bytesFromString(bodyText)
    return DiLoCoEnvelopeEncode(envelope)

fn DiLoCoWireEncodeErrorEnvelope(kind: int32, errorText: str): Bytes =
    var envelope = DiLoCoEnvelope()
    envelope.kind = kind
    envelope.ok = false
    envelope.errorText = errorText
    return DiLoCoEnvelopeEncode(envelope)

fn DiLoCoWireDecodeBodyText(payload: Bytes,
                              kind: int32,
                              out: var str): Result[bool] =
    var envelope = DiLoCoEnvelope()
    let decodeRes = DiLoCoEnvelopeDecodeFill(envelope, payload)
    if IsErr(decodeRes):
        return Err[bool](Error(decodeRes))
    if envelope.kind != kind:
        return Err[bool](" diloco wire: unexpected kind")
    if !envelope.ok:
        return Err[bool](envelope.errorText)
    out = bytesToString(envelope.body)
    return Ok[bool](true)

fn DiLoCoWireAppendArtifactRef(out: str,
                                 prefix: str,
                                 ref: core.DiLoCoArtifactRef): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "stub_cid"), layout.FixedBytes32Hex(ref.stubCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "blob_summary_cid"), layout.FixedBytes32Hex(ref.blobSummaryCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "manifest_cid"), layout.FixedBytes32Hex(ref.manifestCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "blob_cid"), layout.FixedBytes32Hex(ref.blobCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "payload_len"), IntToStr(ref.payloadLen))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "params_cid"), layout.FixedBytes32Hex(ref.paramsCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "layout_kind"), IntToStr(ref.layoutKind))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "data_shard_count"), IntToStr(ref.dataShardCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "parity_shard_count"), IntToStr(ref.parityShardCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "shard_payload_bytes"), IntToStr(ref.shardPayloadBytes))
    return next

fn DiLoCoWireParseArtifactRefFill(out: var core.DiLoCoArtifactRef,
                                    wire: str,
                                    prefix: str): Result[bool] =
    out = core.DiLoCoArtifactRef()
    let stubCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "stub_cid"))
    if IsErr(stubCidRes):
        return Err[bool](Error(stubCidRes))
    let blobSummaryCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "blob_summary_cid"))
    if IsErr(blobSummaryCidRes):
        return Err[bool](Error(blobSummaryCidRes))
    let manifestCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "manifest_cid"))
    if IsErr(manifestCidRes):
        return Err[bool](Error(manifestCidRes))
    let blobCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "blob_cid"))
    if IsErr(blobCidRes):
        return Err[bool](Error(blobCidRes))
    let payloadLenRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "payload_len"))
    if IsErr(payloadLenRes):
        return Err[bool](Error(payloadLenRes))
    let paramsCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "params_cid"))
    if IsErr(paramsCidRes):
        return Err[bool](Error(paramsCidRes))
    let layoutKindRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "layout_kind"))
    if IsErr(layoutKindRes):
        return Err[bool](Error(layoutKindRes))
    let dataShardCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "data_shard_count"))
    if IsErr(dataShardCountRes):
        return Err[bool](Error(dataShardCountRes))
    let parityShardCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "parity_shard_count"))
    if IsErr(parityShardCountRes):
        return Err[bool](Error(parityShardCountRes))
    let shardPayloadBytesRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "shard_payload_bytes"))
    if IsErr(shardPayloadBytesRes):
        return Err[bool](Error(shardPayloadBytesRes))
    out.stubCid = Value(stubCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.blobCid = Value(blobCidRes)
    out.payloadLen = Value(payloadLenRes)
    out.paramsCid = Value(paramsCidRes)
    out.layoutKind = Value(layoutKindRes)
    out.dataShardCount = Value(dataShardCountRes)
    out.parityShardCount = Value(parityShardCountRes)
    out.shardPayloadBytes = Value(shardPayloadBytesRes)
    return Ok[bool](true)

fn DiLoCoWireAppendPeerIdArray(out: str,
                                 prefix: str,
                                 peers: types.Libp2pPeerId[]): str =
    var next = DiLoCoWireAppendLine(out, DiLoCoWireField(prefix, "count"), IntToStr(peers.len))
    for i in 0..<peers.len:
        next = DiLoCoWireAppendLine(next,
                                        DiLoCoWireField(prefix, IntToStr(i)),
                                        peer_id.Libp2pPeerIdText(peers[i]))
    return next

fn DiLoCoWireParsePeerIdArrayFill(out: var types.Libp2pPeerId[],
                                    wire: str,
                                    prefix: str): Result[bool] =
    let countRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        let peerRes = DiLoCoWireRequirePeerId(wire, DiLoCoWireField(prefix, IntToStr(i)))
        if IsErr(peerRes):
            return Err[bool](Error(peerRes))
        add(out, Value(peerRes))
    return Ok[bool](true)

fn DiLoCoWireAppendFixed32Array(out: str,
                                  prefix: str,
                                  items: layout.FixedBytes32[]): str =
    var next = DiLoCoWireAppendLine(out, DiLoCoWireField(prefix, "count"), IntToStr(items.len))
    for i in 0..<items.len:
        next = DiLoCoWireAppendLine(next,
                                        DiLoCoWireField(prefix, IntToStr(i)),
                                        layout.FixedBytes32Hex(items[i]))
    return next

fn DiLoCoWireParseFixed32ArrayFill(out: var layout.FixedBytes32[],
                                     wire: str,
                                     prefix: str): Result[bool] =
    let countRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        let valueRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, IntToStr(i)))
        if IsErr(valueRes):
            return Err[bool](Error(valueRes))
        add(out, Value(valueRes))
    return Ok[bool](true)

fn DiLoCoWireAppendJob(out: str,
                         prefix: str,
                         job: core.DiLoCoJob): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(job.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "requested_worker_count"), IntToStr(job.requestedWorkerCount))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "inner_step_budget"), IntToStr(job.innerStepBudget))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "outer_step_timeout_seconds"), IntToStr(job.outerStepTimeoutSeconds))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "current_global_version_cid"), layout.FixedBytes32Hex(job.currentGlobalVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "current_outer_step"), IntToStr(job.currentOuterStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "sealed"), DiLoCoWireBoolText(job.sealed))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(job.cohortCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "opened_at_epoch_seconds"), IntToStr(int32(job.openedAtEpochSeconds)))
    return next

fn DiLoCoWireParseJobFill(out: var core.DiLoCoJob,
                            wire: str,
                            prefix: str): Result[bool] =
    out = core.DiLoCoJob()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let requestedWorkerCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "requested_worker_count"))
    if IsErr(requestedWorkerCountRes):
        return Err[bool](Error(requestedWorkerCountRes))
    let innerStepBudgetRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "inner_step_budget"))
    if IsErr(innerStepBudgetRes):
        return Err[bool](Error(innerStepBudgetRes))
    let timeoutRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "outer_step_timeout_seconds"))
    if IsErr(timeoutRes):
        return Err[bool](Error(timeoutRes))
    let currentVersionRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "current_global_version_cid"))
    if IsErr(currentVersionRes):
        return Err[bool](Error(currentVersionRes))
    let currentStepRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "current_outer_step"))
    if IsErr(currentStepRes):
        return Err[bool](Error(currentStepRes))
    let sealedRes = DiLoCoWireRequireBool(wire, DiLoCoWireField(prefix, "sealed"))
    if IsErr(sealedRes):
        return Err[bool](Error(sealedRes))
    let cohortCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "cohort_cid"))
    if IsErr(cohortCidRes):
        return Err[bool](Error(cohortCidRes))
    let openedAtRes = DiLoCoWireRequireI64(wire, DiLoCoWireField(prefix, "opened_at_epoch_seconds"))
    if IsErr(openedAtRes):
        return Err[bool](Error(openedAtRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.requestedWorkerCount = Value(requestedWorkerCountRes)
    out.innerStepBudget = Value(innerStepBudgetRes)
    out.outerStepTimeoutSeconds = Value(timeoutRes)
    out.currentGlobalVersionCid = Value(currentVersionRes)
    out.currentOuterStep = Value(currentStepRes)
    out.sealed = Value(sealedRes)
    out.cohortCid = Value(cohortCidRes)
    out.openedAtEpochSeconds = Value(openedAtRes)
    return Ok[bool](true)

fn DiLoCoWireAppendCohort(out: str,
                            prefix: str,
                            cohort: core.DiLoCoCohort): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(cohort.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(cohort.cohortCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "leader_peer_id"), peer_id.Libp2pPeerIdText(cohort.leaderPeerId))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "sealed_at_epoch_seconds"), IntToStr(int32(cohort.sealedAtEpochSeconds)))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "fixed_member_count"), IntToStr(cohort.fixedMemberCount))
    next = DiLoCoWireAppendPeerIdArray(next, DiLoCoWireField(prefix, "members"), cohort.members)
    return next

fn DiLoCoWireParseCohortFill(out: var core.DiLoCoCohort,
                               wire: str,
                               prefix: str): Result[bool] =
    out = core.DiLoCoCohort()
    let jobBundleCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let cohortCidRes = DiLoCoWireRequireFixed32(wire, DiLoCoWireField(prefix, "cohort_cid"))
    if IsErr(cohortCidRes):
        return Err[bool](Error(cohortCidRes))
    let leaderPeerIdRes = DiLoCoWireRequirePeerId(wire, DiLoCoWireField(prefix, "leader_peer_id"))
    if IsErr(leaderPeerIdRes):
        return Err[bool](Error(leaderPeerIdRes))
    let sealedAtRes = DiLoCoWireRequireI64(wire, DiLoCoWireField(prefix, "sealed_at_epoch_seconds"))
    if IsErr(sealedAtRes):
        return Err[bool](Error(sealedAtRes))
    let fixedCountRes = DiLoCoWireRequireInt32(wire, DiLoCoWireField(prefix, "fixed_member_count"))
    if IsErr(fixedCountRes):
        return Err[bool](Error(fixedCountRes))
    var members: types.Libp2pPeerId[]
    let membersRes = DiLoCoWireParsePeerIdArrayFill(members, wire, DiLoCoWireField(prefix, "members"))
    if IsErr(membersRes):
        return Err[bool](Error(membersRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.cohortCid = Value(cohortCidRes)
    out.leaderPeerId = Value(leaderPeerIdRes)
    out.members = members
    out.sealedAtEpochSeconds = Value(sealedAtRes)
    out.fixedMemberCount = Value(fixedCountRes)
    return Ok[bool](true)

fn DiLoCoWireAppendLease(out: str,
                           prefix: str,
                           lease: core.DiLoCoLease): str =
    var next = out
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(lease.jobBundleCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(lease.cohortCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "peer_id"), peer_id.Libp2pPeerIdText(lease.peerId))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(lease.baseVersionCid))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "outer_step"), IntToStr(lease.outerStep))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "inner_step_budget"), IntToStr(lease.innerStepBudget))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "leased_at_epoch_seconds"), IntToStr(int32(lease.leasedAtEpochSeconds)))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "expires_at_epoch_seconds"), IntToStr(int32(lease.expiresAtEpochSeconds)))
    next = DiLoCoWireAppendLine(next, DiLoCoWireField(prefix, "active"), DiLoCoWireBoolText(lease.active))
    return next

fn DiLoCoWireParseLeaseFill(out: var core.DiLoCoLease,
