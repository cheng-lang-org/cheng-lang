    return DiLoCoWireParseGlobalVersionArrayFill(out.versions, body, "versions")

fn DiLoCoFetchLineageResponseDecodeOkFill(out: var DiLoCoFetchLineageResponse,
                                            payload: Bytes): bool =
    let res = DiLoCoFetchLineageResponseDecodeFill(out, payload)
    return res.ok
